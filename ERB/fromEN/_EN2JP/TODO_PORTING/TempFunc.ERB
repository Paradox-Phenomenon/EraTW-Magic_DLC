			ENDSELECT
			CALL PRINT_RANK(ABL:C_ID:LOCAL, "MAX_99")
			PRINTFORM {ABL:C_ID:LOCAL, 4}|
		NEXT
	ENDIF
	PRINTFORML 

CASE 2 ;Technique
