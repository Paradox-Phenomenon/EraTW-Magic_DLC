@TEMP_SORT_LIST(SORT_TYPE, CHARA_LIST, CHARA_CNT)
#DIM      SORT_TYPE  ;ソート内容の指示
#DIM      MEMO_TYPE  ;今回のソート項目、CSVでの要素数
#DIMS     CHECK_VAR  ;チェック対象となる変数名
#DIMS     CHECK_TYPE ;比較演算子の種類
#DIM      NUM_LOOP   ;ループ回数
#DIM  REF CHARA_LIST ;キャラリストの内容配列
#DIM      CHARA_CNT  ;リストに含まれるキャラ数
;ソート項目の種別
{
#DIMS CONST DISP_MEMO = 
	"体力", "気力", 
	"Ｃ感", "Ｖ感", "Ａ感", "Ｂ感", "Ｍ感", 
	"親密", "従順", "欲望", "技巧", "奉仕精神", "露出癖",
	"指技", "舌技", "胸技", "腰技", "膣技", "Ａ技", "マゾ", "サド", "精液",
	"苦痛", "快楽", "不埒", "反発", "時姦", 
	"教養", "話術", "戦闘", "清掃", "料理", "音楽", "釣り", "採集", "調合",
	"好感", "信頼", "欲求", 
	"弾幕勝負勝利", "ムシバトル直接勝利", "料理勝負勝利"
}
;ソート項目の各キャラ変数における位置
{
#DIM CONST MEMO_ID = 
	 0,  1, 
	 0,  1,  2,  3,  4, 
	 9, 10, 11, 12, 13, 14,
	50, 51, 52, 53, 54, 55, 15, 16, 31,
	 0,  1,  2,  3,  5, 
	43, 41, 42, 40, 44, 45, 47, 48, 49,
	 2,  4,340,
   930,932,933
}
;ソート項目の検索
MEMO_TYPE = 0
NUM_LOOP = SortListSize
MEMO_TYPE = SORT_TYPE%SortListSize

SELECTCASE DISP_MEMO:MEMO_TYPE ;refer to CHARA_COMPARE for CHECK_VAR
CASE "体力", "気力"
	CHECK_VAR '= "BASE"
CASE "Ｃ感", "Ｖ感", "Ａ感", "Ｂ感", "Ｍ感", "親密", "従順", "欲望", "技巧", "奉仕精神", "露出癖"
	CHECK_VAR '= "ABL"
CASE "指技", "舌技", "胸技", "腰技", "膣技", "Ａ技", "マゾ", "サド", "精液"
	CHECK_VAR '= "ABL"
CASE "苦痛", "快楽", "不埒", "反発", "時姦",
	CHECK_VAR '= "MARK"
CASE "教養", "話術", "戦闘", "清掃", "料理", "音楽",
	CHECK_VAR '= "ABL"
CASE "釣り", "採集", "調合",
	CHECK_VAR '= "TALENT"
CASE "好感", "信頼", "欲求"
	CHECK_VAR '= "CFLAG"
CASE "弾幕勝負勝利", "ムシバトル直接勝利", "料理勝負勝利"
	CHECK_VAR '= "CFLAG"
CASEELSE
	THROW 不正なDISP_MEMO:MEMO_TYPE %DISP_MEMO:MEMO_TYPE%、MEMO_TYPE {MEMO_TYPE}
ENDSELECT

IF SORT_TYPE < 1050
	CHECK_TYPE '= ">="
ELSEIF SORT_TYPE >= 1050
	CHECK_TYPE '= "<="
ENDIF

;ソート実処理
LOCAL:0 = 1
WHILE LOCAL:0 < CHARA_CNT
	SIF !(LOCAL:0)
		LOCAL:0 ++
	IF CHARA_COMPARE(CHECK_VAR, MEMO_ID:MEMO_TYPE, CHARA_LIST:(LOCAL:0 - 1), CHECK_TYPE, CHARA_LIST:(LOCAL:0))
		LOCAL:0 ++
	ELSE
		SWAP CHARA_LIST:(LOCAL:0 - 1), CHARA_LIST:(LOCAL:0)
		LOCAL:0 --
	ENDIF
WEND


;###############################################
;SORT_TYPE, <41 descending, >41 ascending
;BUTTON, which button it is, corresponds with DISP_MEMO
;starting value of a first button with modulo % should be equal to 0! update all button values accordingly afterward!
;main thing is the total amount of items in DISP_MEMO (aka headers for sorting, must be the same everywhere)
;you'll need to change the button modulo with it (%41) (41 is the amount of items), then see which nearest value of 1000%41 produces 0, that'll be the starting value of a button
;next you update the button result code where it's handled (min-max range)
@TEMP_MAKE_SORT_BUTTON(SORT_TYPE, BUTTON)
#DIM SORT_TYPE ;現在のソートタイプ
#DIM BUTTON    ;基本のボタン名
#DIM StartingValue
{
#DIMS CONST DISP_MEMO = 
	"体力", "気力",
	"Ｃ感", "Ｖ感", "Ａ感", "Ｂ感", "Ｍ感",
	"親密", "従順", "欲望", "技巧", "奉仕精神", "露出癖",
	"指技", "舌技", "胸技", "腰技", "膣技", "Ａ技", "マゾ", "サド", "精液",
	"苦痛", "快楽", "不埒", "反発", "時姦",
	"教養", "話術", "戦闘", "清掃", "料理", "音楽", "釣り", "採集", "調合",
	"好感", "信頼", "欲求",
	"弾幕", "ムシバトル", "料理"
}
;auto sort
SortListSize = VARSIZE("DISP_MEMO")
FOR LOCAL, 1000, 9999
	IF LOCAL%SortListSize == 0
		StartingValue = LOCAL
		BREAK
	ENDIF
NEXT

IF SORT_TYPE%SortListSize != BUTTON
	;LOCAL = 1032+BUTTON+24	;PRINT
	;BUTTON @"{LOCAL}", LOCAL
	PRINTBUTTON @"　%DISP_MEMO:BUTTON%", StartingValue+BUTTON
ELSEIF SORT_TYPE < StartingValue+SortListSize ;this is the sum of <button value> + total amount of items in DISP_MEMO
	PRINTBUTTON @"▼%DISP_MEMO:BUTTON%", StartingValue+BUTTON+SortListSize
ELSEIF SORT_TYPE >= StartingValue+SortListSize
	PRINTBUTTON @"▲%DISP_MEMO:BUTTON%", StartingValue+BUTTON
ENDIF

