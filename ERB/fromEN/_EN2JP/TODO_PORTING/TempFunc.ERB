		;IF DIALOGSTATUS:C_ID:0 == -1 || C_ID == MASTER
			;PRINTFORM %" ",10%|
		;ELSE
			;PRINTFORM {DIALOGSTATUS:C_ID:(CFLAG:C_ID:口上セレクタ), 8}％|
		;ENDIF

		;恋慕
		;IF TALENT:C_ID:妻
			;SETCOLOR C_RED
			;表示文 '= PRINT_MALE("Husband", C_ID)
		;ELSEIF TALENT:C_ID:妾
			;SETCOLOR C_RED
			;表示文 = Concubine
