				;C_ID = RESULT
			;ENDIF
		;ENDIF
		;BREAK
	CASE 9999
		qol_Relation_AscendingOrder = !qol_Relation_AscendingOrder
	CASE 3500 TO 3505
		SFSR_PAGE = RESULT-3500
	CASEELSE
		$RETRY
