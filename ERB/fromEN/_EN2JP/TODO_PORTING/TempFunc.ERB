		FOR LOCAL, 36, 38
			CALL TEMP_MAKE_SORT_BUTTON(SORT_TYPE, LOCAL)
			PRINT |
			SELECTCASE LOCAL
				CASE 36
					PRINTFORM     
				CASE 37
