@TEMP_SHOW_CHARA_LIST(LIST_TYPE = "存在するキャラリスト", DISP_TYPE_STR = "体力気力", OP)
#DIMS LIST_TYPE                     ;リストの種別
#DIMS DISP_TYPE_STR                 ;Ensures it can still be called like normal
#DIM  DISP_TYPE                      ;Handle the type as int, rather than string
#DIMS OP                            ;機能オプション
#DIM  GET_LIST = 1                  ;リスト更新フラグ
#DIM  L_ID                          ;リスト上の番号（ループカウンタ）、登録番号にあらず
#DIM  L_CLASS_ID                    ;リストのクラス内ID
#DIM  CHARA_LIST , キャラクタ数上限 ;リスト本体、登録番号にて記録
#DIM  CHARA_CNT                     ;リストに該当したキャラの数
#DIMS INPUT_STR                     ;入力内容の一時保持
#DIM  INPUT_INT                     ;入力内容をINT化したモノ
#DIM  NOW_GROUP = 1                 ;表示中のキャラグループ
#DIM  LAST_GROUP                    ;キャラグループ総数
#DIM  SORT_TYPE                     ;キャラリストのソートタイプ
;表示タイプの名称
{
#DIMS CONST DISP_NAME = 
	"体力気力", "感度など", "性技", "刻印", "技能", "好感度", "勝負"
}
{
#DIMS CONST DISP_MEMO = 
	"体力", "気力",
	"Ｃ感", "Ｖ感", "Ａ感", "Ｂ感", "Ｍ感",
	"親密", "従順", "欲望", "技巧", "奉仕精神", "露出癖",
	"指技", "舌技", "胸技", "腰技", "膣技", "Ａ技", "マゾ", "サド", "精液",
	"苦痛", "快楽", "不埒", "反発", "時姦",
	"教養", "話術", "戦闘", "清掃", "料理", "音楽", "釣り", "採集", "調合",
	"好感", "信頼", "欲求",
	"弾幕", "ムシバトル", "料理"
}
#DIM CREDRAW
#DIM FIRST_LINE

;情報表示用
SELECTCASE DISP_TYPE_STR
	CASE "体力気力"
		DISP_TYPE = 0
	CASE "感度など"
		DISP_TYPE = 1
	CASE "性技"
		DISP_TYPE = 2
	CASE "刻印"
		DISP_TYPE = 3
	CASE "好感度"
		DISP_TYPE = 4
ENDSELECT

FIRST_LINE = LINECOUNT
$REPRINT
CLEARLINE LINECOUNT - FIRST_LINE
CREDRAW = CURRENTREDRAW()
REDRAW 0

;LIST_TYPE_TR '= LISTING_TR(LIST_TYPE)

IF GET_LIST || ResetList
	CALL MAKE_CHARA_LIST(LIST_TYPE, L_CLASS_ID, CHARA_LIST, CHARA_CNT)
	GET_LIST = 0
	SORT_TYPE = -1
	ResetList = 0
ENDIF
DRAWLINE

;項目なし
IF CHARA_CNT <= 0
	PRINTFORML ＜該当なし＞　%LIST_TYPE%
	PRINTFORML 
	DRAWLINE
	FOR LOCAL, 0, 40
		PRINTL
	NEXT
;項目あり
ELSE
	;現在のタイプの総グループ数を更新
	LAST_GROUP = 1 + (CHARA_CNT - 1) / 40
	PRINTFORML （該当{CHARA_CNT}名　{NOW_GROUP}/{LAST_GROUP}）　%LIST_TYPE%　　色付きのキャラは口上あり
	PRINTFORM 
	CALL TEMP_CHARA_BUTTON(-1, , DISP_TYPE, SORT_TYPE)
	DRAWLINE
	FOR L_ID, (NOW_GROUP - 1) * 40, NOW_GROUP * 40
		IF INRANGE(L_ID, 0, CHARA_CNT - 1)
			CALL TEMP_CHARA_BUTTON(L_ID, CHARA_LIST:L_ID, DISP_TYPE, SORT_TYPE)
		ELSE
			PRINTL
		ENDIF
	NEXT
ENDIF
DRAWLINE


IF STRCOUNT(OP, "「情報固定」")
	PRINTFORM %" "*20%
ELSE
	PRINTBUTTON @"<- %DISP_NAME:((DISP_TYPE - 1 + VARSIZE("DISP_NAME")) % VARSIZE("DISP_NAME")), 16, LEFT%", 444
ENDIF

;modded to have infinite scroll
IF LAST_GROUP == 1
	SETCOLOR 0x606060
	PRINTFORM %"前のキャラ",15,LEFT%
	RESETCOLOR 
ELSE
	PRINTBUTTON @"%"前のキャラ",15,LEFT%", 888
ENDIF
PRINTFORM 
IF LAST_GROUP == 1
	SETCOLOR 0x606060
	PRINTFORM %"次のキャラ",15,LEFT%
	RESETCOLOR 
ELSE
	PRINTBUTTON @"%"次のキャラ",15,LEFT%", 222
ENDIF
IF STRCOUNT(OP, "「情報固定」")
	PRINTFORM 　　　　　　　　　　　
ELSE
	PRINTBUTTON @"%DISP_NAME:((DISP_TYPE + 1 + VARSIZE("DISP_NAME")) % VARSIZE("DISP_NAME")), 20, LEFT% →", 666
ENDIF
PRINTFORML 

PRINTFORML 
PRINTBUTTON "[999] もどる　", 999
PRINTFORM                
SIF STRCOUNT(OP, "「条件変更」")
	PRINTBUTTON "[500] 条件変更", 555
IF FLAG:画像表示
	PRINTFORM %" "*15%
	PRINTBUTTON "[777] 人物名簿", 777
ENDIF
PRINTFORML 


INPUT
SELECTCASE RESULT
	;先にシステム系を処理、222なら余裕あるっしょ（Kでは使えんわな）
	CASE 222, 888
		SIF LAST_GROUP == 1
			GOTO REPRINT
		NOW_GROUP = PAGE_HANDLE(RESULT, 888, NOW_GROUP, 1, LAST_GROUP)
		GOTO REPRINT
	CASE 444
		SIF STRCOUNT(OP, "「情報固定」")
			GOTO RETRY
		DISP_TYPE = (DISP_TYPE - 1 + VARSIZE("DISP_NAME")) % VARSIZE("DISP_NAME")
		GOTO REPRINT
	CASE 555
		SIF !STRCOUNT(OP, "「条件変更」")
			GOTO RETRY
		CALL TEMP_CHANGE_LIST(LIST_TYPE, OP)
		GET_LIST = 1
		NOW_GROUP = 1
		GOTO REPRINT
	CASE 666
		SIF STRCOUNT(OP, "「情報固定」")
			GOTO RETRY
		DISP_TYPE = (DISP_TYPE + 1 + VARSIZE("DISP_NAME")) % VARSIZE("DISP_NAME")
		GOTO REPRINT
	CASE 999
		;REFで配列作れば多キャラ選択も行けそう
		;受け渡しはともかくとして表示まわりがめんどいか
		GET_LIST = 1
		NOW_GROUP = 1
		RETURN 999
	CASE 1008 TO 1091 ;the max range after TO is DISP_MEMO-1*2?
		SORT_TYPE = RESULT
		CALL TEMP_SORT_LIST(RESULT, CHARA_LIST, CHARA_CNT)
		GOTO REPRINT
	CASE 777
		SIF !FLAG:画像表示
			GOTO REPRINT
		CALL TEMP_FULL_ROSTER
		GOTO REPRINT
	CASEELSE
	;キャラが選択された時
		IF !INRANGE(RESULT, MAX(0, (NOW_GROUP - 1) * 40), MIN(CHARA_CNT - 1, NOW_GROUP * 40))
			PRINTFORMW {RESULT} 範囲外
			GOTO REPRINT
		ELSEIF L_CLASS_ID == -1 && !CHECK_CHARA(CHARA_LIST:RESULT, LIST_TYPE)
			PRINTFORMW {RESULT} リストじゃない
			GOTO REPRINT
		ELSEIF L_CLASS_ID > 0 && !GET_INT(CHARA_LIST:RESULT, "キャラリスト", L_CLASS_ID, "判定")
			PRINTFORMW {RESULT} リストに弾かれる
			GOTO REPRINT
		ENDIF
		;ここだけDO-LOOPぬけます
ENDSELECT
$RETRY

IF STRCOUNT(OP, "「情報表示」")
	CALL TEMP_LIST_CHARA_STATE(CHARA_LIST, RESULT, CHARA_CNT, OP)
	SIF !RESULT
		GOTO REPRINT
	NOW_GROUP = 1
	GET_LIST = 1
	;一応RESULTが正になるのは「最終確認」のみだが念のために判定
	SIF STRCOUNT(OP, "「最終確認」")
		RETURN RESULT
ELSE
	NOW_GROUP = 1
	GET_LIST = 1
	RETURN CHARA_LIST:RESULT
ENDIF


