			CASE 3
				PRINTFORMDW %CALLNAME:(LOCAL:1)%は一度の産卵で複数の卵を産みます。
				TALENT:(LOCAL:1):PregnancyType = 3
			CASE 4
		CASEELSE
			GOTO LOOP2
		ENDSELECT
		GOTO MANUALSETTING
	CASE 11
		IF FLAG:CHILD_SUPPORT_RELIEF
			PRINTFORMDW 多産キャラは満額の養育費が必要です。
		ELSE
			PRINTFORMDW 多産キャラの一人頭養育費が1/3になります。
		ENDIF
		FLAG:CHILD_SUPPORT_RELIEF = !FLAG:CHILD_SUPPORT_RELIEF
	CASE 12
		IF FLAG:MOB_PREGNANCY_TYPES
			PRINTFORMDW 新規作成されたモブキャラはすべて通常妊娠です
		ELSE
			PRINTFORMDW 新規作成されたモブキャラが種族に応じた妊娠タイプになります
		ENDIF
		FLAG:MOB_PREGNANCY_TYPES = !FLAG:MOB_PREGNANCY_TYPES
	CASE 13
		IF FLAG:EGGNANCY
			PRINTFORMDW 産卵キャラは有精卵を産みます。
		ELSE
			PRINTFORMDW 産卵キャラは抱卵します。
		ENDIF
		FLAG:EGGNANCY = !FLAG:EGGNANCY
	CASE 14
		PRINTFORMDL 確率を入れてください (0-100)
		$LOOP3
		INPUT
		LOCAL:3 = RESULT
		SIF !INRANGE(LOCAL:3,0,100)
			GOTO LOOP3
		FLAG:TWINS_CHANCE = LOCAL:3
	CASE 15
		PRINTFORMDL 確率を入れてください (0-100)
		$LOOP4
		INPUT
		LOCAL:3 = RESULT
		SIF !INRANGE(LOCAL:3,0,100)
			GOTO LOOP4
		FLAG:TRIPLETS_CHANCE = LOCAL:3
	CASE 16
		PRINTFORMDL
		CALL D_LINE
		PRINTFORMDL
		PRINTFORMDL 妊娠タイプを設定できます。
		PRINTFORMDL
		PRINTFORMDL 通常 - 基本的に一児を出産します。。双子、三つ子が生まれることもあります。
		PRINTFORMDL 多胎 - 一度に2～6子を出産します。
		PRINTFORMDL 産卵（単） - 受精後すぐに産卵し、ふ化まで世話をします。この間にも受精することがあります。
		PRINTFORMDL 産卵（複） - 一度に2～6個産卵します。
		PRINTFORMDL
		PRINTFORMDL 陥落後の産卵キャラはデート終了時に無精卵をくれることがあります。
		PRINTFORMDL
		PRINTFORMDL 懐卵オプションをオンにすると、卵生キャラはすぐには産卵せず体内に卵を保持し、外見的には妊娠と同じになります。
		PRINTFORMDL 産卵はふ化直前に行います。無精卵をくれるイベントはちゃんと発生します。
		PRINTFORMDL
