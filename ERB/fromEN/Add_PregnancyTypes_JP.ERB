@PREGNANCY_TYPE_OPTIONS
#DIMS DESCRIPTION
	;Pregnancy type settings menu, accessible through new game or modded options.
$TOP
PRINTFORMDL
CALL D_LINE
PRINTFORMDL
PRINTFORMDL [ 0] 全员正常妊娠
PRINTFORMDL [ 1] 全员多胎
PRINTFORMDL [ 2] 全员产卵（单）
PRINTFORMDL [ 3] 全员产卵（复）
PRINTFORMDL [ 4] 没有多胎
PRINTFORMDL [ 5] 没有产卵
PRINTFORMDL [ 6] 生产时，必定生多个
PRINTFORMDL [ 7] 产卵时，必定产单个
PRINTFORMDL [ 8] 产卵时，必定产多个
PRINTFORMDL [ 9] 全员默认
PRINTFORMDL
PRINTFORMDL [10] 手动设定
PRINTFORMDL
PRINTFORMDL [11] 多产角色育儿补贴: \@ FLAG:CHILD_SUPPORT_RELIEF ? ON # OFF \@
PRINTFORMDL [12] 路人角色特殊妊娠: \@ FLAG:MOB_PREGNANCY_TYPES ? ON # OFF \@
PRINTFORMDL [13] 胎内孵化选项: \@ FLAG:EGGNANCY ? ON # OFF \@
PRINTFORMDL [14] 双胞胎发生率: {FLAG:TWINS_CHANCE}\%
PRINTFORMDL [15] 三胞胎发生率: {FLAG:TRIPLETS_CHANCE}\%
PRINTFORMDL
PRINTFORMDL [16] 说明
PRINTFORMDL
PRINTFORMDL [17] 返回
$LOOP
INPUT
SELECTCASE RESULT
	CASE 0
		FOR LOCAL,1,CHARANUM
			SIF TALENT:LOCAL:PregnancyType != 4
				TALENT:LOCAL:PregnancyType = 0
		NEXT
		PRINTFORMDW 特殊妊娠全部无效了
	CASE 1
		FOR LOCAL,1,CHARANUM
			SIF TALENT:LOCAL:PregnancyType != 5
				TALENT:LOCAL:PregnancyType = 1
		NEXT
		PRINTFORMDW 全员都变成生多胞胎了
	CASE 2
		FOR LOCAL,1,CHARANUM
			SIF TALENT:LOCAL:PregnancyType != 3
				TALENT:LOCAL:PregnancyType = 2
		NEXT
		PRINTFORMDW 全员都变成产卵了
	CASE 3
		FOR LOCAL,1,CHARANUM
			SIF TALENT:LOCAL:PregnancyType != 2
				TALENT:LOCAL:PregnancyType = 3
		NEXT
		PRINTFORMDW 全员都变成产卵了
	CASE 4
		FOR LOCAL,1,CHARANUM
			SIF TALENT:LOCAL:PregnancyType == 1
				TALENT:LOCAL:PregnancyType = 0
			SIF TALENT:LOCAL:PregnancyType == 5
				TALENT:LOCAL:PregnancyType = 4
		NEXT
		PRINTFORMDW 多胞胎无效了
	CASE 5
		FOR LOCAL,1,CHARANUM
			SIF GROUPMATCH(TALENT:LOCAL:PregnancyType,2,3)
				TALENT:LOCAL:PregnancyType = 0
		NEXT
		PRINTFORMDW 产卵无效了
	CASE 6
		FOR LOCAL,1,CHARANUM
			SIF TALENT:LOCAL:PregnancyType == 0
				TALENT:LOCAL:PregnancyType = 1
			SIF TALENT:LOCAL:PregnancyType == 4
				TALENT:LOCAL:PregnancyType = 5
		NEXT
		PRINTFORMDW 不产卵的角色都变成必然多胎了
	CASE 7
		FOR LOCAL,1,CHARANUM
			SIF TALENT:LOCAL:PregnancyType == 3
				TALENT:LOCAL:PregnancyType = 2
		NEXT
		PRINTFORMDW 产卵的角色都变成只产一个卵了
	CASE 8
		FOR LOCAL,1,CHARANUM
			SIF TALENT:LOCAL:PregnancyType == 2
				TALENT:LOCAL:PregnancyType = 3
		NEXT
		PRINTFORMDW 产卵的角色都变成必然产多个卵了
	CASE 9
		FOR LOCAL,1,CHARANUM
			SIF TALENT:LOCAL:PregnancyType != 4
				TALENT:LOCAL:PregnancyType = 0
			CALLF CustomTraits_PregnancyType(LOCAL)
		NEXT
		PRINTFORMDW 全员都变成默认了
	CASE 10
		$MANUALSETTING
		PRINTFORMDL
		SIF FLAG:並び替え
			CALL CHARASORT_EX
		FOR LOCAL:2, 1, EX_CHARANUM + 1
			IF FLAG:並び替え
				LOCAL:1 = RESULT:(LOCAL:2)
				SIF LOCAL:1 < 0
					CONTINUE
			ELSE
				LOCAL:1 = LOCAL:2
				SIF LOCAL:1 >= CHARANUM
					BREAK
			ENDIF
			SIF CFLAG:(LOCAL:1):出禁
				CONTINUE
			PRINTFORMLC [{LOCAL:1, 3}] %CALLNAME:(LOCAL:1)%
			RESETCOLOR
		NEXT
		PRINTFORML 
		DRAWLINE
		PRINTFORML [999] 返回
		$LOOP1
		INPUT
		LOCAL:1 = RESULT
		SIF LOCAL:1 == 999
			GOTO TOP
		SIF !INRANGE(LOCAL:1,1,CHARANUM)
			GOTO LOOP1
		PRINTFORMDL
		SELECTCASE TALENT:(LOCAL:1):PregnancyType
			CASE 0,4
				DESCRIPTION = 通常状态
			CASE 1,5
				DESCRIPTION = 多胎状态
			CASE 2
				DESCRIPTION = 产卵（单）状态
			CASE 3
				DESCRIPTION = 产卵（复）状态
		ENDSELECT
		PRINTFORMDL %CALLNAME:(LOCAL:1)%的妊娠类型是%DESCRIPTION%
		PRINTFORMDL
		RESETCOLOR
		SIF GROUPMATCH(TALENT:(LOCAL:1):PregnancyType,0,4)
			SETCOLOR 50,50,50
		PRINTFORML [\@ GROUPMATCH(TALENT:(LOCAL:1):PregnancyType,0,4) ? X # 0 \@] 设为通常
		RESETCOLOR
		SIF GROUPMATCH(TALENT:(LOCAL:1):PregnancyType,1,5)
			SETCOLOR 50,50,50
		PRINTFORML [\@ GROUPMATCH(TALENT:(LOCAL:1):PregnancyType,1,5) ? X # 1 \@] 设为多胎
		RESETCOLOR
		SIF TALENT:(LOCAL:1):PregnancyType == 2
			SETCOLOR 50,50,50
		PRINTFORML [\@ TALENT:(LOCAL:1):PregnancyType == 2 ? X # 2 \@] 设为产卵（单）
		RESETCOLOR
		SIF TALENT:(LOCAL:1):PregnancyType == 3
			SETCOLOR 50,50,50
		PRINTFORML [\@ TALENT:(LOCAL:1):PregnancyType == 3 ? X # 3 \@] 设为产卵（复）
		RESETCOLOR
		PRINTFORMDL
		PRINTFORMDL [4] 决定
		$LOOP2
		INPUT
		SELECTCASE RESULT
			CASE 0
				PRINTFORMDW %CALLNAME:(LOCAL:1)%会进行正常的生产。可能会生双胞胎或三胞胎。
				IF TALENT:(LOCAL:1):PregnancyType == 5
					TALENT:(LOCAL:1):PregnancyType = 4
				ELSE
					TALENT:(LOCAL:1):PregnancyType = 0
				ENDIF
			CASE 1
				PRINTFORMDW %CALLNAME:(LOCAL:1)%生产必然会生多胞胎。
				IF TALENT:(LOCAL:1):PregnancyType == 4
					TALENT:(LOCAL:1):PregnancyType = 5
				ELSE
					TALENT:(LOCAL:1):PregnancyType = 1
				ENDIF
			CASE 2
				PRINTFORMDW %CALLNAME:(LOCAL:1)%会产卵。
				TALENT:(LOCAL:1):PregnancyType = 2
			CASE 3
				PRINTFORMDW %CALLNAME:(LOCAL:1)%一次会产多个卵。
				TALENT:(LOCAL:1):PregnancyType = 3
			CASE 4
		CASEELSE
			GOTO LOOP2
		ENDSELECT
		GOTO MANUALSETTING
	CASE 11
		IF FLAG:CHILD_SUPPORT_RELIEF
			PRINTFORMDW 需要支付多产角色的全额抚养费。
		ELSE
			PRINTFORMDW 多产角色每个孩子抚养费为1/3。
		ENDIF
		FLAG:CHILD_SUPPORT_RELIEF = !FLAG:CHILD_SUPPORT_RELIEF
	CASE 12
		IF FLAG:MOB_PREGNANCY_TYPES
			PRINTFORMDW 新创建的路人角色全部为正常妊娠
		ELSE
			PRINTFORMDW 新创建的路人角色会根据种族决定妊娠类型
		ENDIF
		FLAG:MOB_PREGNANCY_TYPES = !FLAG:MOB_PREGNANCY_TYPES
	CASE 13
		IF FLAG:EGGNANCY
			PRINTFORMDW 产卵角色会产下受精卵。
		ELSE
			PRINTFORMDW 产卵角色会在腹中孵育。
		ENDIF
		FLAG:EGGNANCY = !FLAG:EGGNANCY
	CASE 14
		PRINTFORMDL 请输入概率 (0-100)
		$LOOP3
		INPUT
		LOCAL:3 = RESULT
		SIF !INRANGE(LOCAL:3,0,100)
			GOTO LOOP3
		FLAG:TWINS_CHANCE = LOCAL:3
	CASE 15
		PRINTFORMDL 请输入概率 (0-100)
		$LOOP4
		INPUT
		LOCAL:3 = RESULT
		SIF !INRANGE(LOCAL:3,0,100)
			GOTO LOOP4
		FLAG:TRIPLETS_CHANCE = LOCAL:3
	CASE 16
		PRINTFORMDL
		CALL D_LINE
		PRINTFORMDL
		PRINTFORMDL 可以设置妊娠类型。
		PRINTFORMDL
		SETCOLOR C_RED
		PRINTFORML 注意：目前本系统多胎妊娠有显著bug，因此目前对于多胎的调整均无法生效，其余调整可行
		PRINTFORML 目前不自动开启预设怀孕模式，不进行调整时全员应用原版正常妊娠，若想体验卵生请手动点击“全员默认”选项
		RESETCOLOR
		PRINTFORMDL 通常 - 基本上生一个孩子。也可能生双胞胎或三胞胎。
		PRINTFORMDL 多胎 - 一次生2～6个孩子。
		PRINTFORMDL 产卵（单） - 受精后立即产卵，并照顾到孵化。在此期间也可能再次受精。
		PRINTFORMDL 产卵（复） - 一次产2～6个卵。
		PRINTFORMDL
		PRINTFORMDL 陷落后的产卵角色可能会在约会结束后给你少女的未受精卵。
		PRINTFORMDL
		PRINTFORMDL 开启胎内孵化选项后，卵生角色不会立即产卵，而是在体内孵化，外观和行为上与普通妊娠相同。
		PRINTFORMDL 产卵会在孵化前进行。给你少女之卵的事件也会正常发生。
		PRINTFORMDL
		PRINTFORMDL 启用育儿补贴后，多产角色的抚养费将从通常的¥1000变为每人¥330。
		PRINTFORMDL 平均来说，总额大致相同。
		PRINTFORMDL
		PRINTFORMDW 请注意，更改正在妊娠/胎内孵化中的角色的设置可能会导致问题。
	CASE 17
		RETURN
	CASEELSE
		GOTO LOOP
ENDSELECT
GOTO TOP

