		RESETCOLOR
		SIF GROUPMATCH(TALENT:(LOCAL:1):PregnancyType,1,5)
			SETCOLOR 50,50,50
		PRINTFORML [\@ GROUPMATCH(TALENT:(LOCAL:1):PregnancyType,1,5) ? X # 1 \@] 多胎にする
		RESETCOLOR
		SIF TALENT:(LOCAL:1):PregnancyType == 2
			SETCOLOR 50,50,50
