@CONCEPTION_COUNT(Character,ConceptionCount)
	;Determine how many children should be conceived from a single impregnation.
#FUNCTION
#DIM DYNAMIC Character
#DIM DYNAMIC ConceptionCount
SELECTCASE TALENT:Character:PregnancyType
	CASE 1,5
			;Has Litters.
		CFLAG:Character:妊娠経過日数 = MAX(CFLAG:Character:妊娠経過日数,1)
			;Usually has 3-4, with a small chance to have up to 6 or down to 2.
		ConceptionCount += RAND:2+3
		IF !RAND:10
			ConceptionCount += RAND:2+1
		ELSEIF !RAND:10
			ConceptionCount -= 1
		ENDIF
	CASE 2
			;Egg Layer.
		IF FLAG:EGGNANCY
			;Eggnancies are treated as regular pregnancies to work with existing functions, might cause funkiness if the setting is changed midway.
			CFLAG:Character:妊娠経過日数 = MAX(CFLAG:Character:妊娠経過日数,1)
		ELSE
			TALENT:Character:Nesting = MAX(TALENT:Character:Nesting,1)
		ENDIF
		ConceptionCount++
	CASE 3
			;Clutch Layer.
		IF FLAG:EGGNANCY
			CFLAG:Character:妊娠経過日数 = MAX(CFLAG:Character:妊娠経過日数,1)
		ELSE
			TALENT:Character:Nesting = MAX(TALENT:Character:Nesting,1)
		ENDIF
		ConceptionCount += RAND:2+3
		IF !RAND:10
			ConceptionCount += RAND:2+1
		ELSEIF !RAND:10
			ConceptionCount -= 1
		ENDIF
	CASEELSE
			;Normal.
		CFLAG:Character:妊娠経過日数 = MAX(CFLAG:Character:妊娠経過日数,1)
		ConceptionCount++
		IF RAND:100+1 <= FLAG:TRIPLETS_CHANCE
			ConceptionCount += 2
		ELSEIF RAND:100+1 <= FLAG:TWINS_CHANCE
			ConceptionCount++
		ENDIF
ENDSELECT
CFLAG:Character:WithChildCount += MIN(ConceptionCount,MAXCHILD)
;RETURNF ConceptionCount
RETURNF 1

@NESTING_MESSAGE
	;Display descriptions of fertilized eggs in the rooms of nesting girls.
	;受精卵を育てる時のメッセージ
#DIM DYNAMIC Children
#DIMS DYNAMIC eggs
FOR LOCAL,1,CHARANUM
		;Loop through all characters.
	IF CFLAG:LOCAL:初期位置 == CFLAG:MASTER:現在位置 && TALENT:LOCAL:Nesting
			;Find if the player is in their room and they're nesting.
		IF IS_HERE(LOCAL) && !FLAG:70 && !CFLAG:LOCAL:睡眠 && !CFLAG:LOCAL:うふふ && !TCVAR:LOCAL:泥酔 && !CFLAG:LOCAL:イタズラ && !CFLAG:LOCAL:添い寝中
				;If time isn't stopped and they're not asleep, having sex, drunk, being molested, or in bed with the player.
			Children = CFLAG:LOCAL:WithChildCount
			PRINTFORM %CALLNAME:LOCAL%は
			SELECTCASE RAND:2
				CASE 0
					PRINTFORML 卵の様子を見ている
				CASE 1
					PRINTDATAL
						DATAFORM 卵の上に乗って温めている
						DATAFORM 卵を温めている
						DATAFORM 卵を大事に抱えている
					ENDDATA
			ENDSELECT
		ELSEIF Children > 1
			PRINTFORMDL %CALLNAME:LOCAL%の{Children}個の卵が育っている
		ELSE
			PRINTFORMDL %CALLNAME:LOCAL%の卵が育っている
		ENDIF
	ENDIF
NEXT

@CHILD_SUPPORT_COST()
	;Loop through characters and calculate child support cost based on their pregnancy type.
	;養育費
#FUNCTION
#DIM DYNAMIC Cost
FOR LOCAL,1,CHARANUM
	IF GROUPMATCH(TALENT:LOCAL:PregnancyType,1,3,5) && FLAG:CHILD_SUPPORT_RELIEF
		Cost += CFLAG:LOCAL:育児人数 * 330 / (1 + (FLAG:甲斐性無 > 0))
	ELSE
		Cost += CFLAG:LOCAL:育児人数 * 1000 / (1 + (FLAG:甲斐性無 > 0))
	ENDIF
NEXT
RETURNF Cost

@EGG_GIFT_DATE_CHECK(CHARA)
	;Like GIFT_DATE_CHECK, but for eggs. Only called if no regular gift is given.
#FUNCTION
#DIM CHARA
#DIM 上限
#DIM 発生率
IF FESTIVAL() == ""
	上限 = 80
ELSE
	上限 = 100
ENDIF

SIF TALENT:CHARA:行きずり
	RETURNF 0
SIF DAY == CFLAG:CHARA:LatestEggGiftDay
		;No giving twice in one day.
	RETURNF 0
SIF MARK:CHARA:反発刻印 || TALENT:CHARA:機嫌 < 0 || CFLAG:CHARA:ブチギレ
	RETURNF 0
SIF BASE:CHARA:ムード < 1200
	RETURNF 0

	;Higher chance than regular gift.
発生率 = (ABL:CHARA:親密 - 4) * 6
発生率 += MIN(CFLAG:CHARA:好感度 / 10000, 10)
;----------------------------------------------------------------
SIF FESTIVAL() != ""
	TIMES 発生率, 1.5
SIF TALENT:CHARA:恋人
	TIMES 発生率, 1.5
SIF MIN(発生率, 上限) > RAND:100
	RETURNF 1
RETURNF 0

@EGG_GIFT_DATE_EVENT(CHARA)
	;Like GIFT_DATE_EVENT, but for eggs.
	;デート帰りに卵をくれる
#DIM CHARA
#DIM EGG
#DIM RELATIONSHIP

PRINTL 
SELECTCASE CFLAG:CHARA:性格傾向
CASE 1
	LOCALS = そわそわした様子でポケットから何かを取り出し、おずおずと差し出した…
CASE 2
	;PRINTFORM took a look at your face and then took out something as if remembering about it, handing it over without any hesitation...
	LOCALS = あなたの顔を見てから、何かを思い出したように取り出し、ためらうことなく差し出した…
CASE 3
	;PRINTFORM suddenly took out something and handed it over, saying it was meant for you...
	LOCALS = いきなり何かを取り出してプレゼントだと言って手渡してきた…
CASE 4
	;PRINTFORM took out a carton and politely presented it to you, saying that she had something she wanted you to have...
	LOCALS = 箱を取り出し、渡したいものがあると丁寧にそれを差し出した…
CASEELSE
	;PRINTFORM took out something and presented it to you, saying that you should have it...
	LOCALS = 何かを取り出して、受け取って欲しいと言いながら差し出してきた…
ENDSELECT
PRINTFORM 帰り道、%CALLNAME:CHARA%は%LOCALS%

CALL PRINT_BREAK
PRINTW 

	;Give as many eggs as have been built up since the last time, to a maximum of a dozen.
EGG = DAY-CFLAG:CHARA:LatestEggGiftDay
SIF TALENT:CHARA:PregnancyType == 3
		;Clutch layers give three times as many, but still have the same maximum.
	TIMES EGG, 3
EGG = MIN(EGG,12)
CFLAG:CHARA:LatestEggGiftDay = DAY

RELATIONSHIP = 3
IF TALENT:CHARA:恋慕
	RELATIONSHIP = 1
ELSEIF TALENT:CHARA:愛欲
	RELATIONSHIP = 2
ENDIF
CALL KOJO_MESSAGE_SEND("EVENT", 0, CHARA, RELATIONSHIP, EGG, "EGG_GIFT")
ITEM:少女の卵 += EGG
;PRINTFORMW Received \@ EGG > 1 ? %NUM_COUNT(EGG)% eggs # an egg \@ from %CALLNAME:CHARA%!
PRINTFORMW %CALLNAME:CHARA%から卵を\@ EGG > 1 ? {EGG}個 # \@貰った！

@CUSTOM_RESET_VAR_1(ARG)
	;Reset custom pregnancy variables when resetting characters.
	;カスタム妊娠関連変数のリセット
CFLAG:ARG:WithChildCount = 0
CFLAG:ARG:BirthEventsCount = 0
CFLAG:ARG:LatestChildCount = 0
TALENT:ARG:Nesting = 0
FOR LOCAL,0,MAXCHILD
	PregnancyProgress:ARG:LOCAL = 0
NEXT
CALLF CustomTraits_PregnancyType(ARG)

@UPDATE_SET_PREGNANCY_COUNTERS
	;Set the pregnancy progress array for all characters and the birth event count for all characters who have given birth, for older saves.
	;旧セーブ用に、全キャラのpregnancy progress配列、birth event countをセットする
FOR LOCAL,1,CHARANUM
	PregnancyProgress:LOCAL:0 = MAX(CFLAG:LOCAL:妊娠経過日数,TALENT:LOCAL:Nesting)
	SIF (CFLAG:LOCAL:妊娠経過日数 || TALENT:LOCAL:Nesting) && !CFLAG:LOCAL:WithChildCount
		CFLAG:LOCAL:WithChildCount = 1
	SIF !CFLAG:LOCAL:BirthEventsCount && CFLAG:LOCAL:子供人数
		CFLAG:LOCAL:BirthEventsCount = CFLAG:LOCAL:子供人数
NEXT

@ADD_PREGNANCY_PROGRESS(CharacterNumber,ConceptionCount)
	;Set a progress tracker for a new pregnancy or egg, so that they can be born at different times if applicable.
	;新たな妊娠・卵にpregnancy trackersをセットし、異なるタイミングで出産・ふ化するようにする
#DIM DYNAMIC CharacterNumber
#DIM DYNAMIC ConceptionCount
VARSET LOCAL
FOR LOCAL,0,ConceptionCount
	FOR LOCAL:1,0,MAXCHILD
		IF PregnancyProgress:CharacterNumber:(LOCAL:1) == 0
			PregnancyProgress:CharacterNumber:(LOCAL:1) = 1
			BREAK
		ENDIF
	NEXT
NEXT

@PROGRESS_PREGNANCIES(CharacterNumber)
	;Progress all pregnancy trackers in sync with the vanilla one.
	;pregnancy trackersをバニラのと同期させる
#DIM DYNAMIC CharacterNumber
#DIM DYNAMIC ProgressNumber
ProgressNumber = MAX(CFLAG:CharacterNumber:妊娠経過日数,TALENT:CharacterNumber:Nesting)
ProgressNumber -= PregnancyProgress:CharacterNumber:0
FOR LOCAL,0,MAXCHILD
	IF PregnancyProgress:CharacterNumber:LOCAL == 0
		BREAK
	ELSE
		PregnancyProgress:CharacterNumber:LOCAL += ProgressNumber
	ENDIF
NEXT

@REMOVE_PREGNANCY_PROGRESS(CharacterNumber)
	;Remove a pregnancy tracker for when the child is born.
	;子供が生まれたとき、pregnancy trackerをリセットする関数
#DIM DYNAMIC CharacterNumber
FOR LOCAL,0,MAXCHILD
	IF PregnancyProgress:CharacterNumber:LOCAL == 0
		BREAK
	ELSE
		SIF LOCAL > 0
			PregnancyProgress:CharacterNumber:(LOCAL-1) = PregnancyProgress:CharacterNumber:LOCAL
		PregnancyProgress:CharacterNumber:LOCAL = 0
	ENDIF
NEXT

@COUNT_BIRTH_MATES(CharacterNumber)
	;Count how many children will be born within a single birth event.
	;一回の誕生イベントで何人生まれるか
#FUNCTION
#DIM DYNAMIC CharacterNumber
#DIM DYNAMIC ChildCount
FOR LOCAL,0,MAXCHILD
	IF PregnancyProgress:CharacterNumber:LOCAL == 0
		BREAK
	ELSE
		IF PregnancyProgress:CharacterNumber:LOCAL == PregnancyProgress:CharacterNumber:0
			ChildCount++
		ELSE
			BREAK
		ENDIF
	ENDIF
NEXT
RETURNF ChildCount


@ADD_WITH_CHILD(CharacterNumber,Quantity=1)
#DIM DYNAMIC CharacterNumber
#DIM DYNAMIC Quantity
	;Helper function to make a character pregnant with one or more additional children, to be used in dialogues.
SIF !Quantity
	RETURN
IF GROUPMATCH(TALENT:CharacterNumber:PregnancyType,2,3) && !FLAG:EGGNANCY
	TALENT:CharacterNumber:Nesting = MAX(TALENT:CharacterNumber:Nesting,1)
ELSE
	CFLAG:CharacterNumber:妊娠経過日数 = MAX(CFLAG:CharacterNumber:妊娠経過日数,1)
ENDIF
CFLAG:CharacterNumber:WithChildCount += Quantity
CALL ADD_PREGNANCY_PROGRESS(CharacterNumber,Quantity)