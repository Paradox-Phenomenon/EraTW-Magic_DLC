			GOTO TOP
		SIF !INRANGE(LOCAL:1,1,CHARANUM)
			GOTO LOOP1
		PRINTFORMDL
		SELECTCASE TALENT:(LOCAL:1):PregnancyType
			CASE 0,4
				DESCRIPTION = 通常です
			CASE 1,5
