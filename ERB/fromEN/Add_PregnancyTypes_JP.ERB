	CASE 3
		FOR LOCAL,1,CHARANUM
			SIF TALENT:LOCAL:PregnancyType != 2
				TALENT:LOCAL:PregnancyType = 3
		NEXT
		PRINTFORMDW 全員産卵するようになりました
	CASE 4
		FOR LOCAL,1,CHARANUM
			SIF TALENT:LOCAL:PregnancyType == 1
				TALENT:LOCAL:PregnancyType = 0
			SIF TALENT:LOCAL:PregnancyType == 5
				TALENT:LOCAL:PregnancyType = 4
		NEXT
		PRINTFORMDW 多生児が無効になりました
	CASE 5
		FOR LOCAL,1,CHARANUM
			SIF GROUPMATCH(TALENT:LOCAL:PregnancyType,2,3)
				TALENT:LOCAL:PregnancyType = 0
		NEXT
		PRINTFORMDW 産卵が無効になりました
	CASE 6
		FOR LOCAL,1,CHARANUM
			SIF TALENT:LOCAL:PregnancyType == 0
				TALENT:LOCAL:PregnancyType = 1
			SIF TALENT:LOCAL:PregnancyType == 4
				TALENT:LOCAL:PregnancyType = 5
		NEXT
		PRINTFORMDW 産卵しないキャラは全員多胎になりました
	CASE 7
		FOR LOCAL,1,CHARANUM
			SIF TALENT:LOCAL:PregnancyType == 3
				TALENT:LOCAL:PregnancyType = 2
		NEXT
		PRINTFORMDW 産卵するキャラは1つだけ産むようになりました
	CASE 8
		FOR LOCAL,1,CHARANUM
			SIF TALENT:LOCAL:PregnancyType == 2
				TALENT:LOCAL:PregnancyType = 3
		NEXT
		PRINTFORMDW 産卵するキャラは複数産むようになりました
	CASE 9
		FOR LOCAL,1,CHARANUM
			SIF TALENT:LOCAL:PregnancyType != 4
				TALENT:LOCAL:PregnancyType = 0
			CALLF CustomTraits_PregnancyType(LOCAL)
		NEXT
		PRINTFORMDW 全員デフォルトにしました
	CASE 10
		$MANUALSETTING
		PRINTFORMDL
		SIF FLAG:並び替え
			CALL CHARASORT_EX
		FOR LOCAL:2, 1, EX_CHARANUM + 1
			IF FLAG:並び替え
				LOCAL:1 = RESULT:(LOCAL:2)
