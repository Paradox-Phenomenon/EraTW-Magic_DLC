;/*************************************************************
;System functions
;/*************************************************************

;returns true if pose is facing the player
@POSE_FACING(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
RETURNF GROUPMATCH(ARG, POSE_MISSIONARY, POSE_LOTUS, POSE_STANDING_MISSIONARY, POSE_SUSPENDED_CONGRESS)

;returns true if pose is from behind
@POSE_BEHIND(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
RETURNF GROUPMATCH(ARG, POSE_DOGGYSTYLE, POSE_REVLOTUS, POSE_STANDING_FROM_BEHIND, POSE_REV_SUSPENDED_CONGRESS)

;returns true for lotus and suspended congress
@POSE_HUGGING(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
RETURNF GROUPMATCH(ARG, POSE_LOTUS, POSE_REVLOTUS, POSE_SUSPENDED_CONGRESS, POSE_REV_SUSPENDED_CONGRESS)

@IS_STANDING_SEX(COM_ID)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM COM_ID

SIF CFLAG:MASTER:イタズラ == 2 ;not possible during sleep sex
	RETURNF 0

;custom code, adapted for toggle
IF CFLAG:STANDING_TOGGLE
    SIF CAN_STANDING_SEX(COM_ID)
        RETURNF 1
    RETURNF 0
ELSE
    SIF CAN_NORMAL_SEX(COM_ID)
        RETURNF 0
    RETURNF 1
ENDIF
RETURNF 0