@CustomTraits_PregnancyType(ARG)
#FUNCTION
	;1 is Has Litters, 2 is Egg Layer, 3 is Clutch Layer, 4 is Hyperfertile, 5 is Hyperfertile Litters.
SELECTCASE ARG
	CASE 24
			;Chen.
		SIF TALENT:ARG:PregnancyType != 5
			TALENT:ARG:PregnancyType = 1
	CASE 25
			;Ran.
		SIF TALENT:ARG:PregnancyType != 5
			TALENT:ARG:PregnancyType = 1
	CASE 27
			;Wriggle.
		TALENT:ARG:PregnancyType = 3
	CASE 28
			;Mystia.
		TALENT:ARG:PregnancyType = 2
	CASE 29
			;Aya.
		TALENT:ARG:PregnancyType = 2
