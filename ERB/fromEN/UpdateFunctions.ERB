@Update_ImageSets
;uses more resources to achieve very little, but since we have a bunch of custom images this is necessary evil
;0.took image check out of the update process
;1.removed the redundant question about which set to replace the current set with
;2.right-click skippable
;3.shows a bit more info, I guess

;Img_Detected detects how many characters have new alts and doubles as CharaNum's real size (how many slots actually hold values)
#DIM C_ID
#DIM Img_Detected
#DIM Img_CharaNum, キャラクタ数上限
#DIM Count_Face
#DIM Count_Standing
#DIMS Resources_Face, 10
#DIMS Resources_Standing, 10

VARSET Img_CharaNum
VARSET Img_Detected

;差し替え画像の有無を確認
FOR C_ID, 1, CHARANUM
	SIF CFLAG:C_ID:出禁
		CONTINUE
	IF CFLAG:C_ID:別顔有 != CSVCFLAG(C_ID, 562) || CFLAG:C_ID:別立ち有 != CSVCFLAG(C_ID, 563)
		Img_CharaNum:Img_Detected = C_ID
		Img_Detected ++
	ENDIF
NEXT
LOCAL:3 = 0
IF Img_Detected > 9
	PRINTFORMDL 检测到{Img_Detected}个角色有新的可选立绘\n渲染过多图片可能导致低配置下游戏崩溃，是否缄默进行此次立绘更新
	CALL ASK_YN
	SIF !RESULT
		LOCAL:3 = 1
	CLEARLINE 1
ELSEIF Img_Detected
	PRINTL 
	PRINTFORML 检测到这些角色有新的可选立绘：
ELSE
	RETURN
ENDIF
FOR LOCAL, 0, Img_Detected
	IF LOCAL:3
		CFLAG:((Img_CharaNum:LOCAL)):別顔有 = CSVCFLAG(NO:(Img_CharaNum:LOCAL), 562)
		CFLAG:((Img_CharaNum:LOCAL)):別立ち有 = CSVCFLAG(NO:(Img_CharaNum:LOCAL), 563)
		CONTINUE
	ENDIF
	CALL SET_KOJO_COLOR(Img_CharaNum:LOCAL)
	PRINTFORML %CALLNAME:(Img_CharaNum:LOCAL)%
	RESETCOLOR
	
	;get the state prior so we can handle header better
	Count_Face = CFLAG:((Img_CharaNum:LOCAL)):別顔有 < CSVCFLAG((Img_CharaNum:LOCAL), 562) ? CSVCFLAG((Img_CharaNum:LOCAL), 562) # 0
	Count_Standing = CFLAG:((Img_CharaNum:LOCAL)):別立ち有 < CSVCFLAG((Img_CharaNum:LOCAL), 563) ? CSVCFLAG((Img_CharaNum:LOCAL), 563) # 0

	SIF !Count_Face && !Count_Standing
		CONTINUE
	VARSET Resources_Face
	VARSET Resources_Standing

	TRYCALLFORM COMPOSE_SPRITE_{NO:(Img_CharaNum:LOCAL)}

	IF Count_Face
		Resources_Face:0 = 顔絵_服_通常_{NO:(Img_CharaNum:LOCAL)}
		FOR LOCAL:1, 1, MAX(Count_Face, Count_Standing) + 1
			LOCALS '= @"\@LOCAL:1 >= 2?別顔{LOCAL:1}#別顔\@_服_通常_{NO:(Img_CharaNum:LOCAL)}"
			SIF SPRITECREATED(LOCALS)
				Resources_Face:(LOCAL:1) '= LOCALS
		NEXT
	ENDIF
	IF Count_Standing
		Resources_Standing:0 = 立絵_服_通常_{NO:(Img_CharaNum:LOCAL)}
		FOR LOCAL:1, 1, MAX(Count_Face, Count_Standing) + 1
			LOCALS '= @"\@LOCAL:1 >= 2?別立ち{LOCAL:1}#別立ち\@_服_通常_{NO:(Img_CharaNum:LOCAL)}"
			SIF SPRITECREATED(LOCALS)
				Resources_Standing:(LOCAL:1) '= LOCALS
		NEXT
	ENDIF

	;display face portraits, print headers for both face and standing
	SIF Count_Face
		CALL Update_ImageSets_Print_Row(Resources_Face, MAX(Count_Face, Count_Standing), 1)
	;display standing portraits, only print headers if there are no face portraits
	SIF Count_Standing
		CALL Update_ImageSets_Print_Row(Resources_Standing, MAX(Count_Face, Count_Standing), !Count_Face)
	CFLAG:((Img_CharaNum:LOCAL)):別顔有 = CSVCFLAG(NO:(Img_CharaNum:LOCAL), 562)
	CFLAG:((Img_CharaNum:LOCAL)):別立ち有 = CSVCFLAG(NO:(Img_CharaNum:LOCAL), 563)
	WAIT
NEXT
SIF Img_Detected
	PRINTFORML 立绘更新已完成
CUSTOMDRAWLINE -
CALL PRINTBUTTON_EX(@"[结束]",0, , , ,)
$LOOP
INPUT
SELECTCASE RESULT
	CASE 0
		RETURN
	CASEELSE
		GOTO LOOP
ENDSELECT

@Update_ImageSets_Print_Row(Resources_Array, Element_Count, Print_Header)
#DIMS REF Resources_Array
#DIM Element_Count
#DIM Print_Header
VARSET LOCALS
FOR LOCAL, 0, Element_Count + 1
	SIF Print_Header
		LOCALS = [\@ !LOCAL ? 初始 # 可选#{LOCAL} \@]
	IF Resources_Array:LOCAL != ""
		CALL SET_IMAGE_WITH_HEADER(Resources_Array:LOCAL, 0, 0, 100, 0, 0, "", "", "", 0,@"%LOCALS%")
	ELSE
		CALL SET_IMAGE_WITH_HEADER("ダミー", 0, 0, 100, 0, 0, "", "", "", 0,@"%LOCALS%")
	ENDIF
NEXT
CALL 画像一斉表示("左", 0, 1)
PRINTL
