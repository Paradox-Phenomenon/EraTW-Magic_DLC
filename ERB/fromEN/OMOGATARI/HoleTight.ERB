@SizePointsToValue(ARG)
#FUNCTION
SELECTCASE ARG
	CASE IS > 1000
		LOCAL = 3
	CASE IS > 600
		LOCAL = 2
	CASE IS > 300
		LOCAL = 1
	CASE IS < -300
		LOCAL = -1
	CASE IS < -600
		LOCAL = -2
	CASEELSE
		RETURNF 0
ENDSELECT
RETURNF LOCAL

