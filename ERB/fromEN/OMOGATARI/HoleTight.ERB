@Add_Size_Check(ARGS, ARG = -1, nInserter = -1)
#DIM nInserter
#FUNCTION
SIF ARG == -1
	ARG = TARGET
SIF nInserter == -1
	nInserter = MASTER
;for normal actions
SELECTCASE ARGS 
	;custom code
	CASE "strictA", "regA", "anal"
		RETURNF Add_HoleSizeCheck(ARG,nInserter,1,1)
	CASE "regU", "strictU"
		RETURNF Add_HoleSizeCheck(ARG,nInserter,2,1)
	CASEELSE
		RETURNF Add_HoleSizeCheck(ARG,nInserter,0,1)
ENDSELECT

