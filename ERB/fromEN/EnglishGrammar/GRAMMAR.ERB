;==================================================
;Returns "-chan" or "-kun" depending on the gender of the character you pass to it
;==================================================
@CHAN_KUN(ARG)
#FUNCTIONS
IF IS_MALE(ARG)
	RETURNF @"%CALLNAME:ARG%-kun"
ELSE
	RETURNF @"%CALLNAME:ARG%-chan"
ENDIF