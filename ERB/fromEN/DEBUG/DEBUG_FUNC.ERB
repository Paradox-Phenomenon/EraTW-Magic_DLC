@MADE_IN_HEAVEN()
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM FIRST_LINE
#DIM NewDate, 5
#DIM DIFF
#DIM CONST YearLength = 124
#DIM CONST MonthCount = 4

FIRST_LINE = LINECOUNT
NewDate = DAY
NewDate:1 = DAY:1
NewDate:2 = DAY:2
NewDate:3 = DAY:3
NewDate:4 = (DAY/YearLength)+1

DO
	CLEARLINE LINECOUNT - FIRST_LINE

	NewDate = ((NewDate:4-1)*YearLength)+((NewDate:2-1)*(YearLength/MonthCount))+NewDate:3

	PRINTFORML 当前日期：%PRINT_DATE_F(DAY)%
	PRINTFORML 目标日期：%PRINT_DATE_F(NewDate)%
	PRINTFORML [0] - 变更年份: {NewDate:4}
	PRINTFORML [1] - 变更月份: {NewDate:2}
	PRINTFORML [2] - 变更日期: {NewDate:3}
	PRINTL
	PRINTFORML [998] - ＭＡＤＥ　ＩＮ　ＨＥＡＶＥＮ！！
	PRINTFORML [999] - 冷静下来…… 数着『素数』冷静下来……
	INPUT
	SELECTCASE RESULT
	CASE 0
		PRINTFORMDL 指定年份
		INPUT
		NewDate:4 = RESULT
	CASE 1
		PRINTFORMDL 指定月份（1～4）
		INPUT
		SELECTCASE RESULT
			CASE 1 TO 4
				NewDate:2 = RESULT
			CASEELSE
				PRINTFORMDL 非法输入
		ENDSELECT
	CASE 2
		$ENTER_THE_DAY
		PRINTFORMDL 指定日期（1～31）
		INPUT
		SELECTCASE RESULT
			CASE 1 TO 31
				NewDate:3 = RESULT
			CASEELSE
				PRINTFORMDL 非法输入
		ENDSELECT
	CASE 998
	BREAK
	CASE 999
	RETURN
	ENDSELECT
LOOP 1
CALL SET_KOJO_COLOR(MASTER)
PRINTFORMW 「请回想起『觉悟才是幸福』这句话！」
PRINTFORMW 「ＭＡＤＥ　ＩＮ　ＨＥＡＶＥＮ！！」
RESETCOLOR
PRINTFORMDW 时间加速。
DIFF = NewDate - DAY

NOSKIP
REPEAT ABS(DIFF)
	REUSELASTLINE %PRINT_DATE_F(DAY)%
	IF DIFF > 0
		DAY ++
		DAY:3 ++
	ELSEIF DIFF < 0
		DAY --
		DAY:3 --
	ENDIF
	SELECTCASE ABS(DIFF)-COUNT
	CASE IS > YearLength*1000
		SIF COUNT % (YearLength*100) == 0
		TWAIT 1, 1
	CASE IS > YearLength*500
		SIF COUNT % (YearLength*10) == 0
		TWAIT 1, 1
	CASE IS > YearLength*250
		SIF COUNT % (YearLength*5) == 0
		TWAIT 1, 1
	CASE IS > YearLength*100
		SIF COUNT % YearLength == 0
		TWAIT 1, 1
	CASE IS > YearLength*10
		SIF COUNT % 31 == 0
		TWAIT 1, 1
	CASE IS > YearLength
		SIF COUNT % 7 == 0
		TWAIT 1, 1
	CASE IS > YearLength/MonthCount
		TWAIT 1, 1
	CASE IS > 7
		TWAIT 50, 1
	CASE IS > 3
		TWAIT 250, 1
	CASE IS > 0
		TWAIT 500, 1
	CASE 1
		TWAIT 1000, 1
	ENDSELECT
	SKIPDISP 1
	CALL CHANGE_MONTH
	SKIPDISP 0
REND
ENDNOSKIP
PRINTFORMDL %PRINT_DATE_F(DAY)%
PRINTFORMDW 我的能力……完成了。
CALL OYASUMI
RETURN 1

