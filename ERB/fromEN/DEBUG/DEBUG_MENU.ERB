;-------------------------------------------------
;Debug menu
;-------------------------------------------------
@DEBUG_MENU
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM nLineCnt_Head

VARSET LOCAL
DEBUG_TARGET = TARGET
DRAWLINE
PRINTL 

nLineCnt_Head = LINECOUNT
REDRAW 0
DO
	SIF LINECOUNT - nLineCnt_Head > 0
		CLEARLINE LINECOUNT - nLineCnt_Head

	CALL DEBUG_MENU_STATE
	SELECTCASE RESULT
		CASE 0
			RETURN
	CASEELSE
	ENDSELECT
LOOP 1

