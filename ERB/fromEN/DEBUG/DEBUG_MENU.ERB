;-------------------------------------------------
; DEBUG_MENU_STATE
; The main selection part of the menu
;-------------------------------------------------
@DEBUG_MENU_STATE(C_ID,OP)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS    OP         ;実行オプション
#DIM     C_ID       ;登録番号
#DIM     PAGE       ;表示中のページ
#DIMS CONST DISP_NAME = "通常","肉体","物品","其他"
#DIM CREDRAW
#DIM FIRST_LINE
FIRST_LINE = LINECOUNT
LOOP_BREAK = 0
$REPRINT
CLEARLINE LINECOUNT - FIRST_LINE
CREDRAW = CURRENTREDRAW()
REDRAW 0

CALL PRINT_STATE_IMAGE(DEBUG_TARGET)
PRINTFORML 当前TARGET: %NAME:DEBUG_TARGET%
PRINTFORML [1000] - 变更TARGET
PRINTFORML [1001] - 设为当前TARGET
PRINTFORML [1002] - 设为%CALLNAME:MASTER%
PRINTFORML
TRYCALLFORM DEBUG_MENU_PAGE_{PAGE}
DRAWLINE
FOR LOCAL, 0, VARSIZE("DISP_NAME")
	SIF !STRLENS(DISP_NAME:LOCAL)
		CONTINUE
	SIF PAGE == LOCAL
		SETCOLOR 0x00FFFF
	;exception for player character
	PRINTBUTTON DISP_NAME:LOCAL, LOCAL + 2
	RESETCOLOR
	PRINTFORM 　　
NEXT
PRINTFORML 
PRINTBUTTON "[0] 返回", 0
DO
	INPUT
	SELECTCASE RESULT
		CASE 0
			RETURN 0
		CASE 1
			GOTO RETRY
		CASE 2 TO VARSIZE("DISP_NAME")+2
			PAGE = RESULT-2
		CASE 画像切り替え
			IF !FLAG:画像表示
				FLAG:画像表示 = !FLAG:画像表示
				FLAG:立ち絵種類 = 0
			ELSEIF !FLAG:立ち絵種類
				FLAG:立ち絵種類 = !FLAG:立ち絵種類
			ELSEIF FLAG:立ち絵種類
				FLAG:画像表示 = !FLAG:画像表示
			ENDIF
		CASE 98
		;alt portraits
			SIF CFLAG:DEBUG_TARGET:別顔有 || CFLAG:DEBUG_TARGET:別立ち有
				CFLAG:DEBUG_TARGET:差し替え適用 += 1
			SIF (CFLAG:DEBUG_TARGET:差し替え適用 > CFLAG:DEBUG_TARGET:別顔有 && FLAG:立ち絵種類) || (CFLAG:DEBUG_TARGET:差し替え適用 > CFLAG:DEBUG_TARGET:別立ち有 && !FLAG:立ち絵種類)
				CFLAG:DEBUG_TARGET:差し替え適用 = 0
		CASE 1000
			$REPRINT_1000
			PRINTFORML 谁？
			DRAWLINE
			FOR LOCAL,0,CHARANUM
				PRINTFORMLC [{LOCAL}] %CALLNAME:LOCAL%
			NEXT
			PRINTFORML
			DRAWLINE
			PRINTFORMLC [990] 取消
			PRINTFORMLC [998] 角色列表
			INPUT
			SELECTCASE RESULT
				CASE 0 TO CHARANUM
					DEBUG_TARGET = RESULT
				CASE 998
					CALL QOL_FULL_ROSTER
					DEBUG_TARGET = RESULT
				CASE 999
					GOTO REPRINT_1000
			ENDSELECT
		CASE 1001
			DEBUG_TARGET = TARGET
		CASE 1002
			DEBUG_TARGET = MASTER
		CASE IS >= 100
			TRYCALLFORM DEBUG_MENU_RESULT_{PAGE}_{RESULT}
			SIF LOOP_BREAK == 1
				RETURN 0
			SIF RESULT
				PRINTFORMW 正常调用
		CASEELSE
			$RETRY
			REUSELASTLINE 非法输入
			CONTINUE
	ENDSELECT
	BREAK
LOOP 1
GOTO REPRINT

@PRINT_CUSTOM_DEBUG(ARG, ARGS, ARGS:1, ARGS:2)
#LOCALSIZE 1
#LOCALSSIZE 1
IF ARGS != "" || ARGS:1 != ""
	IF ARGS:1 != ""
		SETCOLOR C_YELLOW
		PRINTFORML %ARGS:1%
		RESETCOLOR
		SIF ARGS == ""
		RETURN
	ENDIF
	$BYPASS
	SIF ARGS != ""
	PRINTFORM [{ARG}] - %ARGS%
	IF ARGS:2 != ""
		SETCOLOR C_GRAY
		PRINTFORM  %ARGS:2%
		RESETCOLOR
	ENDIF 
	PRINTL
ENDIF