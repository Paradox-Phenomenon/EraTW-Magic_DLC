;口上用文字色関係の処理

;色変更対象の選択
@CHANGE_PT_KOJO_COLOR
#LOCALSIZE 3
#LOCALSSIZE 1
#DIMS DYNAMIC strDialog
LOCAL:2 = LINECOUNT
PRINTFORML 代表色列表

FOR LOCAL:0, 1, CHARANUM
	CALL KOJO_ACTIVE_INFO(LOCAL)
	IF RESULT
		CALL SET_KOJO_COLOR(NO:LOCAL)
		SIF k_DialogueColorSet:(NO:LOCAL):0 != 0
			SETCOLOR k_DialogueColor:(NO:LOCAL):0
		LOCAL:1 = GETCOLOR()
		PRINTFORM [{LOCAL:0, 3}] %CALLNAME:LOCAL,14,LEFT%  代表色：
		PRINTFORM %UNICODE(0x2586)%%UNICODE(0x2586)%%UNICODE(0x2586)%%UNICODE(0x2586)%　(%TOUPPER(TOSTR(LOCAL:1, "X6"))%) (R:{LOCAL:1 / 0x10000,3} G:{(LOCAL:1 & 0xFF00) / 0x100,3} B:{LOCAL:1 & 0xFF,3})
		PRINTFORML 「我在我在～!」
		RESETCOLOR
		strDialog += @"{LOCAL:0}:"
	ENDIF
NEXT
CALL COLOR_LINE
PRINTL [  0] 返回
LOCAL = LINECOUNT
$INPUT_LOOP
CLEARLINE LINECOUNT - LOCAL
INPUT

IF RESULT == 0
	RETURN
ELSE
	SIF !SPLIT_CHECK(strDialog, RESULT)
		GOTO INPUT_LOOP
	CALL PT_SET_KOJO_COLOR(RESULT)
ENDIF
CLEARLINE LINECOUNT - LOCAL:2
RESTART



;指定キャラの文字色変更
;ARG:0	対象キャラID
@PT_SET_KOJO_COLOR(ARG:0)
#LOCALSIZE 3
#LOCALSSIZE 1
;0	LOOP
;1	今の文字色
;2	デフォルトカラー

PRINTFORML 
PRINTFORML 设置%CALLNAME:(ARG:0)%的代表色 (仅展示UI组件功能，不会真的改变代表色)
SIF k_DialogueColorSet:ARG:0 != 0
	LOCAL:1 = k_DialogueColor:ARG:0
CALL SET_KOJO_COLOR(ARG:0)
LOCAL:2 = GETCOLOR()
SIF k_DialogueColorSet:ARG:0 == 0
	LOCAL:1 = LOCAL:2
	
SETCOLOR LOCAL:1
PRINTFORML 当前：%UNICODE(0x2586)%%UNICODE(0x2586)%%UNICODE(0x2586)%%UNICODE(0x2586)%　(%TOUPPER(TOSTR(LOCAL:1, "X6"))%) (R:{LOCAL:1 / 0x10000,3} G:{(LOCAL:1 & 0xFF00) / 0x100,3} B:{LOCAL:1 & 0xFF,3})

PRINTFORML 例：「我在我在～!」
RESETCOLOR

PRINTFORML 
PRINTFORML 变成什么颜色?
SETCOLOR LOCAL:2
PRINTFORML [1] 剧本设置 %UNICODE(0x2586)%%UNICODE(0x2586)%%UNICODE(0x2586)%%UNICODE(0x2586)%　(%TOUPPER(TOSTR(LOCAL:2, "X6"))%) (R:{LOCAL:2 / 0x10000,3} G:{(LOCAL:2 & 0xFF00) / 0x100,3} B:{LOCAL:2 & 0xFF,3})
RESETCOLOR
PRINTFORML [2] 自定义颜色
PRINTFORML [3] 系统默认颜色
PRINTFORML [0] 返回
LOCAL = LINECOUNT
$INPUT_LOOP
CLEARLINE LINECOUNT - LOCAL
INPUT

IF RESULT == 0
	RETURN
ELSEIF RESULT == 1
	k_DialogueColor:ARG:0 = LOCAL:2
	k_DialogueColorSet:ARG:0 = 1
ELSEIF RESULT == 2
	CALL COLOR_RGBBAR,,LOCAL:1
	IF RESULT == -1
		;キャンセルされているので、何もしない
		RETURN
	ENDIF
	k_DialogueColor:ARG:0 = RESULT
	k_DialogueColorSet:ARG:0 = 1
ELSEIF RESULT == 3
	RESETCOLOR
	k_DialogueColor:ARG:0 = GETCOLOR()
	k_DialogueColorSet:ARG:0 = 1
ELSE
	GOTO INPUT_LOOP
ENDIF

SETCOLOR k_DialogueColor:ARG:0
PRINTFORMW 已将%CALLNAME:(ARG:0)%的代表色设置为 %UNICODE(0x2586)%%UNICODE(0x2586)%%UNICODE(0x2586)%%UNICODE(0x2586)%　(%TOUPPER(TOSTR(k_DialogueColor:ARG:0, "X6"))%) (R:{k_DialogueColor:ARG:0 / 0x10000,3} G:{(k_DialogueColor:ARG:0 & 0xFF00) / 0x100,3} B:{k_DialogueColor:ARG:0 & 0xFF,3})
RESETCOLOR

RETURN

;Show RGB/HSV bar, from eraMeiQ Gaiden
@COLOR_RGBBAR, ARGS, ARG
#LOCALSIZE 4
#LOCALSSIZE 1
#DIM nColorBuf

#DIM nInputResult
#DIM nStartLine
#DIM nSelectLine

#DIM nColorList = 0xCF0125, 0xEB5381, 0xF5A0BD, 0xF79101, 0xE49E61, 0xFFF352, 0x7FFF00, 0x2CB232, 0x00A6AF, 0x49BDF0, 0x4169E1, 0x0063A7, 0x7F1184, 0xBC64A4, 0x626063, 0x55461B
TOOLTIP_SETDELAY 50
TOOLTIP_SETDURATION 10000

nColorBuf = ARG

SIF LINEISEMPTY() == 0
	PRINTFORML
nStartLine = LINECOUNT

$PRINT_LIST
SIF LINECOUNT - nStartLine > 0
	CLEARLINE (LINECOUNT - nStartLine)

PRINTFORML

PRINTFORM 选中颜色：
SETCOLOR nColorBuf
PRINTBUTTON @"■", nColorBuf
RESETCOLOR
PRINTFORM  ({nColorBuf}(0x%TOSTR(nColorBuf, "X6")%))
PRINTL 

SETCOLOR nColorBuf
PRINTFORML 例：「我在我在～!」
RESETCOLOR
PRINTL
nSelectLine = LINECOUNT
BITMAP_CACHE_ENABLE 1
; RGBスライダー（実際はボタンの集合体）を表示する
;CALL PRINT_RGB_SLIDER( nColorBuf )
CALL HTML_PRINT_RGB_SLIDER( nColorBuf )
PRINTL 
; HSBスライダー（実際はボタンの集合体）を表示する
;CALL PRINT_HSB_SLIDER( nColorBuf )
CALL HTML_PRINT_HSB_SLIDER( nColorBuf )
PRINTL 
BITMAP_CACHE_ENABLE 0
PRINTFORM  预  设 : 

FOR LOCAL:0, 1, VARSIZE("nColorList")
	PRINT [
	SETCOLOR nColorList:LOCAL
	PRINTBUTTON "■", nColorList:LOCAL
	RESETCOLOR
	PRINT ]
NEXT
RESETCOLOR
PRINTL 

PRINTFORML 点击滑块或样板色选择，或输入16进制颜色代码，或直接输入RGB数值（0～255）来改变颜色

PRINTFORML [-100] 输入RGB数值
PRINTFORML [-200] 输入16进制颜色
PRINTL 
PRINTFORML [-888] 应用
PRINTFORML [-999] 退出

WHILE 1
	INPUT
	nInputResult = RESULT
	SELECTCASE  nInputResult
		CASE -888
			BREAK
		CASE -999
			RESULT = -1
			RESULT:1 = -1
			RESULT:2 = -1
			RESULT:3 = -1
			;RETURN RESULT, RESULT:1, RESULT:2, RESULT:3
			RETURN -1
		CASE -100
			FOR LOCAL, 0, 3
				LOCALS '= "Red", "Green", "Blue"
				PRINTFORML 输入 %LOCALS:LOCAL% 值 (0～255 负数则取消输入并返回)
				INPUT
				IF RESULT >= 0
					LOCAL:(LOCAL + 1) = LIMIT(RESULT, 0, 255)
				ELSE
					GOTO PRINT_LIST
				ENDIF
			NEXT
			nColorBuf = (LOCAL:1 << 16) + (LOCAL:2 << 8) + LOCAL:3
			GOTO PRINT_LIST
		CASE -200
			PRINTFORML 输入六位HEX色码： 000000～FFFFFF (无输入或输入错误则取消并返回)
			INPUTS
			IF RESULTS != ""
				SIF ISNUMERIC("0x" + RESULTS) && INRANGE(TOINT("0x" + RESULTS), 0, TOINT("0xFFFFFF"))
					nColorBuf = TOINT("0x" + RESULTS)
			ENDIF
			GOTO PRINT_LIST
		CASE 0x000000 TO 0xFFFFFF
			nColorBuf = nInputResult
			GOTO PRINT_LIST
	ENDSELECT
	CLEARLINE 1
WEND

RESETCOLOR

SIF LINECOUNT - nSelectLine > 0
	CLEARLINE (LINECOUNT - nSelectLine)
PRINTL 

;RESULTS '= HEXTORGB(nColorBuf)
;SPLIT RESULTS, "//", LOCALS
;RESULT:1 = TOINT(LOCALS:0)
;RESULT:2 = TOINT(LOCALS:1)
;RESULT:3 = TOINT(LOCALS:2)

;RETURN RESULT, RESULT:1, RESULT:2, RESULT:3
TOOLTIP_SETDELAY 500
TOOLTIP_SETDURATION 5000

RETURN nColorBuf

