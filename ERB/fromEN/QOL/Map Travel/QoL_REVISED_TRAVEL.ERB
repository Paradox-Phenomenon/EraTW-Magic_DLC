@QOL_REVISED_TIME_REQUIRED(DEPARTURE, DESTINATION)
#FUNCTION
#DIM DEPARTURE
#DIM DESTINATION
#DIM TRAVEL_TIME
#DIM WEATHER_MULTIPLIER
#DIM NODES
#DIM IS_DANGEROUS

TRAVEL_TIME = QOL_REVISED_DISTANCE(DEPARTURE, DESTINATION, FLAG:DANGEROUS_TRAVEL && тљїУАїС║║ТЋ░() == 0)
IS_DANGEROUS = RESULT:1
NODES = RESULT:2
WEATHER_MULTIPLIER = QOL_REVISED_TRAVEL_WEATHER_MULTIPLIER()

SIF WEATHER_MULTIPLIER > 100 && ITEM:сЃгсѓцсЃ│сѓ│сЃ╝сЃѕ
	WEATHER_MULTIPLIER -= (WEATHER_MULTIPLIER-100) / 2

TRAVEL_TIME = QOL_REVISED_TRAVEL_SPECIAL_ADJUSTMENTS(DEPARTURE, DESTINATION, TRAVEL_TIME, WEATHER_MULTIPLIER, NODES)
TRAVEL_TIME = MULTIPLY(TRAVEL_TIME, WEATHER_MULTIPLIER)

RETURNF TRAVEL_TIME

@QOL_REVISED_TRAVEL_SPECIAL_ADJUSTMENTS(DEPARTURE, DESTINATION, TRAVEL_TIME, WEATHER_MULTIPLIER, NODES)
#FUNCTION
#DIM DEPARTURE
#DIM DESTINATION
#DIM TRAVEL_TIME
#DIM REF WEATHER_MULTIPLIER
#DIM NODES
#DIM DYNAMIC IGNORE_SHORTCUTS
;т░Јућ║сЂ«УЃйтіЏ
SIF CFLAG:[[т░Јућ║]]:тљїУАї
	TRAVEL_TIME = TRAVEL_TIME * 2 / 3
;сѓЈсЂІсЂЋсЂјтДФсЂ«У▓аТІЁ
SIF CFLAG:[[сѓЈсЂІсЂЋсЂјтДФ]]:тљїУАї && !GETBIT (FLAG:сЃЌсЃ╝сЃФ, 0)
	TRAVEL_TIME = TRAVEL_TIME * 3 / 2

;уЦътГљсЂ«УЃйтіЏ
IF CFLAG:[[уЦътГљ]]:тљїУАї && INRANGE(CFLAG:[[уЦътГљ]]:уЈЙтюеСйЇуй«, 100, 199) ;miko
	IF DESTINATION == MAPТюѕ
		TRAVEL_TIME = 30
	ELSE
		TRAVEL_TIME = 10
	ENDIF
    IGNORE_SHORTCUTS = 1
ENDIF

IF CFLAG:[[у┤Ф]]:тљїУАї ;yukari
    TRAVEL_TIME = NODES * 10 ;ten minutes for each node
    SIF (DESTINATION == MAPТюѕ || DEPARTURE == MAPТюѕ) && MOON_WATCH(DAY:3, 1) != 9 ;travel to the moon works normally, excepting on full moon
        TRAVEL_TIME += 10
    IGNORE_SHORTCUTS = 1
ENDIF

IF (CFLAG:[[жџат▓љтЦѕ]]:тљїУАї && TRAVEL_TIME >= 20) || ((CFLAG:[[Уѕъ]]:тљїУАї || CFLAG:[[жЄїС╣Ѓ]]:тљїУАї) && TRAVEL_TIME >= 30) ;okina/mai/satono
    IF CFLAG:[[жџат▓љтЦѕ]]:тљїУАї ;okina's better at it
        TRAVEL_TIME = 20 ;fixed time to traverse the land of the backdoor
    ELSE
        TRAVEL_TIME = 30 ;fixed time to traverse the land of the backdoor
    ENDIF
    SIF (DESTINATION == MAPТюѕ || DEPARTURE == MAPТюѕ) ;travel to the moon works normally
        TRAVEL_TIME += 20
    IGNORE_SHORTCUTS = 1
ENDIF

IF CFLAG:[[тцЕтГљ]]:тљїУАї ;tenshi
    WEATHER_MULTIPLIER = 100 ;ignore weather affects
ELSEIF CFLAG:[[УАБујќ]]:тљїУАї ;iku
    SIF WEATHER_MULTIPLIER > 100
        WEATHER_MULTIPLIER -= (WEATHER_MULTIPLIER-100) / 2 ;halve weather effects
ENDIF

IF CFLAG:[[У▒ітДФ]]:тљїУАї ;toyohime
    TRAVEL_TIME = 0
    WEATHER_MULTIPLIER = 100
    IGNORE_SHORTCUTS = 1
    RESULT:1 = 0 ;not dangerous
ENDIF

;сЂЮсЂ«С╗ќсЂ«сѓисЃДсЃ╝сЃѕсѓФсЃЃсЃѕті╣Тъю
SIF SHORTCUT(DEPARTURE, DESTINATION) && !IGNORE_SHORTCUTS
	TRAVEL_TIME = TRAVEL_TIME * 1 / 2

;ТюѕсЂ«уЙйУАБсЂ«ті╣Тъю
IF (DESTINATION == MAPТюѕ || DEPARTURE == MAPТюѕ) && ITEM:ТюѕсЂ«уЙйУАБ && TRAVEL_TIME >= 40
	TRAVEL_TIME = MIN(TRAVEL_TIME, 40)
    RESULT:1 = 0 ;not dangerous
ENDIF

RETURNF TRAVEL_TIME

@QOL_REVISED_TRAVEL_WEATHER_MULTIPLIER()
#FUNCTION
LOCAL = 100
;(тцЕтђЎсЃЉсЃЃсЃЂ)ТѓфтцЕтђЎТЎѓсЂФсЂ»ТЅђУдЂТЎѓжќЊтбЌтіа
SELECTCASE TIME:5
	CASE 4, 6, 10, 12
		TIMES LOCAL, 1.2
	CASE 7, 8, 11, 13
		TIMES LOCAL, 1.5
	CASE 5, 15
		TIMES LOCAL, 2
	CASE 9
		TIMES LOCAL, 3
	CASE 14
		TIMES LOCAL, 4
ENDSELECT
;(тцЕтђЎсЃЉсЃЃсЃЂ)т╝ижбеТЎѓсЂФсЂ»ТЅђУдЂТЎѓжќЊтбЌтіа
SELECTCASE WIND_VELOCITY
	CASE 1
		TIMES LOCAL, 2
	CASE 2
		TIMES LOCAL, 4
	CASE IS >= 3
		TIMES LOCAL, 6
ENDSELECT

RETURNF LOCAL
