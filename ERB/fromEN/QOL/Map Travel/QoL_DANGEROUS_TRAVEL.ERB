@QOL_TRAVEL_ONI_FIGHT(DESIRED_REWARD, DESIRED_TYPE)
#DIM モブ残機
#DIM DESIRED_REWARD
#DIM DESIRED_TYPE
TARGET = (FREE_MOB_SLOT(1))
TIME += 60
CFLAG:面識 = 1
HANDICAP_FIXED = RAND:(ABL:戦闘能力 * 8 + 1) + 10
HANDICAP_RAND = ABL:戦闘能力 * 50

CALL KOJO_MESSAGE_SEND("DANMAKU", 0, TARGET, 1, -1, "戦闘前")

DRAWLINE
PRINTFORML 
[SKIPSTART]
CALL DANMAKU_OPPONENT_STATUS(TARGET)
IF HANDICAP_FIXED
	CALL COLORMESSAGE(@"Terrain effect: %CALLNAME:MASTER%'s dice goes down by {HANDICAP_FIXED}!",C_YELLOW,1)
	;【三粒の天滴】の効果
	IF ITEM:三粒の天滴
		HANDICAP_FIXED /= 2
		CALL COLORMESSAGE(@"But the Curse of the Native God halves it, becoming {HANDICAP_FIXED}!",C_YELLOW,1)
	ENDIF
ENDIF
CALL COLORMESSAGE(@"Fighting in these narrow tunnels put you at a severe disadvantage!",C_YELLOW,1)
[SKIPEND]

;PRINTFORMW Game Start!!!
CALL KNIFE_FIGHT(MASTER, TARGET, 1, 1) ;replace with eraNAS battle
モブ残機 = !(lcWarResult == CurrentBattle:Battle_PlayerSide); a result over 0 is LOSE for this so we need to invert this

; モブ残機 = RESULT
; CALL RECOVER(MASTER, -500, "体力")
; CALL RECOVER(MASTER, -500, "気力")
CALL KOJO_MESSAGE_SEND("DANMAKU", モブ残機, TARGET, 1, -1, "戦闘後")
SIF モブ残機 < 3
	EXP:MASTER:戦闘経験 += ABL:戦闘能力 * 3
SIF モブ残機 < 1
	EXP:MASTER:戦闘経験 += ABL:戦闘能力
IF モブ残機 > 0
	Qol_Info_Count_Array:MASTER:Qol_Count_EncountLost++

    SELECTCASE DESIRED_REWARD
        CASE 0
            CALL SPTALK, (FREE_MOB_SLOT(1)), "通常", 1, @"「Maybe I went a lil' overboard 'ere.」/「Ah well. 'dem's 'da breaks.」", 1
            PRINTFORMDW Having enjoyed herself, the oni casually walks off, leaving you to nurse your wounds.
        CASE 1
            PRINTFORMDW No longer able to move, %CALLNAME:TARGET% pins you down.
            PRINTFORMDW You feel a warm, almost steamy sigh breathing down on your defenseless throat...
            CALL Add_LOST_GYAKURE_EX(TARGET, 0)
            SIF RESULT
                GOTO GYAKURE_END

            PRINTFORMDW Just when you thought you were finished, you feel something very hot enveloping your crotch.
            PRINTFORMDW %BREAKENG(@"A cautious glance at your lower half reveals %CALLNAME:TARGET% grinning smugly at you, your %FSYN("penis")% firmly lodged deep inside her %FSYN("vagina",,TARGET)% %FSYN("base")%.")%
            PRINTFORMDW 
            PRINTFORMD %CALLNAME:TARGET% quenches her bestial thirst by ravaging, tormenting, and violating your body for all it is worth...
            CALL PRINT_BREAK,,"wait"
            CALL TRIPLEDOT("reverse:timed")
            PRINTFORMDW %BREAKENG(@"After %CALLNAME:TARGET% has ravished you for what seems like an eternity to her utter satisfaction, you find yourself outside the Underground, close to your destination.")%
            
            $GYAKURE_END
            TIME += 60
            FLAG:気絶中断 = 100 + CFLAG:MASTER:現在位置 / 100
            CFLAG:MASTER:デート中 = CFLAG:MASTER:現在位置 / 100
            CALL LOST_GYAKURE(TARGET)
        CASE 2
            CALL SPTALK, (FREE_MOB_SLOT(1)), "通常", 1, @"「Ya lost, so I'll take my reward now.」", 1
		    CALL LOST_MONEY_YEN(QOL_GET_YEAR(DAY) * 50000, 2) ;increases every year
        CASE 3
            CALL SPTALK, (FREE_MOB_SLOT(1)), "通常", 1, @"「Ya lost, so I'll take my reward now.」", 1
		    CALL LOST_MONEY_CM(QOL_GET_YEAR(DAY) * 150, 2) ;increases every year
        CASE 4
            CALL SPTALK, (FREE_MOB_SLOT(1)), "通常", 1, @"「Ya lost, so I'll take my reward now.」", 1
            IF !ITEM:DESIRED_TYPE
                CALL SPTALK, (FREE_MOB_SLOT(1)), "怒り", 1, @"「Ya don't even 'ave anything worth drinkin' on ya?」/「What a pathetic %PRINT_MALE("guy_:gal", MASTER)% ya are.」/「Get 'da hell outta here!」", 1
            ELSE
                CALL LOST_ITEM(ITEMNAME:DESIRED_TYPE, ITEM:DESIRED_TYPE, 2)
            ENDIF
    ENDSELECT
	RETURN 1
ELSE
    ;NAS: dead or unconscious challenger, should not talk.
    SIF !SHIRAHU(FREE_MOB_SLOT(1))
        RETURN
    IF DESIRED_REWARD == 0
        CALL SPTALK, (FREE_MOB_SLOT(1)), "通常", 1, @"「You're pretty strong. You'd fit right in with us oni.」/「If you're ever looking for a party, ya should go down to 'da Underground.」", 1
        PRINTFORMDW Despite her defeat, the oni has a huge smile on her face as she stands back up.
    ELSE
        CALL SPTALK, (FREE_MOB_SLOT(1)), "怒り", 1, @"「Gya. You're tougher 'den I figured ya for.」/「I'm outta 'ere.」", 1
        PRINTFORMDW The oni quickly makes her escape through one the many tunnels littered underground.
    ENDIF
ENDIF
