@QOL_CHECK_DANGEROUS_TRAVEL(TSP)
#DIM TSP
#DIM LUCK
#DIM ROLL
PRINTFORMDL You take a shortcut through some of the Underground's tunnels to save time.

LUCK = 300
LUCK += CFLAG:MASTER:今日の運勢
LUCK += TFLAG:幸運補正 * 100 ;daily fortune
LUCK += TFLAG:DangerousTravelBonus

SIF DAY:3 == 13 && YOUBI_MATCH(DAY, "金")
    LUCK -= 750
LUCK += LEVEL_TO_RANK(ABL:MASTER:教養) * 50
LUCK = MAX(LUCK, 1)

ROLL = RAND:LUCK

IF ROLL < (20 * MAX(TFLAG:DangerousTravelDisaster, 1)) ;very bad result, odds increase with a specific daily travel fortune
    CALL QOL_TRAVEL_MAJOR_ACCIDENT(TSP)
ELSEIF ROLL < 100 ;minor incident
    CALL QOL_TRAVEL_MINOR_ACCIDENT(TSP)
ENDIF

@QOL_TRAVEL_MINOR_ACCIDENT(TSP)
#DIM TSP
SELECTCASE RAND:5
    CASE 0
        PRINTFORMDL As you make your way through the narrow, dark corridors of the Underground, you end up stubbing your little toe on a rock.
        CALL RECOVER(MASTER, -MAX(100, QOL_UNBUFFED_MAXBASE(BASE_体力) / 20), "体力", "Ow!")
        WAIT
    CASE 1
        PRINTFORMDL While you traverse the poorly-lit tunnels of the Underground, you stumble over something, and fall flat onto the ground.
        CALL RECOVER(MASTER, -MAX(150, QOL_UNBUFFED_MAXBASE(BASE_体力) / 15), "体力", "Ow!")
        CALL RECOVER(MASTER, -MAX(150, QOL_UNBUFFED_MAXBASE(BASE_気力) / 15), "気力", "Ow!")
        IF TSP
            CALL RECOVER(MASTER, -30, "TSP", "Ow!")
        ELSE
            TIME += 10
        ENDIF
        WAIT
    CASE 2
        PRINTFORMDL While traveling through some of the Underground's lesser-known tunnels, you accidentally drop something.
        SELECTCASE RAND:3
            CASE 0
                CALL LOST_MONEY_YEN(2000, 2)
            CASE 1
                CALL LOST_MONEY_CM(20, 2)
            CASE 2
                IF TSP
                    CALL RECOVER(MASTER, -45, "TSP", "Searching in the dark")
                ELSE
                    TIME += 15
                ENDIF
                PRINTFORMDW Since it's quite important, you lose some time searching for it.
        ENDSELECT
    CASE 3
        IF TSP
            CALL RECOVER(MASTER, -60, "TSP", "Got lost")
        ELSE
            TIME += 20
        ENDIF
        PRINTFORMDW You end up getting lost while going through the caves, and it takes some time before you manage to escape.
    CASE 4
        PRINTFORMDL As you traverse the depths, you hear a loud sobbing echo throughout the caves.
        PRINTFORMDL Do you want to investigate it?
        CALL ASK_YN
        IF RESULT
            PRINTFORMDW You ignore the obvious trap and head straight for your destination.
        ELSE
            PRINTFORMDL Following the sound to its source, you find one of Eientei's rabbits sitting on her knees, bawling her eyes out.
            PRINTFORMDL After you manage to calm her down, she explains that %CALLNAME:72% had tasked her to deliver medicine to Youkai Mountain.
            PRINTFORMDL Since she fell behind schedule, she decided to take a shortcut through the Underground, but ended up getting lost.
            PRINTFORMDL Feeling sorry for her, you decide to help her out and lead her to her destination.
            PRINTFORMDL When you reach the surface, the rabbit girl gives you a warm hug before running off.
            PRINTFORMDL As you head towards your own destination once more, you realize that the rabbit slipped something into your pocket before she left.

            SELECTCASE RAND:4
                CASE 0
                    CALL GET_ITEM("栄養ドリンク", 1, 2)
                CASE 1
                    CALL GET_ITEM("精力剤", 1, 2)
                CASE 2
                    CALL GET_ITEM("ギンギンＺ", 1, 2)
                CASE 3
                    CALL GET_ITEM("ギンギラギンＸ", 1, 2)
            ENDSELECT

            CALL CHANGE_CFLAG(4,[[永琳]],10)
            CALL CHANGE_CFLAG(4,[[輝夜]],10)
            CALL CHANGE_CFLAG(4,[[てゐ]],10)
            CALL CHANGE_CFLAG(4,[[鈴仙]],10)
            WAIT
            TIME += 20
        ENDIF
ENDSELECT

@QOL_TRAVEL_MAJOR_ACCIDENT(TSP)
#DIM TSP

SELECTCASE RAND:3
    CASE 0
        CALL QOL_TRAVEL_MEET_ONI(TSP)
    CASE 1
        IF TSP
            CALL RECOVER(MASTER, -540, "TSP", "Got lost")
        ELSE
            TIME += 180
        ENDIF
        PRINTFORMDL While traversing the caves, you end up getting completely lost.
        PRINTFORMDW You lose a huge amount of time before you manage to get out.
    CASE 2
        PRINTFORML ...There's something happening in the cave.
        CALL COLORMESSAGE("!!! IT'S A CAVE IN !!!",C_RED,2,1)
        
        PRINTFORML 
        ;NAS Teleporting ESP and physical damage
        CALL YoujutsuMagicCanDo(MASTER,6,0)
        IF RESULT
            PRINTFORMW Luckily, with your Youjutsu powers, you were able to teleport to safety before you any damage could be done.
        ELSE
            CALLF BroadDamage(MASTER,"fullbody",MAX(10000, MULTIPLY(QOL_UNBUFFED_MAXBASE(BASE_体力), 90)),6,MASTER,"cave in")
            CALL CrippleEffects(MASTER)
            IF !IsDead:MASTER:0
                PRINTFORMW After five gruelling hours, you manage to crawl your way out, but the pain is immense...
                TIME += 300
                CALL RECOVER(MASTER, -MAX(10000, MULTIPLY(QOL_UNBUFFED_MAXBASE(BASE_体力), 90)), "体力", "Ow!")
                CALL RECOVER(MASTER, -MAX(10000, MULTIPLY(QOL_UNBUFFED_MAXBASE(BASE_気力), 90)), "気力", "Ow!")
            ENDIF
        ENDIF
ENDSELECT

