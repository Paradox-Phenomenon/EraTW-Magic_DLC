CFLAG:(FREE_MOB_SLOT(1)):デート中 = -1 ;bug fix, disable dating flag

IF TSP
    PRINTFORMDL While walking through the maze-like passages, you end up losing your balance and fall flat onto the ground. 
    PRINTFORMDW The shock causes you to lose control of the stopped time.
    SIF FLAG:70
        RESETBGCOLOR
    PRINTFORMDL As you stand back up, you suddenly notice a large figure standing in front of you.
    CALL SPTALK, (FREE_MOB_SLOT(1)), "通常", 1, @"「Who're you, and how'd ya get 'ere?」/「'dis ain't no place for 'umans, y'know?」", 1
ELSE
    PRINTFORMDW As you move through the tunnels, you suddenly notice a large and imposing figure standing in front of you.
    CALL SPTALK, (FREE_MOB_SLOT(1)), "通常", 1, @"「A 'uman, 'ere?」/「Did ya get lost down 'ere?」", 1
ENDIF
CALL SPTALK, FREE_MOB_SLOT(1), "笑顔", 1, @"「Well, I don't really care what you're doing 'ere, but 'dis is oni territory.」/「If you wanna pass through, ya gotta pay the toll, gya.」", 1
WAIT

IF RAND:300 < MIN(SUMARRAY(PROTECTORS_WEIGHTS), 100)
    ;friends in low places
    CHARA = PROTECTORS:ARRAY_HIT(PROTECTORS_WEIGHTS, 3)

    SELECTCASE CHARA
        CASE [[さとり]]
            CALL SPTALK, (FREE_MOB_SLOT(1)), "通常", 1, @"「Wait, ain'tcha 'dat Satori chick's pet 'uman?」", 1
            CALL SPTALK, (FREE_MOB_SLOT(1)), "怒り", 1, @"「Geh. Don't really wanna deal wit' 'er.」", 1
            CALL SPTALK, (FREE_MOB_SLOT(1)), "通常", 1, @"「Jus' run along, 'den. I ain't seen a t'ing.」", 1
            WAIT
            PRINTFORMDL Not waiting for the oni to change her mind, you stop time again and head for your destination once more.
        CASEELSE
            CALL SPTALK, (FREE_MOB_SLOT(1)), "通常", 1, @"「'old on, ain'tcha %CALLNAME:CHARA%'s friend?」/「She'd prob'ly get pretty mad if I were to mess wit' 'er buddy.」/「It's your lucky day, 'den. You're free to go through.」", 1
            IF FLAG:70
                CALL SPTALK, (FREE_MOB_SLOT(1)), "笑顔", 1, @"「I'll even help you out. Where were you-」", 1
                CALL SPTALK, (FREE_MOB_SLOT(1)), "通常", 1, @"「Eh, where'd 'e go?」", 1
                PRINTFORMDL Before the oni can finish her words, you stop time again and head for your destination once more.
            ELSE
                ;get escorted out
                CALL SPTALK, (FREE_MOB_SLOT(1)), "笑顔", 1, @"「I'll even help you out. Where were ya headed?」", 1
                PRINTFORMDL The oni leads you through the tunnels, and with her help, you make it to your destination even faster than expected.
                TIME -= 10
            ENDIF
    ENDSELECT
    PRINTFORMDW It seems that it pays to have friends down here.
ELSE
    SELECTCASE RAND:5
        CASE 0
            ;money
            LOCAL = QOL_GET_YEAR(DAY) * 10000 ;increases every year
            CALL SPTALK, (FREE_MOB_SLOT(1)), "通常", 1, @"「I need some booze money, so I'll let ya pass for {LOCAL} yen.」", 1
            CALL ASK_YN("Accept", "Refuse")
            IF RESULT
                CALL SPTALK, (FREE_MOB_SLOT(1)), "怒り", 1, @"「'tink you're a tough guy, eh? Guess I'll hafta put a little fear of the oni in ya and take the money off your corpse.」", 1
