    CHARA = PROTECTORS:LOCAL
    PROTECTORS_WEIGHTS:LOCAL += CBRT(CFLAG:CHARA:好感度)
    SIF TALENT:CHARA:恋人
        PROTECTORS_WEIGHTS:LOCAL += 20
    PROTECTORS_WEIGHTS:LOCAL += 5 * TALENT:CHARA:恋慕
    PROTECTORS_WEIGHTS:LOCAL += 5 * TALENT:CHARA:愛欲
NEXT

