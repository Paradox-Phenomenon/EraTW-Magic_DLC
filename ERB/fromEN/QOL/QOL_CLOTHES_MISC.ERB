@SET_EVENT_CLOTHES(C_ID, SET_ID)
#DIM C_ID
#DIM SET_ID
;show a warning if a nonexisting clothing set is called
SIF !GET_EXIST("衣装セット", SET_ID)
    PRINTFORMDL ＊WARNING＊: Clothing set {SET_ID} does not exist. %CALLNAME:C_ID% will be nude.
TCVAR:C_ID:EVENT_CLOTHING_SET = SET_ID

@RESET_EVENT_CLOTHES(C_ID)
#DIM C_ID
TCVAR:C_ID:EVENT_CLOTHING_SET = 0
