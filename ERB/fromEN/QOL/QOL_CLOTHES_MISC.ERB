@SET_EVENT_CLOTHES(C_ID, SET_ID)
#DIM C_ID
#DIM SET_ID
#LOCALSIZE 1
#LOCALSSIZE 1
;show a warning if a nonexisting clothing set is called
SIF INRANGE(SET_ID, 0, OBJ_ID_LAST) && !GET_EXIST("衣装セット", SET_ID)
	PRINTFORMDL ＊WARNING＊: Clothing set {SET_ID} does not exist. %CALLNAME:C_ID% will be nude.
TCVAR:C_ID:EVENT_CLOTHING_SET = SET_ID
CALL SET_CURRENT_CLOTHES_VALUES(C_ID)
CALL CHANGE_CLOTHES(C_ID, "复原衣服")
CALL CLOTHES_SETTING_TRAIN(C_ID)

@RESET_EVENT_CLOTHES(C_ID)
#DIM C_ID
#LOCALSIZE 1
#LOCALSSIZE 1
TCVAR:C_ID:EVENT_CLOTHING_SET = 0
CALL SET_CURRENT_CLOTHES_VALUES(C_ID)
CALL CHANGE_CLOTHES(C_ID, "复原衣服")
CALL CLOTHES_SETTING_TRAIN(C_ID)

@SET_CURRENT_CLOTHES_VALUES(C_ID)
#DIM C_ID
#DIM SET_ID
#LOCALSIZE 2
#LOCALSSIZE 1
SET_ID = CURRENT_CLOTHES_SET(C_ID)

IF SET_ID > 套装范围
	LOCAL:1 = SET_ID - 套装范围
	FOR LOCAL, 1, 23
		CFLAG:C_ID:(200 + LOCAL) = GET_INT(C_ID, "キャラデータ", LOCAL:1, @"便装：%EQUIPNAME:LOCAL%")
	NEXT
ELSE
	FOR LOCAL, 1, 23
		CFLAG:C_ID:(200 + LOCAL) = GET_INT(C_ID, "衣装セット", SET_ID, EQUIPNAME:LOCAL)
	NEXT
ENDIF

;为任何事件时点设计的换装行为
;行为同换装系统，无需关心换回衣服的时点  暂时只设计换上套装，因为只有套装才有立绘支持。
@EVENT_设置暂时变更套装(SET_ID,C_ID = -1)
#DIM DYNAMIC C_ID
#DIM DYNAMIC SET_ID
#LOCALSIZE 1
#LOCALSSIZE 1
SIF C_ID == -1
	C_ID = TARGET
IF STRLENS(GET_STR(C_ID, "衣装セット", SET_ID, "名前"))
	FOR LOCAL, 1, 23
		EQUIP:C_ID:(LOCAL) = GET_INT(C_ID, "衣装セット", SET_ID, EQUIPNAME:(LOCAL))
		CFLAG:C_ID:(600 + LOCAL) = EQUIP:C_ID:(LOCAL)
	NEXT
	CFLAG:C_ID:衣装一時変更 = 100
	CALL CLOTHES_SETTING_TRAIN(C_ID)
	RETURN 1
ENDIF
