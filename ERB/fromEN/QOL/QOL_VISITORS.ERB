				CALL QOL_VISITOR_CHECK_AREA(CHARA, 兎の洞穴)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 永遠亭)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 無名の丘)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 太陽の畑)
