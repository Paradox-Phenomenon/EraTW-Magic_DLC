ENDIF

FOR LOCAL, 1, CHARANUM
	SIF !CFLAG:LOCAL:神社在住
		CONTINUE
	SIF RELATION:CHARA:LOCAL > 100
		CALL QOL_VISITOR_ADD_FRIEND(CHARA, LOCAL, 10 + (RELATION:CHARA:LOCAL - 100) / 2)
NEXT

IF QOL_VISITORS_INDEX > 0
	LOCAL = ARRAY_HIT(QOL_VISITORS_LOCATION_WEIGHTS, QOL_VISITORS_INDEX)
	TCVAR:CHARA:INITIAL_VISITATION_POINT = QOL_VISITORS_POSSIBLE_LOCATIONS:LOCAL
ENDIF

