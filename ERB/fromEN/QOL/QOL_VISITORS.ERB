			CALL QOL_VISITOR_CHECK_AREA(CHARA, 大衆浴場)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 長屋街)
		CASE MAP湖
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 霧の湖)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 廃洋館)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 正門)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 広間)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 食堂)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 大図書館)
		CASE MAP竹林
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 竹林入り口)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 迷いの小道)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 斜角の竹林)
