				CALL QOL_VISITOR_CHECK_AREA(CHARA, 永遠亭奥ノ院)
			SIF !INRANGE(RELATION:CHARA:[[幽香]], 1, 99)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 夢幻館)
		CASE MAP森
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 森の入り口)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 香霖堂)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 古木の大樹)
			SIF !INRANGE(RELATION:CHARA:[[魔理沙]], 1, 99)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 霧雨魔法店)
			SIF !INRANGE(RELATION:CHARA:[[アリス]], 1, 99)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 人形の洋館)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 再思の道)
