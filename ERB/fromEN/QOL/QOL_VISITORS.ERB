@QOL_VISITOR_LOCATION_SELECTION(CHARA, COMPANION)
#DIM CHARA
#DIM CHARA2
#DIM DYNAMIC COMPANION
IF COMPANION && TCVAR:COMPANION:INITIAL_VISITATION_POINT
	TCVAR:CHARA:INITIAL_VISITATION_POINT = TCVAR:COMPANION:INITIAL_VISITATION_POINT
	RETURN
ENDIF

VARSET QOL_VISITORS_POSSIBLE_LOCATIONS
VARSET QOL_VISITORS_LOCATION_WEIGHTS
VARSET QOL_VISITORS_INDEX

FOR LOCAL, MAIN_MAP * 100 + 10, MAIN_MAP * 100 + 100, 10
	RESULT = 0
	RESULT:1 = 0
	CALL KOJO_CHECK(CHARA, "CHARADATA", "MOVE", 7, LOCAL)
	IF RESULT
		RESULT = RESULT:1
	ELSE
		CALLFORM CHARAMOVE_DATA_{NO:CHARA}(7, LOCAL)
	ENDIF 
	SIF !RESULT
		CONTINUE

	CALL QOL_VISITOR_CHECK_AREA(CHARA, LOCAL)
NEXT

IF QOL_VISITORS_INDEX == 0
	SELECTCASE MAIN_MAP
		CASE MAP神社
			IF !INRANGE(RELATION:CHARA:[[霊夢]], 1, 99)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 桜並木の鳥居)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 神社境内)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 神社本堂)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 神社縁側)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 桜並木の鳥居)
			ENDIF
			SIF TALENT:CHARA:妖精
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 妖精の大樹)
			SIF !INRANGE(RELATION:CHARA:[[夢美]], 1, 99) && ABL:CHARA:教養 > 2
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 夢幻遺跡)
		CASE MAP寺
			CALL QOL_VISITOR_CHECK_AREA(CHARA, お地蔵通り)
			IF !INRANGE(RELATION:CHARA:[[白蓮]], 1, 99)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 命蓮寺境内)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 命蓮寺方丈)
			ENDIF
			IF !INRANGE(RELATION:CHARA:[[神子]], 1, 99)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 神霊廟広場)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 神霊廟道場)
			ENDIF
