@QOL_VISITOR_ADD_LOCATION(CHARA, LOCATION, WEIGHT)
#DIM CHARA
#DIM LOCATION
#DIM WEIGHT
SIF QOL_VISITORS_INDEX >= QOL_VISITORS_MAXLOCATION
	RETURN
SIF WEIGHT <= 0
	RETURN
SIF !MAP_CAN_MOVE(LOCATION, CHARA)
	RETURN

RESULT:1 = 0
CALL KOJO_CHECK(CHARA, "CHARADATA", "MOVE", 4, LOCATION)
IF RESULT
	RESULT = RESULT:1
ELSE
	CALLFORM CHARAMOVE_DATA_{NO:CHARA}(4, LOCATION)
ENDIF 
SIF RESULT < 0
	RETURN

QOL_VISITORS_POSSIBLE_LOCATIONS:QOL_VISITORS_INDEX = LOCATION
QOL_VISITORS_LOCATION_WEIGHTS:QOL_VISITORS_INDEX = WEIGHT
QOL_VISITORS_INDEX++

@QOL_VISITOR_ADD_FRIEND(CHARA, FRIEND, WEIGHT)
#DIM CHARA
#DIM FRIEND
#DIM WEIGHT
SIF QOL_VISITORS_INDEX >= QOL_VISITORS_MAXLOCATION
	RETURN
SIF WEIGHT <= 0
	RETURN

QOL_VISITORS_POSSIBLE_LOCATIONS:QOL_VISITORS_INDEX = FRIEND * -1
QOL_VISITORS_LOCATION_WEIGHTS:QOL_VISITORS_INDEX = WEIGHT
QOL_VISITORS_INDEX++
