				CALL QOL_VISITOR_CHECK_AREA(CHARA, 白玉楼庭)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 白玉楼)
			ENDIF
			IF CHECK_CHARA(CHARA, "月人") && !CHECK_CHARA(CHARA, "蓬莱人")
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 彼岸)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 地獄)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 畜生界)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 霊長園)
			ENDIF
		CASE MAP山麓
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 麓の樹海)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 玄武の沢)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 大蝦蟇の池)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 正邪の隠れ家前)
			SIF ABL:CHARA:教養 >= 3 && ABL:CHARA:戦闘能力 >= 3 && !INRANGE(RELATION:CHARA:[[華扇]], 1, 99)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 仙人の屋敷)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 森の深奥)
			IF ABL:CHARA:教養 >= 3 && !INRANGE(RELATION:CHARA:[[姥芽]], 1, 99)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 圣域)
			ENDIF
			IF (ABL:CHARA:教養 >= 3 && !INRANGE(RELATION:CHARA:[[维缦]], 1, 99)) || CHARA == [[丰姬]]
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 浅间净秽山)
			ENDIF
		CASE MAP山頂
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 九天の滝)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 絶景の丘)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 山の湖)
			IF !INRANGE(RELATION:CHARA:[[神奈子]], 1, 99) && !INRANGE(RELATION:CHARA:[[诹访子]], 1, 99)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 守矢神社境内)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 守矢神社本殿)
			ENDIF
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 虹龍洞)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 天界)
		CASE MAP地底
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 幻想風穴)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 地獄の深道)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 旧地獄街道)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 旧地獄温泉)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 地霊殿)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 灼熱地獄跡)
		CASE MAP月
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 槐安通路)
			IF !CHECK_CHARA(CHARA, "妖精")
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 月の都)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 綿月亭)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 玉兎の街)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 桃林～砂浜)
			ENDIF
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 静かの海)
		CASE MAP魔界
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 魔界都市)
			SIF !INRANGE(RELATION:CHARA:[[神绮]], 1, 99)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 万魔殿)
			SIF !INRANGE(RELATION:CHARA:[[依莉斯]], 1, 99) || !INRANGE(RELATION:CHARA:[[萨丽爱尔]], 1, 99)
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 堕落神殿)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 冰雪世界)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 法界)
