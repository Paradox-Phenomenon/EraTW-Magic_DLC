			CALL QOL_VISITOR_CHECK_AREA(CHARA, 中有の道)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 三途の川)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, マヨヒガ)
