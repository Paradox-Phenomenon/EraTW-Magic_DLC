			CALL QOL_VISITOR_CHECK_AREA(CHARA, 広場)
			CALL QOL_VISITOR_CHECK_AREA(CHARA, 商家町)
			SIF TALENT:CHARA:酒耐性 != -2
				CALL QOL_VISITOR_CHECK_AREA(CHARA, 呑屋小道)
