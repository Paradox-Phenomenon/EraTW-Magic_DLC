	TFLAG:193 = 0
ENDIF

DOWNBASE:気力 += 10

CALL RECOVER_PERMIL(MASTER, 150, "体力", 0, "通过进餐的回复")
CALL RECOVER_PERMIL(MASTER, 300, "気力", 0, "通过进餐的回复")
CALL RECOVER_PERMIL(MASTER, 100, "精力", 0, "通过进餐的回复")

TIME += 60
EXP:MASTER:デート経験 ++
CALL 満腹度上昇(MASTER,"主食")
MONEY -= 1500 + (NumberOfDates * 1500)
回復後体力１ = BASE:MASTER:体力
回復後気力１ = BASE:MASTER:気力
TARGET = TEMP

