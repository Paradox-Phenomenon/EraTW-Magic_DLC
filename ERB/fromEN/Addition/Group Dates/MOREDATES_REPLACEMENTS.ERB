@MOREDATES_CABLEWAY(FEE)
#DIM FEE
#DIM RandomResponse, 8 ; same lenght as below array
#DIM ResponseCharacters = 10, 29, 31, 32, 33, 42, 64, 65
#DIM MoriyaCount
#DIM RandomCount

RandomResponse = 0
MoriyaCount = 0
RandomCount = 0

FOR LOCAL:10, 0, 8
	IF IS_IN_GROUP_DATE(ResponseCharacters:(LOCAL:10))
		SIF GROUPMATCH((ResponseCharacters:(LOCAL:10)),31,32,33)
			MoriyaCount += 1
		RandomResponse:RandomCount = ResponseCharacters:(LOCAL:10)
		RandomCount += 1
	ENDIF
NEXT
; check for all 3 moriyas
IF MoriyaCount == 3
	LOCAL = 12 + ((GET_MAPID(CFLAG:MASTER:現在位置) == 8) * 4)
	CALL SPTALK, 0, "通常", LOCAL, @"「咦？%CALLNAME:32%、%CALLNAME:33%和%CALLNAME:31%？她们都离那个\@ IS_MALE(MASTER) ? 小子 # 姑娘\@那么近是在干什么？」",1
	CALL SPTALK, 0, "笑顔", LOCAL, @" [呃，没有，你们是集体出游吗？]", 1
	PRINTFORM 虽然被吓了一跳，但
	;人里側に河童が常駐してるのもアレかなと
	IF GET_MAPID(CFLAG:MASTER:現在位置) == 2
		PRINTFORM 河童
	ELSE
		PRINTFORM 接待员
	ENDIF
	PRINTFORML 迅速挤出营业笑容。
; check for any character with response
ELSEIF RandomCount > 0
	LOCAL:5 = RandomResponse:(RAND:RandomCount)
	LOCAL = 12 + ((GET_MAPID(CFLAG:MASTER:現在位置) == 8) * 4)
	CALL SPTALK, 0, "笑顔", LOCAL, @"「这不是%CALLNAME:(LOCAL:5)%吗，你也来玩吗？」",1
	PRINTFORM 一看到%CALLNAME:(LOCAL:5)%，
	;人里側に河童が常駐してるのもアレかなと
	IF GET_MAPID(CFLAG:MASTER:現在位置) == 2
		PRINTFORM 河童
	ELSE
		PRINTFORM 接待员
	ENDIF
	PRINTFORML 就挤出营业笑容。
; default
ELSE
	;人里側では一応丁寧対応に
	IF GET_MAPID(CFLAG:MASTER:現在位置) == 2
		CALL SPTALK, 0, "通常", 12, @"「哦，看来是团体郊游吗！」/「抱歉，我们不提供折扣，费用是¥{FEE * 200}！{FEE}枚筹码也可以。」",1
	ELSE
		CALL SPTALK, 0, "憤怒", 16, @"「真是个花花公子啊，嗯？」/「没有折扣。{FEE}枚筹码。¥{FEE * 200}也可以。」",1
	ENDIF
	SIF NumberOfDates > 9
		CALL SPTALK, 0, "通常", GET_MAPID(CFLAG:MASTER:現在位置) == 2 ? 12 # 16, @"「…为了安全起见，需要排着队上去哦。」",1	
	;qol custom code
	SIF TIME >= 1020 && FEE != 1
		CALL SPTALK, 0, "笑顔", GET_MAPID(CFLAG:MASTER:現在位置) == 2 ? 12 # 16, @"「哈欠…工作到这么晚，真想多收你点钱。」",1	
ENDIF

@MOREDATES_HOUSE_EXIT(ARG)
#DIM OTHERMOVE
;remove everyone else
FOR LOCAL, 1, CHARANUM
	IF CFLAG:LOCAL:お招き
		;restore original locations (where they start the day)
		IF CFLAG:LOCAL:神社在住
			CFLAG:LOCAL:初期位置 = CFLAG:LOCAL:神社在住
		ELSE
			CFLAG:LOCAL:初期位置 = SUKIMA()
		ENDIF
		;check if character belongs to this map, else send them back home
		IF GET_MAPID(ARG) != CFLAG:LOCAL:よく行く地域 && !IS_IN_GROUP_DATE(LOCAL)
			IF CFLAG:LOCAL:よく行く地域 != -1
				OTHERMOVE = GET_ENTRANCE(CFLAG:LOCAL:よく行く地域)
			ELSE
				OTHERMOVE = CFLAG:LOCAL:初期位置
			ENDIF
		ELSE
			OTHERMOVE = ARG
		ENDIF

		;三种不同的消息/结果：
		;与你一同离开（如果正在约会或他们住在该地图）
		;回家（否则他们会因为在不是自己的地图上移动导致软性中断而整天闲逛）
		;留在招待室睡觉 - 顺便说一句，这里可以改为让他们不要在其他角色的家里睡觉
		;对此的检查将在 SLEEP.ERB 中，我们可以通过 お招き 和 HouseInvitationStatus 来确保
		IF !CFLAG:LOCAL:睡眠 ; 角色移动，要么到他们自己的家，要么到外面
			CFLAG:LOCAL:現在位置 = OTHERMOVE
			IF OTHERMOVE == ARG  
				PRINTFORML %CALLNAME:LOCAL% 和你一起出来了。
			ELSE
				PRINTFORML %CALLNAME:LOCAL% 回家了。
			ENDIF
		ELSE ; 留在里面睡觉，原版游戏的默认行为是保持约会状态，所以我们照此复制
			CFLAG:LOCAL:現在位置 = SUKIMA()
			PRINTFORML %CALLNAME:LOCAL% 留在里面睡觉了。
		ENDIF
		CFLAG:LOCAL:遭遇位置 = OTHERMOVE ; 设置移动位置，以便可以进行见面对话
		CFLAG:LOCAL:お招き = 0	; 移除留在原地的标志
	ENDIF
NEXT

@MOREDATES_HOUSE_VISIT(ARG)
; 询问
PRINTFORML 其他约会对象也要一起来吗？
CALL ASK_YN("和大家一起去","独自一人造访")
; 也许可以添加某种同意检查
IF !RESULT ; 0 - 和大家一起去
	PRINTFORMW 你带着%GET_DATEES_NAMES(ARG,1)%一起造访了。
	FOR LOCAL, 0, NumberOfDates
		; 物理移动（并防止徘徊、要求离开等）
		CFLAG:(Datees:LOCAL):お招き = ARG
		CFLAG:(Datees:LOCAL):初期位置 = OMANEKIBEYA()
		CFLAG:(Datees:LOCAL):現在位置 = OMANEKIBEYA()
		;SIF (Datees:LOCAL) != ARG
			;CALL KOJO_MESSAGE_SEND("EVENT",1,(Datees:LOCAL),1010,ARG)
	NEXT
	;CALL KOJO_MESSAGE_SEND("EVENT",1,ARG,1012,GET_RANDOM_DATE)
	SIF HouseInvitationStatus ; 如果约会结束，则移除所有人的约会状态
		CALL CLEAN_GROUP_DATES
ELSE
	PRINTFORMW 你在结束约会后准备和%CALLNAME:ARG%享受私人时光。
	;FOR LOCAL, 0, NumberOfDates
		;SIF (Datees:LOCAL) != ARG 
			;CALL KOJO_MESSAGE_SEND("EVENT",1,(Datees:LOCAL),1011,ARG)
	;NEXT
	CALL CLEAN_GROUP_DATES
	SIF !HouseInvitationStatus ; 如果约会是在开始/中期，则将房主重新添加到约会中
		CALL ADD_TO_GROUP_DATE(ARG)
ENDIF
;set focus on room owner
IF !HouseInvitationStatus
	FLAG:デート相手 = ARG
	FOR LOCAL, 0, NumberOfDates
		IF Datees:LOCAL == ARG
			TFLAG:デート前好感度 = DatesPrevLike:LOCAL
			BREAK
		ENDIF
	NEXT
ENDIF
TARGET = ARG


@MOREDATES_SOUVENIR
#DIM CANBUY
#DIM TEMP,3
SIF SELECTCOM != 626 || NumberOfDates < 2 || !MOREDATE
	RETURN
TEMP:0 = TARGET
TEMP:1 = TFLAG:97
TEMP:2 = TFLAG:98
$TOP
; Check if everyone already has something
CANBUY = 0
FOR LOCAL, 0, NumberOfDates
	IF !TCVAR:(Datees:LOCAL):今日の贈り物
		CANBUY = 1
	ENDIF
NEXT
IF CANBUY
	PRINTFORML 
	PRINTFORML 要给其他人也买些什么吗？
	PRINTFORML 
	FOR LOCAL, 0, NumberOfDates
		IF Datees:LOCAL != TARGET && !TCVAR:(Datees:LOCAL):今日の贈り物 ; 只能给今天还没收到礼物的人买
			PRINTFORML [{(Datees:LOCAL), 3}] - 也给%CALLNAME:(Datees:LOCAL)%买点东西
		ENDIF
	NEXT
	PRINTFORML 
	PRINTFORML [999] - 不买
	$INPUT_LOOP
	INPUT

	SIF (RESULT != 999 && RESULT >= CHARANUM) || RESULT < 1
		GOTO INPUT_LOOP
	SIF RESULT != 999 && (!IS_IN_GROUP_DATE(RESULT) || TCVAR:RESULT:今日の贈り物)
		GOTO INPUT_LOOP

	IF RESULT != 999 && IS_IN_GROUP_DATE(RESULT) && !TCVAR:RESULT:今日の贈り物
		TARGET = RESULT
		TFLAG:97 = 0
		TFLAG:98 = 0
		CALL COM626
		CALL MESSAGE_COM626
		SIF !nSkipKojo
			CALL KOJO_MESSAGE_SEND("COMMAND",-1,TARGET,-1,-1)
		; 30/10 minutes per buy seems a little harsh so let's reduce it by 80% as bulk purchases
		TIME -= !FLAG:TIME_COMPRESSION ? 24 # 8
		; simulate end of turn, do gems/favor/trust
		CALL FAVOR_CALC(TARGET)
		CALL TRUST_CALC(TARGET)
		CALL SOURCE_歓楽(TARGET)
		CALL SOURCE_受動(TARGET)
		CALL SOURCE_征服(TARGET)
		; 重置以避免无限指数增长
		SOURCE:歓楽 = 0
		SOURCE:受動 = 0
		SOURCE:征服 = 0
		GOTO TOP
	ENDIF
ENDIF
TARGET = TEMP:0
TFLAG:97 = TEMP:1
TFLAG:98 = TEMP:2

