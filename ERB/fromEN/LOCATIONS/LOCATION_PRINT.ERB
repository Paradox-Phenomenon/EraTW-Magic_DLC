;prints locations the player can go to, either one, or multiple
;if ARG:1 isn't specified it prints just one
;if ARG:1 is specified it prints all from ARG to ARG:1
@PRINT_DESTINATION(ARG, ARG:1 = -1)
SIF ARG:1 < 0
	ARG:1 = ARG

FOR LOCAL, ARG, ARG:1+1
	SIF CFLAG:MASTER:現在位置 == 100*MAIN_MAP+LOCAL ;highlight current location
		SETCOLOR C_AQUA
	PRINTBUTTON @"[{LOCAL}] - %STR_TR(8000+100*MAIN_MAP+LOCAL)% ",100*MAIN_MAP+LOCAL
	RESETCOLOR
NEXT