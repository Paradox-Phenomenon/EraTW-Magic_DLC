		PRINTBUTTON "[出産する際、必ず複数産む]", 986
		PRINT   
		PRINTBUTTON "[産卵する際、必ず単数産む]", 987
		PRINT   
		PRINTBUTTON "[産卵する際、必ず複数産む]", 988
		PRINTL
		PRINTBUTTON "[全員デフォルト]", 989
		PRINTL
		PRINTL
