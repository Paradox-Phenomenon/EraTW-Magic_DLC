		CALL COLORMESSAGE("多胎   ", COLOR_LITTERS, 0)
		CALL COLORMESSAGE("産卵（単） ", COLOR_EGG_LAYERS, 0)
		CALL COLORMESSAGE("産卵（複）", COLOR_CLUTCHERS, 0)
		PRINTL
		PRINTL
		PRINTBUTTON "[全員通常の妊娠]", 980
		PRINT   
		PRINTBUTTON "[全員多胎]", 981
		PRINT   
		PRINTBUTTON "[全員産卵（単）]", 982
		PRINT   
		PRINTBUTTON "[全員産卵（複）]", 983
		PRINTL
		PRINTBUTTON "[多胎なし]", 984
		PRINT   
		PRINTBUTTON "[産卵なし]", 985
