			CASE 988
				FOR LOCAL,1,CHARANUM
					SIF TALENT:LOCAL:PREGNANCY_TYPE == PREGNANCY_EGGS
						TALENT:LOCAL:PREGNANCY_TYPE = PREGNANCY_CLUTCH
				NEXT
				PRINTFORMDW 産卵するキャラは複数産むようになりました
			CASE 989
				FOR LOCAL,1,CHARANUM
					TALENT:LOCAL:PREGNANCY_TYPE = PREGNANCY_CHARA_DEFAULT(LOCAL)
				NEXT
				PRINTFORMDW 全員デフォルトにしました
			CASEELSE
		ENDSELECT
		GOTO MANUALSETTING
	CASE 1
		IF FLAG:CHILD_SUPPORT_RELIEF
			PRINTFORMDW 複数児出産するキャラには通常の養育費がかかります。
		ELSE
			PRINTFORMDW 複数児出産するキャラには子供の数ごとに養育費がかかります（ひとり頭1/3）。
		ENDIF
		FLAG:CHILD_SUPPORT_RELIEF = !FLAG:CHILD_SUPPORT_RELIEF
	CASE 2
		IF FLAG:MOB_PREGNANCY_TYPES
			PRINTFORMDW 新規作成されたモブキャラは通常の妊娠をします。
		ELSE
			PRINTFORMDW 新規作成されたモブキャラは種族に応じた妊娠タイプになります。
		ENDIF
		FLAG:MOB_PREGNANCY_TYPES = !FLAG:MOB_PREGNANCY_TYPES
	CASE 3
		IF FLAG:EGGNANCY
			PRINTFORMDW 卵生キャラは受精後に有精卵を産みます。
		ELSE
			PRINTFORMDW 卵生キャラは卵胎生になります。
		ENDIF
		FLAG:EGGNANCY = !FLAG:EGGNANCY
	CASE 4
		PRINTFORML 双子が生まれる確率を入力してください(0-100)。 現在 {FLAG:TWINS_CHANCE}\%.
		CALL INPUT_RANGE(0, 100)
		FLAG:TWINS_CHANCE = RESULT
	CASE 5
		PRINTFORML 三つ子が生まれる確率を入力してください(0-100)。 現在 {FLAG:TRIPLETS_CHANCE}\%.
		CALL INPUT_RANGE(0, 100)
		FLAG:TRIPLETS_CHANCE = RESULT
	CASE 6
		PRINTFORMDL
		CALL D_LINE
		PRINTFORMDL
		PRINTFORMDL 妊娠タイプを設定できます。
		PRINTFORMDL
		PRINTFORMDL 通常 - 基本的に一児を出産します。。双子、三つ子が生まれることもあります。
		PRINTFORMDL 多胎 - 一度に2～6子を出産します。
		PRINTFORMDL 産卵（単） - 受精後すぐに産卵し、ふ化まで世話をします。この間にも受精することがあります。
		PRINTFORMDL 産卵（複） - 一度に2～6個産卵します。
		PRINTFORMDL
		PRINTFORMDL 陥落後の産卵キャラはデート終了時に無精卵をくれることがあります。
		PRINTFORMDL
		PRINTFORMDL 子ども手当を有効にすると、多産キャラの養育費が、通常の¥1000から一人頭¥330になります。
		PRINTFORMDL 平均値でいえばおおよそ同額になるでしょう。
		PRINTFORMDL
		PRINTFORMDL 懐卵オプションをオンにすると、卵生キャラはすぐには産卵せず体内に卵を保持し、外見的には妊娠と同じになります。
		PRINTFORMDL 産卵はふ化直前に行います。無精卵をくれるイベントはちゃんと発生します。
		WAIT
	CASE 7
		PRINTL
		PRINTFORMDL 特殊妊娠設定をリセットしてデフォルトに戻しますか？まだ生まれていない子供が消えることはありません。
		PRINTL
		CALL ASK_YN
		IF !RESULT
			CALL PREGNANCY_TYPES_NEWGAME_SET
			FLAG:CHILD_SUPPORT_RELIEF = 1
			FLAG:MOB_PREGNANCY_TYPES = 1
			FLAG:EGGNANCY = 0
			FLAG:TWINS_CHANCE = 10
			FLAG:TRIPLETS_CHANCE = 2
		ENDIF
	CASE 8
		PRINTL
		PRINTFORMDL 特殊妊娠をすべて無効化し、全員通常妊娠にしますか？まだ生まれていない子供が消えることはありません。
		PRINTL
		CALL ASK_YN
		IF !RESULT
			FOR LOCAL,1,CHARANUM
				TALENT:LOCAL:PREGNANCY_TYPE = PREGNANCY_NORMAL
			NEXT
			FLAG:MOB_PREGNANCY_TYPES = 0
