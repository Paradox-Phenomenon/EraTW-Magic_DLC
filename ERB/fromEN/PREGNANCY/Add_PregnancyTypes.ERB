#DIM CONST COLOR_CLUTCHERS = 0xF0E442 ; Yellow
	;Pregnancy type settings menu, accessible through new game or modded options.
STARTLINECOUNT:0 = LINECOUNT
$TOP
CLEARLINE LINECOUNT - STARTLINECOUNT:0
PRINTFORMDL
CALL D_LINE
PRINTFORMDL
PRINTFORMDL [0] 全員手動設定
PRINTFORMDL
PRINTFORMDL [1] 多産キャラへの子ども手当: \@ FLAG:CHILD_SUPPORT_RELIEF ? ON # OFF \@
PRINTFORMDL [2] モブキャラ特殊妊娠: \@ FLAG:MOB_PREGNANCY_TYPES ? ON # OFF \@
