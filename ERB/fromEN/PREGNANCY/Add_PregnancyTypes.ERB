@PREGNANCY_TYPE_OPTIONS
#DIM DYNAMIC STARTLINECOUNT,2
#DIM DYNAMIC MANUAL_CHARA_RESULT
#DIM CONST COLOR_NORMAL = 0x6A7783 ; Gray
#DIM CONST COLOR_LITTERS = 0x03B484 ; Green
