			CASE 987
				FOR LOCAL,1,CHARANUM
					SIF TALENT:LOCAL:PREGNANCY_TYPE == PREGNANCY_CLUTCH
						TALENT:LOCAL:PREGNANCY_TYPE = PREGNANCY_EGGS
				NEXT
