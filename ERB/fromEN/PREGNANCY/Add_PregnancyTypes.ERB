			CASE 983
				CVARSET TALENT, GETNUM(TALENT, "PREGNANCY_TYPE"), PREGNANCY_CLUTCH
				PRINTFORMDW 全員産卵するようになりました
			CASE 984
				FOR LOCAL,1,CHARANUM
					SIF TALENT:LOCAL:PREGNANCY_TYPE == PREGNANCY_LITTERS
						TALENT:LOCAL:PREGNANCY_TYPE = PREGNANCY_NORMAL
				NEXT
