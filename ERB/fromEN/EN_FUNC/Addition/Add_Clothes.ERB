@EXIST_衣装セット93
#LOCALSIZE 1
#LOCALSSIZE 1

@衣装セット93(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	CALLF MAKE_STR(V_NAME, "魔理沙睡衣套装")
CASE "角色特殊服装集"
	CALLF MAKE_INT(V_NAME, 1)
;こっから衣装设定系
CASE "上半身内衣１"
	CALLF MAKE_INT(V_NAME, 13)
CASE "襪子"
	IF FLAG:2 > 0
		CALLF MAKE_INT(V_NAME, CLOTHES_ID("襪子", "吊带袜"))
	ELSE
		CALLF MAKE_INT(V_NAME, CLOTHES_ID("襪子", "袜子"))
	ENDIF
ENDSELECT

