CALL ADD_SEX_MODULE_COM_ABLE
SIF !RESULT
	RETURN 0

;检查技巧
FOR LOCAL, 0, 2
	SIF ABL:(ADD_SEX_MODULE_CHARA:LOCAL):足 < 3
		RETURN 0
NEXT

RETURN 1

