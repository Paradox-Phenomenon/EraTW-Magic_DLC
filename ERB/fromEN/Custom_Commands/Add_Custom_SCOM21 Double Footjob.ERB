@ADD_CUSTOM_MESSAGE_SCOM21
#DIM SKILL_DIFFERENCE

SKILL_DIFFERENCE = (ABL:(ADD_SEX_MODULE_CHARA:0):足 * 3 + ABL:(ADD_SEX_MODULE_CHARA:0):技巧) - (ABL:(ADD_SEX_MODULE_CHARA:1):足 * 3 + ABL:(ADD_SEX_MODULE_CHARA:1):技巧)

IF NOWEX:MASTER:射精
	PRINTFORMDL 感受到%CALLNAME:MASTER%射精的征兆，%CALLNAME:(ADD_SEX_MODULE_CHARA:0)%和%CALLNAME:(ADD_SEX_MODULE_CHARA:1)%加快玉足的套弄，将%CALLNAME:MASTER%推向高潮。
ELSE
	IF TALENT:PLAYER:双槍
		IF ADD_PREV_SELECTED_SCOM == 21
			PRINTFORMDL %CALLNAME:(ADD_SEX_MODULE_CHARA:0)%和%CALLNAME:(ADD_SEX_MODULE_CHARA:1)%继续用柔软玉足配合侍奉%CALLNAME:MASTER%的两根肉棒。
		ELSE
			PRINTFORMDL %CALLNAME:(ADD_SEX_MODULE_CHARA:1)%的玉足夹住一根时，%CALLNAME:(ADD_SEX_MODULE_CHARA:0)%也伸出另一双玉足缠上。
		ENDIF

		IF ABL:(ADD_SEX_MODULE_CHARA:0):技巧 > 4 && ABL:(ADD_SEX_MODULE_CHARA:0):足 > 3 && ABL:(ADD_SEX_MODULE_CHARA:1):技巧 > 4 && ABL:(ADD_SEX_MODULE_CHARA:1):足 > 3
			PRINTFORMDL 她们足技娴熟，节奏完美契合，肉棒涌起层层快感。
		ELSEIF SKILL_DIFFERENCE
			PRINTFORMDL %CALLNAME:(ADD_SEX_MODULE_CHARA:(SKILL_DIFFERENCE > 0 ? 1 # 0))%难以跟上%CALLNAME:(ADD_SEX_MODULE_CHARA:(SKILL_DIFFERENCE > 0 ? 0 # 1))%的步伐，带来奇妙的不平衡快感。
		ELSE
			PRINTFORMDL 她们动作尚显生涩，玉足偶尔碰撞错位。
		ENDIF
	ELSE
		IF ADD_PREV_SELECTED_SCOM == 21
			PRINTFORMDL %CALLNAME:(ADD_SEX_MODULE_CHARA:0)%和%CALLNAME:(ADD_SEX_MODULE_CHARA:1)%继续用玉足夹住%CALLNAME:MASTER%%TINKO(PLAYER, 1)%上下摩擦。
		ELSE
			PRINTFORMDL %CALLNAME:(ADD_SEX_MODULE_CHARA:0)%加入，用玉足一同侍奉%CALLNAME:MASTER%%TINKO(PLAYER, 1)%。
		ENDIF

		IF ABL:(ADD_SEX_MODULE_CHARA:0):技巧 > 4 && ABL:(ADD_SEX_MODULE_CHARA:0):足 > 3 && ABL:(ADD_SEX_MODULE_CHARA:1):技巧 > 4 && ABL:(ADD_SEX_MODULE_CHARA:1):足 > 3
			PRINTFORMDL 她们熟练地用脚心和脚趾交替刺激，带来滑腻至极的快感。
		ELSEIF SKILL_DIFFERENCE
			PRINTFORMDL %CALLNAME:(ADD_SEX_MODULE_CHARA:(SKILL_DIFFERENCE > 0 ? 1 # 0))%的足技稍逊，时不时与另一人动作相撞。
		ELSE
			PRINTFORMDL 两人配合还不熟练，玉足动作时有错开。
		ENDIF
	ENDIF

	IF ABL:(ADD_SEX_MODULE_CHARA:0):足 > 4 && ABL:(ADD_SEX_MODULE_CHARA:0):技巧 > 4 && ABL:(ADD_SEX_MODULE_CHARA:1):足 && ABL:(ADD_SEX_MODULE_CHARA:1):技巧 > 4 && !RAND:4
		PRINTFORMDL 她们偶尔用脚趾轻拨%FSYN("蛋蛋")%，增添别样刺激……
	ENDIF
ENDIF

@ASSISTANT_KOJO_CUSTOM_SCOM21
FOR LOCAL, 0, ADD_SEX_MODULE_ACTION_COUNT
	SIF ADD_SEX_MODULE_CHARA:LOCAL == TARGET
		CONTINUE
	CALL KOJO_MESSAGE_SEND("COMMAND_ASSISTANT",-1,ADD_SEX_MODULE_CHARA:LOCAL,-1,-1)
NEXT

@ADD_CUSTOM_SCOM_SET21
#DIM DYNAMIC H0
#DIM DYNAMIC H1

H0 = ADD_MASTER_POSE_TR(PLAYER, SET_LEG,SET_P)
H1 = ADD_MASTER_POSE_TR(PLAYER, SET_LEG,SET_P, 1)

SIF H0 <= 0 || H1 <= 0
	RETURN 0

SIF H0 == H1
	RETURN 0

ADD_SEX_MODULE_ACTOR:0 = PLAYER
ADD_SEX_MODULE_CHARA:0 = H0
ADD_SEX_MODULE_CHARA:1 = H1

RETURN 1

@ADD_CUSTOM_SCOM_MODULE21
CALL ADD_SEX_MODULE_START(21)
CALL ADD_SEX_MODULE_ADD_ACTION(SET_P, SET_LEG,,0)
CALL ADD_SEX_MODULE_ADD_ACTION(SET_P, SET_LEG,,1)
CALL ADD_SEX_MODULE_FINISH
