@ADD_CUSTOM_COM12
SIF EQUIP:連衣裙
	TFLAG:194 += 10000 / 10
SIF EQUIP:和服
	TFLAG:194 += 20000
SIF	EQUIP:TARGET:上身衣服１ || EQUIP:TARGET:上身衣服２
	TFLAG:194 += 1000
SIF EQUIP:TARGET:上半身内衣１ || EQUIP:TARGET:上半身内衣２
	TFLAG:194 += 100
SIF	EQUIP:TARGET:裤子 || EQUIP:TARGET:裙子
	TFLAG:194 += 10
SIF EQUIP:TARGET:下半身内衣１ || EQUIP:TARGET:下半身内衣２
	TFLAG:194 += 1
CALL TOUCH_RESET_T(TARGET)
CALL CTRL_CLOTHES_SET(TARGET, "現在衣装の変更_全裸")
CALL CLOTHES_SETTING_TRAIN(TARGET)
CALL CTRL_CLOTHES_SET(MASTER, "現在衣装の変更_全裸")
CALL CLOTHES_SETTING_TRAIN(MASTER)

;直接抄的爱抚环节的数值计算
IF FLAG:70 && !CFLAG:TARGET:344
	BASE:MASTER:TSP -= 20
	SOURCE:快Ｃ = 40
	SOURCE:快Ｂ = 40
	SOURCE:快Ｃ += ABL:PLAYER:指 * 4
	SOURCE:快Ｂ += ABL:PLAYER:指 * 4
	IF TALENT:PLAYER:器用な指
		TIMES SOURCE:快Ｃ , 1.50
		TIMES SOURCE:快Ｂ , 1.50
	ENDIF
	SIF HETEROSEX(TARGET,PLAYER)
		EXP:PLAYER:(50 + HETEROSEX(TARGET,PLAYER)) += 5
	SIF TALENT:PLAYER:猫舌
		EXP:PLAYER:嗜虐快楽経験 += 1
	EXP:PLAYER:手淫経験 ++
ELSE
	DOWNBASE:体力 += 10
	DOWNBASE:気力 += 40
	DOWNBASE:MASTER:体力 += 20
	DOWNBASE:MASTER:気力 += 20
	SOURCE:情愛 = 50
	SOURCE:性行動 = 60
	SOURCE:露出 = 20
	SOURCE:不潔 = 30
	SOURCE:逸脱 = 20
	SOURCE:反感 = 20
	SIF TALENT:PLAYER:舌使い
		TIMES SOURCE:情愛 , 1.50
	SIF TALENT:自己愛 < 0 || TALENT:抵抗
		SOURCE:鬱屈 += 20
	SIF TALENT:自尊心 > 0
		SOURCE:不潔 *= 2
	CALL ADD_EXP_LESNIAN(5)
	SIF TALENT:PLAYER:猫舌
		EXP:PLAYER:嗜虐快楽経験 += 1
	EXP:PLAYER:手淫経験 ++
ENDIF
TIME += 5
RETURN 1

