;Triple Stack Insertion
@ADD_CUSTOM_SCOM16
CALL ADD_CUSTOM_SCOM_MODULE16
CALL ADD_SEX_MODULE_EXECUTE

RETURN 1

@ADD_CUSTOM_SCOM_ABLE16
#DIM DYNAMIC SUCCEED
CALL ADD_CUSTOM_SCOM_MODULE16
CALL ADD_SEX_MODULE_COM_ABLE
SIF !RESULT
	RETURN 0

SIF ABL:PLAYER:技巧 < 5
	RETURN 0
SIF ABL:PLAYER:腰 < 4
	RETURN 0

RETURN 1

@ADD_CUSTOM_CAN_SCOM16(ARG)
SKIPDISP ARG
PRINTFORML Triple Stack
SKIPDISP 0

CALL ADD_CUSTOM_SCOM_MODULE16
CALL ADD_SEX_MODULE_CAN_COM(ARG)
RETURN RESULT

@ADD_CUSTOM_MESSAGE_SCOM16
PRINTFORMDL %BREAKENG(@"You stack %CALLNAME:(ADD_SEX_MODULE_CHARA:0)%, %CALLNAME:(ADD_SEX_MODULE_CHARA:1)%, and %CALLNAME:(ADD_SEX_MODULE_CHARA:2)% on top of each other and insert your %TINKO_TR(PLAYER)% into each of them in turn.")%
PRINTFORMDL %BREAKENG(@"As you continue to move between them, you can feel every difference between %CALLNAME:(ADD_SEX_MODULE_CHARA:0)%'s %SLIT_TR(ADD_SEX_MODULE_CHARA:0, 1)%, %CALLNAME:(ADD_SEX_MODULE_CHARA:1)%'s %SLIT_TR(ADD_SEX_MODULE_CHARA:1, 1)%, and %CALLNAME:(ADD_SEX_MODULE_CHARA:2)%'s %SLIT_TR(ADD_SEX_MODULE_CHARA:2, 1)%.")%

@ASSISTANT_KOJO_CUSTOM_SCOM16
FOR LOCAL, 0, ADD_SEX_MODULE_ACTION_COUNT
	SIF ADD_SEX_MODULE_CHARA:LOCAL <= 0
		BREAK
	SIF ADD_SEX_MODULE_CHARA:LOCAL == TARGET
		CONTINUE
	CALL KOJO_MESSAGE_SEND("COMMAND_ASSISTANT",-1,ADD_SEX_MODULE_CHARA:LOCAL,-1,-1)
NEXT

@ADD_CUSTOM_SCOM_SET16
#DIM DYNAMIC CHARAS, 3

CHARAS:0 = ADD_MASTER_POSE_TR(PLAYER, SET_V,SET_P)

SIF CHARAS:0 <= 0 || ADD_TOUCH_CURRENT_POSE(PLAYER, CHARAS:0, 0) != POSE_DOGGYSTYLE
	RETURN 0

FOR LOCAL, 1, 3
	LOCAL:1 = ADD_MASTER_POSE_TR(PLAYER, SET_V,SET_P,LOCAL)

	SIF !LOCAL:1
		CONTINUE
	SIF FINDELEMENT(CHARAS, LOCAL:1) >= 0
		CONTINUE
    SIF ADD_TOUCH_CURRENT_POSE(PLAYER, LOCAL:1, LOCAL) != POSE_DOGGYSTYLE
        CONTINUE
		
	FOR LOCAL:2, 1, 3
		SIF CHARAS:(LOCAL:2)
			CONTINUE
		CHARAS:(LOCAL:2) = LOCAL:1
		BREAK
	NEXT
NEXT

ADD_SEX_MODULE_ACTOR:0 = PLAYER
FOR LOCAL, 0, 3
	SIF CHARAS:LOCAL <= 0
		RETURN 0
	ADD_SEX_MODULE_CHARA:LOCAL = CHARAS:LOCAL
NEXT

RETURN 1

@ADD_CUSTOM_SCOM_MODULE16
CALL ADD_SEX_MODULE_START(16)
CALL ADD_SEX_MODULE_ADD_ACTION(SET_P, SET_V,, 0)
CALL ADD_SEX_MODULE_ADD_ACTION(SET_P, SET_V,, 1)
CALL ADD_SEX_MODULE_ADD_ACTION(SET_P, SET_V,, 2)
CALL ADD_SEX_MODULE_FINISH
