;足交
@ADD_SEX_ACTION_1_8(ARG, MULTIPLIER)
#DIM MULTIPLIER
;-------------------------------------------------
;COM別FLAGの設定
;-------------------------------------------------
;行為者
TCVAR:ARG:116 = ARG
;奉仕快楽
TCVAR:ARG:108 = 1

CSTR:PLAYER:10 += @"{ARG}/"
;TCVAR:2 射精箇所フラグ 7=足コキ
TCVAR:PLAYER:2 = 7
;強度
TCVAR:PLAYER:4 = MULTIPLY(600, MULTIPLIER)

;-------------------------------------------------
;ソース追加処理
;-------------------------------------------------
IF ABL:足 < 4 || FLAG:70
	SOURCE:PLAYER:快Ｃ += MULTIPLY(90, MULTIPLIER)
ELSE
	SOURCE:PLAYER:快Ｃ += ABL:足 * MULTIPLY(25, MULTIPLIER)
ENDIF

;消費体力、気力
IF FLAG:70 == 1
	BASE:MASTER:TSP -= 40
ELSE
	DOWNBASE:ARG:体力 += 12
	DOWNBASE:ARG:気力 += 65

	SOURCE:ARG:情愛 = MULTIPLY(45, MULTIPLIER)
	SOURCE:ARG:性行動 = MULTIPLY(240, MULTIPLIER)
	SOURCE:ARG:達成 = MULTIPLY(55, MULTIPLIER)
	SOURCE:ARG:屈従 = MULTIPLY(320, MULTIPLIER)
	SOURCE:ARG:逸脱 = 110
	SOURCE:ARG:反感 = 90

	;抑圧、抵抗持ち
	SIF TALENT:ARG:自己愛 < 0 || TALENT:ARG:抵抗
		SOURCE:ARG:鬱屈 += 190
ENDIF
;-------------------------------------------------
;汚れの処理
;-------------------------------------------------
STAIN:ARG:8 |= STAIN:PLAYER:2
STAIN:PLAYER:2 |= STAIN:ARG:8

;-------------------------------------------------
;経験の処理
;-------------------------------------------------
SIF !FLAG:70 && !CFLAG:ARG:イタズラ
	EXP:ARG:足交经验 ++

RETURN 1

@ADD_SEX_ABLE_1_8(ARG)
;足交执行判定
SIF !TFLAG:100
	RETURN 0
SIF GLOBAL_COMABLE(85)
	RETURN RESULT
SIF FLAG:70
	RETURN 0
;调教者必须是男性或扶她
SIF !(TALENT:PLAYER:2 & 2)
	RETURN 0
;绳子限制
SIF TEQUIP:ARG:縄
	RETURN 0
RETURN 1

@ADD_SEX_CAN_1_8()
ADD_SEX_MODULE_DIFFICULTY_TEMP += 22
ADD_SEX_MODULE_COM_ORDER_TEMP |= QOL_COM_ORDER_SERVICE_CUM_FULL | QOL_COM_ORDER_DIRT_SOURCE_PENIS
