@CUSTOM_EVENT_MESSAGE_1(SELECTED_SWIMWEAR,ARG:1,ARG:2,ARG:3)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM SWIM_DIAP
#DIM UNIQUE_SWIMSUIT = 47
#DIM SELECTED_SWIMWEAR

IF TARGET == MASTER
	PRINTFORML %CALLNAME:MASTER%迅速换上了泳装。
ELSEIF CFLAG:TARGET:現在位置 == CFLAG:MASTER:現在位置 ;only show dialogue if present
	IF ADD_SELECTCUSTOMCOM == 1
		PRINTFORM 看到%CALLNAME:MASTER%准备游泳，
	ELSEIF ADD_SELECTCUSTOMCOM == 2
		PRINTFORM 接受%CALLNAME:MASTER%的邀请后，
	ENDIF
	IF !SELECTED_SWIMWEAR || !SELECTED_SWIMWEAR == [[裸泳]]
		IF TARGET == [[咲夜]]
			PRINTFORML %CALLNAME:TARGET%不知何时摁下了自己随身携带的怀表
			PRINTFORML 眨眼间便一丝不挂地出现在%CALLNAME:MASTER%的眼前。
		ELSEIF TARGET == [[若鹭姬]]
			PRINTFORML %CALLNAME:TARGET%微微一笑，钻入水中
			PRINTFORML 不一会儿便片缕不着地浮出水面。		
		ELSEIF ABL:TARGET:露出癖 < 5 || (GET_TARGETNUM() > 1 && ABL:TARGET:露出癖 < 10)
			PRINTFORML %CALLNAME:TARGET%挪到附近一块岩石后面，换起了衣服
			PRINTFORM 回来时全身赤裸着…
		ELSE
			PRINTFORML %CALLNAME:TARGET%丝毫不在意\@ GET_TARGETNUM() > 1 ? 旁人 # +++ \@的视线，褪去了衣物
			PRINTFORM 大大方方地展示着自己的胴体…
		ENDIF
	ELSE
		IF TARGET == [[咲夜]]
			PRINTFORML %CALLNAME:TARGET%不知何时摁下了自己随身携带的怀表
			PRINTFORM 眨眼间便换上了
		ELSEIF TARGET == [[若鹭姬]]
			PRINTFORML %CALLNAME:TARGET%微微一笑，钻入水中
			PRINTFORM 不一会儿钻出来时，便已经换上了		
		ELSEIF ABL:TARGET:露出癖 < 5 || (GET_TARGETNUM() > 1 && ABL:TARGET:露出癖 < 10)
			PRINTFORML %CALLNAME:TARGET%挪到附近一块岩石后面，换起了衣服
			PRINTFORM 回来时穿着
		ELSE
			PRINTFORML %CALLNAME:TARGET%丝毫不在意\@ GET_TARGETNUM() > 1 ? 旁人 # +++ \@的视线，褪去了衣物
			PRINTFORM 没过多久就换好了
		ENDIF

		SELECTCASE SELECTED_SWIMWEAR
			CASE -1 ;SWIM_DIAP
				PRINTFORML 一条防水的尿不湿。
			CASE [[比基尼套装]]
				PRINTFORML 一件可爱的比基尼，完美衬托出%HE_SHE_CN(TARGET)%的身材。
			CASE [[迷你比基尼套装]]
				PRINTFORM 一件大胆的超小比基尼，
				SELECTCASE TALENT:TARGET:胸围
					CASE -3
						PRINTFORML 穿在%HE_SHE_CN(TARGET)%平坦的胸部上显得非常别扭。
					CASE -2
						PRINTFORML 根本不适合%HE_SHE_CN(TARGET)%那小小的胸部。
					CASE -1
						PRINTFORML 与%HE_SHE_CN(TARGET)%纤细的身材形成鲜明对比。
					CASE 0
						PRINTFORML 让%HE_SHE_CN(TARGET)%散发出成熟的气息。
					CASE 1
						PRINTFORML 让%HE_SHE_CN(TARGET)%的胸部更加突出。
					CASE 2, 3, 4
						PRINTFORML 完全束缚不住%HE_SHE_CN(TARGET)%的丰满胸部。
				ENDSELECT
			CASE [[死库水泳衣]]
				PRINTFORML 一件印有%HE_SHE_CN(TARGET)%名字的学校泳衣。
				SIF TALENT:TARGET:胸围 > 0
					PRINTFORML 但是，\@ TALENT:TARGET:ヒップサイズ > 0 ? 胸部和胯部 # 胸部 \@绷得相当紧。
				SIF TALENT:TARGET:ヒップサイズ > 0 && TALENT:TARGET:胸围 <= 0
					PRINTFORML 然而，胯部的布料绷得相当紧。
			CASE [[竞技泳衣]]
				PRINTFORML 一件运动型且舒适的泳衣。
			CASE [[连体泳衣]]
				PRINTFORML 一件可爱的连体泳衣。
			CASE UNIQUE_SWIMSUIT
				PRINTFORML 自己喜欢穿的那件%UNIQUE_UNDERWARE_SWIMMING(TARGET)%。
			CASE [[Y字泳衣]]
				PRINTFORM 一件非常暴露的Y字高叉泳衣，
				SELECTCASE TALENT:TARGET:胸围
					CASE -2,-3
						PRINTFORML 穿在%HE_SHE_CN(TARGET)%身上，与其说色情不如说更显可爱。
					CASE -1
						PRINTFORML 穿在%HE_SHE_CN(TARGET)%身上，与其说大胆不如说更显可爱。
					CASE 0
						PRINTFORML 令人想入非非的部位若隐若现。
					CASE 1
						PRINTFORML 完全起不到蔽体的作用，反而更显诱惑。
					CASE 2,3,4
						PRINTFORML 紧绷住%HE_SHE_CN(TARGET)%丰满的胸部，完全起不到蔽体的作用。
				ENDSELECT
			CASE [[泳裤装]]
				IF IS_MALE(TARGET)
					PRINTFORM 一条简单的泳裤
				ELSE
					PRINTFORM 一条男式泳裤
				ENDIF
				SELECTCASE TALENT:TARGET:ヒップサイズ
					CASE -3
						PRINTFORML ，对于%HE_SHE_CN(TARGET)%太大了，不得不一直往上提。
					CASE -2
						PRINTFORML ，似乎有点大了。
					CASE -1
						PRINTFORML ，几乎垂到%HE_SHE_CN(TARGET)%的膝盖。
					CASE 0
						PRINTFORML 。
					CASE 1
						PRINTFORML ，似乎有点小了。
					CASE 2
						PRINTFORML ，裹着%HE_SHE_CN(TARGET)%%HIP(TARGET)%，更像是热裤。
					CASE 3
						PRINTFORML ，几乎遮不住%HE_SHE_CN(TARGET)%%HIP(TARGET)%。
					CASE 4
						PRINTFORML ，几乎遮不住%HE_SHE_CN(TARGET)%%HIP(TARGET)%。
				ENDSELECT
			CASEELSE
		ENDSELECT
ENDIF
