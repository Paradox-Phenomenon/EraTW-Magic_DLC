@Add_Custom_SCOM_Name(ARG)
#FUNCTIONS
#DIM SHORT
SELECTCASE ARG
;24
	CASE 0
		RETURNF "Simultaneous Insertion"
	CASE 1
		RETURNF "Simultaneous Anal Insertion"
	CASE 2
		RETURNF "Exposed Reverse Anal Lotus"
	CASE 3
		RETURNF "Exposed Spread Labia"
	CASE 5
		RETURNF "Reverse Spitroast"
	CASE 6
		RETURNF "Double Fingering"
	CASE 7
		LOCAL = ADD_LAST_V_POSE()
		IF LOCAL
			RETURNF @"%ADD_SEX_MODULE_POSE(LOCAL)% and Fingering"
        ENDIF
		RETURNF "V and Fingering"
	CASE 8
		LOCAL = ADD_LAST_V_POSE()
		SIF LOCAL
			RETURNF @"%ADD_SEX_MODULE_POSE(LOCAL)% and Double Fingering"
		RETURNF "V and Double Fingering"
	CASE 9
		RETURNF "Triple Paizuri"
	CASE 10
		RETURNF "Triple Fellatio"
	CASE 11
		RETURNF "Reverse Spitroast and Fingering"
	CASE 12
		RETURNF "Double Handjob"
	CASE 13
		RETURNF "Two Handjobs"
	CASE 14
		RETURNF "Spitroast"
	CASE 15
		RETURNF "Cum Outside"
	CASE 16
		RETURNF "Triple Stack"
	CASE 17
		RETURNF "Triple Penetration"
	CASE 18, 19
		RETURNF "Gangbang"
	CASE 20
		RETURNF "Double Bellyjob"
	CASEELSE
		RETURNF "Custom SCOM"
ENDSELECT
