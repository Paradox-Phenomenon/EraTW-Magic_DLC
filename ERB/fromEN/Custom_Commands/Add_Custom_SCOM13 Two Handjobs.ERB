;Handjobbing two people at once
@ADD_CUSTOM_SCOM13
#DIM OTHER

OTHER = ADD_CHARA_WHO_TOUCHING(TARGET, SET_YUBI, SET_P, 1)
;-------------------------------------------------
;COM別FLAGの設定
;-------------------------------------------------
;行為者
TCVAR:116 = TARGET
;奉仕快楽
TCVAR:108 = 1

CALL ADD_CUSTOM_SCOM13_ACTOR_PART(PLAYER)
CALL ADD_CUSTOM_SCOM13_ACTOR_PART(OTHER)
RETURN 1

@ADD_CUSTOM_SCOM13_ACTOR_PART(ACTOR)
#DIM ACTOR
CSTR:ACTOR:10 += @"{TARGET}/"
;TCVAR:2 射精箇所フラグ（-1=コンドーム 1=膣内 2=アナル 3=手淫 4=口淫 5=パイズリ 6=素股 7=足コキ 8=体表 9=アナル奉仕 10=道具 11=触手 12=Ａ責め 13=Ｖ責め）
TCVAR:ACTOR:2 = 3
;強度
TCVAR:ACTOR:4 = 400

;-------------------------------------------------
;ソース追加処理
;-------------------------------------------------
IF ABL:指 < 4 || FLAG:70
	SOURCE:ACTOR:快Ｃ += 40
ELSE
	SOURCE:ACTOR:快Ｃ += ABL:指 * 10
ENDIF

;消費体力、気力
IF FLAG:70 == 1
	BASE:MASTER:TSP -= 80

ELSE

	DOWNBASE:体力 += 10
	DOWNBASE:気力 += 60

	SOURCE:情愛 += 50
	SOURCE:性行動 += 250
	SOURCE:達成 += 50
	SOURCE:屈従 += 350
	SOURCE:逸脱 += 100
	SOURCE:反感 += 100

	;上のほうで計算した汚れデータ
	SOURCE:不潔 += Y*10 + 60


	;-------------------------------------------------
	;特殊ソース処理
	;-------------------------------------------------
	;抑圧、抵抗持ちには、抑鬱ソース追加
	SIF TALENT:自己愛 < 0 || TALENT:抵抗
		SOURCE:鬱屈 += 200
ENDIF
;-------------------------------------------------
;汚れの処理
;-------------------------------------------------
;射精に関係なく行われる処理はここから
;奴隷の指⇔調教者のＰの汚れが移動
STAIN:1 |= STAIN:ACTOR:2
STAIN:ACTOR:2 |= STAIN:1

;-------------------------------------------------
;経験の処理
;-------------------------------------------------
;手淫経験
SIF !FLAG:70 && !CFLAG:イタズラ
	EXP:手淫経験 ++

;同性愛　レズなら戻り値1ゲイなら戻り値2
IF FLAG:70 == 1 || CFLAG:イタズラ
	IF HETEROSEX(TARGET,ACTOR)
		EXP:ACTOR:(50 + HETEROSEX(TARGET,ACTOR)) += 1
	ENDIF
ELSE
	IF HETEROSEX(TARGET,ACTOR)
		EXP:(50 + HETEROSEX(TARGET,ACTOR)) += 4
		EXP:ACTOR:(50 + HETEROSEX(TARGET,ACTOR)) += 1
	ENDIF
ENDIF

@ADD_CUSTOM_CAN_SCOM13(ARG)
SKIPDISP ARG
PRINTL Two Handjobs
;-------------------------------------------------
;実行判定処理
;-------------------------------------------------
IF FLAG:70 == 1 || CFLAG:イタズラ

ELSE
    CALL QOL_COM_ORDER_STANDARD_CHECKS(34, QOL_COM_ORDER_SERVICE_FULL | QOL_COM_ORDER_DIRT_SOURCE_PENIS, TARGET)
    LOCAL = RESULT
    SKIPDISP 0
    RETURN LOCAL
ENDIF
RETURN 1

@ADD_CUSTOM_SCOM_ABLE13
;手淫実行判定
SIF !TFLAG:100
	RETURN 0
SIF FLAG:70 ;not in time stop for now
	RETURN 0
SIF GLOBAL_COMABLE(80)
	RETURN RESULT
;調教者がオトコか半人半妖かふたなりじゃないとダメ
SIF !(TALENT:PLAYER:2 & 2)
	RETURN 0
SIF ADD_CHARA_WHO_TOUCHING(TARGET, SET_YUBI, SET_P, 1) < 0
	RETURN 0
;時間停止中は許可
IF FLAG:70 != 1
	;縄使用中は不可
	SIF TEQUIP:縄
		RETURN 0
	SIF ABL:指 < 4 ;some skill required
		RETURN 0
	SIF ABL:技巧 < 4
		RETURN 0
ENDIF
RETURN 1

