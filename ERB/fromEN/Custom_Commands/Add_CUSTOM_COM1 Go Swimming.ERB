@ADD_CUSTOM_COM1
;游泳
IF !TEQUIP:MASTER:SWIMMING
	TFLAG:194 = 1
	;适配多人约会
	IF FLAG:デート相手
		IF MOREDATE && NumberOfDates > 1
			FOR LOCAL, 0, NumberOfDates
				CALL ADD_START_SWIMMING(Datees:LOCAL)
			NEXT
		ELSE 
			CALL ADD_START_SWIMMING(FLAG:デート相手)
		ENDIF
	ENDIF
	CALL ADD_START_SWIMMING(MASTER)
	CALL ADD_BYSTANDERS_JOIN_SWIMMING
	TIME += 5
ELSE
	TFLAG:194 = 0
	FOR LOCAL, 0, CHARANUM
		SIF TEQUIP:LOCAL:SWIMMING && Activity_Type:LOCAL != 100
			CALL ADD_END_SWIMMING(LOCAL)
	NEXT
ENDIF

RETURN 1

@ADD_CUSTOM_COM_ABLE1
#LOCALSIZE 1
#LOCALSSIZE 1
SIF !TFLAG:100
	RETURN 0
SIF FLAG:70
	RETURN 0

SIF CFLAG:うふふ
	RETURN 0
;一括管理
SIF !ADD_SWIMMING_AREA(CFLAG:MASTER:現在位置)
	RETURN 0
;NAS: Non 0 MASTER
IF FLAG:デート相手 != MASTER ;if with a date, must target date
	SIF !IS_DATING_WITH_PLAYER(TARGET)
		RETURN 0
	SIF BASE:気力 <= 0 ;date is tired
		RETURN 0
	SIF CFLAG:行動
		RETURN 0
	SIF !ADD_SWIMMING_CONSTITUTION(FLAG:デート相手)
		RETURN 0
	IF MOREDATE && NumberOfDates > 1
		FOR LOCAL, 0, NumberOfDates
			SIF !ADD_SWIMMING_CONSTITUTION(Datees:LOCAL)
				RETURN 0
		NEXT
	ENDIF
ENDIF

SIF BASE:MASTER:気力 <= 0
	RETURN 0
SIF TFLAG:デート道中
	RETURN 0
RETURN 1

@ADD_CUSTOM_MESSAGE_COM1
IF TEQUIP:MASTER:SWIMMING
	IF !TARGET
		PRINTFORML 换好衣服后，%CALLNAME:MASTER%开始了游泳。
	ELSEIF TARGET && TEQUIP:TARGET:SWIMMING
		PRINTFORML 换好衣服后，%CALLNAME:MASTER%开始和%CALLNAME:TARGET%游泳了。
	ELSE
		PRINTFORML 换好衣服后，+++打算%COND_STR(@"和%CALLNAME:TARGET%", (IS_DATING_WITH_PLAYER(TARGET) || CFLAG:同行))%游一会儿泳，不过貌似%CALLNAME:TARGET%那边没有这个意思…
	ENDIF
ELSE
	;PRINTFORML 游泳结束了，+++换上了原来的衣服
ENDIF

@ADD_SWIMMING_DESCRIPTION(LOCATION)
#FUNCTIONS
#DIM LOCATION
SELECTCASE LOCATION
	CASE GET_MAP_REPLACEMENT(1015)
		RETURNF "静海"
	CASE GET_MAP_REPLACEMENT(P343湖畔), GET_MAP_REPLACEMENT(347)
		RETURNF "湖"
	CASE GET_MAP_REPLACEMENT(703), GET_MAP_REPLACEMENT(602), GET_MAP_REPLACEMENT(945)
		RETURNF "河"
	CASEELSE
		RETURNF "水"
ENDSELECT

@ADD_SWIMMING_AREA(LOCATION)
#FUNCTION
#DIM LOCATION
;可游泳区：P343湖畔、P347霧の湖、P703玄武の沢、P945河岸、P602赛河原、P806瀑布背面、P1015沙滩、P1183冰雪世界·冰湖
RETURNF GROUPMATCH(LOCATION, GET_MAP_REPLACEMENT(343), GET_MAP_REPLACEMENT(347), GET_MAP_REPLACEMENT(703), GET_MAP_REPLACEMENT(945), GET_MAP_REPLACEMENT(602), GET_MAP_REPLACEMENT(806), GET_MAP_REPLACEMENT(1015), GET_MAP_REPLACEMENT(1183))

@ADD_RUNNING_WATER(LOCATION)
#FUNCTION
#DIM LOCATION
;流水区：P703玄武の沢、P945河岸、P602赛河原、P1015沙滩
RETURNF GROUPMATCH(LOCATION,GET_MAP_REPLACEMENT(703),GET_MAP_REPLACEMENT(945), GET_MAP_REPLACEMENT(602), GET_MAP_REPLACEMENT(1015))

@ADD_SWIMMING_DAMAGE(ARG)
#FUNCTION
SIF TALENT:ARG:143 == 4
	RETURNF 1
SIF IS_VAMPIRE(ARG) && ADD_RUNNING_WATER(CFLAG:ARG:現在位置)
	RETURNF 2
SIF (!ADD_SWIMMING_SEASON() && CFLAG:ARG:現在位置/100 != 9) && !TALENT:ARG:水棲 && !TALENT:ARG:氷精
	RETURNF 1
RETURNF 0

@ADD_SWIMMING_SEASON
#FUNCTION
SELECTCASE DAY:2
	CASE 1
		RETURNF DAY:3 > 15 ;暮春
	CASE 2
		RETURNF 1	;夏天
	CASE 3
		RETURNF DAY:3 < 15 ;早秋
	CASE 4
		RETURNF 0 ;早春、冬季、暮秋——冬泳
ENDSELECT

@ADD_START_SWIMMING(ARG)
IF !ADD_IN_SWIMWEAR(ARG)
	CALL ADD_SWIMMING_OUTFIT(ARG)
ENDIF
TEQUIP:ARG:SWIMMING = 1

@ADD_END_SWIMMING(ARG)
IF TCVAR:ARG:EVENT_CLOTHING_SET
	SIF CFLAG:ARG:現在位置 == CFLAG:MASTER:現在位置
		PRINTFORML %CALLNAME:ARG%换回了衣服准备休息
	CALL RESET_EVENT_CLOTHES(ARG)
ENDIF
TEQUIP:ARG:SWIMMING = 0

@ADD_SWIMMING_OUTFIT(ARG)
#DIM DYNAMIC WEIGHTS, 100
#DIM SWIM_DIAP
#DIM SELECTED_SWIMWEAR
#DIM UNIQUE_SWIMSUIT = 47
#DIM DYNAMIC EROTICISM


;IF 0;CANT_UNDIES(ARG)
	;skip those who can't wear undies
;	SELECTED_SWIMWEAR = 100
;ELSEIF 0;(CanWearUnderwear(ARG, "Diaper")) && nOmutsu
	;NAS: incon 2hus wear swim diapers
;	SELECTED_SWIMWEAR = SWIM_DIAP
IF IS_FEMALE(ARG)
	IF !TALENT:ARG:無知 || TALENT:ARG:小悪魔 ;not ignorant, or a temptress
		EROTICISM = MIN(ABL:ARG:露出癖, 30) ;exposure
		EROTICISM -= OTOKOGIRAI(ARG) ? 3 # 0 ;misandrist
		EROTICISM += TALENT:ARG:性的興味 * 2 ;conservative/curious
		EROTICISM += TALENT:ARG:目立ちたがり * 3 ;show-off
		EROTICISM += TALENT:ARG:セフレ ? 3 # 0 ;sex friend
		EROTICISM += TALENT:ARG:愛欲 * 5 ;lust
		EROTICISM -= TALENT:ARG:貞操 * 5 ;virtuous/unchaste
		EROTICISM += TALENT:ARG:小悪魔 * 10 ;seductress
		EROTICISM += TALENT:ARG:胸围 * 2 ;breast size
		EROTICISM += TALENT:ARG:ヒップサイズ * 2 ;butt size
		EROTICISM -= TALENT:ARG:羞恥心 * 6 ;shameless/shy

		SIF GET_TARGETNUM() > 1 && !TALENT:ARG:淫乱
			EROTICISM /= 2
		EROTICISM = MAX(EROTICISM, 0)
		SIF TALENT:ARG:無知 && !TALENT:ARG:小悪魔 ;ignorant, not a temptress
			EROTICISM = 0
	ENDIF

	WEIGHTS:[[比基尼套装]] = 20
	WEIGHTS:[[迷你比基尼套装]] = EROTICISM
	WEIGHTS:[[连体泳衣]] = 10
	WEIGHTS:[[竞技泳衣]] = ABL:ARG:戦闘能力 * 2 * (CFLAG:ARG:性格傾向 == 4 ? 2 # 1) ;combat skill + serious personality
	SIF UNIQUE_UNDERWARE_SWIMMING(ARG) != ""
		WEIGHTS:UNIQUE_SWIMSUIT = 10
	WEIGHTS:[[裸泳]] = 裸泳可用权重(ARG)	
	
	IF (IS_CHILD(ARG, "mind") || IS_CHILD(ARG, "age")) && !TALENT:ARG:小悪魔 ;child's mindset
		WEIGHTS:[[迷你比基尼套装]] /= 2
		WEIGHTS:[[死库水泳衣]] = 40
		IF TALENT:ARG:胸围 < 0
			WEIGHTS:[[泳裤装]] = 5
		ELSE
			WEIGHTS:[[Y字泳衣]] = EROTICISM / 4
		ENDIF
	ELSEIF IS_CHILD(ARG, "body") && !TALENT:ARG:小悪魔 ;child's body
		WEIGHTS:[[死库水泳衣]] = 10
		WEIGHTS:[[连体泳衣]] = 20
		IF TALENT:ARG:胸围 < 0
			WEIGHTS:[[泳裤装]] = 5
		ELSE
			WEIGHTS:[[Y字泳衣]] = EROTICISM / 2
		ENDIF
	ELSE ;adults
		WEIGHTS:[[死库水泳衣]] = EROTICISM / 2 ;it's basically fetish wear to adults
		WEIGHTS:[[Y字泳衣]] = EROTICISM
		SIF TALENT:ARG:胸围 < 0
			WEIGHTS:[[泳裤装]] = EROTICISM / 4
	ENDIF
	SELECTED_SWIMWEAR = ARRAY_HIT(WEIGHTS, 100)
ELSE
	SELECTED_SWIMWEAR = [[泳裤装]]
ENDIF
DEBUGPRINTFORML %CALLNAME:ARG%泳装决定：%GETMETH_STR(ARG, "衣装セット" , SELECTED_SWIMWEAR, "名前")%({SELECTED_SWIMWEAR})
CALL KOJO_MESSAGE_SEND("CUSTOM_EVENT",1,ARG,SELECTED_SWIMWEAR)
CALL SET_EVENT_CLOTHES(ARG, SELECTED_SWIMWEAR)

@ADD_IN_SWIMWEAR(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
RETURNF GETMETH_INT(ARG, "衣装セット", CURRENT_CLOTHES_SET(ARG), "SWIMWEAR")

@ADD_BYSTANDERS_JOIN_SWIMMING(ARG = 1)
#LOCALSIZE 1
#LOCALSSIZE 1
FOR LOCAL, 1, GET_TARGETNUM() + 1
	SIF ARG && !CFLAG:(TARGET:LOCAL):同行
		CONTINUE
	SIF CAN_JOIN_SWIMMING(TARGET:LOCAL)
		CALL ADD_START_SWIMMING(TARGET:LOCAL)
NEXT

@CAN_JOIN_SWIMMING(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
SIF TEQUIP:ARG:SWIMMING
	RETURNF 0
SIF !ADD_SWIMMING_CONSTITUTION(ARG)
	RETURNF 0
SIF MARK:ARG:反発刻印 || CFLAG:ARG:ブチギレ
	RETURNF 0
;吸血鬼、猫耳、冬泳，且从顺不大于5 不会加入
SIF ADD_SWIMMING_DAMAGE(ARG) && ABL:ARG:従順 < 5
	RETURNF 0
SIF CFLAG:ARG:同行 || CFLAG:ARG:態度 > 0
	RETURNF 1

@ADD_WEATHER_HARSHNESS(LOCATION)
#FUNCTION
#DIM LOCATION
;基于COM411(战斗训练)
SIF !OUTROOF(LOCATION)
	RETURNF 0
SELECTCASE TIME:5
	CASE 4,6,8,10,12,13	;雨、雾雨、雪、细雪、雨夹雪、冰雹
		IF WIND_VELOCITY >= 1
		;(天气补丁特供)强/暴风
			RETURNF 2
		ELSE
			;恶劣天气
			RETURNF 1
		ENDIF
	CASE 5,9,14,15	;(大/暴)(雨/雪)
		IF WIND_VELOCITY >= 1
		;(天气补丁特供)强/暴风
			RETURNF 3
		ELSE
			RETURNF 2
		ENDIF
	;其他
	CASEELSE	;晴天、多云、阴天、雾、雾雪
		SIF WIND_VELOCITY == 1
		;(天气补丁特供)强风
			RETURNF 1
		SIF WIND_VELOCITY >= 2
		;(天气补丁特供)暴风
			RETURNF 2
ENDSELECT
RETURNF 0

;检测在场角色是否会加入游泳（包括恶劣环境）
@ADD_SWIMMING_CONSTITUTION(CHARA,L_分歧)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CHARA
#DIM DYNAMIC L_分歧
SIF !ADD_SWIMMING_AREA(CFLAG:CHARA:現在位置)
	RETURNF 0
IF !BASE:CHARA:気力 ;角色气力为0
	SIF L_分歧 && CHARA == TARGET
		TFLAG:194 = 1
	RETURNF 0
ENDIF
SIF !CHARA
	RETURNF 1 ;只有你先生在场，必定会加入

LOCAL = ADD_SWIMMING_DAMAGE(CHARA)
;吸血鬼
IF LOCAL == 2
	SIF L_分歧 && CHARA == TARGET
		TFLAG:194 = 3
	SIF MAXBASE:CHARA:体力 < 4000
		RETURNF 0
;猫耳
ELSEIF LOCAL == 1 && TALENT:CHARA:143 == 4
	SIF L_分歧 && CHARA == TARGET
		TFLAG:194 = 5
	SIF MAXBASE:CHARA:体力 < 3000
		RETURNF 0
;冷水
ELSEIF LOCAL == 1
	SIF L_分歧 && CHARA == TARGET
		TFLAG:194 = 4
	SIF MAXBASE:CHARA:体力 < 2500
		RETURNF 0
ENDIF
SELECTCASE ADD_WEATHER_HARSHNESS(CFLAG:MASTER:現在位置) ;不同天气条件对应的角色身体素质（体力上限）要求不同
	CASE 0
		RETURNF 1
	CASE 1
		SIF MAXBASE:CHARA:体力 >= 2000
			RETURNF 1
	CASE 2
		SIF MAXBASE:CHARA:体力 >= 3500
			RETURNF 1
	CASE 3
		SIF MAXBASE:CHARA:体力 >= 5000
			RETURNF 1
ENDSELECT
RETURNF 1

@裸泳可用权重(CID)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CID
#DIM L_LEVEL
#DIM F_LEVEL
#DIM 欲求
; --- 静态数据 ---
; 索引:      [0:其他, 1:恋慕, 2:恋人]
#DIM CONST L_系数 = 40,     30,     20
#DIM CONST 固定权重 = 10,     15,     20
; -----------------------------------------------------
欲求 = CFLAG:CID:340

F_LEVEL = GET_FALLEN_LEVEL(CID)
L_LEVEL = 裸泳门槛判定(CID)

SELECTCASE L_LEVEL
    CASE 2 ; 高欲阶段
        RETURNF 欲求 / L_系数:F_LEVEL
    CASE 1 ; 一般阶段
        RETURNF 固定权重:F_LEVEL
    CASEELSE
        RETURNF 0
ENDSELECT

;-------------------------------------------------
; @裸泳门槛判定(CID)
; 返回值：0:不可, 1:一般, 2:高欲
;-------------------------------------------------
@裸泳门槛判定(CID)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CID
#DIM F_LEVEL
#DIM 多人
#DIM 露出
#DIM 欲求

F_LEVEL = GET_FALLEN_LEVEL(CID)
多人 = (GET_TARGETNUM() > 1)
露出 = ABL:CID:露出癖
欲求 = CFLAG:CID:340

SELECTCASE F_LEVEL
    CASE 2 ; 恋人
        SIF 欲求 >= 600
            RETURNF 2
        SIF 欲求 >= 400
            RETURNF 1
        RETURNF 1 ; 恋人保底

    CASE 1 ; 恋慕
        IF 欲求 >= 800
            RETURNF 2
        ELSEIF 欲求 >= 600 && 露出 >= (多人 ? 4 # 3)
            RETURNF 2
        ELSEIF 露出 >= (多人 ? 5 # 4)
            RETURNF 1
        ENDIF

    CASE 0 ; 其他
        IF 欲求 >= 800 && 露出 >= (多人 ? 8 # 6)
            RETURNF 2
        ELSEIF 露出 >= (多人 ? 10 # 8)
            RETURNF 1
        ENDIF
ENDSELECT
RETURNF 0

;-------------------------------------------------
; @GET_FALLEN_LEVEL(CID)
; 统一判定角色的陷落/关系深度等级
; 0:无/他人, 1:恋慕, 2:恋人 (可扩展)
;-------------------------------------------------
@GET_FALLEN_LEVEL(CID)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CID
SIF TALENT:CID:恋人
    RETURNF 2
SIF TALENT:CID:恋慕
    RETURNF 1
; SIF TALENT:CID:
;    RETURNF 3
RETURNF 0