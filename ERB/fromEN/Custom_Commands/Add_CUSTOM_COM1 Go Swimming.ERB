RETURNF GROUPMATCH(LOCATION, GET_MAP_REPLACEMENT(343), GET_MAP_REPLACEMENT(347), GET_MAP_REPLACEMENT(703), GET_MAP_REPLACEMENT(945), GET_MAP_REPLACEMENT(602), GET_MAP_REPLACEMENT(806), GET_MAP_REPLACEMENT(1015))

