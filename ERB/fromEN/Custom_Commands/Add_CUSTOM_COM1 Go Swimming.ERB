@ADD_SWIMMING_DAMAGE(ARG)
#FUNCTION
SIF (GET_TRIBENAME(ARG, GETNUM(TALENT, "妖怪")) == "吸血鬼" || TALENT:ARG:吸血鬼) && ADD_RUNNING_WATER(CFLAG:ARG:現在位置)
	RETURNF 2
SIF (!ADD_SWIMMING_SEASON() && CFLAG:ARG:現在位置/100 != 9) && !TALENT:ARG:水棲 && !TALENT:ARG:氷精
	RETURNF 1
RETURNF 0

@ADD_SWIMMING_SEASON
#FUNCTION
SELECTCASE DAY:2
	CASE 1
		RETURNF DAY:3 > 15 ;second half of spring is warm enough
	CASE 2
		RETURNF 1
	CASE 3
		RETURNF DAY:3 < 15 ;second half of autumn is still warm enough
	CASE 4
		RETURNF 0 ;too cold for normal people
ENDSELECT

@ADD_START_SWIMMING(ARG)
IF !ADD_IN_SWIMWEAR(ARG)
	CALL ADD_SWIMMING_OUTFIT(ARG)
ENDIF
TEQUIP:ARG:SWIMMING = 1

@ADD_END_SWIMMING(ARG)
IF TCVAR:ARG:EVENT_CLOTHING_SET
	SIF CFLAG:ARG:現在位置 == CFLAG:MASTER:現在位置
		PRINTFORML %CALLNAME:ARG%换回了衣服
	CALL RESET_EVENT_CLOTHES(ARG)
ENDIF
TEQUIP:ARG:SWIMMING = 0

@ADD_SWIMMING_OUTFIT(ARG)
#DIM DYNAMIC WEIGHTS, 100
;skinny dipping? (do later)
#DIM BIKINI
#DIM MICRO_BIKINI
#DIM SCHOOL_SWIMSUIT
#DIM COMPETITION_SWIMSUIT
#DIM ONE_PIECE_SWIMSUIT
#DIM SLING_SWIMSUIT
#DIM SWIMMING_TRUNKS
#DIM SWIM_DIAP
#DIM SELECTED_SWIMWEAR
#DIM DYNAMIC EROTICISM

IF !BIKINI ;only fetch ids once, since they're not character-dependent
	SWIMMING_TRUNKS = OBJNAME_TO_ID(ARG, "GET", "衣装セット", "泳裤装")
	BIKINI = OBJNAME_TO_ID(ARG, "GET", "衣装セット", "比基尼套装")
	MICRO_BIKINI = OBJNAME_TO_ID(ARG, "GET", "衣装セット", "微型比基尼套装")
	SCHOOL_SWIMSUIT = OBJNAME_TO_ID(ARG, "GET", "衣装セット", "死库水泳衣")
	COMPETITION_SWIMSUIT = OBJNAME_TO_ID(ARG, "GET", "衣装セット", "竞技泳衣")
	ONE_PIECE_SWIMSUIT = OBJNAME_TO_ID(ARG, "GET", "衣装セット", "连体泳衣")
	SLING_SWIMSUIT = OBJNAME_TO_ID(ARG, "GET", "衣装セット", "Y字型内衣")
	;SWIM_DIAP = OBJNAME_TO_ID(ARG, "GET", "衣装セット", "Swim Diaper Set")
ENDIF

IF 0;CANT_UNDIES(ARG)
	;skip those who can't wear undies
	SELECTED_SWIMWEAR = 100
ELSEIF 0;(CanWearUnderwear(ARG, "Diaper")) && nOmutsu
	;NAS: incon 2hus wear swim diapers
	SELECTED_SWIMWEAR = SWIM_DIAP
ELSEIF IS_FEMALE(ARG)
	IF !TALENT:ARG:無知 || TALENT:ARG:小悪魔 ;not ignorant, or a temptress
		EROTICISM = MIN(ABL:ARG:露出癖, 30) ;exposure
		EROTICISM -= OTOKOGIRAI(ARG) ? 3 # 0 ;misandrist
		EROTICISM += TALENT:ARG:性的興味 * 2 ;conservative/curious
		EROTICISM += TALENT:ARG:目立ちたがり * 3 ;show-off
		EROTICISM += TALENT:ARG:セフレ ? 3 # 0 ;sex friend
		EROTICISM += TALENT:ARG:愛欲 * 5 ;lust
		EROTICISM -= TALENT:ARG:貞操 * 5 ;virtuous/unchaste
		EROTICISM += TALENT:ARG:小悪魔 * 10 ;seductress
		EROTICISM += TALENT:ARG:胸圍 * 2 ;breast size
		EROTICISM += TALENT:ARG:ヒップサイズ * 2 ;butt size
		EROTICISM -= TALENT:ARG:羞恥心 * 6 ;shameless/shy

		SIF GET_TARGETNUM() > 1 && !TALENT:ARG:淫乱
			EROTICISM /= 2
		EROTICISM = MAX(EROTICISM, 0)
		SIF TALENT:ARG:無知 && !TALENT:ARG:小悪魔 ;ignorant, not a temptress
			EROTICISM = 0
	ENDIF

	WEIGHTS:BIKINI = 20
	WEIGHTS:MICRO_BIKINI = EROTICISM
	WEIGHTS:ONE_PIECE_SWIMSUIT = 10
	WEIGHTS:COMPETITION_SWIMSUIT = ABL:ARG:戦闘能力 * 2 * (CFLAG:ARG:性格傾向 == 4 ? 2 # 1) ;combat skill + serious personality

	IF (IS_CHILD(ARG, "mind") || IS_CHILD(ARG, "age")) && !TALENT:ARG:小悪魔 ;child's mindset
		WEIGHTS:MICRO_BIKINI /= 2
		WEIGHTS:SCHOOL_SWIMSUIT = 40
		IF TALENT:ARG:胸圍 < 0
			WEIGHTS:SWIMMING_TRUNKS = 5
		ELSE
			WEIGHTS:SLING_SWIMSUIT = EROTICISM / 4
		ENDIF
	ELSEIF IS_CHILD(ARG, "body") && !TALENT:ARG:小悪魔 ;child's body
		WEIGHTS:SCHOOL_SWIMSUIT = 10
		WEIGHTS:ONE_PIECE_SWIMSUIT = 20
		IF TALENT:ARG:胸圍 < 0
			WEIGHTS:SWIMMING_TRUNKS = 5
		ELSE
			WEIGHTS:SLING_SWIMSUIT = EROTICISM / 2
		ENDIF
	ELSE ;adults
		WEIGHTS:SCHOOL_SWIMSUIT = EROTICISM / 2 ;it's basically fetish wear to adults
		WEIGHTS:SLING_SWIMSUIT = EROTICISM
		SIF TALENT:ARG:胸圍 < 0
			WEIGHTS:SWIMMING_TRUNKS = EROTICISM / 4
	ENDIF

	SELECTED_SWIMWEAR = ARRAY_HIT(WEIGHTS, 100)
ELSE
	SELECTED_SWIMWEAR = SWIMMING_TRUNKS
ENDIF
IF ARG == MASTER
	PRINTFORML 你迅速换上了泳装
ELSEIF CFLAG:ARG:現在位置 == CFLAG:MASTER:現在位置 ;only show dialogue if present
	IF !SELECTED_SWIMWEAR
		PRINTFORML %CALLNAME:ARG%找了一块岩石放好了自己的衣服
		PRINTFORML 光溜溜地回来了
	ELSEIF ABL:ARG:露出癖 < 5 || (GET_TARGETNUM() > 1 && ABL:ARG:露出癖 < 10)
		PRINTFORML %CALLNAME:ARG%到附近一块岩石后面换上了泳装
		PRINTFORM 回来时穿着
	ELSE
		PRINTFORML %CALLNAME:ARG%换上了泳装，丝毫不在意\@ GET_TARGETNUM() > 1 ? 旁人 # +++ \@的视线
		PRINTFORM 没过多久就换好了
	ENDIF

	SELECTCASE SELECTED_SWIMWEAR
		CASE 0
		CASE SWIM_DIAP
			PRINTFORML 一条防水的尿不湿。
		CASE BIKINI
			PRINTFORML 一件可爱的比基尼，完美衬托出%HE_SHE_CN(ARG)%的身材。
		CASE MICRO_BIKINI
			PRINTFORM 一件大胆的超小比基尼，
			SELECTCASE TALENT:ARG:胸圍
				CASE -3
					PRINTFORML 穿在%HE_SHE_CN(ARG)%平坦的胸部上显得非常别扭。
				CASE -3
					PRINTFORML 根本不适合%HE_SHE_CN(ARG)%那小小的胸部。
				CASE -1
					PRINTFORML 与%HE_SHE_CN(ARG)%纤细的身材形成鲜明对比。
				CASE 0
					PRINTFORML 让%HE_SHE_CN(ARG)%散发出成熟的气息。
				CASE 1
					PRINTFORML 让%HE_SHE_CN(ARG)%的胸部更加突出。
				CASE 2, 3, 4
					PRINTFORML 完全束缚不住%HE_SHE_CN(ARG)%的丰满胸部。
			ENDSELECT
		CASE SCHOOL_SWIMSUIT
			PRINTFORML 一件印有%HE_SHE_CN(ARG)%名字的学校泳衣。
			SIF TALENT:ARG:胸圍 > 0
				PRINTFORML 但是，\@ TALENT:ARG:ヒップサイズ > 0 ? 胸部和胯部 # 胸部 \@绷得相当紧。
			SIF TALENT:ARG:ヒップサイズ > 0 && TALENT:ARG:胸圍 <= 0
				PRINTFORML 然而，胯部的布料绷得相当紧。
		CASE COMPETITION_SWIMSUIT
			PRINTFORML 一件运动型且舒适的泳衣。
		CASE ONE_PIECE_SWIMSUIT
			PRINTFORML 一件可爱的连体泳衣。
		CASE SLING_SWIMSUIT
			PRINTFORM 一件非常暴露的Y字高叉泳衣，
			SELECTCASE TALENT:ARG:胸圍
				CASE -2,-3
					PRINTFORML 穿在%HE_SHE_CN(ARG)%身上，与其说色情不如说更显可爱。
				CASE -1
					PRINTFORML 穿在%HE_SHE_CN(ARG)%身上，与其说大胆不如说更显可爱。
				CASE 0
					PRINTFORML 令人想入非非的部位若隐若现。
				CASE 1
					PRINTFORML 完全起不到蔽体的作用，反而更显诱惑。
				CASE 2,3,4
					PRINTFORML 完全起不到蔽体的作用，紧绷在%HE_SHE_CN(ARG)%丰满的胸部上。
			ENDSELECT
		CASE SWIMMING_TRUNKS
			IF IS_MALE(ARG)
				PRINTFORML 一条简单的泳裤
			ELSE
				PRINTFORML 一条男式泳裤
			ENDIF
			SELECTCASE TALENT:ARG:ヒップサイズ
				CASE -3
					PRINTFORML ，对于%HE_SHE_CN(ARG)%太大了，不得不一直往上提。
				CASE -2
					PRINTFORML ，似乎有点大了。
				CASE -1
					PRINTFORML ，几乎垂到%HE_SHE_CN(ARG)%的膝盖。
				CASE 0
					PRINTFORML 。
				CASE 1
					PRINTFORML ，似乎有点小了。
				CASE 2
					PRINTFORML ，裹着%HE_SHE_CN(ARG)%%HIP(ARG)%，更像是热裤。
				CASE 3
					PRINTFORML ，几乎遮不住%HE_SHE_CN(ARG)%%HIP(ARG)%。
				CASE 4
					PRINTFORML ，几乎遮不住%HE_SHE_CN(ARG)%%HIP(ARG)%。
			ENDSELECT
	ENDSELECT
ENDIF

CALL SET_EVENT_CLOTHES(ARG, SELECTED_SWIMWEAR)

@ADD_IN_SWIMWEAR(ARG)
#FUNCTION
RETURNF GET_INT(ARG, "衣装セット", CFLAG:ARG:基本服装セット, "SWIMWEAR")

@ADD_BYSTANDERS_JOIN_SWIMMING
FOR LOCAL, 1, GET_TARGETNUM() + 1
	IF !TEQUIP:(TARGET:LOCAL):SWIMMING && ADD_SWIMMING_CONSTITUTION(TARGET:LOCAL) && !(MARK:(TARGET:LOCAL):反発刻印 || CFLAG:(TARGET:LOCAL):ブチギレ) ; NAS: Hate 4 and 5
		CALL ADD_START_SWIMMING(TARGET:LOCAL)
	ENDIF
NEXT

@ADD_WEATHER_HARSHNESS(LOCATION)
#FUNCTION
#DIM LOCATION
;based on COM411
SIF !OUTROOF(LOCATION) ;probably won't be relevant unless Remilia's pool is ever included
	RETURNF 0
SELECTCASE TIME:5
	CASE 4,6,8,10,12,13
		IF WIND_VELOCITY >= 1
			;(天候パッチ)強風時はヤバい天気
			RETURNF 2
		ELSE
			;悪天候
			RETURNF 1
		ENDIF
	CASE 5,9,14,15
		;ヤバい天気
		IF WIND_VELOCITY >= 1
			RETURNF 3
		ELSE
			RETURNF 2
		ENDIF
	;それ以外
	CASEELSE
		;(天候パッチ)強風時は悪天候
		SIF WIND_VELOCITY == 1
			RETURNF 1
		;(天候パッチ)暴風時はヤバい天気
		SIF WIND_VELOCITY >= 2
			RETURNF 2
ENDSELECT
RETURNF 0

;checks if character will join in, even in dangerous conditions
@ADD_SWIMMING_CONSTITUTION(CHARA)
#FUNCTION
;#DIM WEATHER_HARSHNESS
#DIM CHARA
SIF !CHARA
	RETURNF 1 ;master can always join
IF !BASE:CHARA:気力 ;no energy left
	SIF CHARA == TARGET
		TFLAG:194 = 1
	RETURNF 0
ENDIF
SIF !ADD_SWIMMING_AREA(CFLAG:CHARA:現在位置)
	RETURNF 0

LOCAL = ADD_SWIMMING_DAMAGE(CHARA)
IF LOCAL > 1 && MAXBASE:CHARA:体力 < 4000 ;vampires need a strong constitution to join in
	SIF CHARA == TARGET
		TFLAG:194 = 3
	RETURNF 0
ELSEIF LOCAL == 1 && MAXBASE:CHARA:体力 < 2500 ;cold, not resistant, need good constitution to join in
	SIF CHARA == TARGET
		TFLAG:194 = 4
	RETURNF 0
ENDIF

SELECTCASE ADD_WEATHER_HARSHNESS(CFLAG:MASTER:現在位置) ;can join if they have a high constitution (determined by max STA)
	CASE 0
		RETURNF 1
	CASE 1
		SIF MAXBASE:CHARA:体力 >= 2000
			RETURNF 1
	CASE 2
		SIF MAXBASE:CHARA:体力 >= 3500
			RETURNF 1
	CASE 3
		SIF MAXBASE:CHARA:体力 >= 5000
			RETURNF 1
ENDSELECT
RETURNF 1