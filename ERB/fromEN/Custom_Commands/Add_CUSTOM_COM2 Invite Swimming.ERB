@ADD_CUSTOM_MESSAGE_COM2
PRINTFORML +++邀请%CALLNAME:TARGET%一起来游泳
SELECTCASE TFLAG:194
	CASE 1
		PRINTFORML %CALLNAME:TARGET%表示很疲惫了
	CASE 2
		PRINTFORML %CALLNAME:TARGET%不悦地拒绝了
	
	CASE 3
		PRINTFORML %CALLNAME:TARGET%谢绝了，流水会伤害到她
	CASE 4
		PRINTFORML %CALLNAME:TARGET%的体格承受不了这么冷的水温
ENDSELECT
