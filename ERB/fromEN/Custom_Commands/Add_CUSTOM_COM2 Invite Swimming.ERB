@ADD_CUSTOM_COM2
IF !ADD_SWIMMING_CONSTITUTION(TARGET)
	RETURN 0
ELSEIF MARK:反発刻印 || CFLAG:ブチギレ
	TFLAG:194 = 2
	RETURN 0
ELSE
	CALL ADD_START_SWIMMING(TARGET)
	CALL ADD_BYSTANDERS_JOIN_SWIMMING
	TIME += 5
RETURN 1
ENDIF
