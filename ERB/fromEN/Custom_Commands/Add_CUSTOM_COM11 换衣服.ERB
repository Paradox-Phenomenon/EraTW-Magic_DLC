@ADD_CUSTOM_COM11
IF TALENT:恋慕 || TALENT:恋人
	IF CFLAG:MASTER:300 == CFLAG:MASTER:311
	;你先生的卧室
		PRINTL 要如何提议呢？
		PRINT [0] - 提议换上浴袍  
		SETCOLOR 216,160,166
		PRINT [1] - 提议换上白衬衫  
		RESETCOLOR
		PRINT 
		IF TALENT:恋人
			SETCOLOR 196,97,140
			PRINT [2] - 提议全裸
			RESETCOLOR
		ENDIF
		DO
		INPUT
		SELECTCASE RESULT
		CASE 0
			TFLAG:194 = 2
			CALL CTRL_CLOTHES_SET(TARGET, "現在衣装の変更_衣装セット", 68)
			CALL CLOTHES_SETTING_TRAIN(TARGET)
			TIME += 2
			CFLAG:TARGET:同行 = 0				;清除与当前角色的同行状态，保证角色不动的同时你先生可自由移动
			CFLAG:TARGET:延迟 = 60				;抑制角色自由移动所用变量
			TCVAR:TARGET:TIME_CLOTHING_SET = 1	;抑制复原衣物操作所用变量
		CASE 1
			TFLAG:194 = 4
			CALL CTRL_CLOTHES_SET(TARGET, "現在衣装の変更_衣装セット", 60)
			CALL CLOTHES_SETTING_TRAIN(TARGET)
			TIME += 3
			CFLAG:TARGET:同行 = 0
			CFLAG:TARGET:延迟 = 60
			TCVAR:TARGET:TIME_CLOTHING_SET = 1
		CASE 2
			TFLAG:194 = 5
			CALL CTRL_CLOTHES_SET(TARGET, "現在衣装の変更_全裸")
			CALL CLOTHES_SETTING_TRAIN(TARGET)
			TIME += 1
			CFLAG:TARGET:同行 = 0
			CFLAG:TARGET:延迟 = 60
			TCVAR:TARGET:TIME_CLOTHING_SET = 1	
		CASEELSE
			CONTINUE
		ENDSELECT
		BREAK
		LOOP 1
	ELSEIF CFLAG:MASTER:300 == CFLAG:TARGET:311
	;角色卧室
		PRINTL 要如何选择呢？
		PRINT [0] - 提议换身干衣服  
		SETCOLOR 216,160,166
		PRINT [1] - 提议换身内衣裤  
		RESETCOLOR
		IF TALENT:恋人
			SETCOLOR 196,97,140
			PRINT [2] - 提议全裸
			RESETCOLOR
		ENDIF
		DO
		INPUT
		SELECTCASE RESULT
		CASE 0
			TFLAG:194 = 1
			CALL CTRL_CLOTHES_SET(TARGET, "現在衣装の変更_便装")
			CALL CLOTHES_SETTING_TRAIN(TARGET)
			TIME += 3
		CASE 1
			TFLAG:194 = 3
			CALL CTRL_CLOTHES_SET(TARGET, "現在衣装の変更_下着姿")
			CALL CLOTHES_SETTING_TRAIN(TARGET)
			TIME += 2
			CFLAG:TARGET:同行 = 0
			CFLAG:TARGET:延迟 = 60
			TCVAR:TARGET:TIME_CLOTHING_SET = 1
		CASE 2
			TFLAG:194 = 5
			CALL CTRL_CLOTHES_SET(TARGET, "現在衣装の変更_全裸")
			CALL CLOTHES_SETTING_TRAIN(TARGET)
			TIME += 1
			CFLAG:TARGET:同行 = 0
			CFLAG:TARGET:延迟 = 60
			TCVAR:TARGET:TIME_CLOTHING_SET = 1
		CASEELSE
			CONTINUE
		ENDSELECT
		BREAK
		LOOP 1
	ELSE
	;情色旅店
		TFLAG:194 = 5
		CALL CTRL_CLOTHES_SET(TARGET, "現在衣装の変更_全裸")
		CALL CLOTHES_SETTING_TRAIN(TARGET)
		TIME += 1
		CFLAG:TARGET:延迟 = 60
		TCVAR:TARGET:TIME_CLOTHING_SET = 1
		;往下的两个变量主要是限制你先生在外带着角色自由移动（全裸出门逛街吗，那很厉害了）
		CFLAG:MASTER:延迟 = 60
		TCVAR:MASTER:TIME_CLOTHING_SET = 1
	ENDIF
	;你先生的卧室
ELSE
	IF CFLAG:MASTER:300 == CFLAG:TARGET:311
	;角色的卧室
		TFLAG:194 = 1
		CALL CTRL_CLOTHES_SET(TARGET, "現在衣装の変更_便装")
		CALL CLOTHES_SETTING_TRAIN(TARGET)
		CFLAG:TARGET:同行 = 0
		TIME += 3
	ELSE
	;你先生的卧室、情色旅店
		TFLAG:194 = 2
		CALL CTRL_CLOTHES_SET(TARGET, "現在衣装の変更_衣装セット", 68)
		CALL CLOTHES_SETTING_TRAIN(TARGET)	
		TIME += 2
		CFLAG:TARGET:延迟 = 60
		TCVAR:TARGET:TIME_CLOTHING_SET = 1
		IF CFLAG:MASTER:300 != CFLAG:MASTER:311
			CFLAG:MASTER:延迟 = 60
			TCVAR:MASTER:TIME_CLOTHING_SET = 1
		ENDIF
	ENDIF
ENDIF
湿身度:TARGET = 0 

@ADD_CUSTOM_COM_ABLE11
SIF !TFLAG:100  ;会话实行判定
	RETURN 0
SIF FLAG:70 ;时停状态还要拿熨衣服当扒衣服理由？回答我！Look in my eyes!
    RETURN 0
SIF CFLAG:うふふ	;做爱的时候有另外的脱衣逻辑
	RETURN 0
SIF !湿身度:TARGET   ;没湿身脱啥
    RETURN 0
SIF !Tequip:0 && !Tequip:1   ;已经全裸了就用不着了
    RETURN 0
SIF CFLAG:MASTER:300 != GET_MAP_REPLACEMENT(P225情人用宿屋) && CFLAG:MASTER:300 != GET_MAP_REPLACEMENT(P935情人旅館) && CFLAG:MASTER:300 != CFLAG:MASTER:311 && CFLAG:MASTER:300 != CFLAG:TARGET:311
	RETURN 0
SIF !TARGET
	RETURN 0
RETURN 1

@ADD_CUSTOM_MESSAGE_COM11
SELECTCASE TFLAG:194
CASE 1	;换成角色的衣服
	PRINTFORM %CALLNAME:PLAYER%提议换件干衣服
	IF TALENT:恋人 || TALENT:恋慕	
		PRINTFORML  
		PRINTFORM %CALLNAME:TARGET%
			IF TARGET == 57
				PRINTFORM 瞧了一眼%CALLNAME:PLAYER%，默默地
			ELSE
				PRINTFORM 看着似乎有些不满，不过还是
			ENDIF
			PRINTFORML 走到自己的衣柜旁边解开衣服…		
	ELSEIF TALENT:思慕
		PRINTFORML ，然后乖乖地将身子背了过去
		PRINTFORM %CALLNAME:TARGET%
		IF TARGET == 57
			PRINTFORM 切出猿猴面具
		ELSE
			PRINTFORM 脸上泛红
		ENDIF
		PRINTFORML 的同时，一边挪到衣柜边一边开始宽衣解带…
	ELSE
		PRINTFORML ，然后乖乖地将身子背了过去
		PRINTFORM %CALLNAME:TARGET%
		IF TARGET == 57
			PRINTFORM 切出狮子面具，
		ELSE
			PRINTFORM 带着警惕的神情，
		ENDIF
		PRINTFORML 一边注意%CALLNAME:PLAYER%的动作，一边缓缓挪到衣柜旁…
	ENDIF
CASE 2	;换成浴袍
	PRINTFORM %CALLNAME:PLAYER%向%CALLNAME:TARGET%提议在衣服晾干前先换上
	IF CFLAG:MASTER:300 == CFLAG:MASTER:311
		PRINTFORML 自己洗澡时常穿的浴袍
	ELSE
		PRINTFORML 旅店里提供的浴袍
	ENDIF
	PRINTFORM %CALLNAME:TARGET%
	IF TALENT:恋人 || TALENT:恋慕	
		IF TARGET == 57
			PRINTFORM 切出猿猴面具，在%CALLNAME:PLAYER%的目视下走进浴室…
		ELSE
			PRINTFORML 微微一笑，在%CALLNAME:PLAYER%的目视下走进浴室…
		ENDIF	
	ELSEIF TALENT:思慕
		IF TARGET == 57
			PRINTFORM 切出猿猴面具
		ELSE
			PRINTFORM 脸上泛红
		ENDIF
		PRINTFORML 的同时，对建议本身似乎也不是很不满的样子…
	ELSE
		IF TARGET == 57
			PRINTFORM 切出狮子面具，
		ELSE
			PRINTFORM 带着警惕的神情，
		ENDIF
		PRINTFORML 看向%CALLNAME:TARGET%和其递来的衣服…
	ENDIF
CASE 3	;只换上内衣（恋慕特有）
	PRINTFORML %CALLNAME:PLAYER%提议让%CALLNAME:TARGET%换上自己的干燥内衣
	PRINTFORM %CALLNAME:TARGET%	
	IF TARGET == 57
		PRINTFORM 切出猿猴面具，侧过眼神，
	ELSE
		PRINTFORM 有些羞涩地微微一笑，然后
	ENDIF
	IF TALENT:恋人
		PRINTFORML 在%CALLNAME:PLAYER%的目视下宽衣解带起来…
	ELSE
		PRINTFORML 背过身去，缓缓解开自己身上的束缚…
	ENDIF
CASE 4	;换成裸白衬衫（恋慕特有）
	PRINTFORML %CALLNAME:PLAYER%拿了件白衬衫，提议让%CALLNAME:TARGET%换上这身
	PRINTFORM %CALLNAME:TARGET%	
	IF TARGET == 57
		PRINTFORM 切出猿猴面具，
	ELSEIF TALENT:恋人
		PRINTFORM 羞涩着上扬起嘴角，然后
	ELSE
		PRINTFORM 的目光有些慌乱，但最后还是
	ENDIF
	IF TALENT:恋人
		PRINTFORML 在%CALLNAME:PLAYER%的目视下宽衣解带起来…
	ELSE
		PRINTFORML 背过身去，缓缓解开自己身上的束缚…
	ENDIF
CASE 5	;全裸（恋慕特有）
	PRINTFORML %CALLNAME:PLAYER%提议和%CALLNAME:TARGET%一起光着身子等候
	PRINTFORM %CALLNAME:TARGET%	
	IF TARGET == 57
		PRINTFORM 切出猿猴面具，
	ELSEIF TALENT:恋人
		PRINTFORM 也似是早有预料，
	ELSE
		PRINTFORM 不禁面红耳赤，但还是
	ENDIF
	IF TALENT:恋人
		PRINTFORML 在%CALLNAME:PLAYER%的贪婪视姦中，诱惑似的缓缓剥去身上的衣衫…
	ELSE
		PRINTFORML 一点点地脱下自己身上湿漉漉的衣服…
	ENDIF
ENDSELECT