@关系_INFO(ARG)
#FUNCTIONS
#DIMS 关系
关系 = 
SIF TALENT:ARG:恋人
	关系 += @"%GET_TALENTNAME(TALENT_恋人, TALENT:ARG:恋人)%/"
SIF TALENT:ARG:恋慕
	关系 += @"%GET_TALENTNAME(TALENT_恋慕, TALENT:ARG:恋慕)%/"
SIF TALENT:ARG:思慕
	关系 += @"%GET_TALENTNAME(TALENT_思慕, TALENT:ARG:思慕)%/"
SIF TALENT:ARG:炮友
    关系 += @"%GET_TALENTNAME(TALENT_炮友, TALENT:ARG:炮友)%/"
SIF TALENT:ARG:爱欲
    关系 += @"%GET_TALENTNAME(TALENT_爱欲, TALENT:ARG:爱欲)%/"
SIF CFLAG:ARG:清い交際
    关系 += "纯洁交往/"
IF TALENT:ARG:把柄 && ARG != MASTER
    关系 += @"被玩家拿捏了把柄/"
ELSEIF TALENT:ARG:把柄 && ARG == MASTER
    关系 += @"拿捏了玩家的把柄/"
ENDIF
关系 += @"好感度等级:%CALC_RANKF(CFLAG:ARG:好感度, "MAX_50000")%/"
关系 += @"信赖度等级:%CALC_RANKF(CFLAG:ARG:信頼度, "MAX_20000")%/"
关系 += @"亲密等级:%CALC_RANKF(ABL:ARG:親密, "MAX_99")%/"
关系 += @"欲望等级:%CALC_RANKF(ABL:ARG:欲望, "MAX_99")%/"
SIF MARK:ARG:反発刻印
    关系 += @"惹火了%NAME:ARG%,等级为{MARK:ARG:反発刻印}/"
RETURNF 关系

