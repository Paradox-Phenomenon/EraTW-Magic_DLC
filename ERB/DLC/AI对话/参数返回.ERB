@GET_CURRENT_ACTION_INFO(CHARA)
#DIM CHARA
VARSET RESULTS
RESULTS:1 = 当前人物:%NAME:CHARA%
RESULTS:2 = 当前行动:%TRAINNAME_TR(SELECTCOM)%
RESULTS:3 = 当前状态:%状态_INFO(CHARA)%
RESULTS:4 = 当前装备:%装备_INFO(CHARA)%
RESULTS:5 = 关系信息:%关系_INFO(CHARA)%
RESULTS:6 = 身体信息:%身体_INFO(CHARA)%
RESULTS:7 = 能力信息:%能力_INFO(CHARA)%
RESULTS:8 = 性履历信息:%履历_INFO(CHARA)%
RESULTS:9 = 性格信息:%性格_INFO(CHARA)%
RESULTS:10 = 当前同一位置的人:%同室人_INFO(CHARA)%
RESULTS:11 = 成否判定:%成否判定()%
RESULTS:12 = 环境信息:%环境信息_INFO()%
FOR LOCAL, 0, 13
    PRINTFORML %RESULTS:LOCAL%
NEXT
@成否判定()
#FUNCTIONS
IF TFLAG:192 == -2
    LOCALS = 指令未实行
ELSEIF TFLAG:192 == -1
    LOCALS = 失败
ELSE
    SELECTCASE M_TFLAG:成功
        CASE 1
            LOCALS = 大成功
        CASE 2
            LOCALS = 大失败
        CASEELSE
            LOCALS = 一般成功
    ENDSELECT
ENDIF
RETURNF LOCALS




@状态_INFO(ARG)
#FUNCTIONS
LOCALS =
IF TALENT:ARG:心情 == 1
	LOCALS += "・好心情"
ELSEIF TALENT:ARG:心情 == -1
	LOCALS += "・不高兴"
ENDIF
IF CHECK_HEHAI(ARG)
    SELECTCASE KEHAI
        CASE 1
            LOCALS += "什么都没在做"
        CASE 2
            LOCALS += "工作中"
        CASE 3
            LOCALS += "睡眠中"
        CASE 4
            LOCALS += "自由行动中"
    ENDSELECT
ENDIF
SIF TCVAR:ARG:発情
    LOCALS += "・发情中"
SIF TCVAR:ARG:烂醉
    LOCALS += "・烂醉中"
IF CFLAG:ARG:睡眠
    SELECTCASE TCVAR:ARG:睡眠薬強度
        CASE 1
            LOCALS += "・深度睡眠"
        CASE 2
            LOCALS += "・极深睡眠"
        CASE 3
            LOCALS += "・昏睡中"
        CASEELSE
            LOCALS += "・睡眠中"
    ENDSELECT
ELSEIF TCVAR:ARG:睡眠薬強度
    SELECTCASE TCVAR:ARG:睡眠薬強度
        CASE 1
            LOCALS += "・睡意"
        CASE 2
            LOCALS += "・强烈睡意"
        CASE 3
            LOCALS += "・朦胧中"
    ENDSELECT
ENDIF
RETURNF LOCALS

