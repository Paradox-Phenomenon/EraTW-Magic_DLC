@环境信息_INFO
#FUNCTIONS
#DIMS 环境信息
环境信息 = 季节:
环境信息 += @"%GET_MONTH()%/"
环境信息 += @"天气:%GET_WEATHER()%/"
环境信息 += "时间:"
SELECTCASE TIME
    ;AM0~3
    CASE 0 TO 179
        环境信息 += "凌晨/"
    ;AM3~6
    CASE 180 TO 359
        环境信息 += "黎明/"
    ;AM6~9
    CASE 360 TO 539
        环境信息 += "早晨/"
    ;AM9~12
    CASE 540 TO 719
        环境信息 += "上午/"
    ;PM0~3
    CASE 720 TO 899
        环境信息 += "下午/"
    ;PM3~6
    CASE 900 TO 1079
        环境信息 += "傍晚/"
    ;PM6~9
    CASE 1080 TO 1259
        环境信息 += "夜晚/"
    ;PM9~12
    CASE IS >= 1260
        环境信息 += "深夜/"
    CASEELSE
        环境信息 += "时间段错误/"   
ENDSELECT
IF FESTIVAL() != ""
	环境信息 += @"节日:%FESTIVAL_TR()%/"
ENDIF
环境信息 += @"地点:%GET_MAPNAME(GET_MAPID(CFLAG:MASTER:现在位置))%-%NAME_FROM_PLACE(CFLAG:MASTER:现在位置)%/"
RETURNF 环境信息

@CALC_RANKF(VAR_VALUE, RANK_SCALE)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM VAR_VALUE
#DIMS RANK_SCALE
#DIM RANK
#DIM RANK_NUM 
#DIMS RANKS
#FUNCTIONS
SELECTCASE RANK_SCALE
    CASE "MAX_50000"
    ;好感度用
        RANK_NUM = 10
        SELECTCASE VAR_VALUE
        CASE IS >= 50000
            RANK = 0
        CASE IS >= 30000
            RANK = 1
        CASE IS >= 10000
            RANK = 2
        CASE IS >=  5000
            RANK = 3
        CASE IS >=  3000
            RANK = 4
        CASE IS >=  1500
            RANK = 5
        CASE IS >=  1000
            RANK = 6
        CASE IS >=   500
            RANK = 7
        CASE IS >=   100
            RANK = 8
        CASEELSE
            RANK = 9
        ENDSELECT
    CASE "MAX_20000"
    ;信赖度用
        RANK_NUM = 10
        IF !MAGIC_DLC_好感亲密重做
            SELECTCASE VAR_VALUE
            CASE IS >= 20000
                RANK = 0
            CASE IS >= 10000
                RANK = 1
            CASE IS >=  3000
                RANK = 2
            CASE IS >=  1000
                RANK = 3
            CASE IS >=   500
                RANK = 4
            CASE IS >=   150
                RANK = 5
            CASE IS >=   100
                RANK = 6
            CASE IS >=    50
                RANK = 7
            CASE IS >=    10
                RANK = 8
            CASEELSE
                RANK = 9
            ENDSELECT
        ELSE
            SELECTCASE VAR_VALUE
                CASE IS >= 20000
                    RANK = 0
                CASE IS >= 8000
                    RANK = 1
                CASE IS >=  3000
                    RANK = 2
                CASE IS >=  1500
                    RANK = 3
                CASE IS >=   700
                    RANK = 4
                CASE IS >=   250
                    RANK = 5
                CASE IS >=   100
                    RANK = 6
                CASE IS >=    50
                    RANK = 7
                CASE IS >=    10
                    RANK = 8
                CASEELSE
                    RANK = 9
            ENDSELECT
        ENDIF
    CASE "MAX_99"
    ;技術系以外のABL
        ;数字が縦に並ぶと非常に見にくかったんで意図的にインデントずらしてます
        RANK_NUM = 10
        SELECTCASE VAR_VALUE
        CASE IS >= 99
                RANK = 0
        CASE IS >= 75
                RANK = 1
        CASE IS >= 50
                RANK = 2
        CASE IS >= 20
                RANK = 3
        CASE IS >= 10
                RANK = 4
        CASE IS >=  5
                RANK = 5
        CASE IS >=  3
                RANK = 6
        CASE IS >=  2
                RANK = 7
        CASE IS >=  1
                RANK = 8
        CASEELSE
                RANK = 9
        ENDSELECT
    CASE "MAX_6"
    ;技能系ABL
        RANK_NUM = 7
        RANK = MAX(6 - VAR_VALUE, 0)
    CASEELSE
        THROW 不明なRANK_SCALE %RANK_SCALE%
ENDSELECT
SELECTCASE RANK
    CASE 0
        RANKS = "Ex"
    CASE 1
        RANKS = SS
    CASE 2
        RANKS = S
    CASE 3
        RANKS = A
    CASE 4
        RANKS = B
    CASE 5
        RANKS = C
    CASE 6
        RANKS = D
    CASE 7
        RANKS = E
    CASE 8
        RANKS = F
    CASEELSE
        RANKS = G
ENDSELECT
RETURNF RANKS
