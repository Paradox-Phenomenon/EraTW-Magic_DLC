@EVENT_WUXING_START
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS L_TEXT
; 根据全局变量悟性开局事件的值
SELECTCASE 悟性开局事件
    CASE 1
        IF TALENT:MASTER:278 != 1
			SETCOLOR C_RED
            PRINTL 你迷茫地睁开双眼，对自己此前的身世一无所知
			PRINTFORML 你遗忘了自己的出身，也遗忘了那些赖以生存的知识
			PRINTFORML 尽管你现在仅仅略强于大字不识一个的稚童，但好在你聪明的大脑没有受伤
			PRINTFORML 希望这些许灵性能够帮助你爬上顶峰
			RESETCOLOR
            ; 用户待补充文字，先留注释
            ; PRINTFORML ...
            TALENT:MASTER:278 = 1
			悟性开局事件 = 0
        ENDIF
    CASE 2
        ; 检查所有技能是否都小于1
        IF ABL:MASTER:教養 < 2 && (ABL:MASTER:清掃技能 + ABL:MASTER:話術技能 + ABL:MASTER:戦闘能力 + ABL:MASTER:音楽技能 + ABL:MASTER:料理技能) < 2
			SETCOLOR C_RED
			PRINTFORML 盲目与痴愚一直困扰着你，如果你能够找到一点破除你头脑中笼罩的迷雾的依仗的话·····
			RESETCOLOR
            TALENT:MASTER:278 = -1
        ELSE
            ; 至少一项 >=1
			SETCOLOR C_YELLOW
			PRINTL
			PRINTL
			PRINTL
			PRINTL
			PRINTL
			PRINTL
			PRINTL
			PRINTL
			PRINTL
			PRINTL
			PRINTL
			PRINTL
			PRINTFORML 忽地顿开金枷，这里扯断玉锁
			PRINTFORML 幻想乡中仙风来，今日方知我是我
			PRINTL
			PRINTL
			PRINTL
			PRINTFORML 破茧成蝶，你的灵性觉醒了！
			RESETCOLOR
            TALENT:MASTER:278 = 2
			悟性开局事件 = 0
        ENDIF
    CASEELSE
        ; 其他情况不做处理
ENDSELECT
