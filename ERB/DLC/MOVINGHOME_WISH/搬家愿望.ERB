;该文件存放有关“搬家愿望”（Moving Home Wish）这个补丁的相关函数
;补丁的创作灵感源于不能随时让少女搬到我家的恨！（凭什么一定要月初啊？！）
;可以预见的是由于参考的只是NEWMEMBER_ADD这个函数，因此大概率会有BUG，如有问题还请提出！（去贴吧上反馈吧，我会注意的）
;补丁内容如下：
;①在祈愿中添加了“希望她能来到我家……”选项（需要在OPTIONS中开启住宿事件）
;②选项保证目前不位于大地图的少女能够搬到自机房间（或者相关的其他空房间），本质上是月初搬家事件的补充
;③房间只能入住除自机外的最多一人，多了会很麻烦的，这点还请见谅（另外对少女的素质还有经验有额外要求，参考搬家时的角色筛选）
;④搬家愿望许下后次日选定的少女便会入住，可以在入住发生前取消愿望（但是请不要在许愿后下一天就搬家，否则愿望作废）
;以上，愿您生活愉快
;顺便一提这已经是我做的第2个本体相关内容了（）

;搬家愿望菜单
@MHW_MENU
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM FIRSTTIME_FLAG
#DIM INPUT_INT
VARSET LOCAL
gLineCount = LINECOUNT
DRAWLINE
PRINTFORML %"可搬家角色",16% %"搬家状态",15% %"搬家位置",15%
DRAWLINE

;初始化列表
CALL MHW_INIT
MHW_WishExists = 0
MHW_EmplyPlace = MHW_GETMOVABLEPLACE(MASTER)

;获取搬家列表
FOR LOCAL, 1, CHARANUM
	SIF TALENT:LOCAL:路人
		CONTINUE
	SIF MHW_CANMOVEHOME(LOCAL)
		SETBIT MHW_WishList:LOCAL, 0
	IF GETBIT(MHW_WishList:LOCAL, 0)
		IF GETBIT(MHW_WishList:LOCAL, 1)
			MHW_WishExists = 1
			SETCOLOR C_YELLOW
		ENDIF
		PRINTBUTTON @"[{LOCAL, 3}] %CALLNAME:LOCAL, 10% %MHW_MOVINGSTATUE(LOCAL), 15% %MHW_SHOWMOVINGPLACE(LOCAL, 0), 15%", LOCAL
		RESETCOLOR
		PRINTL 
	ENDIF
NEXT

DRAWLINE
PRINTFORMDL [999] - 退出

DO
	INPUT
	CLEARLINE 1
	INPUT_INT = RESULT
	SELECTCASE INPUT_INT
		CASE 0 TO CHARANUM
			IF GETBIT(MHW_WishList:INPUT_INT, 0)
				CALL MHW_PLACESELECT(INPUT_INT)
			ELSE
				GOTO RETRY
			ENDIF
			CLEARLINE LINECOUNT - gLineCount
			RESTART
		CASE 999
			RETURN
		CASEELSE
			$RETRY
			CONTINUE
	ENDSELECT
LOOP 1

;初始化相关
@MHW_INIT
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
SIF LOCAL
	RETURN 
FOR CHARA, 1, CHARANUM
	SIF TALENT:CHARA:路人
		CONTINUE
	IF CHARA == FLAG:住宿人物 && SUMIKOMI_ROOM && CFLAG:CHARA:初期位置 == SUMIKOMI_ROOM
		MHW_HomeList:CHARA = SUMIKOMI_ROOM
	ELSE
		MHW_HomeList:CHARA = CSVCFLAG(CHARA, GETNUM(CFLAG, "初期位置"))
	ENDIF
NEXT
LOCAL ++

;搬家状态显示函数
@MHW_MOVINGSTATUE(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
IF GETBIT(MHW_WishList:ARG, 1)
	IF GETBIT(MHW_WishList:ARG, 2)
		RETURNF "搬出"
	ELSE
		RETURNF "搬进"
	ENDIF
ENDIF
RETURNF "未定"

;是否可以搬家
@MHW_CANMOVEHOME(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
RETURNF GET_MAPID(CSVCFLAG(ARG, GETNUM(CFLAG, "初期位置"))) != MAIN_MAP && ((TALENT:ARG:恋慕 && EXP:ARG:愛情経験 >= 50) || TALENT:ARG:愛欲)

;搬家位置获取函数
@MHW_GETMOVINGPLACE(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
IF GETBIT(MHW_WishList:ARG, 1)
	IF !GETBIT(MHW_WishList:ARG, 3)
		IF GETBIT(MHW_WishList:ARG, 2)
			RETURNF CSVCFLAG(ARG, GETNUM(CFLAG, "初期位置"))
		ELSE
			RETURNF CFLAG:MASTER:初期位置
		ENDIF
	ELSE
		RETURNF MHW_GETMOVABLEPLACE(ARG)
	ENDIF
ENDIF
RETURNF 0

;搬家位置显示函数（分为简略表示与完整表示）
@MHW_SHOWMOVINGPLACE(ARG, ARG:1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
IF GETBIT(MHW_WishList:ARG, 1)
	IF MHW_GETMOVINGPLACE(ARG) == CSVCFLAG(ARG, GETNUM(CFLAG, "初期位置"))
		RETURNF ARG:1 == 1 ? STR_TR(8000 + CSVCFLAG(ARG, GETNUM(CFLAG, "初期位置"))) # "原来房间"
	ELSEIF MHW_GETMOVINGPLACE(ARG) == CFLAG:MASTER:初期位置
		RETURNF ARG:1 == 1 ? STR_TR(8000 + CFLAG:MASTER:初期位置) # "你的房间"
	ELSEIF MHW_GETMOVINGPLACE(ARG) == MHW_GETMOVABLEPLACE(ARG) || MHW_GETMOVINGPLACE(ARG) == MHW_EmplyPlace
		RETURNF ARG:1 == 1 ? STR_TR(8000 + MHW_GETMOVABLEPLACE(ARG)) # "空的房间"
	ENDIF
ENDIF
RETURNF ""

;搬家位置选择
@MHW_PLACESELECT(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
PRINTFORMD %CALLNAME:ARG%的当前住所为：
IF !GROUPMATCH(MHW_HomeList:ARG % 100, 0, 99)
	PRINTFORMD %STR_TR(8000 + MHW_HomeList:ARG)%
ELSE
	PRINTD 未知地点
ENDIF
IF MHW_HomeList:ARG == CSVCFLAG(ARG, GETNUM(CFLAG, "初期位置"))
	PRINTDL （原住所）
ELSE
	PRINTDL （非原住所）
ENDIF
PRINTFORMD 设定的住所为：
IF GETBIT(MHW_WishList:ARG, 1)
	PRINTFORMD %MHW_SHOWMOVINGPLACE(ARG, 1)%
	IF MHW_GETMOVINGPLACE(ARG) == CSVCFLAG(ARG, GETNUM(CFLAG, "初期位置"))
		PRINTDL （原住所）
	ELSE
		PRINTDL （非原住所）
	ENDIF
ELSE
	PRINTDL 暂无
ENDIF
PRINTFORMDL 请选择搬家位置：
IF MHW_HomeList:ARG != CSVCFLAG(ARG, GETNUM(CFLAG, "初期位置"))
	SIF GETBIT(MHW_WishList:ARG, 1) && GETBIT(MHW_WishList:ARG, 2)
		SETCOLOR C_YELLOW
	PRINTFORML [0] - 搬回原来的房间（%STR_TR(8000 + CSVCFLAG(ARG, GETNUM(CFLAG, "初期位置")))%）
ELSE
	SETCOLOR C_L_GRAY
	PRINTPLAINFORM [0] - 搬回原来的房间（%STR_TR(8000 + CSVCFLAG(ARG, GETNUM(CFLAG, "初期位置")))%）
	PRINTL 
ENDIF
RESETCOLOR
IF MHW_HomeList:ARG != CFLAG:MASTER:初期位置 && !MHW_CHECKSUMIKOMIROOM(ARG)
	SIF GETBIT(MHW_WishList:ARG, 1) && !GETBIT(MHW_WishList:ARG, 2) && !GETBIT(MHW_WishList:ARG, 3)
		SETCOLOR C_YELLOW
	PRINTFORML [1] - 搬到%CALLNAME:MASTER%的房间（%STR_TR(8000 + CFLAG:MASTER:初期位置)%）
ELSE
	SETCOLOR C_L_GRAY
	PRINTPLAINFORM [1] - 搬到%CALLNAME:MASTER%的房间（%STR_TR(8000 + CFLAG:MASTER:初期位置)%）
	PRINTL 
ENDIF
RESETCOLOR
IF MHW_HomeList:ARG != MHW_GETMOVABLEPLACE(ARG) && MHW_GETMOVABLEPLACE(ARG)
	SIF GETBIT(MHW_WishList:ARG, 1) && !GETBIT(MHW_WishList:ARG, 2) && GETBIT(MHW_WishList:ARG, 3)
		SETCOLOR C_YELLOW
	PRINTFORML [2] - 搬到空房间（%STR_TR(8000 + MHW_GETMOVABLEPLACE(ARG))%）
ELSE
	SETCOLOR C_L_GRAY
	PRINTPLAINFORM [2] - 搬到空房间（当前没有空房间）
	PRINTL 
ENDIF
RESETCOLOR
PRINTFORML [999] - 退出

gLineCount:1 = LINECOUNT
$MHW_CHOICE
CLEARLINE LINECOUNT - gLineCount:1
INPUT
SELECTCASE RESULT
	CASE 0
		IF MHW_HomeList:ARG != CSVCFLAG(ARG, GETNUM(CFLAG, "初期位置"))
			IF GETBIT(MHW_WishList:ARG, 1) && GETBIT(MHW_WishList:ARG, 2)
				CLEARBIT MHW_WishList:ARG, 1
				CLEARBIT MHW_WishList:ARG, 2
				CLEARBIT MHW_WishList:ARG, 3
			ELSE
				SETBIT MHW_WishList:ARG, 1
				SETBIT MHW_WishList:ARG, 2
				CLEARBIT MHW_WishList:ARG, 3
			ENDIF
		ELSE
			GOTO RETRY
		ENDIF
	CASE 1
		IF MHW_HomeList:ARG != CFLAG:MASTER:初期位置 && !MHW_CHECKSUMIKOMIROOM(ARG)
			IF GETBIT(MHW_WishList:ARG, 1) && !GETBIT(MHW_WishList:ARG, 2) && !GETBIT(MHW_WishList:ARG, 3)
				CLEARBIT MHW_WishList:ARG, 1
				CLEARBIT MHW_WishList:ARG, 2
				CLEARBIT MHW_WishList:ARG, 3
			ELSE
				SETBIT MHW_WishList:ARG, 1
				CLEARBIT MHW_WishList:ARG, 2
				CLEARBIT MHW_WishList:ARG, 3
			ENDIF
		ELSE
			GOTO RETRY
		ENDIF
	CASE 2
		IF MHW_HomeList:ARG != MHW_GETMOVABLEPLACE(ARG) && MHW_GETMOVABLEPLACE(ARG)
			IF GETBIT(MHW_WishList:ARG, 1) && !GETBIT(MHW_WishList:ARG, 2) && GETBIT(MHW_WishList:ARG, 3)
				CLEARBIT MHW_WishList:ARG, 1
				CLEARBIT MHW_WishList:ARG, 2
				CLEARBIT MHW_WishList:ARG, 3
			ELSE
				SETBIT MHW_WishList:ARG, 1
				CLEARBIT MHW_WishList:ARG, 2
				SETBIT MHW_WishList:ARG, 3
			ENDIF
		ELSE
			GOTO RETRY
		ENDIF
	CASE 999

	CASEELSE
		$RETRY
		GOTO MHW_CHOICE
ENDSELECT

;检测是否有人决定或已经在你的房间里了（除要搬过来的ARG外）
@MHW_CHECKSUMIKOMIROOM(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
FOR LOCAL, 1, CHARANUM
	SIF LOCAL == ARG
		CONTINUE
	SIF (GETBIT(MHW_WishList:LOCAL, 1) && !GETBIT(MHW_WishList:LOCAL, 2) && !GETBIT(MHW_WishList:LOCAL, 3)) || MHW_HomeList:LOCAL == CFLAG:MASTER:初期位置
		RETURNF 1
NEXT
RETURNF 0

;搬家愿望对应的搬家函数
@MHW_NEWMEMBER_ADD
#LOCALSIZE 1
#LOCALSSIZE 1
PRINTFORML 许下的愿望似乎被神明听到了……
IF MHW_GETMOVABLEPLACE(MASTER) != MHW_EmplyPlace
	PRINTFORML 但由于你在许愿后又很快选择了搬家，故而祂对于你的期望感到疑惑
	PRINTFORML 愿望被弃置了……
ELSE
	PRINTFORML 希望少女搬家的心愿经由祂得以传达……
	FOR LOCAL, 0, CHARANUM
		IF GETBIT(MHW_WishList:LOCAL, 1)
			PRINTFORML %CALLNAME:LOCAL%选择\@ !GETBIT(MHW_WishList:LOCAL, 2) ? 来到了%STR_TR(5000 + MAIN_MAP)% # 回到原来的家\@，地点是%MHW_SHOWMOVINGPLACE(LOCAL, 1)%
			IF !GETBIT(MHW_WishList:LOCAL, 2)
				FLAG:住宿人物 = LOCAL
				M_CFLAG:LOCAL:后宫居住标记 = 1
				CFLAG:LOCAL:初期位置 = MHW_GETMOVINGPLACE(LOCAL)
				CFLAG:LOCAL:神社在住 = MHW_GETMOVINGPLACE(LOCAL)
				CFLAG:LOCAL:現在位置 = MHW_GETMOVINGPLACE(LOCAL)
			ELSE
				M_CFLAG:LOCAL:后宫居住标记 = 0
				CFLAG:LOCAL:初期位置 = SUKIMA()
				CFLAG:LOCAL:神社在住 = 0
				CFLAG:LOCAL:現在位置 = GET_MAP_REPLACEMENT(MHW_GETMOVINGPLACE(LOCAL))
			ENDIF
			MHW_HomeList:LOCAL = MHW_GETMOVINGPLACE(LOCAL)
		ENDIF
	NEXT
	CALL ROOMSETTING
ENDIF
PRINTFORML 

MHW_WishExists = 0


;可用于搬家的空房间获取
@MHW_GETMOVABLEPLACE(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
IF ARG != MASTER
	FOR LOCAL, 1, CHARANUM
		SIF LOCAL == ARG 
			CONTINUE
		SIF (GETBIT(MHW_WishList:LOCAL, 1) && !GETBIT(MHW_WishList:LOCAL, 2) && GETBIT(MHW_WishList:LOCAL, 3)) || MHW_HomeList:LOCAL == MHW_EmplyPlace
			RETURNF 0
	NEXT
	RETURNF MHW_EmplyPlace
ENDIF
SELECTCASE MAIN_MAP
	CASE 0
		;暂时不加入大别墅
		SELECTCASE CFLAG:MASTER:初期位置
			CASE P15霊夢私室, P18壁櫥間, P19大的倉庫, P52別屋, P55和室, P69先代巫女的小屋
				RETURNF P53倉庫
			CASE P32桑尼私室, P33露娜私室, P34斯塔私室
				RETURNF P35三妖精之家・地下室
			CASE P43夢美私室, P44千百合私室
				RETURNF P51夢幻遺跡・倉庫
		ENDSELECT
	CASE 1
		SELECTCASE CFLAG:MASTER:初期位置
			CASE P109女苑私室, P113納茲琳私室, P114村紗私室, P115星私室, P116一輪私室, P117鵺私室, P118白蓮私室, P136響子私室, P137猯藏の棲家
				RETURNF P119別屋
			CASE P125屠自古私室, P127布都私室, P128神子私室
				RETURNF P134蔵
		ENDSELECT
	CASE 2
		;按理说雪和舞的房间应该是弃用了也就是空置的，但这里不将其作为可选项
		SELECTCASE CFLAG:MASTER:初期位置
			CASE P208雷鼓的房間, P209八橋的房間, P210弁弁的房間, P230空的部屋, P231蛮奇的房間, P232蓮子的房間, P233梅莉的房間
				RETURNF P241空的部屋
		ENDSELECT
	CASE 3
		SELECTCASE CFLAG:MASTER:初期位置
			CASE P303守衛小屋, P311帕秋莉私室, P312小悪魔私室, P320咲夜私室, P326蕾米莉亜私室, P331地下室
				RETURNF P304空的小屋
		ENDSELECT
	CASE 4
		SELECTCASE CFLAG:MASTER:初期位置
			CASE P410帝私室, P411鈴仙私室, P412空的部屋, P413永琳私室, P414輝夜私室, P412空的部屋
				RETURNF P428二階空的部屋
			CASE P428二階空的部屋
				RETURNF P412空的部屋
			CASE P451胡桃私室, P452艾麗私室, P457夢月私室, P459幻月私室, P463幽香私室
				RETURNF P460空的部屋
			CASE P432影狼的家, P443米斯蒂亜的家, P445妹紅的家
				RETURNF P442空的小屋
		ENDSELECT
	CASE 5
		SELECTCASE CFLAG:MASTER:初期位置
			CASE P512魔理沙宅・寝室
				RETURNF P515魔理沙宅・倉庫
			CASE P521人偶洋館・愛麗絲的房間
				RETURNF P531人偶洋館・空的部屋
			CASE P535艾伦宅・寝室
				RETURNF P536艾伦宅・倉庫
		ENDSELECT
	CASE 6
		SELECTCASE CFLAG:MASTER:初期位置
			CASE P615映姫的房間, P616小町的房間
				RETURNF P618空的部屋
			CASE P623幽幽子私室, P624妖夢私室
				RETURNF P625空室
			CASE P633紫私室, P635橙私室, P638藍私室
				RETURNF P634空部屋
		ENDSELECT
	CASE 7
		SELECTCASE CFLAG:MASTER:初期位置
			CASE P717秋姉妹的家・寝室
				RETURNF P719秋姉妹的家・座敷
			CASE P727仙人的宅邸・華扇私室
				RETURNF P728仙人的宅邸・空的部屋
			CASE P753浅间的房间, P760磐永神社内屋
				RETURNF P754空房间
			CASE P704河童の宣傳站, P706厄神的家, P709莉莉們的家, P737招财猫的家
				RETURNF P734小屋
		ENDSELECT
	CASE 8
		SELECTCASE CFLAG:MASTER:初期位置
			CASE P807椛宅, P808文宅, P809果宅, P851久侘歌の小屋, P852駒草の小屋, P853魅須丸の小屋, P869龙宅客卧
				RETURNF P810山小屋
			CASE P817神奈子私室, P818諏訪子私室, P820早苗私室
				RETURNF P823空室
			CASE P839比那名居邸和室, P840天子私室, P841衣玖私室
				RETURNF P842比那名居邸庫房
			CASE P872典的卧室, P873龙的卧室
				RETURNF P869龙宅客卧
		ENDSELECT
	CASE 9
		SELECTCASE CFLAG:MASTER:初期位置
			CASE P911阿空私室, P912阿燐私室, P918恋私室, P919覚私室
				RETURNF P916庫房
			CASE P940帕露西的家, P941山女的家, P942琪斯美的家
				RETURNF P937空屋
		ENDSELECT
	CASE 10
		SELECTCASE CFLAG:MASTER:初期位置
			CASE P1006探女宅・寝室, P1008鈴瑚宅, P1009清蘭宅
				RETURNF P1007闲置的房子
			CASE P1032鈴仙二號私室, P1041豊姫私室, P1042依姫私室
				RETURNF P1033綿月亭・空的部屋
			CASE P1051哆来咪宅・寝室
				RETURNF P1052哆来咪宅・倉庫
			CASE P1064克勞恩皮絲私室, P1071純狐私室, P1072赫卡提亚私室
				RETURNF P1063純狐邸・空的部屋
		ENDSELECT
	CASE 11
		SELECTCASE CFLAG:MASTER:初期位置
			CASE P1118雪的公寓, P1120舞的公寓, P1124奥莲姬的公寓, P1126里香的公寓, P1128露易兹的公寓
				RETURNF P1122空屋子
			CASE P1165万魔殿・梦子卧室, P1167万魔殿・神绮卧室
				RETURNF P1168万魔殿・空屋
		ENDSELECT

ENDSELECT
RETURNF 0