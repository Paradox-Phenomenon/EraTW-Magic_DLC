@SP_WEATHERCHANGED()
#DIM 无天气
无天气 = IS_NO_WEATHER_SEE(AT_AREA(MASTER))
SELECTCASE TIME:5
;晴天の时
CASE 0,1,19
	FOR LOCAL, 0, CHARANUM
		IF MAXBASE:LOCAL:気力 <= 1500
	 		MAXBASE:LOCAL:気力 = 1500
	 		BASE:LOCAL:気力 = MAXBASE:LOCAL:気力
		ENDIF
	NEXT
	;20%继续是晴天
	IF RAND:5 == 0
		IF TIME:5 == 1
	 		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 	PRINTW 天空上一丝云彩都找不到
		ENDIF
		TIME:5 = 0
	;20%晴朗
	ELSEIF RAND:4 == 0
		IF TIME:5 == 0
	 		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 	PRINTW 天空上漂浮着几缕云彩
		ENDIF
		TIME:5 = 1
	;20%几率多云
	ELSEIF RAND:3 == 0
		TIME:5 = 2
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 变成了多云天气了
	;10%几率阴天
	ELSEIF RAND:4 == 0
		TIME:5 = 3
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 浓浓的云彩遮盖了天空
	;10%几率晴岚
	ELSEIF RAND:3 == 0 && TIME:2 >= 6 && TIME:2 <= 1
		TIME:5 = 17
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 升腾起了淡淡的烟雾
	;10%几率无风
	ELSEIF TIME:5 != 19 && RAND:2 == 0
		TIME:5 = 19
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 一丝风都没有
	;4%几率太阳雨
	ELSEIF RAND:25 == 0
		TIME:5 = 14
	SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
		PRINTW 下起了暴雨！
	;夏天6%几率冰雹
	ELSEIF DAY:2 == 2
		IF RAND:1 == 0
	 		TIME:5 = 13
	 		FOR LOCAL, 0, CHARANUM
	 		 	MAXBASE:LOCAL:気力 += 300
	 		NEXT
		ENDIF
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 突然下起了冰雹！
	;其他季节2%几率冰雹
	ELSEIF RAND:3 == 0
		TIME:5 = 13
		FOR LOCAL, 0, CHARANUM
	 		MAXBASE:LOCAL:気力 += 300
		NEXT
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 突然下起了冰雹！
	;上记概率に引っかからなかったら晴天
	ENDIF
;阴天の时
CASE 2,3
	;20%几率变晴
	IF RAND:5 == 0
		IF TIME:5 == 2
	 		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 	PRINTW 天空上漂浮着几缕云彩
	 		TIME:5 = 1
		ELSE
	 		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 	PRINTW 变成了多云天气了
	 		TIME:5 = 2
		ENDIF
	;20%几率不变
	ELSEIF RAND:4 == 0
		TIME:5 = TIME:5
	;10%几率加重
	ELSEIF RAND:6
		IF TIME:5 == 2
	 		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 	PRINTW 浓浓的云彩遮盖了天空
		ENDIF
		TIME:5  = 3
	;10%几率晴天
	ELSEIF RAND:5 == 0
		TIME:5 = 0
		IF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		IF TIME:2 >= 5 && TIME:2 <= 7
	 		 	PRINTW 可以看见星星了
	 		ELSE
	 		 	PRINTW 太阳出来了
	 		ENDIF
		ENDIF
	;多云なら10%で雨か雪に移行
	ELSEIF TIME:5 == 2
		IF RAND:4 == 0
	 		IF DAY:2 == 4
	 		 	TIME:5 = 8
	 		 	SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 		PRINTW 下雪了！
	 		ELSEIF DAY:2 == 3
	 		 	IF RAND:2 == 0
	 		 		TIME:5 = 20
	 		 		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 PRINTW 稀稀拉拉的下起了梅雨
	 		 	ENDIF
	 		ELSE
	 		 	TIME:5 = 4
	 		 	SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 		PRINTW 下雨了！
	 		ENDIF
		ENDIF
		IF RAND:2 == 0 && TIME:2 >= 6 && TIME:2 <= 1
	 		IF RAND:2 == 0
	 		 	TIME:5 = 7
	 		ELSE
	 		 	TIME:5 = 18
	 		ENDIF
	 		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 	PRINTW 起雾了
		ENDIF
	ELSEIF TIME:5 == 3 && RAND:4 == 0
		IF DAY:2 == 2
	 		TIME:5 = 16
	 		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 	PRINTW 雨伴随着风落到了地面上
		ENDIF
	;阴天なら30%で雨に移行
	ELSEIF TIME:5 == 3 && RAND:1 == 0
		IF DAY:2 == 4
	 		TIME:5 = 8
	 		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 	PRINTW 下雪了！
		ELSE
	 		TIME:5 = 4
	 		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 	PRINTW 下雨了！
		ENDIF
	ENDIF
;雨の时
CASE 4,5,6,14,15,16,20
	;25%变成大雨
	IF RAND:4 == 0
		IF TIME:5 != 5 && TIME:5 != 14
	 		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 	PRINTW 大雨倾盆落下！！！
	 		TIME:5 = 5
		ENDIF
	;25%阴天
	ELSEIF RAND:3 == 0
		TIME:5 = 3
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 雨要停了的样子
		;念のため相合い伞を解除
		FOR LOCAL,0,CHARANUM
	 		SIF TEQUIP:LOCAL:201
	 		 	TEQUIP:LOCAL:201 = 0
		NEXT
	;雨なら10%で雾雨か雨雪交加に移行
	ELSEIF TIME:5 == 4 && RAND:5 == 0
		IF DAY:2 == 4
	 		TIME:5 = 12
	 		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 	PRINTW 雨中掺了一些雪花
		ELSE
	 		TIME:5 = 6
	 		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 	PRINTW 雨点变小了
	 		ENDIF
	;10%で晴天に移行
	ELSEIF RAND:4 == 0
		TIME:5 = 0
		IF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		;かもしれないといいつつ确实に见えるのは气分をよくさせる魔法
	 		IF TIME:2 >= 5 && TIME:2 <= 7
	 		 	PRINTW 突然星空变的晴朗了！说不定能看到月下彩虹呢
	 		ELSE
	 		 	PRINTW 突然太阳出来了！说不定能看到彩虹呢
	 		ENDIF
	 		FOR LOCAL,0,CHARANUM
	 		 	SIF TEQUIP:LOCAL:201
	 		 		TEQUIP:LOCAL:201 = 0
	 		NEXT
		ENDIF
		;更に低概率で晴朗
		SIF RAND:5 < 1
	 		TIME:5 = 1
		;雨→晴天を处理したら虹が出る
		TIME:7 = 1
	ENDIF
CASE 7,17,18
	IF TIME:2 > 1 || TIME:2 < 6
		TIME:5 = 0
		IF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 雾散去了
		ENDIF
	ELSEIF RAND:4 == 0
		TIME:5 = 0
		IF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		IF TIME:2 >= 5 && TIME:2 <= 7
	 		 	PRINTW 可以看见星星了
	 		ELSE
	 		 	PRINTW 太阳出来了
	 		ENDIF
		ENDIF
	ELSEIF RAND:3 == 0
		TIME:5 = 1
		IF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 雾渐渐的散了
		ENDIF
	ENDIF
;雪の时
CASE 8
	;雪は冬以外降らない
	IF DAY:2 != 4
		;雨になる
		TIME:5 = 4
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 雪天好像变成了雨天的样子
	;10%で强化
	ELSEIF RAND:10 == 0
		TIME:5 = 9
		PRINTW 雪花变得更加密集了！！！
	;30%の概率で弱体化
	ELSEIF RAND:3 == 0
		IF RAND:2 == 0
	 		TIME:5 = 10
		ELSE
	 		TIME:5 = 11
		ENDIF
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 降雪好像变弱了
	ELSEIF RAND:2 == 0
	 		TIME:5 = 3
	 		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 	PRINTW 雪好像停了的样子
	 		FOR LOCAL,0,CHARANUM
	 		 	SIF TEQUIP:LOCAL:201
	 		 		TEQUIP:LOCAL:201 = 0
	 		NEXT
	;雪なら10%で细雪か雨雪交加に移行
	ELSEIF RAND:3 == 0
	 		TIME:5 = 12
	 		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		 	PRINTW 雪中掺了一些雨点
	;10%で晴天に移行
	ELSEIF RAND:2 == 0
		TIME:5 = 0
		IF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		IF TIME:2 >= 5 && TIME:2 <= 7
	 		 	PRINTW 突然星空变的晴朗了！说不定能看到钻石尘呢
	 		ELSE
	 		 	PRINTW 突然太阳出来了！说不定能看到钻石尘呢
	 		ENDIF
	 		FOR LOCAL,0,CHARANUM
	 		 	SIF TEQUIP:LOCAL:201
	 		 		TEQUIP:LOCAL:201 = 0
	 		NEXT
		ENDIF
		;更に低概率で晴朗
		SIF RAND:5 < 1
	 		TIME:5 = 1
		TIME:7 = 2
	ENDIF
CASE 9,12
	;雪は冬以外降らない
	IF DAY:2 != 4
		;雨になる
		TIME:5 = 4
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 雪天好像变成了雨天的样子
	ELSEIF RAND:5 == 0
		TIME:5 = 8
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 雪变小了
	ELSEIF RAND:4 == 0
		TIME:5 = 0
		IF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		IF TIME:2 >= 5 && TIME:2 <= 7
	 		 	PRINTW 突然星空变的晴朗了！说不定能看到钻石尘呢
	 		ELSE
	 		 	PRINTW 突然太阳出来了！说不定能看到钻石尘呢
	 		ENDIF
	 		FOR LOCAL,0,CHARANUM
	 		 	SIF TEQUIP:LOCAL:201
	 		 		TEQUIP:LOCAL:201 = 0
	 		NEXT
		ENDIF
		;更に低概率で晴朗
		SIF RAND:5 < 1
	 		TIME:5 = 1
		TIME:7 = 2
	ENDIF
CASE 10,11
	;雪は冬以外降らない
	IF DAY:2 != 4
		;雨になる
		TIME:5 = 3
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 雪天好像变成了雨天的样子
	ELSEIF RAND:2 == 0
		TIME:5 = 8
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 雪变小了
	ELSEIF RAND:5 == 0
		TIME:5 = 0
		IF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		IF TIME:2 >= 5 && TIME:2 <= 7
	 		 	PRINTW 突然星空变的晴朗了！说不定能看到钻石尘呢
	 		ELSE
	 		 	PRINTW 突然太阳出来了！说不定能看到钻石尘呢
	 		ENDIF
	 		FOR LOCAL,0,CHARANUM
	 		 	SIF TEQUIP:LOCAL:201
	 		 		TEQUIP:LOCAL:201 = 0
	 		NEXT
		ENDIF
		;更に低概率で晴朗
		SIF RAND:5 < 1
	 		TIME:5 = 1
		TIME:7 = 2
	ENDIF
CASE 13
	IF RAND:5 < 4
		FOR LOCAL, 0, CHARANUM
	 		MAXBASE:LOCAL:気力 -= 300
	 		IF BASE:LOCAL:気力 >= MAXBASE:LOCAL:気力
	 		 	BASE:LOCAL:気力 = MAXBASE:LOCAL:気力
	 		ENDIF
		NEXT
		TIME:5 = 0
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
	 		PRINTW 冰雹消失了
	ENDIF
CASEELSE
	TIME:5 = RAND:5
ENDSELECT
