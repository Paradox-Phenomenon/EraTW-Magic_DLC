@Pt01(LOCAL,ARG,ARGS,ARG:1,ARGS:1,ARG:2,ARGS:2,ARG:3,ARGS:3)
;PrintOn/Off
PRINTFORM %ARGS, 15%：
IF LOCAL
	SETCOLOR 0x00FF00
	LOCALS=已启动
	IF ARG:1>0&&ARGS:1!=""
		LOCALS'=ARGS:1
	ELSEIF ARG:2&&ARGS:2!=""
		LOCALS'=ARGS:2
	ELSEIF ARG:3&&ARGS:3!=""
		LOCALS'=ARGS:3
	ENDIF
ELSE
	SETCOLOR 0x994C00
	LOCALS=未启动
	SIF ARG:1<0&&ARGS:1!=""
		LOCALS'=ARGS:1
ENDIF
PRINTFORM %LOCALS, 25, LEFT%
RESETCOLOR
PRINTFORML %@"[{ARG,2,RIGHT}] %ARGS%设置"%