;--------------------------------------------------
;PrintOn/Off，LOCAL，开启条件；ARG，选项编号；ARGS，补丁名
;默认显示文字已/未启动，如需更改填写后续ARG:1……
;ARG:1，条件1，正为启动，负为未启动；ARGS:1显示文字；以此类推
;由于仅存在启动模式1~3，未启动单一情况，条件2、3非0显示已启动
;--------------------------------------------------
@Pt01(LOCAL,ARG,ARGS,ARG:1,ARGS:1,ARG:2,ARGS:2,ARG:3,ARGS:3)
#LOCALSIZE 1
#LOCALSSIZE 1
PRINTFORM %ARGS, 15%：
IF LOCAL
	SETCOLOR 0x00FF00
	LOCALS=已启动
	IF ARG:1>0&&ARGS:1!=""
		LOCALS'=ARGS:1
	ELSEIF ARG:2&&ARGS:2!=""
		LOCALS'=ARGS:2
	ELSEIF ARG:3&&ARGS:3!=""
		LOCALS'=ARGS:3
	ENDIF
ELSE
	SETCOLOR 0x994C00
	LOCALS=未启动
	SIF ARG:1<0&&ARGS:1!=""
		LOCALS'=ARGS:1
ENDIF
PRINTFORM %LOCALS, 25, LEFT%
RESETCOLOR
PRINTFORML %@"[{ARG,2,RIGHT}] %ARGS%设置"%
