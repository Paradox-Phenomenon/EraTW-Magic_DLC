;==================================================
; @完全变成炮房了呢
; 检测私室是否变成了炮房（最近7天内在私室与超过2名不同角色发生过关系）
;==================================================
@完全变成炮房了呢
#DIM CONST 炮房值 = 3
#DIM CONST 最大尝试次数 = 10
#LOCALSIZE 6
#LOCALSSIZE 1
#DIM L_MY_ROOM
#DIM L_DATE_THRESHOLD
#DIM L_LOG_COUNT
#DIM L_UID
#DIMS L_PARTNER_LIST,7
#DIM L_TEMP_MEMBER
#DIM L_TEMP_DATE
#DIM L_TEMP_DAY
#DIM L_WEEKDAY_IDX

#DIM DYNAMIC L_SAMPLE_PARTNERS, 7
#DIM DYNAMIC L_SAMPLE_DATES, 3
#DIM DYNAMIC L_SAMPLE_COUNT

;接收要删除的行数
LOCAL:5 = RESULT

L_LOG_COUNT = DT_SELECT(DT_UFUFU_LOG, @"%DT_ULOG_PLACE% = {CFLAG:MASTER:初期位置} AND %DT_ULOG_DATE% >= {(DAY - 7) * 1440} AND %DT_ULOG_DATE% < {DAY * 1440}", "", TEMP_LOG_ROWS)

IF L_LOG_COUNT == 0
	RETURN 0
ENDIF

FOR LOCAL, 0, L_LOG_COUNT
	; 获取该场战斗的 UID 和 日期(DAY)
	L_UID = DT_CELL_GET(DT_UFUFU_LOG, TEMP_LOG_ROWS:LOCAL, DT_ULOG_ID, 1)
	L_TEMP_DATE = DT_CELL_GET(DT_UFUFU_LOG, TEMP_LOG_ROWS:LOCAL, DT_ULOG_DATE, 1)
	L_TEMP_DAY = L_TEMP_DATE / 1440
	L_WEEKDAY_IDX = L_TEMP_DAY - (DAY - 7)
	; 查询该 UID 对应的所有参与者
	LOCAL:1 = DT_SELECT(DT_UFUFU_M_LOG, @"%DT_ULOG_ID% = {L_UID}", "", TEMP_MLOG_ROWS)
	FOR LOCAL:2, 0, LOCAL:1
		L_TEMP_MEMBER = DT_CELL_GET(DT_UFUFU_M_LOG, TEMP_MLOG_ROWS:(LOCAL:2), DT_ULOG_MEMBER, 1)
		GT_SET '= L_PARTNER_LIST:L_WEEKDAY_IDX
		CALLF SET_UPDATECHECK(L_TEMP_MEMBER,"GT_SET",,1)
		L_PARTNER_LIST:L_WEEKDAY_IDX '= GT_SET
		DEBUGPRINTFORML L_PARTNER_LIST:{L_WEEKDAY_IDX} = %L_PARTNER_LIST:L_WEEKDAY_IDX%
	NEXT
NEXT

GT_SET =
FOR LOCAL, 0, 7
	SIF GROUPMATCH(L_PARTNER_LIST:LOCAL, "/", "")
		CONTINUE
	REPEAT 20
		L_TEMP_MEMBER = TOINT(TEXTR(L_PARTNER_LIST:LOCAL))
		IF L_TEMP_MEMBER > 0 && !SET_UPDATECHECK(L_TEMP_MEMBER,"GT_SET",,1)
			DEBUGPRINTFORML 0:GT_SET = %GT_SET%
			L_SAMPLE_PARTNERS:LOCAL = L_TEMP_MEMBER
			L_SAMPLE_COUNT += 1
			BREAK
		ENDIF
	REND
NEXT
IF L_SAMPLE_COUNT >= 炮房值
	CLEARLINE LOCAL:5
	CALL HPH_PRINT, @"HPH但最近…好像完全变成炮房了呢…"   
	COUNT = 0
	FOR LOCAL, 0, 7
		IF L_SAMPLE_PARTNERS:LOCAL
			COUNT += 1
			PRINTFORM 周%GET_DAY_CN(LOCAL + (DAY - 7))%是%CALLNAME:(L_SAMPLE_PARTNERS:LOCAL)%
			IF COUNT < 炮房值
				PRINT 、
			ELSE
				PRINTL …
				BREAK
			ENDIF
		ENDIF
	NEXT
ENDIF

RETURN 0