@attackSnatchFoodChara()
#LOCALSIZE 1
#LOCALSSIZE 1
;when the plugin isn't open
SIF !ASFCConfig
	RETURN 0
PRINTFORML %CALLNAME:TARGET%似乎想要抢夺食物\n要阻止吗?
;yes is false, no is ture……tw is very interesting
CALL ASK_YN()
;yes
IF !RESULT
	CALL attackSnatchFoodCharaFight()
;no
ELSE
	PRINTFORMW %CALLNAME:MASTER%把%EX_DISH_NAME%递给了两眼放光的%CALLNAME:TARGET%
	RETURN 0
ENDIF

;fight
@attackSnatchFoodCharaFight()
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM gradeOfMaster	;fight grade of master
#DIM gradeOfTarget	;fight grade of target
gradeOfTarget = ndRandom(ABL:戦闘能力)
IF ASFCConfig == 1
	gradeOfMaster = ndRandom(ABL:MASTER:戦闘能力) + TALENT:MASTER:神性 * MAGIC_DLC
ELSE
	gradeOfMaster = 7 + MAGIC_DLC_等级重置 * 2
ENDIF
;scuess
IF gradeOfMaster > gradeOfTarget
	PRINTFORMW 经过一番纠缠下、%CALLNAME:MASTER%把%EX_DISH_NAME%藏了起来
	RETURN 1
;fail
ELSE
	PRINTFORMW 最终%CALLNAME:TARGET%还是抢走了%EX_DISH_NAME%
	RETURN 0
ENDIF

;normal distribution random
;once I use normally rand
;I be scold by player because 100 grade ,the result is 10……
;so I think I should use normal distribution random
@ndRandom(num)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM num
#DIM index
#DIM DYNAMIC out
FOR index, 0, num
	out += RAND:2
NEXT
RETURNF out