@GMF_LARGE_MAP_ID()
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
IF !GMF_GETBIT("幻想乡大地图")
	RETURNF MAIN_MAP
ELSEIF !GMF_MAP_MODE
	RETURNF GMF_HOME_MAP
ELSE
	RETURNF GET_MAPID(CFLAG:MASTER:現在位置)
ENDIF

;-----------------------------------------------------------
;判断角色是否在大地图上
;-----------------------------------------------------------
@GMF_AT_LARGE_MAP(ARG)
#FUNCTION
#DIM 当前大地图
当前大地图 = GMF_LARGE_MAP_ID()
IF GET_MAPID(CFLAG:ARG:現在位置) == 当前大地图
	RETURNF 1
ELSE
	RETURNF 0
ENDIF
;-----------------------------------------------------------
;外出地图模式，即普通外出模式和特殊据点模式，该模式下返回的地图都应该是外出地图
;-----------------------------------------------------------
@GMF_IS_ODEKAKE(MAP_ID = -1)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM MAP_ID
SIF MAP_ID == -1
	MAP_ID = GET_MAPID(CFLAG:MASTER:現在位置)
;搬家时默认设0以使用修改的MAIN_MAP，HITOSAGASI等仅据点逻辑调用时设0，ODEKAKEMAP_SETTING等仅外出逻辑调用时设1
SIF 引っ越し
	RETURNF 0
SIF GROUPMATCH(GMF_METHOD_STACK, "OHEYA_CHECK", "HITOSAGASI")
	RETURNF 0
SIF GROUPMATCH(GMF_METHOD_STACK, "ODEKAKEMAP_SETTING", "RANDOM_ODEKAKE")
	RETURNF 1
;根据地图模式决定是否为外出
IF GMF_MAP_MODE
	;特殊地图模式，此时家地图也切换为外出地图
	SIF MAP_ID == GMF_HOME_MAP
		RETURNF 1
ELSE
	;原版地图模式，不在家地图即为外出
	SIF MAP_ID != GMF_HOME_MAP
		RETURNF 1
ENDIF
RETURNF 0
;-----------------------------------------------------------
;获取当前主地图ID
;-----------------------------------------------------------
@GMF_GET_BASE_MAPID()
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
IF GMF_IS_ODEKAKE(-1)
	RETURNF GMF_HOME_MAP
ELSE
	RETURNF GET_MAPID(CFLAG:MASTER:現在位置)
ENDIF
;-----------------------------------------------------------
;地图内（据点）判定，这里应该是判断地点是否在据点
;这个判断有两个含义，第一是在家地图上，第二是在据点地图上
;二者用外出模式来界定似乎可行
;-----------------------------------------------------------
@GMF_IN_HOME(ARG)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC MAP_ID
;外出模式下选用家地图，否则选用玩家所在据点地图
MAP_ID = GMF_IS_ODEKAKE(-1) ? GMF_HOME_MAP # GET_MAPID(CFLAG:MASTER:現在位置)
;特殊的，当玩家在家地图启用外出模式时，视为所有地图都不在据点内
IF GMF_IS_ODEKAKE(-1) && GET_MAPID(CFLAG:MASTER:現在位置) == GMF_HOME_MAP
	RETURNF 0
ELSEIF ARG == GMF_MAXROOM:MAP_ID
	RETURNF 2
ELSEIF INRANGE(ARG, MAP_ID*100+1, GMF_MAXROOM:MAP_ID)
	RETURNF 1
ELSE
	RETURNF 0
ENDIF

;-----------------------------------------------------------
;约会中，与其说是约会中，不如说是外出中的意思……
;我不知道作者怎么想的，估计是因为把所有角色的初始位置都丢隙间，所以约会中锁家地图吧
;总之是看“角色外出状态”的意思，需要和“外出地图模式”做区分
;-----------------------------------------------------------
@GMF_CHK_DATENOW(MAP_ID)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM MAP_ID
;原函数逻辑 RETURNF MAP_ID != MAIN_MAP
RETURNF MAP_ID != GMF_HOME_MAP

;-----------------------------------------------------------
;据点地图移动模式和外出地图移动模式的地点变换
;-----------------------------------------------------------
@GMF_LOCATION_HOME_TO_ODEKAKE
#LOCALSIZE 1
#LOCALSSIZE 1
;玩家位置直接变换
CFLAG:MASTER:現在位置 = GETMETH(@"MAP_SEARCH_REPLACEMENT_{CFLAG:MASTER:現在位置/100}", CFLAG:MASTER:現在位置, CFLAG:MASTER:現在位置)
;角色位置变换
FOR LOCAL, 1, CHARANUM
	;出禁应该跳过变换
	SIF CFLAG:LOCAL:出禁
		CONTINUE
	;角色的职场需要转换，神社在住可能也先变换着吧
	CFLAG:LOCAL:GMF_職場拠点位置 = CFLAG:LOCAL:職場
	CFLAG:LOCAL:職場 = GETMETH(@"MAP_SEARCH_REPLACEMENT_{CFLAG:LOCAL:職場/100}", CFLAG:LOCAL:職場, CFLAG:LOCAL:職場)
	CFLAG:LOCAL:神社在住 = (GET_MAPID(CFLAG:LOCAL:初期位置) == MAIN_MAP) ? CFLAG:LOCAL:初期位置 # 0
	;修正角色位于隙间空间时的状态，即隙间空间情况下角色应该视为处于自宅中
	IF CFLAG:LOCAL:現在位置 % 100 == 0 || CFLAG:LOCAL:現在位置 % 100 == 99
		CFLAG:LOCAL:GMF_現在拠点位置 = CFLAG:LOCAL:初期位置
		CFLAG:LOCAL:現在位置 = CFLAG:LOCAL:自宅位置
	ELSE
		CFLAG:LOCAL:GMF_現在拠点位置 = CFLAG:LOCAL:現在位置
		CFLAG:LOCAL:現在位置 = GETMETH(@"MAP_SEARCH_REPLACEMENT_{CFLAG:LOCAL:現在位置/100}", CFLAG:LOCAL:現在位置, CFLAG:LOCAL:現在位置)
	ENDIF
	;随后，修正当前位置的情况，将自宅内睡眠等的情况重新移回隙间空间，表示隐藏无法访问的意思
	SIF CFLAG:LOCAL:睡眠 && CFLAG:LOCAL:GMF_現在拠点位置 == CFLAG:LOCAL:初期位置
		CFLAG:LOCAL:現在位置 = SUKIMA()
NEXT
;一些特殊地点的转换，例如宴会场
TFLAG:宴会場 = GETMETH(@"MAP_SEARCH_REPLACEMENT_{FLAG:宴会会場/100}", FLAG:宴会会場, FLAG:宴会会場)

@GMF_LOCATION_ODEKAKE_TO_HOME
#LOCALSIZE 1
#LOCALSSIZE 1
;玩家位置直接变换
CFLAG:MASTER:現在位置 = GMF_GET_MAP_REPLACEMENT_INVERSE(CFLAG:MASTER:現在位置)
;角色位置变换
FOR LOCAL, 1, CHARANUM
	;出禁应该跳过变换
	SIF CFLAG:LOCAL:出禁
		CONTINUE
	;角色的职场需要转换，神社在住可能也先变换着吧，这可能得重新设定一遍才能解决，毕竟没有暂存
	CFLAG:LOCAL:職場 = CFLAG:LOCAL:GMF_職場拠点位置
	CFLAG:LOCAL:神社在住 = (GET_MAPID(CFLAG:LOCAL:初期位置) == GET_MAPID(CFLAG:MASTER:現在位置)) ? CFLAG:LOCAL:初期位置 # 0
	IF !CFLAG:LOCAL:GMF_現在拠点位置
		CALLF GMF_ERROR_INFO_PRINT(@"%CALLNAME:LOCAL%的据点位置为空！角色当前的现在位置为{CFLAG:LOCAL:現在位置}")
	ELSE
		CFLAG:LOCAL:現在位置 = CFLAG:LOCAL:GMF_現在拠点位置
	ENDIF
NEXT
;一些特殊地点的转换，例如宴会场
TFLAG:宴会場 = FLAG:宴会会場

;-----------------------------------------------------------
;移动指令和散步指令的变换
;-----------------------------------------------------------
@GMF_400_TO_604
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM MAP_ID
MAP_ID = GET_MAPID(CFLAG:MASTER:現在位置)
;设定地图模式，使GMF_IS_ODEKAKE一定返回1，从而在此时据点地点恒替换为外出地点
GMF_MAP_MODE = MAP_ID == GMF_HOME_MAP
CALL GMF_LOCATION_HOME_TO_ODEKAKE

@GMF_604_TO_400
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM MAP_ID
#DIM 経過時間
#DIM TSP消費倍率
MAP_ID = GET_MAPID(CFLAG:MASTER:現在位置)
;设定地图模式，使GMF_IS_ODEKAKE一定返回0
GMF_MAP_MODE = MAP_ID != GMF_HOME_MAP
経過時間 = GMF_GET_MAP_REPLACEMENT_INVERSE_TIME(CFLAG:MASTER:現在位置)
CALL GMF_LOCATION_ODEKAKE_TO_HOME
TFLAG:地圖切換 = MAP_AREASELECT(MAP_ID, CFLAG:MASTER:現在位置)
;时间消耗，借鉴SKIP_MOVE
TSP消費倍率 = 5
SIF TALENT:MASTER:100 < -4
	TSP消費倍率 += 15
SIF TFLAG:運搬
	TSP消費倍率 += 3
IF FLAG:70 == 1 || (GETBIT(FLAG:瞬間移動, 1) && !CFLAG:MASTER:同行 && BASE:MASTER:TSP > TSP消費倍率 * 経過時間)
	BASE:MASTER:TSP -= TSP消費倍率 * 経過時間
	SIF TFLAG:運搬
		CFLAG:(TFLAG:運搬):現在位置 = CFLAG:MASTER:現在位置
ELSE
	SIF TALENT:MASTER:100 < -4 && !CFLAG:MASTER:同行
		TIME += 7 * 経過時間
	TIME += 2 * 経過時間
	IF CFLAG:93:同行 && !GETBIT (FLAG:泳池, 0)
		TIME += 2 * 経過時間
		BASE:MASTER:体力 = MAX(BASE:MASTER:体力 - (5 * 経過時間), 500)
	ENDIF
ENDIF

;-----------------------------------------------------------
;GMF遭遇位置设定函数，主要用于据点地图下的遭遇设置
;-----------------------------------------------------------
@GMF_ENCOUNTER_LOCATION_DETERMINE(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
IF CFLAG:ARG:遭遇位置
	;#;PRINTFORM GMF_DEBUG:%CALLNAME:ARG%的遭遇位置为{CFLAG:ARG:遭遇位置}%STR_TR(6000 + (CFLAG:ARG:遭遇位置 / 10))%，
	IF CFLAG:ARG:遭遇位置 == CFLAG:ARG:自宅位置
		CFLAG:ARG:遭遇位置 = CFLAG:ARG:初期位置
	ELSE
		CFLAG:ARG:遭遇位置 = GMF_GET_MAP_REPLACEMENT_INVERSE(CFLAG:ARG:遭遇位置)
	ENDIF
	;#;PRINTFORML 现遭遇位置为{CFLAG:ARG:遭遇位置}%STR_TR(8000 + CFLAG:ARG:遭遇位置)%
ENDIF

;-----------------------------------------------------------
;GMF移动函数相关，即MOVEMENT.ERB内的函数改版或增补
;ARG一般为角色ID
;-----------------------------------------------------------
;強制移動
@GMF_FORCE_MOVE(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;时停期间不进行处理
IF !FLAG:70
	;重新判定需要回家休息的角色应该去的位置
	IF CFLAG:ARG:衰弱
		;处于非外出地图模式，且角色初期位置位于该地图时，应该返回该地图的初期位置
		SIF !GMF_IS_ODEKAKE(-1) && (GET_MAPID(CFLAG:ARG:初期位置) == GET_MAPID(CFLAG:MASTER:現在位置))
			CFLAG:ARG:現在位置 = CFLAG:ARG:初期位置
	ENDIF
ENDIF

;起床就寝処理
@GMF_SLEEP_AND_AWAKE(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;目前似乎起床就寝对现在位置的赋值都是据点地图上的，应该可以直接转过来没问题
CFLAG:ARG:GMF_現在拠点位置 = CFLAG:ARG:現在位置

;訪問帰宅処理
@GMF_VISIT_AND_KITAKU(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;这玩意最好拆成两个分别处理，用两个细则的函数内容，毕竟逻辑不一样

;主人公物件へ向かう
@GMF_VISITOR_COME(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;因为是来访，所以直接搬现在位置也可以，目前看来IFELSE都是覆盖了的，同行部分有后面同行处理解决
CFLAG:ARG:GMF_現在拠点位置 = CFLAG:ARG:現在位置

;KITAKU
@GMF_KITAKU(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;现在位置也需要根据玩家的地图模式确定
IF !TCVAR:ARG:休憩中 && !CFLAG:ARG:招待
	CFLAG:ARG:GMF_現在拠点位置 = CFLAG:ARG:初期位置
	;外出地图模式下，活动时间外在自宅，否则隙间隐藏表睡觉，据点地图模式下在初期位置就行
	CFLAG:ARG:現在位置 = (CFLAG:ARG:自宅位置 && !IN_HOME(CFLAG:ARG:自宅位置) && !睡眠時間(ARG)) ? CFLAG:ARG:自宅位置 # SUKIMA()
	SIF !GMF_IS_ODEKAKE(-1)
		CFLAG:ARG:現在位置 = CFLAG:ARG:初期位置
ENDIF

;休日移動処理
@GMF_ODEKAKE_CHARA_LOCATION_DETERMINE(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;没有遭遇位置时，默认设为自宅位置，这里自宅应该就是初期位置
;之前现在位置是设为了隙间空间
IF VISIT(ARG) && CFLAG:ARG:現在位置 != CFLAG:ARG:遭遇位置
	CFLAG:ARG:GMF_現在拠点位置 = CFLAG:ARG:遭遇位置 ? CFLAG:ARG:遭遇位置 # CFLAG:ARG:初期位置
	CFLAG:ARG:現在位置 = CFLAG:ARG:遭遇位置 ? CFLAG:ARG:遭遇位置 # CFLAG:ARG:初期位置
ENDIF

;待客室から出る
@GMF_RECEPTION_ROOM_OUT(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;初期位置恢复，遭遇位置恢复
IF GROUPMATCH(CFLAG:ARG:初期位置%100, 0, 99)
	CFLAG:ARG:初期位置 = CSVCFLAG(ARG, GETNUM(CFLAG, "初期位置"))
ENDIF
CFLAG:ARG:遭遇位置 = CFLAG:ARG:初期位置
;现在位置再判定
IF CFLAG:ARG:現在位置 == CFLAG:ARG:自宅位置 || CFLAG:ARG:現在位置 == SUKIMA()
	CFLAG:ARG:GMF_現在拠点位置 = CFLAG:ARG:初期位置
	SIF !GMF_IS_ODEKAKE(-1)
		CFLAG:ARG:現在位置 = CFLAG:ARG:初期位置
ELSE
	CFLAG:ARG:GMF_現在拠点位置 = CFLAG:ARG:現在位置
ENDIF
;玩家位置修正，因为是出待客室所以默认进行外出自宅位到据点的转化，不会直接使用初期位置
;唉还得做多人约会的兼容
IF !MOREDATE || (MOREDATE && CFLAG:MASTER:お招き == ARG)
	SIF !GMF_IS_ODEKAKE(-1)
		CFLAG:MASTER:現在位置 = GMF_GET_MAP_REPLACEMENT_INVERSE(CFLAG:MASTER:現在位置)
ENDIF

;同行処理
@GMF_JOINT_MOVE(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;根据玩家的外出地图模式决定
SIF CFLAG:ARG:同行 || CHK_DATENOW(CFLAG:ARG:约会中)
	CFLAG:ARG:GMF_現在拠点位置 = GMF_IS_ODEKAKE(-1) ? GMF_GET_MAP_REPLACEMENT_INVERSE(CFLAG:ARG:現在位置) # CFLAG:ARG:現在位置

;角色移動処理２
@GMF_CHARA_MOVE_MAINMAP(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;因为是据点地图移动，所以直接赋值即可，然后现在位置根据玩家的外出地图模式切换
CFLAG:ARG:GMF_現在拠点位置 = CFLAG:ARG:現在位置
SIF GMF_IS_ODEKAKE(-1)
	CFLAG:ARG:現在位置 = GET_MAP_REPLACEMENT(CFLAG:ARG:現在位置)

;移动后总位置修正，目前暂时没什么要加的（
@GMF_LOCATION_FIX(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
SIF CFLAG:ARG:現在位置 == 0
	CFLAG:ARG:現在位置 = SUKIMA()

;風呂から逐出
@GMF_BATH_KICKOUT(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;浴室逐出，似乎也是直接照搬即可
CFLAG:ARG:GMF_現在拠点位置 = CFLAG:ARG:現在位置

;COMF444 女の子を物色
@GMF_444_RANDOM_CHARA_SETTING
#LOCALSIZE 1
#LOCALSSIZE 1
;现在据点位置，要考虑玩家在外出的情况
CFLAG:RANDOM_CHARANUM:GMF_現在拠点位置 = GMF_IS_ODEKAKE(-1) ? GMF_GET_MAP_REPLACEMENT_INVERSE(CFLAG:RANDOM_CHARANUM:現在位置) # CFLAG:RANDOM_CHARANUM:現在位置

