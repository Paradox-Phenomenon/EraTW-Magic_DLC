	CLEARLINE LINECOUNT - LOCAL
CALL PRINTBUTTON_EX, @"[0] 大地图开关　状态：%\@ GMF_GETBIT("幻想乡大地图") ? 开启 # 关闭 \@%", 0, 0, GMF_GETBIT("幻想乡大地图")
