;-----------------------------------------------------------
;全地图房间设定
;-----------------------------------------------------------
@GMF_ALL_MAP_ROOMSETTING
#LOCALSIZE 3
#LOCALSSIZE 1
#DIM CHARA_ORIGINAL_HOME
GMF_HOME_MAP = MAIN_MAP
VARSET LOCAL
FOR LOCAL, 0, MAXHOME
	;为旅馆地图做准备
	;SIF LOCAL == MAXHOME - 1
	;	LOCAL = MAP自建旅馆
	MAIN_MAP = LOCAL
	TRYCCALLFORM ROOMSETTING_{MAIN_MAP}
		GMF_MAXROOM:LOCAL = MAXROOM
		GMF_ENTRANCE:LOCAL = ENTRANCE
		GMF_MAP_PAGES:LOCAL = MAP_PAGES
		FOR LOCAL:1, 0, 15
			GMF_MAPNAME:LOCAL:(LOCAL:1) '= MAPNAME:(LOCAL:1)
		NEXT
		FOR LOCAL:1, 0, 100
			GMF_ROOMDATA:LOCAL:(LOCAL:1) = ROOMDATA:(LOCAL:1)
		NEXT
	CATCH
		CALLF GMF_ERROR_INFO_PRINT(GET_MAPNAME(MAIN_MAP) + "的房间情报设定失败")
	ENDCATCH
	TRYCCALLFORM DEFAULT_OWNER_{MAIN_MAP}
		GMF_默认初期位置:LOCAL = 默认初期位置
		GMF_拠点_家主:LOCAL = 拠点_家主
	CATCH
		CALLF GMF_ERROR_INFO_PRINT(GET_MAPNAME(MAIN_MAP) + "的家主情报设定失败")
	ENDCATCH
NEXT
FOR LOCAL, 1, CHARANUM
	;重修初期位置的逻辑，将0和隙间空间99的初期位置改回原据点初期位置
	IF GROUPMATCH(CFLAG:LOCAL:初期位置%100, 0, 99)
		CFLAG:LOCAL:初期位置 = CSVCFLAG(LOCAL, GETNUM(CFLAG, "初期位置"))
	ENDIF
	;重修自宅位置的逻辑，将自宅位置统一为初期位置，因为有大量使用自宅位置的地方，现在来看其实可能已经不需要自宅位置这个设定了
	;先这么改着，出bug再说，多半是外出地图上的位置问题，到时候用初期位置的外出变换替代即可
	CFLAG:LOCAL:自宅位置 = CFLAG:LOCAL:初期位置
	IF !CFLAG:LOCAL:出禁
		;PRIVATEROOM变量，注意，最终编号大的角色会成为共用寝室的家主，如秋姐妹里的穰子，典龙中的龙
		CHARA_ORIGINAL_HOME = CFLAG:LOCAL:本来の初期位置 ? CFLAG:LOCAL:本来の初期位置 # CFLAG:LOCAL:初期位置
		GMF_PRIVATEROOM:(CHARA_ORIGINAL_HOME / 100):(CHARA_ORIGINAL_HOME % 100) = LOCAL
	ENDIF
NEXT
MAIN_MAP = GMF_HOME_MAP
TRYCALLFORM ROOMSETTING_{MAIN_MAP}
TRYCALLFORM DEFAULT_OWNER_{MAIN_MAP}
PRINTFORMW GMF_INFO：幻想乡全地图房间情报设定完毕

