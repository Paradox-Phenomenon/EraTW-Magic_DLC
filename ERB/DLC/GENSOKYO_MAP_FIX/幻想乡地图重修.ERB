;-----------------------------------------------------------
;GMF调用栈操作，用于GMF调用函数的标识符
;-----------------------------------------------------------
@GMF_METHOD_STACK_PUSH(ARGS)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
SIF GMF_METHOD_STACK:(GMF_METHOD_STACK_SIZE-1) != ""
	CALLF GMF_ERROR_INFO_PRINT("StackOverflowError：作者！你爆栈啦！", 1)
FOR LOCAL, (GMF_METHOD_STACK_SIZE-1), 0, -1
	GMF_METHOD_STACK:(LOCAL) '= GMF_METHOD_STACK:(LOCAL-1)
NEXT
GMF_METHOD_STACK '= ARGS
;GMF_METHOD_STACK_USE++
RETURNF -1

@GMF_METHOD_STACK_POP
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
FOR LOCAL, 0, (GMF_METHOD_STACK_SIZE-1)
	GMF_METHOD_STACK:(LOCAL) '= GMF_METHOD_STACK:(LOCAL+1)
NEXT
GMF_METHOD_STACK:(GMF_METHOD_STACK_SIZE-1) '= ""
;GMF_METHOD_STACK_USE--
RETURNF -1

;-----------------------------------------------------------
;GMF调用数据操作，用于GMF调用函数的数据备份、更改与恢复
;调用数据应该包含所有和家地图相关的信息，不仅包括MAIN_MAP系，还有神社在住、宴会场等等信息
;-----------------------------------------------------------
@GMF_METHOD_BACKUP(TEMP_MAIN_MAP)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM REF TEMP_MAIN_MAP
TEMP_MAIN_MAP = MAIN_MAP
RETURNF -1

@GMF_METHOD_UPDATE(LOCATION_ID)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC LOCATION_ID
#DIM DYNAMIC MAP_ID
;根据是否为外出模式决定地图，外出模式下需要保证与当前地图绝不相同，+1%20应该就可以了
MAP_ID = GMF_IS_ODEKAKE(GET_MAPID(LOCATION_ID)) ? (GET_MAPID(LOCATION_ID)+1)%20 # GET_MAPID(LOCATION_ID)
MAIN_MAP = MAP_ID
MAXROOM = GMF_MAXROOM:MAP_ID
ENTRANCE = GMF_ENTRANCE:MAP_ID
MAP_PAGES = GMF_MAP_PAGES:MAP_ID
FOR LOCAL, 0, 15
	MAPNAME:LOCAL '= GMF_MAPNAME:MAP_ID:LOCAL
NEXT
FOR LOCAL, 0, 100
	ROOMDATA:LOCAL = GMF_ROOMDATA:MAP_ID:LOCAL
	PRIVATEROOM:LOCAL = GMF_PRIVATEROOM:MAP_ID:LOCAL
NEXT
FOR LOCAL, 0, CHARANUM
	CFLAG:LOCAL:神社在住 = (GET_MAPID(CFLAG:LOCAL:初期位置) == MAP_ID) ? CFLAG:LOCAL:初期位置 # 0
NEXT
TFLAG:宴会場 = (GET_MAPID(FLAG:宴会会場) == MAP_ID) ? FLAG:宴会会場 # GETMETH(@"MAP_SEARCH_REPLACEMENT_{GET_MAPID(FLAG:宴会会場)}", 0, FLAG:宴会会場)
RETURNF -1

@GMF_METHOD_RESTORE(TEMP_MAIN_MAP)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM REF TEMP_MAIN_MAP
MAIN_MAP = TEMP_MAIN_MAP
MAXROOM = GMF_MAXROOM:TEMP_MAIN_MAP
ENTRANCE = GMF_ENTRANCE:TEMP_MAIN_MAP
MAP_PAGES = GMF_MAP_PAGES:TEMP_MAIN_MAP
FOR LOCAL, 0, 15
	MAPNAME:LOCAL '= GMF_MAPNAME:TEMP_MAIN_MAP:LOCAL
NEXT
FOR LOCAL, 0, 100
	ROOMDATA:LOCAL = GMF_ROOMDATA:TEMP_MAIN_MAP:LOCAL
	PRIVATEROOM:LOCAL = GMF_PRIVATEROOM:TEMP_MAIN_MAP:LOCAL
NEXT
FOR LOCAL, 0, CHARANUM
	CFLAG:LOCAL:神社在住 = (GET_MAPID(CFLAG:LOCAL:初期位置) == TEMP_MAIN_MAP && CFLAG:LOCAL:初期位置%100 != 0 && CFLAG:LOCAL:初期位置%100 != 99) ? CFLAG:LOCAL:初期位置 # 0
NEXT
TFLAG:宴会場 = (GET_MAPID(FLAG:宴会会場) == TEMP_MAIN_MAP) ? FLAG:宴会会場 # GETMETH(@"MAP_SEARCH_REPLACEMENT_{GET_MAPID(FLAG:宴会会場)}", 0, FLAG:宴会会場)
RETURNF -1

;-----------------------------------------------------------
;GMF调用函数，用于调用被MAIN_MAP，MINROOM，MAXROOM，ROOMDATA等家地图参数强绑定的函数，并获取在其他地图的对应返回值
;一般来说，要在非家地图上实现家地图功能时，涉及以上变量的函数都应通过该函数的形式调用
;但MINROOM()本身例外，因为该函数没有MAPID参数，且一般和MAXROOM成对出现，此时上级函数已经需要经过该函数形式调用，因此不需要重复修改MAIN_MAP了
;MAP_ID		目标地图，用于将家地图切换至此地图
;ARG_NUM	参数个数，用于匹配不同参数个数的@GETMETH
;FUNC_NAME	函数名，这里主要是避免多次调用出栈时错误显示
;剩下参数与@GETMETH功能一致
;-----------------------------------------------------------
@GMF_MAP_METHOD(LOCATION_ID = -1, ARG_NUM, FUNC_NAME, ARG:0 = -1, ARG:1 = -1, ARG:2 = -1, ARG:3 = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC LOCATION_ID
#DIM DYNAMIC ARG_NUM
#DIMS DYNAMIC FUNC_NAME
#DIM DYNAMIC TEMP_MAIN_MAP

SIF LOCATION_ID == -1
	LOCATION_ID = CFLAG:MASTER:現在位置
;函数名入栈
CALLF GMF_METHOD_STACK_PUSH(FUNC_NAME)
;备份家地图信息
CALLF GMF_METHOD_BACKUP(TEMP_MAIN_MAP)
;临时修改家地图
CALLF GMF_METHOD_UPDATE(LOCATION_ID)
;PRINTFORML GMF_MAP_METHOD调用，GMF_METHOD_STACK入栈函数为%FUNC_NAME%，当前主地图设置为{MAIN_MAP}，栈使用量{GMF_METHOD_STACK_USE}
;获取函数返回值
SELECTCASE ARG_NUM
	CASE 0
		TRYCALLFORM %FUNC_NAME%()
	CASE 1
		TRYCALLFORM %FUNC_NAME%(ARG:0)
	CASE 2
		TRYCALLFORM %FUNC_NAME%(ARG:0, ARG:1)
	CASE 3
		TRYCALLFORM %FUNC_NAME%(ARG:0, ARG:1, ARG:2)
	CASE 4
		TRYCALLFORM %FUNC_NAME%(ARG:0, ARG:1, ARG:2, ARG:3)
	CASEELSE
		CALLF GMF_ERROR_INFO_PRINT("未设置正确的参数数量", 1)
ENDSELECT
;恢复家地图信息
CALLF GMF_METHOD_RESTORE(TEMP_MAIN_MAP)
;函数名出栈，函数返回
CALLF GMF_METHOD_STACK_POP
;PRINTFORML GMF_MAP_METHOD调用，GMF_METHOD_STACK出栈函数为%FUNC_NAME%，当前主地图还原为{MAIN_MAP}，栈使用量{GMF_METHOD_STACK_USE}

@GMF_MAP_METHODF(LOCATION_ID = -1, ARG_NUM, FUNC_NAME, DEFAULT_VALUE = -1, ARG:0 = -1, ARG:1 = -1, ARG:2 = -1, ARG:3 = -1)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC LOCATION_ID
#DIM DYNAMIC ARG_NUM
#DIMS DYNAMIC FUNC_NAME
#DIM DYNAMIC DEFAULT_VALUE
#DIM DYNAMIC RETURN_VALUE
#DIM DYNAMIC TEMP_MAIN_MAP

SIF LOCATION_ID == -1
	LOCATION_ID = CFLAG:MASTER:現在位置
;函数名入栈
CALLF GMF_METHOD_STACK_PUSH(FUNC_NAME)
;备份家地图信息
CALLF GMF_METHOD_BACKUP(TEMP_MAIN_MAP)
;临时修改家地图
CALLF GMF_METHOD_UPDATE(LOCATION_ID)
;PRINTFORML GMF_MAP_METHODF调用，GMF_METHOD_STACK入栈函数为%FUNC_NAME%，当前主地图设置为{MAIN_MAP}，栈使用量{GMF_METHOD_STACK_USE}
SELECTCASE ARG_NUM
	CASE 0
		RETURN_VALUE = GETMETH(FUNC_NAME, DEFAULT_VALUE)
	CASE 1
		RETURN_VALUE = GETMETH(FUNC_NAME, DEFAULT_VALUE, ARG:0)
	CASE 2
		RETURN_VALUE = GETMETH(FUNC_NAME, DEFAULT_VALUE, ARG:0, ARG:1)
	CASE 3
		RETURN_VALUE = GETMETH(FUNC_NAME, DEFAULT_VALUE, ARG:0, ARG:1, ARG:2)
	CASE 4
		RETURN_VALUE = GETMETH(FUNC_NAME, DEFAULT_VALUE, ARG:0, ARG:1, ARG:2, ARG:3)
	CASEELSE
		CALLF GMF_ERROR_INFO_PRINT("未设置正确的参数数量", 1)
ENDSELECT
;恢复家地图信息
CALLF GMF_METHOD_RESTORE(TEMP_MAIN_MAP)
;函数名出栈，函数返回
CALLF GMF_METHOD_STACK_POP
;PRINTFORML GMF_MAP_METHODF调用，GMF_METHOD_STACK出栈函数为%FUNC_NAME%，当前主地图还原为{MAIN_MAP}，栈使用量{GMF_METHOD_STACK_USE}
RETURNF RETURN_VALUE

@GMF_MAP_METHODFS(LOCATION_ID = -1, ARG_NUM, FUNC_NAME, DEFAULT_VALUES = "", ARG:0 = -1, ARG:1 = -1, ARG:2 = -1, ARG:3 = -1)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC LOCATION_ID
#DIM DYNAMIC ARG_NUM
#DIMS DYNAMIC FUNC_NAME
#DIMS DYNAMIC DEFAULT_VALUES
#DIMS DYNAMIC RETURN_VALUES
#DIM DYNAMIC TEMP_MAIN_MAP

SIF LOCATION_ID == -1
	LOCATION_ID = CFLAG:MASTER:現在位置
;函数名入栈
CALLF GMF_METHOD_STACK_PUSH(FUNC_NAME)
;备份家地图信息
CALLF GMF_METHOD_BACKUP(TEMP_MAIN_MAP)
;临时修改家地图
CALLF GMF_METHOD_UPDATE(LOCATION_ID)
;PRINTFORML GMF_MAP_METHODFS调用，GMF_METHOD_STACK入栈函数为%FUNC_NAME%，当前主地图设置为{MAIN_MAP}，栈使用量{GMF_METHOD_STACK_USE}
SELECTCASE ARG_NUM
	CASE 0
		RETURN_VALUES '= GETMETHS(FUNC_NAME, DEFAULT_VALUES)
	CASE 1
		RETURN_VALUES '= GETMETHS(FUNC_NAME, DEFAULT_VALUES, ARG:0)
	CASE 2
		RETURN_VALUES '= GETMETHS(FUNC_NAME, DEFAULT_VALUES, ARG:0, ARG:1)
	CASE 3
		RETURN_VALUES '= GETMETHS(FUNC_NAME, DEFAULT_VALUES, ARG:0, ARG:1, ARG:2)
	CASE 4
		RETURN_VALUES '= GETMETHS(FUNC_NAME, DEFAULT_VALUES, ARG:0, ARG:1, ARG:2, ARG:3)
	CASEELSE
		CALLF GMF_ERROR_INFO_PRINT("未设置正确的参数数量", 1)
ENDSELECT
;恢复家地图信息
CALLF GMF_METHOD_RESTORE(TEMP_MAIN_MAP)
;函数名出栈，函数返回
CALLF GMF_METHOD_STACK_POP
;PRINTFORML GMF_MAP_METHODFS调用，GMF_METHOD_STACK出栈函数为%FUNC_NAME%，当前主地图还原为{MAIN_MAP}，栈使用量{GMF_METHOD_STACK_USE}
RETURNF RETURN_VALUES

