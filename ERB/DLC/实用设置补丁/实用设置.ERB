
;-----------------------------------------------------------
;函数作用:关闭实用设置开关
;-----------------------------------------------------------
@Shutdown_Setting
Setting_五重绝顶 = 0
Setting_满足终了 = 0
Setting_主动权转移禁止 = 0
Setting_外出时可以带出去 = 0
Setting_单独一人吃饭 = 0
Setting_逆推口上找补 = 0
Setting_即时重载 = 0


;-----------------------------------------------------------
;函数作用:新增的额外设置功能
;-----------------------------------------------------------
@Show_Setting
CALL RELINE(1,1)
$LOOP
CALL RELINE(1)
PRINTL


SELECTCASE Setting_五重绝顶
	CASE 0
		LOCALS =  五重绝顶:原版
	CASE 1
		LOCALS =  五重绝顶:总是可用
	CASE 2
		LOCALS =  五重绝顶:逆推时可用
ENDSELECT
IF Five_Orgasm_Magic
	CALL PRINTBUTTON_EX(@"[%LOCALS%]", 1, !Setting_五重绝顶)
	PRINTL
ELSE
	Setting_五重绝顶 = 0
ENDIF


SELECTCASE Setting_满足终了
	CASE 0
		LOCALS =  逆推满足终了:原版
	CASE 1
		LOCALS =  逆推满足终了:禁止
	CASE 2
		LOCALS =  逆推满足终了:总是
ENDSELECT
CALL PRINTBUTTON_EX(@"[%LOCALS%]", 2, !Setting_满足终了)
PRINTL


SELECTCASE Setting_主动权转移禁止
	CASE 0
		LOCALS =  诶嘿嘿主动权转移:允许
	CASE 1
		LOCALS =  诶嘿嘿主动权转移:禁止
ENDSELECT
CALL PRINTBUTTON_EX(@"[%LOCALS%]", 3, Setting_主动权转移禁止)
PRINTL


IF GMF_GETBIT("幻想乡大地图")
	SELECTCASE Setting_外出时可以带出去
		CASE 0
			LOCALS =  外出时可以带出去:禁止（需要开启幻想乡大地图）
		CASE 1
			LOCALS =  外出时可以带出去:允许（需要开启幻想乡大地图）
	ENDSELECT
	CALL PRINTBUTTON_EX(@"[%LOCALS%]", 4, !Setting_外出时可以带出去)
	PRINTL
ELSE
	Setting_外出时可以带出去 = 0
ENDIF


SELECTCASE Setting_单独一人吃饭
	CASE 0
		LOCALS =  单独一人吃饭:禁用
	CASE 1
		LOCALS =  单独一人吃饭:启用
ENDSELECT
CALL PRINTBUTTON_EX(@"[%LOCALS%]", 5, !Setting_单独一人吃饭)
PRINTL


IF Real_Time_Save
	SELECTCASE Setting_即时重载
		CASE 0
			LOCALS =  即时重载:禁用
		CASE 1
			LOCALS =  即时重载:允许
	ENDSELECT
	CALL PRINTBUTTON_EX(@"[%LOCALS%]", 6, !Setting_即时重载)
	PRINTL
ELSE
	Setting_即时重载 = 0
ENDIF

IF GMF_GETBIT("幻想乡大地图")
	CALL PRINTBUTTON_EX(@"[重载地图房间设定]", 7)
	PRINTL
ENDIF

SELECTCASE Setting_逆推口上找补
	CASE 0
		LOCALS =  逆推口上找补:禁用
	CASE 1
		LOCALS =  逆推口上找补:启用
ENDSELECT
CALL PRINTBUTTON_EX(@"[%LOCALS%]", 8, !Setting_逆推口上找补)
PRINTL

IF HOUGONG
	SELECTCASE Setting_跟随型后宫
		CASE 0
			LOCALS =  跟随型后宫:禁用
		CASE 1
			LOCALS =  跟随型后宫:启用
	ENDSELECT
	CALL PRINTBUTTON_EX(@"[%LOCALS%]", 9, !Setting_跟随型后宫)
	IF Setting_跟随型后宫
		PRINT ==
		CALL PRINTBUTTON_EX("[清除所有人的后宫标记]", 10)
	ENDIF
	PRINTL
ELSE
	Setting_跟随型后宫 = 0
ENDIF
SELECTCASE Setting_背景图片
	CASE 0
		LOCALS =  背景图片:禁用
	CASE 1
		LOCALS =  背景图片:启用
ENDSELECT
CALL PRINTBUTTON_EX(@"[%LOCALS%]", 11, !Setting_背景图片)
PRINTL

CALL PRINTBUTTON_EX(@"[即时设置(实验性)]", 998)
PRINTL
CALL PRINTBUTTON_EX(@"[确认]", 999)
PRINTFORML
INPUT


IF RESULT == 1
	IF Setting_五重绝顶 < 2
		Setting_五重绝顶 ++
	ELSE
		Setting_五重绝顶 = 0
	ENDIF
ELSEIF RESULT == 2
	IF Setting_满足终了 < 2
		Setting_满足终了 ++
	ELSE
		Setting_满足终了 = 0
	ENDIF
ELSEIF RESULT == 3
	Setting_主动权转移禁止 = !Setting_主动权转移禁止
ELSEIF RESULT == 4 && GMF_GETBIT("幻想乡大地图")
	Setting_外出时可以带出去 = !Setting_外出时可以带出去
ELSEIF RESULT == 5
	Setting_单独一人吃饭 = !Setting_单独一人吃饭
ELSEIF RESULT == 6 && Real_Time_Save
	Setting_即时重载 = !Setting_即时重载
ELSEIF RESULT == 7
	CALL GMF_ALL_MAP_ROOMSETTING
ELSEIF RESULT == 8
	Setting_逆推口上找补 = !Setting_逆推口上找补
ELSEIF RESULT == 9 && HOUGONG
	Setting_跟随型后宫 = !Setting_跟随型后宫
ELSEIF RESULT == 10 && Setting_跟随型后宫
	PRINTFORMW 确认清除所有人的后宫标记吗？
	CALL ASK_YN, "那当然", "再想想"
	IF !RESULT
		CVARSET Setting_CFLAG, 1, 0
	ENDIF
ELSEIF RESULT == 11
	Setting_背景图片 = !Setting_背景图片
	SIF !Setting_背景图片 
		CBGCLEAR
ELSEIF RESULT == -100
	CALL 运行时函数调用
	PRINTFORMW {RESULT}
ELSEIF RESULT == -101
	;PRINT_IMG "博丽神社",1000,1000
	;PRINTFORMW %"\n"*10%
	CALL 背景展示
ELSEIF RESULT == 998
	PRINTFORMW 警告，实验性功能，不建议用此功能进行某些dlc开关的设置，尤其是幻想乡大地图。
	CALL OPTION
ELSEIF RESULT == 999
	RETURN 
ENDIF
GOTO LOOP

@逆推指令转化(ARG)
#FUNCTION
IF CFLAG:MASTER:诶嘿嘿 == 1
	SELECTCASE ARG
		CASE T3手指插入
			RETURNF T316手指插入
		CASE T5肛门爱抚
			RETURNF T314肛门爱抚
		CASE T6胸爱抚
			RETURNF T313胸爱抚
		CASE T15阴蒂爱抚
			RETURNF T315阴蒂爱抚
		CASE T20接吻
			RETURNF T312接吻
		CASE T60正常位
			RETURNF T320对方主导正常位
		CASE T61后背位
			RETURNF T322对方主导后背位
		CASE T63后背位肛交
			RETURNF T323对方主导后背位Ａ
	ENDSELECT
ELSEIF CFLAG:MASTER:诶嘿嘿 == 2
	SELECTCASE ARG
		CASE 316
			RETURNF T3手指插入
		CASE T314肛门爱抚
			RETURNF T5肛门爱抚
		CASE T313胸爱抚
			RETURNF T6胸爱抚
		CASE T315阴蒂爱抚
			RETURNF T15阴蒂爱抚
		CASE T312接吻
			RETURNF T20接吻
		CASE T320对方主导正常位
			RETURNF T60正常位
		CASE T322对方主导后背位
			RETURNF T61后背位
		CASE T323对方主导后背位Ａ
			RETURNF T63后背位肛交
	ENDSELECT
ENDIF
RETURNF 0

@SET_逆推口上找补(KOJO_NAME, COM_ID, COM_TYPE)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC KOJO_NAME
#DIM DYNAMIC COM_ID
#DIMS DYNAMIC COM_TYPE
#DIM DYNAMIC LINE_RECORD
#DIM DYNAMIC REPEAT_TIMES
#DIM DYNAMIC 子宫开发
LINE_RECORD = LINECOUNT
TRYCALLFORM M_KOJO%KOJO_NAME%_MESSAGE_%COM_TYPE%_K{NO:TARGET}_{COM_ID}
IF 检测最新输出内容(LINECOUNT-LINE_RECORD) && COM_ID == 317 && COM_TYPE == "COM"
	REPEAT_TIMES = 0
	$LOOP_317
	子宫开发 = 0
	REPEAT_TIMES ++
	LINE_RECORD = LINECOUNT
	SELECTCASE RAND:4
		CASE 1
			TRYCALLFORM M_KOJO%KOJO_NAME%_MESSAGE_SCOM_K{NO:TARGET}_6
		CASE 2
			TRYCALLFORM M_KOJO%KOJO_NAME%_MESSAGE_SCOM_K{NO:TARGET}_7
			子宫开发 = 1
		CASE 3
			TRYCALLFORM M_KOJO%KOJO_NAME%_MESSAGE_COM_K{NO:TARGET}_360
		CASEELSE
			TRYCALLFORM M_KOJO%KOJO_NAME%_MESSAGE_COM_K{NO:TARGET}_{POSE_TO_COMNO:(TEQUIP:TARGET:体位)}
	ENDSELECT
	IF 检测最新输出内容(LINECOUNT-LINE_RECORD) && REPEAT_TIMES < 20
		GOTO LOOP_317
	ELSEIF REPEAT_TIMES >= 20
		RESULT = 0
		TRYCALLFORM M_KOJO%KOJO_NAME%_MESSAGE_COM_K{NO:TARGET}_00
	ELSE
		RESULT = 1
	ENDIF
	SIF 子宫开发
		EXP:TARGET:子宮口開発経験 ++
ELSEIF 检测最新输出内容(LINECOUNT-LINE_RECORD) && COM_ID == 318 && COM_TYPE == "COM"
	REPEAT_TIMES = 0
	$LOOP_318
	REPEAT_TIMES ++
	LINE_RECORD = LINECOUNT
	SELECTCASE RAND:4
		CASE 1
			TRYCALLFORM M_KOJO%KOJO_NAME%_MESSAGE_SCOM_K{NO:TARGET}_14
		CASE 2
			TRYCALLFORM M_KOJO%KOJO_NAME%_MESSAGE_SCOM_K{NO:TARGET}_15
		CASE 3
			TRYCALLFORM M_KOJO%KOJO_NAME%_MESSAGE_COM_K{NO:TARGET}_360
		CASEELSE
			TRYCALLFORM M_KOJO%KOJO_NAME%_MESSAGE_COM_K{NO:TARGET}_{POSE_A_TO_COMNO:(TEQUIP:TARGET:体位)}
	ENDSELECT
	IF 检测最新输出内容(LINECOUNT-LINE_RECORD) && REPEAT_TIMES < 20
		GOTO LOOP_318
	ELSEIF REPEAT_TIMES >= 20
		RESULT = 0
		TRYCALLFORM M_KOJO%KOJO_NAME%_MESSAGE_COM_K{NO:TARGET}_00
	ELSE
		RESULT = 1
	ENDIF
ELSEIF 检测最新输出内容(LINECOUNT-LINE_RECORD) && 逆推指令转化(COM_ID) != 0 && COM_TYPE == "COM"
	REPEAT_TIMES = 0
	$LOOP_360
	REPEAT_TIMES ++
	LINE_RECORD = LINECOUNT
	SELECTCASE RAND:2
		CASE 1
			TRYCALLFORM M_KOJO%KOJO_NAME%_MESSAGE_COM_K{NO:TARGET}_360
		CASEELSE
			TRYCALLFORM M_KOJO%KOJO_NAME%_MESSAGE_COM_K{NO:TARGET}_{逆推指令转化(COM_ID)}
	ENDSELECT
	IF 检测最新输出内容(LINECOUNT-LINE_RECORD) && REPEAT_TIMES < 20
		GOTO LOOP_360
	ELSEIF REPEAT_TIMES >= 20
		RESULT = 0
		TRYCALLFORM M_KOJO%KOJO_NAME%_MESSAGE_COM_K{NO:TARGET}_00
	ELSE
		RESULT = 1
	ENDIF
ENDIF
RETURN RESULT

@背景展示
#DIMS 地点名
#DIM 季节编号
#DIM 时间编号
#DIMS 背景名
#DIM 无季节差分
#DIM 无时间差分
背景名 =
地点名 = 
无季节差分 = 0
无时间差分 = 0
IF IS_GAP_GUEST(MASTER)
ELSE
	IF GMF_AT_LARGE_MAP(MASTER)
		IF 位置归类(CFLAG:MASTER:現在位置) == 神社境内
			地点名 '= "神社境内"
		ELSEIF 位置归类(CFLAG:MASTER:現在位置) == 神社本堂
			地点名 '= "神社本殿"
		ELSEIF 位置归类(CFLAG:MASTER:現在位置) == 桜花道的鳥居
			地点名 '= "参道"
		ELSEIF CFLAG:MASTER:現在位置 == P36夢幻遺跡前
			地点名 '= "梦幻遗迹前"
		ELSEIF 位置归类(CFLAG:MASTER:現在位置) == 神社走廊
			地点名 '= "神社走廊"
		ELSEIF 位置归类(CFLAG:MASTER:現在位置) == 夢幻遺跡
			地点名 '= "梦幻遗迹内部"
			无时间差分 ++
			无季节差分 ++
		ELSEIF GROUPMATCH(位置归类(CFLAG:MASTER:現在位置), 斜角的竹林, 兎的洞穴, 迷失的小道, 竹林入口)
			地点名 '= "竹林"
		ELSEIF GROUPMATCH(位置归类(CFLAG:MASTER:現在位置), 永遠亭, 永遠亭的内院)
			地点名 '= "永远亭"
		ELSEIF 位置归类(CFLAG:MASTER:現在位置) == 正門
			地点名 '= "红魔馆正门"
		ELSE
		ENDIF
	ELSE
		IF CFLAG:MASTER:現在位置 == 神社境内
			地点名 '= "神社境内"
		ELSEIF CFLAG:MASTER:現在位置 == 神社本堂
			地点名 '= "神社本殿"
		ELSEIF CFLAG:MASTER:現在位置 == 桜花道的鳥居
			地点名 '= "参道"
		ELSEIF CFLAG:MASTER:現在位置 == 夢幻遺跡
			地点名 '= "梦幻遗迹前"
		ELSEIF CFLAG:MASTER:現在位置 == 神社走廊
			地点名 '= "神社走廊"
		ELSEIF GROUPMATCH(CFLAG:MASTER:現在位置, 斜角的竹林, 兎的洞穴, 迷失的小道, 竹林入口)
			地点名 '= "竹林"
		ELSEIF GROUPMATCH(CFLAG:MASTER:現在位置, 永遠亭, 永遠亭的内院)
			地点名 '= "永远亭"
		ELSEIF CFLAG:MASTER:現在位置 == 正門
			地点名 '= "红魔馆正门"
		ELSE
		ENDIF
	ENDIF
ENDIF
IF !无季节差分
	季节编号 = DAY:季節
ELSE
	季节编号 = 0
ENDIF
IF !无时间差分
	时间编号 = TIME >= 360 && TIME < 1080 ? 0 # 1
ELSE
	时间编号 = 0
ENDIF
背景名 += @"%地点名%_{季节编号}_{时间编号}"
;PRINTFORMW 背景名 = %背景名% 地点名 = %地点名%
IF 地点名 != ""
	CALL 背景图片打印(背景名)
ELSE
	CALL 背景图片打印()
ENDIF