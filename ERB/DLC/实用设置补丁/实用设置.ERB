
;-----------------------------------------------------------
;函数作用:关闭实用设置开关
;-----------------------------------------------------------
@Shutdown_Setting
Setting_五重绝顶 = 0
Setting_满足终了 = 0
Setting_主动权转移禁止 = 0
Setting_外出时可以带出去 = 0
Setting_单独一人吃饭 = 0
Setting_即时重载 = 0


;-----------------------------------------------------------
;函数作用:新增的额外设置功能
;-----------------------------------------------------------
@Show_Setting
CALL RELINE(1,1)
$LOOP
CALL RELINE(1)
PRINTL


SELECTCASE Setting_五重绝顶
	CASE 0
		LOCALS =  五重绝顶:原版
	CASE 1
		LOCALS =  五重绝顶:总是可用
	CASE 2
		LOCALS =  五重绝顶:逆推时可用
ENDSELECT
IF Five_Orgasm_Magic
	CALL PRINTBUTTON_EX(@"[%LOCALS%]", 1, !Setting_五重绝顶)
	PRINTL
ELSE
	Setting_五重绝顶 = 0
ENDIF


SELECTCASE Setting_满足终了
	CASE 0
		LOCALS =  逆推满足终了:原版
	CASE 1
		LOCALS =  逆推满足终了:禁止
	CASE 2
		LOCALS =  逆推满足终了:总是
ENDSELECT
CALL PRINTBUTTON_EX(@"[%LOCALS%]", 2, !Setting_满足终了)
PRINTL


SELECTCASE Setting_主动权转移禁止
	CASE 0
		LOCALS =  诶嘿嘿主动权转移:允许
	CASE 1
		LOCALS =  诶嘿嘿主动权转移:禁止
ENDSELECT
CALL PRINTBUTTON_EX(@"[%LOCALS%]", 3, Setting_主动权转移禁止)
PRINTL


IF GMF_GETBIT("幻想乡大地图")
	SELECTCASE Setting_外出时可以带出去
		CASE 0
			LOCALS =  外出时可以带出去:禁止（需要开启幻想乡大地图）
		CASE 1
			LOCALS =  外出时可以带出去:允许（需要开启幻想乡大地图）
	ENDSELECT
	CALL PRINTBUTTON_EX(@"[%LOCALS%]", 4, !Setting_外出时可以带出去)
	PRINTL
ELSE
	Setting_外出时可以带出去 = 0
ENDIF


SELECTCASE Setting_单独一人吃饭
	CASE 0
		LOCALS =  单独一人吃饭:禁用
	CASE 1
		LOCALS =  单独一人吃饭:启用
ENDSELECT
CALL PRINTBUTTON_EX(@"[%LOCALS%]", 5, !Setting_单独一人吃饭)
PRINTL


IF Real_Time_Save
	SELECTCASE Setting_即时重载
		CASE 0
			LOCALS =  即时重载:禁用
		CASE 1
			LOCALS =  即时重载:允许
	ENDSELECT
	CALL PRINTBUTTON_EX(@"[%LOCALS%]", 6, !Setting_即时重载)
	PRINTL
ELSE
	Setting_即时重载 = 0
ENDIF
CALL PRINTBUTTON_EX(@"[即时设置(实验性)]", 998)
PRINTL
CALL PRINTBUTTON_EX(@"[确认]", 999)
PRINTFORML
INPUT


IF RESULT == 1
	IF Setting_五重绝顶 < 2
		Setting_五重绝顶 ++
	ELSE
		Setting_五重绝顶 = 0
	ENDIF
ELSEIF RESULT == 2
	IF Setting_满足终了 < 2
		Setting_满足终了 ++
	ELSE
		Setting_满足终了 = 0
	ENDIF
ELSEIF RESULT == 3
	Setting_主动权转移禁止 = !Setting_主动权转移禁止
ELSEIF RESULT == 4 && GMF_GETBIT("幻想乡大地图")
	Setting_外出时可以带出去 = !Setting_外出时可以带出去
ELSEIF RESULT == 5
	Setting_单独一人吃饭 = !Setting_单独一人吃饭
ELSEIF RESULT == 6 && Real_Time_Save
	Setting_即时重载 = !Setting_即时重载
ELSEIF RESULT == 998
	PRINTFORMW 警告，实验性功能，不建议用此功能进行某些dlc开关的设置，尤其是幻想乡大地图。
	CALL OPTION
ELSEIF RESULT == 999
	RETURN 
ENDIF
GOTO LOOP