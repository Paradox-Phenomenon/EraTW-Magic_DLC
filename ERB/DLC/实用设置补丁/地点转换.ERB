
@位置归类(ARG)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM 対象Map
#DIM OUTID
対象Map = GET_MAPID(ARG)
SELECTCASE 対象Map
	CASE 0
		OUTID = MAP_SEARCH_REPLACEMENT_0_ALTER(ARG)
	CASE 1
		OUTID = MAP_SEARCH_REPLACEMENT_1(ARG)
	CASE 2
		OUTID = MAP_SEARCH_REPLACEMENT_2(ARG)
	CASE 3
		OUTID = MAP_SEARCH_REPLACEMENT_3(ARG)
	CASE 4
		OUTID = MAP_SEARCH_REPLACEMENT_4(ARG)
	CASE 5
		OUTID = MAP_SEARCH_REPLACEMENT_5(ARG)
	CASE 6
		OUTID = MAP_SEARCH_REPLACEMENT_6(ARG)
	CASE 7
		OUTID = MAP_SEARCH_REPLACEMENT_7(ARG)
	CASE 8
		OUTID = MAP_SEARCH_REPLACEMENT_8(ARG)
	CASE 9
		OUTID = MAP_SEARCH_REPLACEMENT_9(ARG)
	CASE 10
		OUTID = MAP_SEARCH_REPLACEMENT_10(ARG)
	CASE 11
		OUTID = MAP_SEARCH_REPLACEMENT_11(ARG)
	CASEELSE
		OUTID = ARG
ENDSELECT
RETURNF OUTID

@MAP_SEARCH_REPLACEMENT_0_ALTER(ARG)
#FUNCTION
SELECTCASE ARG
	CASE P1鳥居, P22参道, P23温泉・脱衣所, P24温泉
		RETURNF 桜花道的鳥居
	CASE P2境内, P5手水舎, P6庫房, P21守矢神社分社, P56阿吽の棲家, P16破舊小屋, P3賽銭箱
		RETURNF 神社境内
	;賽銭箱,本堂
	CASE P4本堂, P7土間 ,P8廚房, P9居間 ,P12脱衣所, P13風呂, P14廁所, P15霊夢私室, P18壁櫥間, P55和室
		RETURNF 神社本堂
	;三妖精之家
	CASE P27三妖精之家・大廳 TO P35三妖精之家・地下室, P25鎮守之森
		RETURNF 妖精的大樹
	;夢幻遺跡
	CASE P36夢幻遺跡前 TO P51夢幻遺跡・倉庫
		RETURNF 夢幻遺跡
	;大别墅
	CASE P57大温泉 TO P68大广场
		RETURNF 大别墅
	CASEELSE
		RETURNF 神社走廊
ENDSELECT
RETURNF 0