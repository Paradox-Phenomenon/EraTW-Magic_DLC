@BGM_PLAY
#DIMS BGM
SIF NO_BGM
    RETURN
STOPSOUND
SETSOUNDVOLUME BGMVOLUME*10
IF 现在BGM参数2 == 99
    BGM = 游戏bgm/隙间待客室
ELSE
    SELECTCASE 现在BGM参数1
        CASE 0
            IF 现在BGM参数2 == 0
                BGM = 游戏bgm/博丽神社
            ELSEIF 现在BGM参数2 == 1
                BGM = 游戏bgm/参道
            ENDIF
        CASE 1
            IF 现在BGM参数2 == 0
                BGM = 游戏bgm/命莲寺
            ELSEIF 现在BGM参数2 == 1
                BGM = 游戏bgm/神灵庙
            ENDIF
        CASE 2
            BGM = 游戏bgm/人间之里
        CASE 3
            BGM = 游戏bgm/红魔馆
        CASE 4
            IF 现在BGM参数2 == 0
                BGM = 游戏bgm/迷途竹林
            ELSEIF 现在BGM参数2 == 1
                BGM = 游戏bgm/太阳花田
            ENDIF
        CASE 5
            BGM = 游戏bgm/魔法森林
        CASE 6
            BGM = 游戏bgm/三途川_冥界
        CASE 7
            BGM = 游戏bgm/妖怪之山山麓
        CASE 8
            BGM = 游戏bgm/妖怪之山山顶
        CASE 9
            IF 现在BGM参数2 == 0
                BGM = 游戏bgm/旧地狱
            ELSEIF 现在BGM参数2 == 1
                BGM = 游戏bgm/地灵殿
            ELSEIF 现在BGM参数2 == 2
                BGM = 游戏bgm/地狱遗址
            ENDIF
        CASE 10
            BGM = 游戏bgm/月都
        CASE 11
            BGM = 游戏bgm/魔界
    ENDSELECT
ENDIF
LOCAL:1 = 0
FOR LOCAL, 0, 10
    LOCALS = %BGM%/{LOCAL}.MP3
    IF EXISTSOUND(LOCALS)
        LOCAL:1 ++
        BREAK
    ENDIF
NEXT
SIF LOCAL:1 == 0
    RETURN
$RESELECTBGM
LOCALS = %BGM%/{RAND:10}.MP3
IF EXISTSOUND(LOCALS)
    BGM_LASTTIME = BGM_NOWTIME
    PLAYSOUND @"%LOCALS%"
ELSE
    GOTO RESELECTBGM
ENDIF

@EVENTCOMEND
CALL BGM_PLAY_CHECK

@EVENTFIRST
BGMVOLUME = 5

@EVENTLOAD
STOPSOUND
BGMVOLUME = 5
现在BGM参数1 = CFLAG:MASTER:現在位置/100
现在BGM参数2 = 特殊位置检查(CFLAG:MASTER:現在位置)
BGM_NOWTIME = GETTIME()/100000
CALL BGM_PLAY

@BGM_PLAY_CHECK
BGM_NOWTIME = GETTIME()/100000
IF 现在BGM参数1 == CFLAG:MASTER:現在位置/100 && 现在BGM参数2 == 特殊位置检查(CFLAG:MASTER:現在位置) && BGM_NOWTIME - BGM_LASTTIME < 5
    RETURN
ELSEIF 现在BGM参数2 == 99 && 特殊位置检查(CFLAG:MASTER:現在位置) == 99 && BGM_NOWTIME - BGM_LASTTIME >= 5
    RETURN
ELSE
    现在BGM参数1 = CFLAG:MASTER:現在位置/100
    现在BGM参数2 = 特殊位置检查(CFLAG:MASTER:現在位置)
    CALL BGM_PLAY
ENDIF
RETURN

@特殊位置检查(ARG)
#FUNCTION
IF IS_GAP_GUEST(MASTER)
    RETURNF 99
ELSEIF GMF_AT_LARGE_MAP(MASTER)
    SIF GROUPMATCH(ARG, P22参道, P23温泉・脱衣所, P24温泉) || INRANGE(ARG,P25鎮守之森,P51夢幻遺跡・倉庫)
        RETURNF 1
    SIF INRANGE(ARG,P123霊廟大門,P134蔵) || GROUPMATCH(ARG,P138鐘楼,P139邪仙楼)
        RETURNF 1
    SIF INRANGE(ARG,P436無名之丘,P439拉尔瓦的家) || INRANGE(ARG,P450玄関,P466庭)
        RETURNF 1
    SIF INRANGE(ARG,P901地霊殿前,P926中庭)
        RETURNF 1
    SIF INRANGE(ARG,P928灼熱地獄跡,P930旧血の池地獄) || GROUPMATCH(ARG,P949托卡马克装置核心,P947ちやりの棲み処)
        RETURNF 2
ELSE
    SIF GROUPMATCH(ARG, 桜花道的鳥居, 妖精的大樹, 夢幻遺跡)
        RETURNF 1
    SIF GROUPMATCH(ARG,神霊廟広場,神霊廟道場)
        RETURNF 1
    SIF GROUPMATCH(ARG,太陽花田,無名之丘,夢幻館)
        RETURNF 1
    SIF ARG == 地霊殿
        RETURNF 1
    SIF ARG == 灼熱地獄跡
        RETURNF 2
ENDIF
RETURNF 0