@BREAKCOLUMN(strInput, nLength = 0, strMatch = "\s", nIndent = 0, strBreakLine = "/")
#FUNCTIONS
#DIMS DYNAMIC MESSAGE_PRINT,50
#DIM LINELENGTH
#DIM nIndent
#DIM nLength
#DIMS strInput
#DIMS strBreakLine
#DIMS strMatch
;PRINTFORML %strInput%的strMatch是%strMatch%
SIF !nLength
	nLength = MAXWIDTH() - 19
LINELENGTH = nLength - nIndent
VARSET LOCALS
IF LINELENGTH < 1
	THROW @BREAKCOLUMN Usable length cannot be less than 1, strInput - %strInput%, nIndent - {nIndent}
ELSE
	strInput '= REPLACE(strInput, "\s", strBreakLine)
	SPLIT strInput,"/",MESSAGE_PRINT
	FOR LOCAL,0,RESULT
		IF strMatch == "NULL"
			;PRINTFORML %MESSAGE_PRINT:LOCAL%的REPLACE是%REPLACE(MESSAGE_PRINT:LOCAL, "(.{1," + TOSTR(LINELENGTH) + "})(?:|$)", " "*nIndent + "$1")%
			MESSAGE_PRINT:LOCAL '= REPLACE(MESSAGE_PRINT:LOCAL, "(.{1," + TOSTR(LINELENGTH) + "})(?:|$)", " "*nIndent + "$1" + strBreakLine)
		ELSE
			;PRINTFORML %MESSAGE_PRINT:LOCAL%的REPLACE是%REPLACE(MESSAGE_PRINT:LOCAL, "(.{1," + TOSTR(LINELENGTH) + "})(?:" + strMatch + "|$)", " "*nIndent + "$1")%
			MESSAGE_PRINT:LOCAL '= REPLACE(MESSAGE_PRINT:LOCAL, "(.{1," + TOSTR(LINELENGTH) + "}?"+ strMatch +")", " "*nIndent + "$1" + strBreakLine)
		ENDIF
		LOCALS += MESSAGE_PRINT:LOCAL
	NEXT
ENDIF
SUBSTRING LOCALS, 0, STRLENS(LOCALS) - STRLENS(strBreakLine)
SPLIT RESULTS,"/",MESSAGE_PRINT
VARSET LOCALS
FOR LOCAL,0,RESULT
	LOCALS += @"║%MESSAGE_PRINT:LOCAL,54,LEFT%║/ "
NEXT
;RETURNF SUBSTRING(LOCALS, 0, STRLENS(LOCALS) - STRLENS(strBreakLine))
RETURNF REPLACE(LOCALS,"\s+$","")


;-------------------------------------------------
;函数名:IMG_TALK
;概　要:简单图文混排
;引　用：SPTALK,CID,表情="",默认=0,MESSAGE,整形=0
;K63_PRINT_FACE与SPTALK的功能融合版，为了简单图片与对话混排，默认整形
;-------------------------------------------------
@IMG_COLUMN(基本画像, MESSAGE, 整形=1, CID,尺寸)
#DIMS DYNAMIC 基本画像
#DIMS DYNAMIC MESSAGE
#DIMS DYNAMIC MESSAGE_PRINT,50
#DIMS DYNAMIC FONTCOLOR
#DIM DYNAMIC TEMP_COLOR
#DIM DYNAMIC CID
#DIM DYNAMIC 整形
#DIM DYNAMIC 尺寸
#DIM DYNAMIC PATTERN
#LOCALSIZE 1
#LOCALSSIZE 1
SIF !尺寸
	尺寸 = 角色画像表示尺寸比
TEMP_COLOR = GETCOLOR()

;口上色取得判定:通常角色
IF CID
	CALL SET_KOJO_COLOR(CID)
	IF GETCOLOR() == 12632256 || !FLAG:口上色
		FONTCOLOR = 0xD5DEDF
	ELSE
		FONTCOLOR = 0%TOSTR(GETCOLOR(), "X")% 
	ENDIF
ELSE
	FONTCOLOR = 0%TOSTR(GETCOLOR(), "X")% 
ENDIF
VARSET MESSAGE_PRINT
IF 顔絵付きメッセージ == 1
	IF 基本画像 == ""
		GOTO 图形错误
	ELSEIF !RM_リソースチェック(基本画像) 
		PRINTFORMDL 资源「%基本画像%」未设置
		GOTO 图形错误
	ELSE
		CALL 画像セット(基本画像, 0, 0, 尺寸, 0)
	ENDIF
	;オプション指定で行送りを揃える
	SIF 整形
		MESSAGE = %SPTALK整形(MESSAGE)%

	SPLIT MESSAGE,"/",MESSAGE_PRINT
	FOR LOCAL,0,RESULT
		CALL PRINT_STR, MESSAGE_PRINT:LOCAL
		LOCALS = %HTML_POPPRINTINGSTR()%
		SIF LOCAL != 0
			CALL ダミーセット(0, 0, 尺寸 * RM_リソースの幅(基本画像)/RM_リソースの高さ(基本画像), LOCAL)
		TEMP_HTML:LOCAL += @"<font color='#%FONTCOLOR%'>%LOCALS%</font>"
	NEXT
	CALL 画像一斉表示(0, 0, 1, -1)
	PRINTL
ELSE
	$图形错误
	;顔絵メッセージOFF時は通常街道に表示させる
	SIF CID
		PRINTFORML －%CALLNAME:CID%－
	SPLIT MESSAGE,"/",MESSAGE_PRINT
	FOR LOCAL,0,RESULT
		SIF MESSAGE_PRINT:LOCAL != ""
			PRINTFORML %MESSAGE_PRINT:LOCAL%
	NEXT
ENDIF
SETCOLOR TEMP_COLOR

