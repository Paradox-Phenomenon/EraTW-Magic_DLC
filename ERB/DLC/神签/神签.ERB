@神签打印(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC MESSAGE_PRINT,50
#DIMS DYNAMIC COL,4
#DIM DYNAMIC 神签GID
SIF INRANGE(ARG,1,128)
	CALL 生成图片,@"剧本自定义附件/东方幻存神签/神签_{ARG}.webp",@"神签_{ARG}"
神签GID = RESULT
LOCALS '= 神签INFO(ARG)
SPLIT LOCALS," ",MESSAGE_PRINT
FOR count, 2, 5
	COL:1 += MESSAGE_PRINT:count + " "
NEXT
FOR count, 5, RESULT
	IF STRCOUNT(MESSAGE_PRINT:count,"：")
		COL:3 += MESSAGE_PRINT:count + " "
	ELSE
		COL:2 += MESSAGE_PRINT:count + " "
	ENDIF
NEXT
MESSAGE_PRINT '= REPLACE(MESSAGE_PRINT,"(第|签)","")
IF TOINT(MESSAGE_PRINT) < 10
	LOCAL = 2
ELSEIF TOINT(MESSAGE_PRINT) < 100
	LOCAL = 1
ELSE
	LOCAL = 0
ENDIF
{
LOCALS '= @"/
╔═════╦═════════════════════╗/
║          ║                                          ║/
║ 第%"0"*LOCAL%%MESSAGE_PRINT%签  ║  %MESSAGE_PRINT:1,40,LEFT%║/
║          ║                                          ║/
╠═════╩═════════════════════╣/
║                                                      ║/
%BREAKCOLUMN(REPLACE(COL:1,"\s+$",""),25,"NULL")%
║                                                      ║/
╠═══════════════════════════╣/
║                                                      ║/
%BREAKCOLUMN(REPLACE(COL:2,"\s+$",""),25,"[，。？！；]")%
║                                                      ║/
╟───────────────────────────╢/
║                                                      ║/
%BREAKCOLUMN(REPLACE(COL:3,"\s+$",""),25,"NULL")%
║                                                      ║/
╚═══════════════════════════╝"
}
IF INRANGE(ARG,1,128)
	默认角色画像横幅 *= 4
	CALL IMG_COLUMN,@"神签_{ARG}",LOCALS,,神签TOID:ARG,100
	默认角色画像横幅 /= 4
ELSE
	SPLIT LOCALS,"/",MESSAGE_PRINT
	FOR LOCAL,0,RESULT
		SIF MESSAGE_PRINT:LOCAL != ""
			PRINTFORML %MESSAGE_PRINT:LOCAL%
	NEXT
ENDIF
RETURN 神签GID

