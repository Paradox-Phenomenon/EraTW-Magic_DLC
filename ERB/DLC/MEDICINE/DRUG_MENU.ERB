;药品菜单
@DRUG_MENU
;打印出患者
CALL MedUI
CALL MIDInfo
PRINTL
VARSET LOCAL
;治疗方式选择，只能用一次。
FOR LOCAL,1,8
	LOCAL:1++
	CALL USED_DRUG(LOCAL)
	SIF !(LOCAL:1%3)
		PRINTL
NEXT
;IF TFLAG:958 == 0
SIF BASE:MASTER:TSP < 500
	SETCOLOR C_GRAY
PRINTFORMLC [8] SPECIAL
RESETCOLOR
;ELSE
;	PRINTLC 已使用
;ENDIF
PRINTL
PRINTL
LOCAL=(DHis-BASE:mCID:病症残余) * 100 / DHis;治疗后满意度
IF LOCAL>=80
	SETCOLOR C_AQUA
ELSEIF LOCAL<=20
	SETCOLOR C_GRAY
ENDIF
PRINTL [998]结束了，明天再来哦！（大概明天还会来）
PRINTL [999]结束了，不来也没关系！（近期不会再出现了）
RESETCOLOR
INPUT
IF RESULT == 998
	BASE:mCID:明日再来 = 1
	RETURN
ELSEIF RESULT == 999
	BASE:mCID:近期问诊 = 10 + RAND:6
	RETURN
ELSEIF BASE:0:0<500||BASE:0:1<500
	CALL IFTire
	RESTART
ELSEIF TFLAG:(RESULT+950)
	PRINTFORMW 已使用
	RESTART
ENDIF
;打印出对应治疗方式的药品
SIF !INRANGE(RESULT,1,8)
	RESTART
IF RESULT==8
	CALL SPECIAL_SKILL
	RESTART
ENDIF
CALL PRINT_DRUG(RESULT,mCID)
PRINTL
PRINTL [0]返回
INPUT
SIF !RESULT
	RESTART
IF EIRIN_POINT <= DRUG_PRICE(RESULT)
	PRINTW EP不足
	RESTART
ENDIF
;使用药品后为对应的类型，添加已使用标志。
LOCAL=RESULT/100+950
TFLAG:LOCAL=1
;使用药品扣除对应EP点数
EIRIN_POINT -= DRUG_PRICE(RESULT)
;选择好药品后，进行药效结算
CALL EfCalc(RESULT)
;如果患者体力耗尽询问是否抢救
SIF BASE:mCID:患者体力 <= 0
	CALL PATIENT_COMA
SIF RESULT==-1
	RETURN
;如果没治好返回药品菜单选择页面
SIF BASE:mCID:病症残余 > 0
	RESTART
;打印药品清单和药品最强药效
@PRINT_DRUG(ARG,mCID)
VARSET LOCAL
FOR LOCAL, ARG*100, ARG*100+19
	CALL DRUG_TYPE(LOCAL)
	SIF RESULT==-1
		RETURN
	SIF BASE:mCID:诊断完成&&(GROUPMATCH(LOCAL,104,105,106,108,109,203,208,209,307,402,405,406,407,408,409,507,511,605,607,609,704,705,708,711,716)&&CgAb(LOCAL))||(LOCAL==607&&Ck607())
		SETCOLOR C_PINK
	SIF BASE:mCID:诊断完成&&GROUPMATCH(LOCAL,700,713,715)&&IFHeal(LOCAL)
		SETCOLOR C_GREEN	
	PRINTFORM [{LOCAL}]%STR:(LOCAL + 18000), 20,LEFT% {CKMax(),3,RIGHT}/ 
	RESETCOLOR
	SELECTCASE DRUG_PRICE(LOCAL)/100
		CASE IS > EIRIN_POINT/100
			SETCOLOR C_GRAY
		CASE IS >= 30
			SETCOLOR C_RED
		CASE 20 TO 29
			SETCOLOR C_D_ORANGE
		CASE 15 TO 19
			SETCOLOR C_YELLOW
		CASE 10 TO 14
			SETCOLOR C_GREEN
		CASE 6 TO 10
			SETCOLOR C_PINK
	ENDSELECT
	PRINTFORM EP {DRUG_PRICE(LOCAL), 4, RIGHT}/ 
	RESETCOLOR
	IF DRUG_HP(LOCAL)>0
		SETCOLOR C_GREEN
	ELSEIF DRUG_HP(LOCAL)+BASE:mCID:患者体力<=0
		SETCOLOR C_RED
	ELSEIF DRUG_HP(LOCAL)<0
		SETCOLOR C_D_ORANGE	
	ENDIF	
	PRINTFORM \@DRUG_HP(LOCAL)<0?消耗#恢复\@ {ABS(DRUG_HP(LOCAL)), 3, RIGHT}/ 
	RESETCOLOR
	SIF BASE:mCID:诊断完成
		CALL CK_Ef(mCID)
	PRINTL
NEXT
@CK_Ef(mCID)
VARSET LOCAL
FOR LOCAL, 0, 36
	LOCAL:2=TFLAG:(LOCAL+900)
	LOCAL:1=LOCAL:2*BASE:mCID:(LOCAL+50)/100
	IF LOCAL:1
		SETCOLOR C_GRAY
		IF LOCAL:1>=BASE:mCID:疾病防御
			LOCAL:3=(DHis-(BASE:mCID:病症残余-LOCAL:2))*100/DHis;治疗后满意度
			IF LOCAL:3>=100
				SETCOLOR C_H_PINK
			ELSEIF LOCAL:3>=80
				SETCOLOR C_AQUA
			ELSEIF LOCAL:2>=700
				SETCOLOR C_GREEN
			ELSEIF LOCAL:2>=500
				SETCOLOR C_YELLOW
			ELSEIF LOCAL:2>=300
				SETCOLOR C_ORANGE
			ELSE
				RESETCOLOR
			ENDIF
		ENDIF
		PRINTFORM %STR:(LOCAL:0 + 19550)%:{LOCAL:1,4,RIGHT}/ 
		RESETCOLOR
	ENDIF
NEXT
;特殊技能
@SPECIAL_SKILL
SIF BASE:MASTER:TSP < 500
	SETCOLOR C_GRAY
PRINTFORMLC [1]超執刀 消耗：500 TSP 使已使用的治疗能够再次使用。
RESETCOLOR
PRINTL
PRINTL [0]返回
INPUT
IF RESULT==1
	IF BASE:MASTER:TSP >= 500
		PRINTFORML %CALLNAME:0%身影一阵模糊，新治疗器具重新摆放整齐。
		PRINTL
		PRINTFORML %CALLNAME:0% TSP - 500
		PRINTL
		;超執刀 TPS-500 重置TFLAG使用标记
		BASE:MASTER:TSP -= 500
		VARSET TFLAG, 0, 951, 958
	ELSE
		PRINT TSP不足。
	ENDIF
ENDIF
PRINTW
@USED_DRUG(ARG)
#DIMS Meth,7 ="注射","食疗","内服","外用","理疗","语疗","其他"
SIF !INRANGE(ARG,1,7)
	RETURN
PRINTFORMLC \@!TFLAG:(ARG+950)?[{ARG}] %Meth:(ARG-1)%#已使用\@