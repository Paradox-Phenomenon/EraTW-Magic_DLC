;患者昏迷
@PATIENT_COMA
CALL MedUI
CALL MAssi
PRINTL
PRINTFORML %CALLNAME:mCID%倒地昏迷不起！要进行救援吗？
PRINTL
PRINTL [1]紧急救援！！！
SIF BASE:mCID:病症残余>0
	PRINTFORML [2]支付{BASE:mCID:医疗费 * 2}现金作为转院医药费，放弃这次治疗。
LOCAL=(DHis-BASE:mCID:病症残余) * 100 / DHis;治疗后满意度
SIF LOCAL<=20
	SETCOLOR C_GRAY
SIF LOCAL>=80
	SETCOLOR C_AQUA
PRINTL [0]弃之不顾（救不了，等死吧，抬出去！！！扁鹊三连）
RESETCOLOR
INPUT
IF RESULT == 1
	CALL Aid
	SIF RESULT==-1
		RESTART
	RETURN 0
ELSEIF RESULT == 2 && BASE:mCID:病症残余>0
	PRINTL
	PRINTFORML 将昏迷的%CALLNAME:mCID%抬出去了，%CALLNAME:0%带着歉意将{BASE:mCID:医疗费 * 2}现金塞进%CALLNAME:mCID%的钱包里。
	PRINTL
	PRINTFORML %CALLNAME:0% 现金 - {BASE:mCID:医疗费 * 2}
	PRINTL
	MONEY -= BASE:mCID:医疗费 * 2
	BASE:mCID:病症残余=MAX(BASE:mCID:病症残余/2-200,100);满意度
	BASE:mCID:医疗费=0
ELSE
	PRINTL
	PRINTFORML 将昏迷的%CALLNAME:mCID%抬了出去，任其自生自灭；
	PRINTFORML 不知过了多久，%CALLNAME:mCID%才醒过来。
ENDIF
RETURN -1
@Aid
IF BASE:mCID:患者体力 > 0
	PRINTFORMW  %CALLNAME:mCID%醒过来了！
	PRINTL
	RETURN 1
ELSEIF BASE:0:0<500||BASE:0:1<500
	CALL IFTire
	RESULT=-1
	RETURN RESULT
ENDIF
CALL MedUI
CALL MAssi
PRINTL
FOR LOCAL, 800, 807
	CALL DRUG_TYPE(LOCAL)
	PRINTFORM [{LOCAL}]%STR:(LOCAL + 18000), 14,LEFT%{CKMax(),3,RIGHT}/ 成功率：{AidSucRate(LOCAL)}％ 恢复：{DRUG_HP(LOCAL)}/ 
	SELECTCASE DRUG_PRICE(LOCAL)
		CASE IS > EIRIN_POINT
			SETCOLOR C_GRAY
		CASE IS >= 3000
			SETCOLOR C_RED
		CASE 2000 TO 2999
			SETCOLOR C_D_ORANGE
		CASE 1500 TO 1999
			SETCOLOR C_YELLOW
		CASE 1001 TO 1499
			SETCOLOR C_GREEN
		CASE 600 TO 1000
			SETCOLOR C_PINK
	ENDSELECT
	PRINTFORM EP {DRUG_PRICE(LOCAL), 4, RIGHT}/
	RESETCOLOR
	SIF BASE:mCID:诊断完成
		CALL CK_Ef(mCID)
	PRINTL
NEXT
PRINTFORML [999]  放弃治疗
PRINTL
CALL RELINE(,1)
WHILE 1
	INPUT
	SIF RESULT==999
		RETURN -1
	IF !INRANGE(RESULT,800,807)
	ELSEIF EIRIN_POINT<DRUG_PRICE(RESULT)
		PRINTFORMW EP不足
	ELSE
		EIRIN_POINT-=DRUG_PRICE(RESULT)
		LOCAL=RESULT
		;添加急救耗时
		CALL TPas
		IF AidSucRate(LOCAL) > (RAND:100 + 1)
			CALL EfCalc(LOCAL)
			RETURN 1
		ELSE
			PRINTL 没能成功！！！
			CALL MDBase
		ENDIF
	ENDIF
CALL RELINE()
WEND
@MDBase
RESULT=RAND:MAX(80-POPULARITY/100,20)+21
RESULT:1=RAND:MAX(80-POPULARITY/100,20)+21
PRINTL
PRINTFORML 医生：%CALLNAME:0%  ↓体力-{RESULT}↓  ↓气力-{RESULT:1}↓
BASE:MASTER:体力-=RESULT
BASE:MASTER:気力-=RESULT:1
PRINTW
