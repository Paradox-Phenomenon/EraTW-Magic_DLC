					CALL RECOVER(MASTER, -500, GET_CURRENT_MPS(), "使用变形魔法的魔力消耗")
					LOCAL:1 = 0
				ENDIF
				PRINTLC [1] 改变人类属性
				PRINTLC [2] 改变妖怪属性
				PRINTL [3] 改变妖精属性
				PRINTLC [4] 改变付丧神属性
				PRINTLC [5] 改变人形属性
				PRINTL [6] 改变幽灵属性
				PRINTLC [7] 改变追加属性
				PRINTLC [8] 改变神灵属性
				PRINTL [9] 改变其他属性
				PRINTL [999] 跳过
				INPUT
				SELECTCASE RESULT
				CASE 1
					DRAWLINE
					PRINTL 请选择要改变的人类属性：
					PRINTLC [1] 人类
					PRINTLC [2] 仙人
					PRINTL [3] 天人
					PRINTLC [4] 月人
					PRINTLC [5] 魔界人
					PRINTL [6] 外界人
					PRINTLC [999] 跳过
					PRINTL [0] 我不做人啦
					INPUT
					IF RESULT != 999
						TALENT:MASTER:190 = RESULT
						LOCAL:1 ++
					ELSE
						LOCAL:1 = 0
					ENDIF
					GOTO SPECIES
				CASE 2
					DRAWLINE
					PRINTL 请选择要改变的妖怪属性：
					PRINTLC [1] 妖怪
					PRINTLC [2] 鬼
					PRINTL [3] 吸血鬼
					PRINTLC [4] 河童
					PRINTLC [5] 天狗
					PRINTL [6] 妖獣     
					PRINTLC [7] 妖鳥
					PRINTL [8] 妖蟲    
					PRINTLC [999] 跳过
					PRINTL [0] 去除妖怪属性
					INPUT
					IF RESULT != 999
						TALENT:MASTER:191 = RESULT
						LOCAL:1 ++
					ELSE
						LOCAL:1 = 0
					ENDIF
					GOTO SPECIES
				CASE 3
					DRAWLINE
					PRINTL 要成为妖精吗：
					PRINTL [1] 是   [0] 否
					PRINTL [999] 跳过
					INPUT
					IF RESULT != 999
						TALENT:MASTER:192 = RESULT
						LOCAL:1 ++
					ENDIF
					GOTO SPECIES
				CASE 4
					DRAWLINE
					PRINTL 要成为付丧神吗：
					PRINTL [1] 是   [0] 否
					PRINTL [999] 跳过
					INPUT
					IF RESULT != 999
						TALENT:MASTER:195 = RESULT
						LOCAL:1 ++
					ELSE
						LOCAL:1 = 0
					ENDIF
					GOTO SPECIES
				CASE 5
					DRAWLINE
					PRINTL 请选择要成为的人形类型：
					PRINTLC [1] 人形
					PRINTLC [2] 机械
					PRINTL [3] 魔像
					PRINTLC [4] 埴轮
					PRINTL [5] 僵尸
					PRINTLC [999] 跳过
					PRINTL [0] 去除人形属性
					INPUT
					IF RESULT != 999
						TALENT:MASTER:196 = RESULT
						LOCAL:1 ++
					ELSE	
						LOCAL:1 = 0
					ENDIF
					GOTO SPECIES
				CASE 6
					DRAWLINE
					PRINTL 请选择要成为的幽灵类型：
					PRINTLC [1] 幽灵
					PRINTLC [2] 骚灵
					PRINTLC [3] 亡灵
					PRINTL [4] 恶灵
					PRINTLC [999] 跳过
					PRINTL [0] 去除幽灵属性
					INPUT
					IF RESULT != 999
						TALENT:MASTER:194 = RESULT
						LOCAL:1 ++
					ELSE
						LOCAL:1 = 0
					ENDIF
					GOTO SPECIES
				CASE 7
					DRAWLINE
					PRINTL 请选择要附加的追加属性：
					SIF GETBIT(TALENT:MASTER:2, 0)
						PRINTLC [1] 巫女
					PRINTLC [2] 魔法使
					SIF GETBIT(TALENT:MASTER:2, 0)
						PRINTLC [3] 女仆
					PRINTL [4] 蓬莱人
					PRINTLC [999] 跳过
					PRINTL [0] 去除追加属性
					INPUT
					IF RESULT != 999
						TALENT:MASTER:197 = RESULT
						LOCAL:1 ++
					ELSE
						LOCAL:1 = 0
					ENDIF
					GOTO SPECIES
				CASE 8
					DRAWLINE
					PRINTL 请选择要成为的神灵属性：
					PRINTLC [1] 神灵
					PRINTLC [2] 死神
					PRINTL [3] 阎魔
					PRINTL [4] 道祖神
					PRINTL [5] 古神人
					PRINTL [6] 天使
					PRINTLC [999] 跳过
					PRINTL [0] 去除神灵属性
					INPUT
					IF RESULT != 999
						IF RESULT <= 6
							TALENT:MASTER:193 = RESULT
							LOCAL:1 ++
						ENDIF
					ELSE
						LOCAL:1 = 0
					ENDIF
					GOTO SPECIES
				CASE 9
					CALL TRANSFORM_MAGIC(MASTER)
					LOCAL:1 ++
					GOTO SPECIES
				CASEELSE
				ENDSELECT
			ENDIF
			PRINTL
			PRINTL 魔法施放完毕！
		ELSEIF 对象 != MASTER
			PRINTL 变形魔法只能对自己使用！
		ELSE
			PRINTL 魔力不足，无法发动魔法！
			PRINTL 至少需要1000点魔力才能施放此魔法。
		ENDIF
		RETURN 0
	CASE 979
		IF GET_CURRENT_MP() >= 500
			PRINTFORML 发动转运仪式...
			LOCAL = 0
			LOCAL += RANDSF(魔法知识(100, 110),3 + TALENT:MASTER:幸运儿) - RANDSF(200,3) + 150
			TFLAG:幸運補正 += TALENT:MASTER:幸运儿 * (LOG10(MAXBASE:MASTER:TSP/1000 + 1) + LOG10(MAXBASE:MASTER:法力/1000 + 1)) + 无限TSP*3 + 无限法力*2
			IF LOCAL + CFLAG:MASTER:今日の運勢 > 999
				CFLAG:MASTER:今日の運勢 = 999
				TFLAG:幸運補正 += TALENT:MASTER:幸运儿 + 1
			ELSEIF LOCAL + CFLAG:MASTER:今日の運勢 > 0 && LOCAL + CFLAG:MASTER:今日の運勢 < 999
				CFLAG:MASTER:今日の運勢 += LOCAL
			ELSE
				CFLAG:MASTER:今日の運勢 = 0
				TFLAG:幸運補正 += TALENT:MASTER:幸运儿 - 1
			ENDIF
			IF LOCAL > 700
				PRINTL 大成功，看样子今天的运气会非常好！
			ELSEIF LOCAL < 700 && LOCAL > 300
				PRINTL 不错的结果，看来仪式起作用了。  
			ELSEIF LOCAL < 300 && LOCAL > 0
				PRINTL 马马虎虎吧，运气似乎变稍微好了一些呢。
			ELSEIF LOCAL < 0 && LOCAL > -300
				PRINTL 失败了啊，运气反而变得更差了...
			ELSEIF LOCAL < -300
				PRINTL 妈耶，大失败啊！要不今天别出门了?
			ENDIF
			PRINTFORML 运气变化：{LOCAL}
			CALL RECOVER(MASTER, -500, GET_CURRENT_MPS(), "使用魔法的魔力消耗")  
			M_TFLAG:转运魔法CD = 1
			PRINTL
			PRINTL 魔法施放完毕！
		ELSE
			PRINTL 使用此魔法必须至少有500点TSP。
		ENDIF
		RETURN 0
	CASE 980
		;察知之眼
		IF GET_CURRENT_MP() >= 200
			IF GETBIT(M_CFLAG:39:魔法奖励获得, 0) || TALENT:MASTER:神性
				PRINTL 要使用察知之眼干什么呢？
				CALL ASK_YN("寻人","依赖寻找")
				IF RESULT
					PRINTL 你开始使用察知之眼...
					CALL CLAIRVOYANT
				ELSE
					PRINTL 你开始使用察知之眼...
					CALL BROAD_HITOSAGASI
					CALL RECOVER(MASTER, -200, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
				ENDIF
			ELSE
				CALL BROAD_HITOSAGASI
				CALL RECOVER(MASTER, -200, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
			ENDIF
			PRINTL 魔法施放完毕！
		ELSE
			PRINTL 使用此魔法必须至少有200点TSP。
		ENDIF
		M_TFLAG:瞬移中 = 0
		RETURN 0
	CASE 981
		;魔法换装
		M_TFLAG:魔法换装 = 1
		IF GET_CURRENT_MP() >= 100
			PRINTL 你开始使用魔法换装...
			CALL COM429
			CALL RECOVER(MASTER, -100, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
			PRINTL
			PRINTL 魔法施放完毕！
		ELSE
			PRINTL 使用此魔法必须至少有100点TSP。
		ENDIF
		M_TFLAG:魔法换装 = 0
		RETURN 0
	CASE 982
		;隙间魔法
		IF GET_CURRENT_MP() >= 300
			PRINTL 你开始使用隙间魔法...
			DRAWLINE
			IF 对象 == MASTER
				PRINTL 要使用：
				PRINTL [1] 隙间商店
				IF !FLAG:70
					IF !M_FLAG:隙间标记 && !TFLAG:约会道中
						PRINTL [2] 隙间待客室
					ELSEIF M_FLAG:隙间标记
						PRINTL [2] 邀请其他角色来到隙间待客室
					ELSEIF TFLAG:约会道中
						PRINTL [2] 穿越隙间赶路
					ENDIF
				ENDIF
				SIF !M_FLAG:隙间标记
					PRINTL [3] 查看角色隙间标记
				PRINTL [4] 隙间旅行
				SIF TALENT:MASTER:神性 >= 10 || TALENT:MASTER:昨日重现 >= 5
					PRINTL [5] 隙间嬗变术
				PRINTL [9] 取消
				INPUT
				SELECTCASE RESULT
					CASE 1
						CALL ITEM_BUY
						CALL RECOVER(MASTER, -100, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
					CASE 2
						SIF FLAG:70
							RESTART
						IF !TFLAG:约会道中 && !M_FLAG:隙间标记
							CALL OMANEKIBEYA_GAP(对象)
						ELSEIF TFLAG:约会道中
							TFLAG:约会道中 = 1
						ELSEIF M_FLAG:隙间标记
							IF CFLAG:MASTER:現在位置 != OMANEKIBEYA()
								CALL OMANEKIBEYA_GAP(对象)
								CALL RECOVER(MASTER, -300, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
							ELSE
								IF CFLAG:MASTER:诶嘿嘿
									PRINTL 这种时候还是别叫人进来了吧。
								ELSE
									M_FLAG:标记手动 = 0
									CALL OMANEKIBEYA_GUEST
								ENDIF
							ENDIF
						ENDIF
					CASE 3
						SIF M_FLAG:隙间标记
							RESTART
						CALL OMANEKIBEYA_GUEST
					CASE 4
						CALL GAP_TRAVEL
					CASE 5
						SIF TALENT:MASTER:神性 >= 10 || TALENT:MASTER:昨日重现 >= 5
							CALL GAP_TRANSFORM_BEFORE
					CASEELSE
						PRINTL 已取消释放。
				ENDSELECT
			ELSEIF 对象 != MASTER
				PRINTL 要进入隙间待客室吗
				PRINTL [1] 是     [0] 否
				INPUT
				IF RESULT
					IF !TFLAG:约会道中 && !M_FLAG:隙间标记
						CALL OMANEKIBEYA_GAP(对象)
						CALL RECOVER(MASTER, -300, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
					ELSEIF TFLAG:约会道中
						PRINTL 赶路时不能进入隙间待客室。
					ELSEIF M_FLAG:隙间标记
						PRINTL 你已经位于隙间待客室。
					ENDIF
				ENDIF
			ENDIF
			PRINTL
			PRINTL 魔法施放完毕！
		ELSE
			PRINTL 使用此魔法必须至少有300点TSP。
		ENDIF
		RETURN 1
ENDSELECT
PRINTFORMW