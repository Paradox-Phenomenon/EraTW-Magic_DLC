;魔法主界面
@MAGIC_USE
#DIM 对象
#DIM 经验获取量
#DIM 经验类型选择
#DIM 酒气清除量
#DIM 提升点数

对象 = MASTER
CALL RELINE(1,1)
$LOOP
CALL RELINE(1)
;重置魔力
CALL INFINITE_TSP_MANA_SET

IF TALENT:MASTER:禁断的知識
	SETCOLOR C_PINK
	CALL PRINTBUTTON_EX("[制作符咒]",10)
	PRINTFORM 　　
	SETCOLOR C_PINK
	CALL PRINTBUTTON_EX("[使用符咒]",11)
	PRINTL
ENDIF
M_FLAG:法强 = MIN(2 + 3*TALENT:MASTER:禁断的知識 + ABL:MASTER:TSLv + 2 *MAX((TALENT:MASTER:神性 - 5),0) + (CFLAG:MASTER:今日の運勢-499)/100 + TFLAG:幸運補正, 40) + TALENT:MASTER:昨日重现 * (TALENT:MASTER:神性 ? 2 # 1)
SIF M_FLAG:法强 < 0
	M_FLAG:法强 = 0
;法强调整
PRINTFORML 当前魔法强度：{M_FLAG:法强 - M_FLAG:魔法强度修正}/{M_FLAG:法强}
IF M_FLAG:魔法强度修正 > 0
	PRINTFORM [1]恢复魔法强度　　　　　
ELSE
	SETCOLOR 50,50,50
	PRINTPLAINFORM [1]恢复魔法强度　　　　　
	RESETCOLOR
ENDIF
IF M_FLAG:魔法强度修正 < M_FLAG:法强
	PRINTFORM [2]降低魔法强度
ELSE
	SETCOLOR 50,50,50
	PRINTPLAINFORM [2]降低魔法强度
	RESETCOLOR
ENDIF
PRINTL
;魔力来源切替
PRINTFORM [3]切换魔力来源：
IF M_FLAG:魔力来源 == 1
	SETCOLOR 0xffab6a
	PRINTFORML 法力
ELSE
	SETCOLOR 0x5090FF
	PRINTFORML TSP
ENDIF
RESETCOLOR
;神性时间因子调整
IF TALENT:MASTER:神性
	PRINTFORML 当前神性时间因子Lv：{TALENT:MASTER:神性 - 神性时间影响削弱}/{TALENT:MASTER:神性}
	IF 神性时间影响削弱 > 0
		PRINTFORM [4]恢复神性时间影响　　　
	ELSE
		SETCOLOR 50,50,50
		PRINTPLAINFORM [4]恢复神性时间影响　　　
		RESETCOLOR
	ENDIF
	IF 神性时间影响削弱 < TALENT:MASTER:神性
		PRINTFORM [5]削弱神性时间影响
	ELSE
		SETCOLOR 50,50,50
		PRINTPLAINFORM [5]削弱神性时间影响
		RESETCOLOR
	ENDIF
ENDIF
PRINTL
PRINTL
;魔法获得进度展示
IF ITEM:957 < 2
	LOCALS = %"解酒魔法Lv1进度",16,LEFT%：{ITEM:957}/2
ELSEIF ITEM:957 < 4
	LOCALS = %"解酒魔法Lv2进度",16,LEFT%：{ITEM:957}/4
ELSE
	LOCALS = %"解酒魔法熟练度",16,LEFT%：{ITEM:957}/4
ENDIF
PRINTFORMLC %LOCALS, 20, LEFT%
LOCALS = %"清扫魔法熟练度",16,LEFT%：{ITEM:977}/3
PRINTFORMLC %LOCALS, 20, LEFT%
LOCALS = %"博识魔法熟练度",16,LEFT%：{ITEM:975}/3
PRINTFORML %LOCALS, 20, LEFT%
IF ITEM:982 < 2
	LOCALS = %"隙间魔法熟练度",16,LEFT%：{ITEM:982}/2
	PRINTFORMLC %LOCALS, 20, LEFT%
ENDIF
IF ITEM:979 < 2
	LOCALS = %"转运魔法熟练度",16,LEFT%：{ITEM:979}/2
	PRINTFORMLC %LOCALS, 20, LEFT%
ENDIF
IF MONEY:1 < 50000
	PRINTFORML 魔法TSP经验：{MONEY:1}/50000（到达后时间转化魔法提升一级）
ELSE
	PRINTFORML
ENDIF
SIF !全魔法检测()
	PRINTFORML 仍有魔法尚未习得
PRINTL
CALL MAGIC_LIST(对象)
INPUT
;魔法可用性检测
IF INRANGE(RESULT, 950, 985) && !MAGIC_AVALIABLE(RESULT,对象)
	PRINTL 魔法未习得或不满足释放条件！
	GOTO LOOP
ELSEIF !COMABLE_RECORD() && GROUPMATCH(RESULT, 991, 992)
	PRINTL 魔法未习得或不满足释放条件！
	GOTO LOOP
ENDIF

SELECTCASE RESULT
	CASE 1
		SIF M_FLAG:魔法强度修正 > 0
			M_FLAG:魔法强度修正 -= 1
		GOTO LOOP
	CASE 2
		SIF M_FLAG:魔法强度修正 < M_FLAG:法强
			M_FLAG:魔法强度修正 += 1
		GOTO LOOP
	CASE 3
		IF M_FLAG:魔力来源 < 1
			M_FLAG:魔力来源 ++
		ELSE
			M_FLAG:魔力来源 = 0
		ENDIF
		GOTO LOOP
	CASE 4
		SIF 神性时间影响削弱 > 0
			神性时间影响削弱 -= 1
		GOTO LOOP
	CASE 5
		SIF 神性时间影响削弱 < TALENT:MASTER:神性
			神性时间影响削弱 += 1
		GOTO LOOP
	CASE 10
		CALL RELINE(1)
		CALL SPELL_ENGRAVE
	CASE 11
		CALL RELINE(1)
		CALL SPELL_USE
	CASE 998
		IF 对象 != MASTER
			对象 = MASTER  ; 如果当前不是自己，则切换回自己
		ELSEIF TARGET
			对象 = TARGET  ; 如果当前是自己且存在目标，则切换为目标
		ENDIF
		GOTO LOOP
				
	CASE 951
		; 气恢复Lv1魔法
		; 检查TSP剩余量是否足够
		IF GET_CURRENT_MP() >= 100
			PRINTFORML 发动气恢复Lv1魔法...
			PRINTL 魔力在空气中流动，汇聚到目标身上...
			; TSP消耗
			CALL RECOVER(MASTER, -100, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
			; 恢复気力
			CALL RECOVER(对象, 魔法知识(100, 110), "気力", "气恢复魔法的回复")
			PRINTL
			PRINTL 魔法施放完毕！
		ELSE
			PRINTL 魔力不足，无法发动魔法！
			PRINTL 至少需要200点魔力才能施放此魔法。
		ENDIF
		RETURN 0
	CASE 952
		; 气恢复Lv2魔法
		; 检查TSP剩余量是否足够（需要200点）
		IF GET_CURRENT_MP() >= 200
			PRINTFORML 发动气恢复Lv2魔法...
			PRINTL 魔力在空气中流动，汇聚到目标身上...
			; TSP消耗
			CALL RECOVER(MASTER, -200, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
			; 恢复気力
			CALL RECOVER(对象, 魔法知识(200, 120), "気力", "气恢复魔法的回复")
			PRINTL
			PRINTL 魔法施放完毕！
		ELSE
			PRINTL 魔力不足，无法发动魔法！
			PRINTL 至少需要400点魔力才能施放此魔法。
		ENDIF
		RETURN 0
	CASE 953
		; 体恢复魔法Lv1
		IF GET_CURRENT_MP() >= 100
			PRINTFORML 发动体恢复魔法Lv1...
			PRINTL 生命能量在空气中流动，汇聚到目标身上...
			; TSP消耗
			CALL RECOVER(MASTER, -100, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
			; 恢复体力
			CALL RECOVER(对象, 魔法知识(100, 110), "体力", "体恢复魔法Lv1的体力回复")
			PRINTL
			PRINTL 魔法施放完毕！
		ELSE
			PRINTL 魔力不足，无法发动魔法！
			PRINTL 至少需要200点魔力才能施放此魔法。
		ENDIF
		RETURN 0
	CASE 954
		; 体恢复魔法Lv2
		IF GET_CURRENT_MP() >= 200
			PRINTFORML 发动体恢复魔法Lv2...
			PRINTL 生命能量在空气中流动，汇聚到目标身上...
			; TSP消耗
			CALL RECOVER(MASTER, -200, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
			; 恢复体力
			CALL RECOVER(对象, 魔法知识(200, 120), "体力", "体恢复魔法Lv2的体力回复")
			PRINTL
			PRINTL 魔法施放完毕！
		ELSE
			PRINTL 魔力不足，无法发动魔法！
			PRINTL 至少需要400点魔力才能施放此魔法。
		ENDIF
		RETURN 0
	CASE 955
		; 全恢复魔法Lv1
		IF 对象 == MASTER
			PRINTL 目标：
			CALL ASK_YN("单体","群体")
			IF RESULT == 0
				GOTO 单体全恢复1
			ELSE
				IF GET_CURRENT_MP() >= 300
					PRINTFORML 发动全恢复魔法Lv1...
					PRINTL 生命能量在空气中流动，汇聚到所有目标身上...
					; TSP消耗
					VARSET LOCAL
					FOR LOCAL,0,CHARANUM
						IF CFLAG:LOCAL:現在位置 == CFLAG:MASTER:現在位置
							CALL RECOVER(LOCAL, 魔法知识(100, 110), "体力", "全恢复魔法Lv1的体力回复")
							CALL RECOVER(LOCAL, 魔法知识(100, 110), "気力", "全恢复魔法Lv1的体力回复")
							CALL RECOVER(LOCAL, 魔法知识(100, 110), "精力", "全恢复魔法Lv1的精力回复")
							SIF HAS_PENIS(LOCAL)
								CALL RECOVER(LOCAL,MAXBASE:LOCAL:勃起/2,"勃起")
						ENDIF
					NEXT
					; TSP消耗
					CALL RECOVER(MASTER, -300, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
					PRINTL
					PRINTL 魔法施放完毕！
				ELSE
					PRINTL 魔力不足，无法发动魔法！
					PRINTL 至少需要300点魔力才能施放此魔法。
				ENDIF
				RETURN
			ENDIF
		ENDIF
		$单体全恢复1
		IF GET_CURRENT_MP() >= 300
			PRINTFORML 发动全恢复魔法Lv1...
			PRINTL 生命能量在空气中流动，汇聚到目标身上...
			; TSP消耗
			CALL RECOVER(MASTER, -300, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
			; 恢复体力
			CALL RECOVER(对象, 魔法知识(200, 120), "体力", "全恢复魔法Lv1的体力回复")
			; 恢复気力
			CALL RECOVER(对象, 魔法知识(200, 120), "気力", "全恢复魔法Lv1的気力回复")
			; 恢复精力
			CALL RECOVER(对象, 魔法知识(200, 120), "精力", "全恢复魔法Lv1的精力回复")
			SIF HAS_PENIS(对象)
				CALL RECOVER(对象,MAXBASE:对象:勃起/2,"勃起")
			PRINTL
			PRINTL 魔法施放完毕！
		ELSE
			PRINTL 魔力不足，无法发动魔法！
			PRINTL 至少需要300点魔力才能施放此魔法。
		ENDIF
		RETURN
	CASE 956
		; 全恢复魔法Lv2
		IF 对象 == MASTER
			PRINTL 目标：
			CALL ASK_YN("单体","群体")
			IF RESULT == 0
				GOTO 单体全恢复2
			ELSE
				IF GET_CURRENT_MP() >= 600
					PRINTFORML 发动全恢复魔法Lv2...
					PRINTL 生命能量在空气中流动，汇聚到所有目标身上...
					; TSP消耗
					VARSET LOCAL
					FOR LOCAL,0,CHARANUM
						IF CFLAG:LOCAL:現在位置 == CFLAG:MASTER:現在位置
							CALL RECOVER(LOCAL, 魔法知识(200, 115), "体力", "全恢复魔法Lv2的体力回复")
							CALL RECOVER(LOCAL, 魔法知识(200, 115), "気力", "全恢复魔法Lv2的体力回复")
							CALL RECOVER(LOCAL, 魔法知识(200, 115), "精力", "全恢复魔法Lv2的精力回复")
							SIF HAS_PENIS(LOCAL)
								CALL RECOVER(LOCAL,MAXBASE:LOCAL:勃起,"勃起")
						ENDIF
					NEXT
					PRINTL
					; TSP消耗
					CALL RECOVER(MASTER, -600, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
					PRINTL 魔法施放完毕！
				ELSE
					PRINTL 魔力不足，无法发动魔法！
					PRINTL 至少需要600点魔力才能施放此魔法。
				ENDIF
				RETURN
			ENDIF
		ENDIF
		$单体全恢复2
		IF GET_CURRENT_MP() >= 600
			PRINTFORML 发动全恢复魔法Lv2...
			PRINTL 生命能量在空气中流动，汇聚到目标身上...
			; TSP消耗
			CALL RECOVER(MASTER, -600, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
			; 恢复体力
			CALL RECOVER(对象, 魔法知识(400, 130), "体力", "全恢复魔法Lv2的体力回复")
			; 恢复気力
			CALL RECOVER(对象, 魔法知识(400, 130), "気力", "全恢复魔法Lv2的気力回复")
			; 恢复精力
			CALL RECOVER(对象, 魔法知识(400, 130), "精力", "全恢复魔法Lv2的精力回复")
			SIF HAS_PENIS(对象)
				CALL RECOVER(对象,MAXBASE:对象:勃起,"勃起")
			PRINTL
			PRINTL 魔法施放完毕！
		ELSE
			PRINTL 魔力不足，无法发动魔法！
			PRINTL 至少需要600点魔力才能施放此魔法。
		ENDIF
		RETURN
	CASE 957
		; 酒气清除魔法
		IF GET_CURRENT_MP() >= 150
			PRINTFORML 发动解酒魔法...
			PRINTL 神秘的能量在空气中流动，汇聚到目标身上...
			; TSP消耗
			CALL RECOVER(MASTER, -150, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
			IF MAXBASE:对象:酒気 / 6 + BASE:对象:酒気 * ITEM:957 / 6 <= BASE:对象:酒気
				酒气清除量 = MAXBASE:对象:酒気 / 6 + BASE:对象:酒気 * ITEM:957 / 6
			ELSE
				酒气清除量 = BASE:对象:酒気
			ENDIF
			CALL RECOVER(对象, -MAXBASE:对象:酒気 / 6 - BASE:对象:酒気 * ITEM:957 / 6, "酒気", "解酒魔法的酒气清除")
			CALL RECOVER(对象, 酒气清除量 * ITEM:957 / 6, "法力", "酒气转化的法力")
			PRINTL
			PRINTL 魔法施放完毕，酒气清除了一部分！
		ELSE
			PRINTL 魔力不足，无法发动魔法！
			PRINTL 至少需要150点魔力才能施放此魔法。
		ENDIF
		RETURN 0
	CASE 958
		; 解酒魔法Lv2
		酒气清除量 = 0
		IF GET_CURRENT_MP() >= 250
			PRINTFORML 发动解酒魔法...
			PRINTL 神秘的能量在空气中流动，汇聚到目标身上...
			; TSP消耗
			CALL RECOVER(MASTER, -250, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
			IF (ITEM:957 >= 6 || TALENT:MASTER:昨日重现 >=3) && 对象 == MASTER
				DRAWLINE
				PRINTL 要清除在场所有人的酒气吗？
				PRINTL [1] 是    [2] 否
				INPUT
				IF RESULT == 1
					FOR LOCAL,0,CHARANUM
						IF CFLAG:(LOCAL):現在位置 == CFLAG:MASTER:現在位置
							IF MAXBASE:(LOCAL):酒気 / 3 + BASE:(LOCAL):酒気 * ITEM:957 / 4 <= BASE:(LOCAL):酒気
								酒气清除量 = MAXBASE:(LOCAL):酒気 / 3 + BASE:(LOCAL):酒気 * ITEM:957 / 4
							ELSE
								酒气清除量 = BASE:(LOCAL):酒気
							ENDIF
							TCVAR:LOCAL:烂醉 = 0
							SIF CFLAG:LOCAL:職種 == 51
								CFLAG:LOCAL:職種 = 49
							CALL RECOVER(LOCAL, -MAXBASE:(LOCAL):酒気 / 3 - BASE:(LOCAL):酒気 * ITEM:957 / 4, "酒気", "解酒魔法的酒气清除")
							CALL RECOVER(LOCAL, 酒气清除量 * ITEM:957 / 4, "法力", "酒气转化的法力")
						ENDIF
					NEXT
				ELSE
					GOTO 单体解酒lv2
				ENDIF
			ELSE
				$单体解酒lv2
				TCVAR:对象:烂醉 = 0
				SIF CFLAG:对象:職種 == 51
					CFLAG:对象:職種 = 49
				IF MAXBASE:对象:酒気 / 3 + BASE:对象:酒気 * ITEM:957 / 4 <= BASE:对象:酒気
					酒气清除量 = MAXBASE:对象:酒気 / 3 + BASE:对象:酒気 * ITEM:957 / 4
				ELSE
					酒气清除量 = BASE:对象:酒気
				ENDIF
				CALL RECOVER(对象, -MAXBASE:对象:酒気 / 3 - BASE:对象:酒気 * ITEM:957 / 4, "酒気", "解酒魔法的酒气清除")
				CALL RECOVER(对象, 酒气清除量 * ITEM:957 / 4, "法力", "酒气转化的法力")
			ENDIF
			PRINTL
			PRINTL 魔法施放完毕，酒气清除了一部分！
		ELSE
			PRINTL 魔力不足，无法发动魔法！
			PRINTL 至少需要250点魔力才能施放此魔法。
		ENDIF
		RETURN 0
	CASE 959
		; 时间转化Lv1
		IF !M_TFLAG:往日之隙 && !M_TFLAG:时间循环
			PRINTFORML 发动时间转化Lv1...
			PRINTL 神秘的能量在空气中流动，消耗大量时间回复了TSP值...
			; 恢复TSP
			LOCAL = 魔法知识(100, 110)/50
			CALL CHANGE_MAXBASE(MASTER, BASE_TSP, LOCAL)
			CALL RECOVER(对象, 魔法知识(100, 110), "TSP", "时间转化Lv1的TSP回复")
			M_TFLAG:时间因子类型 = TimeFactor_无加速
			TIME += 30
			TFLAG:你起床 += 30
			PRINTL
			PRINTL 魔法施放完毕！
			CALL COLORMESSAGE(@"冥想使你受益良多，TSP上限提高了{LOCAL}点。",C_GREEN,1)
		ELSEIF M_TFLAG:时间循环
			PRINTL 处于时间循环中的你无法将时间转化为TSP！
		ELSE
			PRINTL 处于过去时间的你无法将时间转化为TSP！
		ENDIF
		PRINTL
		SELECTCOM = 950
		TFLAG:3 = SELECTCOM
		DOTRAIN 999
		RETURN
	CASE 960
		IF !M_TFLAG:往日之隙 && !M_TFLAG:时间循环
		; 时间转化Lv2
			PRINTFORML 发动时间转化Lv2...
			PRINTL 神秘的能量在空气中流动，消耗大量时间回复了TSP值...
			; 恢复TSP
			LOCAL = 魔法知识(200, 110)/50
			CALL CHANGE_MAXBASE(MASTER, BASE_TSP, LOCAL)
			CALL RECOVER(对象, 魔法知识(120, 115), "TSP", "时间转化Lv2的TSP回复")
			M_TFLAG:时间因子类型 = TimeFactor_无加速
			TIME += 30
			TFLAG:你起床 += 30
			PRINTL
			PRINTL 魔法施放完毕！
			CALL COLORMESSAGE(@"冥想使你受益良多，TSP上限提高了{LOCAL}点。",C_GREEN,1)
		ELSEIF M_TFLAG:时间循环
			PRINTL 处于时间循环中的你无法将时间转化为TSP！
		ELSE
			PRINTL 处于过去时间的你无法将时间转化为TSP！
		ENDIF
		PRINTL
		SELECTCOM = 950
		TFLAG:3 = SELECTCOM
		DOTRAIN 999
		RETURN
	CASE 961
		; 时间转化Lv3
		DRAWLINE
		IF !M_TFLAG:时间循环
			PRINTL 时间转化的长度为？
			PRINTL [1] 0.5小时    [2] 1小时   [3] 1.5小时   [4] 2小时
		ENDIF
		IF TALENT:MASTER:神性 > 7
			SIF !M_TFLAG:时间循环
				PRINTL [998] 时间循环
			SIF M_TFLAG:时间循环
				PRINTL [998] 时间循环解除
		ENDIF
		SIF M_TFLAG:往日之隙
			PRINTL [997] 返回现在
		PRINTL [999] 放弃
		INPUT
		LOCAL = RESULT

		IF LOCAL <= 10 
			DRAWLINE
			PRINTL 时间的箭头将指向：
			PRINTL [0] 未来 （将时间转化为TSP）
			PRINTL [1] 过去 （消耗TSP使时钟倒转）
			INPUT
			SELECTCASE RESULT
				CASE 0
					IF !M_TFLAG:往日之隙 && !M_TFLAG:时间循环
						PRINTFORML 将时间转化为TSP中...
						PRINTL 神秘的能量在空气中流动，消耗大量时间回复了TSP值...
						; 恢复TSP
