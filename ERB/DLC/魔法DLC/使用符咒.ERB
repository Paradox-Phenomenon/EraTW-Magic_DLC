@SPELL_USE
#DIM TMP_ID
#DIM SPELL_ID
CALL RELINE(1,1)
$LOOP
CALL RELINE(1)
PRINTFORML 请选择要使用的符咒
CALL SPELL_LIST
PRINTFORML [ 0] 返回
INPUT
SPELL_ID = RESULT
SIF INRANGE(SPELL_ID,1,99) && M_SPELL:SPELL_ID:数量 <= 0
	GOTO LOOP
SELECTCASE SPELL_ID
	CASE 1
		CALL RECOVER(MASTER, 魔法知识(100, 105), "気力", "恢复符咒的回復")
		CALL RECOVER(MASTER, 魔法知识(100, 105), "体力", "恢复符咒的回復")
		LOCAL:1 ++
	CASE 2
		PRINTFORM 要寻找谁的位置?
		PRINTL
		DRAWLINEFORM －
		FOR LOCAL,1,CHARANUM
			SIF !CFLAG:LOCAL:出禁 && !TALENT:LOCAL:路人
				PRINTFORMLC [{LOCAL,3}] %CALLNAME:LOCAL,12,LEFT%
		NEXT
		PRINTL 
		DRAWLINEFORM － 
		INPUT
		TMP_ID = RESULT
		IF INRANGE(TMP_ID,1,CHARANUM)
			IF CFLAG:TMP_ID:現在位置 != SUKIMA()
				PRINTFORML 「看到了%CALLNAME:TMP_ID% ,位于%STR_TR(5000 + GET_MAPID(CFLAG:TMP_ID:現在位置))% 」
			ELSE
				PRINTFORML 「看到了%CALLNAME:TMP_ID% ,但似乎无法到达她的位置。」
			ENDIF
			LOCAL:1 ++
		ELSE
			RESTART
		ENDIF
	CASE 3
		M_TFLAG:千里眼 = 1
		PRINTFORML 使用千里眼符咒后, 你可以看到很远的地方了
		LOCAL:1 ++
	CASE 4
		CALL GAP_TRAVEL
		LOCAL:1 ++
	CASE 5
		IF TFLAG:幸運補正 < 1
			TFLAG:幸運補正 = 1
		ELSEIF TFLAG:幸運補正 < MAX(3, TALENT:MASTER:神性/2+1)
			TFLAG:幸運補正 ++
		ENDIF
		IF CFLAG:MASTER:今日の運勢 < 250 + TALENT:MASTER:神性 * 50
			CFLAG:MASTER:今日の運勢 = 300 + TALENT:MASTER:神性 * 50 - 1
		ELSEIF CFLAG:MASTER:今日の運勢 <= 674
			CFLAG:MASTER:今日の運勢 += 25
		ELSEIF CFLAG:MASTER:今日の運勢 <= 699
			CFLAG:MASTER:今日の運勢 = 699
		ENDIF
		LOCAL:1 ++
	CASE 6
		IF TFLAG:幸運補正 < 3
			TFLAG:幸運補正 = 3
		ELSEIF TFLAG:幸運補正 < MAX(5, TALENT:MASTER:神性)
			TFLAG:幸運補正 ++
		ENDIF
		IF CFLAG:MASTER:今日の運勢 < 450 + TALENT:MASTER:神性 * 50
			CFLAG:MASTER:今日の運勢 = 500 + TALENT:MASTER:神性 * 50 - 1
		ELSEIF CFLAG:MASTER:今日の運勢 <= 949
			CFLAG:MASTER:今日の運勢 += 50
		ELSEIF CFLAG:MASTER:今日の運勢 <= 999
			CFLAG:MASTER:今日の運勢 = 999
		ENDIF
		LOCAL:1 ++
	CASE 7
		M_TFLAG:解密 = 1
		PRINTFORML 使用解密符咒后, 开锁变得简单了
		LOCAL:1 ++
	CASE 8
		M_TFLAG:时之蠹 = 1
		PRINTFORML 这块符咒好像侵蚀了时间
		LOCAL:1 ++
	CASE 9
		TFLAG:你起床 += 60
		M_TFLAG:神清气爽 += 60
		CFLAG:316 = 0
		PRINTFORML 睡眠推迟了一个小时
		LOCAL:1 ++
	CASE 10
		TIME:天気 = 天气_晴	
		FORBIDDEN_CHANGE_WEATHER = 1
		PRINTFORML 符咒使用后, 天空变得晴朗, 万里无云
		CALL qol_FORCESET_REGION_WEATHER_SYSTEM
		LOCAL:1 ++
	CASE 11
		TIME:天気 = 天气_雨	
		FORBIDDEN_CHANGE_WEATHER = 1
		PRINTFORML 符咒使用后, 雨滴开始轻轻落下...
		CALL qol_FORCESET_REGION_WEATHER_SYSTEM
		LOCAL:1 ++
	CASE 12
		TIME:天気 = 天气_大雨	
		FORBIDDEN_CHANGE_WEATHER = 1
		SIF WIND_VELOCITY < 1
			WIND_VELOCITY = 1
		PRINTFORML 符咒使用后, 大雨倾盆而下...
		CALL qol_FORCESET_REGION_WEATHER_SYSTEM
		CALL qol_FORCESET_REGION_WIND_VE_SYSTEM
		LOCAL:1 ++
	CASE 13
		TCVAR:MASTER:加護 = 1
		PRINTFORML 你获得了加护效果, 这将削弱弹幕战中对手的骰子数
		LOCAL:1 ++
	CASE 14
		PRINTL 是否额外增加处女保护功能(保护你小姐的处女不丢失)
		CALL ASK_YN()
		IF !RESULT
			TCVAR:MASTER:避孕魔法 = 2
		ELSE
			TCVAR:MASTER:避孕魔法 = 1
		ENDIF
		LOCAL:1 ++
	CASE 15
		CALL RECOVER(MASTER, MAXBASE:MASTER:法力/2, "法力", "聚灵符咒的魔力回复")
		M_TFLAG:BUFF标记 = 1
		CALL BUFF_BASE(MASTER, BASE_法力, SQRT(MAXBASE:MASTER:法力)*2, 1)
		CALL CHANGE_MAXBASE(MASTER, BASE_法力, SQRT(MAXBASE:MASTER:法力), 1)
		PRINTFORML 使用了聚灵符咒, 你的最大法力值增加了
		LOCAL:1 ++
	CASE 16
		TCVAR:MASTER:豊穣 = 1
		PRINTFORML 你获得了丰穰效果, 收获将获得更多农作物
		LOCAL:1 ++
	CASE 17
		TMP_ID = RANDSF(YOGORE:(CFLAG:MASTER:現在位置)/300,ITEM:977 + 2)
		YOGORE:(CFLAG:MASTER:現在位置) = 0 ; 设置房间清洁度为最高（YOGORE值越低越干净）
		CALL SWEEPCHARA
		PRINTL 当前房间清洁度已提升至最高, 房间内所有人的污垢也已被清除
		; 增加清扫经验
		EXP:MASTER:清掃経験 += TMP_ID
		PRINTFORML 获得了 {TMP_ID} 点清扫经验！
		LOCAL:1 ++
	CASE 18
		IF MAXBASE:MASTER:酒気 / 6 + BASE:MASTER:酒気 <= BASE:MASTER:酒気
			TMP_ID = MAXBASE:MASTER:酒気 / 6 + BASE:MASTER:酒気
		ELSE
			TMP_ID = BASE:MASTER:酒気
		ENDIF
		CALL RECOVER(MASTER, TMP_ID, "酒気", "解酒魔法的酒气清除")
		CALL RECOVER(MASTER, TMP_ID, "法力", "酒气转化的法力")
		LOCAL:1 ++
	CASEELSE
		CALL RELINE(1)
		CALL MAGIC_USE
		RETURN
ENDSELECT
IF LOCAL:1
	M_SPELL:SPELL_ID:数量 --
	SELECTCOM = 950
	TFLAG:3 = SELECTCOM
	DOTRAIN 999
	PRINTFORMW
ENDIF
RETURN

@SPELL_ENGRAVE
#DIM 选择位
#DIM 获得符咒数
#DIM TMP_符咒选择
#DIM TMP_触媒序号
#DIM TMP_投入符咒数
#DIM TMP_投入触媒数
CALL RELINE(1,1)
$LOOP
CALL RELINE(1)
FOR LOCAL,1,10
	IF 符咒铭刻位:LOCAL:符咒种类 == 0
		IF LOCAL > 3 + ABL:MASTER:教养
			SETCOLOR C_GRAY
			PRINTPLAINFORM [{LOCAL}] -------------------
			RESETCOLOR
		ELSE
			PRINTFORM [{LOCAL}] -------------------
		ENDIF
	ELSE
		IF TIME:1 - 符咒铭刻位:LOCAL:铭刻时间 >= 360
			SETCOLOR C_GREEN
			PRINTFORM [{LOCAL}] %ERDNAME(M_SPELL,符咒铭刻位:LOCAL:符咒种类,1), 13, LEFT% 符咒投入:{符咒铭刻位:LOCAL:符咒数,5,LEFT} 触媒投入:{符咒铭刻位:LOCAL:触媒数,5,LEFT} 
			SETCOLOR 0x2196f3
			PRINTFORM 可收获
			RESETCOLOR
		ELSE
			PRINTPLAINFORM [{LOCAL}] %ERDNAME(M_SPELL,符咒铭刻位:LOCAL:符咒种类,1), 13, LEFT% 符咒投入:{符咒铭刻位:LOCAL:符咒数,5,LEFT} 触媒投入:{符咒铭刻位:LOCAL:触媒数,5,LEFT} 剩余所需时间:{360 - (TIME:1 - 符咒铭刻位:LOCAL:铭刻时间)}
		ENDIF
	ENDIF
	PRINTL
NEXT
DRAWLINE
PRINTLC [0] 返回
PRINTLC [99] 主动注魔以加速制作(-1000 法力)
INPUT
选择位 = RESULT
IF 选择位 == 99 
	IF BASE:MASTER:法力 >= 1000
		FOR LOCAL,1,10
			符咒铭刻位:LOCAL:铭刻时间 -= 60
		NEXT
		CALL RECOVER(MASTER, -1000, "法力", "主动注魔的法力消耗")
		PRINTFORMW
	ELSE
		PRINTFORMW 没有足够的法力
	ENDIF
	GOTO LOOP
ELSEIF 选择位 == 0
	CALL RELINE(1)
	CALL MAGIC_USE
ELSEIF 选择位 > 3 + ABL:MASTER:教养
	PRINTFORMW 提升教养等级以解锁更多的符咒铭刻位
	GOTO LOOP
ELSEIF INRANGE(选择位,1,9)
	IF 符咒铭刻位:选择位:符咒种类 == 0
		PRINTL 请选择要铭刻的符咒
		CALL SPELL_LIST(2)
		PRINTFORML [0] 返回
		INPUT
		SIF RESULT == 0
			GOTO LOOP
		TMP_符咒选择 = RESULT
		TMP_触媒序号 = 270 + M_SPELL:TMP_符咒选择:等级
		IF !CAN_ENGRAVE(TMP_符咒选择)
			PRINTFORMW 不合规的符咒选择
			GOTO LOOP
		ELSEIF ITEM:符咒 <= 0 || ITEM:(TMP_触媒序号) <= 0
			PRINTFORMW 没有足够的符咒或触媒
			GOTO LOOP
		ENDIF
		CALL RELINE(2,1)
		$LOOP2
		CALL RELINE(2)
		PRINTFORML 请选择要投入的符咒数（1-10）当前:{TMP_投入符咒数}
		PRINTLC [1] -5
		PRINTLC [2] -1
		SIF ITEM:符咒 < TMP_投入符咒数 + 1
			SETCOLOR C_GRAY
		PRINTLC [3] +1
		SIF ITEM:符咒 < TMP_投入符咒数 + 5
			SETCOLOR C_GRAY
		PRINTLC [4] +5
		RESETCOLOR
		SIF INRANGE(TMP_投入符咒数,1,10)
			PRINTL [5] 确认
		INPUT
		SELECTCASE RESULT
			CASE 1
				IF TMP_投入符咒数 >= 5
					TMP_投入符咒数 -= 5
				ELSE
					TMP_投入符咒数 = 0
				ENDIF
				GOTO LOOP2
			CASE 2
				IF TMP_投入符咒数 >= 1
					TMP_投入符咒数 -= 1
				ELSE
					TMP_投入符咒数 = 0
				ENDIF
				GOTO LOOP2
			CASE 3
				IF ITEM:符咒 >= TMP_投入符咒数 + 1
					IF TMP_投入符咒数 <= 9
						TMP_投入符咒数 += 1
					ELSE
						TMP_投入符咒数 = 10
					ENDIF
				ENDIF
				GOTO LOOP2
			CASE 4
				IF ITEM:符咒 >= TMP_投入符咒数 + 5
					IF TMP_投入符咒数 <= 5
						TMP_投入符咒数 += 5
					ELSE
						TMP_投入符咒数 = 10
					ENDIF
				ENDIF
				GOTO LOOP2
			CASE 5
				SIF !INRANGE(TMP_投入符咒数,1,10)
					GOTO LOOP2
				CALL RELINE(2)
			CASEELSE
				GOTO LOOP2
		ENDSELECT
		CALL RELINE(2,1)
		$LOOP3
		CALL RELINE(2)
		PRINTFORML 请选择要投入的触媒数（1-10）当前:{TMP_投入触媒数}
		PRINTLC [1] -5
		PRINTLC [2] -1
		SIF ITEM:(TMP_触媒序号) < TMP_投入触媒数 + 1
			SETCOLOR C_GRAY
		PRINTLC [3] +1
		SIF ITEM:(TMP_触媒序号) < TMP_投入触媒数 + 5
			SETCOLOR C_GRAY
		PRINTLC [4] +5
		RESETCOLOR
		SIF INRANGE(TMP_投入触媒数,1,10)
			PRINTL [5] 确认
		INPUT
		SELECTCASE RESULT
			CASE 1
				IF TMP_投入触媒数 >= 5
					TMP_投入触媒数 -= 5
				ELSE
					TMP_投入触媒数 = 0
				ENDIF
				GOTO LOOP3
			CASE 2
				IF TMP_投入触媒数 >= 1
					TMP_投入触媒数 -= 1
				ELSE
					TMP_投入触媒数 = 0
				ENDIF
				GOTO LOOP3
			CASE 3
				IF ITEM:(TMP_触媒序号) >= TMP_投入触媒数 + 1
					IF TMP_投入触媒数 <= 9
						TMP_投入触媒数 += 1
					ELSE
						TMP_投入触媒数 = 10
					ENDIF
				ENDIF
				GOTO LOOP3
			CASE 4
				IF ITEM:(TMP_触媒序号) >= TMP_投入触媒数 + 5
					IF TMP_投入触媒数 <= 5
						TMP_投入触媒数 += 5
					ELSE
						TMP_投入触媒数 = 10
					ENDIF
				ENDIF
				GOTO LOOP3
			CASE 5
				SIF !INRANGE(TMP_投入触媒数,1,10)
					GOTO LOOP3
			CASEELSE
				GOTO LOOP3
		ENDSELECT
		PRINTFORML 铭刻 %ERDNAME(M_SPELL,TMP_符咒选择,1)% ,投入了 {TMP_投入符咒数} 个符咒和 {TMP_投入触媒数} 个触媒lv{TMP_触媒序号-270}, 确认吗?
		CALL ASK_YN
		IF RESULT == 0
			ITEM:符咒 -= TMP_投入符咒数
			ITEM:(TMP_触媒序号) -= TMP_投入触媒数
			符咒铭刻位:选择位:符咒种类 = TMP_符咒选择
			符咒铭刻位:选择位:符咒数 = TMP_投入符咒数
			符咒铭刻位:选择位:触媒数 = TMP_投入触媒数
			符咒铭刻位:选择位:铭刻时间 = TIME:1
			PRINTFORMW 符咒开始制作, 等待6个小时吸收环境魔力后即可收获
			M_TFLAG:时间因子类型 = TimeFactor_TSLv
		ENDIF
		TMP_投入触媒数 = 0
		TMP_投入符咒数 = 0
		TMP_符咒选择 = 0
		TMP_触媒序号 = 0
		GOTO LOOP
	ELSE
		TMP_符咒选择 = 符咒铭刻位:选择位:符咒种类
		IF TIME:1 - 符咒铭刻位:选择位:铭刻时间 >= 360
			获得符咒数 = 1 + RANDSF(-100/符咒铭刻位:选择位:触媒数, 符咒铭刻位:选择位:符咒数 * 10 + ABL:MASTER:战斗能力 * 5 + MAGIC_SuccessRate()/2)
			IF TMP_符咒选择 == 51
				M_SPELL:晴空符咒:数量 += 获得符咒数/3 + 获得符咒数%3
				M_SPELL:雨符咒:数量 += 获得符咒数/3
				M_SPELL:风暴符咒:数量 += 获得符咒数/3
				SETCOLOR C_GREEN
				PRINTFORML 获得了 {获得符咒数/3 + 获得符咒数%3} 个 %ERDNAME(M_SPELL,10,1)%！
				PRINTFORML 获得了 {获得符咒数/3} 个 %ERDNAME(M_SPELL,11,1)%！
				PRINTFORML 获得了 {获得符咒数/3} 个 %ERDNAME(M_SPELL,12,1)%！
				RESETCOLOR
			ELSEIF TMP_符咒选择 == 52
				LOCAL = RANDSF(-10,获得符咒数)
				M_SPELL:奇迹符咒:数量 += LOCAL
				M_SPELL:幸运符咒:数量 += 获得符咒数 - LOCAL
				SETCOLOR C_GREEN
				PRINTFORML 获得了 {LOCAL} 个 %ERDNAME(M_SPELL,6,1)%！
				PRINTFORML 获得了 {获得符咒数 - LOCAL} 个 %ERDNAME(M_SPELL,5,1)%！
				RESETCOLOR
			ELSEIF CAN_ENGRAVE(TMP_符咒选择) 
				M_SPELL:(TMP_符咒选择):数量 += 获得符咒数
				SETCOLOR C_GREEN
				PRINTFORML 获得了 {获得符咒数} 个 %ERDNAME(M_SPELL,TMP_符咒选择,1)%！
				RESETCOLOR
			ENDIF
			PRINTFORMW
			符咒铭刻位:选择位:符咒种类 = 0
			符咒铭刻位:选择位:符咒数 = 0
			符咒铭刻位:选择位:触媒数 = 0
			符咒铭刻位:选择位:铭刻时间 = 0
			GOTO LOOP
		ELSE
			SETCOLOR 0xf5632a
			PRINTFORMW 这批符咒还需要吸收环境魔力 {360 - (TIME:1 - 符咒铭刻位:选择位:铭刻时间)} 分钟后才能收获
			RESETCOLOR
			GOTO LOOP
		ENDIF
	ENDIF
ENDIF