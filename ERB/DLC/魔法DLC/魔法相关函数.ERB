	LOCAL = LOCAL * (15-ABL:MASTER:清掃技能)/15
SIF M_TFLAG:时间因子类型 == TimeFactor_料理 && GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (15-ABL:MASTER:料理技能)/15
SIF M_TFLAG:时间因子类型 == TimeFactor_音乐 && GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (10-ABL:MASTER:音楽技能)/10
SIF M_TFLAG:时间因子类型 == TimeFactor_战斗 && GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (10-ABL:MASTER:戦闘能力)/10
SIF M_TFLAG:时间因子类型 == TimeFactor_技巧 && GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (25-ABL:MASTER:技巧)/25


SIF M_TFLAG:时间因子类型 == TimeFactor_采集 && GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (12-TALENT:MASTER:採集Lv)/12
SIF M_TFLAG:时间因子类型 == TimeFactor_调合 && GETBIT(MAGIC_DLC_时间因子,0)	
	LOCAL = LOCAL * (15-TALENT:MASTER:調合Lv-TALENT:MASTER:調合知識*3-TALENT:MASTER:禁断的知識*2)/15
SIF M_TFLAG:时间因子类型 == TimeFactor_钓鱼 && GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (10-TALENT:MASTER:釣りLv)/10
SIF M_TFLAG:时间因子类型 == TimeFactor_采伐 && GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (10-TALENT:MASTER:伐採Lv)/10

SIF M_TFLAG:时间因子类型 == TimeFactor_学习 && GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (10-ABL:MASTER:教養) * (2-TALENT:MASTER:習得速度) /20

SIF M_TFLAG:时间因子类型 == TimeFactor_泡茶 && GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (30 - ABL:MASTER:教養 - TALENT:MASTER:調合Lv - ABL:MASTER:TSLv)/30

IF M_TFLAG:时间因子类型 != TimeFactor_TSLv
	IF ARG > 0
		LOCAL = MAX(LOCAL, 1)
	ELSEIF ARG < 0
		LOCAL = MIN(LOCAL, -1)
	ENDIF
ENDIF

RETURNF LOCAL

