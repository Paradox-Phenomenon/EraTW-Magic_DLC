
;-----------------------------------------------------------
;函数作用:打印魔法列表按钮的函数
;-----------------------------------------------------------
@MAGIC_LIST_BUTTON(ARG,改行用,ARG:1 = 1)
#DIMS 魔法名
#DIM 改行用

魔法名 = [{ARG}] %ITEMNAME:(ARG), 18, LEFT% 
改行用 += STRLENS(魔法名)
SIF LOCAL:0 < 100
	改行用 ++
IF 改行用 > 116
	IF 改行用 >= 999
	ELSE
		PRINTL 
	ENDIF
	改行用 = STRLENS(魔法名)
	SIF LOCAL:0 < 100
		改行用 ++
	PRINT 　　
ENDIF

IF ARG:1 
	PRINTFORM [{ARG}] %ITEMNAME:(ARG), 18, LEFT%
ELSE
	SETCOLOR 0x606060
	PRINTPLAINFORM [{ARG}] %ITEMNAME:(ARG), 18, LEFT%
	RESETCOLOR
ENDIF
SIF ARG < 1000  ; 魔法ID从950开始
	PRINT  
PRINT 　　
RETURN 改行用

;-----------------------------------------------------------
;函数作用:打印魔法列表的函数
;-----------------------------------------------------------
@MAGIC_LIST(对象)
#DIM 对象
#DIM r_index
#DIM m_index
FOR r_index ,1, 6
	m_index = 6 - r_index
	PRINTFORM ■TSLv{m_index} 
	PRINTL ===========================================================================================================
	VARSET LOCAL
	LOCAL:2 = (ABL:MASTER:TSLv >= m_index || TALENT:MASTER:昨日重现 || GETBIT(M_TFLAG:代替魔法等级, m_index))
	LOCAL:1 = 999
	FOR LOCAL:0 ,0, 1000
		IF MAGIC_RANK(LOCAL:0) == m_index
			IF MAGIC_OTHERCONDITION(LOCAL:0) && (MAGIC_GENERALCONDITION(LOCAL:0) || TALENT:MASTER:昨日重现 >= m_index) && (!MAGIC_MASTERONLY(LOCAL:0) || 对象 == MASTER)     
				CALL MAGIC_LIST_BUTTON(LOCAL:0, LOCAL:1,LOCAL:2)
				LOCAL:1 = RESULT
			ENDIF
		ENDIF
	NEXT
	PRINTL 
NEXT
[SKIPSTART]
IF COMABLE_RECORD()
	PRINTL ■ 特殊魔法 ===========================================================================================================
	PRINTFORM [991] %"空想记录", 18, LEFT%
	PRINTFORM [992] %"记录演绎", 18, LEFT%
	PRINTL
ENDIF
[SKIPEND]
DRAWLINE
IF TARGET 
	SIF 对象 != MASTER
		SETCOLOR C_YELLOW
	PRINTFORML [998] 用于%CALLNAME:TARGET%
	RESETCOLOR
ENDIF
PRINTL [0] 返回

@MAGIC_AVALIABLE(ARG,ARG:1)
#FUNCTION
SIF MAGIC_RANK(ARG) > ABL:MASTER:TSLv && !TALENT:MASTER:昨日重现 && !GETBIT(M_TFLAG:代替魔法等级, MAGIC_RANK(ARG))
	RETURNF 0
SIF !MAGIC_OTHERCONDITION(LOCAL:0)
	RETURNF 0
SIF !MAGIC_GENERALCONDITION(ARG) && !TALENT:MASTER:昨日重现
	RETURNF 0
SIF ARG:1 != MASTER && MAGIC_MASTERONLY(ARG:1)
	RETURNF 0
RETURNF 1

;-----------------------------------------------------------
;函数作用:用于判断魔法释放所需等级的函数
;-----------------------------------------------------------
@MAGIC_RANK(ARG:0)
; 魔法等级判断
#FUNCTION
SELECTCASE ITEMNAME:(ARG:0)
	;(酒造パッチ)追加酒の調合難易度は1
	CASE "气恢复魔法Lv1", "体恢复魔法Lv1",  "避孕魔法",  "魔法换装"
		RETURNF 1
	CASE "气恢复魔法Lv2", "体恢复魔法Lv2",  "解酒魔法Lv1", "时间转化Lv1", "清扫魔法", "转运魔法"
		RETURNF 2
	CASE "全恢复魔法Lv1", "解酒魔法Lv2",  "时间转化Lv2", "博识魔法", "锻炼魔法", "疲劳去除魔法", "察知之眼"
		RETURNF 3
	CASE "天气控制魔法", "全恢复魔法Lv2", "变形魔法"
		RETURNF 4
	CASE "时间转化Lv3", "隙间魔法",  "魅力魔法", "魅力魔法解除"
		RETURNF 5
ENDSELECT
RETURNF 0

;-----------------------------------------------------------
;函数作用:用于判断魔法能否使用的函数(检测是否只能对自己使用)
;-----------------------------------------------------------
@MAGIC_MASTERONLY(ARG:0)
; 魔法是否仅对自身生效
#FUNCTION
SELECTCASE ITEMNAME:(ARG:0)
	;(酒造パッチ)追加酒の調合難易度は1
	CASE "时间转化Lv1", "时间转化Lv2", "时间转化Lv3", "天气控制魔法", "魅力魔法", "魅力魔法解除", "博识魔法", "锻炼魔法", "变形魔法", "转运魔法", "察知之眼"
		RETURNF 1
	;(酒造パッチ)灰汁卷の調合難易度は2
	CASEELSE
		RETURNF 0
ENDSELECT

;-----------------------------------------------------------
;函数作用:用于判断魔法能否使用的函数(检测是否拥有)
;-----------------------------------------------------------
@MAGIC_GENERALCONDITION(ARG:0)
#FUNCTION
SIF !ITEM:(ARG:0)
	RETURNF 0
;解酒魔法Lv1
SIF ARG:0 ==957 && ITEM:957 < 2
	RETURNF 0
;清扫魔法
SIF ARG:0 ==977 && ITEM:977 < 3
	RETURNF 0
;隙间魔法
SIF ARG:0 == 979 && ITEM:979 < 2
	RETURNF 0
;转运魔法
SIF ARG:0 == 982 && ITEM:982 < 2
	RETURNF 0
;博识魔法
SIF ARG:0 == 975 && ITEM:975 < 3
	RETURNF 0
RETURNF 1

;-----------------------------------------------------------
;函数作用:用于判断魔法能否使用的函数(其他条件)
