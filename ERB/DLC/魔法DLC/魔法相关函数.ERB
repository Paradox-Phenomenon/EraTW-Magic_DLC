;-----------------------------------------------------------
;函数作用:根据法强,将ARG:0乘以ARG:1的法强次方并返回
;-----------------------------------------------------------
@魔法知识(ARG:0, ARG:1)
#FUNCTION
#DIM 回復量
#DIM 强化回数

回復量 = ARG  ; 初始化回復量为参数值
强化回数 =  M_FLAG:法强 - M_FLAG:魔法强度修正
  
WHILE 强化回数 > 0
	回復量 = TIMESF(回復量, ARG:1)
	强化回数 --
WEND
RETURNF 回復量

