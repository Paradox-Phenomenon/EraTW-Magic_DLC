			CALL CHARA_LIST_BUTTON(LOCAL, 改行用)
			改行用 = RESULT
		ENDIF
	ELSEIF !CFLAG:LOCAL:360 && LOCAL:21 == 3
		IF LOCAL:21 == 3 && TALENT:LOCAL:恋人
			CALL CHARA_LIST_BUTTON(LOCAL, 改行用)
			改行用 = RESULT
		ENDIF
	ENDIF
NEXT

; 显示返回选项
PRINTL
