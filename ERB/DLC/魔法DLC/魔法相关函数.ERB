;-----------------------------------------------------------
;函数作用:清扫魔法, 无垢使用的函数, 用于清空当前位置的所有人的污垢\精液
;-----------------------------------------------------------
@SWEEPCHARA
; 自身清洁功能
; 清除所有与当前位置相同的角色的精液和计数器
FOR LOCAL:2, 1, CHARANUM
	IF CFLAG:(LOCAL:2):現在位置 == CFLAG:MASTER:現在位置
		LOCAL:3 = EX:(LOCAL:2):膣内精液 + EX:(LOCAL:2):肛門内精液 + EX:(LOCAL:2):子宮内精液
		EX:(LOCAL:2):膣内精液 = 0
		EX:(LOCAL:2):肛門内精液 = 0
		EX:(LOCAL:2):子宮内精液 = 0
		CFLAG:(LOCAL:2):膣内精液 = 0
		CFLAG:(LOCAL:2):子宮内精子 = 0
		CFLAG:(LOCAL:2):脸上精液 = 0
		CFLAG:(LOCAL:2):手上精液 = 0
		CFLAG:(LOCAL:2):口内精液 = 0
		CFLAG:(LOCAL:2):膣内射精 = 0
		CFLAG:(LOCAL:2):肛門射精 = 0
		; 清除特定于射精者的计数器
		FOR LOCAL:0,0,CHARANUM
			CFLAG:(LOCAL:2):(LOCAL:0 + 2000) = 0
			CFLAG:(LOCAL:2):(LOCAL:0 + 3000) = 0
		NEXT
		; 清除身体各部位的污垢
		STAIN:(LOCAL:2):"口" = 0
		STAIN:(LOCAL:2):"手" = 0
		STAIN:(LOCAL:2):"Ｐ" = 0
		STAIN:(LOCAL:2):"Ｖ" = 0
		STAIN:(LOCAL:2):"Ａ" = 0
		STAIN:(LOCAL:2):"Ｂ" = 0
		STAIN:(LOCAL:2):"膣内" = 0
		STAIN:(LOCAL:2):"腸内" = 0
		CALL RECOVER(LOCAL:2, LOCAL:3 * ITEM:977 / 3, "体力", "从精液获得的滋养")
		CALL RECOVER(LOCAL:2, LOCAL:3 * ITEM:977 / 3, "気力", "从精液获得的滋养")
	ENDIF
NEXT
; 清除各种精液和相关计数器
LOCAL:1 += EX:MASTER:膣内精液 + EX:MASTER:肛門内精液 + EX:MASTER:子宮内精液
EX:MASTER:膣内精液 = 0
EX:MASTER:肛門内精液 = 0
EX:MASTER:子宮内精液 = 0
CFLAG:MASTER:膣内精液 = 0
CFLAG:MASTER:子宮内精子 = 0
CFLAG:MASTER:脸上精液 = 0
CFLAG:MASTER:手上精液 = 0
CFLAG:MASTER:口内精液 = 0
CFLAG:MASTER:膣内射精 = 0
CFLAG:MASTER:肛門射精 = 0
TFLAG:接吻マーク = 0

FOR LOCAL:0,0,CHARANUM
	CFLAG:MASTER:(LOCAL:0 + 2000) = 0
	CFLAG:MASTER:(LOCAL:0 + 3000) = 0
NEXT

; 清除身体各部位的污垢
STAIN:MASTER:"口" = 0
STAIN:MASTER:"手" = 0
STAIN:MASTER:"Ｐ" = 0
STAIN:MASTER:"Ｖ" = 0
STAIN:MASTER:"Ａ" = 0
STAIN:MASTER:"Ｂ" = 0
STAIN:MASTER:"膣内" = 0
STAIN:MASTER:"腸内" = 0

;-----------------------------------------------------------
;函数作用:变形魔法打印函数
;-----------------------------------------------------------
@TRANSFORM_MAGIC(ARG)
CALL RELINE(3)
CALL RELINE(3,1)
VARSET LOCAL
PRINTL
PRINTL
FOR LOCAL, 0, 157
	IF TRANSFORM_不能选的素质(LOCAL, ARG) == 1
		CONTINUE
	ELSEIF TRANSFORM_不能选的素质(LOCAL, ARG) == 2
		;表示はさせる
		SETCOLOR 50, 50, 50
		LOCALS = [{LOCAL,3}]%TALENT_TR(LOCAL)%
		GOTO SKIP
	ENDIF
	SETCOLOR 150, 150, 150
	SELECTCASE TALENTNAME:LOCAL
	;TALENT.CSVに登録されていない
	CASE ""
		CONTINUE
	;オンオフ型の素質(TALENTNAMEと素質表示が一致)
	CASE GET_TALENTNAME(LOCAL,1)
		SIF TALENT:ARG:LOCAL
			SETCOLOR C_AQUA
		LOCALS = [{LOCAL,3}]%TALENT_TR(LOCAL)%
	;量的素質
	CASEELSE
		LOCALS =  [{LOCAL,3}]%TALENT_TR(LOCAL)%
		IF STRLENS(GET_TALENTNAME(LOCAL, TALENT:ARG:LOCAL))
			LOCALS:1 = 【%GET_TALENTNAME(LOCAL, TALENT:ARG:LOCAL)%】
			SETCOLOR C_AQUA
		ELSEIF TALENTNAME:LOCAL == "性別"
			LOCALS:1 = 【女性】
			SETCOLOR C_AQUA
		ELSE
			LOCALS:1 = 【－】
		ENDIF
		LOCALS += LOCALS:1
	ENDSELECT
	$SKIP
	IF LOCAL:1 % 3 == 0
		PRINTL 
		PRINT   
	ENDIF
	IF TRANSFORM_不能选的素质(LOCAL, ARG) == 2
		PRINTPLAINFORM %LOCALS, 40, LEFT%
	ELSE
		PRINTFORM %LOCALS, 40, LEFT%
	ENDIF
	LOCAL:1 ++
NEXT
RESETCOLOR
PRINTL
PRINTL
PRINTL   [9999] 返回
PRINTL
INPUT
SIF RESULT == 9999
	RETURN
CALLFORM TRANSFORM_TALENT(RESULT, ARG)
RESTART

;-----------------------------------------------------------
;函数作用:变形魔法调整素质参数的函数
;-----------------------------------------------------------
@TRANSFORM_TALENT(inputed, chara)
#DIM inputed
#DIM chara
SIF inputed < 0|| inputed > 500
	RETURN 0
SIF TALENTNAME:inputed == ""
	RETURN 0
SIF TRANSFORM_不能选的素质(inputed, chara)
	RETURN 0
SELECTCASE TALENTNAME:inputed
	;先に例外処理
	CASE "性別"
		IF TALENT:chara:性別 == 3
			TALENT:chara:性別 = 1
		ELSE
			TALENT:chara:性別 ++
		ENDIF
	CASE "性別嗜好"
		IF TALENT:chara:inputed == 3
			TALENT:chara:inputed = -1
		ELSE
			TALENT:chara:inputed ++
		ENDIF
	CASE "性別嗜好"
		;体型が「小人(-5)」と「巨人(3)」の場合を独立処理
		IF TALENT:chara:inputed == -5
			TALENT:chara:inputed = -2
		ELSEIF TALENT:chara:inputed == 5
			TALENT:chara:inputed = -5
		ELSEIF TALENT:chara:inputed == 2
			TALENT:chara:inputed = 5
		ELSE
			TALENT:chara:inputed ++
		ENDIF
	CASE "非童貞", "キス未経験"
		TALENT:chara:inputed = !TALENT:chara:inputed
	CASE "母乳体質"
		TALENT:chara:母乳体質 = !TALENT:chara:母乳体質
		IF TALENT:chara:母乳体質
			MAXBASE:chara:母乳 = 2000
		ELSE
			MAXBASE:chara:母乳 = 0
		ENDIF
	;汎用処理
	CASE "魅力"
		TALENT:chara:inputed = !TALENT:chara:inputed
		M_CFLAG:chara:变形魔法_魅力 = !M_CFLAG:chara:变形魔法_魅力
	CASE "謎之魅力"
		TALENT:chara:inputed = !TALENT:chara:inputed
		M_CFLAG:chara:变形魔法_谜之魅力 = !M_CFLAG:chara:变形魔法_谜之魅力
	CASE "魅惑"
		TALENT:chara:inputed = !TALENT:chara:inputed
		M_CFLAG:chara:变形魔法_魅惑 = !M_CFLAG:chara:变形魔法_魅惑
	CASE "酒耐性" ;(-2~3)
		IF TALENT:chara:inputed < 3 
			TALENT:chara:inputed ++
		ELSE
			TALENT:chara:inputed = -2
		ENDIF
	CASEELSE
		;真偽型の素質は反転
		IF NAME_TR(TALENTNAME:inputed) == GET_TALENTNAME(inputed,1)
			TALENT:chara:inputed = !TALENT:chara:inputed
		ELSE
		;他は端まで行くと-1を掛ける
			IF STRLENS(GET_TALENTNAME(inputed,TALENT:chara:inputed + 1)) || TALENT:chara:inputed == -1
				TALENT:chara:inputed ++
			ELSE
				TALENT:chara:inputed *= -1
				SIF !STRLENS(GET_TALENTNAME(inputed, TALENT:chara:inputed))
					TALENT:chara:inputed ++
			ENDIF
		ENDIF
ENDSELECT

;-----------------------------------------------------------
;函数作用:变形魔法决定无法选择的素质的函数
;-----------------------------------------------------------
@TRANSFORM_不能选的素质(ARG, CHARA)
#FUNCTION
#DIM CHARA
IF GROUPMATCH(ARG,100,103,106,108,121,145,146,163,164,92,94) || INRANGE(ARG,130,139) || INRANGE(ARG,169,173)
	RETURNF 0
ELSEIF (!GETBIT(TALENT:CHARA:性別, 1) && ARG == 152)
	RETURNF 2
ELSEIF (!GETBIT(TALENT:CHARA:性別, 0) && GROUPMATCH(ARG,149,101,102,104,105,142))
	RETURNF 2
ELSEIF INRANGE(ARG,0,99) || GROUPMATCH(ARG,105,108)
	RETURNF 1
ELSE
	SELECTCASE ARG
		;劣情察知～,BOUNS素質および特殊陥落,種族,孕ませ系
		CASE IS >=157
			RETURNF 1
		;你は選べない１
		CASE GETNUM(TALENT, "習得速度") TO GETNUM(TALENT, "擅長用針"), GETNUM(TALENT, "薬毒耐性"), GETNUM(TALENT, "容易高潮"), GETNUM(TALENT, "盲信"), GETNUM(TALENT, "小悪魔")
			SIF CHARA == NO:MASTER
				RETURNF 1
		;你は選べない２
		CASE GETNUM(TALENT, "魅力") TO GETNUM(TALENT, "謎之魅力"), GETNUM(TALENT, "回復速度") TO GETNUM(TALENT, "不可思議的根"), GETNUM(TALENT, "狂気"), GETNUM(TALENT, "人気")
			SIF CHARA == NO:MASTER
				RETURNF 1
		;你は選べず、女性器がないと選べない
		CASE GETNUM(TALENT, "母乳体質"), GETNUM(TALENT, "妊娠願望") 
			SIF CHARA == NO:MASTER
				RETURNF 1
			SIF !GETBIT(TALENT:CHARA:性別, 0)
				RETURNF 2
		;女性器がないと選べない
		CASE GETNUM(TALENT, "処女"), GETNUM(TALENT, "風騷"), GETNUM(TALENT, "Ｖ感度")
			SIF !GETBIT(TALENT:CHARA:性別, 0)
				RETURNF 2
		;男性器がないと選べない
		CASE GETNUM(TALENT, "非童貞")
			SIF !GETBIT(TALENT:CHARA:性別, 1)
				RETURNF 2
		;男性器があると選べない
		CASE GETNUM(TALENT, "具現")
			SIF GETBIT(TALENT:CHARA:性別, 1)
				RETURNF 2
		;你以外は選べない
		CASE GETNUM(TALENT, "年齢")
			SIF CHARA != NO:MASTER
				RETURNF 1
		;全員選べないが表示はする
		CASE GETNUM(TALENT, "キス未経験")
			RETURNF 2
		;全員選べない１
		CASE GETNUM(TALENT, "恋慕") TO GETNUM(TALENT, "思慕"), GETNUM(TALENT, "心情"), GETNUM(TALENT, "容姿"), GETNUM(TALENT, "把柄"), GETNUM(TALENT, "調合知識"), GETNUM(TALENT, "調合Lv"), GETNUM(TALENT, "採集Lv"), GETNUM(TALENT, "釣魚Lv"), GETNUM(TALENT, "伐採Lv")
			RETURNF 1
		;全員選べない２
		CASE GETNUM(TALENT, "自慰狂") TO GETNUM(TALENT, "子宮口性感"), GETNUM(TALENT, "迷信"), GETNUM(TALENT, "嫉妬"), GETNUM(TALENT, "濃厚精液"), GETNUM(TALENT, "精愛味覚"), GETNUM(TALENT, "禁断的知識"), GETNUM(TALENT, "精力超群") TO GETNUM(TALENT, "母性")
			RETURNF 1
		;女性器があって幼児か幼稚がないと選べない
		CASE GETNUM(TALENT, "初潮")
			SIF !GETBIT(TALENT:CHARA:性別, 0)
				RETURNF 2
			SIF !TALENT:CHARA:幼児／幼児退行 && !TALENT:CHARA:幼稚
				RETURNF 2
	ENDSELECT
ENDIF
RETURNF 0

;-----------------------------------------------------------
