;-----------------------------------------------------------
;函数作用:把角色拉进隙间待客室的函数, 具体实施拉人行为与数据变更
;-----------------------------------------------------------
@OMANEKIBEYA_GAP(ARG)
M_CFLAG:MASTER:初期记录 = CFLAG:MASTER:初期位置
;错误初期记录回正
IF M_CFLAG:MASTER:初期记录 == OMANEKIBEYA()
	TRYCALLFORM DEFAULT_OWNER_{MAIN_MAP}
	PRINTFORML 警告: 角色的初期记录错误（{OMANEKIBEYA()}）, 已回正为默认初期记录{默认初期位置}
	M_CFLAG:MASTER:初期记录 = 默认初期位置
ENDIF
SIF ARG
	M_CFLAG:ARG:初期记录 = CFLAG:ARG:初期位置
IF CFLAG:MASTER:現在位置 != OMANEKIBEYA()
	M_FLAG:隙间标记 = CFLAG:MASTER:現在位置
ELSEIF !M_FLAG:隙间标记
	M_FLAG:隙间标记 = M_CFLAG:MASTER:初期记录
ENDIF
IF ARG == MASTER
	; 将所有同行角色带入待客室
	; 遍历所有角色，查找同行的角色
	FOR LOCAL, 1, CHARANUM
		; 检查角色是否处于同行状态
		IF CFLAG:LOCAL:同行 || (CFLAG:MASTER:诶嘿嘿 && CFLAG:LOCAL:現在位置 == CFLAG:MASTER:現在位置 && (!FLAG:潜伏 || CFLAG:LOCAL:潜伏状態 == 1))
			; 设置同行角色的位置
			M_CFLAG:LOCAL:初期记录 = CFLAG:LOCAL:初期位置
			CFLAG:LOCAL:初期位置 = OMANEKIBEYA()
			CFLAG:LOCAL:現在位置 = OMANEKIBEYA()
		ENDIF
	NEXT
	; 处理MASTER
	IF TFLAG:運搬
		M_CFLAG:(TFLAG:運搬):初期记录 = CFLAG:(TFLAG:運搬):初期位置
		CFLAG:(TFLAG:運搬):初期位置 = OMANEKIBEYA()
		CFLAG:(TFLAG:運搬):現在位置 = OMANEKIBEYA()
	ENDIF
ELSE
	CFLAG:ARG:初期位置 = OMANEKIBEYA()
	CFLAG:ARG:現在位置 = OMANEKIBEYA()
ENDIF
CFLAG:MASTER:初期位置 = OMANEKIBEYA()
CFLAG:MASTER:現在位置 = OMANEKIBEYA()
; 设置MASTER的待客室污垢
YOGORE:(OMANEKIBEYA()) = 0

;-----------------------------------------------------------
;函数作用:隙间角色标记相关, 用于打印每个角色名
;-----------------------------------------------------------
@CHARA_LIST_BUTTON(ARG,改行用)
#DIMS 角色名
#DIM 改行用
#DIM 角色ID

角色ID = ARG
; 计算并处理换行逻辑
角色名 = %NAME:角色ID, 30, LEFT%
改行用 += STRLENS(角色名)
SIF 角色ID < 10
	改行用 += 3
SIF 角色ID < 100
	改行用 ++
IF 改行用 > 145
	IF 改行用 >= 999
	;最初のみ改行しない
	ELSE
		PRINTL 
	ENDIF
	改行用 = STRLENS(角色名)
	SIF 角色ID < 100
		改行用 ++
	PRINT 　　
ENDIF
; 根据角色的恋慕状态设置不同颜色
IF  !M_FLAG:标记合意
	IF TALENT:角色ID:炮友 == 1
		; 炮友为番茄红
		SETCOLOR 0x7CFC00
	ELSEIF TALENT:角色ID:炮友 > 1
		SETCOLOR 0x2E8B57
	ENDIF
	SIF TALENT:角色ID:思慕 == 1
		; 思慕为粉色
		SETCOLOR C_PINK
	SIF TALENT:角色ID:恋慕 == 1 && !TALENT:角色ID:恋人
		; 恋人为红色
		SETCOLOR 0xEE60EE
	SIF TALENT:角色ID:恋人
		SETCOLOR C_RED
ELSE
	SIF GETBIT(CFLAG:角色ID:既成事實, 1)
		SETCOLOR C_AQUA
	SIF CFLAG:角色ID:允许无套
		SETCOLOR C_PINK
ENDIF
SIF CFLAG:角色ID:睡眠 && M_FLAG:标记睡眠
	SETCOLOR C_BLUE
SIF M_CFLAG:角色ID:手动标记
	SETCOLOR C_GREEN
; 打印角色名称并添加序号标识
IF CFLAG:角色ID:現在位置 != OMANEKIBEYA() || M_FLAG:标记手动
	PRINTFORM [{角色ID,3}] %角色名%
ELSE
	PRINTPLAINFORM [{角色ID,3}] %角色名%
ENDIF
PRINT 　　
; 重置颜色
RESETCOLOR
RETURN 改行用


