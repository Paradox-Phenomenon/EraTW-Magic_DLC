@Show_Setting
CALL RELINE(1,1)
$LOOP
CALL RELINE(1)
PRINTL
SELECTCASE Setting_五重绝顶
	CASE 0
		LOCALS =  五重绝顶:原版
	CASE 1
		LOCALS =  五重绝顶:总是可用
	CASE 2
		LOCALS =  五重绝顶:逆推时可用
ENDSELECT
CALL PRINTBUTTON_EX(@"[%LOCALS%]", 1, !Setting_五重绝顶)
PRINTL
SELECTCASE Setting_满足终了
	CASE 0
		LOCALS =  逆推满足终了:原版
	CASE 1
		LOCALS =  逆推满足终了:禁止
	CASE 2
		LOCALS =  逆推满足终了:总是
ENDSELECT
CALL PRINTBUTTON_EX(@"[%LOCALS%]", 2, !Setting_满足终了)
PRINTL
SELECTCASE Setting_主动权转移禁止
	CASE 0
		LOCALS =  诶嘿嘿主动权转移:允许
	CASE 1
		LOCALS =  诶嘿嘿主动权转移:禁止
ENDSELECT
CALL PRINTBUTTON_EX(@"[%LOCALS%]", 3, Setting_主动权转移禁止)
PRINTL
SIF !GMF_GETBIT("幻想乡大地图")
	Setting_外出时可以带出去 = 0
SELECTCASE Setting_外出时可以带出去
	CASE 0
		LOCALS =  外出时可以带出去:禁止（需要开启幻想乡大地图）
	CASE 1
		LOCALS =  外出时可以带出去:允许（需要开启幻想乡大地图）
ENDSELECT
CALL PRINTBUTTON_EX(@"[%LOCALS%]", 4, !Setting_外出时可以带出去)
PRINTL
CALL PRINTBUTTON_EX("[确认]", 999)
INPUT
IF RESULT == 1
	IF Setting_五重绝顶 < 2
		Setting_五重绝顶 ++
	ELSE
		Setting_五重绝顶 = 0
	ENDIF
ELSEIF RESULT == 2
	IF Setting_满足终了 < 2
		Setting_满足终了 ++
	ELSE
		Setting_满足终了 = 0
	ENDIF
ELSEIF RESULT == 3
	Setting_主动权转移禁止 = !Setting_主动权转移禁止
ELSEIF RESULT == 4 && GMF_GETBIT("幻想乡大地图")
	Setting_外出时可以带出去 = !Setting_外出时可以带出去
ELSEIF RESULT == 999
	RETURN 
ENDIF
GOTO LOOP


@MP_RECOVERY(ARG,ARG:1,Efficiency = 100)
#DIM Efficiency
SIF BASE:ARG:法力 <= 0 && Efficiency > 0
	RETURN
IF ARG:1 <= BASE:ARG:法力 * Efficiency / 100
	CALL RECOVER(ARG, -ARG:1, "法力")
	CALL RECOVER(ARG, ARG:1, "体力")
	CALL RECOVER(ARG, ARG:1, "気力")
ELSE
	CALL RECOVER(ARG, -BASE:ARG:法力 * Efficiency / 100, "法力")
	CALL RECOVER(ARG, BASE:ARG:法力 * Efficiency / 100, "体力")
	CALL RECOVER(ARG, BASE:ARG:法力 * Efficiency / 100, "気力")
ENDIF

@GAP_TRAVEL
#DIM ANIMATION_SEED
#DIM 目的地MAPID
#DIM 現在地MAPID
#DIM 隙间位置
ANIMATION_SEED = 0
SIF ANIMATERECOLOREDMAPS && !FLAG:70
	ANIMATION_SEED ++
CALL DRAW_COLOREDMAP(ANIMATION_SEED, "GLOBAL")
PRINTL 要去哪里呢？
現在地MAPID = GET_MAPID(CFLAG:MASTER:現在位置)
FOR 目的地MAPID, 0, MAXHOME
	SIF !GET_EXISTMAP(目的地MAPID)
		CONTINUE
	IF 目的地MAPID == 現在地MAPID
		PRINTPLAINFORM [{目的地MAPID, 3}] - %GET_MAPNAME(目的地MAPID), 18, LEFT%
		CALL COLORMESSAGE(@"　现在地　　", C_GREEN, 3)
	ELSE
		PRINTFORM [{目的地MAPID, 3}] - %GET_MAPNAME(目的地MAPID), 30, LEFT%
	ENDIF
	SIF 目的地MAPID % 2 == 1
		PRINTL
NEXT
PRINT [100] - 返回
INPUT
目的地MAPID = RESULT
隙间位置 = 98 + 目的地MAPID * 100
IF 目的地MAPID == 100
	RETURN
ELSEIF INRANGE(目的地MAPID, 0, MAXHOME)
	;切换地图
	CALL QUICK_SWITCH_MAP(目的地MAPID, 1)
	;隙间的出口设置为目的地的entrance
	M_FLAG:隙间标记 = RESULT
	FOR LOCAL, 0, CHARANUM
		;通过初期记录的有无判断其是否应该处于隙间待客室
		IF M_CFLAG:LOCAL:初期记录
			CFLAG:LOCAL:現在位置 = 隙间位置
			CFLAG:LOCAL:初期位置 = 隙间位置
		ENDIF
	NEXT
ENDIF