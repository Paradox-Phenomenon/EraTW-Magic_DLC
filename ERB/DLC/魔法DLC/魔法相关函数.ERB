;-----------------------------------------------------------
;函数作用:根据当前魅力魔法, 提取倍数因子的函数
;-----------------------------------------------------------
@MAGIC_CharmFactor(ARG)
#FUNCTION
SIF !MAGIC_DLC
	RETURNF 0
SELECTCASE ARG
	CASE 0
		RETURNF M_TFLAG:魅力魔法
	CASE 1
		RETURNF SQRT(M_TFLAG:魅力魔法)
	CASE 2
		RETURNF SQRT(SQRT(M_TFLAG:魅力魔法))
	CASE 3
		RETURNF MAX(LOG10(M_TFLAG:魅力魔法), 1)
	CASE 4
		RETURNF 1 + SQRT(SQRT(M_TFLAG:魅力魔法)) / 5
ENDSELECT

;-----------------------------------------------------------
;函数作用:判断与角色恋慕程度的函数, 在获取魔法奖励exp中被调用, 也在魅力魔法提高积攒度时被调用
;-----------------------------------------------------------
@MAGIC_LoveFactor(ARG,ARG:1 = 1)
#FUNCTION
LOCAL = 3
SIF CFLAG:ARG:清い交際
	LOCAL += 2
SIF TALENT:ARG:恋人
	LOCAL += 3
SIF TALENT:ARG:恋慕
	LOCAL += 3
SIF TALENT:ARG:思慕
	LOCAL += 1
SIF TALENT:ARG:愛欲
	LOCAL += 1
SIF TALENT:一線越えない
	LOCAL += 3*TALENT:ARG:恋慕 - 1
SIF CFLAG:ARG:2 >= 1000000
	LOCAL += 3
LOCAL -= MARK:ARG:反発刻印 * 2
LOCAL = MAX(LOCAL, 0)
LOCAL:1 = MAX(ABL:ARG:欲望+ABL:ARG:親密, 10)

IF !MAGIC_DLC_好感亲密重做
	RETURNF 0
ELSE
	RETURNF SQRT(LOCAL:1*10) * LOCAL * ARG:1 / 30
ENDIF

;-----------------------------------------------------------
;函数作用:时间因子的函数, 可以根据时间因子类型和时间因子值来计算经过时间
;该版本已经废弃
;-----------------------------------------------------------
@MAGIC_TimeFactor(ARG,ARGS = "")
#FUNCTION
SIF !MAGIC_DLC
	RETURNF ARG

IF GETBIT(MAGIC_DLC_时间因子,1)
	IF ARGS == ""
		LOCAL = 100 - 8*TALENT:MASTER:神性
	ELSE
		LOCAL = 100 - 6*TALENT:MASTER:神性
	ENDIF
ENDIF

SIF ARGS == "教养" && !GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (10-ABL:MASTER:教養)/10
SIF ARGS == "话术" && !GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (10-ABL:MASTER:話術技能)/10
SIF ARGS == "清扫" && !GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (15-ABL:MASTER:清掃技能)/15
SIF ARGS == "料理" && !GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (15-ABL:MASTER:料理技能)/15
SIF ARGS == "音乐" && !GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (10-ABL:MASTER:音楽技能)/10
SIF ARGS == "战斗" && !GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (10-ABL:MASTER:戦闘能力)/10
SIF ARGS == "技巧" && !GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (25-ABL:MASTER:技巧)/25


SIF ARGS == "采集" && !GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (12-TALENT:MASTER:採集Lv)/12
SIF ARGS == "调合" && !GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (15-TALENT:MASTER:調合Lv-TALENT:MASTER:調合知識*3-TALENT:MASTER:禁断的知識*2)/15
SIF ARGS == "钓鱼" && !GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (10-TALENT:MASTER:釣りLv)/10
SIF ARGS == "采伐" && !GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (10-TALENT:MASTER:伐採Lv)/10

SIF ARGS == "学习" && !GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (10-ABL:MASTER:教養) * (2-TALENT:MASTER:習得速度) /20

SIF ARGS == "泡茶" && !GETBIT(MAGIC_DLC_时间因子,0)
	LOCAL = LOCAL * (30 - ABL:MASTER:教養 - TALENT:MASTER:調合Lv - ABL:MASTER:TSLv)/30
SIF ARGS == "TSLv" && !GETBIT(MAGIC_DLC_时间因子,1)
	LOCAL = LOCAL * (10-ABL:MASTER:TSLv)/10
RETURNF MAX(ARG * LOCAL / 100, 3)

;-----------------------------------------------------------
;函数作用:时间因子的函数, 可以根据时间因子类型和时间因子值来计算经过时间
;-----------------------------------------------------------
@MAGIC_TimeFactor2(ARG)
#FUNCTION
SIF !MAGIC_DLC || M_TFLAG:时间因子类型 == TimeFactor_无加速
	RETURNF ARG

IF GETBIT(MAGIC_DLC_时间因子,1)
	IF M_TFLAG:时间因子类型 == 0
		LOCAL = (100 - 8*(TALENT:MASTER:神性 - 神性时间影响削弱)) * ARG / 100
	ELSEIF M_TFLAG:时间因子类型 == TimeFactor_TSLv
		LOCAL = ARG * (10 - ABL:MASTER:TSLv + 神性时间影响削弱) / 10
		RETURNF LOCAL
	ELSE
		LOCAL = (100 - 6*(TALENT:MASTER:神性 - 神性时间影响削弱)) * ARG / 100
	ENDIF
ELSE
	LOCAL = ARG
ENDIF

SIF M_TFLAG:时间因子类型 == TimeFactor_教养 && GETBIT(MAGIC_DLC_时间因子,0)
