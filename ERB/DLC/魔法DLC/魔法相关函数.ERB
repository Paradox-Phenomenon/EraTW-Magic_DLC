	RESETCOLOR
	SETCOLOR 0xEE60EE
	PRINTFORM 恋慕/
	RESETCOLOR
	SETCOLOR C_PINK
	PRINTFORM 思慕/
	RESETCOLOR
	SETCOLOR 0x7CFC00
	PRINTFORM 炮友/
	RESETCOLOR
	SETCOLOR 0x2E8B57
	PRINTFORM 爱欲/
