;-----------------------------------------------------------
;函数作用:用于确定魔法奖励EXP类型, 0为清扫, 1为学习, 2为调合, ARG应该为M_CFLAG:TARGET:魔法奖励EXP
;-----------------------------------------------------------
@GET_MAGIC_EXP_BIT(ARG, BIT_TYPE)
#FUNCTION
#DIM BIT_TYPE
LOCAL:1 = ARG
WHILE BIT_TYPE > 0
	BIT_TYPE --
	LOCAL:1 = LOCAL:1 / 100
WEND
RETURNF (LOCAL:1 % 100)

;-----------------------------------------------------------
;函数作用:开始游戏时, 对每个角色, 改变其战斗能力, 清掃技能, 教養, 戦闘能力, 清掃経験, 学習経験, 戦闘経験
;由于之前出过bug(导致所有角色经验等级多了一级), 新增了一部分修复之前bug的代码
;-----------------------------------------------------------
@LEVEL_RESET()
SIF !MAGIC_DLC_等级重置
	RETURN 0
IF !LEVEL_RESETED
	FOR LOCAL, 0,CHARANUM
		IF GROUPMATCH(LOCAL,1,23,31,52,103)
			ABL:LOCAL:清掃技能 = 4
		ENDIF
		IF GROUPMATCH(LOCAL,2,15,159)
			ABL:LOCAL:清掃技能 = 5
		ENDIF
		IF GROUPMATCH(LOCAL,26,99)
			ABL:LOCAL:教養 = 6
		ENDIF
		SIF LOCAL == 67
			ABL:LOCAL:教養 = 5
		SIF LOCAL == 72
			ABL:LOCAL:教養 = 7
		SIF LOCAL == 113
			ABL:LOCAL:戦闘能力 = 7
		EXP:LOCAL:清掃経験 = EXPLV:(2+ABL:LOCAL:清掃技能)
		EXP:LOCAL:学習経験 = EXPLV:(2+ABL:LOCAL:教養)
		EXP:LOCAL:戦闘経験 = EXPLV:(2+ABL:LOCAL:戦闘能力)
	NEXT
	LEVEL_RESETED = 2
;解决先前bug受害者的问题
ELSEIF LEVEL_RESETED == 1
	FOR LOCAL, 0,CHARANUM
		LOCAL:2 = 0
		LOCAL:3 = 0
		LOCAL:4 = 0
		FOR LOCAL:1,2,12
			IF EXP:LOCAL:清掃経験 < EXPLV:(LOCAL:1) && !LOCAL:2
				EXP:LOCAL:清掃経験 = EXPLV:(LOCAL:1 - 2)
				ABL:LOCAL:清掃技能 = LOCAL:1 - 4
				LOCAL:2 ++
			ENDIF
			IF EXP:LOCAL:学習経験 < EXPLV:(LOCAL:1) && !LOCAL:3
				EXP:LOCAL:学習経験 = EXPLV:(LOCAL:1 - 2)
				ABL:LOCAL:教養 = LOCAL:1 - 4
				LOCAL:3 ++
			ENDIF
			IF EXP:LOCAL:戦闘経験 < EXPLV:(LOCAL:1) && !LOCAL:4
				EXP:LOCAL:戦闘経験 = EXPLV:(LOCAL:1 - 2)
				ABL:LOCAL:戦闘能力 = LOCAL:1 - 4
				LOCAL:4 ++
			ENDIF
		NEXT
	NEXT
	LEVEL_RESETED = 2
ENDIF
RETURN 1

;-----------------------------------------------------------
;函数作用:开始游戏时, 对每个角色, 依据其种族与战斗能力确定其法力值上限
;ARG为角色ID时, 重置该角色法力值
;-----------------------------------------------------------
@MP_RESET(ARG = 0)
SIF !MAGIC_DLC
	RETURN 0
IF ARG == 0
	FOR LOCAL ,0,CHARANUM
		LOCAL:1 = ABL:LOCAL:戦闘能力 * 500
		IF GROUPMATCH(TALENT:LOCAL:追加種族,1,2)
			LOCAL:1 += 500
			TIMES LOCAL:1, 1.6
		ELSEIF TALENT:LOCAL:追加種族 != 4 && GROUPMATCH(TALENT:LOCAL:人类,1,6)
			TIMES LOCAL:1, 0.8
		ENDIF
		IF GROUPMATCH(TALENT:LOCAL:人类,2,3,4)
			LOCAL:1 += 500
			TIMES LOCAL:1, 1.2
		ENDIF
		SIF TALENT:LOCAL:妖怪 || TALENT:LOCAL:付喪神
			TIMES LOCAL:1, 1.3
		SIF TALENT:LOCAL:妖精
			TIMES LOCAL:1, 0.9
		SIF TALENT:LOCAL:神霊
			TIMES LOCAL:1, 2.0
		SIF TALENT:LOCAL:幽霊
			TIMES LOCAL:1, 0.8
		SIF TALENT:LOCAL:人形 && !GROUPMATCH(TALENT:LOCAL:追加種族,1,2)
			TIMES LOCAL:1, 0.4
		IF !TALENT:LOCAL:高难开局
			LOCAL:1 += RANDSF(5, 20)
		ELSE
			LOCAL:1 = 0
		ENDIF
		MAXBASE:LOCAL:法力 = LOCAL:1
		BASE:LOCAL:法力 = LOCAL:1
		BUFF:LOCAL:7 = 0
	NEXT
	MP_RESETED = 1
ELSE
	LOCAL:1 = ABL:ARG:戦闘能力 * 500
	IF GROUPMATCH(TALENT:ARG:追加種族,1,2)
		LOCAL:1 += 500
		TIMES LOCAL:1, 1.6
	ELSEIF TALENT:ARG:追加種族 != 4 && GROUPMATCH(TALENT:ARG:人类,1,6)
		TIMES LOCAL:1, 0.8
	ENDIF
	IF GROUPMATCH(TALENT:ARG:人类,2,3,4)
		LOCAL:1 += 500
		TIMES LOCAL:1, 1.2
	ENDIF
	SIF TALENT:ARG:妖怪 || TALENT:ARG:付喪神
		TIMES LOCAL:1, 1.3
	SIF TALENT:ARG:妖精
		TIMES LOCAL:1, 0.9
	SIF TALENT:ARG:神霊
		TIMES LOCAL:1, 2.0
	SIF TALENT:ARG:幽霊
		TIMES LOCAL:1, 0.8
	SIF TALENT:ARG:人形 && !GROUPMATCH(TALENT:ARG:追加種族,1,2)
		TIMES LOCAL:1, 0.4
	IF !TALENT:ARG:高难开局
		LOCAL:1 += RANDSF(5, 20)
	ELSE
		LOCAL:1 = 0
	ENDIF
	MAXBASE:ARG:法力 = LOCAL:1
	BASE:ARG:法力 = LOCAL:1
	BUFF:ARG:7 = 0
ENDIF
RETURN

;-----------------------------------------------------------
;函数作用:角色提高战斗能力时, 根据种族特征返回对应的因子, 以确定提高法力值上限的数值
;-----------------------------------------------------------
@MP_FACTOR(ARG)
#FUNCTION
SIF ARG == MASTER && TALENT:MASTER:高难开局
	RETURNF 0
IF GROUPMATCH(TALENT:ARG:追加種族,1,2)
	RETURNF 160
ELSEIF TALENT:ARG:追加種族 != 4 && GROUPMATCH(TALENT:ARG:人类,1,6)
	RETURNF 80
ENDIF
SIF GROUPMATCH(TALENT:ARG:人类,2,3,4)
	RETURNF 120
SIF TALENT:ARG:妖怪 || TALENT:ARG:付喪神
	RETURNF 130
SIF TALENT:ARG:妖精
	RETURNF 90
SIF TALENT:ARG:神霊
	RETURNF 200
SIF TALENT:ARG:幽霊
	RETURNF 80
SIF TALENT:ARG:人形 && !GROUPMATCH(TALENT:ARG:追加種族,1,2)
	RETURNF 40
RETURNF 100	

