IF M_FLAG:标记手动
	PRINTPLAINFORM 当前：手动标记模式   
	PRINTFORM [994] 清空标记
	PRINTL
ELSE
	PRINTL
ENDIF
SIF LOCAL:21 == 0
	PRINTL 当前：显示所有角色
SIF LOCAL:21 == 1
	PRINTL 当前：显示思慕以上情感的角色
SIF LOCAL:21 == 2
	PRINTL 当前：显示恋慕与恋人
SIF LOCAL:21 == 3
	PRINTL 当前：仅显示恋人
DRAWLINE
PRINTFORM [999] 返回   [998] 切换睡眠标记   [997] 切换感情显示   [996] 切换合意标记   
IF M_FLAG:隙间标记
	PRINTFORM [995] 手动标记
ELSE
	SETCOLOR 0x606060
	PRINTPLAINFORM [995] 手动标记
	RESETCOLOR
ENDIF
PRINTL
; 获取用户选择
INPUT 

; 处理用户选择
SELECTCASE RESULT
	CASE 999
		; 返回
		RETURN 0
	CASE 998
		; 切换睡眠标记
		M_FLAG:标记睡眠 = !M_FLAG:标记睡眠
		GOTO LOOP1
	CASE 997
		IF LOCAL:21 == 3
			LOCAL:21 = 0
		ELSE
			LOCAL:21 ++
		ENDIF
		GOTO LOOP1
	CASE 996
		; 切换合意标记
		M_FLAG:标记合意 = !M_FLAG:标记合意
		GOTO LOOP1
	CASE 995
		; 切换手动标记
		M_FLAG:标记手动 = !M_FLAG:标记手动
		GOTO LOOP1
	CASE 994
		FOR LOCAL, 1, CHARANUM - 1
			M_CFLAG:LOCAL:手动标记 = 0
		NEXT
		GOTO LOOP1
	CASEELSE
		; 检查选择是否有效（1到CHARANUM-1之间）
		IF RESULT >= 1 && RESULT <= CHARANUM - 1
			; 调用OMANEKIBEYA_GAP函数带选中角色
			CHARA = RESULT
			IF !M_FLAG:标记手动
				IF GAP_ABLE(CHARA) >= 2
					CALL OMANEKIBEYA_GAP(CHARA)
					PRINTFORML %CALLNAME:(CHARA)%很高兴地答应了你的邀请，来到了隙间待客室。
					CALL RECOVER(MASTER, -300, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
				ELSEIF GAP_ABLE(CHARA) == 1
					SELECTCASE !RAND:2
					CASE 1
						CALL OMANEKIBEYA_GAP(CHARA)
						PRINTFORML 再三邀请下，虽然有些不情愿的样子，但%CALLNAME:(CHARA)%仍然答应了你的邀请。
					CASEELSE
						PRINTFORML %CALLNAME:(CHARA)%似乎有些不情愿，没有答应你的邀请。
					ENDSELECT
				ELSEIF !GAP_ABLE(CHARA)
					PRINTFORML 出于各种各样的原因，%CALLNAME:(CHARA)%没有或无法答应你的邀请。
				ENDIF
				CALL RECOVER(MASTER, -300, GET_CURRENT_MPS(), "使用魔法的魔力消耗")
			ELSE
				M_CFLAG:CHARA:手动标记 = !M_CFLAG:CHARA:手动标记
				GOTO LOOP1
			ENDIF
		ELSE
			PRINTL 无效的选择！
			RETURN 0
		ENDIF
ENDSELECT

RETURN 0
