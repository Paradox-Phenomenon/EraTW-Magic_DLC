;==================================================
@M_KOJO_MESSAGE_SCOM_K94_1
CALL M_KOJO_MESSAGE_SCOM_K94_1_1
RETURN 1
@M_KOJO_MESSAGE_SCOM_K94_1_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(TFLAG:50 + 500)
		PRINTFORMW 
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		PRINTFORMW 
		RETURN 1
	;出す直前
	ELSEIF BASE:PLAYER:2 > 8000
		IF RAND:3 == 0
			PRINTFORMW 「嗯姆%"♥" *1%嗯%"♥" *1%啾%"♥" *1%啾%"♥" *1%嘶呜%"♥" *1%噗%"♥" *1%咻噗%"♥" *1%」
			PRINTFORMW 「变的舒服起来…%"♥" *1%…快射出来吧…%"♥" *1%」
		ELSEIF RAND:2 == 0
			PRINTFORMW 「咻%"♥" *1%咻噗%"♥" *1%嘶%"♥" *1%嗯呼%"♥" *1%吸吸%"♥" *1%嘶っ%"♥" *1%」
			PRINTFORMW 「嗯っ…%"♥" *1%…忍耐汁流出来了……真美味呀…%"♥" *1%」
		ELSE
			PRINTFORMW 「啊呜%"♥" *1%嗯咻%"♥" *1%嗯%"♥" *1%嗯哈%"♥" *1%」
			PRINTFORM 「
			CALL MASTER_CALLNAME_K94
			PRINTFORMW 的种子汁、满满的…让我喝个够吧？%"♥" *1%」
		ENDIF
	;恋慕
	ELSEIF TALENT:恋慕
		IF RAND:3 == 0
			PRINTFORMW 「咻噜%"♥" *1%哈嘶っ%"♥" *1%嗯噗っ…%"♥" *1%…嗯っ%"♥" *1%吸吸っ%"♥" *1%」
		ELSEIF RAND:2 == 0
			PRINTFORMW 「嗯噗っ%"♥" *1%咕っ%"♥" *1%嗯咻%"♥" *1%咻噗%"♥" *1%咻噗%"♥" *1%咻呼%"♥" *1%嗯っ%"♥" *1%哈姆%"♥" *1%」
		ELSE
			PRINTFORMW 「咻噗%"♥" *1%啾噗%"♥" *1%」
			PRINTFORM 「可不会把
			CALL MASTER_CALLNAME_K94
			PRINTFORMW 的种子让给其他女人…%"♥" *1%」
		ENDIF
	;屈服3
	ELSEIF MARK:不埒刻印 == 3
		IF RAND:3 == 0
			PRINTFORM 「
			CALL MASTER_CALLNAME_K94
			PRINTFORMW 的肉棒、再给我吸一吸嘛%"♥" *1%」
		ELSEIF RAND:2 == 0
			PRINTFORMW 「嗯啾%"♥" *1%嗯咕%"♥" *1%」
		ELSE
			PRINTFORMW 「嗯啾%"♥" *1%咻噗っ%"♥" *1%啊呜%"♥" *1%」
		ENDIF
	;それ以外
	ELSE
		IF RAND:3 == 0
			PRINTFORMW 「咻噗%"♥" *1%吸吸%"♥" *1%嘶呼%"♥" *1%嗯呜%"♥" *1%咻噗%"♥" *1%」
		ELSEIF RAND:2 == 0
			PRINTFORMW 「…嗯っ%"♥" *1%奇怪的味道…%"♥" *1%」
		ELSE
			PRINTFORMW 「嗯啾%"♥" *1%舔舔%"♥" *1%」
			PRINTFORMW 「满满的、射出来…%"♥" *1%」
		ENDIF
	ENDIF
ENDIF
