;==========================================================
;确认是否查看回想的函数
;==========================================================
@RUMIA_Moe_K12_DIARY_MEMORY_COMFIRM(ARG)

	PRINTFORML 确定要查看本条日记的回想吗？
	CALL ASK_M("确定",1,"不看",1)
	IF !RESULT 
		FOR LOCAL , 1 , 17
			PRINTFORM …
			AWAIT 111
		NEXT
		PRINTFORML 
		TRYCALLFORM DIARY_Moe_K12_{ARG}_MEMORY_TEXT
	ELSE 
		CLEARLINE 1 
	ENDIF 

;==========================================================
;确认某段日记有无回想的式中函数
;==========================================================
@RUMIA_Moe_K12_DIARY_MEMORY_EXIST_ENSURE(ARG)
#FUNCTION

RESULT = 0
SIF RUMIA_DIARY_MEMORY:12:ARG 
	RESULT = RUMIA_DIARY_MEMORY:12:ARG 
RETURNF RESULT 


;==========================================================
;确认某段日记有无回想
;==========================================================
@RUMIA_Moe_K12__DIARY_MEMORY_EXIST_ENSURE_ALL
#DIM DCOUNT

FOR DCOUNT,1,RUMIA_DIARY:12:DCOUNT 
	RESULT = 0
	TRYCALLFORM DIARY_Moe_K12_{DCOUNT}_MEMORY_EXIST
	SIF RESULT
		RUMIA_DIARY_MEMORY:12:DCOUNT = RESULT 
NEXT 

