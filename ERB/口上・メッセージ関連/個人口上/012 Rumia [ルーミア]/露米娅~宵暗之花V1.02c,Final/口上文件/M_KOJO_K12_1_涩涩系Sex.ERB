@M_KOJO_Moe_MESSAGE_PALAMCNG_C_K12
CALL PALAM_MESSAGE_C
;処女喪失
IF TCVAR:破瓜
	;正真正銘処女喪失
	IF TCVAR:破瓜 == 1
		;给重要的东西用
		CFLAG:12:1801 = 31
		;日记记载
		SIF SHIRAHU(12) 
		CALL M_KOJO_Moe_DIARYSETTING_K12(31,1)
		CALL RUMIA_MOE_WITH_YOUR_DIARY_TO_WRITE(8,0,1)
	;再生処女喪失
	ELSEIF TCVAR:破瓜 == 2
	;無自覚非処女喪失
	ELSEIF TCVAR:破瓜 == -1
	ENDIF
ENDIF

;Ａ処女喪失
IF TCVAR:Ａ破瓜
	;正真正銘Ａ処女喪失
	IF TCVAR:Ａ破瓜 == 1
		CFLAG:12:1801 = 131 
	;無自覚Ａ処女喪失
	ELSEIF TCVAR:Ａ破瓜 == -1
	ENDIF
ENDIF

;フェラで射精後のお掃除
IF (TCVAR:MASTER:112 == 1 || TCVAR:MASTER:112 == 2) && SELECTCOM == 81
	PRINTFORMW 
ENDIF


