;从帕露战神（不是）DOKU那里扒的代码工具
;只是稍微扒的代码就很有用了呢！还有好多能整的花活，因为完成度很高了所以不整了
;-------------------------------------------------

@DOKU_OD_ASK_M_MOERUMIA(ARGS:0, ARG:0, ARGS:1, ARG:1, ARGS:2, ARG:2, ARGS:3, ARG:3, ARGS:4, ARG:4, ARGS:5, ARG:5, ARGS:6, ARG:6, ARGS:7, ARG:7, ARGS:8, ARG:8, ARGS:9, ARG:9, ARGS:10, ARG:10, ARGS:11, ARG:11, ARGS:12, ARG:12, ARGS:13, ARG:13, ARGS:14, ARG:14, ARGS:15, ARG:15, ARGS:16, ARG:16)
;DOKU:我这个东西的强大之处是
;隐藏选项（编号空出来）
;隐藏选项（编号不空出来）
;菜单选项（编号自定义）
;额外空行（相当于选项中间插printl）

#DIM CONST MAX_OPTION_NUM = 17
#DIM CURRENT
#DIM NOWCURRENT
#DIM BIT_NOT_AVAI = 0
RESETCOLOR
NOWCURRENT = 0
FOR CURRENT, 0, (MAX_OPTION_NUM + 1)
IF ARGS:(CURRENT) != ""
SELECTCASE ARG:(CURRENT)
CASE 1
PRINTBUTTON @"[{CURRENT}]%ARGS:(CURRENT)%", CURRENT
PRINTL 
CASE 0 
SETCOLOR 0x606060
SETBIT BIT_NOT_AVAI,CURRENT
PRINTPLAINFORM [{CURRENT}]%ARGS:(CURRENT)%
RESETCOLOR
PRINTL 
CASE 2
SETBIT BIT_NOT_AVAI,CURRENT
