;露米亜的移动轨迹
;用于配合自己留在补丁里面的接口
@M_KOJO_CHARAMOVE_DATA_K12_1(ARG,ARG:2)
;此部分对应的补丁为ERB\キャラデータ\Chara_data_12_ルーミア.ERB

	SELECTCASE ARG
		;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
		CASE 1

		;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
		;可以在未来实装上课的时候，在这里做更改
		CASE 3
			IF (CFLAG:12:1202 || CFLAG:12:1002) && YOUBI_MATCH(DAY, "水金") && CFLAG:ARG:妊娠経過日数 <= 20
			;早⑩（确信）
				CFLAG:12:生活時間補正 = -120
			ELSE 
				CFLAG:12:生活時間補正 = 0 
			ENDIF 

		;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
		;相比原版，补充了不会进艾伦房间和浴室的设定，与在各个地方的移动倾向
		CASE 4
			SELECTCASE ARG:2	
				CASE P2境内, P10走廊, P11庭
					RETURN 5
				CASE P8廚房
					RETURN 7
				CASE P27三妖精之家・大廳
					RETURN -5
				CASE P201人里的門, P202中央広場, P203南大街, P204東大街, P205北大街, P206西大街, P207龍神像
					RETURN -7
				CASE P216食料品店, P217甜品店, P218小料理屋
					RETURN 7 
				CASE P213鈴奈庵 , P222寺子屋
					RETURN 5 
				CASE P301正門, P302庭, P303守衛小屋
					RETURN -10 
				CASE P343湖畔, P347霧之湖
					RETURN 5 
				CASE P345琪露諾的冰屋, P346大妖精の棲家
					SIF CFLAG:12:1204 || CFLAG:12:1004 
						RETURN 7
				;私人房间不会去
				CASE P303守衛小屋, P304空的小屋, P305仓库, P328地下走廊 TO P333大浴場
					RETURN -100
				;私人房间不会去
				CASE P512魔理沙宅・寝室, P514魔理沙宅・風呂, P521人偶洋館・愛麗絲的房間, P522人偶洋館・神綺的房間
					RETURN -100
				CASE P523人偶洋館・夢子的房間, P526人偶洋館・風呂, P531人偶洋館・空的部屋, P537艾倫宅・風呂, P535艾倫宅・寝室
					RETURN -100
				CASE P541朱鷺子的棲息処, P542莉格露的棲息処, P544成美の小屋
					RETURN -100
				CASE 543
					;白天很喜欢在家里
					IF INRANGE(TIME, 480, 1020) 
						RETURN 10
					;總不能在外面淋雨不回家吧
					ELSEIF TIME:5 == 4 || TIME:5 == 5 || TIME:5 == 6 
						RETURN 7
					ELSE 
						RETURN 5 
					ENDIF 
			ENDSELECT
		;出现场所
		;相比原版完全改掉了，现在不会去冥界那种地方了——
		;本来去那里就不太正常吧）
		CASE 7
			SELECTCASE ARG:2
				CASE 桜花道的鳥居, 神社境内, 神社本堂, 神社走廊, 妖精的大樹
					RETURN 1      
				CASE 広場, 商家町, 呑屋小道, 寺子屋    ;二周目，或者一周目学生才会这些
					SIF CFLAG:12:1200 || CFLAG:12:1004 || CFLAG:12:1204
					RETURN 1          
				CASE 霧之湖, 正門, 廃洋館
					RETURN 1         
				CASE 冰造的小雪屋
					SIF CFLAG:12:1204 || CFLAG:12:1004
						RETURN 1         
				CASE 竹林入口, 迷失的小道, 斜角的竹林, 無名之丘, 太陽花田
					RETURN 1          
				CASE 森林的入口, 古木的大樹, 霧雨魔法店, 人偶的洋館, 再思之道, 無縁塚
					RETURN 1 
				CASE 山麓樹海, 玄武之澤, 森の深奥
					RETURN 1         
				CASE 九天瀑布, 絶景之丘, 山之湖, 守矢神社境内
					RETURN 1         
			ENDSELECT
		;引力設定（CFLAG:LOCAL:引力点を設定する）
		;可以参考一下魔理沙的
		CASE 8	
			;露米娅讨厌阳光
			IF INRANGE(TIME, 480, 1020) 
				TCVAR:12:引力点 = 543
			ENDIF
	ENDSELECT
