;==================================================
;自慰 触发函数
;-------------------------------------------------
;这段代码是从AFTERTRAIN.ERB里面掏出来的
;用于补正CFLAG:12:1720的数值变化，同时更加使得露米娅的自慰自定义化
;虽然嘴上说是自定义化了……但是我还是没想到怎么自定义比较好
;不过目前是把无知消除的那个给去掉了
;-------------------------------------------------

@RUMIA_COMFORT_HERSELF_DURING_NIGHT
#DIM 欲求不満度
#DIM 満足度
#DIM 嫉妬度
#DIM 珠入手倍率
#DIM 部位指定
#DIM 追加Ｖ自慰
#DIM 追加Ａ自慰
#DIM 追加Ｂ自慰
#DIM 自慰タイプ
#DIM 自慰発生閾値
#DIM CONST 文字尺寸 = 15
#DIMS 自慰画像
VARSET LOCAL

	SIF CFLAG:12:出禁	
	GOTO RUMIA_COMFORT_HERSELF_DURING_NIGHT_END 

	部位指定 = 0
	自慰タイプ = 0
	追加Ｖ自慰 = 0
	追加Ａ自慰 = 0
	追加Ｂ自慰 = 0
	自慰発生閾値 = LIMIT(650 - 200 * TALENT:12:容易自慰 - 100 * TALENT:12:快感応答 - 100 * TALENT:12:自己愛 + 200 * TALENT:12:自制心,298,999)
	自慰発生閾値 -= 200 * TALENT:12:自慰狂
	IF CFLAG:12:1724 && CFLAG:12:1722
		PRINTFORML 
		PRINTFORMDW %CALLNAME:12%把臉埋在了枕頭裡面…
		PRINTFORML 
		SETCOLOR MOE_FADED_RED 
		PRINTFORMW 「……大坏蛋%UNICODE(0x2764)%……弄得人家%UNICODE(0x2764)%……说话都变奇怪了%UNICODE(0x2764)%……」
		RESETCOLOR
		CFLAG:12:1724 = 0 		
	ELSEIF CFLAG:12:1720 > 自慰発生閾値
		CALL PrintOnanismImage(12)
		LOCAL:1 = 0
		IF TALENT:12:愛欲
			LOCAL:1 = 3
		ELSEIF TALENT:12:恋慕
			LOCAL:1 = 3
		ELSEIF TALENT:12:炮友
			;愛人もここ
			LOCAL:1 = 2
		ELSEIF TALENT:12:思慕
			LOCAL:1 = 1
		ENDIF
		IF TALENT:12:自制心 && LOCAL:1 < 5
			LOCAL:1 += 1
		ENDIF
		IF CFLAG:12:既成事實 & 合意_诶嘿嘿 && !RAND:(7 - LOCAL:1)
			PRINTFORML %CALLNAME:12%忍耐著身體的蠢動、想到明天就能和%CALLNAME:MASTER%做了、強忍著睡著了……
			自慰タイプ = 7
			CFLAG:12:1720 = LIMIT(CFLAG:12:1720 + 100, 0 ,1000)
			SIF !CFLAG:12:神社在住 
				CFLAG:12:翌日来訪 = 1
			PRINTL
		ELSEIF CFLAG:MASTER:現在位置 == CFLAG:12:初期位置
			;PRINTFORML 夜里、%CALLNAME:MASTER%听到了一些动静而睁開了眼睛
			;PRINTFORML ……%CALLNAME:12%一边抓着%CALLNAME:MASTER%的手一边压抑着呻吟声沉溺于自慰之中……
			自慰タイプ = 2
		ELSEIF EX:12:膣内精液 
			PRINTFORML 無法忍耐的%CALLNAME:12%、伴著膣内殘留的%CALLNAME:MASTER%的精液開始了自慰……
			自慰タイプ = 3
		ELSEIF ABL:12:自慰中毒 >= 3 && (TALENT:12:思慕 || IS_LOVER(12) || TALENT:12:恋人 || TALENT:12:炮友) && !RAND:3
			PRINTFORML 怎么也忍耐不住了的%CALLNAME:LOCAL%、一边嗅着沾在衣服上的%CALLNAME:MASTER%的气味一边激烈的自慰着……
			LOCAL:2 = RAND:5
			IF (TALENT:12:Ｃ感度 == 1 || ABL:12:Ｃ感覚 >= 10) && LOCAL:2 == 4
				PRINTFORM 揉搓著陰核、即使潮吹了還一味地持續著動作
				部位指定 = 1
			ELSEIF (TALENT:12:Ｖ感度 == 1 || ABL:12:Ｖ感覚 >= 10) && LOCAL:2 == 3
				PRINTFORM 把手指深深地插入到蜜壷之中持續扣弄著愛液
				部位指定 = 2
				追加Ｖ自慰 = 1
			ELSEIF (TALENT:12:Ａ感度 == 1 || ABL:12:Ａ感覚 >= 10) && LOCAL:2 == 2
				PRINTFORM 持續玩弄著蜜穴和菊穴
				部位指定 = 3
				追加Ａ自慰 = 1
			ELSEIF (TALENT:12:Ｂ感度 == 1 || ABL:12:Ｂ感覚 >= 10) && LOCAL:2 == 1
				IF TALENT:12:胸圍 >= 1
					PRINTFORM 吸吮著自己那豊満的乳房、
				ELSEIF TALENT:12:胸圍 <= -1
					PRINTFORM 撫摸著貧瘠的胸部來回揉搓著乳頭、
				ELSE
					PRINTFORM 用下流的手法揉弄著柔軟的乳房、
				ENDIF
				PRINTFORM 高潮了好幾次
				部位指定 = 4
				追加Ｂ自慰 = 1
			ELSE
				;PRINTFORML しかし、どんなに快感を得ようとも%CALLNAME:MASTER%への想いは治まることはなく、%CALLNAME:LOCAL%は朝まで悶々とした時間を過ごした……
				PRINTFORM 因體內的快感餘韻而顫抖著身體
				部位指定 = 5
			ENDIF
			IF TALENT:12:思慕 || TALENT:12:恋慕 || TALENT:12:恋人
				PRINTFORML 、對%CALLNAME:MASTER%的思念平息了……
			ELSE
				PRINTFORML 、燃燒了身體的熱量還沒有平息……
			ENDIF
			追加Ｖ自慰 = 1
			自慰タイプ = 5
		ELSEIF ABL:12:自慰中毒 >= 3 && !RAND:2
			PRINTFORM 已经无法用手指满足的%CALLNAME:12%、用从河童那买来的玩具
			IF ABL:12:Ａ感覚 >= 5
				IF TALENT:12:貞操 == -1 && TALENT:12:処女 == 0
					PRINTFORM 尽可能深的插入陰道和肛門的深处
					追加Ｖ自慰 = 1
				ELSEIF TALENT:12:貞操 == 1
					PRINTFORM 抵住私处和肛門
				ELSE
					PRINTFORM 玩弄着私处和尻穴
				ENDIF
				部位指定 = 3
				追加Ａ自慰 = 1
			ELSE
				IF TALENT:12:貞操 == -1 && TALENT:12:処女 == 0
					PRINTFORM 插入陰道的深处
					追加Ｖ自慰 = 1
				ELSEIF TALENT:12:貞操 == 1
					PRINTFORM 抵住私处
				ELSE
					PRINTFORM 玩弄着私处
				ENDIF
				部位指定 = 1
			ENDIF
			PRINTFORML 沉溺于自慰之中…
			自慰タイプ = 6
		ELSE
			PRINTFORML 身体变的躁动难安的%CALLNAME:12%、自己用手指玩弄起了私处…
			自慰タイプ = 1
		ENDIF
		CALL KOJO_MESSAGE_SEND("EVENT",22,12,自慰タイプ,部位指定)
		SIF 自慰タイプ == 7
		GOTO RUMIA_COMFORT_HERSELF_DURING_NIGHT_END 
		EXP:12:自慰経験 += ABL:12:自慰中毒 * 2 + 1
		CALL COLORMESSAGE(@"自慰経験＋{ABL:12:自慰中毒 * 2 + 1}",C_PINK,1)
		SELECTCASE ABL:12:自慰中毒
			CASE 0 TO 2
				珠入手倍率 = 5
			CASE 3 TO 5
				珠入手倍率 = 3
			CASEELSE
				珠入手倍率 = 1
		ENDSELECT
		;快C
		CALL JUEL_UP_SPECIAL(12,"快Ｃ","Ｃ感覚",珠入手倍率,1)
		SIF 追加Ｖ自慰
			CALL JUEL_UP_SPECIAL(12,"快Ｖ","Ｖ感覚",珠入手倍率,1)
		SIF 追加Ａ自慰
			CALL JUEL_UP_SPECIAL(12,"快Ａ","Ａ感覚",珠入手倍率,1)
		SIF 追加Ｂ自慰
			CALL JUEL_UP_SPECIAL(12,"快Ｂ","Ｂ感覚",珠入手倍率,1)
		;恥情
		CALL JUEL_UP_SPECIAL(12,"恥情","自慰中毒",珠入手倍率 * 2,1)
		;欲情
		CALL JUEL_UP_SPECIAL(12,"欲情","欲望",珠入手倍率,1)
		CFLAG:12:1720 /= 4
		PRINTW 
	ENDIF
	;まず欲望で基礎値を決める
	SELECTCASE ABL:12:欲望
		CASE 0 TO 2
			欲求不満度 = 10
		CASE 3 TO 5
			欲求不満度 = 20
		CASE 6 TO 10
			欲求不満度 = 30
		CASE 10 TO 15
			欲求不満度 = 50
		CASEELSE
			欲求不満度 = 80
	ENDSELECT

	欲求不満度 += ABL:12:自慰中毒 * 7 + (ABL:12:膣射中毒 + ABL:12:肛射中毒) * 3
	欲求不満度 = 欲求不満素質補正(12,欲求不満度)
	SELECTCASE 欲求不満度
		CASE IS > 400
			欲求不満度 = (欲求不満度 - 400) / 10 + 400
		CASE IS > 200
			欲求不満度 = (欲求不満度 - 200) / 4 + 200
		CASE IS > 100
			欲求不満度 = (欲求不満度 - 100) / 2 + 100
	ENDSELECT
	SIF 自慰タイプ
		欲求不満度 = 0
	SIF TCVAR:12:今天有否见面
		欲求不満度 /= 2
	SIF TALENT:12:妊娠
		欲求不満度 /= 5
	SIF TALENT:12:育児中
		欲求不満度 /= 2
	;积攒度は0~1000の間に
	CFLAG:12:1720 = LIMIT(CFLAG:12:1720 + 欲求不満度, 0, 1000)
	DEBUGPRINTFORML %CALLNAME:12%的満足度：{満足度}　欲求不満上昇値：{欲求不満度}　积攒度：{CFLAG:12:1720}

$RUMIA_COMFORT_HERSELF_DURING_NIGHT_END 




;==================================================
;生育许可的好感判断用 函数
;-------------------------------------------------
;以下代码照搬ERB/イベント関連/妊娠関連/OGAMITAOSHI.ERB
;经过一点点屏蔽后制成
;-------------------------------------------------
@OGAMITAOSHI_MOE_RUMIA(ARG,ARG:1)
#DIM 理性判定値
#DIM 好意判定値
#DIM 好意表示
VARSET LOCAL


PRINTFORMW %CALLNAME:ARG%的心中

好意判定値 = CHK_HININ_LOVE(ARG) 
CALL SHOW_LOVEPOWER(好意判定値)

WAIT
理性判定値 = CHK_HININ_REASON(ARG)

;考虑到小孩子对生孩子这样的事情，肯定会有极大的恐惧
;而且事件发生的时候无任何PALAM……反倒能固定好期望值
;因此，加上这个补正之后，恋慕恋人默认的理性之壁将成为20星，即为2000 
;测试的时候，好感度34200+16亲密+17从顺+10奉仕精神，爱情经验371，且恋人加300，刚好21心

理性判定値 += 1200 

;不为什么
SIF TEQUIP:12:縄 || TEQUIP:12:拘束
理性判定値 += 1000 

CALL SHOW_REASONWALL(理性判定値)
IF TALENT:MASTER:謎之魅力
	CALL COLORMESSAGE(@"%CALLNAME:ARG%、因%CALLNAME:MASTER%的謎之魅力感覺理性有些蒸発……",C_PINK,1,1)
	理性判定値 = 理性判定値 * 9 / 10
	CALL SHOW_REASONWALL(理性判定値)
ENDIF
IF TALENT:ARG:自尊心 == -1
	理性判定値  = 理性判定値 * 9 / 10
ELSEIF TALENT:ARG:自尊心 == 1
	理性判定値 = 理性判定値 * 6 / 5
	CALL COLORMESSAGE(@"架子很大的%CALLNAME:ARG%、不想讓自己表現的太過廉價",C_PINK,1,1)
	CALL SHOW_REASONWALL(理性判定値)
ENDIF
IF TALENT:ARG:貞操 == 1
	理性判定値 = 理性判定値 * 6 / 5
	CALL COLORMESSAGE(@"非常重視贞操的%CALLNAME:ARG%、在改変觀念之前沒那麼容易就接受的……",C_PINK,1,1)
	CALL SHOW_REASONWALL(理性判定値)
ENDIF
IF OTOKOGIRAI(ARG)
	理性判定値 = 理性判定値 * 3 / 2
	IF TALENT:ARG:性別嗜好 == 3
		CALL COLORMESSAGE(@"%CALLNAME:ARG%対他人抱有同樣的忌避感情……",C_PINK,1,1)
	ELSEIF TALENT:ARG:性別嗜好 == 1
		CALL COLORMESSAGE(@"%CALLNAME:ARG%対男性抱有同樣的忌避感情……",C_PINK,1,1)
	ENDIF
	CALL SHOW_REASONWALL(理性判定値)
ENDIF
IF TALENT:ARG:倒錯的
	CALL COLORMESSAGE(@"%CALLNAME:ARG%は、爛れた関係に倒錯的な魅力を感じている……",C_PINK,1,1)
	理性判定値 = 理性判定値 * 8 / 10
	CALL SHOW_REASONWALL(理性判定値)
ENDIF
IF TALENT:ARG:難以越過的底線
	SELECTCASE EXP:ARG:愛情経験
		CASE IS >= 500
			CALL COLORMESSAGE(@"%CALLNAME:ARG%、已經就快要完全接受%CALLNAME:MASTER%了……！",C_PINK,1,1)
			理性判定値 = 理性判定値 / 2
		CASE IS >= 300
			CALL COLORMESSAGE(@"%CALLNAME:ARG%、雖然是面対%CALLNAME:MASTER%但還是有些抵抗……",C_PINK,1,1)
			理性判定値 = 理性判定値 * 6 / 5
		CASE IS >= 100
			CALL COLORMESSAGE(@"%CALLNAME:ARG%、即使是和親密的対象也保持著一定距離……",C_PINK,1,1)
			理性判定値 = 理性判定値 * 3 / 2
		CASEELSE
			CALL COLORMESSAGE(@"%CALLNAME:ARG%、不願意接受其他人……",C_PINK,1,1)
			理性判定値 *= 2
	ENDSELECT
	CALL SHOW_REASONWALL(理性判定値)
ENDIF
IF TALENT:ARG:傲嬌
	IF TALENT:ARG:恋慕
		理性判定値 = 理性判定値 * 2 / 3
		CALL COLORMESSAGE(@"%CALLNAME:ARG%撒嬌求歡！",C_PINK,1,1)
	ELSE
		理性判定値 = 理性判定値 * 3 / 2
		CALL COLORMESSAGE(@"%CALLNAME:ARG%抱有了反感……",C_PINK,1,1)
	ENDIF
	CALL SHOW_REASONWALL(理性判定値)
ENDIF
WAIT
IF CHK_HININ_LOVE(ARG) > 理性判定値
	CFLAG:ARG:允许无套 = 2
ELSE
ENDIF




