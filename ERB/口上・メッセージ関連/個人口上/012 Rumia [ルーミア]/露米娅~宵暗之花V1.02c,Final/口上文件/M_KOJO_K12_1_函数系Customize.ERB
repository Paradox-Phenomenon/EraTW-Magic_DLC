;获取系统时间函数

;用于很久不见面的情况

@RUMIA_GETDATA

#DIM 年
#DIM 月
#DIM 日
#DIM 记录年
#DIM 记录月
#DIM 记录日
#DIM 日期差
GETTIME
年 = RESULT:0 / 10000000000000
月 = (RESULT:0 % 10000000000000) / 100000000000
日 = (RESULT:0 % 100000000000) / 1000000000
记录年 = CFLAG:12:1402 / 10000000000000
记录月 = (CFLAG:12:1402 % 10000000000000) / 100000000000
记录日 = (CFLAG:12:1402 % 100000000000) / 1000000000
日期差 = (年 - 记录年) * 365 + (月 - 记录月) *30 + (日 - 记录日) 
RETURN 日期差



