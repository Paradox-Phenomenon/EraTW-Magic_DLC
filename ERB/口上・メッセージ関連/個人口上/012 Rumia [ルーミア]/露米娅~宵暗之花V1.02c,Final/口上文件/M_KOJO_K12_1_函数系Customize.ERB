;-------------------------------------------------
;身高・体重・3尺寸の表示処理
;-------------------------------------------------
;BASE:20 … 身高
;BASE:21 … 体重
;BASE:22 … 胸圍
;BASE:23 … 腰圍
;BASE:24 … 臀圍
;MAXBASE:20 … 身高係数
;MAXBASE:21 … 体重係数
;MAXBASE:22 … 胸圍係数
;MAXBASE:23 … 腰圍係数
;MAXBASE:24 … 臀圍係数

;身体測定フラグが立っている場合は係数を生成
;身体測定済みかつ未設定の場合も生成
;CSVに記入されていない場合の標準値は1000
;-------------------------------------------------
@RUMIA_MAKE_SIZE, ARG
#DIM 数值影响值,5

VARSET LOCAL
IF CFLAG:ARG:身体測定 == 2 || (CFLAG:ARG:身体測定 == 1 && (MAXBASE:ARG:身高 == 0 || MAXBASE:ARG:体重 == 0 || MAXBASE:ARG:胸圍 == 0 || MAXBASE:ARG:腰圍 == 0 || MAXBASE:ARG:臀圍 == 0))
	FOR LOCAL, 20, 25
		MAXBASE:ARG:LOCAL = CSVBASE(ARG,LOCAL) * 980 / 1000
		SIF MAXBASE:ARG:LOCAL == 0
			MAXBASE:ARG:LOCAL = 980
		MAXBASE:ARG:LOCAL = MAXBASE:ARG:LOCAL * RAND(965, 995) / 1000
		;这里稍微提高了一点测量器具的精度
	NEXT
ENDIF

;===身高の算出===
;基本値
BASE:ARG:身高 = (TALENT:ARG:性別 == 2) ? 1700 # 1500
BASE:ARG:身高 = BASE:ARG:身高 * MAXBASE:ARG:身高 / 1000


;体型補正
IF TALENT:ARG:体型 == -2
	TIMES BASE:ARG:身高, 0.80
ELSEIF TALENT:ARG:体型 == -1
	TIMES BASE:ARG:身高, 0.90
ELSEIF TALENT:ARG:体型 == 1
	TIMES BASE:ARG:身高, 1.10
ELSEIF TALENT:ARG:体型 == 2
	TIMES BASE:ARG:身高, 1.20
ELSEIF TALENT:ARG:体型 == 3
	TIMES BASE:ARG:身高, 1.50
ENDIF

;-------------------------------------------------
;Moe的自定义部分 身高
;-------------------------------------------------
IF ( DAY:0 - CFLAG:12:1299 ) < 480 
	数值影响值:1 = (730 + ( (DAY:0 - CFLAG:12:1299) * 190 / 480 ) )
	BASE:ARG:身高 *= 数值影响值:1 / 1000
ELSE 
	数值影响值:1 = 920
	BASE:ARG:身高 *= 数值影响值:1 / 1000
ENDIF 
IF ( DAY:0 - CFLAG:12:1299 ) < 180
	数值影响值:1 = (730 + ( (DAY:0 - CFLAG:12:1299) * 120 / 180 ) )
	BASE:ARG:身高 *= 数值影响值:1 / 1000
ELSE 
	数值影响值:1 = 850
	BASE:ARG:身高 *= 数值影响值:1 / 1000
ENDIF 
;-------------------------------------------------

;===腰圍の算出===
;基本値
BASE:ARG:腰圍 = BASE:ARG:身高 * 40 / 100
BASE:ARG:腰圍 = BASE:ARG:腰圍 * MAXBASE:ARG:腰圍 / 1000

;体型補正
IF TALENT:ARG:体型 == -2
	TIMES BASE:ARG:腰圍, 1.16 
ELSEIF TALENT:ARG:体型 == -1
	TIMES BASE:ARG:腰圍, 1.08 
ENDIF

;-------------------------------------------------
;Moe的自定义部分 腰围
;-------------------------------------------------

IF TALENT:ARG:体型 == -2
	数值影响值:2 = 1160 - ( (DAY:0 - CFLAG:12:1299) * 80 / 180 )
	BASE:ARG:腰圍 *= 数值影响值:2 / 1000
ELSEIF TALENT:ARG:体型 == -1
	数值影响值:2 = 1080 - ( (DAY:0 - CFLAG:12:1299) * 80 / 480 )
	BASE:ARG:腰圍 *= 数值影响值:2 / 1000
ENDIF
;-------------------------------------------------

;其他補正
SIF TALENT:ARG:魅力
	TIMES BASE:ARG:腰圍, 0.95

;===胸圍の算出===
;基本値
BASE:ARG:胸圍 = BASE:ARG:身高 * 51 / 100
BASE:ARG:胸圍 = BASE:ARG:胸圍 * MAXBASE:ARG:胸圍 / 1000

;胸圍補正
IF TALENT:ARG:胸圍 == -2
	TIMES BASE:ARG:胸圍, 0.85
ELSEIF TALENT:ARG:胸圍 == -1
	TIMES BASE:ARG:胸圍, 0.92 
ELSEIF TALENT:ARG:胸圍 == 1
	TIMES BASE:ARG:胸圍, 1.08
ELSEIF TALENT:ARG:胸圍 == 2
	TIMES BASE:ARG:胸圍, 1.16
ENDIF

;-------------------------------------------------
;Moe的自定义部分 胸围
;-------------------------------------------------

IF TALENT:ARG:胸圍 == -2
	数值影响值:3 = 840 + ( (DAY:0 - CFLAG:12:1299) * 80 / 180 )
	BASE:ARG:胸圍 *= 数值影响值:3 / 1000
ELSEIF TALENT:ARG:胸圍 == -1
	数值影响值:3 = 920 + ( (DAY:0 - CFLAG:12:1299) * 80 / 480 )
	BASE:ARG:胸圍 *= 数值影响值:3 / 1000
ENDIF 
;-------------------------------------------------

;Ｂ感覚による補正
BASE:ARG:胸圍 = BASE:ARG:胸圍 * (1000 + MIN(ABL:ARG:Ｂ感覚, 100)) / 1000

;其他補正
SIF TALENT:ARG:魅力
	TIMES BASE:ARG:胸圍, 1.05

;アンダー胸圍以下なら補正
BASE:ARG:胸圍 = MAX(BASE:ARG:身高 * 43 / 100, BASE:ARG:胸圍)

;===臀圍の算出===
;基本値
BASE:ARG:臀圍 = BASE:ARG:身高 * 53 / 100
BASE:ARG:臀圍 = BASE:ARG:臀圍 * MAXBASE:ARG:臀圍 / 1000

;其他補正
SIF TALENT:ARG:魅力
	TIMES BASE:ARG:臀圍, 1.05

;===体重の算出===
;基本値
BASE:ARG:体重 = BASE:ARG:身高 * BASE:ARG:身高 / 5000
BASE:ARG:体重 = BASE:ARG:体重 * MAXBASE:ARG:体重 / 1000

;体型補正
IF TALENT:ARG:体型 == -2
	TIMES BASE:ARG:体重, 0.80
ELSEIF TALENT:ARG:体型 == -1
	TIMES BASE:ARG:体重, 0.90
ELSEIF TALENT:ARG:体型 == 1
	TIMES BASE:ARG:体重, 1.10
ELSEIF TALENT:ARG:体型 == 2
	TIMES BASE:ARG:体重, 1.20
ELSEIF TALENT:ARG:体型 == 3
	TIMES BASE:ARG:体重, 1.50
ELSEIF TALENT:ARG:体型 == 5
	TIMES BASE:ARG:体重, 10.00
ENDIF

;-------------------------------------------------
;Moe的自定义部分 体重
;-------------------------------------------------
IF TALENT:ARG:体型 == -2
	IF ( DAY:0 - CFLAG:12:1299 ) < 480 
		数值影响值:4 = ( (DAY:0 - CFLAG:12:1299) * 130 / 480 )  + 800 
		BASE:ARG:体重 *= 数值影响值:4 / 1000
	ENDIF 
	IF ( DAY:0 - CFLAG:12:1299 ) < 180
		数值影响值:4 = ( (DAY:0 - CFLAG:12:1299) * 100 / 180 )  + 800 
		BASE:ARG:体重 *= 数值影响值:4 / 1000
	ENDIF 
ENDIF 
;-------------------------------------------------

;其他補正
SIF TALENT:ARG:魅力
	TIMES BASE:ARG:体重, 0.95



