					PRINTFORMW 「与露米娅成为朋友了！」
					;日记书写
					CALL M_KOJO_Moe_DIARYSETTING_K12(6)		
					CALL RUMIA_MOE_WITH_YOUR_DIARY_TO_WRITE(2,0,1)
					RESETCOLOR
					TALENT:12:15 = 1 	;心情
					CFLAG:12:1001 = 1	;朋友
					ABL:12:9 += 1 	;亲密
					PRINTFORML 		
						IF !FLAG:1031 
							PRINTFORMW 要启用本口上的颜色设定吗？
							PRINTFORML 
							PRINTFORMDL 启用后，这个口上内的台词，均会有对应的口上色区分
							PRINTFORMDW 不启用的话，大部分时候都会使用默认颜色
							PRINTFORML 
							CALL DOKU_OD_ASK_M_MOERUMIA("启用",1,"不启用",1)
								SELECTCASE RESULT 
									CASE 0 
										CFLAG:12:1031 = 1
										CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)
										PRINTFORML 
										PRINTFORMW 已启用
										PRINTFORMW 日后如果想要更改，还请通过UPDATE菜单进行更改
										PRINTFORML 
									CASE 1 
										CFLAG:12:1031 = 0 
										CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)
										PRINTFORML 
										PRINTFORMW 那么不启用口上色设定
										PRINTFORMW 日后如果想要更改，还请通过UPDATE菜单进行更改
										PRINTFORML 
								ENDSELECT
						ENDIF 		
			
				ELSE
					SELECTCASE TFLAG:193
						CASE 0,1
							SELECTCASE RAND:4
								CASE 0
										PRINTFORMW  「……好多人……」
								CASE 1
										PRINTFORMW  「有点怕……被认出来……」
								CASE 2
										PRINTFORMW  「……那边……是什么呀？……」
								CASE 3
										PRINTFORMW  「等一等嘛……」
							ENDSELECT
						CASE -1,-2 
							SELECTCASE RAND:2
								CASE 0
										PRINTFORMW  「诶……要说什么来着……」
								CASE 1
										PRINTFORMW  「……呜哇！没听见……」
							ENDSELECT
					ENDSELECT
				ENDIF 
			RETURN 1
			ENDIF
	ENDSELECT

;或许加个在外面遇见的对话

ELSE
	RETURN 0
ENDIF 




