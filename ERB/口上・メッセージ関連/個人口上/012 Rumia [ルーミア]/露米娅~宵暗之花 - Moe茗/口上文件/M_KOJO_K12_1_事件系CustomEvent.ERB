;==================================================
;早点睡觉 函数
;-------------------------------------------------
;半夜吓人用
;日常系300触发
;-------------------------------------------------
@RUMIA_NIGHT_LATE
#DIM HOURS
#DIM DAYTIME
GETTIME
DAYTIME = RESULT:0 %1000000000
HOURS = DAYTIME / 10000000
IF ONCE("RUMIA_NIGHT_LATE") && HOURS <= 6
	PRINTFORMW 「诶？%MASTERNAME:12%看起来有点疲倦了呢……」
	PRINTFORMW 「要不要去睡一觉呢？」
	PRINTFORMW 「已经{HOURS}点了呢，要注意休息啊。」
	PRINTFORMW 「啊咧？现在是几点来着？」
	RETURN 1
ELSE
	RETURN 0
ENDIF



