;302,スキンシップ
;TFLAG:193(1=大成功 0=成功 -1=失敗)
;==================================================
@M_KOJO_Moe_SUCCESS_COM_K12_302
;成否判定
;TFLAG:192(-2=コマンド終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

@M_KOJO_Moe_MESSAGE_COM_K12_302
CALL TRAIN_MESSAGE
CALL M_KOJO_Moe_MESSAGE_COM_K12_302_1
RETURN RESULT

@M_KOJO_Moe_MESSAGE_COM_K12_302_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)
	SIF MARK:12:3
		GOTO K12_1_302_1
	;身体检查
	CALL RUMIA_BODY_MEASURE_COMFIRM
	SIF RESULT == 1
	RETURN 1 
	;约会时身体接触
	IF FLAG:73 == 12
		IF TALENT:12:7
			$APPOINTMENT_TOUCH_1
			SELECTCASE RAND:10
				CASE 0
					PRINTFORML 「%MASTERNAME:12%——」
					PRINTFORMDL 露米娅扑进了你怀里
					PRINTFORMDW 你稳稳地抱住娇弱的小妖怪，摸了摸露米娅的头
				CASE 1
					PRINTFORML 「有些累了呢……」
					PRINTFORMDL 露米娅坐在你旁边，躺了下来，头枕在你的大腿上
					PRINTFORMDW 四目相对，小妖怪羞怯地移开了眼神……
				CASE 2
					PRINTFORML 「%MASTERNAME:12%怎么啦？」
					PRINTFORMDL 被轻轻碰着的露米娅抬头好奇地看向了你
					PRINTFORMDL 四目相对，小妖怪的小脸飞快地红起来了……
					PRINTFORML 「%MASTERNAME:12%……怎么感觉跟小孩子一样呢……」
					PRINTFORMW 「只是想看看的话……在外面总觉得很害羞……」
				CASE 3
					IF CFLAG:12:1200
						PRINTFORMDL 你悄悄地将双手伸向女孩身体两侧……
						PRINTFORML 「唔哈哈哈！%MASTERNAME:12%别挠了！哈哈哈……」
						PRINTFORMDL 你放开了手，小妖怪红润着脸喘着气
						PRINTFORMW 「真是的……%MASTERNAME:12%也要小心哦，露米娅会反击的！」
					ELSE
						GOTO APPOINTMENT_TOUCH_1
					ENDIF
				CASE 4
					PRINTFORMDL 你学着露米娅的样子，凑近了女孩的脸颊
					PRINTFORMDL 在露米娅有些疑惑但是又娇羞着的表情中，把下巴放在了她柔弱的肩膀上
					PRINTFORMDL 保持着脸颊的互相接触，露米娅也像是要撒娇似的，贴着你的脸轻轻磨蹭
					PRINTFORMDW 沉默着的温馨时光里，只要感受着露米娅的体温，心里就会充盈着满足感
