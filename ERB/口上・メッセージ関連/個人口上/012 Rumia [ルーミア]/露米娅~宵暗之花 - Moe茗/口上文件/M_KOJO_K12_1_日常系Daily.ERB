;==================================================
;300,会話
;TFLAG:193(1=大成功 0=成功 -1=失敗 -2=大失敗（TARGETがMASTERより教養が4以上高い)
;TCVAR:302(0=会話可能 1>=非恋慕時会話不能)
;MARK:反発刻印(3以上=会話不能)(4以上はバグ
;TCVAR:泥酔(1=通常成功or大失敗)
;==================================================
@M_KOJO_Moe_SUCCESS_COM_K12_300
;成否判定
;TFLAG:192(-2=コマンド終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 = 0

@M_KOJO_Moe_MESSAGE_COM_K12_300
;コマンド共通メッセージ(TRAIN_MESSAGE) 
;削除すると「～話をした。」とかが消えます。また、削除した場合は自動で口上色が付きません。
CALL TRAIN_MESSAGE
;口上メイン呼出
CALL M_KOJO_Moe_MESSAGE_COM_K12_300_1
RETURN RESULT

@M_KOJO_Moe_MESSAGE_COM_K12_300_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)	
	CALL RUMIA_BECOME_FRIEND
	;成为朋友了哦
	SIF RESULT == 1
		RETURN 1

	CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)			
	CALL RUMIA_YOIYAMI_FLOWER
	;宵暗之花
	SIF RESULT == 1
		RETURN 1

	CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)	
	CALL RUMIA_WAITINGYOU
	;记得回来看看露米娅
	SIF RESULT == 1
		RETURN 1

	CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)	
	CALL RUMIA_BAKAFRIENDS
	;露米娅交朋友
	SIF RESULT == 1
		RETURN 1

	CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)	
	CALL RUMIA_SCHOOL
	;上学校
	SIF RESULT == 1
		RETURN 1

	CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)	
	CALL RUMIA_BUY_FUMO
	;买FUMOFUMO
	SIF RESULT == 1
		RETURN 1

	CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)	
	CALL RUMIA_BAKAFRIENDS
	;为什么要call两遍）
	SIF RESULT == 1
		RETURN 1

	CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)	
	CALL RUMIA_ANGRY_TALK
	;生气对话
	SIF RESULT == 1
		RETURN 1

	CALL RUMIA_FESTIVAL_TALK
	;节日中的露米娅
	SIF RESULT == 1
		RETURN 1
	
	CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)	
	CALL RUMIA_ASKFEELING
	;今天的心情
	SIF RESULT == 1
		RETURN 1	

	CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)	
	CALL RUMIA_NIGHT_LATE
	;早点睡觉啊「你」先生
	SIF RESULT == 1
		RETURN 1

	CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)	
	CALL RUMIA_BODY_MEASURE_COMFIRM
	;身体测定
	SIF RESULT == 1
		RETURN 1 

	CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)	
	CALL RUMIA_OUTSIDE_TALK
	;在外对话
	SIF RESULT == 1
		RETURN 1

	CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)	
	CALL RUMIA_NORMALTALK
	;通常对话
	
ENDIF
RESETCOLOR
RETURN 1


;==================================================
;301,お茶を淹れる
;TFLAG:193(1=大成功 0=成功 -1=失敗)
;==================================================
@M_KOJO_Moe_SUCCESS_COM_K12_301
;成否判定
;TFLAG:192(-2=コマンド終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

@M_KOJO_Moe_MESSAGE_COM_K12_301
CALL TRAIN_MESSAGE
CALL M_KOJO_Moe_MESSAGE_COM_K12_301_1
RETURN RESULT

@M_KOJO_Moe_MESSAGE_COM_K12_301_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)
	SIF MARK:12:3
		GOTO K12_1_301_4
	IF TALENT:12:3
		SELECTCASE TFLAG:193
			CASE 0,1
			$K12_1_301_3
			SELECTCASE RAND:7
				CASE 0
					PRINTFORML 「以前溜进红魔馆玩的时候，露米娅还被一位白头发的女仆姐姐发现了！」
					PRINTFORML 「虽然看起来很不好惹，但是她居然没有赶露米娅走，还给了很好喝的红茶！」
					PRINTFORML 「那是露米娅第一次喝红茶，现在想起来也很奇怪，为什么她要给我茶呢？」
					PRINTFORML 「啊不是！当然是%MASTERNAME:12%泡的茶更好喝啊！」
					PRINTFORMDL 露米娅微微垂下了视线
					PRINTFORMW 「%MASTERNAME:12%泡的茶，是全幻想乡最好喝的啦～」
				CASE 1
					PRINTFORML 「%MASTERNAME:12%真会泡茶呢……」
					PRINTFORML 「教一教露米娅好不好？露米娅也想给%MASTERNAME:12%泡出这样的茶！」
					PRINTFORMDL 你向露米娅讲解着茶具的用法……
					PRINTFORML 「好难……要注意的细节好多啊……」
					PRINTFORMW 「不过如果能给%MASTERNAME:12%泡茶的话，那就太好啦！」
				CASE 2
					PRINTFORML 「跟神社的茶完全不一样呢……」
					PRINTFORMDL 你问露米娅哪里不一样
					PRINTFORML 「灵梦姐姐用的茶叶不一样，她泡的茶好苦好苦……真的不是为了赶我走吗……」
					PRINTFORML 「诶？不是这样的吗？那个茶是廉价的茶吗……」
					PRINTFORML 「原来这么强大的灵梦姐姐，居然比露米娅还没钱……真是稀奇呢」
					PRINTFORMW 「不行啊，得找个时间去神社和灵梦姐姐道歉才行！」
				CASE 3
					IF CFLAG:12:1201
						PRINTFORML 「哇！%MASTERNAME:12%居然会随身带奶茶诶！」
						PRINTFORML 「是给露米娅的吗？非常感谢！那我就不客气啦！」
						PRINTFORMDL 露米娅找到了吸管，突然想起来什么似的，向纸杯里插了两根吸管
						PRINTFORML 「这么好喝的奶茶，%MASTERNAME:12%也一起来喝吧！」
						PRINTFORMDL 距离相当近呢，女孩微微垂下视线，脸红扑扑的，似乎根本就没有在吮吸奶茶……
						PRINTFORMDW 你也慢慢的享受着这美好的时刻……
					ELSE
						GOTO K12_1_301_3
					ENDIF
				CASE 4
				SELECTCASE DAY:2
					CASE 1
					PRINTFORML 「能不能试试把采到的花瓣加进茶水里呢？」
					PRINTFORML 「咦？怎么感觉这个茶……好像在哪里喝过？」
					PRINTFORML 「啊，想起来了！是偶然遇见莉莉白，她分给了我一些晒好的樱花花瓣」
					PRINTFORML 「除去水分的花瓣就跟茶叶一样，用热水一泡，沉沉浮浮，不一会儿就会很香呢」
					PRINTFORMW 「虽然不是樱花，不过%MASTERNAME:12%这样泡的茶，也非常好喝！」
					CASE 2
					SELECTCASE RAND:2
						CASE 0
						PRINTFORML 「哎呀，茶冷了哦……没关系，还是很好喝呢！」
						PRINTFORML 「住在雾之湖的琪露诺，在去人里开店的路上，就给露米娅做过这样的茶」
						PRINTFORML 「在红茶里放很多很多糖，再放入冰块，就做成了冰红茶！」
						PRINTFORMW 「酸酸甜甜的，在夏天喝这种茶，真的停不下来呢」
						SIF CFLAG:12:1001
							PRINTFORMW 「不知道人里有没有这样的茶呢？」
						SIF CFLAG:12:1004 || CFLAG:12:1204
							PRINTFORMW 「不知道琪露诺哪去了呢，找她过来帮忙做冰块吧」
						CASE 1
						PRINTFORML 「用草药也能泡茶，原来需要煮一下啊……」
						PRINTFORML 「会不会很苦呢……」
						PRINTFORMDL 你试了一口茶，津甜交融于凉茶的甘味中，冲淡着体内的暑气
						PRINTFORMDL 好甜……露米娅偷偷放了糖对吧，这么甜会得蛀牙的
						PRINTFORML 「诶嘿嘿……」
						PRINTFORMDW 女孩咧着樱桃小嘴，向你做了个鬼脸
					ENDSELECT
					CASE 3
					PRINTFORML 「听说人里很少有人会做这种茶呢，%MASTERNAME:12%真厉害啊……」
					PRINTFORML 「是叫青茶吗？好香啊！虽然没有红茶的甜味，但是也很独特呢！」
					PRINTFORML 「第二泡茶味道更淡一些也更耐喝一些……露米娅比较喜欢」
					PRINTFORML 「啊，第一泡也很喜欢啦，浓郁的味道……也很回味无穷呢」
					PRINTFORMW 「不如说只要是%MASTERNAME:12%泡的茶，露米娅就很喜欢！」
					CASE 4
					PRINTFORML 「果然这么冷的天，喝红茶就能暖和起来呢」
					PRINTFORML 「总觉得%MASTERNAME:12%泡的茶，似乎总是有着特别的温暖，哪怕是冰红茶也是这样」
					PRINTFORML 「再怎么冷的天，只要喝%MASTERNAME:12%泡的茶……不，只要%MASTERNAME:12%在身旁……」
					PRINTFORML 「啊……在说什么呢」
					PRINTFORMDW 你扭过头去，侧着脸的露米娅摸着自己已经泛红的脸，是冻着了吗？
					CASEELSE 
					 GOTO K12_1_301_2
				ENDSELECT
			CASEELSE
				PRINTFORMDL 不知何时，露米娅给你泡好了茶
				PRINTFORMDW 很香呢，是什么时候学会的呢……
			ENDSELECT
		ENDSELECT
	ELSEIF TALENT:12:8
		SELECTCASE TFLAG:193
			CASE 0,1
			$K12_1_301_2
			SELECTCASE RAND:10
				CASE 0
				IF CFLAG:12:1001
					PRINTFORML 「听说人里的甜品店有很好吃的羊羹卖呢！」
					PRINTFORMW 「品茶的时候吃一份，真的感觉很不错呢！」
				ELSE
					GOTO K12_1_301_2
				ENDIF
				CASE 1
				PRINTFORML 「相比绿茶，露米娅好像更喜欢红茶呢」
				PRINTFORMDW 露米娅吹了吹绿茶，小口小口地喝起来
				CASE 2
				PRINTFORML 「%MASTERNAME:12%的手艺，越来越好了呢！」
				PRINTFORMDL 露米娅细细品味着红茶
				PRINTFORMW 「嗯——好喝！」
				CASE 3
				PRINTFORML 「嘶————有点烫呢……」
				PRINTFORMDL 露米娅把茶水放在一旁
				PRINTFORMW 「等冷下来一点点再喝吧！」
				CASE 4
				PRINTFORML 「如果说味道的话还是不如酒呢……」
				PRINTFORML 「不过酒喝多了会醉的……」
				PRINTFORMW 「醉了让%MASTERNAME:12%看护，怪不好意思的呢」
				CASE 5
				IF CFLAG:12:1202 || CFLAG:12:1002
					PRINTFORML 「%MASTERNAME:12%！这是我放学的时候买的羊羹！」
					PRINTFORMW 「一起吃吧！」
				ELSE
					GOTO K12_1_301_2
				ENDIF
				CASE 6,7
					SELECTCASE DAY:2
						CASE 1
						PRINTFORML 「下次想试试把花瓣加进茶里呢……」
						PRINTFORMW 「感觉会很好喝的样子！」 
						CASE 2
						PRINTFORML 「听琪露诺说，有一种茶叫冰红茶，酸酸甜甜的很好喝……」
						PRINTFORMW 「红茶又不是酸酸甜甜的，难道是加了冰就会变成这样吗……」
						CASE 4
						PRINTFORML 「冷天就应该喝红茶嘛」
						PRINTFORMDW 露米娅抱着热气腾腾的红茶，小口小口吹着
						CASEELSE
							GOTO K12_1_301_2
					ENDSELECT
				CASEELSE 
					GOTO K12_1_301_1
			ENDSELECT
			CASEELSE
			PRINTFORML 「要不让露米娅来泡茶吧？」
			PRINTFORMDW 露米娅抿了一口茶就如此说道……
		ENDSELECT
	ELSEIF CFLAG:12:1001 || CFLAG:12:1201
		SELECTCASE TFLAG:193
			CASE 0,1
			$K12_1_301_1
			SELECTCASE RAND:9
				CASE 0
				IF CFLAG:12:1001
					PRINTFORML 「泡茶有那么麻烦吗？」
					PRINTFORMDL 你向露米娅讲解着茶具的用法
					PRINTFORMW 「是这样吗……」
				ELSE
					GOTO K12_1_301_1
				ENDIF
				CASE 1
				PRINTFORML 「我想要水……咦？好像还有点好喝？」
				PRINTFORMDW 露米娅啜饮着红茶……
				CASE 2
				PRINTFORML 「谢谢%MASTERNAME:12%！那我就用茶啦」
				PRINTFORMDW 露米娅吹了吹茶，慢慢地喝了起来
				CASE 3
				IF CFLAG:12:1201
					PRINTFORML 「让露米娅给%MASTERNAME:12%泡茶吧！」
					PRINTFORMDW 看来是从村民那里学的待客之道呢
				ELSE
					GOTO K12_1_301_1
				ENDIF
				CASE 4
				IF CFLAG:12:1201
					PRINTFORML 「是茶水吗？谢谢%MASTERNAME:12%！」
					PRINTFORMW 「啊……怀念的感觉……很好喝呢！」
				ELSE
					GOTO K12_1_301_1
				ENDIF
				CASE 5
				IF CFLAG:12:1201
					PRINTFORML 「%MASTERNAME:12%喝茶——请慢用！」
					PRINTFORMW 「诶？露米娅也正好带着茶叶和保温杯哦！」
				ELSE
					GOTO K12_1_301_1
				ENDIF

				CASE 6
				IF CFLAG:12:1201
					PRINTFORML 「%MASTERNAME:12%的茶，泡的挺好的呢！」
					PRINTFORMW 「在别人家里，喝不到这么精致的茶呢……」
				ELSE
					GOTO K12_1_301_1
				ENDIF
				
				CASE 7
				IF CFLAG:12:1201
					PRINTFORML 「露米娅泡的茶，%MASTERNAME:12%觉得如何呢？」
					PRINTFORMDW 虽然只是廉价茶叶，但是却意外地泡出了满壶清香
				ELSE
					GOTO K12_1_301_1
				ENDIF

				CASE 8
				IF CFLAG:12:1201
					PRINTFORML 「啊！%MASTERNAME:12%的茶，很不错呢！」
					PRINTFORMW 「不知道为什么，有一种，梦幻一样的感觉？」
				ELSE
					GOTO K12_1_301_1
				ENDIF

			ENDSELECT
			CASEELSE
			SELECTCASE RAND:6
				CASE 0
				PRINTFORML 「我想喝水……」
				PRINTFORMDW 露米娅把茶水放在一边……
				CASE 1
				PRINTFORML 「想吃点甜的……」
				PRINTFORMDW 露米娅不太喜欢的样子……
				CASE 2
				PRINTFORML 「呜……喝不出味道……？」
				PRINTFORMDW 露米娅困惑地望着茶水
				CASE 3
				IF CFLAG:12:1201
					PRINTFORML 「先放在一边，等它稍微泡开一点……」
					PRINTFORMDW 露米娅把茶水放在旁边了……
				ELSE
					GOTO K12_1_301_1
				ENDIF
				CASE 4
				IF CFLAG:12:1201
					PRINTFORML 「%MASTERNAME:12%需要帮忙吗？」
					PRINTFORMDW 露米娅看着你泡茶的动作，不知为何有些担忧的样子
				ELSE
					GOTO K12_1_301_1
				ENDIF

				CASE 5
				IF CFLAG:12:1201
					PRINTFORML 「%MASTERNAME:12%用的水，如果更烫一些，就好了」
					PRINTFORMW 「泡得太慢……露米娅都知道泡不开呀……」
				ELSE
					GOTO K12_1_301_1
				ENDIF

			ENDSELECT
		ENDSELECT
	ELSE
		$K12_1_301_4
		SELECTCASE RAND:2
			CASE 0
			PRINTFORMDL 你泡好茶，试探地问问露米娅要不要喝茶……
			PRINTFORMDL 黑暗中伸出一只小手，小心翼翼地接过茶……
			PRINTFORML 「呀!」
			PRINTFORMDL 露米娅不小心被茶烫到了……
			PRINTFORMDW 你连忙表示道歉……
			CASE 1
			PRINTFORMDL 你泡好茶，待到茶冷了之后，试探地问问露米娅要不要喝茶……
			PRINTFORMDW 黑暗中伸出一只小手，小心翼翼地接过茶并带进黑暗中……
		ENDSELECT
	ENDIF
ENDIF
RESETCOLOR
RETURN 1
