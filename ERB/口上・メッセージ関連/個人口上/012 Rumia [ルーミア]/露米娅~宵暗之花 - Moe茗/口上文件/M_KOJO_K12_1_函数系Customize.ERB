#DIM 好意判定値
#DIM 好意表示
VARSET LOCAL


PRINTFORMW %CALLNAME:ARG%的心中

好意判定値 = CHK_HININ_LOVE(ARG) 
CALL SHOW_LOVEPOWER(好意判定値)

WAIT
理性判定値 = CHK_HININ_REASON(ARG)

;考虑到小孩子对生孩子这样的事情，肯定会有极大的恐惧
;而且事件发生的时候无任何PALAM……反倒能固定好期望值
;因此，加上这个补正之后，恋慕恋人默认的理性之壁将成为20星，即为2000 
;测试的时候，好感度34200+16亲密+17从顺+10奉仕精神，爱情经验371，且恋人加300，刚好21心

理性判定値 += 1200 

;不为什么
SIF TEQUIP:12:縄 || TEQUIP:12:拘束
理性判定値 += 1000 

CALL SHOW_REASONWALL(理性判定値)
;蜜汁魅力
IF TALENT:MASTER:94
	CALL COLORMESSAGE(@"%CALLNAME:ARG%、因%CALLNAME:MASTER%的謎之魅力感覺理性有些蒸発……",C_PINK,1,1)
	理性判定値 = 理性判定値 * 9 / 10
	CALL SHOW_REASONWALL(理性判定値)
ENDIF
;自尊心
IF TALENT:ARG:13 == -1
	理性判定値  = 理性判定値 * 9 / 10
ELSEIF TALENT:ARG:13 == 1
	理性判定値 = 理性判定値 * 6 / 5
	CALL COLORMESSAGE(@"架子很大的%CALLNAME:ARG%、不想讓自己表現的太過廉價",C_PINK,1,1)
	CALL SHOW_REASONWALL(理性判定値)
ENDIF
;贞操重视
IF TALENT:ARG:30 == 1
	理性判定値 = 理性判定値 * 6 / 5
	CALL COLORMESSAGE(@"非常重視贞操的%CALLNAME:ARG%、在改変觀念之前沒那麼容易就接受的……",C_PINK,1,1)
	CALL SHOW_REASONWALL(理性判定値)
ENDIF
;性别嗜好
IF OTOKOGIRAI(ARG)
	理性判定値 = 理性判定値 * 3 / 2
	IF TALENT:ARG:81 == 3
		CALL COLORMESSAGE(@"%CALLNAME:ARG%対他人抱有同樣的忌避感情……",C_PINK,1,1)
	ELSEIF TALENT:ARG:81 == 1
		CALL COLORMESSAGE(@"%CALLNAME:ARG%対男性抱有同樣的忌避感情……",C_PINK,1,1)
	ENDIF
	CALL SHOW_REASONWALL(理性判定値)
ENDIF
;倒错的
IF TALENT:ARG:80
	CALL COLORMESSAGE(@"%CALLNAME:ARG%は、爛れた関係に倒錯的な魅力を感じている……",C_PINK,1,1)
	理性判定値 = 理性判定値 * 8 / 10
	CALL SHOW_REASONWALL(理性判定値)
ENDIF
;难以逾越
IF TALENT:ARG:25
	SELECTCASE EXP:ARG:41
		CASE IS >= 500
			CALL COLORMESSAGE(@"%CALLNAME:ARG%、已經就快要完全接受%CALLNAME:MASTER%了……！",C_PINK,1,1)
			理性判定値 = 理性判定値 / 2
		CASE IS >= 300
			CALL COLORMESSAGE(@"%CALLNAME:ARG%、雖然是面対%CALLNAME:MASTER%但還是有些抵抗……",C_PINK,1,1)
			理性判定値 = 理性判定値 * 6 / 5
		CASE IS >= 100
			CALL COLORMESSAGE(@"%CALLNAME:ARG%、即使是和親密的対象也保持著一定距離……",C_PINK,1,1)
			理性判定値 = 理性判定値 * 3 / 2
		CASEELSE
			CALL COLORMESSAGE(@"%CALLNAME:ARG%、不願意接受其他人……",C_PINK,1,1)
			理性判定値 *= 2
	ENDSELECT
	CALL SHOW_REASONWALL(理性判定値)
ENDIF
;傲娇
IF TALENT:ARG:14
	IF TALENT:ARG:3
		理性判定値 = 理性判定値 * 2 / 3
		CALL COLORMESSAGE(@"%CALLNAME:ARG%撒嬌求歡！",C_PINK,1,1)
	ELSE
		理性判定値 = 理性判定値 * 3 / 2
		CALL COLORMESSAGE(@"%CALLNAME:ARG%抱有了反感……",C_PINK,1,1)
	ENDIF
	CALL SHOW_REASONWALL(理性判定値)
ENDIF
WAIT
IF CHK_HININ_LOVE(ARG) > 理性判定値
	CFLAG:ARG:14 = 2
ELSE
ENDIF



