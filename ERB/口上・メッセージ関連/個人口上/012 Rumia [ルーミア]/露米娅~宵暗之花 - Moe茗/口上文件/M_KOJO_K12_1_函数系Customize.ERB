@RUMIA_ENCOUNTUER_EAT
IF TCVAR:12:351 && FIRSTTIME("RUMIA_ENCOUNTUER_EAT") && !CFLAG:12:1001 
	SETCOLOR MOE_RUMIA 
	PRINTFORML 「唔……露米娅其实很少能来这里吃饭呢……」
	PRINTFORML 「因为露米娅其实并不强，而且与人类的关系不好……」
	PRINTFORMW 「所以，非常感谢，你能带露米娅出来吃饭！」
	CALL CHANGE_CFLAG(2, 12, 30)
	CALL CHANGE_CFLAG(2, 12, 10)
	ABL:12:9 += 1
	;自己日记
	IF SELECTCOM == 610
	CALL RUMIA_MOE_WITH_YOUR_DIARY_TO_WRITE(1,0,4,1)
	ELSE 
	CALL RUMIA_MOE_WITH_YOUR_DIARY_TO_WRITE(1,0,4)
	ENDIF 
	RESETCOLOR
	TCVAR:12:351 = 0 
	RETURN 1
ELSE
	RETURN 0
ENDIF

