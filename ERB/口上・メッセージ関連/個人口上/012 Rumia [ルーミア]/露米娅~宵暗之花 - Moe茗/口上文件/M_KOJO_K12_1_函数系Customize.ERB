;-------------------------------------------------

@RUMIA_COMFORT_HERSELF_DURING_NIGHT
#DIM 欲求不満度
#DIM 満足度
#DIM 嫉妬度
#DIM 珠入手倍率
#DIM 部位指定
#DIM 追加Ｖ自慰
#DIM 追加Ａ自慰
#DIM 追加Ｂ自慰
#DIM 自慰タイプ
#DIM 自慰発生閾値
#DIM CONST 文字尺寸 = 15
#DIMS 自慰画像
VARSET LOCAL

	SIF CFLAG:12:出禁	
	GOTO RUMIA_COMFORT_HERSELF_DURING_NIGHT_END 

	部位指定 = 0
	自慰タイプ = 0
	追加Ｖ自慰 = 0
	追加Ａ自慰 = 0
	追加Ｂ自慰 = 0
	自慰発生閾値 = LIMIT(650 - 200 * TALENT:12:60 - 100 * TALENT:12:快感応答 - 100 * TALENT:12:自己愛 + 200 * TALENT:12:自制心,298,999)
	自慰発生閾値 -= 200 * TALENT:12:73
	IF CFLAG:12:1724 && CFLAG:12:1722
		PRINTFORML 
		PRINTFORMDW %CALLNAME:12%把臉埋在了枕頭裡面…
		PRINTFORML 
		SETCOLOR MOE_FADED_RED 
		PRINTFORMW 「……大坏蛋%UNICODE(0x2764)%……弄得人家%UNICODE(0x2764)%……说话都变奇怪了%UNICODE(0x2764)%……」
		RESETCOLOR
		CFLAG:12:1724 = 0 		
	ELSEIF CFLAG:12:1720 > 自慰発生閾値
		CALL PrintOnanismImage(12)
		LOCAL:1 = 0
		IF TALENT:12:184
			LOCAL:1 = 3
		ELSEIF TALENT:12:3
			LOCAL:1 = 3
		ELSEIF TALENT:12:185
			;愛人もここ
			LOCAL:1 = 2
		ELSEIF TALENT:12:8
			LOCAL:1 = 1
		ENDIF
		IF TALENT:12:自制心 && LOCAL:1 < 5
			LOCAL:1 += 1
		ENDIF
		IF CFLAG:12:1 & 1 && !RAND:(7 - LOCAL:1)		;既成事实达到合意
			PRINTFORML %CALLNAME:12%忍耐著身體的蠢動、想到明天就能和%CALLNAME:MASTER%做了、強忍著睡著了……
			自慰タイプ = 7
			CFLAG:12:1720 = LIMIT(CFLAG:12:1720 + 100, 0 ,1000)
			SIF !CFLAG:12:30 
				CFLAG:12:362 = 1
			PRINTL
		ELSEIF CFLAG:MASTER:300 == CFLAG:12:311
			;PRINTFORML 夜里、%CALLNAME:MASTER%听到了一些动静而睁開了眼睛
			;PRINTFORML ……%CALLNAME:12%一边抓着%CALLNAME:MASTER%的手一边压抑着呻吟声沉溺于自慰之中……
			自慰タイプ = 2
		ELSEIF EX:12:14 
			PRINTFORML 無法忍耐的%CALLNAME:12%、伴著膣内殘留的%CALLNAME:MASTER%的精液開始了自慰……
			自慰タイプ = 3
		ELSEIF ABL:12:自慰中毒 >= 3 && (TALENT:12:8 || IS_LOVER(12) || TALENT:12:7 || TALENT:12:185) && !RAND:3
			PRINTFORML 怎么也忍耐不住了的%CALLNAME:LOCAL%、一边嗅着沾在衣服上的%CALLNAME:MASTER%的气味一边激烈的自慰着……
			LOCAL:2 = RAND:5
			IF (TALENT:12:Ｃ感度 == 1 || ABL:12:0 >= 10) && LOCAL:2 == 4
				PRINTFORM 揉搓著陰核、即使潮吹了還一味地持續著動作
				部位指定 = 1
			ELSEIF (TALENT:12:Ｖ感度 == 1 || ABL:12:1 >= 10) && LOCAL:2 == 3
				PRINTFORM 把手指深深地插入到蜜壷之中持續扣弄著愛液
				部位指定 = 2
				追加Ｖ自慰 = 1
			ELSEIF (TALENT:12:Ａ感度 == 1 || ABL:12:2 >= 10) && LOCAL:2 == 2
				PRINTFORM 持續玩弄著蜜穴和菊穴
				部位指定 = 3
				追加Ａ自慰 = 1
			ELSEIF (TALENT:12:Ｂ感度 == 1 || ABL:12:3 >= 10) && LOCAL:2 == 1
				IF TALENT:12:22 >= 1
					PRINTFORM 吸吮著自己那豊満的乳房、
				ELSEIF TALENT:12:22 <= -1
					PRINTFORM 撫摸著貧瘠的胸部來回揉搓著乳頭、
				ELSE
					PRINTFORM 用下流的手法揉弄著柔軟的乳房、
				ENDIF
				PRINTFORM 高潮了好幾次
				部位指定 = 4
				追加Ｂ自慰 = 1
			ELSE
				;PRINTFORML しかし、どんなに快感を得ようとも%CALLNAME:MASTER%への想いは治まることはなく、%CALLNAME:LOCAL%は朝まで悶々とした時間を過ごした……
				PRINTFORM 因體內的快感餘韻而顫抖著身體
				部位指定 = 5
			ENDIF
			IF TALENT:12:8 || TALENT:12:3 || TALENT:12:7
				PRINTFORML 、對%CALLNAME:MASTER%的思念平息了……
			ELSE
				PRINTFORML 、燃燒了身體的熱量還沒有平息……
			ENDIF
			追加Ｖ自慰 = 1
			自慰タイプ = 5
		ELSEIF ABL:12:自慰中毒 >= 3 && !RAND:2
			PRINTFORM 已经无法用手指满足的%CALLNAME:12%、用从河童那买来的玩具
			IF ABL:12:2 >= 5
				IF TALENT:12:貞操 == -1 && TALENT:12:0 == 0
					PRINTFORM 尽可能深的插入陰道和肛門的深处
					追加Ｖ自慰 = 1
				ELSEIF TALENT:12:貞操 == 1
					PRINTFORM 抵住私处和肛門
				ELSE
					PRINTFORM 玩弄着私处和尻穴
				ENDIF
				部位指定 = 3
				追加Ａ自慰 = 1
			ELSE
				IF TALENT:12:貞操 == -1 && TALENT:12:0 == 0
					PRINTFORM 插入陰道的深处
					追加Ｖ自慰 = 1
				ELSEIF TALENT:12:貞操 == 1
					PRINTFORM 抵住私处
				ELSE
					PRINTFORM 玩弄着私处
				ENDIF
				部位指定 = 1
			ENDIF
			PRINTFORML 沉溺于自慰之中…
			自慰タイプ = 6
		ELSE
			PRINTFORML 身体变的躁动难安的%CALLNAME:12%、自己用手指玩弄起了私处…
			自慰タイプ = 1
		ENDIF
		CALL KOJO_MESSAGE_SEND("EVENT",22,12,自慰タイプ,部位指定)
		SIF 自慰タイプ == 7
		GOTO RUMIA_COMFORT_HERSELF_DURING_NIGHT_END 
		EXP:12:22 += ABL:12:自慰中毒 * 2 + 1
		CALL COLORMESSAGE(@"自慰経験＋{ABL:12:自慰中毒 * 2 + 1}",C_PINK,1)
		SELECTCASE ABL:12:自慰中毒
			CASE 0 TO 2
				珠入手倍率 = 5
			CASE 3 TO 5
				珠入手倍率 = 3
			CASEELSE
				珠入手倍率 = 1
		ENDSELECT
		;快C
		CALL JUEL_UP_SPECIAL(12,"快Ｃ","Ｃ感覚",珠入手倍率,1)
		SIF 追加Ｖ自慰
			CALL JUEL_UP_SPECIAL(12,"快Ｖ","Ｖ感覚",珠入手倍率,1)
		SIF 追加Ａ自慰
			CALL JUEL_UP_SPECIAL(12,"快Ａ","Ａ感覚",珠入手倍率,1)
		SIF 追加Ｂ自慰
			CALL JUEL_UP_SPECIAL(12,"快Ｂ","Ｂ感覚",珠入手倍率,1)
		;恥情
		CALL JUEL_UP_SPECIAL(12,"恥情","自慰中毒",珠入手倍率 * 2,1)
		;欲情
		CALL JUEL_UP_SPECIAL(12,"欲情","欲望",珠入手倍率,1)
		CFLAG:12:1720 /= 4
		PRINTW 
	ENDIF
	;まず欲望で基礎値を決める
	SELECTCASE ABL:12:11
		CASE 0 TO 2
			欲求不満度 = 10
		CASE 3 TO 5
			欲求不満度 = 20
		CASE 6 TO 10
			欲求不満度 = 30
		CASE 10 TO 15
			欲求不満度 = 50
		CASEELSE
			欲求不満度 = 80
	ENDSELECT

	欲求不満度 += ABL:12:自慰中毒 * 7 + (ABL:12:膣射中毒 + ABL:12:肛射中毒) * 3
	欲求不満度 = 欲求不満素質補正(12,欲求不満度)
	SELECTCASE 欲求不満度
		CASE IS > 400
			欲求不満度 = (欲求不満度 - 400) / 10 + 400
		CASE IS > 200
			欲求不満度 = (欲求不満度 - 200) / 4 + 200
		CASE IS > 100
			欲求不満度 = (欲求不満度 - 100) / 2 + 100
	ENDSELECT
	SIF 自慰タイプ
		欲求不満度 = 0
	SIF TCVAR:12:182
		欲求不満度 /= 2
	SIF TALENT:12:153
		欲求不満度 /= 5
	SIF TALENT:12:154
		欲求不満度 /= 2
	;积攒度は0~1000の間に
	CFLAG:12:1720 = LIMIT(CFLAG:12:1720 + 欲求不満度, 0, 1000)
	DEBUGPRINTFORML %CALLNAME:12%的満足度：{満足度}　欲求不満上昇値：{欲求不満度}　积攒度：{CFLAG:12:1720}

$RUMIA_COMFORT_HERSELF_DURING_NIGHT_END 




