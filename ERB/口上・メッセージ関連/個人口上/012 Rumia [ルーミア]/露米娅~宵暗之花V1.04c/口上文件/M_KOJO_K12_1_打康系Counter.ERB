;-------------------------------------------------
;うふふカウンター
;-------------------------------------------------
;まだ



@UNIQUE_FA_12(CHARA, ARGS,時間係数)
#DIM CHARA
#DIM CHAIN
#DIM 現在地
#DIM メッセージ表示
#DIM 時間係数
現在地 = CFLAG:CHARA:300
メッセージ表示 = 現在地 == CFLAG:MASTER:300 ? 1 # 0

UNIQUE_FA_NAME:CHARA = "躲进黑球"

SELECTCASE ARGS
	CASE "発生"
		;天气是晴天且季节非冬季且时间是下午
		SIF (CFLAG:12:1001 || CFLAG:12:1201)
			RETURN 0 
		SIF ( (DAY:5 != 0) || (DAY:5 != 1) ) && (DAY:2 != 4) && ((TIME > 720) && (TIME < 1020))
			RETURN 0
		SIF CHARA != 12 || CFLAG:12:998 != 1
			RETURN 0
		SIF BASE:CHARA:0 <= 500
			RETURN 0
		SIF SHIRAHU(12)
			RETURN 0
		SIF メッセージ表示
			PRINTFORML 「太阳好大呀……%MASTERNAME:12%，露米娅先在黑球球里躲一会儿～」
			IF (TALENT:12:7 || TALENT:12:3) && !FLAG:73 && CFLAG:MASTER:320 == 12 && (TARGET == 12 ) 
				PRINTFORMW 「呐——%MASTERNAME:12%你也一起嘛～～」
				PRINTFORMDW 你被露米娅拖着一起进入了黑暗中……
				PRINTFORMDW 确实很凉快呢……
				TCVAR:12:355 = 1
			ELSE 
				PRINTFORMDW 你目送着露米娅被黑球吞没的背影……
			ENDIF 
		;返し値は行動時間
		RETURN 45 
	CASE "行動中"
		IF メッセージ表示
			IF TCVAR:12:355
				SELECTCASE RAND:3
					CASE 0 
						PRINTFORML 露米娅似乎在偷偷地摸着你的手……
						PRINTFORMW 「哪里嘛，明明只是……怕跟丢嘛」
					CASE 1
						PRINTFORML 身体被露米娅猛地拽开，才发现你快要撞到树上了……
						PRINTFORMW 「好险……还好一直看着%MASTERNAME:12%呢……」
					CASE 2
						PRINTFORML 因为什么都看不见，你只能顺着露米娅的意思走走停停……
						PRINTFORMW 「就随便玩一玩嘛……嗯哼……」
				ENDSELECT
			ELSE
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 黑球在你身后慢慢地飘着……
					CASE 1
						PRINTFORML 黑球落在地上，似乎有些累了呢
					CASE 2
						PRINTFORML 黑球在一旁蹦蹦跳跳的
				ENDSELECT
			ENDIF 
		ENDIF
	CASE "完了"
		IF メッセージ表示
			IF TCVAR:12:355
				PRINTFORML 「差不多了吧……现在的话，不容易昏昏沉沉的了呢！」
				PRINTFORML 「那就先收回来……」
				PRINTFORML 
				PRINTFORMDW 环绕四周的黑暗渐渐消失了，能看见外界的景象了
				TCVAR:12:355 = 0
			ELSE
				PRINTFORMDL 露米娅从黑暗里跳了出来……
				PRINTFORMW 「好啦！休息得差不多啦！」
			ENDIF 
		ENDIF 
	CASE "中断"
		PRINTFORML 「怎么了怎么了？找露米娅有什么事情……」
		;中断メッセージは诶嘿嘿突入時等でも表示されてしまうので表示しない
		TCVAR:12:355 = 0
	CASE "交手"
		PRINTFORML 
		IF TFLAG:193 < 0
			PRINTFORML 「呜……」
			PRINTFORMDW 露米娅鼓着嘴望着你……
		ELSE
			PRINTFORML 「诶嘿嘿……」
			TALENT:12:15 = 1 
		ENDIF
	CASE "ソース"
		DOWNBASE:MASTER:1 += 20 * 時間係数
		DOWNBASE:TARGET:1 += 20 * 時間係数
		SOURCE:20 = (100 + ((ABL:9 + ABL:MASTER:41) * 50)) * 時間係数	;亲密，欢乐
		SOURCE:22 = (60 + ((ABL:10 + ABL:MASTER:41) * 30)) * 時間係数	;从顺，受动
		IF TALENT:12:15 == -1 
			TFLAG:193 = + 1 
		ELSE 
			TFLAG:193 = 0 
		ENDIF 
ENDSELECT

@M_KOJO_Moe_DOKUTARGETSYS_K12_LOCK
	CALL RUMIA_MOE_SET_COLOR(MOE_RUMIA)
	PRINTFORMDW 你想要走出黑暗的时候，手被露米娅拉住了
	PRINTFORMW 「现在是露米娅时间……不准去找别人！」
	RESETCOLOR

