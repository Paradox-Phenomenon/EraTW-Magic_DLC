	SIF (CFLAG:12:908 == CHILD_就学) && (CFLAG:12:311 == CFLAG:0:311) && (TALENT:12:7) && !CFLAG:12:906 && (CFLAG:12:14 == 2)
	CALL RUMIA_MOE_MORE_CHILD

	;事件系日记
	CALL M_KOJO_Moe_EVENT_AFTER_TRAIN_DIARYSETTING_K12
	;-------------------------------------------------
