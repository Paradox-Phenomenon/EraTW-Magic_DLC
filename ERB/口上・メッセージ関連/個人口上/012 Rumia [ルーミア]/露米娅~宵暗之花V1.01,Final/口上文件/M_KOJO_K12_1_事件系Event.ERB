	SIF CFLAG:12:1298 
		CFLAG:12:1298 -= 1  

	;夜袭事件的计数
	CFLAG:12:1725 += 1

	;思慕转恋慕计数
	SIF CFLAG:12:1010 
		CFLAG:12:1010 -= 1 

	;恋人阶段锁定思慕用
	SIF ( ABL:12:9 == 9 ) && CFLAG:12:1009 && TALENT:12:7 
