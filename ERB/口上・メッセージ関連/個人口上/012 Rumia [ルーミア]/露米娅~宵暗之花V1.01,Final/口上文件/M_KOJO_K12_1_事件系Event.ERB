;贈り物イベント ;能写，所以需要补充
;==================================================
@M_KOJO_Moe_EVENT_K12_GIFT(ARG, GIFT_ID, 評価点, GIFT_NAME, SENSE)
#DIM GIFT_ID
#DIM 評価点
#DIMS GIFT_NAME
#DIMS SENSE
;---------------------------------------------------------------------------------------------------
;評価点       贈り物の評価点（1～999）,口上主があげた場合でも口上主の評価点
;GIFT_NAME    贈り物の名称
;SENSE        贈り物に設定された属性。STRCOUNT(SENSE, "ほげほげ/")を使うと特定の属性を判定できます。
;GIFT_ID      これ単体では使いません。以下の式内関数を使うとデータを抽出できます（こだわりたい人用）
;　GET_GIFTDATA(GIFT_ID, "回数")    貰った（あげた）回数
;　GET_GIFTDATA(GIFT_ID, "得点")    得点（1～999）,口上テンプレ内では用意されてます。
;　GET_GIFTDATA(GIFT_ID, "日付")    貰った（あげた）日付（1～9999）
;　GET_GIFTDATA(GIFT_ID, "場所")    買った場所（デートの行き先）
;　GET_GIFTDATA(GIFT_ID, "形容詞")  形容詞番号（贈り物_形容詞.erb参照）
;　GET_GIFTDATA(GIFT_ID, "本体")    本体番号（贈り物_本体.erb参照）
;--------------------------------------------------------------------------------------------------
;デート帰りに口上主があなたに贈り物を渡す（陥落や好感度に関わらず親密5以上から発生）;约会回来的时候，角色给你送的礼物(无论沦陷还是好感度，亲密5以上才会产生)
;評価点は701～999（渡すキャラ本人の評価）;评价分数为701 ~ 999(交付角色本人的评价)
;--------------------------------------------------------------------------------------------------
IF ARG == 1
	;PRINTFORMW 「%GIFT_NAME%をあげるから大事に使って」
	;弥补原版没有约会结束后送礼就取消结语的bug

	;SIF !MARK:12:3 
	;CALL M_KOJO_Moe_SPEVENT_K12_3(0)

	RETURN 1
;--------------------------------------------------------------------------------------------------
;一日の終わりに今日貰った贈り物を大事にする（700点以上）;在一天结束时珍惜今天收到的礼物(700点以上)
;--------------------------------------------------------------------------------------------------
ELSEIF ARG == 2
	IF STRCOUNT(SENSE, "かわいい/")
		PRINTFORMW 「好——可爱啊！%MASTERNAME:12%怎么知道有这么可爱的东西呀！」
	ELSEIF 評価点 >= 800
		PRINTFORMW 「这份礼物……好喜欢……露米娅一定会好好珍惜的……」
	ELSE
		PRINTFORMW 「这份礼物……好喜欢……露米娅一定会好好珍惜的……」
	ENDIF
	RETURN 1
;--------------------------------------------------------------------------------------------------
;一日の終わりに今日貰った贈り物をお気に入りにする（↑の大事にするから続き）（700点以上かつ最高得点）;在一天结束的时候，把今天收到的礼物收藏起来(↑我会好好珍惜的，继续)(700分以上，最高得分)
;--------------------------------------------------------------------------------------------------
ELSEIF ARG == 3
	IF STRCOUNT(SENSE, "身につける/")
		PRINTFORMW 「好喜欢！感觉可以戴在身上呢！%MASTERNAME:12%看到了一定会很开心吧！」
	ELSE
		PRINTFORMW 「好喜欢！不行不行！出门也想要随身带着啦！给%MASTERNAME:12%看到了一定会很开心吧！」
	ENDIF
	RETURN 1
;--------------------------------------------------------------------------------------------------
;一日の終わりに今日貰った贈り物をとりあえず保管する（400～699点）;在一天结束时，暂时保管今天收到的礼物(400 ~ 699件)
;--------------------------------------------------------------------------------------------------
ELSEIF ARG == 4
	PRINTFORMW 「很少收到过礼物呢……得好好感谢%MASTERNAME:12%才行！」
	RETURN 1
;--------------------------------------------------------------------------------------------------
;一日の終わりに今日貰った贈り物をこっそり質に入れる（400点未満）;在一天结束的时候，把今天收到的礼物悄悄典当进去(不到400分)
;--------------------------------------------------------------------------------------------------
ELSEIF ARG == 5
	CLEARLINE 1 
	PRINTFORMDW 露米娅看着你赠送的礼物，纠结着到底应该如何处理 	
	PRINTFORMW 「怎么说呢……毕竟是%MASTERNAME:12%送的……果然还是收下吧～」
	PRINTFORMW 「%MASTERNAME:12%是不是忘了露米娅喜欢什么呢……」
	RETURN 1
ENDIF
RETURN 1
