		RELATION:[[百々世]]:[[妹紅]] = 50 ;Mokou
		RELATION:[[百々世]]:[[勇儀]] = 120 ;Yuugi
		RELATION:[[百々世]]:[[幽香]] = 120 ;Yuuka
		RELATION:[[百々世]]:[[マミゾウ]] = 130 ;Mamizou
		RELATION:[[百々世]]:[[ヤマメ]] = 120 ;Yamame
		RELATION:[[百々世]]:[[ラルバ]] = 120 ;Eternity
		RELATION:[[百々世]]:[[早鬼]] = 130 ;Saki
		RELATION:[[百々世]]:[[たかね]] = 70 ;Takane
		RELATION:[[百々世]]:[[魅須丸]] = 70 ;Misumaru
		RELATION:[[百々世]]:[[典]] = 130 ;Tsukasa
		RELATION:[[百々世]]:[[千亦]] = 90 ;Chimata

		RELATION:[[リグル]]:[[萃香]] = 0 ;Suika
		RELATION:[[リグル]]:[[魔理沙]] = 0 ;Marisa
		RELATION:[[リグル]]:[[リグル]] = 0 ;Wriggle
		RELATION:[[リグル]]:[[妹紅]] = 0 ;Mokou
		RELATION:[[リグル]]:[[勇儀]] = 0 ;Yuugi
		RELATION:[[リグル]]:[[マミゾウ]] = 0 ;Mamizou
		RELATION:[[リグル]]:[[早鬼]] = 0 ;Saki
		RELATION:[[リグル]]:[[たかね]] = 0 ;Takane
		RELATION:[[リグル]]:[[魅須丸]] = 0 ;Misumaru
		RELATION:[[リグル]]:[[典]] = 0 ;Tsukasa
		RELATION:[[リグル]]:[[千亦]] = 0 ;Chimata
		RELATION:[[リグル]]:[[ヤマメ]] = 50 ;Yamame

		IF RELATION:[[リグル]]:[[久侘歌]] == 50
			RELATION:[[リグル]]:[[ラルバ]] = 120 ;Eternity
		ELSE
			RELATION:[[リグル]]:[[ラルバ]] = 0 ;Eternity
		ENDIF

		PRINTFORMDL done.
	ENDIF

