	;Hate Mark 1 removed
	;反発刻印消去イベント
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		PRINTFORMW 「Well, you behaved yourself, so I guess I can let you off the hook.」
		PRINTFORMW 「But don't do it again! 'Cause I swear on my mother's grave, next time you get on my bad side I'm gonna settle things the oomukade way!」
		PRINTFORMDW %CALLNAME:[[百々世]]% makes a fist and punches %HIS_HER([[百々世]])% palm for emphasis.
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;Hate Mark 2 removed (changes to Hate Mark 1)
	;反発刻印2>1レベルダウンイベント
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		PRINTFORMW 「You coulda groveled a little more... but I guess you showed enough respect.」
		PRINTFORMW 「I still haven't totally forgiven ya, though.」
		PRINTFORMW 「Just be glad you aren't another oomukade. I'd have to knock a couple teeth out before my honor was avenged.」
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;Hate Mark 3 removed (changes to Hate Mark 2)
	;反発刻印3>2レベルダウンイベント
	;記入チェック（=0, 非表示、1, 表示）
