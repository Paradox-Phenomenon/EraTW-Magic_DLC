VERSION = 14
IF CFLAG:[[百々世]]:1001 == VERSION
	PRINTFORMDL %CALLNAME:[[百々世]]%'s dialogue is at the latest version (v{CFLAG:[[百々世]]:1001 / 100}.{CFLAG:[[百々世]]:1001 / 10}.{CFLAG:[[百々世]]:1001 % 10}).
ELSE
	PRINTFORMDL Updating %CALLNAME:[[百々世]]%'s dialogue to v{VERSION / 100}.{VERSION / 10}.{VERSION % 10}...

	IF CFLAG:[[百々世]]:K142EN_FLAG_VER < 11 && RELATION:[[百々世]]:[[リグル]] == 140
		PRINTFORM Fixing incorrect relations... 

		RELATION:[[百々世]]:[[萃香]] = 130 ;Suika
		RELATION:[[百々世]]:[[魔理沙]] = 150 ;Marisa
