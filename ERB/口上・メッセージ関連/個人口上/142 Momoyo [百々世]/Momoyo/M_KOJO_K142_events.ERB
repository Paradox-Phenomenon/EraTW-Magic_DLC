	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;Standard dialogue
	;通常帰宅
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 0
		IF TALENT:[[百々世]]:恋人
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「Another awesome date with my awesome %PRINT_MALE("boy", MASTER)%friend. 」
					PRINTFORMDW %CALLNAME:[[百々世]]% grins and slaps you on the back.
				CASE 1
