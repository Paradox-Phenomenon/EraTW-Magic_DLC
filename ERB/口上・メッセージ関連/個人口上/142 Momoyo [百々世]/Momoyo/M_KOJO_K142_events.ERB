						PRINTFORMW 「...Never mind. Catch you later!」
					ELSE
						PRINTFORML 「Hey, I think we have time for a quickie before you head back.」
						PRINTFORMW 「You down?」
					ENDIF
				CASE 2
					PRINTFORML 「I had a lot of fun! We should do this again some time.」
					PRINTFORMW 「And maaaaybe a little something afterwards～?」
					PRINTFORMDW %CALLNAME:[[百々世]]% winks and makes finger guns at you.
			ENDSELECT
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「That was a lot of fun!」
					PRINTFORMW 「You really know how to show a %PRINT_MALE("guy", TARGET)% a good time.」
					PRINTFORMDW %CALLNAME:[[百々世]]% winks.
