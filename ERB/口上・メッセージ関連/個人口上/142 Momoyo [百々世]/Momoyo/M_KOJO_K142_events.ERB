	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		PRINTFORML 「Hmph.」
		PRINTFORMDW %CALLNAME:[[百々世]]% scowls at you.
		PRINTFORMW 「I guess I can let you off with a light beating now.」
		PRINTFORMW 「Which limb do you want me to not break?」
		RETURN 1
	ENDIF
	PRINTFORML
ENDIF
RETURN 1

