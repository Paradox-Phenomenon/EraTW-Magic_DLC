;615,お弁当を食べる
;実行可能場所　お地蔵通り,枝垂れ柳の下,霧の湖,玄武の沢,大蝦蟇の池,絶景の丘,山の湖,天界
;TFLAG:193(1=大成功 0=成功 -1=失敗)
;ABL:料理技能(2未満=微妙な出来 4未満=そこそこ美味しい 4以上=絶品)
;==================================================
@M_KOJO_MESSAGE_COM_K142_615
CALL M_KOJO_MESSAGE_COM_K142_615_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K142_615_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF ABL:[[百々世]]:44 >= 3
		PRINTFORML 「Check it out!」
		PRINTFORMDW %CALLNAME:[[百々世]]% grins at you and pulls some food out of a bag.

		SELECTCASE IFRAND("0TO1", 1, "2", (TALENT:セフレ || TALENT:愛欲) && HAS_VAGINA([[百々世]]))
			CASE 0
				PRINTFORMW 「%CHAN_KUN([[百々世]])%'s Carnivore Pizza!」
				PRINTFORML 「It's like pizza, except instead of crust, I used steak.」
				PRINTFORMW 「And instead of cheese, I used shredded pork.」
				PRINTFORMW 「And instead of sauce... well, you get the picture.」

			CASE 1
				PRINTFORMDW Earthworms?!
				PRINTFORML 「Oh crap! Sorry!」
				PRINTFORMDW %CALLNAME:[[百々世]]% snatches the container out of your hands and looks apologetic.
				PRINTFORMW 「That's for me. Earthworm spaghetti with hexapod meatballs and a nice energy drink sauce.」
				CALL PRINT_STRW, @"「@ITALIC@This@ is yours.」"
				PRINTFORML 「She hands you another container. It's full of normal-looking spaghetti and meatballs.」
				PRINTFORMW 「At least, you hope it is.」

			CASE 2
				PRINTFORML 「It's, uh...」
				PRINTFORMDW Why is %HE_SHE([[百々世]])% blushing?
				PRINTFORML 「My special homemade caviar over rice with wasabi and... special homemade sauce.」
				PRINTFORMW 「I put a whole lotta love into it!」
				PRINTFORMDW ...Homemade caviar? What does that mean?
		ENDSELECT
	ELSEIF IS_FALLEN([[百々世]]) && FIRSTTIME("MomoyoTriesToCook", 1)
		PRINTFORML 「I know it ain't great... but I made it for you.」
		PRINTFORMW 「That's what you're supposed to do when you go on a date, right?」
		PRINTFORMDW You open the container.
		PRINTFORMDL It's full of meat, clumsily shredded, lying on a mound of undercooked rice.
		PRINTFORMDW A few straps of carrot lie on top of the meat.
		PRINTFORMDW The whole thing is drenched in so much soy sauce that it's almost a stew.
		PRINTFORMDL
		PRINTFORMDL [0] Compliment it
		PRINTFORMDL [1] Say you don't like it
		PRINTFORMDL [2] Say nothing
		$INPUT_LOOP
		INPUT
		SELECTCASE RESULT
			CASE 0
				PRINTFORMDW %CALLNAME:[[百々世]]% snorts.
				PRINTFORMW 「C'mon, %CALLNAME:MASTER%, you don't gotta lie to spare my feelings. I know it's a mess.」

			CASE 1
				PRINTFORMW 「That's what I figured you'd say.」
				PRINTFORMDW %CALLNAME:[[百々世]]% sighs and takes the container away from you.

			CASE 2
				PRINTFORMW 「That bad, huh?」

			CASEELSE
				GOTO INPUT_LOOP
		ENDSELECT
		PRINTFORMW 「But don't worry. I'm gonna work hard and become the best damn cook on Youkai Mountain!」
		PRINTFORMW 「They say the way to a %PRINT_MALE("man", MASTER)%'s heart is through %HIS_HER(MASTER)% stomach, right?」
		CALLF FIRSTTIME("MomoyoTriesToCook")
	ELSE
		PRINTFORML 「Don't get too excited. I just got some stuff from the mine's cafeteria.」
		PRINTFORMDW %CALLNAME:[[百々世]]% looks apologetic.
		PRINTFORMW 「Sorry, but... I can't cook worth a damn.」
		IF !FIRSTTIME("MomoyoTriesToCook", 1)
			PRINTFORMW 「You learned that the hard way.」
		ELSE
			PRINTFORMW 「Trust me, it's better than anything I'd make.」
		ENDIF
	ENDIF
ENDIF
RETURN 1
