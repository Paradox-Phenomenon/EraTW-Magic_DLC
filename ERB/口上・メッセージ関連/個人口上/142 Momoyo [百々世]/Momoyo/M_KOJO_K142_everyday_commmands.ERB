				ENDSELECT
			ELSE
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「Just so you know, I fell in there on purpose.」
						PRINTFORMW 「Wanted to see if there were any cool minerals down there.」
					CASE 1
						PRINTFORML 「Everyone says I'm crazy for carryin' my pick and shovel everywhere.」
