				CASE 2
					PRINTFORMW 「We can at least cook it rare, can't we?」

				CASE 3
					PRINTFORMW 「Where does this bottle go again?」
					PRINTFORMDW Momoyo opens yet another cabinet and looks inside.
					PRINTFORMDW Maybe you should put away the ingredients instead...

				CASE 4
					PRINTFORMW 「I still say it could use more salt.」
					PRINTFORMW 「Yeah, yeah, I know I can just add as much salt as I want to my portion. I'm just sayin'.」

			ENDSELECT
		ENDIF
	ENDIF
