LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF CFLAG:妊娠自覚状態
		SELECTCASE RAND:3
			CASE 0
				PRINTFORMW 「Hey, y'know I'm pregnant, right?」

			CASE 1
				;PRINTFORMW 「No way. Our %BABYPLNOUN("kid",142)% %BABYPLVERB("isn't",142)% gettin' any booze until they earn it.」

			CASE 2
				PRINTFORML 「I'm pretty sure alcohol ain't good for kids.」
				PRINTFORMW 「Maybe half-oomukade are different, but I don't wanna take that risk.」
		ENDSELECT
	ELSEIF FIRSTTIME("MomoyoServeAlcohol", 1)
		PRINTFORMDL %CALLNAME:[[百々世]]% looks at you suspiciously.
		PRINTFORMW 「You aren't tryin' to pickle me in that, are you? I heard that some humans make wine outta centipedes.」
		PRINTFORMDL %HE_SHE([[百々世]],1)% snickers.
		PRINTFORMW 「Nah, I'm just kiddin'.」
		CALLF FIRSTTIME("MomoyoServeAlcohol")
	ELSE
		IF ALCOHOL_TASTE(TFLAG:194) < 10
			SELECTCASE RAND:3
				CASE 0
					PRINTFORMW 「Eh... this doesn't really suit me.」

				CASE 1
					PRINTFORMW （Gonna need a lot of energy drinks for this one...）

				CASE 2
					PRINTFORMW 「You got somethin' a little less sweet? I like my booze bitter.」
			ENDSELECT
		ELSEIF ALCOHOL_TASTE(TFLAG:194) >= 15
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「Ah...」
					PRINTFORMDW %CALLNAME:[[百々世]]% swirls the drink around in %HIS_HER([[百々世]])% mouth and swallows.
					PRINTFORMW 「That hit the spot. Got any more?」

				CASE 1
					PRINTFORML 「This is good. Damn good.」
					PRINTFORMW 「Bet it'd go great with some dragon steak...」

				CASE 2
					PRINTFORML 「Whoa, this is incredible!」
					PRINTFORMW 「You have some too! It's your booze, after all.」
			ENDSELECT
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「Mmm... it's not bad, but it's missing something...」
					PRINTFORML 「Aha!」
					PRINTFORMDW %CALLNAME:[[百々世]]% pulls an energy drink out of %HIS_HER([[百々世]])% pocket and empties it into %HIS_HER([[百々世]])% cup.
					PRINTFORMW 「Now we're talkin'.」

				CASE 1
					PRINTFORMW 「Hey, this is pretty good!」
					PRINTFORMDL %CALLNAME:[[百々世]]% holds the bottle out to you.
					IF TALENT:[[百々世]]:恋人
						PRINTFORMW 「You wanna share～?」
					ELSEIF TALENT:[[百々世]]:恋慕 || TALENT:[[百々世]]:セフレ || TALENT:[[百々世]]:愛欲
						PRINTFORMW 「Want me to pour you some? Or would you rather drink straight from the bottle～?」
					ELSE
						PRINTFORMW 「Want me to pour you some?」
					ENDIF

				CASE 2
					PRINTFORML 「This ain't half bad!」
					PRINTFORMDW %CALLNAME:[[百々世]]% takes another swig.
			ENDSELECT
		ENDIF
	ENDIF
ENDIF
RETURN 1
