						PRINTFORMW 「So %HE_SHE(138)% sends these things to hassle us.」
						PRINTFORMW 「They're more of an annoyance than anything... but somethin' tells me %HES_SHES(138)% plannin' something big.」
					ENDIF

				CASE 4
					PRINTFORMW 「Y'gettin' tired yet?」
					PRINTFORMW 「I've got plenty of energy drinks if you need one.」
			ENDSELECT
			PRINTFORMDL
			PRINTFORMDW Hauling all these tailings is hard work...
			CALL RECOVER(MASTER, -200, "体力", "Hauling tailings")
			CALL RECOVER(MASTER, -200, "気力", "Hauling tailings")
		ENDIF
	ENDIF
ENDIF
