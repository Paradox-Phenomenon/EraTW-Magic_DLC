@M_KOJO_MESSAGE_COM_K142_416_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	SELECTCASE TFLAG:193
		CASE 1
			IF TALENT:[[百々世]]:恋人
				PRINTFORMDW Momoyo stares at you, awestruck.
				PRINTFORMW 「That was... beautiful...」
				PRINTFORMDW She wipes a tear from her eye.
			ELSEIF TALENT:[[百々世]]:恋慕 || TALENT:[[百々世]]:セフレ || TALENT:[[百々世]]:愛欲
				PRINTFORMDW Momoyo applauds enthusiastically.
				CALL HPH_PRINT, @"「If y'hadn't already stolen my heart, that woulda done it for sureHPH」", "W"
			ELSE
				PRINTFORMW 「Hot damn, that's one catchy tune!」
				PRINTFORMW 「How long've you been playin' for? You've got some real talent.」
			ENDIF

		CASE 0
			IF TALENT:[[百々世]]:恋人
				SELECTCASE RAND:3
					CASE 0
						PRINTFORMDW Momoyo closes her eyes, smiles, and bobs her head to the beat.

					CASE 1
						PRINTFORMW 「I always love listenin' to you play.」
						CALL HPH_PRINT, @"「It makes me fall for you all over againHPH」", "W"

					CASE 2
						PRINTFORMDW Momoyo claps so hard and fast that her hands are a blur.
						PRINTFORMW 「En-core! En-core! En-core! En-core!」

				ENDSELECT
			ELSEIF TALENT:[[百々世]]:恋慕 || TALENT:[[百々世]]:セフレ || TALENT:[[百々世]]:愛欲
				SELECTCASE RAND:3
					CASE 0
						PRINTFORMW 「Wouldn't mind hearin' that outside my window in the middle of the night...」

					CASE 1
						PRINTFORMW (So am I supposed to throw my underwear at %HIM_HER(MASTER)% now?)

					CASE 2
						CALL HPH_PRINT, @"「Cute and talented? That's just my typeHPH」", "W"

				ENDSELECT
			ELSE
				SELECTCASE RAND:3
					CASE 0
						PRINTFORMDW Momoyo applauds politely as you finish your song.

					CASE 1
						PRINTFORMW 「Can you play a little louder? My hearing ain't that good.」

					CASE 2
						PRINTFORMW 「Hey, you're pretty good.」
						PRINTFORMW 「Didn't recognize that tune, though. What's it called?」

				ENDSELECT
			ENDIF

		CASE -1
			IF TALENT:[[百々世]]:恋人
				PRINTFORMDW Momoyo has her hands over her ears.
				IF ABL:MASTER:音楽技能 < 3
					PRINTFORMW 「...You might wanna try singin' instead.」
				ELSE
					PRINTFORMW 「What happened, %CALLNAME:MASTER%? I know y'can play better than that!」
				ENDIF

			ELSEIF TALENT:[[百々世]]:恋慕 || TALENT:[[百々世]]:セフレ || TALENT:[[百々世]]:愛欲
				PRINTFORML 「Stop! Stop!」
				PRINTFORMDW Momoyo claps her hands over her ears.
				PRINTFORMW 「Why don't ya do somethin' else with those hands of yours?」

			ELSE
				PRINTFORMW 「Oi! Cut that out!」
				PRINTFORMW 「You tryin' to deafen me?!」
				PRINTFORMDW Momoyo scowls at you.

			ENDIF

	ENDSELECT
ENDIF
RETURN 1
