;Hate Mark
;反発刻印
IF TFLAG:21 == 1
	PRINTFORMW 「Hey! Knock it off!」
ELSEIF TFLAG:21 == 2
	PRINTFORML 「Look, buddy, you're really starting to get on my nerves.」
	PRINTFORMW 「You'd better watch yourself before I take a chunk outta you.」
ELSEIF TFLAG:21 == 3
	IF TEQUIP:[[百々世]]:縄
		PRINTFORMDW %CALLNAME:[[百々世]]% struggles with all %HIS_HER([[百々世]])% might, but %HE_SHE([[百々世]])% can't break the ropes.
		PRINTFORMW 「Damn you...」
		PRINTFORMW 「When I get outta these ropes, I'm gonna break every bone in your body!」
	ELSE
		PRINTFORMW 「All right, that's it! I'm kickin' your ass!」
		PRINTFORMDW %CALLNAME:[[百々世]]% stretches, cracks %HIS_HER([[百々世]])% neck from side to side, and grabs you.
		PRINTFORMDW One second you're on the ground, the next you're in the air, spinning around... and then you slam into the ground head-first.
		CALL RECOVER(MASTER, -3000, "体力", "Spinning Piledriver")
		CALL PRINT_STRW, @"「I warned you. Now get the hell away from me before I @ITALIC@really@ mess you up.」"
	ENDIF
ENDIF
