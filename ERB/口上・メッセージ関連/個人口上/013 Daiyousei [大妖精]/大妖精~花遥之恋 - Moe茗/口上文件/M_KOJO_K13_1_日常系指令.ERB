@M_KOJO_Moe_MESSAGE_COM_K13_301_1
;-------------------------------------------------
;启用（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	PRINTL 
	IF TALENT:13:7 && 0  ;待补充
		SELECTCASE RAND:5 
			CASE 0 
				PRINTFORML 
				PRINTFORML 
				PRINTFORML 
			CASE 1 
				PRINTFORML 
				PRINTFORML 
				PRINTFORML 
			CASE 2 
				PRINTFORML 
				PRINTFORML 
				PRINTFORML 
			CASE 3 
				PRINTFORML 
				PRINTFORML 
				PRINTFORML 
			CASE 4 
				PRINTFORML 
				PRINTFORML 
				PRINTFORML 
		ENDSELECT 
	ELSEIF TALENT:13:3 && RAND:5 
		SELECTCASE RAND:4  
			CASE 0 
				PRINTFORML 「%MASTERNAME:13%想喝茶了嘛？嗯嗯，那我来好嘛？」
				PRINTFORMDL 大妖精抢着想要泡茶，索性让她自己泡了起来
				PRINTFORMDL 只用茶壶少了很少的水，茶叶也放得少了一些
				PRINTFORMDL 不过，斟茶的动作因此变得轻松了，泡出来的茶……
				PRINTFORML 「诶嘿嘿，泡茶泡得好喝就对了嘛，才不管加了什么呢……」
				PRINTFORMDL 果然是装着方糖的小袋子！就说刚刚为什么大妖精背着手泡茶嘛……
			CASE 1 
				PRINTFORML 「%MASTERNAME:13%又要泡蜂蜜茶了呢，好期待噢～♪」
				PRINTFORMDL 看着大妖精开心得晃起双腿的样子，不由得多放了一些蜂蜜
				PRINTFORML 「呜哇！加，加那么多什么的，会变胖的啦」
				PRINTFORMDL 想象着大妖精变胖了一些的样子……不由得笑了出来 
				PRINTFORML 「诶呀笑什么啦！女孩子肯定要在意自己的体重的……」
			CASE 2 
				PRINTFORML 「喜欢哪种茶……呜……」
				PRINTFORMDL 同时泡了一杯红茶和一杯绿茶，让大妖精自己选
				PRINTFORML 「这个随便啦！只要是%MASTERNAME:13%泡的茶，都很甜噢……」
				PRINTFORML 「就连%MASTERNAME:13%也……啊！没，没什么……」
				PRINTFORMDL 说着说着自己都脸红了……
			CASE 3 
				PRINTFORMDL 在你泡茶的时候，大妖精聚精会神地看着你的动作……
				PRINTFORML 「诶？啊！那个，因为想学一学%MASTERNAME:13%的手法……」
				PRINTFORML 「人家也想泡出%MASTERNAME:13%那样的茶，作为心意，什么的……」
				PRINTFORMDL 捧着茶水的大妖精，脸颊也随着话语微微泛红了
				PRINTFORMDL 下次就由她来泡吧？不禁这样想着
			CASE 4 
				PRINTFORML 
		ENDSELECT 
	ELSEIF (TALENT:13:8 || TALENT:13:3) && RAND:5 
		SELECTCASE RAND:7 
			CASE 0,1
				IF !RAND:2 
					PRINTFORML 「是茶嘛？嗯嗯，那人家就不客气了噢……」
					PRINTFORMDL 大妖精用双手端过了茶杯，低着脑袋脸颊微红的样子
					PRINTFORMDL 将茶水端到嘴前轻轻抿了一口，偷偷抬着眼睛瞄着你……
					PRINTFORML 「啊！没什么……很，很好喝噢……」
					PRINTFORMDL 似乎并没有完全留意茶水味道的样子……
				ELSE 
					PRINTFORML 「哇……闻起来好香噢……」
					PRINTFORMDL 大妖精用双手端过茶杯，用指尖感受着茶杯的温度
					PRINTFORML 「很，很暖和……没那么烫，是特意冷了冷嘛？」
					PRINTFORMDL 因为怕大妖精烫到，所以稍微加了一些凉开水
					PRINTFORML 「哇！谢谢你……」
				ENDIF 
			CASE 2 
				PRINTFORMDL 因为大妖精喜欢吃甜食，所以给她准备了奶茶
				PRINTFORML 「哇！这个……谢，谢谢你！我不客气啦！」
				PRINTFORMDL 大妖精接过奶茶，迫不及待地喝了一口 
				PRINTFORML 「那个……%MASTERNAME:13%喜欢喝这个嘛……」
				PRINTFORML 「喜欢的话，那%MASTERNAME:13%也试试嘛！真的很好喝！」
			CASE 3 
				PRINTFORMDL 只是喝茶的话有点太单调了，给大妖精准备了点心
				PRINTFORML 「诶？这个是饼干嘛？谢谢%MASTERNAME:13%！」
				PRINTFORMDL 大妖精将饼干用牙齿轻轻咬住，伴着咔嚓的声音咬了一口
				PRINTFORMDL 似乎是饼干太好吃了，大妖精的眼睛都亮了起来，将剩下的饼干一次塞进嘴里
				PRINTFORML 「呜……唔嗯，很，很好吃！」
				PRINTFORMDL 就连嘴角沾上饼干屑了，也没有注意到……
			CASE 4 
				PRINTFORMDL 因为大妖精喜欢喝花茶，所以自然是往茶杯里放了花瓣
				PRINTFORML 「今天也是花茶嘛？诶嘿嘿……」
				PRINTFORMDL 大妖精将茶杯捧在手心，还没等冷下来就喝了一口
				PRINTFORML 「呜！哇……有点，有点烫……诶嘿嘿，人家太急了……」
				PRINTFORMDL 大妖精吐着被烫到的舌头，不好意思地吹起了热气
				PRINTFORML 「呼……只是花香也很好闻噢，我不客气啦——」
			CASE 5
				PRINTFORML 「谢谢%MASTERNAME:13%的茶呢！诶嘿嘿……」
				PRINTFORMDL 不知为何，大妖精看上去有些害羞，但是又很开心地笑着
				PRINTFORML 「因为，妖精们都是直接喝露水，茶什么的，很少能喝到……」
				PRINTFORML 「不管是茶还是%MASTERNAME:13%都很棒……啊……没，没什么……」
				PRINTFORMDL 似乎不小心说出了心里话，大妖精的脸颊瞬间红透了 
			CASE 6 
				PRINTFORML 「那，那个，让我也来泡一下试试，可以嘛……」
				PRINTFORMDL 大妖精拿起茶壶，小心地地向茶杯中撒进茶叶
				PRINTFORMDL 倒热水的时候小心翼翼地，手指尖都在微微颤抖着
				PRINTFORMDL 不由得将茶壶的把手和她的小手一起握住……
				PRINTFORML 「哇！那个，我，我自己，自己来啦……」
				PRINTFORMDL 大妖精的脸蛋瞬间红透了，低下脑袋不敢动一下手……
		ENDSELECT 
	ELSEIF CFLAG:13:1001 
		IF TFLAG:193 < 0  
			SELECTCASE RAND:3
				CASE 0 
					PRINTFORML 「那个……这个味道，好苦噢……」
					PRINTFORML 「人家不喜欢苦茶啦……先苦后甜也好呀」
					PRINTFORMDL 大妖精将抿了一口的茶放在一旁……
				CASE 1 
					PRINTFORML 「呜……那个……」
					PRINTFORMDL 大妖精喝了一口茶之后，眉头微微皱了起来
					PRINTFORML 「人家就算是妖精，也能喝出茶叶的品质噢……」
				CASE 2 
					PRINTFORML 「那个……茶的种类，能换一下嘛？」
					PRINTFORML 「天天只喝一种茶当然容易腻嘛……」
					PRINTFORMDL 大妖精有些不太情愿地喝着茶……
			ENDSELECT 
		ELSE 
			SELECTCASE RAND:5 
				CASE 0 
					PRINTFORML 「是红茶嘛？嗯嗯，我试试噢……」
					PRINTFORMDL 大妖精小心地接过茶杯，轻轻吹了吹热气
					PRINTFORML 「好香噢，有一点甜甜的味道，很好喝噢」
					PRINTFORMDL 大妖精将茶杯捧在手心，小口小口地啜吸着茶水
				CASE 1 
					PRINTFORML 「那个……这个是什么花呀？」
					PRINTFORMDL 因为大妖精看上去很喜欢花香，所以给大妖精泡了茉莉花茶
					PRINTFORML 「诶嘿嘿，那个，很好喝噢，比平常的茶更让人清爽」
					PRINTFORMDL 是因为喝到了喜欢的味道嘛？大妖精歪着脑袋微笑了起来
				CASE 2 
					PRINTFORML 「这个罐子……是蜂蜜吗？！」
					PRINTFORMDL 看见你拿出蜂蜜罐子，大妖精有些好奇地凑近了过来
					PRINTFORMDL 果然妖精都抵挡不住甜食的诱惑呢……
					PRINTFORMDL 将加好蜂蜜的茶端给大妖精，她尝了一口之后，两眼都发光了
					PRINTFORML 「哇……本来有点苦的茶，变得甜甜的，超好喝噢……」
				CASE 3 
					PRINTFORML 「虽然我也会泡茶噢，但是，可以的话还是希望你来……」
					PRINTFORML 「那当然是因为，%MASTERNAME:13%泡的茶很好喝啦」
					PRINTFORML 「能让不喜欢喝茶的妖精静下来喝茶，%MASTERNAME:13%泡的茶就有这种魔力噢」
					PRINTFORMDL 没看出来大妖精不喜欢喝茶……真的是因为茶很好喝吗？
				CASE 4 
					PRINTFORML 「诶？同时泡了两杯……不一样的？」
					PRINTFORMDL 泡了一杯红茶和一杯绿茶，让大妖精自己选了一杯
					IF !RAND:10 && TFLAG:193 > 0  
						PRINTFORMDL 似乎两杯泡得都很好，大妖精歪着脑袋纠结了很久
						PRINTFORMDL 最后……两杯都端到了自己的面前
						PRINTFORML 「嘻嘻……我都想喝，可以嘛？」
						PRINTFORMDL 看着大妖精的笑容，有些没法拒绝……
					ELSEIF !RAND:2 
						PRINTFORMDL 稍微歪着脑袋想了一会之后，大妖精选了红茶
						PRINTFORML 「因为红茶有水果的香味！而且甜甜的，很好喝……」
						PRINTFORMDL 大妖精含着甜甜的茶水品味着，笑容也变得甜甜的啦
					ELSE 
						PRINTFORMDL 大妖精纠结了很久，终于还是选择了绿茶
						PRINTFORML 「因为绿茶很提神！一口下去，满满的都是清香……呼——」
						PRINTFORMDL 每喝一口绿茶大妖精便吐出一口气，让空气也变得充满了清新味道
					ENDIF 
			ENDSELECT 
		ENDIF 
	ELSE 
		SELECTCASE RAND:4 
			CASE 0 
				PRINTFORML 「怎，怎么啦……」
				PRINTFORMDL 大妖精看着你给的茶，有些怀疑的样子
				PRINTFORML 「那个！把你自己的那杯给我！不然我不喝……」
				PRINTFORMDL 警戒意识还是很强呢……
			CASE 1 
				PRINTFORML 「茶嘛……嗯，谢，谢谢……」
				PRINTFORMDL 大妖精颤抖着手接过茶
				PRINTFORMDL 不知是因为很烫还是紧张，茶托撞着茶杯叮叮当当地响个不停……
				PRINTFORML 「那，那个……没，没什么的说……」
			CASE 2 
				PRINTFORML 「那个……我，我不需要的……谢谢……」
				PRINTFORMDL 虽然嘴上拒绝了茶，但是真的端给大妖精的时候，她还是害怕地接了过去……
				PRINTFORMDL 但是……放在一边并没有喝？
				PRINTFORML 「啊！因为，因为很烫……不行吗？」
			CASE 3 
				PRINTFORML 「嗯？是花瓣的香味……诶？给我吗？」
				PRINTFORMDL 给大妖精端上花茶的时候，她惊讶地抬起了脑袋
				PRINTFORML 「哇……这个……嗯，谢，谢谢你……」
				PRINTFORMDL 吹了吹热气之后稍微抿了一口，看起来很中意这个味道
			CASE 4 
				PRINTFORML 
				PRINTFORML 
				PRINTFORML 
		ENDSELECT 
	ENDIF 
ENDIF
PRINTW 
RETURN 1
