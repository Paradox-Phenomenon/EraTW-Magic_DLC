@M_KOJO_Moe_MESSAGE_COM_K13_309_1
;-------------------------------------------------
;启用（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	PRINTL 
	;時間停止中
	IF FLAG:70
	;睡眠中
	ELSEIF CFLAG:睡眠
	;通常
	ELSE
		IF FIRSTTIME("309_1_0")
			IF (TALENT:13:3 || TALENT:13:8) && 0 

			ELSE 
				PRINTFORML 「哇！哇呜！%MASTERNAME:13%要干什么——」
				PRINTL 
				PRINTFORMDL 想将手伸向大妖精的脑袋，她却吓得跳了起来
				PRINTL 
				PRINTFORML 「摸，摸头嘛……这，这样会不会有点……」
				PRINTL 
				PRINTFORMDL 虽然嘴上说着拒绝的话，可是她的身体却没有逃开
				PRINTFORMDL 将手放在大妖精的头上，她便忍不住抖了抖身体
				PRINTL 
				PRINTFORML 「呀……有点，暖暖的，很舒服……」
				PRINTL 
				PRINTFORMDL 大妖精眯起眼睛享受着抚摸，翅膀也随着你的动作微微扇动着
				PRINTFORMDL 摸着摸着，原本有些困惑的表情也变得放松了下来，微微地笑了起来
				PRINTL 
				PRINTFORML 「……诶？哇！摸了多久呀……」
				PRINTL 
				PRINTFORMDL 直到收回了手，大妖精才反应了过来，慌忙从你身边跳开
				PRINTFORMDL 不好意思地掐着裙子，脸上也泛起了红晕
				PRINTL 
				PRINTFORML 「那个……谢谢……这样，没关系噢」
				PRINTFORML 「想摸的话，跟，跟人家说就好……」
			ENDIF 
		ELSEIF TALENT:13:3 && RAND:5
			SELECTCASE RAND:5 
				CASE 0 
					PRINTFORML 「那个……听说摸多了会长不高呀……」
					PRINTFORMDL 享受着大妖精头发的触感时，她有些担心地反问了回来
					PRINTFORMDL 不过从认识到现在大妖精也没有长高过……
					PRINTFORML 「呜，那肯定是因为%MASTERNAME:13%摸太多了啦……」
					PRINTFORMDL 虽然小声责怪着，但是大妖精完全没有不想要摸头的样子
				CASE 1	
					PRINTFORML 「哇！%MASTERNAME:13%想要摸头嘛……」
					PRINTFORMDL 才刚伸出手，大妖精便微微低下脑袋，乖巧地接受了抚摸
					PRINTFORMDL 像是小动物一样，不仅是顺从了你的动作，还主动蹭着你的掌心
					PRINTFORML 「诶嘿嘿……有点，想要更多的摸摸……」
					PRINTFORMDL 即便是低着脑袋，大妖精还是露出了像是花儿一样的微笑 
				CASE 2
					PRINTFORML 「那个……有点……呜！——」
					PRINTFORMDL 摸着摸着，大妖精便忍不住凑得更近，几乎要贴在你身上了
					PRINTFORMDL 索性轻轻搂住了她的后背，保持着拥抱的姿势摸着她的脑袋
					PRINTFORML 「……呜……才，才没有……想，这样……」
					PRINTFORMDL 能明显地感觉到她的体温越来越高，心跳声也变得越来越快…… 
				CASE 3
					PRINTFORML 「%MASTERNAME:13%的手……好温柔……」
					PRINTFORMDL 大妖精低着脑袋红透了脸颊，声音也颤抖着越来越小
					PRINTFORMDL 那可爱的脸蛋红得跟苹果似的，就连耳朵尖上都泛起了红晕 
					PRINTFORML 「咿呀！耳朵……耳朵不能碰……」
					PRINTFORMDL 虽然身体都吓得跳了起来，大妖精却没有逃开
					PRINTFORMDL 不由得更进一步的摸弄着她的耳朵，直到连耳朵也红透了……
				CASE 4
					PRINTFORMDL 即便大妖精盯着你伸出的手……但还是摸上了她的脑袋
					PRINTFORML 「哇呜！……%MASTERNAME:13%……欺负人……」
					PRINTFORMDL 虽然嘴上说着生气的话，可大妖精却完全没有躲开的意思
					PRINTFORMDL 故意放轻动作时，她又不满地嘟起了小嘴，主动往你手里蹭了蹭
					PRINTFORML 「呜……不要放开好嘛……欺负一下，也没关系……」
			ENDSELECT 
		ELSEIF (TALENT:13:8 || TALENT:13:3)&& RAND:4
			SELECTCASE RAND:5 
				CASE 0 
					PRINTFORML 「呜！%MASTERNAME:13%的手……」
					PRINTFORMDL 才刚伸出手，大妖精便微微低下脑袋，乖巧地接受了抚摸
					PRINTFORMDL 像是小动物一样，不仅是顺从了你的动作，还主动蹭着你的掌心
					PRINTFORML 「嘻嘻……这样的感觉，很不错噢……」
					PRINTFORMDL 为了夸奖这样的大妖精，稍微多抚摸了一小会
				CASE 1	
					PRINTFORML 「……嗯……呜哇！」
					PRINTFORMDL 趁着大妖精发呆的时候，将手搭在了她的头上
					PRINTFORML 「哇……趁着人家不注意的时候……」
					PRINTFORMDL 虽然小声地责怪着你，但是大妖精似乎并不讨厌这样
					PRINTFORMDL 她的脸上露出了微微的笑容，翅膀也轻轻地扇动着
				CASE 2
					PRINTFORMDL 想伸出手抚摸大妖精的脑袋时，被她有些气鼓鼓地盯了过来
					PRINTFORML 「真是的，就这么想摸人家嘛……呜……」
					PRINTFORMDL 即便表情保持着有点生气的样子，大妖精却低下了脑袋
					PRINTFORMDL 看来是默许了摸头呢，那自然是伸出手贴在头发上摸了起来
					PRINTFORML 「……嗯，呜……真是一点都不客气呢……」
				CASE 3
					PRINTFORML 「那个……%MASTERNAME:13%……」
					PRINTFORML 「摸人家的脑袋什么的，很好玩嘛？」
					PRINTFORMDL 被摸着脑袋的大妖精抬起了脑袋，歪着脸蛋有些疑惑的样子
					PRINTFORML 「因为，因为……摸头什么的，是那些小妖精才会想要的事」
					PRINTFORML 「但是，人家却有点像她们那样了，而且，也不讨厌……」
					PRINTFORMDL 说到这里的大妖精又低下了脑袋，脸颊上泛起了红晕
					PRINTFORMDL 不过她的表情却是微微地笑着，似乎还是很享受着摸头的感觉
				CASE 4
					PRINTFORML 「%MASTERNAME:13%真是的……总喜欢这样……」
					PRINTFORMDL 大妖精低下了脑袋，任由你的手指穿过那柔软的发丝
					PRINTFORMDL 顺着柔顺的头发梳理下来，让原本有些紧张的她也放松了些许
					PRINTFORML 「……这样的话，%MASTERNAME:13%……会很高兴嘛？」
					PRINTFORMDL 听到了肯定的回答，大妖精的脸上露出了微微的笑容，马上又脸红了些许
			ENDSELECT 
		ELSE 	
			SELECTCASE RAND:5 
				CASE 0 
					PRINTFORML 「哇！%MASTERNAME:13%……」
					PRINTFORMDL 虽然摸上去的时候，大妖精紧张地缩了缩脖子
					PRINTFORMDL 不过，马上又往你的掌心里蹭了蹭，享受着手心的温暖
					PRINTFORML 「诶嘿嘿……很暖和噢」
				CASE 1	
					PRINTFORML 「%MASTERNAME:13%的手掌……原来有这样的感觉噢……」
					PRINTFORMDL 大妖精享受着抚摸，翅膀也随着你的动作微微扇动着
					PRINTFORMDL 那柔顺的头发在手心里流动着，似乎都没法握住似的
				CASE 2
					PRINTFORML 「%MASTERNAME:13%想摸人家的头嘛？嗯嗯，可以噢」
					PRINTFORMDL 大妖精乖巧地端坐了下来，双手交叠着按在裙摆之间
					PRINTFORMDL 用手拂过大妖精的头发，轻轻的摸着她的脑袋
					PRINTFORML 「哇……嘿嘿，有种被夸奖的感觉……」
				CASE 3
					PRINTFORML 「那个……这个，只是朋友之间的礼仪……吧？」
					PRINTFORMDL 似乎是有些太习惯抚摸了，大妖精有些不安地低下了脑袋
					PRINTFORMDL 不过并没有想要逃开的意思，反而是微微地靠近了你
					PRINTFORML 「是的话，那就，那就多摸一下嘛……」
				CASE 4
					PRINTFORML 「诶……这样，不觉得，有点奇怪嘛……」
					PRINTFORMDL 大妖精的脸上泛起了红晕，低下脑袋小声嘀咕着
					PRINTFORMDL 不过并没有要推开的意思，而是安静地接受着抚摸
					PRINTFORML 「不过，是%MASTERNAME:13%的话……诶嘿嘿……」
			ENDSELECT 
		ENDIF 
	ENDIF
ENDIF
PRINTW 
RETURN 1
