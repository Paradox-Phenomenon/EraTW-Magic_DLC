;==================================================
@M_KOJO_Moe_MESSAGE_MESSAGECHECK_COM_K13_300
RETURN 0

@M_KOJO_Moe_MESSAGE_COM_K13_300
;指令共通メッセージ(TRAIN_MESSAGE) 
;4.920之前的指令地文，是使用函数TRAIN_MESSAGE来控制的
;如果删除它，例如「TARGET和你无聊地说着话」这种叙述将不显示，且您的口上不会自动启用口上色
;下面是调用口上的主函数
CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1
RETURN RESULT

@M_KOJO_Moe_MESSAGE_COM_K13_300_1
;-------------------------------------------------
;启用（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	PRINTL 
	;请在这个区间里输入口上的输出内容
		;成为朋友\放下戒心
	SIF !CFLAG:13:1001
	CALL Moe_DAI_FIRST_BECOME_FRINED
	SIF RESULT == 1 
		RETURN 1

	$M_KOJO_Moe_MESSAGE_COM_K13_300_1_START
	;约会期间可能触发
	IF FLAG:73 == 13 
		;愤怒？
		SIF CFLAG:318 == 1
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_14 
		SIF RESULT == 1 
			RETURN 1

		;会话失败 
		SIF TFLAG:193 < 0 
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_11 
		SIF RESULT == 1 
			RETURN 1

		;醉酒对话
		SIF BASE:13:15 > MAXBASE:13:15 / 2
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_13 
		SIF RESULT == 1 
			RETURN 1

		;天气对话
		SIF ONCE("K13_REACT_FOR_WEATHER") && !RAND:3
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_4
		SIF RESULT == 1 
			RETURN 1

		;位置对话
		SIF  !RAND:3
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_5
		SIF RESULT == 1 
			RETURN 1

		;约会对话
		SIF  !RAND:3 
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_6
		SIF RESULT == 1 
			RETURN 1

		;恋人对话
		SIF TALENT:13:7 && RAND:3 > RAND:2
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_7
		SIF RESULT == 1 
			RETURN 1
		
		;恋慕对话
		SIF TALENT:13:3 && RAND:5 > RAND:4
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_8
		SIF RESULT == 1 
			RETURN 1

		;炮友对话
		SIF MOE_DAI_SEX_FRIEND() && RAND:2
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_10
		SIF RESULT == 1 
			RETURN 1		
		
		;思慕对话
		SIF TALENT:13:8 && RAND:4 > RAND:3
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_9
		SIF RESULT == 1 
			RETURN 1

		;剧情相关
		SIF CFLAG:13:1001 && !RAND:2
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_2
		SIF RESULT == 1 
			RETURN 1

		;设定相关
		CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_1
		SIF RESULT == 1 
			RETURN 1

	;非约会
	ELSE 

		;愤怒？
		SIF CFLAG:318 == 1
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_14 
		SIF RESULT == 1 
			RETURN 1

		;会话失败 
		SIF TFLAG:193 < 0 
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_11 
		SIF RESULT == 1 
			RETURN 1

		;醉酒对话
		SIF BASE:13:15 > MAXBASE:13:15 / 2
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_13 
		SIF RESULT == 1 
			RETURN 1

		;天气对话
		SIF ONCE("K13_REACT_FOR_WEATHER") && !RAND:7
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_4
		SIF RESULT == 1 
			RETURN 1

		;季节对话
		SIF ONCE("K13_REACT_FOR_SEASON") && !RAND:7
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_3
		SIF RESULT == 1 
			RETURN 1

		;联动对话
		SIF ONCE("K13_REACT_FOR_OTHER") && !RAND:10
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_12
		SIF RESULT == 1 
			RETURN 1

		;位置对话
		SIF RAND:3 
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_5
		SIF RESULT == 1 
			RETURN 1

		;恋人对话
		SIF TALENT:13:7 && !RAND:3
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_7
		SIF RESULT == 1 
			RETURN 1
		
		;恋慕对话
		SIF (TALENT:13:3 && !RAND:3) || (TALENT:13:3 && TALENT:13:7 && (RAND:5) )
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_8
		SIF RESULT == 1 
			RETURN 1

		;炮友对话
		SIF MOE_DAI_SEX_FRIEND() && RAND:2
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_10
		SIF RESULT == 1 
			RETURN 1		

		;思慕对话
		SIF TALENT:13:3 && RAND:3
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_9
		SIF RESULT == 1 
			RETURN 1

		;剧情相关
		SIF CFLAG:13:1001 && RAND:2
			CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_2
		SIF RESULT == 1 
			RETURN 1

		;设定相关
		CALL M_KOJO_Moe_MESSAGE_COM_K13_300_1_Custom_1
		SIF RESULT == 1 
			RETURN 1
		;
		GOTO M_KOJO_Moe_MESSAGE_COM_K13_300_1_START
	ENDIF 
	;
ENDIF
PRINTW 
RETURN 1
