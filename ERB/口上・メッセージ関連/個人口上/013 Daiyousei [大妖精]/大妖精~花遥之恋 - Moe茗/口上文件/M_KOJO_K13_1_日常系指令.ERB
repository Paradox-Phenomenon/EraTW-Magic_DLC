IF LOCAL
	PRINTL 
	;并不是都需要写，部分内容可以合并在一起
	IF FLAG:70 
		IF TALENT:13:7 
			PRINTFORMDL 在时间停止的状态下，将心爱的大妖精抱了起来
			PRINTFORMDW 想必是恋人的她会允许吧？怀着些许罪恶感将大妖精推倒了
		ENDIF 
	ELSEIF TFLAG:194 
		;非初次，拒绝
		SELECTCASE TFLAG:194
			CASE 1,2,3 		;有路人;不想在户外做;不想多人一起做
				IF TALENT:13:7 
					PRINTFORML 「这！这里！那个……」
					PRINTFORMW 「……会被当成，欺负妖精的大坏蛋噢……」
					PRINTFORMDL 
					PRINTFORMDL 看着紧抓着裙摆不放的大妖精，自己也有些害羞了……
					PRINTFORMDW 那，去没人的地方的话……
					PRINTFORMDL 
					PRINTFORMW 「哇！才，才没有说可以……别，别盯着人家啦！」
				ELSE 
					PRINTFORMW 「在这里……嗯？什么啊！」
					PRINTFORML 
					PRINTFORMDW 大妖精顿时抓住裙摆大叫了起来，看向你的表情又羞又恼
					PRINTFORMDW 啊……在这个地方确实不该这么说……
				ENDIF 
			CASE 4 		;还没有做的心情（即使有合意）
				IF TALENT:13:7 
					IF BASE:13:10 > BASE:13:11  
						PRINTFORMW 「诶嘿嘿……那个，只是抱抱可以嘛？」
						PRINTFORMDW 主动抱了过来的大妖精，小脸上只是满满的欢喜与期待 
						PRINTFORMDW 不由得挠了挠这可爱妖精的鼻尖，和她毫无邪念地打闹了起来
					ELSE 
