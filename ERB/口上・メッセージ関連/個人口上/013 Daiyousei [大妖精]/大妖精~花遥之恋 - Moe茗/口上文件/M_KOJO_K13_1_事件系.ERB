						PRINTFORMDL 大妖精像是耍赖一样，蹲在地上不肯走了……
						PRINTFORMDL 只能抱起耍起小脾气的大妖精跑回了家……
					CASE 2 
						PRINTFORML 「啊？就回家吗，明明才一小会儿……」
						PRINTFORML 「要%MASTERNAME:13%背着回去！不然……呜哇！」
						PRINTFORMDL 大妖精那轻盈的身体抱着会更轻松，索性用公主抱的姿势抱住了她
						PRINTFORMDL 在她红着脸蛋却又一脸不爽的注视下，抱着她回到了家
				ENDSELECT
			ELSE 
				SELECTCASE RAND:5 
					CASE 0 
						PRINTFORML 「啊咧？就，就回去嘛……」
						PRINTFORML 「那个……没，没关系的说……」
						PRINTFORMDL 大妖精似乎没玩够的样子……
					CASE 1 
						PRINTFORML 「那个……嗯，没，没关系……」
						PRINTFORML 「能出门玩就，挺好的，真的没关系啦……」
					CASE 2 
						PRINTFORML 「就回家嘛？还，还没……」
						PRINTFORML 「还没玩够呢……啊！没，没什么……」
				ENDSELECT
			ENDIF 
		ENDIF 
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;反発刻印从1到消去
	;启用（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		IF TALENT:13:3 || TALENT:13:7
			PRINTFORML 「……笨蛋……不用那么怕我啦……」
			PRINTFORML 「上次的事，下不为例噢」
		ELSE 
			PRINTFORML 「那个……我原谅你了噢」
			PRINTFORML 「不要再用那样的眼神偷偷看我啦……」
		ENDIF 
		PRINTFORMDL 大妖精似乎没那么生气了
		PRINTW 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;反発刻印从2降级到1
	;启用（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		IF TALENT:13:3 || TALENT:13:7
			PRINTFORML 「对不起……请再让我生一会气……」
			PRINTFORML 「因为%MASTERNAME:13%确实是好过分……」
		ELSE 
			PRINTFORML 「我不觉得%MASTERNAME:13%是坏人……」
			PRINTFORML 「但是，也不太想相信你……」
		ENDIF 
		PRINTFORMDL 大妖精对你的态度温和了一些
		PRINTW 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;反発刻印从3降级到2
	;启用（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		IF TALENT:13:3 || TALENT:13:7
			PRINTFORML 「不要再做坏事了，可以吗」
			PRINTFORML 「因为%MASTERNAME:13%是我重要的人……」
		ELSE 
			PRINTFORML 「我还想，和%MASTERNAME:13%做朋友……」
			PRINTFORML 「但是……我……我还是怕你做那种事……」
		ENDIF 
		PRINTFORMDL 大妖精似乎没那么害怕你了
		PRINTW 
		RETURN 1
	ENDIF
	PRINTFORML
ENDIF
RETURN 1

