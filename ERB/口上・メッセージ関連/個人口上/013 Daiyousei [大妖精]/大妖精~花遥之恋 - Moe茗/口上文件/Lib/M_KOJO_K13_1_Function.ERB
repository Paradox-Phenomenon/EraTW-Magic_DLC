;==================================================
;充填率_OF_DAI检测函数
;避免不同版本充填率函数定义不一样
;==================================================

;身体部位 1=V, 2=A, 3=VA 4= 子宮
@充填率_OF_DAI(角色登録番号, 身体部位)
#FUNCTION
#DIM 角色登録番号
#DIM 身体部位
#DIM 精液量
#DIM 身体容量

VARSET 精液量

;該当部位の精液量の取得
SELECTCASE 身体部位
	CASE 1
		精液量 = EX:角色登録番号:14
	CASE 2
		精液量 = EX:角色登録番号:15
	CASE 3
		;------ ALTER 精液填充加算
		精液量 = EX:角色登録番号:14 + EX:角色登録番号:15 + (EX:角色登録番号:18)
		;------ END
		;精液量 = EX:角色登録番号:14 + EX:角色登録番号:15
	CASE 4
		精液量 = EX:角色登録番号:18
ENDSELECT

;該当部位の容量を取得
SELECTCASE TALENT:角色登録番号:体型
	CASE -5
		身体容量 = 300
	CASE -4 TO -2
		身体容量 = 600
	CASE -1
		身体容量 = 1000
	CASE 0
		身体容量 = 1200
	CASE IS > 0
		身体容量 = 1500
ENDSELECT

;子宮ならば容量半減
IF 身体部位 == 4
	身体容量 /= 2
ENDIF
RETURNF 100 * 精液量 / 身体容量



