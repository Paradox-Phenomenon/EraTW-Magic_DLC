;==================================================
;独有称呼设置函数
;这一段是DOKU佬搓的版本
	;ARG为0，则设置自机
	;ARG为1，则设置对方自称
	;当ARGS有指定至值时，（就叫XXX）的内容会换成ARGS
;==================================================
@MOE_DAI_NAME_SET(ARGS,ARG=0)
;预处理
SIF ARG
	ARG = 1
$RE_INPUT
IF ARGS == ""
	IF ARG
		ARGS '= CSTR:13:20
	ELSE
		ARGS '= MASTERNAME:13
	ENDIF
	SIF ARGS == ""
	ARGS '= CALLNAME:(ARG*13)
ENDIF
LOCALS '= ARGS

;预处理结束

PRINTBUTTON @"[就叫%LOCALS%]", 0
IF LOCALS != CALLNAME:(ARG*13)
	PRINTL 
	PRINTBUTTON @"[改回%CALLNAME:(ARG*13)%]", 1
ENDIF
PRINTL 
PRINTBUTTON @"[更改]", 2
INPUT
CLEARLINE 1
PRINTL 
SELECTCASE RESULT
CASE 0
$NAMESET_CASE0
;CASE0 改成另外一个
	PRINTDL 确认吗？
	PRINTBUTTON "[确认]",0
	PRINTL 
	PRINTBUTTON "[再想想]",1
	INPUT
	CLEARLINE 1
	PRINTL 
	IF RESULT
		GOTO RE_INPUT
	ENDIF
	LOCALS '= ARGS
	LOCAL = 0
CASE 1
$NAMESET_CASE1
;CASE1 就用原来的
	PRINTDL 确认吗？
	PRINTBUTTON "[确认]",0
	PRINTL 
	PRINTBUTTON "[再想想]",1
	INPUT
	CLEARLINE 1
	PRINTL 
	IF RESULT
		GOTO RE_INPUT
	ENDIF
	LOCALS '= CALLNAME:(ARG*13)
	LOCAL = 1
;输入一个名字
CASE 2
	PRINTDL （请在下方输入名字）
	INPUTS
	LOCALS:1 '= REPLACE(RESULTS,"[\s]","")
	IF STRLENS(LOCALS) > 10
		PRINTW 「嗯……太长了，能不能简短一点？」  
		GOTO RE_INPUT
	ENDIF 
	;统一处理
	SELECTCASE LOCALS:1
		CASE LOCALS
			GOTO NAMESET_CASE0
		CASE CALLNAME:(ARG*13)
			GOTO NAMESET_CASE1
		CASE ""
			PRINTL 「那个……我没听见……」  
			GOTO RE_INPUT
	ENDSELECT
	LOCALS = 2
	
	IF ARG
		;角色
		SELECTCASE LOCALS:1
		
		
		ENDSELECT
	ELSE
		;玩家
		SELECTCASE LOCALS:1

		ENDSELECT
	ENDIF
	PRINTDL 确认吗？
	PRINTBUTTON "[确认]",0
	PRINTL 
	PRINTBUTTON "[再想想]",1
	INPUT
	CLEARLINE 1
	PRINTL 
	IF RESULT
		GOTO RE_INPUT
	ENDIF
	LOCALS '= LOCALS:1
CASEELSE
	GOTO RE_INPUT
ENDSELECT
LOCALS '= REPLACE(LOCALS,"[\s]","")
IF ARG
	;角色
	CSTR:13:20 '= LOCALS
ELSE
	;玩家
	MASTERNAME:13 '= LOCALS
ENDIF

;口上内容
SELECTCASE LOCAL
	CASE 0
	;没有改变
		
	CASE 1
	;初始名称
		
	CASE 2
	;普通更改
		
	CASE 3
	;彩蛋一号

ENDSELECT
RETURN LOCAL
