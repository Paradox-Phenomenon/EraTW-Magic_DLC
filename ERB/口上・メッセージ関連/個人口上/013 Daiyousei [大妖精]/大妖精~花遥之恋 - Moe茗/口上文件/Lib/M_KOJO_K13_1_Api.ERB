;※※※※※※※※※※※※※※※※※※※※※※※※※※
;"口上色判定"
;※※※※※※※※※※※※※※※※※※※※※※※※※※
@M_KOJO_Moe_COLOR_K13

SETCOLOR 0xB6FAB6 
;b6fab6

;这里可以通过SETCOLOR设置自己的口上颜色
;在系统启用口上色设定后才可以触发
;例：SETCOLOR 0xC07070

;※※※※※※※※※※※※※※※※※※※※※※※※※※
;"UPDATE判定"
;※※※※※※※※※※※※※※※※※※※※※※※※※※
@M_KOJO_Moe_UPDATE_K13
;口上独自的UPDATE用
;当您专门为 ENCOUNTER 准备了自己的分支标志时，请使用它（原文如此）
;在UPDATE判断中使用字符变量（如CFLAG）时，不会有自动填充，需要自己指定角色编号
;目前可作为口上自定义设置用，可以控制一些功能是否开启

IF CFLAG:13:18 && CFLAG:13:1001	;初见过，且放下过戒心
	PRINTL 
	PRINTFORMDW 你好，这里是大妖精Moe版口上（暂行名）的Update区域
	PRINTL 
	PRINTFORML 「那个……%MASTERNAME:118%……」
	PRINTL 
	PRINTDL 如聚光灯般洒下来的光束，照亮了黑暗之中的大妖精
	PRINTDW 只是，看上去好像很怕的样子……
	PRINTDL 
	PRINTFORMW 「一醒来就到这里了，也不知道要做什么……好怕……」
	PRINTL 
	$LARVA_UPDATE_MAIN
	PRINTFORML 「是，%MASTERNAME:118%有什么事吧？」
	PRINTFORML 「快一点好嘛？人家还想回去睡觉……」
	PRINTFORML 	
	CALL ASK_M("修改对你的称呼",1,"结束设置",1)
    PRINTL 
	SELECTCASE RESULT 
		CASE 0 
			PRINTFORML 「诶？%MASTERNAME:13%要换名字嘛？……」
			PRINTFORML 「只是打算，让人家换个方式叫你嘛？」
            PRINTL 
			CALL ASK_M("是的",1,"刚刚选错了",1)
            PRINTL 
			IF !RESULT 
				IF TALENT:118:7
					PRINTFORML 「嗯！那要怎么叫呢？」
					PRINTFORML 「人家是随便啦，能亲密一些也可以……」
				ELSE 
					PRINTFORML 「嗯，那要让%CSTR:118:20%怎么叫你呢？」
				ENDIF 
				CALL MOE_LARVA_NAME_SET(,0)
				PRINTFORMW 「好噢，%RESULTS%！就这样叫可以嘛？」
				GOTO LARVA_UPDATE_MAIN
			ELSE 
				PRINTFORML 「选错了？是说错了的意思嘛？诶……」
				IF TALENT:118:7
					PRINTFORML 「那个，不要紧张噢，叫什么都没关系的啦」
				ELSE 
					PRINTFORML 「确实噢，要习惯新的称呼，有点难的说……」
				ENDIF 
				PRINTFORMW 
				GOTO LARVA_UPDATE_MAIN
			ENDIF 
		CASE 1
			PRINTL 
			PRINTFORMDL 好的，祝你游戏愉快
			PRINTL 
			PRINTFORML 「%MASTERNAME:13%要走了嘛？等等我，带我一起出去嘛——」
			PRINTFORML 「诶？怎么有点困……想睡了……」
			PRINTFORMW 「%MASTERNAME:13%明天见……晚安的说……」
			PRINTL 
			;PRINTFORMD TIPS：
			;PRINTDATADW
				;DATAFORM 
			;ENDDATA
	ENDSELECT
ENDIF 



RETURN 1

