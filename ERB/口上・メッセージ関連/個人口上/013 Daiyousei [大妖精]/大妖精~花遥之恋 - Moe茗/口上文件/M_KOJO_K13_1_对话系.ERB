				PRINTFORML 
				PRINTFORML 

			CASE 1 
				IF FIRSTTIME("300_1_4_1")
					PRINTFORML 「%MASTERNAME:13%，教我写字可以嘛？」
					PRINTFORMDL 
					CALL ASK_M("大妖精不是会认字嘛",1)
					PRINTFORMDL 
					PRINTFORML 「诶呀，会认一点点，又不是会写啦……」
					PRINTFORML 「而且，会写字了的话，会成为独一无二的会写字的妖精噢」
					PRINTFORMDL 
					PRINTFORMDL 看着大妖精期待的眼神，没什么拒绝的理由……
					PRINTFORMDL 
					CALL ASK_M("想学写什么字呢",1)
					PRINTFORML 
					PRINTFORML 「想，想……啊……」
					PRINTFORML 「那个，想写%MASTERNAME:13%的名字，那个……可以写在手心里吗？」
					PRINTFORML 
					PRINTFORMDL 刚说完大妖精的脸蛋便已经红透，但还是伸出了左手
					PRINTFORMDL 往大妖精的手心里，一个字一个字地教她写着自己的名字……
					PRINTFORML 
					PRINTFORML 「诶嘿嘿……那个，可能记不太清……」
					PRINTFORML 「下次我自己写一写吧？会准备好给%MASTERNAME:13%看噢」
					PRINTFORML 
					PRINTFORMDL 大妖精的脸颊依旧红红的，但是笑容却十分地开心
				ELSE 
					PRINTFORML 「%MASTERNAME:13%教我写字的事情……」
					PRINTFORMDL 大妖精的脸颊又红了起来，似乎是想起了之前的事情
					PRINTFORMDL 
					IF ( ABL:13:43 >= 3 ) && !RAND:3 
						PRINTFORML 「那个……我练了很久，很好看吧？」
						PRINTFORMDL 大妖精递过来的本子上，你的名字写得像花式签名一样
						PRINTFORMDL 看得出来是可以设计过的，相当好看……
						PRINTFORML 「诶嘿嘿……谢谢夸奖……」
					ELSEIF ABL:13:43 == 2  
						PRINTFORML 「那个……我练了很久，很好看吧？」
						PRINTFORMDL 大妖精递过来的本子上，用娟秀的字体写着你的名字
						PRINTFORMDL 虽然写得不多，但是每一个都很好看
						PRINTFORML 「诶嘿嘿……谢谢夸奖……」
					ELSE 
						PRINTFORML 「那个……写得不太好，请多见谅……」
						PRINTFORMDL 大妖精递过来的本子上，写满了一页你的名字……
						PRINTFORMDL 虽然一开始写得有些歪歪扭扭，不过渐渐地写得很好了
						PRINTFORML 「诶嘿嘿……谢谢夸奖……」
					ENDIF 
				ENDIF 
			CASE 0 
				IF FIRSTTIME("300_1_4_0")
					PRINTFORML 「%MASTERNAME:13%，很好奇我的名字嘛？」
					PRINTFORMDL 
					PRINTFORMDW 谈论到名字的时候，不由得问起了大妖精
					PRINTFORML 
					PRINTFORMW 「那个……诶嘿嘿，人家也忘了……」
					PRINTFORML 
					PRINTFORMDW 再怎么说也是容易忘事的妖精，能理解……
					PRINTFORML 
					PRINTFORML 「啊！虽然听说也有其他的妖精，被叫做大妖精……」
					PRINTFORMW 「但是后来，似乎是她们比我出现得要少，所以现在大家就只叫我"大妖精"了」
					PRINTFORML
					CALL ASK_M("那，大妖精对自己的名字，有什么看法嘛？",1) 
					PRINTFORML 
					PRINTFORML 「嗯？让我想一想……一直都没有噢」
					PRINTFORMW 「一定要说的话，本来我是没有名字的，渐渐的有了这个很好记的名字……」
					PRINTFORMW 「哇！突然发现这样也不错……」
					PRINTFORMW 「……那，%MASTERNAME:13%对我的名字，有什么看法呢？」
					PRINTFORML 
					CALL ASK_M("很好记",1,"很可爱",1,"很普通",1,"很奇怪",1) 
					SELECTCASE RESULT 
						CASE 0 
							PRINTFORMW 「嗯！果然很好记呢！」
							PRINTFORMW 「因为，很多妖精都喜欢……追赶潮流，所以，跟着有名的妖精取西洋名字的也不少……」
							PRINTFORMW 「结果，她们连自己的名字都念不明白，怎么让人记得住嘛……」
							PRINTL 
							PRINTFORMDW 如果学过西洋文的话，应该会更容易理解一点……
							PRINTL 
							PRINTFORMW 「可是哪里有会西洋文的妖精嘛，就连露娜都不太懂……」
							PRINTL 
							PRINTFORML ……
							PRINTL 
							PRINTFORMDW 和大妖精持续着小小的争论……
						CASE 1 
							PRINTFORMW 「呜！哇！突然说这种话，干什么啦……」
							PRINTL 
							PRINTFORMDW 大妖精害羞得用手捂住脸颊，转过头去不敢看你
							PRINTL 
							PRINTFORML 「我，我从来没想过……这样的名字，真的会感觉可爱……」
							PRINTFORMW 「本来以为都会说普通什么的……呜……」
							PRINTL 
							PRINTFORMDW 大妖精的声音越来越小，最后一点都听不见了……
							PRINTL 
							PRINTFORMW ……
							PRINTL 
							PRINTFORMDW 只能等大妖精冷静了下来……
						CASE 2 
							PRINTFORMW 「嗯嗯……很普通的，我知道的噢」
							PRINTFORMW 「但是！但是，这样普通的名字，是妖精里面独一无二的……」
							PRINTFORMW 「希望你能好好记住……呀我在说什么呀……」
							PRINTL 
							PRINTFORMDW 大妖精不好意思地扭过了脸颊，声音忽而也变小了
							PRINTL 
							PRINTFORMW ……
							PRINTL 
							PRINTFORMW 「那个……真的要记住噢……」
						CASE 3 
							PRINTFORMW 「啊……原来你也觉得很奇怪啊」
							PRINTFORMW 「跟别的人类说得一样……呜……」
							PRINTFORMW 「那个……以前这样说，经常被当作是奇怪的妖精……%MASTERNAME:13%知道不是吧！」
							PRINTL 
							PRINTFORMDW 大妖精急切地向你解释着，直到得到肯定的回答才安静下来
							PRINTL 
							PRINTFORMW 「嗯……才不是奇怪的妖精……是很强的，独一无二的大妖精……」
							PRINTL 
							PRINTFORMDW 好像快要哭出来了，只能急忙连声安慰着她……
					ENDSELECT 
				ELSE 
					PRINTFORML 「说起来，%MASTERNAME:13%有听过，别的妖精里有叫大妖精的嘛……」
					PRINTFORMDL 大妖精时常好奇这样的问题，当然是如实告诉她并没有……
					PRINTFORML 「嗯，没有的话就好噢……」
					IF TALENT:13:7 
						PRINTFORML 「想要做%MASTERNAME:13%……唯一的大酱呀……」
						PRINTFORMDL 说完这句话，大妖精便小脸红红地依偎了过来
						PRINTFORMDL 自然是搂住她小小的身体，在她耳边呼唤着她的爱称
						PRINTFORML 「哇呀……也不要这么叫……呜……」
					ELSE 
						PRINTFORML 「大妖精这个名字，只想听%MASTERNAME:13%叫我一个人……」
						PRINTFORMDL 听着大妖精担心的声音，不由得有些心疼她……
						PRINTFORMDL 自然是再次许诺了下来，多叫了几次大妖精的名字
						PRINTFORML 「诶！那，那个……诶呀也不要叫那么多哇……」
					ENDIF 
				ENDIF 
		ENDSELECT
	ELSEIF (TALENT:13:8 || TALENT:13:3) && RAND:5	;思慕会说小八卦
		SELECTCASE RAND:10
			CASE 10 
				PRINTFORML 
				PRINTFORML 
				PRINTFORML 

			CASE 9 
				PRINTFORMDL 说话的时候，有只小鸟落在了大妖精的肩膀上……
				PRINTFORML 「嗯？怎么啦？哦，小动物什么的，很常见啦……」
				PRINTFORML 「因为人家对自然很亲和哦，所以它们都不怕我的哟」
				PRINTFORMDL 哪怕是大妖精伸出手指也不飞走，在她的手心里蹦蹦跳跳的

			CASE 8 
				PRINTFORML 「相比去其他地方找别的妖精玩，我更喜欢待在家附近……」
				PRINTFORML 「因为出远门不太方便，飞得很慢的……所以还是雾之湖这边适合我——」
				PRINTFORML 「超喜欢在湖边的森林里，探索大自然的说……」

			CASE 7 
				PRINTFORML 「在红魔馆工作的妖精很多，不过总是有干不完的活呢」
				PRINTFORML 「不，不要小瞧了妖精的啦！至少，自己家能收拾得干干净净的……」
				PRINTFORML 「只是红魔馆实在是太大了……人家上次去的时候，都迷路了啦……」

			CASE 6 
				PRINTFORML 「%MASTERNAME:13%有丢过东西嘛？」
				PRINTFORML 「诶呀我没捡啦，只是说一下，命莲寺的老鼠妖怪可以帮忙找东西哦」
				PRINTFORMW 「不过要很多钱……人家丢的东西都不值那个价呢，嘿嘿……」

			CASE 5 
				PRINTFORML 「我不喜欢像其他的妖精一样，趁着异变的时候跑去打架……」
				PRINTFORML 「因为总是打输嘛，每次都要把人家珍藏的符卡给拿走……」
				PRINTFORMDL 说起来……大妖精有用过符卡嘛？
				PRINTFORML 「诶呀，就是因为一直存着不想用……所以留到最后满身疮痍了都没有用过……」

			CASE 4 
				PRINTFORML 「那个……我在旁边，没有什么奇怪的感觉吧？」
				PRINTFORMDL 一定要说有什么感觉的话，妖精特有的自然气息让你稍微精神了一些
				PRINTFORML 「啊，因为总感觉人类很讨厌妖精的说……」
				PRINTFORML 「还是说，是因为有别的妖精经常做恶作剧吗？」

			CASE 3 
				PRINTFORML 「人家平常很少独自出门……」
				PRINTFORML 「不过，认识%MASTERNAME:13%之后就不这样了……」
				PRINTFORML 「那个，那个……带人家出去玩啦，才不是……约会什么的……」

			CASE 2 
				PRINTFORML 「有点羡慕太阳花田的妖精们呢……」
				PRINTFORML 「因为，她们都有那么大的一根向日葵，而且那边环境也很不错」
				PRINTFORML 「只是人家需要雾气才能飞得快啦，所以才住在雾之湖……」

			CASE 1 
				PRINTFORML 「不要把人家和其他普通的妖精相提并论哦，我可是大妖精——」
				PRINTFORML 「大在哪里呢？体型啦，翅膀啦，能力啦，还有……嗯……呜！」
				PRINTFORMDL 忽然想起什么的大妖精遮住了嘴唇，脸颊也涨得通红
				PRINTFORMDL 看着这样的反应，很容易就能猜出答案了……

			CASE 0 
				PRINTFORML 「听拉尔瓦说，河童和山童们的帽子下面，其实……噗……」
				IF FIRSTTIME("300_1_3_0")
					PRINTFORMDL 还没说出来，大妖精就强忍着笑意扭过了脑袋，笑出声来了
					PRINTFORMDL 
					CALL ASK_M("怎么了嘛，快告诉我",1)
					PRINTFORMDL 
					PRINTFORML 「其实，是地中海！哇……拉尔瓦是怎么知道的呀……每次讲起来都憋不住笑……」
				ELSE 
					PRINTFORML 
					CALL ASK_M("我记得哦，大妖精说是地中海",1)
					PRINTFORML 
					PRINTFORMDL 大妖精因为你的陈述彻底憋不住笑意，哈哈地笑出了声……
					PRINTFORMDL 虽然说嘲笑别人的身体有些不对，但还是跟着笑了笑……
				ENDIF 
		ENDSELECT
	ELSEIF CFLAG:13:1001 
		SELECTCASE RAND:7 
			CASE 7 
				PRINTFORML 
				PRINTFORML 
				PRINTFORML 
			CASE 6 
				IF FIRSTTIME("300_1_2_6")
					PRINTFORML 「说起来，%MASTERNAME:13%见过琪露诺酱了吗？」
					IF CFLAG:14:18 ;见面了
						PRINTFORML 「见过了？有要你什么东西吗？没跟她打起来吧……」
					ELSE 
						PRINTFORML 「还没见过吗？那回头见到她要注意哦……」
					ENDIF 
					PRINTFORML 「她虽然是很强的妖精，但是脑袋很简单哦，很容易就会跟人打架什么的……」
					PRINTFORML 「如果她要打你的话……呼呼，就问她一个难题难住她吧？最简单的数学题都可以哦」
					PRINTFORML 「这样的话她就会在原地愣住，一直想一直想这个问题，好有意思——」
					PRINTFORMDL 看着大妖精如同小恶魔般的笑容，大概能猜到她问了不少次了……
					PRINTFORML 「诶嘿嘿……这也是为了锻炼琪露诺酱的能力嘛……」
				ELSE 
					RETURN 0 
				ENDIF 
			CASE 5
				PRINTFORML 「我的翅膀和其他人不一样？嗯嗯，是这样哦」
				PRINTFORML 「不只是外观哦，它还能借助雾气的力量，让我在雾里面，比平常飞得快很多呢！」
				PRINTFORMDL 说到自己得意的能力，大妖精开心地挥了挥翅膀
				PRINTFORMDL 不由得想起了一句精准的概括，雾湖，起飞……
			CASE 4 
				PRINTFORML 「我最近变得不那么害怕生人了」
				PRINTFORML 「因为认识了%MASTERNAME:13%……发现人类并没有很可怕……」
				PRINTFORML 「甚至还有人会怕妖精的恶作剧，所以害怕妖精起来了呢……好有趣」
				PRINTFORMDL 大妖精娴静地坐着的模样，看上去也不像是会恶作剧……是这样吗？
			CASE 3 
				PRINTFORML 「虽然说听说过妖精被抓走这样的恐怖故事……」
				PRINTFORML 「不过真正发生的，其实也就是被抓住了一下下，然后就放掉了」
				PRINTFORMDL 即便作为强大的妖精会飞行，大妖精看上去依旧对人类抱有戒心
				PRINTFORML 「呜……就是有点害怕陌生人嘛……」
			CASE 2 
				IF TALENT:13:15 != -1 
					PRINTFORML 「%MASTERNAME:13%！我今天找到了代表着幸运的四叶草哦——」
					PRINTFORMDL 大妖精向你展示着手上的小草，那小小的叶片上还沾着露水
					PRINTFORML 「诶嘿嘿，这个送给你哦，人家家里还有很多……」
				ELSE 	;这个应该给小零食？
					PRINTFORML 「呜……人类村庄里买到的糖果，好难撕开哦……」
					PRINTFORMDL 确定不是因为放久了吗？糖纸里的糖果已经完全没了固体的样子
					PRINTFORML 「啊……扔掉的话好可惜……就这样舔着吃好嘛？」

				ENDIF 
			CASE 1 
				PRINTFORML 「妖精都是很亲近自然的生物哦」
				PRINTFORML 「所以这种情况当然很常见……哇啊头发里面没吃的啦——」
				PRINTFORMDL 大妖精捂住脑袋把过来讨食的小鸟赶跑了
			CASE 0 
				PRINTFORML 「啊……嘘……」
				PRINTFORMDL 有只蝴蝶扑扇着翅膀，停在了大妖精的鼻尖上
				PRINTFORMDL 大妖精瞪着斗鸡眼观察着蝴蝶的样子，让人忍不住笑出了声
				PRINTFORML 「哇！……都怪%MASTERNAME:13%……飞走了……」
		ENDSELECT 
	ELSE
		SELECTCASE RAND:5
			CASE 4
				PRINTFORML 「啊！干，干什么……」
				PRINTFORMDL 大妖精因为你忽然的搭话而吓了一跳
				PRINTFORMDL 看着这样的反应感到有些好笑，连想说什么都忘记了
				PRINTFORML 「呜！不，不准笑！有什么好笑的……」
			CASE 3
				PRINTFORML 「啊！别，别过来——」
				PRINTFORMDL 似乎被误会成会伤害妖精的坏人了……
				PRINTFORMDL 即便保持着距离跟大妖精搭话，她也只是敷衍地回应着……
				PRINTFORML 「嗯……是，是这样……对吧？」
			CASE 2
				PRINTFORML 「听说，人类里面有不少会伤害妖精的坏蛋……」
				PRINTFORML 「我不知道你是不是这种人……」
				PRINTFORMDL 急忙向大妖精解释了，自己靠近她并没有恶意
				PRINTFORML 「不行不行……还是不能相信你哦」
			CASE 1
				PRINTFORML 「嗯，那个……我……」
				PRINTFORMDL 大妖精似乎不知道怎么回答你提出的话题……
				PRINTFORMDL 还是说是因为过于害怕了呢？
			CASE 0
				PRINTFORML 「我听说有人抓妖精做实验……」
				PRINTFORMDL 大妖精缩在一旁的\@INROOM(CFLAG:13:300)?窗户下面#树后面\@。露出来的翅膀微微发抖……
				PRINTFORMDL 因为怕她逃走，只能暂且闭上了嘴……
		ENDSELECT 
	ENDIF 
	RETURN 1 
ELSE 
	RETURN 0 
ENDIF 

