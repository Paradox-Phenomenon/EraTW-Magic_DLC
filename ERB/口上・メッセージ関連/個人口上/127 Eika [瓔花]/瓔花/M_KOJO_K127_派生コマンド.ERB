;==================================================
;6,挿入Ｇスポ責め
;==================================================
@M_KOJO_MESSAGE_SCOM_K127_6
CALL M_KOJO_MESSAGE_SCOM_K127_6_1
RETURN 1
@M_KOJO_MESSAGE_SCOM_K127_6_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
	ENDIF
	;-------------------------------------------------
	;挿入継続
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && TCVAR:101 == PLAYER
		;前回射精した
		IF TCVAR:104
			PRINTFORMW 
			RETURN 1
		ELSE
			PRINTFORMW 
			RETURN 1
		ENDIF
	ENDIF
	;基本セット
	;恋慕
	IF TALENT:恋人 || TALENT:恋慕
			SELECTCASE RAND:6
				CASE 0
					PRINTFORML 「んんっ%UNICODE(0x2764)%%UNICODE(0x2764)%そこはっ%UNICODE(0x2764)%%UNICODE(0x2764)%」
					PRINTFORML 「きもちよく%UNICODE(0x2764)%%UNICODE(0x2764)%なりすぎちゃうからダメっ%UNICODE(0x2764)%%UNICODE(0x2764)%」
					PRINTFORMW 
				CASE 1
					PRINTFORML 「はぁうん%UNICODE(0x2764)%%UNICODE(0x2764)%んっ%UNICODE(0x2764)%きもちよすぎてへんなこえでちゃった…」
				CASE 2
					PRINTFORML 「あっ%UNICODE(0x2764)%%UNICODE(0x2764)%あっ%UNICODE(0x2764)%%UNICODE(0x2764)%そこっ%UNICODE(0x2764)%%UNICODE(0x2764)%%UNICODE(0x2764)%そこっ」
					PRINTFORMW 
				CASEELSE
					CALL EIKA_SEX
			ENDSELECT
		RETURN 1
	;それ以外
	ELSE
			SELECTCASE RAND:6
				CASE 0
					PRINTFORML 「んっ%UNICODE(0x2764)%うんっ%UNICODE(0x2764)%ねちっこく気持ちいいところを狙って……」
					PRINTFORMW 
				CASE 1
					PRINTFORML 「はぁうん%UNICODE(0x2764)%んっ%UNICODE(0x2764)%変な声出ちゃった…」
					PRINTFORMW 
				CASE 2
					PRINTFORML 「ふぅ…%UNICODE(0x2764)%んっ%UNICODE(0x2764)%……んっ%UNICODE(0x2764)%」
					PRINTFORMW 
				CASEELSE
					CALL EIKA_SEX
			ENDSELECT
		RETURN 1
	ENDIF
ENDIF
RETURN 1

