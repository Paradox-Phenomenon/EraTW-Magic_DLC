@M_KOJO_米歇尔制口上_MESSAGE_COM_K125_300
;指令共通メッセージ(TRAIN_MESSAGE)
;削除すると「～说着话。」とかが消えます。また、削除した場合は自動で口上色が付きません。
;口上メイン呼出
CALL M_KOJO_米歇尔制口上_MESSAGE_COM_K125_300_1
RETURN RESULT

@M_KOJO_米歇尔制口上_MESSAGE_COM_K125_300_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF TCVAR:125:350 == 0
		;每天第一次对话时触发
		IF TALENT:恋人
			;新年
			IF DAY:2 == 1 && DAY:3 == 1
				PRINTFORMW 「今天是一年的起始呢，也标志着我们又一起度过了一年」
				PRINTFORMW 「今年亲爱的你许了什么愿望？不用告诉我，说出来就不灵了呢」
				PRINTFORMDW “当然是能跟最爱的女苑一起无数次度过下一年了”
				PRINTFORMW 「你啊，真是的，这种事情不用许愿也可以的吧」
				PRINTFORMW 「无论如何我都会和%CALLNAME:MASTER%一起走下去呢」
				PRINTW
				;白色情人節
			ELSEIF DAY:2 == 1 && DAY:3 == 14
