;==================================================
;621,釣魚
;TFLAG:193(0=釣れない 1～4=魚 11～15=好吃的魚 610=木材 131=守矢之守札 21=跳蛋 609=氷之鱗 606=龍之爪)
;TFLAG:194(1000以上ならTARGETが釣った)
;==================================================
@M_KOJO_米歇尔制口上_MESSAGE_COM_K125_621
CALL M_KOJO_米歇尔制口上_MESSAGE_COM_K125_621_1
RETURN RESULT

@M_KOJO_米歇尔制口上_MESSAGE_COM_K125_621_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF TFLAG:194 >= 1000
		IF TALENT:恋慕 || TALENT:恋人
			PRINTFORMW 看到在钓鱼的%CALLNAME:MASTER%，女苑也搬了个椅子过来一起钓鱼
			PRINTFORMW 是不是靠的太近了，鱼线真的不会缠在一起吗？
			PRINTFORMW 「哦呀，这就钓上来了呢」
			PRINTFORMW 我都坐在这这么久了还没有上钩，你怎么刚过来就钓到鱼了呢？
			PRINTFORMW 总之%CALLNAME:MASTER%开始帮着女苑将鱼收杆回来
			PRINTW
		ELSEIF TALENT:思慕
			PRINTFORMW 应%CALLNAME:MASTER%的邀请，女苑坐到了一边开始钓鱼
			PRINTFORMW 「看起来今天是我运气更好呢」
			PRINTFORMW 女苑说完就开始提杆了，这么快就上钩了吗？
			PRINTFORMW 看看女苑到底钓上来了什么吧
			PRINTW
		ELSE
			PRINTFORMW 女苑似乎并不想搭理你，径直走到一边掏了个凳子坐下来钓鱼
			PRINTFORMW 「哦？上钩了呢」
			PRINTFORMW 女苑收杆检查起了钓上来的东西
			PRINTW
		ENDIF

		SELECTCASE TFLAG:193
			CASE 1 TO 4
				PRINTFORMW 「嗯，成功上钩，你想要吗？那就给你吧」
			CASE 11 TO 15
				PRINTFORMW 「哦哦，好大的鱼，看起来很好吃呢」
				PRINTFORMW 「你想要吗？那就给你吧，记得烧好之后喊我来吃就行」
			CASE 610
				PRINTFORMW 「嗯？怎么是块木头啊，送你了，我拿着又没用」
			CASE 131
				PRINTFORMW 「嗯？这个是什么东西，一张纸条？」
				PRINTFORMW 「守矢神社的礼品卷？这种类型的东西啊，送你了，我又不会去那里抽签」
			CASE 21
				PRINTFORMW 「诶？这是个什么东西？是吃的吗？」
				PRINTFORMW 女苑捏了两下发现搞不明白后就丢给了%CALLNAME:MASTER%
			CASE 609
				PRINTFORMW 「呜哇，这是个什么东西啊，好冰，不会是那个冰精的翅膀碎片吧」
			CASE 606
				PRINTFORMW 「这是什么东西？像是什么东西的爪子呢，能感受到其中蕴含的能量」
				PRINTFORMW 「你想要吗？那就送你了。嗯？这么贵重的东西随手就送出去了没问题吗？」
				PRINTFORMW 「嘛，毕竟我又不知道有什么用，要是你有用那就拿去吧」
		ENDSELECT
		;你が釣った
	ELSE
		SELECTCASE TFLAG:193
			CASE 0
				IF TALENT:恋慕 || TALENT:恋人
					PRINTFORMW 「嘛，空军了也是没办法的事情，来，先喝口水」
					PRINTFORMW 「时间也不早了，不行的话我们先回去吧，明天多带点鱼饵来打窝吧」
					PRINTW
				ELSEIF TALENT:思慕
					PRINTFORMW 「空军了吗？看来你需要女苑来好好的教教你该怎么钓鱼了呢」
					PRINTFORMW 过了一会儿，结果女苑也加入了空军的行列呢
					PRINTFORMW 「可恶，一定是今天的鱼儿都还在睡觉，肯定不是我的问题」
					PRINTW
				ELSE
					PRINTFORMW 女苑看了眼空军的%CALLNAME:MASTER%，眼神中带点鄙视的样子
					PRINTFORMW 可恶，必须得钓上条大的好好给她长长见识
					PRINTW
				ENDIF
				;石斑魚
			CASE 1
				PRINTFORMW 「哦哦，这个是」
				PRINTFORMW 「是石斑鱼啊，这个鱼好吃但是腐坏的也很快呢，乘早下锅烧了吧」
				;皐月鱒
			CASE 2
				PRINTFORMW 「哦哦，这个是」
				PRINTFORMW 「是皐月鳟啊，是种刺很少的小型鱼呢，真好啊，不用剔刺的鱼」
				;山女
			CASE 3
				PRINTFORMW 「哦哦，这个是」
				PRINTFORMW 「是山女啊，是虹鳟的亲戚呢，虽然没有虹鳟那么名贵，但也是很好吃的鱼类了」
				;岩魚
			CASE 4
				PRINTFORMW 「哦哦，这个是」
				PRINTFORMW 「这不是岩鱼吗，听说是种很抗冻的鱼呢，连深冬都能见到它的踪迹，要养起来冬天再吃吗？」
				;鲫魚
			CASE 7
				PRINTFORMW 「哦哦，这个是」
				PRINTFORMW 「这不是鲫鱼吗，是种到处都能见到的鱼类呢，你应该很会料理吧，毕竟可以说是最为常见的鱼类呢」
				;食人魚
			CASE 8
				PRINTFORMW 「哦哦，这个是」
				PRINTFORMW 「这不是食人鱼吗？呜哇，好吓人，这一嘴的牙要是被咬到肯定讨不了好」
				PRINTFORMW 「听说曾经有人见过一头落水的老牛瞬间就被撕成碎片了呢」
				;雀鳝
			CASE 9
				PRINTFORMW 「哦哦，这个是」
				PRINTFORMW 「这不是雀鳝吗，有这种鱼在的地方基本见不到其他的鱼呢」
				PRINTFORMW 「因为其他的鱼类大多都被它当作食物吃掉了，为了幻想乡的鱼类安全，干得好！」
				;鮭魚
			CASE 11
				PRINTFORMW 「哇，这个是！」
				PRINTFORMW 「这不是三文鱼吗，这个东西不是极品吗，不管煎着吃还是烤着吃，甚至生食都可以」
				PRINTFORMW 「不过还是做熟了比较好呢，毕竟野生的鱼要是有寄生虫那可就糟了」
				;虹鱒
			CASE 13
				PRINTFORMW 「哇，这个是！」
				PRINTFORMW 「这不是虹鳟吗，这也是分布很广有很好吃的有名鱼呢」
				PRINTFORMW 「不过绝对不能生吃哦，这种鱼的体内几乎百分之百会有寄生虫的，把它处理下烤着吃吧」
				;八目鰻
			CASE 14
				PRINTFORMW 「哇，这个是！」
				PRINTFORMW 「这不是七鳃鳗吗，这种鳗鱼比一般的鱼类脂肪含量要高不少所以会很好吃呢」
				PRINTFORMW 「要是不知道怎么处理的话把它拿给森林的那只鸟妖吧，她天天烧这种鱼肯定很会处理」
				;巨骨舌鱼
			CASE 15
				PRINTFORMW 「哇，这个是！」
				PRINTFORMW 「这不是巨骨舌鱼吗，这种鱼听说是有肺部的呢，所以直接放在那里不管应该也不会死」
				PRINTFORMW 「不过这种鱼据说不怎么好吃啊，不过分量倒是很大，那么该怎么处理它呢」
				;香魚
			CASE 17
				PRINTFORMW 「咦，这个是？」
				PRINTFORMW 「这不是香鱼吗，这种鱼也非常好料理，无论是清蒸红烧都只需要稍微处理一下就可以下锅了」
				PRINTFORMW 「而且据说熟了之后会散发出一种很明显的香味，我们快把它吃了吧」
				;鲶魚
			CASE 18
				PRINTFORMW 「咦，这个是？」
				PRINTFORMW 「这不是鲶鱼吗，有着长长的两条胡子呢，听说也是种很美味的鱼」
				PRINTFORMW 「而且尤其对身体差还有老人这类人群最为适宜食用，听说还可以……咳咳，那个我们以后再说」
				;鰻魚
			CASE 19
				PRINTFORMW 「咦，这个是？」
				PRINTFORMW 「这不是鳗鱼吗，是比八目鳗更为接近祖先的原始种呢」
				PRINTFORMW 「鳗鱼也是种很好吃的鱼啊，尤其是切成条后可以很轻易的就在吃的时候把刺剃掉，真是太好了呢」
				;跳蛋
			CASE 21
				PRINTFORMW 「咦，这个是？」
				PRINTFORMW 「这是什么玩意啊！怎么还会不停的震动啊！这东西真的是鱼吗？」
				PRINTFORMW %CALLNAME:MASTER%默默的将跳蛋收了起来，纯洁的孩子还是不要知道这是干什么用的比较好……
				;鯉魚
			CASE 22
				PRINTFORMW 「咦，这个是？」
				PRINTFORMW 「这不是鲤鱼吗，这也是一种有药用价值的鱼类呢，听说可以使人气血更为流通」
				PRINTFORMW 「而且民间还有着鲤鱼跃龙门的传说，总之把它好好的收起来吧」
				;腔棘鱼
			CASE 23
				PRINTFORMW 「咦，这个是？」
				PRINTFORMW 「我**你把什么东西钓上来了，快把它放回去！这种鱼可是跟我一个时代诞生的老古董，而且都快要灭绝了，你忍心把它吃掉吗」
				PRINTFORMW 「诶？你说你有养殖手册会把它好好的养起来的？呜，我会盯着你的」
				;鲟
			CASE 24
				PRINTFORMW 「咦，这个是？」
				PRINTFORMW 「这不是鲟鱼吗，听说这种鱼富含的营养能使人更聪明呢」
				PRINTFORMW 「听说外面因为过度捕捞都已经濒临灭绝了，不过这里是幻想乡，还有很多存活呢那么该怎么料理它呢」
				;泷太郎
			CASE 31
				PRINTFORMW 「等等！你到底又把什么东西钓上来了啊！」
				PRINTFORMW 「这不是只在传说中出现过的泷太郎吗，你到底怎么钓到这家伙的啊」
				PRINTFORMW 「把它吃掉也太浪费了，要不我们给它建个展览馆吧，肯定能大赚一笔」
				;守矢之守札
			CASE 131
				PRINTFORMW 「守矢神社的抽奖卷？垃圾，把它找个垃圾桶丢掉吧，真是晦气」
				;龍之爪
			CASE 606
				PRINTFORMW 「唉？这个是什么东西？一个巨大的爪子？」
				PRINTFORMW 「不会是什么化石吧？但是看着很新，里面还有股莫名的能量波动，你知道这是什么东西吗？」
				;氷之鱗
			CASE 609
				PRINTFORMW 「透明的，鳞片？哇，好冰」
				PRINTFORMW 「莫名的感觉能拿来当调和素材呢，而且总觉得和那个冰精的翅膀很像，下次要不要拔那个冰精的翅膀下来试试？」
				;木材
			CASE 610
				PRINTFORMW 「哈哈哈哈哈，你就钓到了这个？」
				PRINTFORMW 「亏你刚才拉杆的时候还在说好大的鱼，这下真的，好大的“鱼”了吧」
				;青蛙
			CASE 706
				PRINTFORMW 「这不是青蛙吗」
				PRINTFORMW 「嘛，虽然也能做成吃的，不过总觉得有点恶心，要是烧成料理可别拿给我吃啊」
			CASEELSE
				PRINTFORMW 「噢，上钩了呢，好好收起来吧」
		ENDSELECT
	ENDIF
ENDIF
RETURN 1
