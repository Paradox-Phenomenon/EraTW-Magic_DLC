;==================================================
;40,ローター
;==================================================
@M_KOJO_ENG01_MESSAGE_COM_K36_40
CALL M_KOJO_ENG01_MESSAGE_COM_K36_40_1
RETURN RESULT

@M_KOJO_ENG01_MESSAGE_COM_K36_40_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF !FLAG:70 && LOCAL:1 && FIRSTTIME(SELECTCOM)
		PRINTFORML 「なにそれ？　…おもちゃ？」
		PRINTFORML 「なんか、おもしろそうだねー。どうやって遊ぶの？」
		PRINTFORMW 「…なにかな、その怪しい笑顔は？　…って、ふにゃああああああっ！？」
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		;PRINTFORMW 
		RETURN 1
	;恋慕
	ELSE
		SELECTCASE RAND:4
			CASE 0
				PRINTFORML 「ふぅっ、ぅんっ、ふぁっ、はっ」
				PRINTFORML 「お、お兄さん、あたいで遊んでない？」
				PRINTFORMW 「おもちゃだからって…ふぁっ、にゃっ」
			CASE 1
				PRINTFORML 「それ、気持いいけど…」
				PRINTFORMW 「お兄さんの指の方が…うにゃぁ…」
			CASE 2
				PRINTFORMW 「ん……くっ……震えてるのが凄く……んにゃっ！」
			CASE 3
				PRINTFORMW 「機械に頼られてもねぇ……んんっ」
		ENDSELECT
	ENDIF
ENDIF
RETURN 1

;==================================================
;43,オナホール
;==================================================
@M_KOJO_ENG01_MESSAGE_COM_K36_43
CALL M_KOJO_ENG01_MESSAGE_COM_K36_43_1
RETURN RESULT

@M_KOJO_ENG01_MESSAGE_COM_K36_43_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF !FLAG:70 && LOCAL:1 && FIRSTTIME(SELECTCOM)
		PRINTFORMW 「へぇー、変わった筒だねぇ……え？おちんちんを？」
		PRINTFORMW 「ふぁぁぁっ！？え？な、なんだいこれ？す……すごいよぉっ！」
		RETURN 1
	ENDIF
	;基本セット
	;装着
	IF TEQUIP:オナホール
		;恋慕
		;時姦中
		IF FLAG:70
			;PRINTFORMW 
			RETURN 1
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「ひぁぁっ！？これだめぇっ、震えて、こすれて……」
					PRINTFORMW 「んんっ、だしたくてたまんないねぇ……」
				CASE 1
					PRINTFORML 「あ……ふみゃぁぁんっ！？」
					PRINTFORMDW お燐の腰はオナホールをつけた瞬間に何度も跳ねた。
				CASE 2
					PRINTFORML 「やぁ……おかしくなる……こんなの……」
					PRINTFORMW 「あふぅ……あぁっ……」
			ENDSELECT
			RETURN 1
		ENDIF
	;解除
	ELSE
		;時姦中
		IF FLAG:70
			;PRINTFORMW 
			RETURN 1
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「んっ……きゃっふぅっ！」
					PRINTFORMDW 一気にひき抜いた衝撃でお燐は体を震えさせた。
				CASE 1
					PRINTFORMW 「ふやぁっ！……あ……あたいの……おちんちん……」
				CASE 2
					PRINTFORML 「うあぁっ……はぁ……ひぅ……辛かったねぇ」
					PRINTFORMW 「って、さらに動かさないでおくれよ……にゃぁっ！？」
			ENDSELECT
		ENDIF
	ENDIF
ENDIF
RETURN 1

;==================================================
;44,バイブ
;==================================================
@M_KOJO_ENG01_MESSAGE_COM_K36_44
CALL M_KOJO_ENG01_MESSAGE_COM_K36_44_1
RETURN RESULT

@M_KOJO_ENG01_MESSAGE_COM_K36_44_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF !FLAG:70 && LOCAL:1 && FIRSTTIME(SELECTCOM)
		IF TCVAR:破瓜 == 1
			PRINTFORML 「…それ…何に使うかはわかるけど…」
			PRINTFORMW 「あたい、初めてなんだよ？　それ使うのがじゃなくて…」
			PRINTFORML 「…そういう趣味なんだ…ふぅん…」
			PRINTFORMW 「…ん…せめて、優しく入れてね…」
			PRINTFORML 「…ッ！　…無理に、押して…！」
			PRINTFORMW 「～～～ッ！！　…はぁ…はぁ…。入った…の？」
			PRINTFORML 「ん…ブルブル、震え…」
			PRINTFORML 「お兄さん、ちょっと待って…」
			PRINTFORMW 「スイッチは…ふぁ…！」
			PRINTFORML 「あたいの中で…暴れ…！　やだ…まだ、あたい…！」
			PRINTFORML 「変だよ…痛いのに…！　痛かったのに、だんだん…気持…」
			PRINTFORMW 「…くぅん！　ハッ…あぁっ！　い…く…にゃぁっ！」
			RETURN 1
		ELSE
			PRINTFORML 「…んー…それ、使うの…？」
			PRINTFORMW 「ひょっとして、お兄さん、自信ない？」
			PRINTFORML 「冗談冗談♪　…冗談だって、お兄さん、目が怖いよ？」
			PRINTFORMW 「…ごめん、ちょっとしたお茶目…ふにゃぁっ！？」
			PRINTFORML 「ちょ、お兄さ…！　これ…いきなり、激し…！」
			PRINTFORML 「振動…が、強す…ぎて…！」
			PRINTFORMW 「…ぁ…にゃぁぁぁっ！？」
			RETURN 1
		ENDIF
	ENDIF
	;基本セット
	;装着
	IF TEQUIP:バイブ
		;時姦中
		IF FLAG:70
			;PRINTFORMW 
			RETURN 1
		ELSE
			SELECTCASE RAND:4
				CASE 0
					PRINTFORML 「うぅ～…」
					PRINTFORML 「気持いいのは認めるけど…お兄さんに見られてるのが…ちょっと…」
					PRINTFORML 「『そんな燐を見るのも可愛い』って？　…うぅ～…やっぱりお兄さんは変態だよ！」
					PRINTFORML 「…でも、自分で言ったんだから、嫌いになっちゃやだよ…？」
					PRINTFORML 「あたいは、お兄さんがちょっとくらい変態でも…くぅん！　ハッ、ハァッ…！」
					PRINTFORMW 「いいん…だから…ぁ…！　…～～～ッ！」
				CASE 1
					PRINTFORML 「また、それ使うの…？」
					PRINTFORML 「お兄さん以上に癖になっちゃったら…それはそれで、責任とってね？」
					PRINTFORML 「…ん…！　ブルって、振動が…」
					PRINTFORMW 「やっぱり、まだ慣れな…ゥ…～～～ッ！」
				CASE 2
					PRINTFORML 「……何か入れるなら、繋がるのほうがあたいとしては嬉しいねぇ」
					PRINTFORMW 「ダメかい？……そ、残念だね。　　ふぁぁっ…」
				CASE 3
					PRINTFORMW 「んあっ……これ、またくれるんだね？さぁさ……おいで」
			ENDSELECT
		ENDIF
	;解除
	ELSE
		;時姦中
		IF FLAG:70
			;PRINTFORMW 
			RETURN 1
		ELSE
			PRINTFORML 「んっ……ふみゃぁ……」
			PRINTFORML 「あ……中、無くなると……寂しいねぇ。代わりのものをくれないかい？」
			PRINTFORMDW お燐は喉をならし、期待に満ちた視線を%CALLNAME:PLAYER%に送っている。
		ENDIF
	ENDIF
ENDIF
RETURN 1

;==================================================
;45,アナルバイブ
;==================================================
@M_KOJO_ENG01_MESSAGE_COM_K36_45
CALL M_KOJO_ENG01_MESSAGE_COM_K36_45_1
RETURN RESULT

@M_KOJO_ENG01_MESSAGE_COM_K36_45_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF !FLAG:70 && LOCAL:1 && FIRSTTIME(SELECTCOM)
		IF TALENT:恋慕
			PRINTFORMW 「なんだい、これ？……後ろって……正気かい！？」
			PRINTFORMDW あまりにお燐が驚くので、%CALLNAME:PLAYER%は諦めようとした。が、
			PRINTFORMW 「ちょ、ちょっと待った！あたいをそんじょそこらの猫と同じにしないでおくれよ」
			PRINTFORMW 「こちとら強い妖怪変化さ。後ろくらいなんてことないよ！……お兄さんのためなら」
			PRINTFORMDW そう言って、お燐は健気に自分で自分のアナルを広げた。
		ELSEIF MARK:3
			PRINTFORMW 「これを後ろに……？冗談じゃないのかい？」
			PRINTFORMW 「うわぁ……本気とは恐れ入ったね。　　んぐっ」
		ELSE
			PRINTFORMW 「…お兄さん、それって…？」
			PRINTFORMW 「え、ちょ、ちょっと待って！？」
			PRINTFORMW 「それって、そっちに入れるも…や、駄目だって…！」
			PRINTFORMW 「そんなの、入るわ…ふぁぁぁぁぁぁっ！？」
		ENDIF
		RETURN 1
	ENDIF
	;基本セット
	;装着
	IF TEQUIP:アナルバイブ
		;時姦中
		IF FLAG:70
			;PRINTFORMW 
			RETURN 1
		ELSE
			SELECTCASE RAND:5
				CASE 0
					PRINTFORML 「う…それ…」
					PRINTFORML 「そ、そりゃ、あたいだって気持ちよくなってるけどさ！」
					PRINTFORML 「だからって、欲しいとかそういうんじゃ…！」
					PRINTFORMW 「や、そんな強引…！　スイッチ入れちゃ…にゃぁぁぁぁっ！！？」
				CASE 1
					PRINTFORML 「また…それでするの…？」
					PRINTFORML 「そんなの駄目だよ…あたい…」
					PRINTFORML 「壊れ…んん…！」
					PRINTFORMW 「駄目だって、言ってる…のにぃ…」
				CASE 2
					PRINTFORML 「ひぁっ……前にも後ろにもなんてっ……にゃぁっ……」
					PRINTFORMW 「ダメッ、入れたらあたいおかし……きひゃぁぁっ！？」
				CASE 3
					PRINTFORM 「ん……いいよ。でも、前の方
					IF HAS_PENIS(MASTER)
						PRINT にはきちんとお兄さんのを入れて
					ELSEIF TALENT:MASTER:122 == 0
						PRINT はちゃんと、お姉さんが弄って
					ENDIF
					PRINTFORML おくれよっ？」
					PRINTFORMDW そういいながら、お燐は自分のアナルを広げて微笑みながら受け入れた。
				CASE 4
					PRINTFORML 「ん……こんなのがあると、落ち着いてお兄さんを感じられないかも……」
					PRINTFORMDW そういいながらも、お燐は抵抗せずにお尻を差し出し、受け入れた。
			ENDSELECT
		ENDIF
	;解除
	ELSE
		;時姦中
		IF FLAG:70
			;PRINTFORMW 
			RETURN 1
		ELSE
			IF RAND:2
				PRINTFORML 「んっ……きゃっふぅっ！」
				PRINTFORML 「ふやぁっ！……あ……あたいの……開きっぱなしになっちゃってる」
				PRINTFORMDW 一気にひき抜いた衝撃でお燐は再び体を震えさせた。
			ELSE
				PRINTFORML 「うー、なんかヒリヒリするねぇ」
				PRINTFORMW 「って、さらに動かさないでよ……にゃぁっ！？」
			ENDIF
		ENDIF
	ENDIF
ENDIF
RETURN 1

;==================================================
;46,アナルビーズ
;==================================================
@M_KOJO_ENG01_MESSAGE_COM_K36_46
CALL M_KOJO_ENG01_MESSAGE_COM_K36_46_1
RETURN RESULT

@M_KOJO_ENG01_MESSAGE_COM_K36_46_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		IF ABL:Ａ感覚 >= 3
			PRINTFORMW 「わ、楽しそうな玩具だね……って、後ろに？」
			PRINTFORMW 「んー、なんかムズムズしちゃうねぇ」
		ELSE
			PRINTFORMW 「わ、楽しそうな玩具だね……って、ここに入れるのかい！？」
			PRINTFORMW 「うわー、なんか違和感……」
		ENDIF 
		RETURN 1
	ENDIF
	;基本セット
	;装着
	IF TEQUIP:アナルビーズ
		SELECTCASE RAND:4
			CASE 0
				PRINTFORML 「あぁぁっ……そんなに入れちゃ……お、おかしいよぉ！」
				PRINTFORML 「ダメ、あたいの中……本当にオモチャ箱になっちゃったみたいだねぇ」
				PRINTFORMDW お燐は異様な数のビーズを飲み込み、息も絶え絶えになっている。
			CASE 1
				PRINTFORML 「あぁぁっ……そんなに入れちゃ……ふぁっ！こわれるぅ！」
				PRINTFORMW 「ダメ、あたいの中、全部、ビーズで一杯になっちゃ……ひきぃっ」
			CASE 2
				PRINTFORML 「あ、この玩具……好き。また引き抜いてくれるかい？」
				PRINTFORMDL お燐は期待に満ちた目で%CALLNAME:PLAYER%を見つめてくる。
				PRINTFORMW 「ねぇ、見て。また入れれる数増えたんだよっ！」
			CASE 3
				PRINTFORML 「うー、これ、入れるときはともかく、抜くときに痛いんだよねぇ」
				PRINTFORMDW そういいながらも、お燐はアナルビーズを受け入れた。
		ENDSELECT
	;解除
	ELSE
		IF RAND:2
			PRINTFORML 「んっ……きゃっふぅっ！ひぁぁん！」
			PRINTFORMDW 一気にひき抜いた衝撃でお燐は再び体を震えさせた。
		ELSE
			PRINTFORML 「ふやぁっ！……あぁっ！好き、これすきぃっ！」
			PRINTFORMDW お燐は体全体をガクガクとさせて反応した。
		ENDIF
	ENDIF
ENDIF
RETURN 1

