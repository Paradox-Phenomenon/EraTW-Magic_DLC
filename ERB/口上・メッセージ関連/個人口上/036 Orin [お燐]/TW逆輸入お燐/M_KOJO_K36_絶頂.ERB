@M_KOJO_ENG01_MESSAGE_PALAMCNG_D_K36(ARG)
;-------------------------------------------------
;After reaching certain threshold for palams for the first time
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
;don't show if unconscious
SIF FLAG:70 || !SHIRAHU(TARGET)
	RETURN 0

SIF CFLAG:うふふ != 1 ;don't show stuff below unless having sex
	RETURN 0

;-------------------------------------------------
;初めて潤滑がLV2超えた
;-------------------------------------------------
IF PALAM:潤滑 + UP:潤滑 > PALAMLV:2 && FIRSTTIME("潤滑V2")
	IF IS_SELECTCOM("ローション")
		PRINTFORMW 「うぇ……べとべとぉ……」
		PRINTFORMDW お燐は濡れた子猫のように体をブルブルッと震えさせた。
	ELSEIF TALENT:恋慕
		PRINTFORMW 「あはははは、あたいもう…どろどろになっちゃった……困ったねぇ」
		PRINTFORMDW お燐の蜜は太ももを伝って既に床に小さな水溜りを作り出している。
	ELSE
		PRINTFORMW 「ん……ふぁ…少し感じちゃったねぇ」
		PRINTFORMDW お燐は恥ずかしげに身をよじった。
	ENDIF
ENDIF

;-------------------------------------------------
;初めて欲情がLV2超えた
;-------------------------------------------------
IF PALAM:欲情 + UP:欲情 > PALAMLV:3 && FIRSTTIME("欲情V2")
	IF IS_SELECTCOM("媚薬")
		PRINTFORMW 「んあっ……にゃっ……体が…あつ…ふぁっ」
		PRINTFORMDW お燐の目が徐々にトロンとしていくのが%CALLNAME:PLAYER%にはわかった。
	ELSE
		PRINTFORMW 「んあっ…やば……あたいもノッてきちゃったかも……」
	ENDIF
ENDIF

;-------------------------------------------------
;初めて恥情がLV2超えた
;-------------------------------------------------
IF PALAM:恥情 + UP:恥情 > PALAMLV:3 && FIRSTTIME("恥情V2")
	PRINTFORML
	PRINTFORMDW 気のせいか、お燐の頬は彼女の髪のように羞恥で赤く染まっている。
ENDIF

;-------------------------------------------------
;初めて恐怖がLV2超えた
;-------------------------------------------------
IF PALAM:恐怖 + UP:恐怖 > PALAMLV:3 && FIRSTTIME("恐怖V2")
	PRINTFORML
	PRINTFORMDW お燐は少しだけ、まゆをひそめた。
ENDIF
