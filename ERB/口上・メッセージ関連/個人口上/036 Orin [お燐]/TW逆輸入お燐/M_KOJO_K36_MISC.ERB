;==================================================
;100,スパンキング
;==================================================
@M_KOJO_ENG01_MESSAGE_COM_K36_100
CALL M_KOJO_ENG01_MESSAGE_COM_K36_100_1
RETURN RESULT

@M_KOJO_ENG01_MESSAGE_COM_K36_100_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF !FLAG:70 && LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		PRINTFORMW 「んぐっ、やめてぇっ！痛いっ！痛いよお兄さんっ！」
		IF ABL:マゾっ気 >= 5
			PRINTFORMDW お燐は体をぶるっと震わせると、眉根を寄せながら呟いた。
			PRINTFORMW 「あれ？……痛いのに……ふくぅ……気持ちい……い？」
		ELSEIF TALENT:恋慕
			PRINTFORMW 「あたいの事……嫌いになっちゃったのかい？」
			PRINTFORMDW お燐はさびしそうに呟いた。
		ELSEIF MARK:不埒刻印 >= 2
			PRINTFORMDW お燐は涙を目にためて、必死に耐えている。
		ELSE
			PRINTFORMW 「こんな事して何がいいのかねぇ……理解できないよ。くー」
			PRINTFORMDW お燐はこちらを軽くにらんできた。
		ENDIF
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		;PRINTFORMW 
		RETURN 1
	ELSEIF ABL:マゾっ気 >= 5
		SELECTCASE RAND:4
			CASE 0
				PRINTFORML 「くぅっ……痛いけど……いいねぇっ！なんだか、癖になりそうだよっ！」
				PRINTFORMDW お燐は%CALLNAME:PLAYER%の攻めを受け入れ、幸せそうにお尻を振るった。
			CASE 1
				PRINTFORML 「…んんっ！……あぁぅあっ！？」
				PRINTFORMDW お燐は叩きやすいようにお尻を突き出し、快感を享受している。
			CASE 2
				PRINTFORML 「んくっ……おかしいねぇ……こんなので……ふぁっ！？」
				PRINTFORMDW 叩く手を止めると、お燐は自分の尻尾で自分の臀部を軽く叩いた。
			CASE 3
				PRINTFORML 「…くぁっ！にゃふっ！……なんでぇっ！？」
				PRINTFORMDW お燐は自分を襲う快感に戸惑っている。
		ENDSELECT
	ELSEIF PALAM:欲情 >= PALAMLV:4
		PRINTFORML 「……ぐぅっ！？……いい感じだったのに、なんでこんな事するんだい？」
		PRINTFORMDW お燐は気分を害したようで、%CALLNAME:PLAYER%のお尻を尻尾で叩いてきた。
	ELSEIF TALENT:恋慕
		PRINTFORML 「くぅっ……大丈夫！あたい、お兄さんのなら我慢できるからっ」
		PRINTFORMW 「……でも、出来るならやりすぎないでほしいねぇ……うぁっ」
	ELSEIF MARK:反発刻印
		PRINTFORML 「こんだけやるからには、死ぬ覚悟は出来てるだろうねぇ……ぐぅっ」
		PRINTFORMDW お燐の瞳は叩かれるたびに怒りに揺れている。
	ELSE
		IF RAND:2
			PRINTFORMW 「んぎぃっ……こんなの……楽しくないからやめてくれないかい？」
		ELSE
			PRINTFORMW 「いたいいたいいたいいたい！あたいを遺体にする気かいっ！？」
		ENDIF
	ENDIF
ENDIF
RETURN 1

;==================================================
;104,アイマスク
;==================================================
@M_KOJO_ENG01_MESSAGE_COM_K36_104
CALL M_KOJO_ENG01_MESSAGE_COM_K36_104_1
RETURN RESULT

@M_KOJO_ENG01_MESSAGE_COM_K36_104_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF !FLAG:70 && LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		IF MARK:不埒刻印 == 3
			PRINTFORMW 「へー、こりゃまた面白そうなオモチャだねぇ！」
			PRINTFORMDW アイマスクを見て、お燐は目を輝かせている
			PRINTFORMW 「って、真っ暗だね。これでどうするんだい？」
			PRINTFORMDW 装着しても、あまり不安そうな様子は見られない。
		ELSE
			PRINTFORMW 「なんだい、このオモチャは？」
			PRINTFORMDW お燐はちょっと不安そうにアイマスクを身につけた。
			PRINTFORMW 「わぉ、真っ暗！……で、何をする気だい？」
		ENDIF		
		RETURN 1
	ENDIF
	;基本セット
	;装着
	IF TEQUIP:アイマスク
		IF ABL:マゾっ気 >= 5
			IF TALENT:恋慕
				PRINTFORML 「また、それかい？目隠し遊び、好きなんだねぇ……」
				PRINTFORML 「それとも、あたいの恋する視線に耐えられなくなっちゃったのかい？」
				PRINTFORMDW おどけられるだけの余裕は未だ健在のようだ。
			ELSE
				PRINTFORML 「また、見えなくしちゃうのかい？」
				PRINTFORMDW お燐はなんだか、とても楽しげだ。
			ENDIF
		ELSEIF TALENT:恋慕
			PRINTFORML 「うーん……お兄さんが見えなくなるのが悲しいねぇ」
			PRINTFORMW 「もっと、丁重にあたいを扱ってほしいねぇ、お兄さん」
		ELSEIF MARK:反発刻印
			PRINTFORML 「やめろ……」
			PRINTFORMDL 怯える慧音の乳首をつまんでやると、体を大きく跳ねさせた。
			PRINTFORMDW 言葉とは裏腹に、随分興奮しているようだ。
		;屈服3
		ELSEIF MARK:不埒刻印 == 3
			PRINTFORML 「猫の瞳でも見通せない闇があるだなんて、ちょっと悔しいねぇ」
			PRINTFORMW 「でも、なんだか気持ちいいかも……」
		;それ以外
		ELSE
			PRINTFORMW 「見えないって……なんだか落ち着かないねぇ」
			RETURN 1
		ENDIF
	;解除
	ELSE
		IF TALENT:恋慕
			PRINTFORML 「ん……こんなにそばにいたんだね、お兄さん」
			PRINTFORMDW お燐は、%CALLNAME:MASTER%の顔を見ると、幸せそうな笑顔になった。
		ELSE
			PRINTFORMDW お燐は突然差し込んできた光に、思わず目を細めた。
		ENDIF 
		RETURN 1
	ENDIF
ENDIF
RETURN 1

;==================================================
;105,縄
;==================================================
@M_KOJO_ENG01_MESSAGE_COM_K36_105
CALL M_KOJO_ENG01_MESSAGE_COM_K36_105_1
RETURN RESULT

@M_KOJO_ENG01_MESSAGE_COM_K36_105_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF !FLAG:70 && LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		IF MARK:不埒刻印 == 3
			PRINTFORMW 「……おおっ、奇術か何かだね！種も仕掛けもありゃしない！」
			PRINTFORMW 「で、どうやって抜ければいいんだい？やり方を教えてほしいねぇ」
			PRINTFORMDW お燐は勘違いしたままのようだ。
		ELSE
			PRINTFORMW 「おやまぁ、縛り付けてどうするつもりだい？」
			PRINTFORMW 「獄門？磔？血の池へ放り込む？それとも、市中引き回しの上さらし首？」
			PRINTFORMW 「できれば、何もせず解いてくれたほうが嬉しいんだけどねぇ」
		ENDIF 
		RETURN 1
	ENDIF
	;基本セット
	;装着
	IF TEQUIP:縄
		IF ABL:マゾっ気 >= 5
			IF TALENT:恋慕
				PRINTFORML 「あぁ、好きだねぇ、この奇術」
				PRINTFORML 「縛られるだけであら不思議、貴方に手も足も出なくなる」
				PRINTFORMW 「おまけに……ものすごく気持ちよくなっちゃうのさ。最高だねぇ」
			ELSE
				PRINTFORML 「縛られたりしたら、こっちからうごけないからねぇ」
				PRINTFORML 「その分、気持ちよくして欲しいところさ！」
				PRINTFORMDW お燐の瞳は期待に満ちている。
			ENDIF
		;恋慕
		ELSEIF TALENT:恋慕
			PRINTFORML 「こうされるの嫌いだねぇ」
			PRINTFORMW 「だって、あたいがお兄さんを抱きしめられないじゃない」
			RETURN 1
		;屈服3
		ELSEIF MARK:不埒刻印 == 3
			PRINTFORML 「んー……動こうとすると痛くなるのがなんとも、だねぇ」
			PRINTFORMDW お燐は抵抗せずに縛られた。
			RETURN 1
		ELSEIF MARK:反発刻印
			PRINTFORML 「人をこんなにして何が楽しいのかねぇ」
			PRINTFORMW 「このまま血の池へ放り込むなら、古き地獄の鬼と同じさ」
		;それ以外
		ELSE
			PRINTFORML 「いーもーむーしー」
			PRINTFORML 「いや、見てないでさ。早く何かしてくれないかい？」
			PRINTFORMDW お燐は自分から動けないのがつまらなさそうだ。
			RETURN 1
		ENDIF
	;解除
	ELSE
		;恋慕
		IF TALENT:恋慕
			PRINTFORMW 「さぁ、ようやくの自由だねぇ。楽しませてもらうよ！」
			RETURN 1
		;それ以外
		ELSE
			PRINTFORMW 「痛た……結構食い込むんだねぇ、縄って」
			RETURN 1
		ENDIF
	ENDIF
ENDIF
RETURN 1

