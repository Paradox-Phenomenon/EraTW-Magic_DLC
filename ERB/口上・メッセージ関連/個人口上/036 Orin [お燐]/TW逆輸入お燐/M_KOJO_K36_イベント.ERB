;※※※※※※※※※※※※※※※※※※※※※※※※※※
;"EVENT"系イベント
;※※※※※※※※※※※※※※※※※※※※※※※※※※
;==================================================
;部屋で遭遇
;==================================================
@M_KOJO_ENG01_EVENT_K36_1(ARG,ARG:1)
;口上主はTARGET
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;MASTERが入ってきた
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && GROUPMATCH(1, 2, 6)
		IF TALENT:恋人 && FIRSTTIME("遭遇恋人")
			PRINTFORML 「あ、お兄さん…」
			PRINTFORML 「夢じゃ…無いんだよね？」
			PRINTFORMDL あなたが頷くと、燐は腕にギュッとしがみつく
			PRINTFORMW 「にゃはー。…これからもよろしくね、お兄さん♪」
		ELSEIF TALENT:恋慕 && FIRSTTIME("遭遇恋慕")
			PRINTFORML 「ねえ、お兄さん…」
			PRINTFORML 「お兄さんは、猫は好き？」
			PRINTFORMDW 特に嫌いではない
			PRINTFORML 「じゃあ、死体は好き？」
			PRINTFORMDW …特に好きではない
			PRINTFORML 「じゃあ…んー、いいや。なんでもない、忘れて」
			PRINTFORMDW ………朝一でそんなことを聞かれて、忘れるのは難しいのだが…
		ELSEIF TALENT:恋人
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「にゃーん♪」
					PRINTFORMDW 燐は人（？）の姿のまま、背中にしがみついて頬を摺り寄せて来た
				CASE 1
					PRINTFORML 「今日も、来てくれたんだね♪」
					PRINTFORML 「来てくれなかったら、どうしてやろう…」
					PRINTFORMW 「もとい、どうしようって思ってたよ」
				CASE 2
					PRINTFORMW 「お兄さん、今日は何しよっか？」
			ENDSELECT
		ELSEIF TALENT:恋慕
			PRINTFORML 「お兄さん。今日も、一緒に頑張ろうね♪」
			PRINTFORMDW なにやら機嫌よさそうに、背中をバシバシ叩いてくる
		ELSEIF EXP:キス経験
			PRINTFORML 「えへー…」
			PRINTFORMDL 鏡を前に、唇を投げながら緩い笑みを浮かべる
			PRINTFORML 「なんか、残ってるようなー…は！？　お兄さん、いつからそこに！？」
			PRINTFORMDW どう答えても角が立ちそうだと判断したあなたは、そそくさとその場を離れることにした
		ELSE
			PRINTFORMW 「今日も、張り切って行こー！」
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGETが入ってきた
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGETが風呂に入ってきて一緒に入る
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		PRINTFORML 「風呂で裸は普通だけどさ」
		PRINTFORMW 「目的が違うと……なんだかドキドキしちゃうね」
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGETが風呂に入ってきて出て行った
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 4
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGETが風呂に入ってきて追い出された
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 5
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;外出先で遭遇した
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 6
		PRINTFORMDL 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;他角色と约会中に遭遇した
	;ARG:1に约会的对象
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 7 ;when she meets you dating someone else
		IF TALENT:恋人
			SELECTCASE ARG:1
				CASE [[さとり]]
					PRINTFORML 「お兄さん…一つだけ言っておくけど…」
					PRINTFORML 「いつもあたいとどんなふうに過ごしてるか、思い浮かべたら駄目だからね！」
					PRINTFORMW 「思い出すのも、絶対禁止！」
				CASE [[お空]]
					PRINTFORML 「猫耳と尻尾だけじゃな足りないの！？」
					PRINTFORML 「羽か！？　やっぱり、羽っ子がいいの！？」
					PRINTFORMW 「お兄さんの性癖の話だよ！　あたいじゃなくて、おくうを選ぶなんて…」
				CASE [[こいし]]
					PRINTFORML 「お兄さん…どういうつもりかは聞かないけど…」
					PRINTFORML 「気をつけてね？　こいし様は、ホントに何考えてるかわからないから」
					PRINTFORMW 「あたいはいつ交代してもいいから！　待ってるよ！」
			CASEELSE
				PRINTFORMW 「やだ」
				PRINTL  
				PRINTL  
				PRINTFORMW 　
				PRINTL  
				PRINTL  
				PRINTFORMW 　
				PRINTL  
				PRINTL  
				PRINTFORMW 　
				PRINTL  
				PRINTL  
				PRINTFORMW 　
				PRINTFORML 「…じゃあ、その娘とエッチなことしないなら、いいよ」
				PRINTFORMW 「（と言っても、無理だろうなぁ、お兄さんだし）」
			ENDSELECT
		ELSE
			SELECTCASE ARG:1
				CASE [[さとり]]
					PRINTFORML 「さすがお兄さん、度胸があるのか、わかってないのか…」
					PRINTFORML 「さとり様と一緒に過ごそうなんて、普通考えないからね」
					PRINTFORML 「でも、お兄さんなら、ひょっとしたら…」
					PRINTFORMW 「…うん。さとり様をよろしくね、お兄さん！」
				CASE [[お空]]
					PRINTFORML 「うわぁ…」
					PRINTFORML 「お兄さん、一つだけ忠告しておくよ…」
					PRINTFORMW 「おくうにあまり変なことしないでね。消し飛ぶのは、お兄さんだけじゃないから」
				CASE [[こいし]]
					PRINTFORML 「え？　こいし様いたの！？」
					PRINTFORML 「まあ、ほら、それがこいし様の能力だから…」
					PRINTFORMW 「じゃあ、頑張ってね。…いろいろな意味で」
			CASEELSE
				PRINTFORMW 「ん。じゃ、またね～」
				PRINTFORMW 「あぁあ、退屈だなぁ」
			ENDSELECT
		ENDIF
		RETURN 1
	ENDIF
 
ENDIF
RETURN 1

