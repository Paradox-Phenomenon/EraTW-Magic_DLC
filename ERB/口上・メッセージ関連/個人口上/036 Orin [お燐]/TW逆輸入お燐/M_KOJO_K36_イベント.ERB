;==================================================
@M_KOJO_ENG01_EVENT_K36_15(ARG,ARG:1)
#DIM 絶頂回数
;口上主はTARGET
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------

IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;未実装（推倒指令に統合？
	;MASTERが推倒た（ウフフ開始時）
	;記入チェック（=0, 非表示、1, 表示）
	;LOCAL:1 = 0
	;-------------------------------------------------
	;IF LOCAL:1 && ARG == 1
		;PRINTFORML
		;RETURN 1
	;ENDIF
	;-------------------------------------------------
	;逢瀬終了（ウフフ終了時）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		SIF FLAG:時間停止 || (CFLAG:睡眠 && CFLAG:衰弱 != 360) ;fix
			RETURN 0
		絶頂回数 = 0
		絶頂回数 += EX:Ｃ絶頂
		絶頂回数 += EX:Ｖ絶頂
		絶頂回数 += EX:Ａ絶頂
		絶頂回数 += EX:Ｂ絶頂
		絶頂回数 += EX:Ｍ絶頂
		IF BASE:0 <= 500 ;if exhausted
			IF 絶頂回数 >= 20
				PRINTFORMDL お燐は指を折りながらなにやら数えている。
				PRINTFORML 「あふ……お兄さんに……イかされちゃった……」
				PRINTFORML 「気持ちい…のは嬉しいけどさ……加減して……欲しいねぇ…………」
				PRINTFORMDW お燐は裸のまま、気絶したように眠り始めた。
			ELSEIF 絶頂回数 == 0
				PRINTFORML 「うーん、さすがに疲れちゃったよ」
				PRINTFORMDL お燐は軽く伸びをすると、%CALLNAME:MASTER%の耳元に唇をよせ、囁いた。
				PRINTFORMW 「次は……あたいをちゃんとイかせないと、承知しないよ。あはははは」
			ELSE
				PRINTFORML 「くー、お兄さん中々やるね。あたいはいたくていたく感動さ」
				PRINTFORML 「次はお手柔らかに頼むよ。あはははは……はぁ」
				PRINTFORMDW そういうと、お燐は猫の姿になってそのままぐったりと眠り始めた
			ENDIF
		ELSEIF 絶頂回数 == 0 ;if didn't come once
			PRINTFORML 「この前は……一度もイかせてくれなかったんだよねぇ……」
			PRINTFORMW 「今度は何回イかせてくれるのかい？」
			PRINTFORMW 「……両手で数えられるくらいの回数じゃ、許してあげないよっ！」
		ELSEIF CFLAG:溜まってる度 >= 500 ;if still horny
			SELECTCASE RAND:3
				CASE 0
					PRINTFORMW 「あらららら、もうおしまいかい？」
					PRINTFORMW 「うーん、もうちょっとしたかったけど、残念だわぁ」
				CASE 1
					PRINTFORMW 「んー……なんだか物足りないねぇ」
					PRINTFORMW 「お預けって……されてみると意外と辛いんだねぇ」
				CASE 2
					PRINTFORMW 「おや、あっさり終わったねぇ」
					PRINTFORMW 「いつもこんなのなら、楽なんだけど」
			ENDSELECT
		ELSE
			IF 絶頂回数 >= 20
				PRINTFORML 「あひっ…ふぁっ…ん……っ」
				PRINTFORMDL お燐は体を震えさせながら胸を激しく上下させている。
				PRINTFORMDL その目は虚ろで未だ気をやっているようだ。
				PRINTFORMW 「ふ……ん……あ、終わった……の？」
			ELSEIF !TALENT:恋慕 && 絶頂回数
				PRINTFORML 「くー、お兄さん意外とやるね」
				PRINTFORML 「地上の、%PRINT_MALE("男の子:女の子", MASTER)%って、みんなこんな感じなのかい？あはははは」
			ELSEIF 絶頂回数
				IF RAND:2
					PRINTFORMW 「あーあ、いい仕事したねぇ。今日は気持ちよく眠れそうだよ」
					PRINTFORMDW お燐はそう言って伸びをした。
				ELSE
					PRINTFORMDL お燐は指を折りながらなにやら数えている。
					PRINTFORMW 「この前は、{絶頂回数}回くらいあたいをイかせてくれたんだよねぇ……」
					PRINTFORMW 「今度は何回イかせてくれるんだい？」
				ENDIF
			ENDIF
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;事後描写
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		;-------------------------------------------------
		;精液が垂れてきた
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1 && ARG:1 == 1
			IF SOAKED_OR_NOT("V_SEMINAL") + SOAKED_OR_NOT("A_SEMINAL")
				IF 絶頂回数 >= 20
					PRINTFORML 「あひっ…ふぁっ…ん……っ」
					PRINTFORMDL お燐はよだれをふきこぼし、ビクビクと身体を痙攣させながら鳴き叫んでいる
					PRINTFORMDL どうやら絶頂から降りられず、イキっぱなしになっているようだ。
					PRINTFORMDL 泉から断続的に潮が吹き上げながら、お燐はうわ言を呟き続けている。
					PRINTFORML 「ふ…ん…あ…ひゃ…にゃぁっ……すきっ…お兄さん…すきぃっ」
					PRINTFORMDW うわ言を呟くお燐の体を、%CALLNAME:MASTER%は軽く濡れタオルで拭ってあげた。
				ELSE
					PRINTFORML 「わ、まだ溢れてくるねぇ……」
					PRINTFORMDL お燐は幸せそうな表情で、自分の中から溢れてくる精液を見つめている。
					PRINTFORMW 「あたいの中の灼熱地獄、そんなに気持ちよかったかい？お兄さん」
				ENDIF
			ENDIF
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;愛液が垂れてきた
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1 && ARG:1 == 2
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;事後の情緒
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1 && ARG:1 == 3
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;服を着る
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1 && ARG:1 == 4
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
ENDIF
RETURN 1

