;==================================================
;约会帰りに告白（恋人が付く）
;==================================================
@M_KOJO_ENG01_SPEVENT_K36_2(ARG,ARG:1)
;口上主はTARGET
;地の文表示
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;告白内容
	;この告白内容表示後に接受かどうかの選択分が表示されます
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 0
		PRINTFORMW 「えーい！」
		PRINTFORMDW 後ろを歩いていた燐が、いきなり勢い良くぶつかってくる
		PRINTFORMW 「あれ？　うーん…押し倒そうとしたんだけどなぁ…」
		PRINTFORMDW 腰にしがみ付きながら。そんなことをつぶやく
		PRINTFORMW 「まあ、いいか。このまま話すね」
		PRINTFORMW 「お兄さんのこと、好き」
		PRINTFORMW 「大好きだよ。男と女の意味で」
		PRINTFORMDW 腰にまわされた腕に、さらに力がこもる
		PRINTFORMW 「あたいの…素直な気持ちだよ」
		PRINTFORMDW そして、しばらく沈黙が続いた
		PRINTFORMW 「…うう…。…やっぱり、ちょっと恥ずかしかったかな？」
		PRINTFORMW 「思い切って言っちゃえば、大丈夫だって思ってたけど…」
		PRINTFORMW 「自分でも火照ってるのがわかるよ…。…今は、顔見ないでほしいな…」
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;告白オッケー（恋人が付く）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		PRINTFORMDW 背中に顔を埋める燐に対し、あなたは『自分も好きだ』と告げる
		PRINTFORMW 「！！？」
		PRINTFORMDW ビクンと身体が震え、尻尾がピンと立つ
		PRINTFORMW 「…にゃあ…本当に？」
		PRINTFORMW 「………」
		PRINTFORMW 「…んっ！」
		PRINTFORMDW 突然顔を上げた燐が、無理やり唇を重ねてくる
		PRINTFORMW 「へへへ…」
		SIF EXP:キス経験 == 0
			PRINTFORMW 「初めてのチューだね…」
		PRINTFORMW 「これで、お兄さんのこれからを予約だよ。死ぬまでずっと…」
		PRINTFORMW 「ううん、死んでも絶対、お兄さんのこと手放さないよ♪」
		CALL MUTUAL_KISS(TARGET, 1, 0)
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;告白失敗
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		PRINTFORML
		RETURN 1
	ENDIF

ENDIF
RETURN 1

