;==================================================
;夜寝るとき（おやすみ口上）
;==================================================
@M_KOJO_ENG01_EVENT_K36_3(ARG,ARG:1)
;口上主はTARGET
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------

IF LOCAL
	;-------------------------------------------------
