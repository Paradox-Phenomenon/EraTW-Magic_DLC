;==================================================
;相手が推倒を解除
;==================================================
@M_KOJO_ENG01_EVENT_K36_30(ARG,ARG:1)
;口上主はTARGET
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------

IF LOCAL
	;-------------------------------------------------
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		;疲惫
		PRINTFORML 「んあ……ふぅあ……」
		PRINTFORML 「あはははは、やりすぎちゃったみたい」
		PRINTFORMDW 胸を上下させて激しく呼吸をしながらも、お燐はあなたに微笑みかけた。
		PRINTFORMW 「ねぇ、ちょっといい？」
		PRINTFORMDL 返事をまたずに、お燐は%CALLNAME:MASTER%の腕とって枕にしてゆっくりと横になる。
		PRINTFORMW 「ん……もう少しだけ、このままでいて」
		PRINTFORMDW しばらくすると、横から安心しきった寝息が聞こえてきた。
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		;満足して解放
		PRINTFORML 「死体運びもいいけどさ……」
		PRINTFORMDL お燐は%CALLNAME:MASTER%の服の裾をつまんで、幸せそうな笑みをこぼした。
		PRINTFORML 「あたい、お兄さんといるのも、とても楽しいねぇ」
		PRINTFORMDW %CALLNAME:MASTER%が喉を軽くくすぐると、お燐はごろごろと喉を鳴らして微笑んだ。
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
	;満足したところを被逆推た
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 4
	;壊れるまでしてあげる
		PRINTFORML
		RETURN 1
	ENDIF
ENDIF
RETURN 1


