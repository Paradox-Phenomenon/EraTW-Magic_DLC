;==================================================
;23,ピロートーク
;==================================================
@M_KOJO_ENG01_MESSAGE_COM_K36_23
CALL M_KOJO_ENG01_MESSAGE_COM_K36_23_1
RETURN RESULT

@M_KOJO_ENG01_MESSAGE_COM_K36_23_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1
		IF FIRSTTIME(SELECTCOM)
			PRINTFORML 「なななななに言いだすのさ、いきなり！？」
			PRINTFORMW 「お兄さんってば、おかしくなっちゃったの！？」
			CALLF ONCE(SELECTCOM)
		ELSEIF ONCE(SELECTCOM)
			PRINTFORML 「ん、なに？　ピロートーク？」
			PRINTFORML 「う～ん、お兄さんには似合わない感じ？」
			PRINTFORMW 「あたいはもっと、イチャイチャする方が好きだなぁ」
		ENDIF
		RETURN 1
	ENDIF
	;失敗
	IF TFLAG:193
		IF RAND:2
			PRINTFORML 「にゃはははははははは！」
			PRINTFORMW 「なに？　新手の冗談？」
		ELSE
			PRINTFORML 「うわぁ…」
			PRINTFORMW 「…はっきりいっていいかな…？　似合わないよ…」
		ENDIF 
		RETURN 1
	;恋慕
	ELSEIF TALENT:恋慕
		SELECTCASE RAND:3
			CASE 0
				PRINTFORML 「にゃん♪」
				PRINTFORML 「もう…耳元で囁かないでよ…くすぐったいから…」
				PRINTFORMW 「え、うん。内容もだよ、こそばゆいのは…」
			CASE 1
				PRINTFORML 「へぇ…お兄さんの口って、そんな言葉も出てくるんだ…」
				PRINTFORML 「意外…。うん、悪くないよ…」
				PRINTFORMW 「でも、他の子にもそんなこと言ってるのかな？」
			CASE 2
				PRINTFORML 「改めてそういうこと言われると、恥ずかしいっていうか…」
				PRINTFORML 「なんていうか………変？」
				PRINTFORMW 「ああ！？　嬉しくないわけじゃないから！！　そんなに落ち込まないでよ、お兄さん！？」
		ENDSELECT 
		RETURN 1
	;それ以外
	ELSE
		IF RAND:2
			PRINTFORML 「ふひゃあっ！？　くすぐったい！？」
			PRINTFORML 「え、内容？　うぅん、聞いてなかった」
			PRINTFORMW 「（てか、恥ずかしくて、聞いてられないってば！）」
		ELSE
			PRINTFORML 「どうしたの、お兄さん！？」
			PRINTFORML 「…あ～…うん。悪気はなかったけど…」
			PRINTFORMW 「やっぱり、お兄さんにそういうの、似合わないと思う…」
		ENDIF  
		RETURN 1
	ENDIF
ENDIF
RETURN 1