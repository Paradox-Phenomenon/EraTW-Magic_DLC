;==================================================
;20,キスする
;==================================================
@M_KOJO_ENG01_MESSAGE_COM_K36_20
CALL M_KOJO_ENG01_MESSAGE_COM_K36_20_1
RETURN RESULT

@M_KOJO_ENG01_MESSAGE_COM_K36_20_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		PRINTFORMW 「んちゅ…んんっ……ぷぁっ……」
		PRINTFORMW 「お兄さん……」
		PRINTFORMDW お燐の舌に気をつけながらの長い長いディープキス。
		PRINTFORMDW 唇を離すと、舌の間の唾液がたわんで落ちた。
		PRINTFORMW 「キスだけって……意外と、いい物なんだねぇ」 
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		;PRINTFORMW 
		RETURN 1
	ELSE
		SELECTCASE RAND:3
			CASE 0
				PRINTFORML 「ん……ぷぁっ……ふぅぅっ……」
				PRINTFORML 「もう、そんなに早く離さなくてもいいじゃないさ」
				PRINTFORMW 「１年くらい、ずーっと、キスし続けたりしたくないかい？」
			CASE 1
				PRINTFORML 「…ふぅぅ……んんっ……くぅん……」
				PRINTFORMDL 唇を離すと、お燐は舌を突き出したまま恍惚としている。
				PRINTFORMDW その舌を指で擦ってやると、さらに甘い声を聞くことが出来た。
			CASE 2
				PRINTFORMW 「んぷっ……ふぁっ……んちゅ……」
				PRINTFORMW 「うーん、感じながらだと、舌を動かすのって意外と難しいねぇ」
		ENDSELECT
	ENDIF
ENDIF
RETURN 1


