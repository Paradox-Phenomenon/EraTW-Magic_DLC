@K36_BOYO(ARG)
#FUNCTIONS
LOCALS '= PRINT_MALE("boyo:sis", MASTER)
RETURNF ARG ? CAPITALIZE(LOCALS) # LOCALS

@K36_DATEPLACE ;called at "date" (405) and "explore" (604, once per location)
SELECTCASE DATENAME_PLACE()
;人里でデート
CASE "人間の里"
	IF TALENT:恋人
		PRINTFORML 「地底より、明るくて活気があるねぇ」
		PRINTFORML 「今度、旧地獄街道にも行かない？」
		PRINTFORMW 「あっちなら、あたいもいろいろ案内できるよ♪」
	ELSEIF TALENT:恋慕
		PRINTFORML 「いやいや、ここも結構遊べるねぇ」
		PRINTFORML 「いつもは、仕事…と言うかまぁ」
		PRINTFORMW 「別口でしか来なかったけど、こういうのもいいもんだね♪」
	ELSE
		PRINTFORML 「いやぁ…火車の血が騒ぐねぇ」
		PRINTFORML 「え？　大丈夫大丈夫、死体探しはしてないよ」
		PRINTFORMW 「今は、ね。下見くらいは…冗談冗談♪」
	ENDIF
;博麗神社でデート
CASE "博麗神社"
	IF TALENT:恋人
		PRINTFORML 「この神社って、実は結構御利益ある？」
		PRINTFORML 「こんないい雰囲気で、お兄さんと二人きりなんて…」
		PRINTFORMW 「なかなか、あるもんじゃないよね？」
	ELSE
		PRINTFORML 「地獄の妖怪が、神社でデートかぁ…」
		PRINTFORML 「結構、奇天烈なシチュエーションだよね？」
		PRINTFORMW 「でも、ここの神社なら、なんとなくありっぽいかな」
	ENDIF
;霧の湖でデート
CASE "霧の湖～紅魔館"
	IF TALENT:恋人 && DAY:2 != 4
		PRINTFORML 「じゃじゃ～ん！」
		PRINTFORML 「お兄さんの為の、新調した水着だよ！」
		PRINTFORMW 「どう、可愛い？　それとも、セクシー？」
	ELSEIF TALENT:恋慕
		PRINTFORML 「ここって、改めてみると、涼しげでわりといい感じかな」
		PRINTFORML 「ちょっと、のんびりしよっか？」
		PRINTFORMW 「こういうまったりしたデートも、たまにはいいんじゃないかな？」
	ELSE
		PRINTFORML 「ここって、凄いバカな妖精が出るんだって？」
		PRINTFORML 「しかも、氷精とか…」
		PRINTFORMW 「いろいろな意味で、泳ぐには向かないロケーションだねぇ…」
	ENDIF
;花畑でデート
CASE "迷いの竹林"
	IF TALENT:恋人
		PRINTFORML 「お兄さん、そろそろお弁当にしよっか？」
		PRINTFORML 「え？　あたいが作って来たんだよ」
		PRINTFORMW 「にゃはぁ…。つい、夜更かししちゃった。だから、しっかり味わってね♪」
	ELSEIF TALENT:恋慕
		PRINTFORML 「ふぅ…見目も綺麗で…いい匂いがして…」
		PRINTFORML 「ふにゃ…ちょっと、眠くなっちゃう」
		PRINTFORMW 「お兄さん、ちょっと膝枕してよ…ｚｚｚ…」
	ELSE
		PRINTFORML 「へぇ…。日向ぼっこにい感じ」
		PRINTFORML 「でも、なんだろう…妙に怖気を感じるって言うか…」
		PRINTFORMW 「それを含めて、あたいにはいい感じだけどね♪」
	ENDIF
;白玉楼
CASE "三途の川～冥界"
	IF TALENT:恋人
		PRINTFORML 「ねぇ、ここに来たのに、深い意味は無いよね？」
		PRINTFORML 「あたいみたいな火車が言うのもなんだけど…」
		PRINTFORMW 「お兄さんには、長生きしてほしいな」
	ELSEIF TALENT:恋慕
		PRINTFORML 「実を言うと、あまり好きじゃないんだよねー、ここ」
		PRINTFORML 「商売敵というか、死神がいるし」
		PRINTFORMW 「『いないみたいなもの』？　にゃは、お兄さんも言うねぇ！　同感だけどさ♪」
	ELSE
		PRINTFORML 「あれ？　お兄さん、ひょっとして死にたくなった？」
		PRINTFORML 「それであたいを連れて来たってことは、死体をくれるってことで…」
		PRINTFORMW 「違う？　ま、あたいも冗談で言ったけどね♪」
	ENDIF
;月の都
CASE "夢の世界～月"
	IF TALENT:恋人
		PRINTFORML 「地底暮らしのあたいが、月の都、かぁ」
		PRINTFORML 「なんとも、不思議というか、脾肉めいてるというか…」
		PRINTFORMW 「楽しければ、なんだってかまわないけどね♪」
	ELSEIF TALENT:恋慕
		PRINTFORML 「月って…あの月？」
		PRINTFORML 「…どうやって来たかもそうだけど…」
		PRINTFORMW 「たまに、お兄さんが何物か、わからなくなるよ…」
	ELSE
		PRINTFORML 「………」
		PRINTFORML 「………？」
		PRINTFORMW 「ねぇ、お兄さん…。…ここ…どこ？」
	ENDIF
;妖怪の山
CASE "妖怪の山 (山麓)", "妖怪の山 (山頂)"
	IF TALENT:恋人
		PRINTFORML 「昔、勇儀お姉さんが住んでたり、あの天狗がいたりするんだよね」
		PRINTFORML 「お気楽な性格は、この山の土壌なのかなぁ…」
		PRINTFORMW 「『幻想郷全体がそう』？　ああ、それは言えてるねぇ」
	ELSEIF TALENT:恋慕
		PRINTFORML 「ここだよね、おくうに変なの埋めた神様がいるのって？」
		PRINTFORML 「………ふ～ん…」
		PRINTFORMW 「軽く、荒らして行こっか？」
	ELSE
		PRINTFORML 「ここって、人間には結構危ない場所なんだよね？」
		PRINTFORML 「そういう所に、ホイホイ来るお兄さんって…」
		PRINTFORMW 「…でも、今更かな、そういうの」
	ENDIF
;地霊殿
CASE "地底"
	IF TALENT:恋人
		PRINTFORML 「あんまり散らかすと、さとり様に怒られるし…」
		PRINTFORML 「そうだ！　あたいの部屋に行こうか！」
		PRINTFORMW 「言っとくけど、エッチなのは無しだからね！」
	ELSEIF TALENT:恋慕
		PRINTFORML 「ただいま～♪」
		PRINTFORML 「って、違うか」
		PRINTFORMW 「ま、せっかくだから、くつろいでってよ、お兄さん♪」
	ELSE
		PRINTFORML 「地霊殿へようこそ！」
		PRINTFORML 「…デートと言うより、あたいとしては帰って来ただけだけど…」
		PRINTFORMW 「まあ、あたいが案内できるのって、ここくらいだしねぇ…」
	ENDIF
;魔法の森
CASE "魔法の森"
	IF TALENT:恋人
		PRINTFORML 「ここって、魔法使いのお姉さんとか、人形使いのお姉さんとか住んでるんだよね？」
		PRINTFORML 「それにしては、静かだねぇ」
		PRINTFORMW 「あ、そうか。今はいないんだ。じゃあ、いつもは…」
	ELSEIF TALENT:恋慕
		PRINTFORML 「ちょっと、ジメジメした所だねぇ」
		PRINTFORML 「あたいはこういう所、結構好きだけど」
		PRINTFORMW 「妙な空気もあるし。どっちかというと、妖怪向きの森かな」
	ELSE
		PRINTFORML 「のんびりするには、いいかもね」
		PRINTFORML 「たまに、妖精とか妖怪とか出るけど…」
		PRINTFORMW 「雑魚ばかりだし、あたいがいればその辺は大丈夫！」
	ENDIF
;命蓮寺
CASE "命蓮寺"
	IF TALENT:恋人
		PRINTFORML 「あ、思い出した」
		PRINTFORML 「そうか、これってあの船だったんだ」
		PRINTFORMW 「それが、へぇ………これまた、奇縁だね！」
	ELSEIF TALENT:恋慕
		PRINTFORML 「へえ、船だったんだ？」
		PRINTFORML 「しかも、空を飛んでいて、少し前まで地下にあった？」
		PRINTFORMW 「お寺って、凄いんだねぇ…」
	ELSE
		PRINTFORML 「…う～ん」
		PRINTFORML 「紅白のお姉さんの神社と違って、ここはなんか嫌な感じ…」
		PRINTFORMW 「妖怪を拒否してるわけじゃないけど、荘厳的…っていうのかな？」
	ENDIF
ENDSELECT
