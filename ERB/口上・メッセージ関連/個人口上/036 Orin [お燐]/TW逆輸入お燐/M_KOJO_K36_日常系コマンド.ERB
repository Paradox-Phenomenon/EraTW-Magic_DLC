;301,泡茶
;TFLAG:193(1=大成功 0=成功 -1=失敗)
;==================================================
@M_KOJO_ENG01_SUCCESS_COM_K36_301
;成否判定
;TFLAG:192(-2=指令終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

@M_KOJO_ENG01_MESSAGE_COM_K36_301
CALL M_KOJO_ENG01_MESSAGE_COM_K36_301_1
RETURN RESULT

@M_KOJO_ENG01_MESSAGE_COM_K36_301_1
#DIM 给K36初次泡茶
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF 给K36初次泡茶 == 0
		;PRINTFORML 「Tea for me? I appreciate it, %CALLNAME:PLAYER%. A bit thirsty after all.」
		
		PRINTFORML 「あたいにお茶？ありがとね、%CALLNAME:PLAYER%♪ ちょうど喉が渇いてたとこなんだ～」
		给K36初次泡茶 = 1
		RETURN 0
	ENDIF
	IF TFLAG:193 > -1
		SELECTCASE RAND:5
			CASE 0
				;PRINTFORML 「Nyaa～～ This goes down really well～」
				;PRINTFORML 「You must be skilled at serving tea, aren't you %CALLNAME:PLAYER%?」				
				
				PRINTFORML 「にゃ～っ…これ、すっごく飲みやすくて美味しいね～♪」
				PRINTFORML 「君って、もしかしてお茶を淹れるの上手だったりする？%CALLNAME:PLAYER%？」
			CASE 1
				;PRINTFORML 「Nyaammm～～ It wouldn't hurt to have a bit of tea.」
				;PRINTFORML 「A cup of hot tea after work is wonderfully refreshing～」
				
				PRINTFORML 「にゃーん…ちょっとくらいお茶飲んだってバチは当たらないよね～？」
				PRINTFORML 「お仕事のあとに熱いお茶を一杯…これが最高に癒されるんだよ～♪」
			CASE 2
				;PRINTFORML 「Nyaammm～～ Your tea is always so great, %CALLNAME:PLAYER%～」
				;PRINTFORML 「I wonder how you prepare tea this well. Please provide a bit to Okuu some time.」
				
				PRINTFORML 「にゃーん…君のお茶ってほんっと美味しいんだよね、%CALLNAME:PLAYER%～♪」
				PRINTFORML 「どうやったらこんなに上手に淹れられるのかにゃ～？今度はお空にも、ちょっとだけ分けてあげてよっ♪」
			CASE 3
				;PRINTFORML 「Ohnya? Thank you very much for the tea, %CALLNAME:PLAYER%～」
				;PRINTFORML 「The underground does not cultivate much in terms of tea so you may not find any there.」
				;PRINTFORML 「Although, the palace is an exception.」
				
				PRINTFORML 「うにゃっ？ お茶、ありがとね～、%CALLNAME:PLAYER%♪」
				PRINTFORML 「地底じゃあんまりお茶って育たないから、滅多に飲めないんだよ～」
				PRINTFORML 「でも、地霊殿だけはちょっと特別だけどね♪」
			CASE 4
				;PRINTFORML 「Ahnya, a bit of tea? Thank you, %CALLNAME:PLAYER%～」
				;PRINTFORMDL Rin drinks the entire cup...
				;PRINTFORML 「Haaa～～」
				;PRINTFORML 「This tea is great! Much much better than the subpar tea served at the shrine.」
				;PRINTFORML 「%CALLNAME:PLAYER%, I beg that you make some more so that I may bring back a bit for Satori-sama!」
				
				PRINTFORML 「んにゃっ、お茶？ありがと～、%CALLNAME:PLAYER%♪」
				PRINTFORMDL お燐はお茶を一気に飲み干した…
				PRINTFORML 「はぁ～～」
				PRINTFORML 「このお茶、最高だよ！神社で出される味の薄いのより、ずーっと美味しいっ！」
				PRINTFORML 「ねぇ、%CALLNAME:PLAYER%、お願いっ！さとり様に持って帰れるように、もう少し淹れてくれないかな～？」
		ENDSELECT
	ELSE
		;PRINTFORML 「Tea? Don't mind if I do～」
		;PRINTFORMDW Rin takes a sip. 
		;PRINTFORMDL Suddenly hissing, Rin jumps back and wipes her mouth.
		;PRINTFORML 「Ehhh... This may be a bit too bitter, don't you think?」
		
		PRINTFORML 「お茶？ いただきま～す♪」
		PRINTFORMDW お燐は一口すする。 
		PRINTFORMDL …と思ったら、突然「ふにゃっ！」と声をあげて飛びあがり、口元をぬぐった。
		PRINTFORML 「えぇ～…これ、ちょーっと苦すぎない？大人の味すぎるんじゃないの～？」
	ENDIF
ENDIF
RETURN 1
