		PRINTFORMW 「でも、嬉しいよ。ありがと、お兄さん♪」
		
		CALL GIFTDATA_MAIN(GET_GIFTDATA(TCVAR:36:今日の贈り物, "本体"))
		strGift = %RESULTS%
		nPrice = RESULT:1
		IF STRFIND(RESULTS:1, "抱く") >= 0
			strReaction = 抱く
		ELSEIF STRFIND(RESULTS:1, "眺める") >= 0
			strReaction = 眺める
		ELSEIF STRFIND(RESULTS:1, "握る") >= 0
			SIF STRFIND(RESULTS:1, "装飾") >= 0
				strReaction = 装飾
			strReaction = 握る
		ELSE
			strReaction = 身につける
		ENDIF
	ENDIF

	SELECTCASE TFLAG:194
		;ひやかし
		CASE -2
		;(GET_MAPID(CFLAG:MASTER:現在位置) == 5 && GIFTSHOP_NAME(5) == "香霖堂") ;kourindou check
		;やっぱりやめる（見送り）
		CASE -1
		
		;400点未満（BAD）
		CASE 1
		
		;400点～699点（NOMAL）
		CASE 2, 3
			IF STRFIND(RESULTS:1, "装飾") >= 0
				IF TALENT:恋人
					PRINTFORML 「にゃは～…」
					PRINTFORML 「この間、鈴をリクエストしたの覚えててくれたんだね」
					PRINTFORMW 「これを付けてる間、あたいはお兄さんのものだよ♪」
				ELSEIF TALENT:恋慕
					PRINTFORML 「うーん、おくうに取られないように隠しておかないと…」
					PRINTFORMW 「でも、せっかくだから身に付けておきたいし…うーん…」
				ELSE
					PRINTFORML 「こういうキラキラしたのは、おくうが好きそう…」
					PRINTFORMW 「でも、嬉しいよ。ありがと、お兄さん♪」
				ENDIF
			ELSEIF strReaction == "身につける"
				IF TALENT:恋人
					PRINTFORML 「ねぇねぇねぇねぇ、今度一緒に買いにいこ！」
					PRINTFORML 「それで、その場でプレゼント！」
					PRINTFORMW 「そういうのも、いいもんだよ。デートも兼ねられるし♪」
				ELSEIF TALENT:恋慕
					PRINTFORML 「じゃじゃ～ん！」
					PRINTFORMW 「どう？　可愛い？　可愛い？」
				ELSE
					PRINTFORML 「あたいの服だと、尻尾の関係でオーダーメイドになるよねぇ」
					PRINTFORMW 「わざわざありがとう、お兄さん」
				ENDIF
			ELSE
				IF TALENT:恋人
					PRINTFORML 「だんだん、プレゼントで埋まって行くような…」
					PRINTFORMW 「だってだって、壊すの怖いし、捨てるのやだし！」
				ELSEIF TALENT:恋慕
					PRINTFORML 「うん、大事に使うよ」
					PRINTFORMW 「貰って嬉しく、使って便利。一石二鳥だぁね」
				ELSE
					PRINTFORML 「地上のは、やっぱり地底より新しい感じだねぇ」
					PRINTFORMW 「ありがと。さっそく使わせてもらうね！」
				ENDIF
			ENDIF
	ENDSELECT
ENDIF
