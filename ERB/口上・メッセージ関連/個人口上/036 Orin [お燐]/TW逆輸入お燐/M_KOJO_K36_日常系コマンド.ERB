@M_KOJO_ENG01_MESSAGE_COM_K36_302_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF FIRSTTIME(SELECTCOM)
		PRINTFORML 「お兄さんには、特別にあたいを撫でる許可をあげよう！」
		PRINTFORML 「さとり様と、おくうと、こいし様…その次だから、四人目だよ」
		PRINTFORMW 「それしかいないんだから、光栄に思うように！」
	ELSE
		IF TALENT:恋人 && RAND:4
			SELECTCASE RAND:4
				CASE 0
					PRINTFORML 「にゃーん♪」
					PRINTFORMDL そう言いながら、人（？）の姿のまま、こちらの膝を枕にする
					PRINTFORML 「えへへ…今回は、お兄さんが枕の番だよ」
					PRINTFORMDW 『次は交替してあげる』といいつつ、燐は頬を何度も足に摺り寄せて来た
				CASE 1
					PRINTFORML 「～♪　～～♪」
					PRINTFORMDL 燐は、何かと身体をベッタリくっつけてくる
					PRINTFORML 「ん？　狭いと落ち着くから。猫的に」
					PRINTFORMW 「それに、こういうの悪くないでしょ？　恋人的に」
				CASE 2
					PRINTFORML 「お兄さんさー、あたいのこと、わりと本格的に猫扱いするよね？」
					PRINTFORML 「そりゃ、全面的に違うとは言わないけど」
					PRINTFORML 「あたいとしては、ちゃんと恋人っぽく扱って欲しいのよ」
