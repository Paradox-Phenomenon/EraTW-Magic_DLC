;300,会話
;TFLAG:193(1=大成功 0=成功 -1=失敗 -2=大失敗（TARGETがMASTERより教養が4以上高い)
;TCVAR:302(0=会話可能 1>=非恋慕時会話不能)
;MARK:反発刻印(3以上=会話不能)(4以上はバグ
;TCVAR:烂醉(1=通常成功or大失敗)
;==================================================
@M_KOJO_ENG01_SUCCESS_COM_K36_300
;成否判定
;TFLAG:192(-2=指令終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

@M_KOJO_ENG01_MESSAGE_COM_K36_300
;指令共通メッセージ(TRAIN_MESSAGE) 
;削除すると 「～说着话。」とかが消えます。また、削除した場合は自動で口上色が付きません。
;口上メイン呼出
CALL M_KOJO_ENG01_MESSAGE_COM_K36_300_1
RETURN RESULT

@M_KOJO_ENG01_MESSAGE_COM_K36_300_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF TFLAG:193 == -3 ;custom code, hate mark 3
		RETURN
	ENDIF
	IF TFLAG:193 == -1
		SELECTCASE RAND:3
			CASE 0
				;PRINTFORML 「You mustn't force yourself to talk to me, %CALLNAME:PLAYER%～」
				;PRINTFORML 「Wait a while. You'll have a topic in no time.」
				
				PRINTFORML 「無理にあたいと話そうとしなくていいんだよ、%CALLNAME:PLAYER%～」
				PRINTFORML 「ちょっと待ってれば、そのうち話したくなることも出てくるって♪」
			CASE 1
				;PRINTFORMDL You want to say something but your mind draws a blank.
				;PRINTFORML 「Ahaha, it's alright, %CALLNAME:PLAYER%.」
				;PRINTFORML 「Try relaxing, we have plenty of time to talk over tea.」
				
				PRINTFORMDL 何か言いたいのに、言葉がまったく思い浮かばない。
				PRINTFORML 「あはは、大丈夫だよ、%CALLNAME:PLAYER%♪」
				PRINTFORML 「そんなに緊張しなくていいよ。お茶でも飲みながら、ゆっくりおしゃべりしよ？」
			CASE 2
				;PRINTFORML 「You mustn't force yourself to talk, %CALLNAME:PLAYER%.」
				;PRINTFORML 「No one is born innately well in speech.」
				;PRINTFORML 「Give yourself a bit of think time.」
				
				PRINTFORML 「無理に話そうとしなくていいんだよ、%CALLNAME:PLAYER%」
				PRINTFORML 「生まれつきおしゃべり上手な人なんて、そうそういないしね」
				PRINTFORML 「ゆっくりで良いから、おしゃべりしよ？」
		ENDSELECT
	ELSE
		IF TALENT:恋人 && RAND:6
			SELECTCASE RAND:6
				CASE 0
					PRINTFORML 「恋人…恋人かぁ…」
					PRINTFORML 「にゃふ～…にゃあ～…ぁぁぁぁぁっ！？」
					PRINTFORMDL なにやら、情緒不安定になっているようだ
					PRINTFORMDW そこまで意識されると、こちらも恥ずかしくなってしまうのだが…
				CASE 1
					PRINTFORML 「ねえ、お兄さん」
					PRINTFORML 「お兄さんの呼び方、お兄さんのままでいいのかな？」
					PRINTFORML 「でも、お兄さんって呼び方気に入ってるから、お兄さんのままでいいか…」
					PRINTFORMW 「ね、お兄さん♪」
				CASE 2
					PRINTFORML 「いっそ、地上で暮らすのもいいかなぁ…」
					PRINTFORML 「さとり様のペットは、放し飼いってことで続けてもいいし…」
					PRINTFORML 「さすがに、おくうとはあまり会えなくなるだろうけど…」
					PRINTFORMW 「お兄さんは、どう思う？」
				CASE 3
					PRINTFORML 「お兄さんってさぁ…」
					PRINTFORML 「………所謂、獣属性？」
					PRINTFORML 「あ、ううん。別に、お兄さんの人間性を貶めたいとかじゃなくて」
					PRINTFORMW 「あたいは…“ああいう妖怪”だからさ。ちょっと、気になっただけ」
				CASE 4
					PRINTFORML 「仮に、あたいが地上に居座るとして」
					PRINTFORML 「やっぱり、赤い方の巫女はなんか言うかなぁ…」
					PRINTFORML 「まめにお酒を仕入れれば、大丈夫っぽいけど」
					PRINTFORML 「ついでに、御賽銭の一つや二つ入れれば、完璧だね！　きっと」
					PRINTFORMDW 酷い言い様だ。反論しにくいが
				CASE 5
					PRINTFORML 「あたいは火の車だし、死体相手ばっかだったから」
					PRINTFORML 「こうして誰かとじっくり話したことってなかったけど…」
					PRINTFORML 「もっと前からこうしてたら、早く恋人できたかな？」
					PRINTFORMW 「あ、お兄さんちょっとムッとした？　冗談だよ、冗談♪」
			ENDSELECT
		ELSEIF TALENT:恋慕 && RAND:6
			SELECTCASE RAND:5
				CASE 0
					PRINTFORML 「ね、お兄さん」
					PRINTFORML 「今度、地底に遊びに来ない？」
					PRINTFORML 「さとり様達に、紹介したいし…あ、でも…」
					PRINTFORMDW 突如、う～んと唸り始める。なんなのだろう？
				CASE 1
					PRINTFORML 「お兄さんお兄さんお兄さん！」
					PRINTFORMDL いきなり腕にしがみつきながら、そう連呼する
					PRINTFORML 「あれ…？　なんだっけ…？　まあ、いいか♪」
					PRINTFORMDW 一人納得すると、ギュッと腕に力を込めてくる
				CASE 2
					PRINTFORML 「いやしかし、地上暮らしも悪くないね」
					PRINTFORML 「おくうのおかげで、温泉も近くにあるし…」
					PRINTFORML 「え？　あたいは温泉好きだよ？」
					PRINTFORMW 「なんか、変なこと言ったかなぁ？」
				CASE 3
					PRINTFORML 「それにしても、おくうがあんなになった時はどうなる事かと思ってたけど」
					PRINTFORML 「今の幻想卿が、おおらかでよかったよ」
					PRINTFORML 「もともとが、旧地獄には嫌われ者が多かったからね」
					PRINTFORMW 「ましてや、お兄さんみたいな人間がいるなんて、想像もできなかったよ」
				CASE 4
					PRINTFORML 「あたいは、火の車なんだよ。赤い方の巫女的じゃない意味で」
					PRINTFORML 「だからお兄さん、もしもの時も安心していいよ♪」
					PRINTFORMDW …どう安心しろと言うのだろうか…
			ENDSELECT
		ELSE
			SELECTCASE RAND:15
				CASE 0
					;PRINTFORML 「Nya～ Nothing interesting has happened recently.」
					;PRINTFORMDL Rin arches her back with a stretch.
					
					PRINTFORML 「にゃ～、最近はぜんっぜん面白いこと起きないんだよね～」
					PRINTFORMDL お燐は背中をぐ～んと反らして、気持ちよさそうに伸びをした。
				CASE 1
					;PRINTFORML 「There are always more and more pets in the palace! Satori-sama keeps taking them home!」
					;PRINTFORMDL You wonder if all of them are like Rin.
					;PRINTFORML 「Ohnya? There are other felines, but I'll have you know I'm Satori-sama's favorite!」
					
					PRINTFORML 「地霊殿ってね、ペットがどんどん増えてくんだよ！さとり様ってば、かわいい子見つけるたびにお持ち帰りしちゃうんだから！」
					PRINTFORMDL みんなお燐みたいなやつなのだろうか。
					PRINTFORML 「んにゃ？他にも猫はいるけどさ、あたいがさとり様のお気に入りってこと、ちゃんと覚えといてよね♪」
				CASE 2
					;PRINTFORML 「Ohnya? There are very few pets that can turn human like Okuu and I.」
					;PRINTFORMDL You wonder how that can be the case if you only ever see those two around.
					;PRINTFORML 「Not all animals have the energy to. It certainly is difficult to stay human for any duration.」
					
					PRINTFORML 「んにゃ？お空とあたいみたいに、人の姿になれるペットはそう多くないんだよ」
					PRINTFORMDL でも、実際に見るのはその二人ばかりだし…他にはいないのかと君はふと疑問に思う。
					PRINTFORML 「みんながみんな、その力を持ってるわけじゃないしね～。それに、人の姿を保つのって、実はけっこうエネルギー使うんだよ。」
				CASE 3
					;PRINTFORMDW You wonder how Rin can live in the hot climate of the palace.
					;PRINTFORML 「Hehe, that scorching heat must be unbearable for an ordinary human.」
					;PRINTFORML 「It must really be as if it were summer all year round, eh %CALLNAME:PLAYER%?」
					
					PRINTFORMDW お燐はどうしてあんなに暑い地霊殿の中でも平気で暮らせるのだろうか？君はふと疑問に思う。
					PRINTFORML 「ふふっ、普通の人間だったら、あの暑さはたまったもんじゃないだろうね～」
					PRINTFORML 「地上なら、一年中ずーっと真夏って感じかな？ね、%CALLNAME:PLAYER%？」
				CASE 4
					;PRINTFORMDL You wonder how Rin came to join the Komeiji household.
					;PRINTFORML 「Well, Okuu and I were originally strays on the streets of Old Hell.」
					;PRINTFORML 「Satori-sama found the crow and the cat, bringing them into the palace.」
					;PRINTFORML 「Ah, but this hobby of Satori-sama's has become a bit of a problem...」
					
					PRINTFORMDL お燐はどうして古明地家に仕えることになったのか…君はふと気になった。
					PRINTFORML 「ん～、あたいとお空は、もともと旧地獄の路地裏で暮らしてた野良だったんだよ」
					PRINTFORML 「それをさとり様が拾ってくれてさ、カラスと猫をそのままお屋敷に迎えてくれたの」
					PRINTFORML 「でも、さとり様のこの“趣味”が、ちょっとした問題になってたりもするんだよね～」
				CASE 5
					;PRINTFORML 「Ohoho-nya, daring to try some local liquor, %CALLNAME:PLAYER%?」
					;PRINTFORML 「Onikoroshi—the oni slaying sake～～ The Oni love to down it dry but you may meet your doom after just a drop!」
					
					PRINTFORML 「にゃはは～♪地底の地酒に手を出すなんて、なかなか勇気あるじゃん、%CALLNAME:PLAYER%？」
					PRINTFORML 「これが“鬼殺し”鬼ですら酔い潰すっていう伝説の酒なんだよ～鬼たちはガブガブ飲むけど、君なんか一口で昇天しかねないよ？」
				CASE 6
					;PRINTFORML 「Hm? Ahnya, these wisps are what you humans refer to as 'vengeful spirits'. It's my job to keep them controlled.」
					;PRINTFORMDL You wonder what it's like being a vengeful spirit.
					;PRINTFORML 「Eh? Well, for starters, you can never reenter the karmic cycle of reincarnation.」
					;PRINTFORML 「If you ever seriously consider it, you would certainly be safe, sheltered and secure.」
					
					PRINTFORML 「ん？これね、人間の言う“怨霊”ってやつ。あたいの仕事はこいつらをちゃんと抑えておくことなんだ」
					PRINTFORMDL 君はふと、怨霊になるってどんな感じなんだろうと考えた。
					PRINTFORML 「え？まずひとつ言っとくと…いったん怨霊になっちゃうと、もう輪廻転生には戻れないよ」
					PRINTFORML 「それでももし本気でそうなろうなんて考えてるなら…今のうちにちゃんと安全な場所で守られてる方がいいと思うよ？」
				CASE 7
					;PRINTFORML 「Is my work much too difficult, %CALLNAME:PLAYER%? Hmmm...I am very much never in any terrible trouble.」
					;PRINTFORML 「Ahnya, but are you familiar with those who meet death by drowning?」
					;PRINTFORML 「Their bodies fill up with water and expand like bread. It's weary work having to wring the bodies dry before wheeling them away.」
					;PRINTFORML 「Nevertheless, it is the duty of a corpse-carting kasha.」
					
					PRINTFORML 「あたいの仕事ってそんなに大変そうに見える？ %CALLNAME:PLAYER% ん～…まぁ、よっぽどのことがない限り、そんなに困ったりはしないけどね～」
					PRINTFORML 「にゃ－、それより…“溺死体”って知ってる？」」
					PRINTFORML 「あれ、体の中が水でパンパンに膨らんじゃってさ、パンみたいになるんだよね～。運ぶ前に絞って水抜きするのがけっこう骨でさ～」
					PRINTFORML 「ま、それでも死体を運ぶのが火車の務めだからね～」
				CASE 8
					;PRINTFORML 「My work is very much easier in the winter～」
					;PRINTFORML 「Exposure to the summer elements leaves bodies to rapid rot.」
					;PRINTFORML 「They are much simpler to fetch when frozen finely.」
					
					PRINTFORML 「冬になると、あたいの仕事もだいぶ楽になるんだよね～」
					PRINTFORML 「夏の暑さにさらされた死体って、すぐ腐っちゃうからさ」
					PRINTFORML 「でも凍ってると、ほら、カチカチで扱いやすいんだよ～♪」
				CASE 9
					PRINTFORML 「Now that I think about it... You're very much weird %CALLNAME:PLAYER%～」
					PRINTFORML 「Humans find matters of the dead horrifying.」
					PRINTFORML 「Is the little kitten not afraid of the kasha?」
					
					PRINTFORM  「そういえばさ…君って、けっこう変わってるよね～、%CALLNAME:PLAYER%？」
					PRINTFORML 「人間ってさ、普通は“死”とか“死体”って聞くだけで震え上がるもんでしょ？」」
					PRINTFORML 「…ちっちゃい子猫ちゃんは、火車が怖くないのかにゃ～？」
				CASE 10
					;PRINTFORML 「Nya? What I would like to eat?」
					;PRINTFORML 「There is a sweets shop in the village that serves the most sugary sponge cakes～～」
					;PRINTFORMDW Orin twirls her tails around, drooling.
					;PRINTFORML 「Surprised that the answer wasn't souls or skeletons? Bleh, I would never!」
					
					PRINTFORML 「にゃ？あたいの好物？」
					PRINTFORML 「人里にね～、すっごく甘いカステラを出してくれるお菓子屋さんがあるんだよ～！」
					PRINTFORMDW お燐は尻尾をくるくる回しながら、よだれをたらしている。
					PRINTFORML 「え、魂とか骨かと思った？やだなー、あたいそんなの食べたりしないってば、べ～っ！」
				CASE 11
					PRINTFORMW 「地底の話？じゃあ、お兄さんは地上の話をしてよ」
				CASE 12
					PRINTFORML 「地上は、太陽がポカポカしてるねぇ」
					PRINTFORMW 「おくうのアレは、ちょっと違うし…」
				CASE 13
					PRINTFORML 「そういえば、地底の舟幽霊、出て来たんだっけ？」
					PRINTFORML 「うん、知ってたよ。でも、あたいの担当は怨霊だったし」
					PRINTFORMW 「それに、あそこまで強くて自我を保ってたら、あたいがどうこうできる代物じゃないよ」
				CASE 14
					PRINTFORML 「さとり様は、あたいの達の他にも、たくさんペットを飼ってるよ」
					PRINTFORML 「その世話の手伝いをしてるけど…」
					PRINTFORML 「ペットがペットの世話をしてるのってさ…」
					PRINTFORMDW 『式の式もいるのだし』、とはお互い口には出さなかった
			ENDSELECT
		ENDIF
	ENDIF
ENDIF
RETURN 1
