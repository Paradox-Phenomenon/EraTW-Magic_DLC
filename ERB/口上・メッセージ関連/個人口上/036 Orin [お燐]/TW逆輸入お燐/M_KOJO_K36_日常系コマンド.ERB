;350,推倒（時姦時猥褻
;TFLAG:194 (0=成功 1=人目がある　2=野外は嫌でござりまする　3=多人数プレイは勘弁　4=合意があっても情緒が足りぬ　100=合意はあるが口上内特殊判定によって失敗）
;TCVAR:初次拥抱　1=普通に合意ゲット　2=先に接吻ぐらいしろよ　3=媚薬or発情には勝てなかったよお…　4=悔しい…刻印さえなければﾋﾞｸﾋﾞｸﾝ
;5=強引に迫られると断れぬ(素質膽怯持ち専用) 6=まんざらでもない　7=駄目　8=論外 98=口上内特殊判定による失敗 99=口上内特殊判定による成功
;口上内特殊判定は該当するCFLAGが0だと無効
;==================================================
@M_KOJO_ENG01_MESSAGE_COM_K36_350
CALL M_KOJO_ENG01_MESSAGE_COM_K36_350_1
RETURN RESULT

@M_KOJO_ENG01_MESSAGE_COM_K36_350_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	SIF !SHIRAHU(TARGET) || FLAG:70 ;custom code - unconscious, time stop
		RETURN 1
	IF TFLAG:194 == 4 || TCVAR:抱き寄せ初回 == 6 ;if refused due to mood
		PRINTFORML 「うー…お兄さんのことは嫌いじゃないけど…」
		PRINTFORMW 「やっぱり、それとこれとは話が別！」
	ELSEIF GROUPMATCH(TCVAR:抱き寄せ初回, 3, 4, 5) ;if agreed, coercion
		PRINTFORML 「強引なのは別にいいけど…」
		PRINTFORMW 「これは強引とは別だと思うな、お兄さん！」
	ELSEIF GROUPMATCH(TCVAR:抱き寄せ初回, 7, 8) ;if refused, flatly
		PRINTFORMW 「にゃあ！？　何するのさ、お兄さん！」
	ELSE
		SIF TFLAG:194 || TFLAG:押し倒せない ;custom code - failure check
			RETURN 1
		IF BATHCHECK(CFLAG:現在位置)
			IF TALENT:恋慕
				PRINTFORML 「～♪」
				PRINTFORML 「ん？　あたい、お風呂好きだよ？」
				PRINTFORMW 「お兄さんと、ダブルで温かいしねぇ」
			ELSE
				PRINTFORML 「お風呂？　そこでするの？」
				PRINTFORML 「お兄さんってば、どこでもいいなんて、ケダモノ！」
				PRINTFORMW 「でも、ま、いいかぁ」
			ENDIF
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「どうしたの、急に盛ったりして…」
					PRINTFORMW 「んー…仕方ないなぁ。お兄さんにだけ、特別だよ」
				CASE 1
					PRINTFORML 「わわ！？　ど、どうしたのお兄さん、いきなり抱きついて！？」
					PRINTFORML 「…はは～ん、なるほど。ムラムラ来ちゃったんだ…」
					PRINTFORMW 「こんなに、硬くしちゃってるもんね…。うん、いいよ…」
				CASE 2
					PRINTFORML 「もう、えっちぃなぁ、お兄さんは」
					PRINTFORMW 「ちょっとだけ…だよ」
			ENDSELECT
		ENDIF
	ENDIF
ENDIF
RETURN 1
