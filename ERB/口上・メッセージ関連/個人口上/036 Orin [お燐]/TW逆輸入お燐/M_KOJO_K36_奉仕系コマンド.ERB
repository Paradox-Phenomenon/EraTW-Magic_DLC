@M_KOJO_ENG01_MESSAGE_COM_K36_80_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		PRINTFORMW 「あ……お兄さんの……凄くびくびく震えてるねぇ」
		PRINTFORMW 「なんだか……猫じゃらしみたいでかわいいねぇ、おちんちんって」
		PRINTFORMDW ビクビクッという男性器の震えを感じながら、お燐はボソッともらした。 
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		;PRINTFORMW 
		RETURN 1
	;恋慕
	ELSEIF TALENT:恋慕 && RAND:3
		SELECTCASE RAND:3
			CASE 0
				PRINTFORML 「にゅふふ～。………ん…」
				PRINTFORMDL 燐は唾液を垂らすと、さするようにしながら丹念に一物に塗りつける
				PRINTFORML 「デリケートなところなんだよね？　だから、滑りをよくしないと…」
				PRINTFORML 「もと、強くされた方がいい？　…なんか、どっちでもよさそうだぁね…」
				PRINTFORML 「だってほら、もうこんなに大きく…ビクビクッてなってるし…」
				PRINTFORMW 「お兄さんが好きな時にイっていんだよ…ちゃんと、受け止めてあげるからさ…」 
			CASE 1
				PRINTFORMW 「んんっ……今日も元気だねぇ」
				PRINTFORMW 「後で、あたいの事も……気持ちよくしてほしいところだねぇ？」
			CASE 2
