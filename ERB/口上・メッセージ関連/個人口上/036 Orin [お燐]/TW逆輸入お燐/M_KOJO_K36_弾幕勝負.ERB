;==================================================
;弾幕勝負 custom code, added
;==================================================
;
@M_KOJO_ENG01_MESSAGE_COM_K36_DANMAKU(ARGS, 相手残機)
#DIM 相手残機
;全体の流れ
;①【戦闘前】→②ダイスロールとプレイヤー選択肢、ハンデをつけた場合は【ハンデ口上】→③対応スキルが発動した場合【スキル口上】→④被弾判定、キャラが被弾したなら【被弾口上】→
;どちらかの残機が0になっていなければ②に戻る→⑤【戦闘後口上】

;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
SIF FLAG:口上色
	TRYCALLFORM M_KOJO_ENG01_COLOR_K{NO:TARGET}
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;ハンデをつけることができ、数値が大きいほどあなたが不利になる　数値が負ならあなたが有利に
	;キャラの能力に関わらずクッソ強くしたり弱くしたりできる
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "戦闘前"
		;戦闘前
		HANDICAP_FIXED = 0
		HANDICAP_RAND = 0
		PRINTFORML 「じゃじゃ～ん」
		PRINTFORMW 「それじゃあ、お兄さん。始めよーかぁ」
		PRINTFORML 「え？ スペカ？」
		PRINTFORML 「お兄さんに使ったら、死体になっちゃうよー」
		PRINTFORMW 「それとも…そっちがお望み？」
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;ハンデ
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "ハンデ"
		;ハンデつけなかったら表示されないので無記入でよい
		PRINTFORML 
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;戦闘中TARGET被弾時口上
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "被弾" 
		;別に一律で「やられたー」だけでもいいよ
		SELECTCASE 相手残機
			;残り残機3が表示されるのは【洽覧深識】持ちのみ
			CASE 3
				PRINTFORML 
			CASE 2
				PRINTFORML 「そろそろ、スペカ使っていこうかぁ」
				PRINTFORML 「小手調べ！　恨霊『スプリーンイーター』！」
				PRINTFORMW 「そういえば、お兄さんって、スペカ持ってたっけ？」
			CASE 1
				IF RAND:2
					PRINTFORML 「『小悪霊復活せし』！！」
					PRINTFORML 「どう、あたいの最強技！」
					PRINTFORMW 「お兄さんも、なんか作ってみたらどうかなぁ？」
				ELSE
					PRINTFORML 「屍霊『食人怨霊』！！」
					PRINTFORML 「どう？　ちょっと、本気」
					PRINTFORML 「褒めていいんだよー？」
					PRINTFORMDW むしろ褒めろと言わんばかりに、尻尾をウズウズと振っている
				ENDIF
			CASE 0
		ENDSELECT
	ENDIF
	
	IF ARGS == "Pichun"
		;RESULT:8 for player's lives
		SELECTCASE RAND:3
			CASE 0
				PRINTFORML 「猫車アタック！！」
				PRINTFORML 「え？　弾幕じゃない？」
				PRINTFORMW 「戦闘中なら、肉弾戦もありだよ♪」
			CASE 1
				PRINTFORML 「呪精『ゾンビフェアリー』！」
				PRINTFORMW 「…と、見せかけて、猫車クラッシュ！」
			CASE 2
				PRINTFORML 「贖罪『旧地獄の針山』！」
				PRINTFORML 「………ごめん、やり過ぎた…かな？」
				PRINTFORMDL そういって、ペロッと舌を出す
				PRINTFORMDW 笑って誤魔化そうとしても…ちょっとくらいなら、許してもいいかも
		ENDSELECT
	ENDIF
	
	;-------------------------------------------------
	;戦闘中
	;TARGETの【残忍酷薄】発動時
	;ARGはTARGETの残機
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "残忍酷薄"

	ENDIF
	;-------------------------------------------------
	;戦闘中
	;TARGETの【乾坤一擲】発動時
	;ARGはTARGETの残機
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "乾坤一擲"
		
	ENDIF
	;-------------------------------------------------
	;戦闘中
	;TARGETの【怪力乱神】発動時
	;ARGはTARGETの残機
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "怪力乱神"
		
	ENDIF
	
	;-------------------------------------------------
	;戦闘後
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "戦闘後" 
		PRINTFORML 
		;残り残機4が表示されうるのは【洽覧深識】持ちのみ
		;残機が1以上ならあなたの負け、0の場合はあなたの勝利
		SELECTCASE 相手残機
			CASE 4
				PRINTFORML 
			CASE 1 TO 3
				IF RAND:2
					PRINTFORML 「大丈夫ー？　集中してよねー」
					PRINTFORMW 「…‥…怪我させたりとか、したくないんだからさ…」
				ELSE
					PRINTFORML 「まだまだ、だぁねぇ」
					PRINTFORMW 「大丈夫、手加減したげるからさ！」
				ENDIF
			CASE 0

		ENDSELECT
	ENDIF
RESETCOLOR
ENDIF
RETURN 1

