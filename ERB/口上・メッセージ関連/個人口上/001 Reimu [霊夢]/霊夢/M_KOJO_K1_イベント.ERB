			PRINTFORML 「…就稍微就原谅你吧」
			PRINTFORML 「但是，如果再得意忘形的话，下场你知道的吧？」
			PRINTFORMDL 灵梦板着脸说道。
			PRINTW
		ENDIF
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;反感刻印3>2レベルダウンイベント
	;记入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		IF TALENT:恋人
			PRINTFORML 「做得太过分的话、就干掉你哦」
			PRINTFORML 「……但是，就稍微原谅你好了」
			PRINTFORML 「不用谢」
			PRINTFORMDW 灵梦板着脸对%CALLNAME:MASTER%说道。
			RETURN 0
		ELSE
			PRINTFORML 「%CALLNAME:MASTER%、听我一言」
			PRINTFORML 「与其向我撒娇、不如停止那些行为哦」
			PRINTFORML 「这次、稍微原谅你了」
			PRINTFORML 「但是、%CALLNAME:MASTER%、以后会怎么样就看你的行动了」
			PRINTW
		ENDIF
		RETURN 0
	ENDIF
	PRINTFORML
ENDIF
RETURN 0

