		ELSE
			PRINTFORMDL 你和灵梦点头致意。
			PRINTFORMDW 灵梦好像有点无动于衷啊，点点头致意就过去了。
		ENDIF
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;无视して街道过ぎた
	;记入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		SIF FLAG:時間停止
			RETURN 1
		PRINTFORMD 灵梦
		IF TALENT:恋人
			PRINTFORMD 带着温柔的笑容
		ELSEIF TALENT:恋慕
			PRINTFORMD 微笑地
		ELSEIF GETBIT(CFLAG:1,0)
			PRINTFORMD 目不转睛地
		ENDIF
			PRINTFORMDW 看着%CALLNAME:MASTER%。
		RETURN 0
	ENDIF
	;其他
ENDIF
RETURN 0

