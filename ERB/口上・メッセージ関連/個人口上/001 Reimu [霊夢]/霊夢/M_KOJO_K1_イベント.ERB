@M_KOJO_SPEVENT_K1_2(ARG,ARG:1)
;台词主人公为TARGET
;地の文表示
;--------------------------------------------------
;记入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;告白内容
	;この告白内容表示后に接受かどうかの选择分が表示されます
	;记入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 0
		PRINTFORMDW ——那么，大概马上就要到神社了吧。
		PRINTFORMDW 走在前面的灵梦突然回过头看着你。
		PRINTFORMW 「……呐」
		PRINTFORMDW 怎么了、突然停下来、这样问道。
		PRINTFORMW 「那个，啊。那个、%CALLNAME:MASTER%、我有话想对你说」
		PRINTFORMDW 灵梦低着头小声的说着。
		PRINTFORMDW 这样扭扭捏捏的灵梦有点不寻常啊，%CALLNAME:MASTER%端详着灵梦的脸。
		PRINTFORMW 「————————额」
		PRINTFORMDW 灵梦的脸变得通红。
		PRINTFORMDW 怎么了，感冒了吗？%CALLNAME:MASTER%开玩笑道、
		PRINTFORMW 「——啊啊，笨蛋笨蛋！」
		PRINTFORMDW 一开口就是骂人吗。
		PRINTFORMW 「%CALLNAME:MASTER%是笨蛋！我认真的烦恼着、你居然――」
		PRINTFORMDW 什么啊？正想这么说，被灵梦阻止了。
		PRINTFORMW 「我啊，有想传达给%CALLNAME:MASTER%的事情」
		PRINTFORMDW 灵梦稍微红着脸说
		PRINTFORMW 「听好了。我、对%CALLNAME:MASTER%――」
		PRINTFORMDW 灵梦稍微有点难为情，但下定决心似的开了口。
		PRINTFORMW 「――我、喜欢%CALLNAME:MASTER%哦」
		PRINTFORMDW %CALLNAME:MASTER%确实地听到了这句话。
		PRINTFORMW 「喜欢，喜欢的不得了」
		PRINTFORMDW %CALLNAME:MASTER%默默地听着这些话。
		PRINTFORMW 「所以，那个……请和我交往吧……」
		PRINTFORMDW %CALLNAME:MASTER%还没给出答复
		PRINTFORMW 「……那个……能告诉我你的答复吗」
		PRINTFORMDW %CALLNAME:MASTER%，终于开口了。
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;告白オッケー（恋人が付く）
	;记入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		PRINTW
		PRINTW
		PRINTFORMW 「——真的吗？」
		PRINTFORMDW 你看着灵梦，点了点头
		PRINTFORMW 「要、要是骗我的话，我会生气的哦」
		PRINTFORMW 「真的吗？是真的吗」
		PRINTFORMW 「……不要、离开我哦？可以吗？」
		PRINTFORMW 「——太好了！没有被拒绝诶！」
		PRINTFORMDW 仿佛失去了全身的力气，灵梦几乎要倒下了。
		PRINTFORMDW %CALLNAME:MASTER%接住了灵梦的身体。
		PRINTFORMW 「啊……谢谢」
		PRINTFORMDW %CALLNAME:MASTER%和灵梦保持了一会这样的状态。
		PRINTFORMW
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;告白失败
	;记入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		PRINTW
		PRINTW
		PRINTFORMW 「——是吗」
		PRINTFORMW 「……不，我知道的」
		PRINTFORMW 「……不，没事。没关系的……」
		PRINTFORMW 「……嗯，谢谢你……」
		PRINTFORMW 「……嗯，没关系哦。虽然很难过……」
		PRINTFORMW 「——我、还没有放弃哦？」
		PRINTW
		RETURN 0
	ENDIF

ENDIF
RETURN 0

