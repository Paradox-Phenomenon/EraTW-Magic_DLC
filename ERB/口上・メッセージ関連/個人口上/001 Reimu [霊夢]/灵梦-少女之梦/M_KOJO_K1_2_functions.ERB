;ISAAC的自定义图像函数
@isaac_DISPLAY_COM_IMAGE(COMNO,INDEX)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC リソース名
#DIM DYNAMIC COMNO
#DIMS DYNAMIC 服装
#DIMS DYNAMIC 表示形式
#DIM DYNAMIC INDEX
;索引从1开始
INDEX += 1
表示形式 = %GET_BASESTYLE(TARGET, 表示形式)%
IF CHECK_NUDE(TARGET)
	服装 = 裸
ELSE
	服装 = 服
ENDIF
CALL IMAGE_CHARA_OVERRIDE("特殊服装", TARGET)
IF RESULT:1
	服装 += RESULTS
ENDIF

リソース名 = %表示形式%_%服装%_COM{COMNO}_{NO:TARGET}

IF INDEX >= 1
	リソース名 = %リソース名%_{INDEX}
ENDIF

IF SPRITECREATED(リソース名)
	CALL PRINT_IMAGE(リソース名)
;ELSEIF SHOW_BOTE(NO:TARGET)
;	CALL PRINT_IMAGE(@"ボテ_{NO:TARGET}")
ENDIF
