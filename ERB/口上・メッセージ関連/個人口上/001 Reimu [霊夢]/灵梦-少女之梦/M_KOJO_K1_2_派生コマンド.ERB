@M_KOJO_少女之梦_MESSAGE_SCOM_K1_6
CALL TRAIN_MESSAGE
CALL M_KOJO_少女之梦_MESSAGE_SCOM_K1_6_1
RETURN 1
@M_KOJO_少女之梦_MESSAGE_SCOM_K1_6_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;主に正常位を想定しております
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		;時間停止
		IF FLAG:時間停止
			PRINTFORML 
			PRINTFORMW %CALLNAME:MASTER%保持着对灵梦的插入、用亀頭抵住灵梦肚子里、阴道上端的敏感位置。
			PRINTFORMW 亀頭前端感到了粗糙的触感、%CALLNAME:MASTER%因为快感身体微微颤抖。
			PRINTFORMW %CALLNAME:MASTER%然后继续重点玩弄着天花板的粗糙处。
		ELSE
			PRINTFORML 
			PRINTFORMW %CALLNAME:MASTER%喘着粗气、暂时停止了抽送。
			PRINTFORMW 「哈啊～……哈啊～……嗯～、要休息一下吗……？」
			PRINTFORMW 灵梦也和%CALLNAME:MASTER%一样气喘吁吁。
			PRINTFORMW %CALLNAME:MASTER%把手放在灵梦的侧腹上、用亀頭磨蹭着灵梦肚子里、阴道上端的敏感位置。
			PRINTFORMW 「哈、呜～！？　……嗯、啊啊～、不要、这样～！　额、哈啊～、太、过刺激了～！」
			PRINTFORMW 灵梦因为突然襲来的強烈快感而发出了悲鳴。
			PRINTFORMW %CALLNAME:MASTER%看着她的反応、更加激烈地開始摩擦起了灵梦的G点。
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;挿入継続
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && TCVAR:100 == PLAYER
		;基本セット
		;時間停止
		IF FLAG:時間停止
			PRINTFORML 
			PRINTFORMW %CALLNAME:MASTER%刮蹭着灵梦阴道上端的敏感位置、享受着颗粒状的粗糙触感。
			PRINTFORMW 灵梦的阴道因为快感而颤动着、也给%CALLNAME:MASTER%带来了快感。
			PRINTFORMW %CALLNAME:MASTER%更加激烈的刺激着灵梦的G点……
		;前回射精した
		ELSEIF TCVAR:102
			PRINTFORML 
			PRINTFORMW 「哈啊～、哈～、嗯～……精液、射了好多出来呢……」
			PRINTFORMW 灵梦感受着阴道里精液的触感。
			PRINTFORMW %CALLNAME:MASTER%稍事休息之后、急促地摩擦起了灵梦阴道上端的敏感位置。
			PRINTFORMW 「呜、啊啊～！？　呀啊～、这样～、刺激过头了～、不行了～！」
			PRINTFORMW 灵梦因为冷不防的強烈快感而陷入了脱力状态。
			PRINTFORMW %CALLNAME:MASTER%不予理会、继续摩擦着G点。
			PRINTFORMW 灵梦由于这种快感、好像高潮时那样的颤动着下半身……
		ENDIF
		;V絶頂＆MASTER射精
		IF NOWEX:Ｖ絶頂 && NOWEX:MASTER:11
			PRINTFORML 
			PRINTFORMW 「哈～、哈啊～……嗯～、稍微、休息一下吗……？」
			PRINTFORMW %CALLNAME:MASTER%在临近射精前暂时停止了抽送、稍微平缓了一下呼吸。
			PRINTFORMW 然后%CALLNAME:MASTER%猛地把腰往前一送、磨蹭起了灵梦的腹内。
			PRINTFORMW 「咿～、啊、哈、啊―――――嗯！」
			PRINTFORMW 灵梦达到了绝顶、%CALLNAME:MASTER%也同时射精了。
			PRINTFORMW 「哈啊～、哈啊～……嗯～、%CALLNAME:MASTER%的、满满的射进来了……」
			PRINTFORMW 灵梦因为快楽而神情迷醉嘴里这样嘟嚷着……
		;MASTER射精
		ELSEIF NOWEX:MASTER:11
			PRINTFORML 
			PRINTFORMW %CALLNAME:MASTER%感到强忍射精到了临界点、稍微停止了抽送缓了口气。
			PRINTFORMW 「嗯……好像、要射了吗……？」
			PRINTFORMW %CALLNAME:MASTER%并没有回答、屏住呼吸用力把腰向前一送。
			PRINTFORMW 「啊、出来了…………被弄得、黏糊糊的了……」
			PRINTFORMW %CALLNAME:MASTER%在灵梦的里面射精了。
			PRINTFORMW 灵梦的敏感部位沾满了精液。
			PRINTFORMW 因为阴道里精液的触感、灵梦脸颊变的通红。
		;V絶頂
		ELSEIF NOWEX:Ｖ絶頂
			PRINTFORML 
			PRINTFORMW %CALLNAME:MASTER%暂时停止了抽送。
			PRINTFORMW 「哈啊～、哈啊～……要、休息吗？　哈啊～、嗯～」
			PRINTFORMW 灵梦喘着粗气这样问道。
			PRINTFORMW 没有休息的打算。
			PRINTFORMW %CALLNAME:MASTER%在心中这样说着、咯吱咯吱的摩擦起了灵梦阴道上端的敏感位置。
			PRINTFORMW 亀頭感到了颗粒状的粗糙触感、強烈的快感在%CALLNAME:MASTER%身体上流转着。
			PRINTFORMW 「啊～、啊――～～嗯！　不、不行了～……那里、好、敏感～！？」
			PRINTFORMW 在%CALLNAME:MASTER%摩擦起来的那一瞬間、灵梦就因为十足的快感而高潮了。
			PRINTFORMW 灵梦沉浸在绝顶的余韻中瘫软了下来。
			PRINTFORMW %CALLNAME:MASTER%在灵梦绝顶后的短暂时间里、进一步的摩擦着Ｇ点。
		;屈服3
		ELSEIF MARK:不埒刻印 == 3
			PRINTFORML 
			PRINTFORMW 「嗯～、呀～、啊～……呐、呐～、%CALLNAME:MASTER%……」
