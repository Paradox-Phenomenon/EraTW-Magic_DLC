;==================================================
;7,挿入子宮口責め
;==================================================
@M_KOJO_ふらん_MESSAGE_SCOM_K50_7
CALL M_KOJO_ふらん_MESSAGE_SCOM_K50_7_1
RETURN 1
@M_KOJO_ふらん_MESSAGE_SCOM_K50_7_1
;custom code, moved from M_KOJO_ふらん_MESSAGE_COM_K50_73
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
	ENDIF
	;-------------------------------------------------
	;挿入継続
	;記入チェック
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && TCVAR:101 == PLAYER
		;前回射精した
		IF TCVAR:104
			PRINTFORMW 
			RETURN 1
		ELSE
			PRINTFORMW 
			RETURN 1
		ENDIF
	ENDIF
	;基本セット
	;恋慕
	IF FLAG:時間停止
	ELSEIF TALENT:恋慕 || TALENT:恋人
		IF NOWEX:MASTER:射精
			[SKIPSTART]
			MEMO FIRST
				PRINTFORM 「あぅ、やっ、%CALLNAME:MASTER%、この態勢……」
				PRINTFORM （上から体重かけられて、動けない……）
				PRINTFORM 「%CALLNAME:MASTER%？ちょっと、痛いよ。落ち着いて…ね？」
				PRINTFORM 「あっ%UNICODE(0x2665)%、んっ、ぅう！%UNICODE(0x2665)%」
				PRINTFORM 「や、そんっ、な、いきな、りぃっ%UNICODE(0x2665)%」
				PRINTFORM 「あっ、はげ、しっ%UNICODE(0x2665)%、やっ、ん、%CALLNAME:MASTER%ぁ%UNICODE(0x2665)%」
				PRINTFORM (私の、奥の、大事なところにガンガン当たって、でも)
				PRINTFORM (気持ちいいところ、にがせ、な……イっ！%UNICODE(0x2665)%)
				PRINTFORM 「やぅ、%UNICODE(0x2665)%、イった、いまイったから、ぁ%UNICODE(0x2665)%」
				PRINTFORM (全然、止めてくれない、し、更に、大きく…%UNICODE(0x2665)%)
				PRINTFORM 「だめ、もうイった、イったからぁ%UNICODE(0x2665)%」
				PRINTFORM 「また、もっと、あっ…ふか、っ深いのが、やっ、クる、からぁ……%UNICODE(0x2665)%」
				PRINTFORM （まだ、大きく、脈うって……孕んじゃう……かも%UNICODE(0x2665)%）
				PRINTFORM 「%CALLNAME:MASTER%%UNICODE(0x2665)%、%CALLNAME:MASTER%%UNICODE(0x2665)%、わた、しもっ……イく、また、あっ、やっ…、また、あっ、ぁ、っっ」
				PRINTFORMW「イっ～～～～～～～っっっっぅぅ！！！%UNICODE(0x2665)*5%」
				PRINTFORML
			[SKIPEND]
			
			IF ABL:1 >= 15
				PRINTFORML 「ダメ%UNICODE(0x2665)% %CALLNAME:MASTER%、なに、かぁ……ふあっ、いぃぃ……%UNICODE(0x2665)%」
				PRINTFORML 「やぁ、%CALLNAME:MASTER%%UNICODE(0x2665)%、今、出され、たらぁ……んぅっ！%UNICODE(0x2665)%」
				PRINTFORML 「ダメ%UNICODE(0x2665)% 戻れない%UNICODE(0x2665)% ふか、くぅ……！%UNICODE(0x2665)%」
				PRINTFORMW 「イ、く…………%UNICODE(0x2665) *5%」
			ELSEIF ABL:1 >= 5
				PRINTFORML 「や、おっぐ……%UNICODE(0x2665)%」
				PRINTFORML 「あ゛っ、や……だめ、だしちゃ、んぅ%UNICODE(0x2665)%」
				PRINTFORMW 「あっ、わ、私…、も%UNICODE(0x2665)%んぅ～～～～～っっっ%UNICODE(0x2665)%」
			ENDIF
		ELSE
			IF ABL:1 >= 15
			;子宮口開発経験があるらしいのでそれも加えたいところ
				PRINTFORML 「あ゛っ%UNICODE(0x2665)%やっ、そこ、よわ、イ゛ぃぃ%UNICODE(0x2665) *3%」
				PRINTFORML 「ダメ、そこ、弱いか、ら゛ぁ%UNICODE(0x2665)%すぐ、イっちゃうからぁ%UNICODE(0x2665)%」
				PRINTFORML 「ん゛お%UNICODE(0x2665)%ダメ、イぐ、イ゛ぎます%UNICODE(0x2665)%」
				PRINTFORMW 「イ゛っ～～～～～～～～っっっ%UNICODE(0x2665) *5%」
			ELSEIF ABL:1 >= 5
				PRINTFORML 「や、おっぐ……%UNICODE(0x2665)%」
				PRINTFORML 「そこ、あっ、よわっ、いぃ……%UNICODE(0x2665)%」
				PRINTFORMW 「ダメ、すぐに、すぐイ゛っ…%UNICODE(0x2665)%」
			RETURN 1
			ENDIF
		ENDIF
	;屈服3
	ELSEIF MARK:不埒刻印 == 3
		;PRINTFORMW 
		RETURN 1
	;それ以外
	ELSE
		;PRINTFORMW 
		RETURN 1
	ENDIF
ENDIF
RETURN 1
