@M_KOJO_EGG_MESSAGE_COM_K50_300_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF TFLAG:193 == -3 && !(TALENT:[[フラン]]:恋慕 || TALENT:[[フラン]]:恋人 || TALENT:[[フラン]]:愛欲 || TALENT:[[フラン]]:セフレ == 2)
		PRINTFORML 「...」
		PRINTFORMW 「You have a pretty 'eye'.」
	ELSE
		SELECTCASE IFRAND("0TO4", 1, "5", IS_FALLEN([[フラン]]), "6", TALENT:[[フラン]]:思慕 || TALENT:[[フラン]]:セフレ == 1)
			CASE 0
				PRINTFORML 「Don't buy that mature sophisticated %PRINT_MALE("gentleman:lady", [[レミリア]])% act my %PRINT_MALE("brother:sister", [[レミリア]])% puts on.」
				PRINTFORMW 「Remi wants everyone to believe %HES_SHES([[レミリア]])% this mature %PRINT_MALE("gentleman:lady", [[レミリア]])%, but %HES_SHES([[レミリア]])% not.」
				PRINTFORMW 「%HES_SHES([[レミリア]],1)% just a better actor than me～」

			CASE 1
				PRINTFORML 「People for the longest time people thought I was locked in the basement.」
				PRINTFORML 「Which technically was true, but I could have left at anytime.」
				PRINTFORMDW Flandre shrugs %HIS_HER(TARGET)% shoulders.
				PRINTFORML 「I just didn't because I was comfortable.」
				PRINTFORMW 「Plus if I kept leaving without a guide or something, my %PRINT_MALE("brother:sister", [[レミリア]])% would have just worried.」

			CASE 2
				PRINTFORMDW Flandre looks around the area before whispering to you.
				PRINTFORML 「I don't trust that gatekeeper at all.」
				PRINTFORMW 「One day, %HES_SHES([[美鈴]])% gonna snap and try to kill us all!」
				PRINTFORMDW %HE_SHE(TARGET,1)% then holds %HIS_HER(TARGET)% palm out to a random item and then clenches %HIS_HER(TARGET)% fist.
				PRINTFORMDW ＼　Bang!　／
				PRINTFORM 「Won't get far though.」

			CASE 3
				PRINTFORML 「Don't offer any of the Hobgoblins clothes.」
				PRINTFORMDW Flandre crosses %HIS_HER(TARGET)% arm and shakes %HIS_HER(TARGET)% head.
				PRINTFORML 「They hate that!」
				PRINTFORMDW %HE_SHE(TARGET,1)% holds a finger up.
				PRINTFORML 「Offer them a bowl of cream instead.」
				PRINTFORMDW Nodding %HIS_HER(TARGET)% head like a leading expert on Hobgoblin lore.
				PRINTFORMW 「They go crazy for that stuff!」

			CASE 4
				PRINTFORML 「"Use my wings as wind chimes"?」
				PRINTFORMDL Flandre stretches her wings out and looks at them.
				PRINTFORMDW They jingle a little.
				PRINTFORMW 「Hehe～ That could be fun!」

			CASE 5
				PRINTFORML 「The Hobgoblins?」
				PRINTFORMDW Flandre's eyes dance with mischief.
				PRINTFORMDW She grins, leaning in conspiratorially.
				PRINTFORML 「They're always scurrying around with such serious faces.」
				PRINTFORMDW Her gaze becomes playful.
				PRINTFORML 「I've thought about pranking them a few times!」
				PRINTFORMDW Flandre nudges you gently, her eyes sparkling.
				PRINTFORML 「We should plan a little mischief together, %CALLNAME:MASTER%～」
				PRINTFORMDW She suggests, the idea clearly delighting her.

			CASE 6
				PRINTFORML 「Do I get lonely living in the basement?」
				PRINTFORMDW Flandre tilts her head, a hint of surprise in her eyes.
				PRINTFORMDW She pauses, then smiles faintly, a reflective look crossing her face.
				PRINTFORML 「Not at all.」
				PRINTFORML 「I get whatever I want, and can split myself into four.」
				PRINTFORMDW She glances at you, a subtle warmth in her gaze.

		ENDSELECT
	ENDIF
ENDIF
RETURN 1

