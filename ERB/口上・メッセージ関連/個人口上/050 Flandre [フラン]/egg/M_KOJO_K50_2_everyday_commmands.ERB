;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF FIRSTTIME(SELECTCOM)
		PRINTFORML 「Tea, for me?」
		PRINTFORML 「Did Sakuya go on strike?」
		PRINTFORMDW You smile and let her know you just had some spare and would like to share.
		PRINTFORML 「Very well, let's see how yours compares.」
		PRINTFORMDW Flandre sips the tea you prepared.
	ELSEIF CFLAG:TARGET:行動 == 5
		GOTO PERSONAL_SAKUYA
	ELSE
		SELECTCASE TFLAG:193

			CASE 1
				SELECTCASE IFRAND("0", TALENT:[[フラン]]:恋人, "1", TALENT:[[フラン]]:恋慕 || TALENT:[[フラン]]:恋人, "2", TALENT:[[フラン]]:思慕 || TALENT:[[フラン]]:恋慕 || TALENT:[[フラン]]:恋人, "3", 1)

					CASE 0
						PRINTFORML 「Mmm, you made tea?」
						PRINTFORMDW Flandre smiles as she takes a sip.
						PRINTFORML 「It's really good – you're getting better at this.」
						PRINTFORMDW She comments, her eyes warm with love.
						PRINTFORMDW Flandre leans in, sharing a quiet, contented moment.
						PRINTFORML 「It's the little things with you that make every day special.」
						PRINTFORMDW She murmurs, holding your gaze affectionately.

					CASE 1
						PRINTFORML 「Oh, you made tea?」
						PRINTFORMDW Flandre looks pleasantly surprised.
						PRINTFORMDW Quickly taking the cup, she sniffs it gently.
						PRINTFORML 「Mmm, smells good～」
						PRINTFORMDW Her eyes meet yours with a thankful glint.
						PRINTFORMDW She tastes it, her face lighting up.
						PRINTFORML 「It's delicious!❤」
						PRINTFORML 「You're full of surprises, aren't you?」
						PRINTFORMDW She says with a playful tone.

					CASE 2
						PRINTFORML 「Tea for me?」
						PRINTFORMDW Flandre's eyes light up.
						PRINTFORML 「Thanks～」
						PRINTFORMDW Accepting the cup she takes a sip, and her smile widens.
						PRINTFORML 「This is really good!」
						PRINTFORMDW She exclaims, savoring the taste.
						PRINTFORMDW Her relaxed posture speaks of her comfort and enjoyment.

					CASE 3
						$PERSONAL_SAKUYA
						PRINTFORML 「Oh? How kind.」
						PRINTFORMDW You hand over the cup of tea and she takes a drink.
						PRINTFORML 「This is great! It's like having my own personal Sakuya～」
						PRINTFORMDW She then quickly drinks the rest and lets out a satisfied sigh.

				ENDSELECT
			CASE 0
				SELECTCASE IFRAND("0", 1, "1", !IS_FALLEN([[フラン]]) || TALENT:[[フラン]]:思慕, "2TO3", TALENT:[[フラン]]:恋慕 || TALENT:[[フラン]]:恋人)
					CASE 0
						PRINTFORML 「Oh, you made tea?」
						PRINTFORMDW Flandre's eyes reflect mild curiosity as she takes the cup from you.
						PRINTFORMDW She tastes it, her expression neutral but thoughtful.
						PRINTFORML 「It's pretty basic, isn't it? You should ask Sakuya for pointers.」
						PRINTFORMDW She comments casually, placing the cup down.
						PRINTFORMDW Her gaze meets yours for a moment, a subtle appreciation in her eyes.

					CASE 1
						PRINTFORML 「Tea, huh?」
						PRINTFORMDW Flandre eyes the cup warily.
						PRINTFORMDW She takes it cautiously, giving it a curious sniff.
						PRINTFORML 「It's just regular tea, right?」
						PRINTFORMDW She asks, still a bit unsure.
						PRINTFORMDW After a hesitant sip, she nods slightly.
						PRINTFORML 「It's alright, I guess. Thanks anyway.」
						PRINTFORMDW She comments, her guard still up but showing a hint of openness.

					CASE 2
						PRINTFORML 「Tea again?」
						PRINTFORML 「You're spoiling me, %CALLNAME:MASTER%～」
						PRINTFORMDW Flandre says with a warm, affectionate tone.
						PRINTFORMDW Her gaze meeting yours with an unmistakable depth of feeling.
						PRINTFORMDW She takes a sip, her expression thoughtful.
						PRINTFORML 「It's not your best batch, but I love it anyway, because it's from you～❤」
						PRINTFORMDW She says with a tender smile.

					CASE 3
						PRINTFORML 「Tea again? You're the best, %CALLNAME:MASTER%～」
						PRINTFORMDW Flandre says with a loving smile, accepting the cup with a gentle touch.
						PRINTFORMDW She takes a sip, her eyes closing briefly to savor the taste.
						PRINTFORML 「It's not your finest, but since you made it I don't care～❤」
						PRINTFORMDW She remarks affectionately, opening her eyes to meet yours with a look full of love.

				ENDSELECT

			CASE -1
				SELECTCASE IFRAND("0TO1", TALENT:TARGET:恋慕 || TALENT:[[フラン]]:恋人 || TALENT:[[フラン]]:愛欲, "2TO3", 1)
					CASE 0
						PRINTFORML 「This is...」
						PRINTFORMDW Flandre sets the cup down.
						PRINTFORMW 「Better luck next time?」

					CASE 1
						PRINTFORML 「...」
						PRINTFORMW 「Maybe you could ask Sakuya for pointers?」

					CASE 2
						PRINTFORMW 「This is awful...」

					CASE 3
						PRINTFORMW 「This... isn't good.」

				ENDSELECT

			CASE -3
				PRINTFORMW 「You should know, poison won't work on a vampire.」

		ENDSELECT
	ENDIF

	;Lines for serving tea with semen mixed in (Good/Mid, Flan likes it) (I don't think you can actually do this yet)
