@GIFT_COMMON_SEND(CHARA,TYPE)
#DIM CHARA
#DIMS TYPE
#DIM GIFT_ID
#DIM 渡した回数
#DIMS GIFT_NAME
#DIMS GIFT_SENSE


CALL CREATE_GIFT_FROM_CHARA(CHARA, 701, 1000)
GIFT_ID = RESULT
GIFT_NAME = %RESULTS%
GIFT_SENSE = %RESULTS:1%
	SIF !GIFT_SEND_CHECK(GIFT_SENSE,TYPE)
		RESTART
渡した回数 = GET_GIFTDATA(CFLAG:CHARA:送出的礼物, "回数") + 1
;IDの設定
GIFT_ID = 渡した回数 * 10000000000000000 + DAY * 1000000000 + CFLAG:MASTER:约会中 * 10000000 + GIFT_ID
GIFT_GAVE:CHARA:(渡した回数 % 100) = GIFT_ID
CFLAG:CHARA:送出的礼物 = GIFT_ID
PRINTFORMW 得到了【%GIFT_NAME%】！
RETURN 1

