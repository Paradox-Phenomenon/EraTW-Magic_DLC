;==================================================
;おはなし，聊起天来
;==================================================
@M_KOJO_Moe_MESSAGE_COUNTER_K118_3
CALL EVENT_COUNTER_MESSAGE
CALL M_KOJO_Moe_MESSAGE_COUNTER_K118_3_1
RETURN RESULT
@M_KOJO_Moe_MESSAGE_COUNTER_K118_3_1
;这一段要不要直接call对话哇

IF TALENT:118:恋慕
    SELECTCASE RAND:7

    ENDSELECT
    GOTO LARVA_COUNTER_K118_3_1
ELSE 
    $LARVA_COUNTER_K118_3_1
    SELECTCASE RAND:10
        CASE 0 
            PRINTFORML 「说起来，为什么最近没有看见妖精们闹腾了呢……」
            PRINTFORML 「没有异变的话，打架都没意思了呢……」
        CASE 1 
            IF  !RAND:7 && ONCE("LARVA_COUNTER_K118_ONCE_3")
                PRINTFORML 「说起来……在那之后，就没一起跳过舞了呢……」
                PRINTFORML 「那个时候，%CSTR:118:20%捡到了一块特别大的P点，后来弄丢了」
                PRINTFORML 「为了去寻找它，就……跳着舞踏上了冒险的旅程呢……」
                PRINTFORML 「居然还打败了摩多罗……想想就觉得不可思议！」
                PRINTFORMDW 是怎样的一段冒险旅程呢？
            ELSEIF !RAND:3
                CALL MOE_LARVA_GET_RUMIA_KOJO_VERSION_NUM()
                IF RESULT == 2 
                    PRINTFORML 「说起来，弹幕舞蹈没有流行之后，没看见露米娅酱跳舞了呢……」
                    PRINTFORML 「……以前她可是很厉害的！一口气打败了灵梦和魔理沙，还有摩多罗的两个童子呢！」
                    PRINTFORML 「不过还是没%CSTR:118:20%厉害！我可是，击败了摩多罗呢！」
                    PRINTFORMDW 哪怕是暂时获得的力量，也不愧是接近神的妖精呢……
                ELSE 
                    GOTO LARVA_COUNTER_K118_3_1
               ENDIF 
            ELSE 
                GOTO LARVA_COUNTER_K118_3_1
            ENDIF
        CASE 2
            PRINTFORML 「说起来……作为人类，不能飞的话，会不会感觉世界很小……」
            PRINTFORML 「妖精们都是想去哪里就去哪里，整个幻想乡都有我们的足迹呢！」
        CASE 3 
            PRINTFORML 「在太阳花田，栖息着传说中的，非常恐怖的花妖怪——」
            PRINTFORML 「——才怪呢！只是幽香姐姐不希望别人采她的花……」
        CASE 4
            PRINTFORML 「%MASTERNAME:118%有遇见过一个白头发，穿着红裤子的大姐姐嘛」
            PRINTFORML 「竹林那边的路特别难走，她有的时候就会带着迷路的人走出去呢」
            IF TALENT:61:恋慕
                PRINTFORML 「说起来……以前的她不太爱说话，现在似乎亲切很多了」
                PRINTFORML 「……嗯哼，难道说，是因为%MASTERNAME:118%……」
           ENDIF 
        CASE 5 
            PRINTFORML 「说起来，花田外有个盛开着铃兰花的小山丘，%MASTERNAME:118%去看过嘛？」
            IF FIRSTTIME("LARVA_COUNTER_K118_FIRST_3_5")
                PRINTFORML 「那里有一位叫做梅蒂欣的人偶妖怪……浑身是毒，与她交流要格外小心……」
            ELSE 
                PRINTFORML 「虽然景色很美，但还是要注意脚下，别踩着梅蒂欣小姐的花了……」
            ENDIF 
            IF TALENT:75:恋慕
                PRINTFORML 「不过，最近她对人类的恶意，看起来减淡了很多呢……」
                PRINTFORML 「……嗯哼，难道说，是因为%MASTERNAME:118%……」
            ENDIF 
        CASE 6 
            PRINTFORML 「我在魔法之森的家，已经很久都没去看过了呢……」
            PRINTDATAW 
                DATAFORM 「如果有别人住进去的话，反倒不需要我打理了，真好」
                DATAFORM 「现在已经没什么必要去那里了呢，%CSTR:118:20%已经不怕冷了哦！」
                DATAFORM 「那个地方还是太闷了，虽然很暖和，但是一点都不透气——」
            ENDDATA
        [SKIPSTART]
        CASE 7
            PRINTFORML 「」
            PRINTFORML 「」
        CASE 8
            PRINTFORML 
            PRINTFORML 
        [SKIPEND]
        CASEELSE
            PRINTFORML 
            SIF !RAND:4 
            TFLAG:193 = 1 
            CALL M_KOJO_Moe_MESSAGE_COM_K118_300_1
    ENDSELECT
ENDIF 
RETURN 1

