;==================================================
;第三人称检测函数
;检测自机性别，扶她暂视为女性
;==================================================
@LARVA_MOE_GET_SEX_OF_YOU(ARG)
#FUNCTIONS 

IF !ARG
	IF TALENT:0:2 == 2 
		RETURNF "他	"
	ELSE 
		RETURNF "她	"
	ENDIF 
ENDIF 
;==================================================
;心情检测函数
;心情低为-1，愤怒为-2，反发为-3以上，可叠加
;==================================================
@MOE_LARVA_MOOD()
#FUNCTION 
RESULT = 0 
IF MARK:118:反発刻印
	RESULT -= (MARK:118:反発刻印 + 2)
ELSEIF TCVAR:118:憤怒
	RESULT -= 2
ELSEIF TALENT:118:心情
	RESULT -= 1
ENDIF  
RETURNF RESULT 


