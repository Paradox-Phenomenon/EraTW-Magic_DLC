@MOE_LARVA_GET_GO_ALONG_TARGET()
#FUNCTION 

FOR LOCAL , 1 , CHARANUM 
	IF CFLAG:LOCAL:同行
		RETURNF LOCAL
		BREAK
	ENDIF 
NEXT

