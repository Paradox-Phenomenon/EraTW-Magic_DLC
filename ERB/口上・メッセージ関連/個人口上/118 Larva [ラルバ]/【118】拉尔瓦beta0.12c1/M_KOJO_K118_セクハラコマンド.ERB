;==================================================
;310,尻を撫でる
;TFLAG:193(1=不快(TALENT:臆病なら涙目) 2&&3=恥ずかしがる(TALENT:男嫌い兼MASTERが男なら、身をすくめる) 4=されるがまま)
;CFLAG:诶嘿嘿==2&&TCVAR:20(パンツ無し顔面騎乗(70=クンニ強制 71=フェラチオ強制 72=アナル奉仕) 35=スカート内見せつけ 52=素股)
;CFLAG:诶嘿嘿==2&&TEQUIP:シックスナイン(パンツありTCVAR:20(70～72)はこちら)
;PREVCOM(305=膝枕
;TFLAG:400(1=デート先or地底のモブが反応する)
;==================================================
@M_KOJO_Moe_SUCCESS_COM_K118_310
;成否判定
;TFLAG:192(-2=コマンド終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

@M_KOJO_Moe_MESSAGE_COM_K118_310
CALL TRAIN_MESSAGE
CALL M_KOJO_Moe_MESSAGE_COM_K118_310_1
RETURN RESULT

@M_KOJO_Moe_MESSAGE_COM_K118_310_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF FLAG:70
	ELSEIF CFLAG:睡眠
	ELSEIF CFLAG:118:诶嘿嘿 == 2 
	ELSE 
		SELECTCASE TFLAG:193 
			CASE 1 
				$K118_310_01
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「%MASTERNAME:118%干什么啊！」
						PRINTFORML 「我可不信！这是哪门子的恶作剧啊！」
					CASE 1
						PRINTFORML 「……%MASTERNAME:118%摸哪里干嘛啊！」
						PRINTFORML 「就算%CSTR:118:20%像是小孩子，屁股也不能摸！」	
					CASE 2 
						PRINTFORML 「不要以为我脾气好，就可以做这样的事！」
						PRINTFORML 「妖精可不是你们能随便欺负的啊！」
				ENDSELECT
			CASE 2,3
				IF TALENT:118:恋慕
				ELSEIF TALENT:118:思慕
					SELECTCASE RAND:2 
						CASE 0
							PRINTFORML 「呜……%MASTERNAME:118%不可以摸那里……」
							PRINTFORML 「再怎么说%CSTR:118:20%也是女孩子……」
						CASE 1
							PRINTFORML 「喂！这个是耍流氓哦……」
							PRINTFORML 「再怎么说%CSTR:118:20%也是女孩子……」
					ENDSELECT
				ELSE 
					GOTO K118_310_01
				ENDIF 
			CASE 4 
				IF TALENT:118:恋人
					IF GET_TARGETNUM() > 1 
						PRINTDATAL 
							DATAFORM 「有别人……就不要这样了啦……」
							DATAFORM 「呜……别人在看着这边呢……」
							DATAFORM 「想摸的话，回家再说好嘛……」
							DATAFORM 「不要在外面这样子啦……」
							DATAFORM 「呐，就这么想要嘛……」
						ENDDATA
						PRINTDATADL
							DATAFORM 拉尔瓦用翅膀挡着你的手……
							DATAFORM 拉尔瓦小声娇嗔着，却没有一点反抗
							DATAFORM 相比你的抚摸，拉尔瓦似乎更担心被人看见
						ENDDATA
						PRINTDATADW 
							DATAFORM 轻轻按揉着柔软的屁股，享受着蝴蝶妖精羞涩的神情
							DATAFORM 沿着屁股的曲线来回抚摸，拉尔瓦便扭着身体，似乎想要挣脱却使不上劲
						ENDDATA
					ELSE
					ENDIF 					
				ELSEIF TALENT:118:思慕 ||  TALENT:118:恋慕
				ELSE

				ENDIF 
		ENDSELECT		
	ENDIF
ENDIF
PRINTFORMW 
RETURN 1
