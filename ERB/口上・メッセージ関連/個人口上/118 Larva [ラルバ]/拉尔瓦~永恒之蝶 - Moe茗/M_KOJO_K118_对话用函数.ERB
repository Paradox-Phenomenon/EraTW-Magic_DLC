					PRINTFORMW 「……说起来，%CSTR:118:20%的周围也会发生这样的事情，是怎么回事呢？」
				CASEELSE 
				RETURN 0 
			ENDSELECT
		;检测不到没有触发过的对象
		ELSE 
			RETURN 0 
		ENDIF 
	ENDIF 
ELSE 
	RETURN 0 
ENDIF 
