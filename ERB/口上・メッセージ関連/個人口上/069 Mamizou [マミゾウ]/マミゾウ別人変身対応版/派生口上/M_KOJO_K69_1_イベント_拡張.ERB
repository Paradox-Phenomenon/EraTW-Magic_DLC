;==================================================
;脱衣口上
;==================================================
@別人変身版_EVENT_K69_28(ARG,ARG:1)
;口上主はTARGET
;ARGに脱がし方選択
;ARG:1（ARG=3の場合のみあり）地の文の反応
;--------------------------------------------------
#DIM TRANSAFTER
#DIM TEMP
#DIM iSize
#DIMS 服装
#DIMS Body
#DIMS picResource,5
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	IF CFLAG:TARGET:変化先 == 0
		TRANSAFTER = TARGET
	ELSE
		TRANSAFTER = CFLAG:TARGET:変化先
	ENDIF
	;TRANSAFTER = CFLAG:TARGET:変化先 == 0 ? 69 # CFLAG:TARGET:変化先
	TEMP = CURRENTREDRAW()
	iSize = !FLAG:画像表示 ? 0 # 1000
	
	;基本画像　表示形式_服装_表情_キャラ番号_差分 (RESULTS:0に格納、RESULTS:1にマウスオーバー画像格納)
	CALL GET_BASE_RESOURCE(TRANSAFTER,"顔絵",@"%服装%","通常")
	SIF !RESULT
		RESULTS:0 = %GET_BASESTYLE(TRANSAFTER)%_服_通常_{TRANSAFTER}
	picResource:0 = %RESULTS:0%
	
	CALL GET_BASE_RESOURCE(TRANSAFTER,"顔絵",@"%服装%","笑顔")
	SIF !RESULT
		RESULTS:0 = %GET_BASESTYLE(TRANSAFTER)%_服_通常_{TRANSAFTER}
	picResource:1 = %RESULTS:0%

	CALL GET_BASE_RESOURCE(TRANSAFTER,"顔絵","裸","通常")
	SIF !RESULT
		RESULTS:0 = %GET_BASESTYLE(TRANSAFTER)%_服_通常_{TRANSAFTER}
	picResource:3 = %RESULTS:0%
	
	CALL GET_BASE_RESOURCE(TRANSAFTER,"立ち絵","裸","通常")
	SIF !RESULT
		RESULTS:0 = %GET_BASESTYLE(TRANSAFTER)%_服_通常_{TRANSAFTER}
	picResource:2 = %RESULTS:0%
	
	CALL GET_BASE_RESOURCE(TRANSAFTER,"顔絵","裸","笑顔")
	SIF !RESULT
		RESULTS:0 = %GET_BASESTYLE(TRANSAFTER)%_服_通常_{TRANSAFTER}
	picResource:4 = %RESULTS:0%
	K69_1_TNAME = \@CFLAG:69:変化先 != 0 ? %CALLNAME:(CFLAG:69:変化先)%の姿をした # \@マミゾウ
	
	RESULTS = 
	
	IF TALENT:TARGET:体型 == -2
		IF TALENT:TARGET:バストサイズ == 1 || TALENT:TARGET:バストサイズ == 2
			Body = ろり巨乳
		ELSE
			Body = こどもぼでぃ
		ENDIF
		ELSEIF TALENT:TARGET:体型 == -1
			IF TALENT:TARGET:バストサイズ == 1 || TALENT:TARGET:バストサイズ == 2
				Body = ろり巨乳
			ELSE
				Body = ろりぼでぃ
			ENDIF
		ELSEIF TALENT:TARGET:バストサイズ == -1 || TALENT:TARGET:バストサイズ == -2
			Body = つるぺたぼでぃ
		ELSEIF TALENT:TARGET:バストサイズ == 1
			Body = えろぼでぃ
		ELSEIF TALENT:TARGET:バストサイズ == 2
			Body = えろぼでぃ
		ELSE
			Body = 裸体
	ENDIF

	SELECTCASE ARG
		;-------------------------------------------------
		CASE 0
		;全裸にする
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1
			;時間停止時
			IF FLAG:70
			;通常
			ELSE
				IF TALENT:TARGET:変化 && TRANSAFTER != TARGET
					TRYCALLFORM 別人変身版_EVENT_K69_K{TRANSAFTER}_28(ARG,ARG:1,picResource)
					IF RESULTS == ""
						IF FIRSTTIME(@"lNUDE_{TRANSAFTER}")
							PRINTFORML
							CALL PRINT_IMAGE(picResource:0,iSize)
							PRINTFORML
							PRINTFORMW ほう、服を脱げとな？
							REDRAW 0
							CLEARLINE (iSize/100)+3
							CALL PRINT_IMAGE(picResource:1,iSize)
							PRINTFORML
							PRINTFORML ほう、服を脱げとな？
							PRINTFORML くっくっく……。いいのか？後で本人に怒られても知らんぞぅ……？
							REDRAW TEMP
							PRINTFORMW %K69_1_TNAME%は妖しく笑いながら、見せつけるように身にまとった衣服を一つ一つ脱いでいく…
							PRINTFORML
							CALL PRINT_IMAGE(picResource:2,iSize)
							PRINTFORMW
							PRINTFORML
							CALL PRINT_IMAGE(picResource:4,iSize)
							PRINTFORML
							PRINTFORML 「ほれ、お望みの%CALLNAME:(CFLAG:69:変化先)%の%Body%じゃぞ♪」
						ELSE
							PRINTFORML
						CALL PRINT_IMAGE(picResource:0,iSize)
						PRINTFORML
						PRINTFORMW ほう、服を脱げとな？
						REDRAW 0
						CLEARLINE (iSize/100)+3
						CALL PRINT_IMAGE(picResource:1,iSize)
						PRINTFORML
						PRINTFORML ほう、服を脱げとな？
						PRINTFORML くっくっく……。いいじゃろう……♪
						REDRAW TEMP
						PRINTFORMW %K69_1_TNAME%は妖しく笑いながら、見せつけるように身にまとった衣服を一つ一つ脱いでいく…
						PRINTFORML
						CALL PRINT_IMAGE(picResource:2,iSize)
						PRINTFORMW
						PRINTFORML
						CALL PRINT_IMAGE(picResource:4,iSize)
						PRINTFORML
						PRINTFORML 「ほれ、お前さんの好きな%CALLNAME:(CFLAG:69:変化先)%の%Body%じゃぞ♪」
						ENDIF
					ENDIF
				ELSE
					IF FIRSTTIME("lNUDE_69")
						PRINTFORML ほう、儂の裸を見たいじゃと？……まあ、いいじゃろう
					ELSE
						PRINTFORML ほう、儂の裸を見たいじゃと？……まあ、いいじゃろう
					ENDIF
				ENDIF
				PRINTFORML 
			ENDIF
			PRINTFORMW
			REDRAW TEMP
			RETURN 1 
		ENDIF
		;-------------------------------------------------
		CASE 1
		;下着姿にする
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1
			;時間停止時
			IF FLAG:70
			;通常
			ELSE
			ENDIF
			RETURN 1
		ENDIF
		;-------------------------------------------------
		CASE 2
		;半脱ぎ
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1
			;時間停止時
			IF FLAG:70
			;通常
			ELSE
			ENDIF
			RETURN 1
		ENDIF
		;-------------------------------------------------
		CASE 3
		;パンツちょうだい
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1
			SELECTCASE ARG:1
				;-------------------------------------------------
				CASE 0
				;交換です
				;記入チェック（=0, 非表示、1, 表示）
				LOCAL:1 = 0
				;-------------------------------------------------
				IF LOCAL:1
					RETURN 1
				ENDIF
				;-------------------------------------------------
				CASE 1
				;OK（嬉々
				;記入チェック（=0, 非表示、1, 表示）
				LOCAL:1 = 0
				;-------------------------------------------------
				IF LOCAL:1
					RETURN 1
				ENDIF
				;-------------------------------------------------
				CASE 2
				;OK（渋々
				;記入チェック（=0, 非表示、1, 表示）
				LOCAL:1 = 0
				;-------------------------------------------------
				IF LOCAL:1
					RETURN 1
				ENDIF
				;-------------------------------------------------
				CASE 3
				;嫌です
				;記入チェック（=0, 非表示、1, 表示）
				LOCAL:1 = 0
				;-------------------------------------------------
				IF LOCAL:1
					RETURN 1
				ENDIF
				RETURN 1
			ENDSELECT
		ENDIF
	ENDSELECT
ENDIF
RETURN 1

