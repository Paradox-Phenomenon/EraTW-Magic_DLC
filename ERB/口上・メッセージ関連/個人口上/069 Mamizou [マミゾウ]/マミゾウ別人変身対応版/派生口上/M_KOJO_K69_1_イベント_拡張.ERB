@別人変身版_EVENT_K69_15(ARG,ARG:1)
#DIM 絶頂回数
;口上主はTARGET
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 0
;-------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;未実装（押し倒しコマンドに統合？
	;MASTERが押し倒した（ウフフ開始時）
	;記入チェック（=0, 非表示、1, 表示）
	;LOCAL:1 = 0
	;-------------------------------------------------
	;IF LOCAL:1 && ARG == 1
		;PRINTFORML
		;RETURN 1
	;ENDIF
	;-------------------------------------------------
	;逢瀬終了（ウフフ終了時）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		絶頂回数 = 0
		絶頂回数 += EX:K69_CNUM:Ｃ絶頂
		絶頂回数 += EX:K69_CNUM:Ｖ絶頂
		絶頂回数 += EX:K69_CNUM:Ａ絶頂
		絶頂回数 += EX:K69_CNUM:Ｂ絶頂
		絶頂回数 += EX:K69_CNUM:Ｍ絶頂
		SELECTCASE 絶頂回数
			CASE 0
				IF CFLAG:K69_CNUM:溜まってる度 < 200
				ELSEIF CFLAG:K69_CNUM:溜まってる度 < 500
				ELSE
					CALL HPH_PRINT,@"「ふー……っHPH　フー……っHPH」","L"
					CALL HPH_PRINT,@"興奮したままのマミゾウがこちらを睨みつけてくる…","W"
				ENDIF
			CASE 1 TO 30
				SELECTCASE RAND:3
				CASE 0
					CALL HPH_PRINT,@"「ん、……HPH","L"
				CASE 1
					CALL HPH_PRINT,@"「ふぅ……HPH","L"
				CASEELSE
					CALL HPH_PRINT,@"「ん、あ……HPH","L"
				ENDSELECT
				IF CFLAG:K69_CNUM:変化先
					SELECTCASE RAND:3
					CASE 0
						CALL HPH_PRINT,@"　%CALLNAME:(CFLAG:K69_CNUM:変化先)%の姿で乱れてしまったなあ……HPH","L"
					CASE 1
						CALL HPH_PRINT,@"　%CALLNAME:(CFLAG:K69_CNUM:変化先)%の身体はどうじゃ……？HPH","L"
					CASEELSE
						CALL HPH_PRINT,@"　%CALLNAME:(CFLAG:K69_CNUM:変化先)%でイってしまったなあ……HPH","L"
					ENDSELECT
				ENDIF
				SELECTCASE RAND:2
				CASE 0
					CALL HPH_PRINT,@"　ふふ……、気持ちよかったぞ、%MASTERNAME:K69_CNUM%……HPH」","W"
				CASE 1
					CALL HPH_PRINT,@"　なあ……、%MASTERNAME:K69_CNUM%は気持ちよかったか……？HPH」","W"
				CASEELSE
				ENDSELECT
			CASEELSE
				SELECTCASE RAND:3
				CASE 0
					CALL HPH_PRINT,@"「お……っHPH","L"
				CASE 1
					CALL HPH_PRINT,@"「ひ、はぁ……っHPH","L"
				CASEELSE
					CALL HPH_PRINT,@"「う…っHPH　ぁ……HPH","L"
				ENDSELECT
				IF CFLAG:K69_CNUM:変化先
					SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"　このからだ、びんかんで、ぅあ……っHPH","L"
					CASE 1
						CALL HPH_PRINT,@"　%CALLNAME:(CFLAG:K69_CNUM:変化先)%の身体、めちゃくちゃにしてくれおって……っHPH","L"
					CASEELSE
					ENDSELECT
				ENDIF
				SELECTCASE RAND:2
				CASE 0
					CALL HPH_PRINT,@"　いきすぎて、おかしくなりそうじゃ……んう……っHPH」","W"
				CASE 1
					CALL HPH_PRINT,@"　はあ……っHPH　はげしすぎじゃ、%MASTERNAME:K69_CNUM%……HPH」","W"
				CASEELSE
				ENDSELECT
		ENDSELECT
		RETURN 1
	ENDIF
	;その他
	PRINTFORML  
	;-------------------------------------------------
	;事後描写
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		;-------------------------------------------------
		;精液が垂れてきた
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1 && ARG:1 == 1
			IF CFLAG:K69_CNUM:生理周期 == 7
				IF SOAKED_OR_NOT("V_SEMINAL")
					IF TALENT:MASTER:濃厚精液
						CALL HPH_PRINT,@"「ほれみろ……あふれてしまっとるぞ……HPH","L"
						CALL HPH_PRINT,@"　まったく、しきゅうが%MASTERNAME:K69_CNUM%のこいせいえきでぱんぱんじゃぁHPH　これははらんでしまうかものぅ……HPH」","L"
						PRINTFORMW マミゾウが\@ CFLAG:K69_CNUM:変化先 ? %CALLNAME:(CFLAG:K69_CNUM:変化先)%の#\@その膨らんだお腹を撫でながら、そこに入りきらなかった精液が垂れる様子を見せつけてきた…
					ELSE
						CALL HPH_PRINT,@"「ほれみろ……あふれてしまっとるぞ……HPH","L"
						CALL HPH_PRINT,@"　まったく、しきゅうが%MASTERNAME:K69_CNUM%のせいえきでぱんぱんじゃぁHPH　ふふ、一滴もにがさんぞぅ……HPH」","L"
						PRINTFORMW マミゾウが\@ CFLAG:K69_CNUM:変化先 ? %CALLNAME:(CFLAG:K69_CNUM:変化先)%の#\@その膨らんだお腹を撫でながら、そこに入りきらなかった精液が垂れる様子を見せつけてきた…
