;### 口上色判定 ###################################
@別人変身版_COLOR_K69

;ここでSETCOLORすることで口上に色を付けられます
;例：SETCOLOR 0xC07070
;派生口上側に移行　存在しない場合のみここで設定
	SETCOLOR 0xCF7C38

;※※※※※※※※※※※※※※※※※※※※※※※※※※
;"EVENT"系イベント
;※※※※※※※※※※※※※※※※※※※※※※※※※※
;==================================================
;部屋で遭遇
;==================================================
@別人変身版_EVENT_K69_1(ARG,ARG:1)
;口上主はTARGET
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
K69_1_TNAME = \@ CFLAG:69:変化先 != 0 ? %CALLNAME:(CFLAG:69:変化先)%の姿をした # \@マミゾウ
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;MASTERが入ってきた
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		IF TALENT:機嫌 == -1
			IF TALENT:恋慕 || TALENT:愛欲 || TALENT:思慕
				PRINTFORML 「……なんじゃ、お前さんか」
				PRINTFORMW %K69_1_TNAME%は不機嫌そうに、%CALLNAME:MASTER%を一瞥するのみだった…
			ELSE
				PRINTFORML 「………」
				PRINTFORMW %K69_1_TNAME%は不機嫌そうに、%CALLNAME:MASTER%に一瞥もくれずにじっとしている…
			ENDIF
		ELSE
			;住処 同居以外
			;現状メインマップのみ対応
			IF !(CFLAG:MASTER:神社在住 == CFLAG:K69_CNUM:神社在住) && CFLAG:MASTER:現在位置 == CFLAG:K69_CNUM:神社在住
				IF !TCVAR:K69_CNUM:357
					PRINTFORML 「おお、いらっしゃい」
					IF FIRSTTIME("EV1A")
						PRINTFORML 「儂の部屋に入るのは初めてじゃの？まあ、ゆっくりしていくがよい」
						PRINTFORMW %K69_1_TNAME%は少し部屋を片付けると%CALLNAME:MASTER%を部屋に招き入れた
					ELSE
						IF TALENT:恋慕
							IF FIRSTTIME("EV1B")
								PRINTFORML 「待っておったぞ、%MASTERNAME:69%」
								PRINTFORML %K69_1_TNAME%は%CALLNAME:MASTER%の姿を認めると、嬉しそうに部屋に招き入れた
								PRINTFORML 「ふむ……」
								PRINTFORML ぼうっとしている彼女にどうしたのかと尋ねる
								PRINTFORML 「ああ、いやなに、%CALLNAME:MASTER%が儂の部屋にいるのが、なんとも、その、な……♪」
								PRINTFORML 「すまんすまん、ゆっくりくつろいでいっておくれ」
								PRINTFORMW 少し恥ずかしそうにそう言う彼女に、%CALLNAME:MASTER%も胸が温かくなるのを感じた
							ELSE
								PRINTFORML 「待っておったぞ、%MASTERNAME:69%」
								PRINTFORML 「ふふ、ゆっくりくつろいでいっておくれ」
								PRINTFORMW %K69_1_TNAME%は%CALLNAME:MASTER%の姿を認めると、嬉しそうに部屋に招き入れた
							ENDIF
						ELSEIF TALENT:思慕
							IF FIRSTTIME("EV1C")
								PRINTFORML 「よく来たの、%MASTERNAME:69%」
								PRINTFORML %K69_1_TNAME%は%CALLNAME:MASTER%の姿を認めると、少し嬉しそうに部屋に招き入れた
								PRINTFORML 「して、今日は何の用じゃ？」
								PRINTFORML 用件を聞かれた%CALLNAME:MASTER%は、マミゾウに会いに来たと伝えた
								PRINTFORML 「ほほっ、そうかそうか。それは嬉しいのう♪」
								PRINTFORML 「ふふ、ゆっくりくつろいでいっておくれ」
								PRINTFORMW 少し嬉しそうににそう言う彼女の言葉に甘え、%CALLNAME:MASTER%はマミゾウの部屋に入った
							ELSE
								PRINTFORML 「よく来たの、%MASTERNAME:69%」
								PRINTFORML 「ふふ、ゆっくりくつろいでいっておくれ」
								PRINTFORMW %K69_1_TNAME%は%CALLNAME:MASTER%の姿を認めると、少し嬉しそうに部屋に招き入れた
							ENDIF
						ELSEIF TALENT:愛欲 || TALENT:セフレ
							IF FIRSTTIME("EV1D")
								PRINTFORML 「待っておったぞ、%MASTERNAME:69%……♪」
								PRINTFORML %K69_1_TNAME%は%CALLNAME:MASTER%の姿を認めると、舌なめずりをしながら部屋に招き入れた
								PRINTFORML 「ふふ……。儂の部屋に来たということは、そういうことじゃろ……？」
								PRINTFORML 「いいぞ？儂もちょうどそういう気分だったからの……♪」
								PRINTFORML 「ふふ……。まあ、ゆっくりくつろいでいっておくれ……♪」
								PRINTFORMW 誘惑するようにそう言う彼女の言葉に、%CALLNAME:MASTER%は期待似胸を膨らませるのであった…
							ELSE
								PRINTFORML 「待っておったぞ、%MASTERNAME:69%……♪」
								PRINTFORML 「ふふ……。まあ、ゆっくりくつろいでいっておくれ……♪」
								PRINTFORMW %K69_1_TNAME%は%CALLNAME:MASTER%の姿を認めると、嬉しそうに部屋に招き入れた
							ENDIF
						ELSE
							PRINTFORML 「まあ、くつろいでいっておくれ」
							PRINTFORMW %K69_1_TNAME%はそう言って%CALLNAME:MASTER%を部屋に招き入れた
						ENDIF
					ENDIF
					TCVAR:K69_CNUM:357 = 1
				;日に二回目の訪問
				ELSE
					PRINTFORMW 「おや、いらっしゃい」
				ENDIF
			;どこでも
			ELSE
				PRINTFORMW 「やあ、%MASTERNAME:69%」
			ENDIF
		ENDIF
		PRINTW 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGETが入ってきた
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		IF TALENT:機嫌 == -1
			IF TALENT:恋慕 || TALENT:愛欲 || TALENT:思慕
				PRINTFORML 「……邪魔するぞい」
				PRINTFORMW %K69_1_TNAME%は不機嫌そうに、%CALLNAME:MASTER%を一瞥するのみだった…
			ELSE
				PRINTFORML 「………」
				PRINTFORMW %K69_1_TNAME%は不機嫌そうに、%CALLNAME:MASTER%に一瞥もくれずに部屋に入ってきた…
			ENDIF
		ELSE
			;自室 同居以外
			IF !(CFLAG:MASTER:神社在住 == CFLAG:K69_CNUM:神社在住) && CFLAG:MASTER:神社在住 == CFLAG:K69_CNUM:現在位置
				IF !TCVAR:K69_CNUM:356
					PRINTFORML 「邪魔するぞい」
					IF FIRSTTIME("EV1E")
						PRINTFORML 「ふむ……ここがお前さんの部屋か……。」
						PRINTFORMW %K69_1_TNAME%が部屋に入ってきた
					ELSE
						IF TALENT:恋慕
							IF FIRSTTIME("EV1F")
								PRINTFORML 「合いに来たぞい、%MASTERNAME:69%♪」
								PRINTFORML %K69_1_TNAME%は%CALLNAME:MASTER%の姿を認めると、嬉しそうに部屋に上がりこんだ
								PRINTFORML 「ふう……」
								PRINTFORML ぼうっとしている彼女にどうしたのかと尋ねる
								PRINTFORML 「ああ、いやなに、%CALLNAME:MASTER%の部屋は落ち着くと思っての…」
								PRINTFORML 「すまんすまん、それじゃゆっくりさせてもらうぞい」
								PRINTFORMW 少し恥ずかしそうにそう言う彼女に、%CALLNAME:MASTER%も胸が温かくなるのを感じた
							ELSE
								PRINTFORML 「合いに来たぞい、%MASTERNAME:69%」
								PRINTFORML 「ふふ、ゆっくりさせてもらおうかの」
								PRINTFORMW %K69_1_TNAME%は%CALLNAME:MASTER%の姿を認めると、嬉しそうに部屋に上がりこんだ
							ENDIF
						ELSEIF TALENT:思慕
							IF FIRSTTIME("EV1G")
								PRINTFORML 「ここにおったか、%MASTERNAME:69%」
								PRINTFORML %K69_1_TNAME%は%CALLNAME:MASTER%の姿を認めると、部屋に上がりこんだ
								PRINTFORML 「何をしに来たか、じゃと？まあ、少し顔を拝みたくなってな」
								PRINTFORML 用件を聞かれたマミゾウが少し照れ臭そうにそう答えた
								PRINTFORML 「まあ、そう邪険にするでない。悪さなどせんよ」
								PRINTFORMW 「ふふ、まあ少し話そうじゃないか」
							ELSE
								PRINTFORML 「ここにおったか、%MASTERNAME:69%」
								PRINTFORML 「ふふ、まあ少し話そうじゃないか」
								PRINTFORMW %K69_1_TNAME%は%CALLNAME:MASTER%の姿を認めると、部屋に上がりこんだ
							ENDIF
						ELSEIF TALENT:愛欲 || TALENT:セフレ
							IF FIRSTTIME("EV1H")
								PRINTFORML 「ここにおったか、%MASTERNAME:69%……♪」
								PRINTFORML %K69_1_TNAME%は%CALLNAME:MASTER%の姿を認めると、舌なめずりをしながら部屋に上がりこんだ
								PRINTFORML 「ふふ……。なに、ここに来る要件なんぞ、一つしかないじゃろう……？」
								PRINTFORML 「さあ、ゆっくりと話をしようではないか……♪」
								PRINTFORMW 誘惑するようにそう言う彼女の言葉に、%CALLNAME:MASTER%は期待似胸を膨らませるのであった…
							ELSE
								PRINTFORML 「待ここにおったか、%MASTERNAME:69%……♪」
								PRINTFORML 「ふふ……。少し話をしようじゃないか……♪」
								PRINTFORMW %K69_1_TNAME%は%CALLNAME:MASTER%の姿を認めると、嬉しそうに部屋に上がりこんだ
							ENDIF
						ELSE
							PRINTFORML 「おや、お前さん、おったのか」
							PRINTFORMW %K69_1_TNAME%はそう言って部屋に上がりこんだ
						ENDIF
					ENDIF
					TCVAR:K69_CNUM:356 = 1
				;日に二回目の訪問
				ELSE
					PRINTFORMW 「邪魔するぞい」
				ENDIF
			;どこでも
			ELSE
				PRINTFORMW 「やあ、%MASTERNAME:69%」
			ENDIF
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGETが風呂に入ってきて一緒に入る
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		PRINTFORML 「おっと、入っておったか　ふふ、邪魔するぞい♪」
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGETが風呂に入ってきて出て行った
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 4
		PRINTFORML 「おっと、入っておったか、すまんの」
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGETが風呂に入ってきて追い出された
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 5
		PRINTFORML 「儂が入るんじゃ、ほれ出てけ出てけ」
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;外出先で遭遇した
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 6
		PRINTFORML 「おや、こんにちは」
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;他キャラとデート中に遭遇した
	;ARG:1にデート相手
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 7
		PRINTFORML 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;MAIN_MAP上で一日最初の挨拶
	;注、このあと通常の遭遇口上、ARG==1 OR ARG==2に接続します
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 8
		PRINTFORML 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;外出先で一日最初の挨拶
	;ARG:1にデート相手、ARG:1が0の場合は非デート
	;注、このあと通常の外出先で遭遇した口上、ARG==6 OR ARG==7に接続します
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 9
		;ARG:1とデート中
		IF ARG:1
		;一人で外出
		ELSE
		ENDIF
		PRINTFORML 
		RETURN 1
	ENDIF
ENDIF
RETURN 1

;==================================================
;朝起きたとき（おはよう口上）
;==================================================
@別人変身版_EVENT_K69_2(ARG,ARG:1)
;口上主はTARGET
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 0
;-------------

IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;非同棲かつ相手が先に起きてる
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		;-------------------------------------------------
		;TARGET私室にMASTERが入っている（恋慕時添い寝中就寝時のみ？
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1 && !ARG:1
			PRINTFORMW 
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;MASTER私室にTARGETが入ってきてる(恋慕無しでも入ってくる可能性有り
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1 && ARG:1 == 1
			PRINTFORMW 
			RETURN 1
		ENDIF
		PRINTFORMW 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;同棲かつ相手が起きている
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		PRINTFORMW 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;同棲かつ相手が寝ている
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		PRINTFORMW 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;MASTERが起きていて、相手が起きてきた
	;添い寝時TARGET起床はこちら（TARGET衰弱or添い寝中TARGET睡魔負け後そのままMASTERが起き続けた上で相手が起床した場合限定
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 4
		;-------------------------------------------------
		;非同棲
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1 && !ARG:1
			PRINTFORMW 
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;同棲中
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1 && ARG:1 == 1
			PRINTFORMW 
			RETURN 1
		ENDIF
		PRINTFORMW 
		RETURN 1
	ENDIF
	;その他
	PRINTFORML  
ENDIF
RETURN 1

;==================================================
;夜寝るとき（おやすみ口上）
;==================================================
@別人変身版_EVENT_K69_3(ARG,ARG:1)
;口上主はTARGET
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 0
;-------------

IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;自室に帰って寝る（～は【現在地】から【キャラの自室】に戻りました）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		IF ARG:1
			;デート中に眠くて帰って寝る（拠点キャラのみ）
			PRINTFORMW 
		ELSEIF CFLAG:うふふ
			;うふふ中に眠くて自室に帰って寝る（拠点キャラのみ）
			PRINTFORMW 
		ELSE
			PRINTFORMW 
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;眠そうにしている（～は眠そうにしている）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		PRINTFORMW 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;睡眠中（～は眠っている）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		PRINTFORMW 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;イタズラ中
	;記入チェック（=0, 非表示、1, 表示）
	;LOCAL:1 = 0
	;-------------------------------------------------
	;IF LOCAL:1 && ARG == 4
		;PRINTFORMW 
		;RETURN 1
	;ENDIF
	;-------------------------------------------------
	;衰弱して寝る（体力500以下,うふふ時はうふふ強制終了）
	;（キャラの自室以外：～を【現在地】から【キャラの自室】に運びました）
	;（キャラの自室　　：～は疲れたと言って、横になりました）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 5
		IF CFLAG:うふふ
			;うふふ中にダウン
			PRINTFORMW 
		ELSE
			PRINTFORMW 
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;MASTERがダウン（恋慕のみ,そのまま一日が終了）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 6
		;お酒でダウン
		IF BASE:MASTER:酒気 >= MAXBASE:MASTER:酒気
			IF ARG:1
				;自室でダウン,（～が【MASTER】をベッド（布団）へと運んでくれた…）
				PRINTFORMW 
			ELSE
				;部屋まで運ばれる,（～が【MASTER】を私室へと運んでくれた…）
				PRINTFORMW 
			ENDIF
		;体力切れでダウン
		ELSE
			IF ARG:1
				;自室でダウン,（～が【MASTER】をベッド（布団）へと運んでくれた…）
				PRINTFORMW 
			ELSE
				;部屋まで運ばれる,（～が【MASTER】を私室へと運んでくれた…）
				PRINTFORMW 
			ENDIF
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGETが寝るために自室まで戻ってきた
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 7
		;-------------------------------------------------
		;そのまま着替えて寝た（【TARGET】が部屋に戻ってきた→寝間着へと着替え、寝床に潜った）
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1 && ARG:1 == 0
			PRINTFORMW 
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;部屋から追い出して寝た（眠そうな【TARGET】に追い出された…）
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1 && ARG:1 == 1
			IF CFLAG:前ターン位置 == CFLAG:現在位置
				;前のターンまで一緒に部屋にいた
				PRINTFORMW 
			ELSE
				;寝るために部屋に帰ってきたところ
				PRINTFORMW 
			ENDIF
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;他キャラとのＨを止めさせて寝た（【TARGET】が部屋に戻ってきた→唇をとがらせる【TARGET】に、【MASTER】は渋々【Ｈの相手】から離れた）
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1 && ARG:1 == 2
			PRINTFORMW 
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;来訪キャラが拠点で休憩（～は疲れ切っている→ちょっと休んでいきなよ）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 8
		PRINTFORMW 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;寝室に居る状態でその場で寝る（～は眠気に負け、眠りについた…）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 9
		IF CFLAG:うふふ
			;うふふ中に寝る
			PRINTFORMW 
		ELSE
			PRINTFORMW 
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;拠点外で自宅前に居るキャラが自室に帰って寝る（眠くなった～は自室に帰って行きました）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 10
		PRINTFORMW 
		RETURN 1
	ENDIF
ENDIF
RETURN 1

;==================================================
;移動時すれちがい
;==================================================
@別人変身版_EVENT_K69_4(ARG,ARG:1)
;口上主はTARGET
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 0
;-------------

IF LOCAL
