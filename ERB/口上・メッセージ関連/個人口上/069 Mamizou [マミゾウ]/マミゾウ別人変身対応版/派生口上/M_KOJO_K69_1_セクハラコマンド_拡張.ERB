						PRINTFORMW マミゾウが\@ CFLAG:K69_CNUM:変化先 == K69_CNUM ? # %CALLNAME:(CFLAG:K69_CNUM:変化先)%の姿で\@煽りながら抱き返してきた…
					CASE 2
						CALL HPH_PRINT,@"「んん……っ、%CALLNAME:(CFLAG:K69_CNUM:変化先)%はこの娘が好きなのか？HPH","L"
						CALL HPH_PRINT,@" ……妬いてしまうのう……、まあじゃがほれ、存分に味わえ……HPH」","L"
						PRINTFORMW マミゾウは%CALLNAME:(CFLAG:K69_CNUM:変化先)%の姿でなされるままになっている…
					ENDSELECT
				ENDIF
			ENDIF
		ELSEIF TALENT:K69_CNUM:恋慕 || TALENT:K69_CNUM:愛欲
			;変身中
			IF CFLAG:K69_CNUM:変化先
				;人里
				IF (CFLAG:K69_CNUM:現在位置 / 100) == 2
					SELECTCASE RAND:2
					CASE 0
						CALL PRINTCOLOR(COLOR("LIGHT-GRAY"),@"「ん……っ、こら、今はダメじゃ……")
						CALL PRINTCOLOR(COLOR("LIGHT-GRAY"),@"　周りがみとるじゃろ、するなら人気のないところでじゃ……」")
						PRINTFORMW マミゾウが周りに目を配りながら小声でそう囁いてきた…
					CASE 1
						CALL PRINTCOLOR(COLOR("LIGHT-GRAY"),@"「ん……っ、こら、今はダメじゃ……")
						CALL PRINTCOLOR(COLOR("LIGHT-GRAY"),@"　周りがみとるじゃろ、するなら人気のないところでじゃ……」")
						PRINTFORMW マミゾウが周りに目を配りながら小声でそう囁いてきた…
					ENDSELECT
				;人里以外
				ELSE
					SELECTCASE RAND:3
					CASE 0
						CALL HPH_PRINT,@"「ん……、%MASTERNAME:K69_CNUM%、あったかいのう……HPH」","L"
						PRINTFORMW マミゾウは%CALLNAME:(CFLAG:K69_CNUM:変化先)%の姿のまま身体を%MASTERNAME:K69_CNUM%に預けてきた…
					CASE 1
						CALL HPH_PRINT,@"「ん……、%MASTERNAME:K69_CNUM%の匂い、落ち着くのう……HPH」","L"
						PRINTFORMW マミゾウは%CALLNAME:(CFLAG:K69_CNUM:変化先)%の姿のまま身体を%MASTERNAME:K69_CNUM%に預けてきた…
					CASE 2
						CALL HPH_PRINT,@"「なんじゃ、お前さんこの娘が好きなのか？HPH","L"
						CALL HPH_PRINT,@" まったく妬けるのう……、 ほれ、存分に味わうのじゃ……HPH」","L"
						PRINTFORMW マミゾウは%CALLNAME:(CFLAG:K69_CNUM:変化先)%の姿でなされるままになっている…
					ENDSELECT
				ENDIF
			;非変身中
			ELSE
				SELECTCASE RAND:2
				CASE 0
					CALL HPH_PRINT,@"「ん……、%MASTERNAME:K69_CNUM%、あったかいのう……HPH」","L"
					PRINTFORMW マミゾウはその身体を%MASTERNAME:K69_CNUM%に預けてきた…
				CASE 1
					CALL HPH_PRINT,@"「ん……、%MASTERNAME:K69_CNUM%の匂い、落ち着くのう……HPH」","L"
					PRINTFORMW マミゾウは顔を%MASTERNAME:K69_CNUM%の胸に埋め、ぽつりと呟くようにそう言った…
				ENDSELECT
			ENDIF
		ELSE
		ENDIF
	ENDIF
ENDIF
RETURN 1
