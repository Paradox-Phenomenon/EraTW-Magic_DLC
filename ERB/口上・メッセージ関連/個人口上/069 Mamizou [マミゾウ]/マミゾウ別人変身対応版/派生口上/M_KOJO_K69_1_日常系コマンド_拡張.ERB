							CASE 3
								PRINTFORML 「せっかくだし、\@ RAND:2 == 0 ? 鈴奈庵 # 鯢呑亭\@でも冷やかしに行こうかのう……♪」
								PRINTFORML 「……ほら、一緒にいきましょ、%CALLNAME:MASTER%♪」
								PRINTFORMW %CALLNAME:(CFLAG:K69_CNUM:変化先)%のフリをしたマミゾウが、%CALLNAME:MASTER%の手を楽しそうに引っ張った…
							ENDSELECT
						;人里以外
