			ELSEIF LOCAL:99 == 23	;呑屋小道
			ELSEIF LOCAL:99 == 24	;寺子屋
			ELSEIF LOCAL:99 == 25	;大衆浴場
			ELSEIF LOCAL:99 == 26	;連れ込み宿
