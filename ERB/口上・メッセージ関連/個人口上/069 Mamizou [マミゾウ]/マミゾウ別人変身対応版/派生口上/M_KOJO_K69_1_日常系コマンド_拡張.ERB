			ELSEIF LOCAL:99 == 12	;枝垂れ柳の下
			ELSEIF LOCAL:99 == 13	;命蓮寺境内
			ELSEIF LOCAL:99 == 14	;命蓮寺本堂
			ELSEIF LOCAL:99 == 15	;墓地
