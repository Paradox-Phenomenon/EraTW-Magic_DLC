@INSERT_KOJO_K69_K70(ARG:0, ARG:1, ARG:2)
#DIM TRANSAFTER
TRANSAFTER = CFLAG:TARGET:変化先 == 0 ? K69_CNUM # CFLAG:TARGET:変化先
;Ｖ
SIF FLAG:70
	RETURN 0
IF ARG:0 == 0
