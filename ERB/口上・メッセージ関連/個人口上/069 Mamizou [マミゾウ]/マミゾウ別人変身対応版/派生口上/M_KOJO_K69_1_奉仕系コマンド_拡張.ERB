;==================================================
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@別人変身版_MESSAGE_COM_K69_80
#DIM TRANSAFTER
#DIMS VALUE
TRANSAFTER = CFLAG:TARGET:変化先 == 0 ? K69_CNUM # CFLAG:TARGET:変化先
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		PRINTFORMW 
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		RETURN 1
	ELSEIF TALENT:恋慕 || TALENT:愛欲 || TALENT:セフレ
		IF NOWEX:MASTER:射精
			LOCAL:99 = RAND:2
			SELECTCASE LOCAL:99
			CASE 0
				CALL HPH_PRINT,@"「うむ、いいぞいHPH　\@ TRANSAFTER == K69_CNUM ? 儂の # %CALLNAME:TRANSAFTER%の\@手に思いっきり射精すがよいHPH」","W"
			CASE 1
				CALL HPH_PRINT,@"「ぴくぴくしてきたのうHPH　ほれ、\@ TRANSAFTER == K69_CNUM ? 儂の # %CALLNAME:TRANSAFTER%の\@手でイけっHPH」","W"
			ENDSELECT
		ELSE
			IF BASE:MASTER:勃起 < 1000
				LOCAL:99 = RAND:2
				SELECTCASE LOCAL:99
				CASE 0
					CALL HPH_PRINT,@"「なんじゃ、萎びとるのう……　どれ、儂が\@ TRANSAFTER == K69_CNUM ? # この娘の \@手で大きくしてやろうHPH」","W"
				CASE 1
					CALL HPH_PRINT,@"「ほれ、\@ TRANSAFTER == K69_CNUM ? 儂の # %CALLNAME:TRANSAFTER%の \@\@ TALENT:K69_CNUM:体型 < 0 ? 小さなおてて # 手 \@でちんちん扱いてやるからはよう勃たせんかHPH」","W"
				ENDSELECT
			ELSE
				LOCAL:99 = RAND:3
				SELECTCASE LOCAL:99
				CASE 0
					CALL HPH_PRINT,@"「ほれ、どうじゃ？\@ TRANSAFTER == K69_CNUM ? 儂の # %CALLNAME:TRANSAFTER%の \@\@ TALENT:K69_CNUM:体型 < 0 ? 小さなおてて # 手 \@に扱かれるのは？HPH気持ちいいか？HPH」","W"
				CASE 1
					CALL HPH_PRINT,@"「こうやって、しこしこ、しこしこ……HPH」","W"
				CASE 2
					CALL HPH_PRINT,@"「\@ TALENT:K69_CNUM:体型 < 0 ? このようなこどもの身体にちんちん扱かれて興奮するなぞ、%MASTERNAME:K69_CNUM%はろりこんの変態じゃなあ…… # ほれほれ、こうすると、気持ちいいじゃろう？\@HPH」","W"
				ENDSELECT
			ENDIF
		ENDIF
		RETURN 1
	;それ以外
	ELSE
		IF NOWEX:MASTER:射精
			CALL HPH_PRINT,@"「む、いいぞいHPH　\@ TRANSAFTER == K69_CNUM ? 儂の # %CALLNAME:TRANSAFTER%の\@手に思いっきり射精すがよいHPH」","W"
		ELSE
			CALL HPH_PRINT,@"「こうやって、しこしこ、しこしこ……」","W"
		ENDIF
		RETURN 1
	ENDIF
ENDIF
RETURN 1

