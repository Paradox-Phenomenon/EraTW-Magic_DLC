;==================================================
;1,クンニ
;==================================================
@別人変身版_MESSAGE_COM_K69_1
#DIM TRANSAFTER
TRANSAFTER = CFLAG:TARGET:変化先 == 0 ? K69_CNUM # CFLAG:TARGET:変化先
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		PRINTFORMW 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;膣内射精直後
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && TCVAR:100 == PLAYER
		IF TCVAR:102
			LOCAL:99 = RAND:1
			SELECTCASE LOCAL:99
			CASE 0
				;CALL HPH_PRINT,@"「……お前さん、とんだ変態じゃな……、っ、あっ……HPH」","W"
				CALL HPH_PRINT,@"%K69_AUTO_AEGI_INS("…お前さん,とんだ,変態,じゃな",3)%","W"
			ENDSELECT
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;絶頂した
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && NOWEX:Ｃ絶頂
		IF FLAG:70
			RETURN 1
		ELSE
			IF TRANSAFTER != K69_CNUM && RAND:5 < 3
				LOCAL:99 = RAND:1
				SELECTCASE LOCAL:99
				CASE 0
					;CALL HPH_PRINT,@"「く……あ……っ、%CALLNAME:TRANSAFTER%のまんこ……っ、イ、イク……ぅ、うああっっHPH」","W"
					LOCALS = く,あ…っ、,%CALLNAME:TRANSAFTER%,の,まんこ,、,イ、イク…ぅ
					CALL HPH_PRINT,@"%K69_AUTO_AEGI_INS(LOCALS,3)%","W"
				ENDSELECT
			ELSE
				LOCAL:99 = RAND:2
				SELECTCASE LOCAL:99
				CASE 0
					;CALL HPH_PRINT,@"「く……う……っ、イ、イク……ぅ、うああっっHPH」","W"
					CALL HPH_PRINT,@"%K69_AUTO_AEGI_INS("く,う…っ、,イ、イク…ぅ",3)%","W"
				CASE 1
					;CALL HPH_PRINT,@"「く……ふ……っま、まて……んあっ……HPH　っああっっHPH」","W"
					CALL HPH_PRINT,@"%K69_AUTO_AEGI_INS("く,ふ…っ,ま,まて,んあっ",3)%","W"
				ENDSELECT
			ENDIF
		ENDIF
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		RETURN 1
	;恋慕
	ELSEIF TALENT:恋慕 || TALENT:愛欲 || TALENT:セフレ
		IF TRANSAFTER != K69_CNUM && RAND:5 < 3
			LOCAL:99 = RAND:1
			SELECTCASE LOCAL:99
			CASE 0
				;CALL HPH_PRINT,@"「ん……っ、どうじゃ、%CALLNAME:TRANSAFTER%のまんこの味は……HPHんん……っHPH」","W"
				LOCALS = どうじゃ、,%CALLNAME:TRANSAFTER%,の,まんこ,の,味,は
				CALL HPH_PRINT,@"%K69_AUTO_AEGI_INS(LOCALS,3)%","W"
			ENDSELECT
		ELSE
			LOCAL:99 = RAND:2
			SELECTCASE LOCAL:99
			CASE 0
				;CALL HPH_PRINT,@"「ん……っ、……そんなところ、嬉しそうに舐めおって……、んん……っHPH」","W"
				CALL HPH_PRINT,@"%K69_AUTO_AEGI_INS("そんな,ところ、,嬉しそう,に,舐め,おって…",3)%","W"
			CASE 1
				;CALL HPH_PRINT,@"「んあ…っ,くう…っ,んん…っ」","W"
				CALL HPH_PRINT,@"%K69_AUTO_AEGI_INS("んあ…っ,くう…っ,んん…っ",3)%","W"
			ENDSELECT
		ENDIF
		RETURN 1
	;それ以外
	ELSE
		;CALL HPH_PRINT,@"「ん……っ、……そんなところ、嬉しそうに舐めおって……、んん……っHPH」","W"
		CALL HPH_PRINT,@"%K69_AUTO_AEGI_INS("そんな,ところ、,嬉しそう,に,舐め,おって…",3)%","W"
		RETURN 1
	ENDIF
ENDIF
RETURN 1
