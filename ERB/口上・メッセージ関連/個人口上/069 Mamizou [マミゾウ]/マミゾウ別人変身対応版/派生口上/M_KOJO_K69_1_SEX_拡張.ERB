							;CALL HPH_PRINT,@"「ふ……っHPH　ふ……っHPH　この光景、興奮するのう、%MASTERNAME:K69_CNUM%HPH」","W"
							LOCALS =ふ……っ、ふ……っ,この光景,、興奮する,のう,、%MASTERNAME:K69_CNUM%…
							CALL HPH_PRINT,@"%K69_AUTO_AEGI_INS(LOCALS,3)%","W"
						CASE 1
							;CALL HPH_PRINT,@"「んおっHPH　儂のちんぽが、%MASTERNAME:K69_CNUM%の子宮をのっくしとるっHPH」","W"
							LOCALS =んおっ,儂のちんぽが,、%MASTERNAME:K69_CNUM%,の,子宮を,のっくしとるっ
							CALL HPH_PRINT,@"%K69_AUTO_AEGI_INS(LOCALS,3)%","W"
						CASE 2
							LOCALS = お…,、うおお,、んん…
							CALL HPH_PRINT,@"%K69_AUTO_AEGI_INS(LOCALS,3)%","W"
						ENDSELECT
					ENDIF
				ENDIF
			ENDIF
		;陥落なし
		ELSE
			IF NOWEX:MASTER:Ｖ絶頂 && NOWEX:TARGET:射精
				CALL HPH_PRINT,@"「んあっHPH　膣内で、大きく……っHPHふおおっHPH」","W"
			ELSEIF NOWEX:MASTER:Ｖ絶頂
				CALL HPH_PRINT,@"「必死になりおってHPH　いいじゃろう、はようイけっHPH」","W"
			ELSEIF NOWEX:TARGET:射精
				CALL HPH_PRINT,@"「んおっHPH　いいぞ、イきそうじゃ……っHPH」","W"
			ELSE
				CALL HPH_PRINT,@"「あんっHPH　どうじゃっHPH　儂のちんちんはっHPH」","W"
			ENDIF
		ENDIF
	;中出し後
	ELSE
		IF TALENT:恋慕 || TALENT:愛欲 || TALENT:セフレ
			IF TCVAR:MASTER:Vに中出しされたフラグ && RAND:3 == 0
				IF TRANSAFTER != K69_CNUM && RAND:5 < 3
					LOCAL:99 = RAND:2
					SELECTCASE LOCAL:99
					CASE 0
						CALL HPH_PRINT,@"「うあっHPH　まて、%MASTERNAME:K69_CNUM%HPH　今射精したばかりじゃろうがっHPH」","W"
						LOCALS = うあっ,まて,、%MASTERNAME:K69_CNUM%,、今,射精した,ばかり,じゃろうがっ
						CALL HPH_PRINT,@"%K69_AUTO_AEGI_INS(LOCALS,3)%","W"
					CASE 1
						CALL HPH_PRINT,@"「うあっHPH　%MASTERNAME:K69_CNUM%っHPH　そんなに%CALLNAME:TRANSAFTER%の子が欲しいのかっ%MASTERNAME:K69_CNUM%」","W"
						LOCALS = うあっ,%MASTERNAME:K69_CNUM%,、そんなに,%CALLNAME:TRANSAFTER%,の,子が,欲しいのか,%MASTERNAME:K69_CNUM%っ
						CALL HPH_PRINT,@"%K69_AUTO_AEGI_INS(LOCALS,3)%","W"
					ENDSELECT
				ELSE
					LOCAL:99 = RAND:2
					SELECTCASE LOCAL:99
					CASE 0
						CALL HPH_PRINT,@"「うあっHPH　まて、%MASTERNAME:K69_CNUM%HPH　今射精したばかりじゃろうがっHPH」","W"
						LOCALS = うあっ,まて,、%MASTERNAME:K69_CNUM%,、今,射精した,ばかり,じゃろうがっ
						CALL HPH_PRINT,@"%K69_AUTO_AEGI_INS(LOCALS,3)%","W"
					CASE 1
						CALL HPH_PRINT,@"「うあっHPH　%MASTERNAME:K69_CNUM%っHPH　そんなに儂の子が欲しいのかっ%MASTERNAME:K69_CNUM%」","W"
						LOCALS = うあっ,%MASTERNAME:K69_CNUM%,、そんなに,儂の,子が,欲しいのか,%MASTERNAME:K69_CNUM%っ
						CALL HPH_PRINT,@"%K69_AUTO_AEGI_INS(LOCALS,3)%","W"
					ENDSELECT
				ENDIF
			ELSE
				GOTO INSERT_V
			ENDIF
		ELSE
			IF TCVAR:MASTER:Vに中出しされたフラグ && RAND:3 == 0
				CALL HPH_PRINT,@"「うあっHPH　まて、%MASTERNAME:K69_CNUM%HPH　今射精したばかりじゃろうがっHPH」","W"
			ELSE
				GOTO INSERT_V
			ENDIF
		ENDIF
	ENDIF
ELSE
;Ａ　現状スキップ
ENDIF
RETURN 1
