RETURN RESULT

@M_KOJO_POWERED_BY_OVERSEAS_MESSAGE_COM_K98_411_1

#DIM 正解
#DIM 経験値
#DIM 制限時間
#DIM 倍率
#DIM FEINT
#DIM イカサマ
VARSET LOCAL
イカサマ = 0
制限時間 = 2000 - (ABL:[[依姫]]:戦闘能力 - ABL:MASTER:戦闘能力) * 100

;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;特訓デイリーからお借りしました
	CALL M_KOJO_POWERED_BY_OVERSEAS_COLOR_K98
	PRINTFORMDL 你手持木剑，与依姬对峙着。
	PRINTFORML 「虽然是练习，但也不要掉以轻心」
	PRINTFORML 「就当作实战，全力应对吧」
	PRINTFORMDW %CALLNAME:TARGET%似乎也很认真。那么……
	RESETCOLOR
	PRINTFORML 
	CALL ASK_YN("开始练习！", "逃跑！")
	IF RESULT
		CALL M_KOJO_POWERED_BY_OVERSEAS_COLOR_K98
		PRINTFORML 「咦！？」
		PRINTFORMDL 逃跑算胜利。也就是说胜者是我自己
		PRINTFORMDW 你置之不理地留下惊讶的%CALLNAME:TARGET%，全力狂奔逃离了现场……
		RESETCOLOR
	ELSE
		正解 = RAND:4
		経験値 = MIN(ABL:[[依姫]]:戦闘能力 * 5, 5)
		SELECTCASE RAND:20
			CASE IS <= 11
			;普通に
				LOCALS:0 = 上
				LOCALS:1 = 右
				LOCALS:2 = 左
				LOCALS:3 = 下
				倍率 = 100
			CASE 12 TO 15
			;ローマ字
				LOCALS:0 = UE
				LOCALS:1 = MIGI
				LOCALS:2 = HIDARI
				LOCALS:3 = SHITA
				倍率 = 160
			;英語
			CASE 16,17,18
				LOCALS:0 = UP
				LOCALS:1 = RIGHT
				LOCALS:2 = LEFT
				LOCALS:3 = DOWN
				倍率 = 120
			;スペイン語
			CASE 19
				LOCALS:0 = encima de
				LOCALS:1 = a la derecha
				LOCALS:2 = a la izquierda
				LOCALS:3 = abajo de
				倍率 = 300
		ENDSELECT
		;あなたの戦闘能力が高いと５分の一の確率でフェイントをかけてくる
		IF ABL:MASTER:戦闘能力 >= 5 && !RAND:5
			FEINT = 1
			制限時間 += 400
			倍率 += 80
		ELSE
			FEINT = 0
		ENDIF
		CALL FISHER_YATES_SHAFFLE(4)
		PRINTFORMW 躲避%CALLNAME:TARGET%的攻击（点击开始）
		PRINTFORM %CALLNAME:TARGET%の
		SETCOLOR C_YELLOW
		IF FEINT
			PRINTFORM %LOCALS:(RAND:4)%
			RESETCOLOR
			PRINTFORM 以假象为幌子%LOCALS:(3 - 正解)%
		ELSE
			PRINTFORM %LOCALS:(3 - 正解)%
			RESETCOLOR
		ENDIF
		PRINTFORML 紧接着的攻击！
		$LOOP_IKASAMA
		FOR LOCAL:10,0,4
			LOCAL = SHAFFLE_ARRAY:(LOCAL:10)
			PRINTFORML [{LOCAL}] - %LOCALS:LOCAL%能够躲避
		NEXT
		SIF !イカサマ && BASE:MASTER:TSP > 500
			PRINTFORML [{4}] - 時間停止
		TINPUT 制限時間, -1, 1
		IF RESULT == 正解
			CALL M_KOJO_POWERED_BY_OVERSEAS_COLOR_K98
			IF !イカサマ
				PRINTFORMDL %CALLNAME:MASTER%成功躲避了攻击！
				PRINTFORMDL ……………
				PRINTFORMDL ………
				PRINTFORMDW …
				PRINTFORML 「非常感谢」
				PRINTFORMDL 练习结束后，你们面对面行礼
				PRINTFORMDL 对于满身汗水的你，%CALLNAME:TARGET%面无表情，一丝汗水都没有
				;乌冬面笑话
				PRINTFORML 「肌肉不错，但有几个方面还有所欠缺呢」
				PRINTFORML 「力量、技巧、速度、斗志……」
				PRINTFORMDW %CALLNAME:TARGET%数着手指。总之，发现了全部都不足的问题……
			ELSE
				PRINTFORMDL %CALLNAME:MASTER%试图躲避攻击……
				PRINTFORML 「你也使用了奇特的术法啊」
				PRINTFORMDL 停止时间，预测行动――
				PRINTFORMDL 明明应该是在后方，你却躺在地上
				PRINTFORML 「嘛，如果你已经看穿了我的戏法，那也没什么好说的了……」
				PRINTFORMDL %CALLNAME:TARGET%说出了你的名字。那是一个和你拥有相同能力的女仆的名字
				PRINTFORMDW 战斗之前结果似乎已经决定。下次看来需要正大光明地进行了……
				BASE:MASTER:体力 -= 1000
			ENDIF
			RESETCOLOR
			BASE:MASTER:体力 -= 100 * (1 + ABL:[[依姫]]:戦闘能力)
			BASE:MASTER:気力 -= 100 * (1 + ABL:[[依姫]]:戦闘能力)
			経験値 = 経験値 * 倍率 / 100
			EXP:MASTER:戦闘経験 += 経験値
			EXP:[[依姫]]:戦闘経験 += 経験値 * 2
			CFLAG:[[依姫]]:好感度 += 経験値 * 2
			CFLAG:[[依姫]]:信頼度 += 経験値 * 2
			PRINTFORML 戦闘経験 ＋{経験値}（%CALLNAME:MASTER%）
			PRINTFORML 戦闘経験 ＋{経験値 * 2}（%CALLNAME:TARGET%）
			PRINTFORML 好感度 ＋{経験値 * 2}（%CALLNAME:TARGET%）
			PRINTFORML 信頼度 ＋{経験値 * 2}（%CALLNAME:TARGET%）
		ELSEIF RESULT == 4 && !イカサマ && BASE:MASTER:TSP > 500
			イカサマ = 1
			倍率 /= 5
			PRINTFORMW %CALLNAME:MASTER%利用时间停止能力洞察了攻击！
			GOTO LOOP_IKASAMA
		ELSE
			CALL M_KOJO_POWERED_BY_OVERSEAS_COLOR_K98
			PRINTFORMDW 失败了……
			PRINTFORMDL 呼吸急促地跪在你面前，%CALLNAME:TARGET%将木剑指向你
			PRINTFORMDL 投降吧。你放下木剑，仰面倒在地上
			PRINTFORML 「没有休息的时间。接下来是跑步训练。休息在之后」
			PRINTFORMDW 鬼啊，有鬼存在。你仿佛稍微理解了那些兔子们发出的惊叫的心情
			RESETCOLOR
			BASE:MASTER:体力 -= 500 * (1 + ABL:[[依姫]]:戦闘能力)
			BASE:MASTER:気力 -= 500 * (1 + ABL:[[依姫]]:戦闘能力)
			PRINTFORML 戦闘経験 ＋{経験値}（%CALLNAME:TARGET%）
			EXP:[[依姫]]:戦闘経験 += 経験値
			CFLAG:[[依姫]]:好感度 += 経験値 / 2
			CFLAG:[[依姫]]:信頼度 += 経験値 / 2
			PRINTFORML 好感度 ＋{経験値}（%CALLNAME:TARGET%）
			PRINTFORML 信頼度 ＋{経験値}（%CALLNAME:TARGET%）
		ENDIF
	ENDIF
ENDIF
RETURN 1
