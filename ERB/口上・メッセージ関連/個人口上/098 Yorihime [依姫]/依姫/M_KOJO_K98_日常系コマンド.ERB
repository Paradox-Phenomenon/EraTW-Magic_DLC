;==================================================
;（任意）:通常の地の文を表示するかスキップするか決定する。
;MESSAGECHECK関数は、以下のような戻り値を返す
;RETURN 0;通常地の文と口上を表示
;RETURN 1;口上のみ表示
;RETURN 2;通常地の文のみ表示
;RETURN 3;どちらも表示しない
;以下原文
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_POWERED_BY_OVERSEAS_MESSAGE_MESSAGECHECK_COM_K98_300
RETURN 0

@M_KOJO_POWERED_BY_OVERSEAS_MESSAGE_COM_K98_300
;コマンド共通メッセージ(TRAIN_MESSAGE) 
;削除すると「～話をした。」とかが消えます。また、削除した場合は自動で口上色が付きません。
;口上メイン呼出
CALL M_KOJO_POWERED_BY_OVERSEAS_MESSAGE_COM_K98_300_1
RETURN RESULT

@M_KOJO_POWERED_BY_OVERSEAS_MESSAGE_COM_K98_300_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;会話不能
	IF TCVAR:302
		;顔絵を表示（オプションでオンにしていないと表示されない）
		;お風呂
		IF BATHCHECK(CFLAG:MASTER:現在位置) && IN_HOME(CFLAG:MASTER:現在位置)
			CALL PRINT_FACE, [[依姫]], "通常", "裸", "", ""
		;それ以外
		ELSE
			CALL PRINT_FACE, [[依姫]], "通常", "服", "", ""
		ENDIF
		;親密５以上
		IF ABL:親密 > 4
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「那个……」
					PRINTFORMDL %CALLNAME:TARGET%似乎想要开启话题
					PRINTFORMDW 但最终气氛变得尴尬起来了……
				CASE 1
					PRINTFORML 「――喜欢的食物，是吗？」
					PRINTFORML 「啊……桃子，我经常喜欢吃……」
					PRINTFORMDW 尽力想解决尴尬的气氛，结果反而变得更尴尬了……
				CASE 2
					PRINTFORML 「稍微……有点口渴呢」
					PRINTFORMDL 是啊。你回应%CALLNAME:TARGET%的发言
					PRINTFORMDW ……不知为何，%CALLNAME:TARGET%却叹了口气……
			ENDSELECT
		;其他情况
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「谈话结束了吗？」
					PRINTFORMDW 尽管在谈论地面上的经历，但依姬似乎并不感兴趣……
				CASE 1
					PRINTFORML 「…………」
					PRINTFORMDW %CALLNAME:TARGET%完全没有理会你的讲话，而是在玩弄手中的旧书型终端……
				CASE 2
					PRINTFORML 「――尴尬？只有你感觉到尴尬吗？」
					PRINTFORMDL 看来依姬并不是在享受……
					PRINTFORMDW 大概她并不在意吧……
			ENDSELECT
		ENDIF
	;通常
	ELSE
		;恋慕
		IF TALENT:恋慕
			SELECTCASE RAND:10
				CASE 0
					PRINTFORML 「我们姐妹本来就不太受信任」
					PRINTFORML 「放过了罪人八意大人，还庇护了你这个凡人……罪行多得数不清」
					PRINTFORML 「……所以，即使再增加一两个罪过也不是什么大问题吧」
					PRINTFORMDW %CALLNAME:TARGET%微笑了一下。难道说，他是个意外的不良吗？
				CASE 1
					PRINTFORML 「即使遇到困难，也不必担心」
					PRINTFORML 「我会成为保护你的剑。姐姐也希望如此」
					PRINTFORMDL 能够得到像%CALLNAME:TARGET%这样实力强大的人的保护，真是令人放心
					PRINTFORMDW 但如果可能的话，我更希望成为守护者而不是被守护者……
				CASE 2
					PRINTFORML 「小时候，我对地球充满了憧憬」
					PRINTFORML 「那颗蓝色闪耀的美丽星球上，一定居住着了不起的人们……」
					PRINTFORML 「虽然很快就被告知那是错误的……」
					PRINTFORMDL %CALLNAME:TARGET%微笑着靠近你
					PRINTFORML 「我没有错。因为有你这个人存在」
					PRINTFORMDW 她的笑容比任何悬浮在空中的星星都要美丽而闪耀
				CASE 3
					PRINTFORML 「就连曾经对地上人民抱有厌恶的月之民族，也渐渐地改变了」
					PRINTFORML 「从监视对象变成了守望对象。一定是因为你这个存在的重要性吧」
					PRINTFORMDL 虽然没有意识到，但不知何时已成为连接月亮和地球的桥梁般的存在
					PRINTFORMDW 有点害羞，但并不觉得不好。你是这样想的
				CASE 4
					PRINTFORML 「希望你能叫我……哥哥？」
					PRINTFORML 「……………………」
					PRINTFORML 「……哥、哥哥……」
					PRINTFORMDW 『怎么了？』你朝她笑了笑，%CALLNAME:TARGET%的脸变得红扑扑的
				CASE 5
					PRINTFORML 「快到了桃子成熟的时候了。不久之后……啊」
					PRINTFORML 「对了……那个是姐姐全都吃掉了……」
					PRINTFORMDL 很好吃。你这样说道，%CALLNAME:TARGET%瞪了你一眼
					PRINTFORMW 「如果你在场的话，请阻止她。真是的」
				CASE 6
					PRINTFORML 「呵呵，那种事情啊」
					PRINTFORMDL %CALLNAME:TARGET%一边微笑着，一边对你的话点头称是
					PRINTFORMDW 当你讲一个特别有趣的故事时，%CALLNAME:TARGET%忍不住笑出声来，肩膀颤抖着
				CASE 7
					PRINTFORML 「怎么了？一直盯着我的脸……」
					PRINTFORML 「——嗯？『被你迷住了』……？」
					PRINTFORML 「……………………嗯咕」
					PRINTFORMDW 在漫长的沉默之后……脸红得发紫的%CALLNAME:TARGET%终于挤出了这句话
				CASE 8
					PRINTFORML 「如果有兴趣的话，请来看看兔子们的训练」
					PRINTFORML 「那些孩子们也都在期待着能见到你呢」
					PRINTFORMDL 防卫队的孩子们啊……好多可爱的孩子呢……
					PRINTFORMDW %CALLNAME:TARGET%像是看出了你的想法，无奈地摇了摇头
				CASE 9
					PRINTFORML 「铃仙。虽然她的实力还远远不及前辈……」
					PRINTFORML 「但我相信她现在的她能够越过那道墙壁」
					PRINTFORMDL 说着她会进一步增加训练的量
					PRINTFORMDW 可以轻易地想象到铃仙2号发出尖叫声的样子
			ENDSELECT
		;思慕
		ELSEIF TALENT:思慕
			SELECTCASE RAND:10
				CASE 0
					PRINTFORML 「……你很像姐姐」
					PRINTFORML 「有一种吸引人的力量。只要在那里，大家就会感到安心」
					PRINTFORML 「同时也被期待着。作为领导的角色」
					PRINTFORML 「你和姐姐都能够背负起这样的重担，毫不在意」
					PRINTFORML 「……我觉得我很难模仿」
					PRINTFORMDL 在对话进行中，突然%CALLNAME:TARGET%展示出的弱点
					PRINTFORMDW 不是这样的。明明想这么说，但你的嘴巴却无法说出来
				CASE 1
					PRINTFORML 「――嗯？有什么事吗？」
					PRINTFORMDL 最近%CALLNAME:TARGET%的表情变得丰富起来了
					PRINTFORMDL 想起我们刚认识的时候，%CALLNAME:TARGET%总是一副苦恼的表情
					PRINTFORMDL 这大概就是她的本性吧。嘿，原来你也能有可爱的表情啊
					PRINTFORML 「…………？」
					PRINTFORMDW 你不自觉地露出了笑容，%CALLNAME:TARGET%用怪异的表情看着你……
				CASE 2
					PRINTFORML 「你知道为什么姐姐对你那么温柔吗？」
					PRINTFORML 「……不知道也没关系」
					PRINTFORMDW 什么意思？虽然这样问了，%CALLNAME:TARGET%却闭口不言
				CASE 3
					PRINTFORML 「――你喜欢孩子吗？」
					PRINTFORML 「如果说喜欢还是讨厌的话，我更喜欢吧，有什么问题吗？」
					PRINTFORMDW 原来如此。看着你满意地点头，%CALLNAME:TARGET%歪了歪头
				CASE 4
					PRINTFORML 「请不要叫我小依了」
					PRINTFORMDL 为什么？小依
					PRINTFORML 「真是的！明明我都说了不要了！」
					PRINTFORMDW 你取笑着和%CALLNAME:TARGET%玩闹了起来
				CASE 5
					PRINTFORML 「――是以前的姐姐吗？」
					PRINTFORML 「姐姐从以前到现在一点都没有变化」
					PRINTFORML 「变化的只是称号而已……」
					PRINTFORML 「难道说，姐姐对我有什么看法吗？」
					PRINTFORMDL 曾经说过她以前是个撒娇鬼之类的话
					PRINTFORMDW 当你这样说时，%CALLNAME:TARGET%的脸变得越来越红
				CASE 6
					PRINTFORML 「这个发带是八意大人送的」
					PRINTFORML 「在她隐退之前，为了让我们意识到作为月之守护者的责任……」
					PRINTFORMDW %CALLNAME:TARGET%温柔地抚摸着头上的发带。想必是重要的回忆吧
				CASE 7
					PRINTFORML 「就算姐姐邀请你去摘桃子，也请拒绝」
					PRINTFORML 「你已经吃得太多了，再胖下去就麻烦了」
					PRINTFORMDL 月之防卫、地上的监视还有姐姐的照顾……
					PRINTFORMDL %CALLNAME:TARGET%每天都看起来非常忙碌
					PRINTFORML 「听着吗？要注意摄入过多的糖分……」
					PRINTFORMDL 和丰姬一起吃的那个桃子很好吃
					PRINTFORMDW 你随意地附和着%CALLNAME:TARGET%的话，心里却在想着那些事情
				CASE 8
					PRINTFORML 「――想试着挥动这把刀吗？」
					PRINTFORML 「没关系，但是先看一下示范……喂！」
					PRINTFORML 「危险！停下！！！」
					PRINTFORMDW 当你帅气地挥舞着玩耍时，被%CALLNAME:TARGET%训斥了。你哭了起来
				CASE 9
					PRINTFORML 「等到庭院里的桃子成熟时，我打算举办宴会」
					PRINTFORML 「届时你也要一起来。姐姐肯定会很高兴的」
					PRINTFORMDW 这真是令人期待。不过，在那之前，丰姬会等着我吗……
			ENDSELECT
		;それ以外
		ELSE
			SELECTCASE RAND:10
				CASE 0
					PRINTFORML 「你被姐姐允许在月亮上逗留」
					PRINTFORML 「虽然有兴趣，但不要盲目地在月都徘徊」
					PRINTFORMW 「……你在听吗？」
				CASE 1
					PRINTFORML 「——练习是否太过严厉了？」
					PRINTFORML 「由于上一次的战斗导致兔子们的数量减少，所以我们加强了训练」
					PRINTFORML 「而且，我知道你在我不在的时候懒散。这样正好合适」
					PRINTFORMDL 原来如此，你很了解兔子们的性格
					PRINTFORMDW 作为外人，似乎不应该插嘴这个问题……
				CASE 2
					PRINTFORML 「如果有什么事情，请告诉铃仙」
					PRINTFORML 「我已经告诉她了。虽然她还不够成熟，但至少能做到最基本的事情吧」
					PRINTFORMDW %CALLNAME:TARGET%冷冷地回答你的问题。感觉有点冷淡……
				CASE 3
					PRINTFORML 「偶尔会有像你这样的地上居民迷路进来」
					PRINTFORML 「大多数人都很快就喊着要回去……」
					PRINTFORMDW %CALLNAME:TARGET%凝视着你。仿佛在等待你说出想回去的话……
				CASE 4
					PRINTFORML （姐姐……你在想什么呢……）
					PRINTFORML （『再次』让这样的人类……）
					PRINTFORMDW 没有反应……%CALLNAME:TARGET%在想些什么呢？
				CASE 5
					PRINTFORML 「铃仙是姐姐养的宠物」
					PRINTFORML 「之前有个不同的孩子，但是逃跑了」
					PRINTFORML 「现在似乎依靠着我的师傅……八意大人」
					PRINTFORMDL 仍然在关心逃跑的宠物
					PRINTFORMDW 他是个温柔的人。你这样想着。
				CASE 6
					PRINTFORML 「——我的兴趣？ 如果非要说的话，那就是锻炼吧」
					PRINTFORML 「我还远远没有达到师傅八意大人的水平。为了接近那位，我还需要更加努力」
					PRINTFORMDW %CALLNAME:TARGET%紧握拳头，仿佛在对自己说这样的话
				CASE 7
					PRINTFORML 「——能放松一下吗？」
					PRINTFORML 「像姐姐那样。不必担心」
					PRINTFORMDL 真的吗？你凑近%CALLNAME:TARGET%的脸
					PRINTFORML 「……总之！我没事的」
					PRINTFORML 「你才是，现在是活在我的宽容之下，别忘了这一点」
					PRINTFORMDL 『如果成为灾祸，就斩断』%CALLNAME:TARGET%这样说道……
					PRINTFORML 「……怎么了？有什么问题吗？」
					PRINTFORMDW 看着她，你觉得她似乎不是那种能做出那样事情的人
				CASE 8
					PRINTFORML 「地上居民进入太空已经半个多世纪了」
					PRINTFORML 「他们曾经在月球上插上国旗而欢呼雀跃，如今他们甚至伸出手臂触及太阳系之外」
					PRINTFORML 「不容忽视的存在。当然，我绝不打算输」
					PRINTFORMDL 听%CALLNAME:TARGET%说，人类似乎真的成功登陆月球了
					PRINTFORMDW 阿波罗计划并非伪造。你感到胸中涌起一股热情之情
				CASE 9
					PRINTFORML 「那么，你想问我什么？」
					PRINTFORML 「——嗯？你有男朋友吗？」
					PRINTFORMDW %CALLNAME:TARGET%抚摸了刀柄，你赶紧道歉了
			ENDSELECT
		ENDIF
	ENDIF
ENDIF
RETURN 1
