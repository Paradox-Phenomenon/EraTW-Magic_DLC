;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;恋慕
	IF TALENT:恋慕
		SELECTCASE RAND:3
			CASE 0
				PRINTFORML 「茶叶的种类和平时不太一样呢」
				PRINTFORMDL 你向%CALLNAME:TARGET%询问，同时展示了茶叶的袋子
				PRINTFORML 「觉得味道熟悉，那就没错了」
				PRINTFORML 「又擅自从厨房拿出来了吗？」
				PRINTFORMDL 因为有剩余。你一边给自己的茶杯倒茶，一边回答道
				PRINTFORML 「算了，下次请留个字条」
				PRINTFORML 「我可不想在无辜的玉兔面前做寻找犯人的游戏」
				PRINTFORMDW 说着，%CALLNAME:TARGET%又抿了一口茶
			CASE 1
				PRINTFORML 「咕噜噜……呼……」
				PRINTFORMDL 为了忙碌的%CALLNAME:TARGET%，我决定泡了一种据说有疲劳恢复效果的茶
				PRINTFORMDW 从%CALLNAME:TARGET%放松的表情来看，效果似乎不错
			CASE 2
				PRINTFORML 「也许是受到了你的影响，铃仙开始学习茶道了呢……」
				PRINTFORML 「不过，我希望她能先努力练习剑道才是……」
				PRINTFORMDW 你一边喝茶，一边与%CALLNAME:TARGET%闲聊
		ENDSELECT
	;思慕
	ELSEIF TALENT:思慕
		SELECTCASE RAND:3
			CASE 0
				PRINTFORML 「……苦涩。但不仅仅是苦味」
				PRINTFORML 「这是一种未经精炼的、地上的茶味道」
				PRINTFORMDW %CALLNAME:TARGET%将空茶杯放在一旁，舒缓地吐了口气
			CASE 1
				PRINTFORML 「确实，你的技术很棒。但并不完美」
				PRINTFORML 「农业之神啊！请你替我，为这个人泡一杯至高无上的茶！」
				PRINTFORMDL 在%CALLNAME:TARGET%的能力召唤下，一位神明出现并懒散地泡了一杯茶
				PRINTFORMDL 然后，他将茶倒入茶杯，完全不理会我们就消失了
				PRINTFORML 「来吧，请喝吧。趁着还没凉」
				PRINTFORMDL 在%CALLNAME:TARGET%的推荐下，我倾斜着茶杯喝了一口。非常美味
				PRINTFORMDW ……但这样强大的能力却被浪费了。难道平时就这样任意驱使别人吗……
			CASE 2
				PRINTFORML 「嗯，休息一下吧」
				PRINTFORMDL 我给你倒了一杯新泡的茶，递给了%CALLNAME:TARGET%
				PRINTFORMDW %CALLNAME:TARGET%向我道谢，接过茶杯，抿了一口
		ENDSELECT
	;其他情况
	ELSE
		SELECTCASE RAND:3
			CASE 0
				PRINTFORML 「我也来帮忙吧」
				PRINTFORMDL %CALLNAME:TARGET%在手心产生了一团小火焰。你离得近，不禁后退了一步，感受到了火焰的热度
				PRINTFORML 「这是愛宕大人的火焰。地上很少有这么热的火焰」
				PRINTFORMDL %CALLNAME:TARGET%触摸了壶。紧接着，警报声响彻四周，宣告水已经沸腾
				PRINTFORML 「就这样了。剩下的就交给你了」
				PRINTFORMDW 我从%CALLNAME:TARGET%那里接过了壶。这个方便的能力，可真的能这样用吗……
			CASE 1
				PRINTFORMDL 噼啪 嘟嘟嘟……
				PRINTFORML 「你在哪里学的泡茶方法？」
				PRINTFORMDW 我看了说明书
			CASE 2
				PRINTFORML 「呼……」
				PRINTFORMDL 我和%CALLNAME:TARGET%一边喝茶，一边休息片刻
				PRINTFORMDW ……安静。安静得有些尴尬
		ENDSELECT
	ENDIF
ENDIF
RETURN 1
