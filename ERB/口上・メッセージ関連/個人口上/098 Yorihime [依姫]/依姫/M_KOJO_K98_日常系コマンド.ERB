@M_KOJO_POWERED_BY_OVERSEAS_MESSAGE_COM_K98_402_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;お招き部屋で依姫が恋慕じゃないor依姫が睡眠中・衰弱中・あなたの部屋にお泊りの場合はこれ
	IF (!TALENT:恋慕 && CFLAG:MASTER:現在位置 == OMANEKIBEYA()) || (CFLAG:睡眠 || CFLAG:衰弱 || FLAG:一時滞在 == [[依姫]])
		PRINTFORML 「……くぅ」
		PRINTFORMDW 在%CALLNAME:TARGET%安稳入睡的旁边，你闭上了眼睛……
	;一緒に寝る
	ELSEIF CFLAG:MASTER:現在位置 == CFLAG:[[依姫]]:初期位置
		;判定
		SELECTCASE TFLAG:193
			;通常
			CASE 0
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「すぅ……すぅ……」
						PRINTFORMDW 你亲吻着熟睡的%CALLNAME:TARGET%的脸颊，然后关闭了房间的灯光。
					CASE 1
						PRINTFORML 「晚安，%CALLNAME:MASTER%。」
						PRINTFORMDL 确认你入睡后，%CALLNAME:TARGET%也闭上了眼睛。
						PRINTFORMDW ……%CALLNAME:TARGET%那天晚上能够安稳入睡，没有在中途醒来。
					CASE 2
						PRINTFORMDL 当你伸手要关灯时，%CALLNAME:TARGET%拉住了你的睡衣。
						PRINTFORML 「那个，再多待一会儿……」
						PRINTFORML 「如果你还没睡意的话……」
						PRINTFORMDL %CALLNAME:TARGET%似乎想多聊一会儿。
						PRINTFORMDW 你收回了伸出的手，%CALLNAME:TARGET%高兴地靠近了你……
						PRINTFORMDL ……………
						PRINTFORMDL ………
						PRINTFORMDW …
						;昨日はよく眠れなかったフラグON
						CFLAG:MASTER:徹夜 = 1
						;好感度５０上昇
						CALL CHANGE_CFLAG(2, [[依姫]], 50)
				ENDSELECT
			;子供と一緒に川の字で寝る
			CASE 1
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「…………すぅ」
						PRINTFORMDL %CHILDNAME:[[依姫]]:(TALENT:[[依姫]]:育児中)%と%CALLNAME:TARGET%已经入睡了。
						PRINTFORMDW 当你潜入被子里，以免惊醒两个人，闭上了眼睛
					CASE 1
						PRINTFORML 「……～～♪」
						PRINTFORMDL %CALLNAME:TARGET%正在哄%CHILDNAME:[[依姫]]:(TALENT:[[依姫]]:育児中)%睡觉。
						PRINTFORMDW 成为了一个真正的母亲。我也必须有作为父亲的自觉……
					CASE 2
						PRINTFORMDW 
						PRINTFORMDW 当三个人都安静入睡时……有一个影子悄悄溜进了房间
						PRINTFORMDW 
						CALL PRINT_FACE, [[豊姫]], "笑顔", "服", "", ""
						CALL M_KOJO_COLOR_K99
						PRINTFORML 「呵呵，她们睡得很香啊」
						PRINTFORMW 「放心吧。你们的记录我会认真保存的♪」
						PRINTFORMDW 这是一个因为过于痴迷于妹妹而变得疯狂的姐姐的样子
						PRINTFORMDL 当然，没有人知道这件事
						PRINTFORMDW 丰姬的私人房间里，有一个隐藏房间，墙上贴满了妹妹的照片……
						PRINTFORMW 「啊……好可爱啊……简直想吃掉她……」
						PRINTFORMDL 尽管会被人鄙视为偷窥狂，但我不在乎
						PRINTFORMDW 丰姬认真地相信这就是我的爱。
						PRINTFORMDL ……………
						PRINTFORMDL ………
						PRINTFORMDW …
						RESETCOLOR
						;昨日はよく眠れなかったフラグON
						CFLAG:MASTER:徹夜 = 1
				ENDSELECT
		ENDSELECT
	;通常
	ELSE
		;恋慕
		IF TALENT:恋慕
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「今天也辛苦了」
					PRINTFORMDW %CALLNAME:TARGET%关闭灯光，离开了房间。
				CASE 1
					PRINTFORML 「那么，我也要去巡视了」
					PRINTFORMDW %CALLNAME:TARGET%向这边鞠躬一礼，然后离开了。
				CASE 2
					PRINTFORML 「不要熬夜太晚哦」
					PRINTFORML 「我会过一会儿去看看你的」
					PRINTFORMDW 你像母亲一样和%CALLNAME:TARGET%挥手道别，让她离开了。
			ENDSELECT
		;其他情况
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「那么，我也要走了」
					PRINTFORMDW %CALLNAME:TARGET%站起身，离开了房间。
				CASE 1
					PRINTFORML 「不铺被子就睡觉……」
					PRINTFORML 「……没办法呢」
					PRINTFORMDW %CALLNAME:TARGET%从衣柜里拿出毛毯，轻轻地给你盖上，你发出轻微的呼噜声……
				CASE 2
					PRINTFORML 「和我一起睡吗？」
					PRINTFORML 「拒绝了。如果你一定要这么说，我会为你找个替代的人」
					PRINTFORMDW 如果被安排和玉兔的老头睡在一起，那就麻烦了。你决定老实地睡觉。
			ENDSELECT
		ENDIF
	ENDIF
ENDIF
RETURN 1
