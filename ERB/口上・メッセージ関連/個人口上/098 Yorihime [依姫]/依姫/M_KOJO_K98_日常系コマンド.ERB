IF LOCAL
	;睡眠中
	IF CFLAG:睡眠
		PRINTFORML 
		RETURN 1
	;通常
	ELSE
		;恋慕
		IF TALENT:恋慕
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「差不多该去看看兔子们的情况了」
					PRINTFORML 「你请休息吧。我很快就回来」
					PRINTFORMDL 当%CALLNAME:TARGET%放下空杯，朝练习场走去
					PRINTFORMDW 对她来说可能是理所当然的，但管理职位确实很辛苦啊……
				CASE 1
					PRINTFORMDL 你和%CALLNAME:TARGET%玩了一会儿%TEXTR("黑白棋/象棋/围棋/")%
					PRINTFORML 「唔……应该是这样了吧……/比赛结束了吧」
					PRINTFORMDW 看起来%CALLNAME:TARGET%也很开心。下次再约吧
				CASE 2
					PRINTFORMDL 即使是休息时间，%CALLNAME:TARGET%也不会放松训练
					PRINTFORML 「呼……」
					PRINTFORMDL 结束了挥拳练习的%CALLNAME:TARGET%擦了擦汗
					PRINTFORMDW 突然对视了一眼。你轻轻挥手回应了%CALLNAME:TARGET%的微笑
			ENDSELECT
		;思慕
		ELSEIF TALENT:思慕
			SELECTCASE RAND:3
				CASE 0
					PRINTFORMDL 闲着无聊，你和%CALLNAME:TARGET%下了一盘棋
					PRINTFORML 「听说姐姐有时也会和兔子们一起下棋」
					PRINTFORML 「据说是连胜连败。嗯，对姐姐来说当然是理所当然的」
					PRINTFORMDW ――%TEXTR("谢谢/输了")%。真是一场激烈的战斗……
				CASE 1
					PRINTFORML 「请休息吧。我去给你泡茶」
					PRINTFORMDL 你一边说着，一边坐下来。%CALLNAME:TARGET%拿着茶和点心过来了
					PRINTFORMDW 真是周到。真希望妹妹也能这样
				CASE 2
					PRINTFORMDL 你们并排休息，%CALLNAME:TARGET%靠了过来
					PRINTFORML 「……呼……呼……」
					PRINTFORMDW ……让她稍微睡一会吧
			ENDSELECT
		;其他
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「呼！ 呼！」
					PRINTFORMDL %CALLNAME:TARGET%专注地挥动剑进行素振
					PRINTFORMDW 嗯，只要能换换心情就好了……
				CASE 1
					PRINTFORML 「什么都不做，只是休息身体。感觉好像在浪费时间」
					PRINTFORML 「――那我们来玩吧？ 为什么会这样呢……」
					PRINTFORMDW %CALLNAME:TARGET%叹了口气。这样下去，她迟早会崩溃的
				CASE 2
					PRINTFORML 「――姐姐让我休息？」
					PRINTFORML 「唉……那就让我稍微替你工作一下吧」
					PRINTFORMDW 你完全理解她的想法，却无话可说
			ENDSELECT
		ENDIF
	ENDIF
ENDIF
RETURN 1
