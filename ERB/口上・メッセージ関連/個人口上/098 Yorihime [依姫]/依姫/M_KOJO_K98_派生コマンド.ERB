;==================================================
@M_KOJO_POWERED_BY_OVERSEAS_MESSAGE_MESSAGECHECK_SCOM_K98_9
RETURN 0

@M_KOJO_POWERED_BY_OVERSEAS_MESSAGE_SCOM_K98_9
CALL M_KOJO_POWERED_BY_OVERSEAS_MESSAGE_SCOM_K98_9_1
RETURN 1

;一人目口上
@M_KOJO_POWERED_BY_OVERSEAS_MESSAGE_SCOM_K98_9_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	LOCAL = MASTER_POSE(4,1,1)
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(TFLAG:50 + 500)
		PRINTFORMW 
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		PRINTFORMW 
		RETURN 1
	;相方が豊姫
	ELSEIF LOCAL == 99
		;依姫と豊姫が恋慕
		IF TALENT:98:恋慕 && TALENT:99:恋慕
			;あなたが射精した
			IF NOWEX:MASTER:射精
				SELECTCASE RAND:3
					CASE 0
						PRINTFORMDL 豊姬和依姬热情地侍奉着阴茎。
						PRINTFORMDL 当无法忍耐时，精液喷洒在她们的脸上。
						CALL M_KOJO_POWERED_BY_OVERSEAS_COLOR_K98
						CALL HPH_PRINT,@"「啊，热……HPH」","L"
						CALL HPH_PRINT,@"「啊啊，太可惜了……嗯……嗯……HPH」","L"
						CALL M_KOJO_COLOR_K99
						PRINTFORMDW 依姬把精液从脸上舔掉，而豊姬则直接品尝着精液……
						RESETCOLOR
					CASE 1
						PRINTFORMDL 由于太过舒服，你在事先警告她们之前就射精了。
						CALL M_KOJO_POWERED_BY_OVERSEAS_COLOR_K98
						CALL HPH_PRINT,@"「嗯布HPH——HPH 咕布HPH 咯布HPH」","L"
						CALL M_KOJO_COLOR_K99
						CALL HPH_PRINT,@"「嘿嘿，冷静点……HPH 嗯……嘟……HPH」","L"
						PRINTFORMDW 豊姬一边抚摸着依姬的背，一边将她无法吞下的精液传给她口中……
						RESETCOLOR
					CASE 2
						CALL HPH_PRINT,@"「嗯热咯……咯……HPH 嗯布……嘟……HPH」","L"
						CALL HPH_PRINT,@"「哈……哈布……HPH 嗯……热咯……HPH」","L"
						PRINTFORMDL 两人一边用舌头舔着阴茎，一边向你投以催促的目光。
						PRINTFORMDW 当你说『再稍微一点』时，两人已经等不及，用手揉捏着睾丸……
				ENDSELECT
			;それ以外
			ELSE
				SELECTCASE RAND:3
					CASE 0
						CALL M_KOJO_COLOR_K99
						CALL HPH_PRINT,@"「依姬，让我们一起侍奉……HPH」","L"
						CALL M_KOJO_POWERED_BY_OVERSEAS_COLOR_K98
						CALL HPH_PRINT,@"「好的……姐姐……HPH 嗯……嘴唇……嘟……HPH 嘴巴……嘟……HPH」","L"
						PRINTFORMDL 两人手牵手面对面，舌头舔舐着你的阴茎。
						PRINTFORMDW 你放松身体，将自己交给她们的侍奉。
						RESETCOLOR
					CASE 1
						CALL M_KOJO_POWERED_BY_OVERSEAS_COLOR_K98
						CALL HPH_PRINT,@"「嗯呼……哈……HPH 热烘烘的……有点味道……HPH」","L"
						CALL M_KOJO_COLOR_K99
						CALL HPH_PRINT,@"「是的，真的……HPH 嗯……吮吸……嘟……HPH 嘟嘟嘟，嗯咕……HPH」","L"
						PRINTFORMDL 两人围绕着竖立的肉棒，发出啜吸的声音。
						PRINTFORMDW 两只兽正在贪婪地吞噬着你的肉体。
						RESETCOLOR
					CASE 2
						CALL M_KOJO_COLOR_K99
						CALL HPH_PRINT,@"「这里也要照顾到……嗯……HPH」","L"
						CALL M_KOJO_POWERED_BY_OVERSEAS_COLOR_K98
						CALL HPH_PRINT,@"「嗯呼……嗯咕……HPH 嗯呼……哈呼……HPH」","L"
						PRINTFORMDL 两人将脸埋在你的下体，友好地分享着睾丸。
						PRINTFORMDW 你掩住脸，努力忍住自己的欲望。
						RESETCOLOR
				ENDSELECT
			ENDIF
		;それ以外
		ELSE
			;あなたが射精した
			IF NOWEX:MASTER:射精
				SELECTCASE RAND:3
					CASE 0
						CALL M_KOJO_COLOR_K99
						CALL HPH_PRINT,@"「看吧……%CALLNAME:MASTER%，你的表情好像要射精了呢……？HPH」","L"
