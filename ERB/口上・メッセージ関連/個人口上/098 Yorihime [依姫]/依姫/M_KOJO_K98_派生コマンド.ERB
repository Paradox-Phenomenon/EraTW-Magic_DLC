						PRINTFORMDL 为了不在铃仙2号面前暴露丑态，依姬拼命地压制住声音
						CALL M_KOJO_POWERED_BY_OVERSEAS_COLOR_K100
						CALL HPH_PRINT,@"「咕噗咕噗，好厉害的声音……依姬大人，感觉舒服吗……？HPH」","L"
						PRINTFORMDW 被问到。是这样想的吗？依姬的阴道更加紧缩了一下
						RESETCOLOR
					CASE 2
						CALL M_KOJO_POWERED_BY_OVERSEAS_COLOR_K100
						CALL HPH_PRINT,@"「啊啊HPH 呼呼HPH 进、进得很深……」","L"
						CALL M_KOJO_POWERED_BY_OVERSEAS_COLOR_K98
						CALL HPH_PRINT,@"「呼……呼……HPH 呼吸……呼……」","L"
						PRINTFORMDL 在让依姬休息的时候，感受着铃仙2号阴道的触感
						PRINTFORMDW 虽然还不够成熟，但铃仙2号的阴道能够牢牢地感知到雄性，并将粘膜缠绕在一起……
						RESETCOLOR
				ENDSELECT
			ENDIF
		ENDIF
	ENDIF
