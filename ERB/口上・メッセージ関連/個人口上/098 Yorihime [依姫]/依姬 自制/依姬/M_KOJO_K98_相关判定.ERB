;口上存在判定
@M_KOJO_K98(ARG)
RESULTS = _STELLARIS
RESULTS:1 = 国人自制
RESULTS:2 = 自设严重OOC，请谨慎选择，与国人自制丰姬口上有联动<br>龟速更新日常系，事件系中<br>含有特殊选项（详情查阅Update）<br>内容量超多（有效输出行：21525行）
RETURN 1
;口上基本設定
@M_KOJO_STELLARIS_FLAGSETTING_K98

CFLAG:98:眠姦口上有 = 1
CFLAG:98:時間停止口上有 = 1
;不会逆推
IF TALENT:恋人 || TALENT:愛欲 || TALENT:恋慕 || TALENT:炮友
	CFLAG:98:377 = 0
ELSE
	CFLAG:98:377 = 1
ENDIF
;初始化变量 优先级很高，会在加载存档前完成
IF FIRSTTIME("初始化变量")
	;在这里初始化开局选项，确保进入自设选单
	CFLAG:98:1221 = 1
ENDIF
;世界线跳跃
SIF CFLAG:99:1221 == 1 && CFLAG:99:1984 != 2
	CFLAG:98:1221 = 1
;体力判定
IF TIME >= 600 && TIME <= 720 || TIME >= 1260 && TIME <= 1380
	BASE:0 = MAXBASE:0
	BASE:1 = MAXBASE:1
ENDIF
;睡眠判定
IF CFLAG:98:1221 == 1
	IF DAY:3 == 17
		CFLAG:98:就寝時間 = 0
		CFLAG:98:起床時間 = 1440
	ELSE
		CFLAG:98:就寝時間 = 0
		CFLAG:98:起床時間 = 30
	ENDIF
ELSE
	PRINTL
ENDIF
RETURN 1
;口上色判定
@M_KOJO_STELLARIS_COLOR_K98
SETCOLOR 238, 130, 238
