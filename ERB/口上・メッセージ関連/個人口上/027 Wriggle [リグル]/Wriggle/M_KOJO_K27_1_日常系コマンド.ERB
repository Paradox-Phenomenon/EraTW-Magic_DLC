;==================================================
;Study
;412,勉強
;ABL:教養(ABL:MASTER:教養より大=MASTERが教えてもらう ABL:MASTER:教養より小=TARGETが教えてもらう
;==================================================
@M_KOJO_EN01_MESSAGE_COM_K27_412
CALL M_KOJO_EN01_MESSAGE_COM_K27_412_1
RETURN RESULT

@M_KOJO_EN01_MESSAGE_COM_K27_412_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF ABL:MASTER:教養 > ABL:TARGET:教養
		SELECTCASE IFRAND("0TO3", ABL:TARGET:教養 < 3, "4", ABL:TARGET:教養 < 3 && FIRSTTIME("WriggleInterrogatesTheTextFromTheWrongPerspective", 1), "5", ABL:TARGET:教養 < 3 && ONCE("WriggleCelebrationbug", 1), "6TO8", 1)
			CASE 0
				PRINTFORML 「And... done!」
				PRINTFORMDW Wriggle finishes the last stroke with a flourish.
				IF FIRSTTIME("WriggleWritebug")
					PRINTFORMW 「I did it! I wrote the kanji for "bug"!」
					PRINTFORMW 「How many more kanji are there?」
					PRINTFORMW 「...47,000?!」
					PRINTFORMDW Wriggle's jaw drops.
					PRINTFORMW 「That's gotta be more than all the bugs in the world!」
					PRINTFORMW 「How does anyone learn how to write?!」
					PRINTFORMW 「...Oh, you don't need to know all of them?」
					PRINTFORMW 「...Just 2000?! That's still more than all the bugs in the world!」
					PRINTFORMW 「Can't I just write in kana? "Bug"'s the most important kanji anyway!」
				ENDIF

			CASE 1
				PRINTFORML 「C'mon, c'mon... how do I write that?!」
				PRINTFORMW 「I can't let Tewi steal all my customers!」

			CASE 2
				PRINTFORMW 「Maybe I should take the weights off my brush...」

			CASE 3
				PRINTFORMW 「I got the stroke order wrong?」
				PRINTFORMDW Wriggle sighs.
				PRINTFORMW 「I'll never remember all this stuff...」

			CASE 4
				PRINTFORML 「What the heck?!」
				PRINTFORMDW Wriggle frowns and holds the manga closer to %HIS_HER([[リグル]])% face.
				PRINTFORMW 「I don't recognize any of these characters! Not even one!」
				PRINTFORMW 「And I know my hiragana! Is this even in Japanese?!」
				PRINTFORMDW You take the manga from %HIM_HER([[リグル]])%, turn it upside down, and hand it back to %HIM_HER([[リグル]])%.
				PRINTFORMW 「...Oh.」
				PRINTFORMDW Wriggle grimaces.
				PRINTFORMW 「Yeah, now I can read it. Let's see...」
				PRINTFORMW 「"Ah... busy busy busy. Sheesh... the"... um... something about flowers?」
				PRINTFORMDW Wriggle keeps reading the manga.
				CALLF FIRSTTIME("WriggleInterrogatesTheTextFromTheWrongPerspective")

			CASE 5
				PRINTFORMW 「Okay, done!」
				PRINTFORMDW Wriggle holds up the paper triumphantly. %HES_SHES([[リグル]],1)% written the kanji for 1 through 10.
				PRINTFORMW 「...It looks good? Awesome! I'm making progress!」
				PRINTFORMW 「This calls for a celebration! Wanna hit Misty's when we're done? My treat.」
				PRINTFORMW 「And I'm gonna read every word on the menu!」
				CALLF ONCE("WriggleCelebrationbug")

			CASE 6
				PRINTFORMW 「"If I have nine bugs on my left shoulder, and one third of them move to my head, how many bugs are still on my shoulder?"」
				PRINTFORMW 「Hmm...」
				PRINTFORMDW Wriggle nibbles the tip of her brush as %HE_SHE([[リグル]])% thinks.

			CASE 7
				PRINTFORMW 「Okay... "If there are ten fireflies on my left shoulder and twelve fireflies on my right shoulder, how many are there in total?"」
				PRINTFORML 「Let's see... one, two, three, four...」
				PRINTFORMDW Wriggle counts on %HIS_HER([[リグル]])% fingers until %HE_SHE([[リグル]])% hits ten.
				PRINTFORML 「Darn. Okay, guys, I need a little he-」
				PRINTFORMW %BREAKENG(@" 「Oh come on, that's not cheating! If there were fireflies on my shoulders and I wanted to know how many there were, I'd just count 'em!」")%

			CASE 8
				PRINTFORMW 「I wish %CHAN_KUN([[チルノ]])% was here to help. She's better at math than the rest of us put together!」
				PRINTFORMW 「She can even count to 100! Before I saw her do it, I didn't even know that numbers went that high!」

		ENDSELECT
	ENDIF

ENDIF
RETURN 1
