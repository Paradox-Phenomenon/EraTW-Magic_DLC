				PRINTFORMW 「%K27_MASTER()%... my whole body is on fire. And it gets worse every time you touch me.」
				PRINTFORMW 「I need you to mate with me. Please...」
			ELSEIF TALENT:[[リグル]]:恋人
				PRINTFORMW 「Mmm...」
				PRINTFORMDW Wriggle interlaces %HIS_HER([[リグル]])% fingers with yours.
				PRINTFORMW 「I forget a lot of stuff... but one thing I'm never gonna forget is how nice it feels to hold hands with you.」
				CALL HPH_PRINT, @"「Every time I do, I swear I fall in love with you all over againHPH」", "W"
			ELSEIF TALENT:[[リグル]]:セフレ || TALENT:[[リグル]]:愛欲
				PRINTFORML 
			ELSEIF TALENT:[[リグル]]:思慕 || TALENT:[[リグル]]:恋慕
				PRINTFORMW 「Ehehe...」
				PRINTFORMDW （My butt isn't glowing, is it?）
				PRINTFORMDL Wriggle tries to lean back far enough to look behind %HIM_HER([[リグル]])%-
				PRINTFORMW 「Wah!」
				PRINTFORMDW Wriggle stumbles and almost falls over. You catch %HIM_HER([[リグル]])% in your arms before she does.
				PRINTFORMW 「Ah! Thanks, %K27_MASTER()%!」
				PRINTFORMDW （Aww man... I should've done a backward somersault or something. Now %K27_MASTER()%'s gonna think I'm a dork!）
			ELSE
				PRINTFORMW 「Ehehe...」
				PRINTFORMDW （Why does this make me so excited? It's not like my hands are erogenous zones.）
				PRINTFORMDW （...Maybe %K27_MASTER()%'s hands are? I dunno much about how \@ !IS_NONHUMAN(MASTER) ? humans work... # %HIS_HER(MASTER)% species works...\@）
			ENDIF

		CASE 0
			IF IN_HEAT([[リグル]])
				SELECTCASE RAND:3
					CASE 0
						PRINTFORMW 「No... here...」
						PRINTFORMDW Wriggle moves your hand onto %HIS_HER([[リグル]])% crotch.
					CASE 1
						PRINTFORMDW Are you taking me... to a bedroom?
					CASE 2
						PRINTFORML 「Haaanh...」
						PRINTFORMDW The sweet smell filling the air grows stronger.
				ENDSELECT
			ELSEIF TALENT:[[リグル]]:恋人
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「Oh? Are you trying to lead me somewhere?」
						CALL HPH_PRINT, @"「You should know by now that I'll go an-y-where you wantHPH」", "W"

					CASE 1
						PRINTFORML 「You can squeeze my hand a little tighter, if you want.」
						PRINTFORMW 「Or a lot tighter...」

					CASE 2
						PRINTFORMDW A few curious fireflies swarm around you as you hold hands.
						PRINTFORMW 「%K27_MASTER()%, look! They're doing it too!」
						PRINTFORMDW You take a closer look. Sure enough, the fireflies have their forelimbs intertwined.
						PRINTFORMDW Wriggle grins.
						PRINTFORML 「They told me that they saw how happy I am when I hold hands with you and wanted to give it a try.」
						CALL HPH_PRINT, @"「Ehehe, we've started a trendHPH」", "W"

				ENDSELECT
			ELSEIF TALENT:[[リグル]]:セフレ || TALENT:[[リグル]]:愛欲
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 
					CASE 1
						PRINTFORML 
					CASE 2
						PRINTFORML 
				ENDSELECT
			ELSEIF TALENT:[[リグル]]:思慕 || TALENT:[[リグル]]:恋慕
				SELECTCASE RAND:3
					CASE 0
						PRINTFORMDW （I hope %HE_SHE(MASTER)% likes how my hands feel.）
						PRINTFORMDW （Maybe I should've taken those spittlebugs up on their offer...）

					CASE 1
						PRINTFORMDW Wriggle slowly interlaces %HIS_HER([[リグル]])% fingers with yours.
						PRINTFORMDW （Yes! %HES_SHES(MASTER)% not pulling away!）
						PRINTFORMDW （Another victory for the great %NAME:[[リグル]]%!）

					CASE 2
						PRINTFORMW 「Your hands are so warm...」
						PRINTFORMW 「And just touching them makes my whole body feel warm! Is that your ability?!」
				ENDSELECT
			ELSE
				SELECTCASE RAND:3
					CASE 0
						PRINTFORMDW Wriggle squeezes your hand. You squeeze back.
						PRINTFORMW 「You can squeeze harder, if you want...」
						PRINTFORMDW Why does %HE_SHE([[リグル]])% sound so excited?

					CASE 1
						PRINTFORML 「Wow, your carapace is really soft...」
						PRINTFORMW 「Wait, no, \@ !IS_NONHUMAN(MASTER) ? humans # you guys\@ don't have those.」
						PRINTFORMDW Wriggle looks a little embarrassed.

					CASE 2
						PRINTFORMW 「What, do you think I'm gonna get lost or something?」
						PRINTFORMW 「C'mon, %K27_MASTER()%! I'm dumb, but not that dumb!」

				ENDSELECT
			ENDIF

		CASE -1
			IF IN_HEAT([[リグル]])
				PRINTFORMW 「Ghh... stop teasing me!」
			ELSEIF TALENT:[[リグル]]:恋人
				PRINTFORMW 「Sorry, %K60_MASTER()%... but a bug just landed on my hand.」
			ELSEIF TALENT:[[リグル]]:セフレ || TALENT:[[リグル]]:愛欲
				PRINTFORML 
			ELSEIF TALENT:[[リグル]]:思慕 || TALENT:[[リグル]]:恋慕
				PRINTFORMDL （Oh no... my hand's all sweaty...）
				PRINTFORMDW Wriggle quickly lets go of your hand.
				PRINTFORMDW （Crap crap crap! Now %HES_SHES(MASTER)% gonna think I'm rude!）
				PRINTFORMW 「Um, uh... I didn't want to mess your skin up, 'cause it's so nice, so I let go of your hand, and...」
			ELSE
				PRINTFORMW 「Hey, I need both hands free!」
				PRINTFORMW 「What if a bad guy tries to mess with us?」
			ENDIF
	ENDSELECT

ENDIF
RETURN 1

