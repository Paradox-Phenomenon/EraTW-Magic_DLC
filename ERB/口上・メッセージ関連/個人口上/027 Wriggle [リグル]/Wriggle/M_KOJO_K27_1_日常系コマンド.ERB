	SELECTCASE TFLAG:193
		CASE -2
			SELECTCASE IFRAND("0TO2", 1, "3", TALENT:[[リグル]]:恋慕)
				CASE 0
					PRINTFORMDW Wriggle thinks for a moment.
					PRINTFORML 「Can I have the cake even if I don't forgive you?」
					PRINTFORMDW ...No.
					PRINTFORMDW Wriggle seems conflicted... but then %HE_SHE([[リグル]])% folds her arms and glares at you.

				CASE 1
					PRINTFORML 「The great %NAME:[[リグル]]% cannot be bribed!」
					PRINTFORMW 「Not even with cake!」
					PRINTFORMDW Wriggle doesn't sound very confident...

				CASE 2
					PRINTFORML （Nnn....）
					PRINTFORMW （Be strong, Wriggle! A true hero always follows the path of justice!）
					PRINTFORMDW It doesn't look like %HES_SHES([[リグル]])% going to accept your cakes.

				CASE 3
					PRINTFORML 「%CALLNAME:MASTER%, I don't want cake... I want a sincere apology.」
					CALL PRINT_STRW, @"「...But a sincere apology @ITALIC@and@ cake would be nice.」"

			ENDSELECT

		CASE -1
			SELECTCASE IFRAND("0TO2", 1, "3", TALENT:[[リグル]]:恋慕)
				CASE 0
					CALL PRINT_STRL, @"「Wait... you did @ITALIC@what@?!」"
					PRINTFORMDW Wriggle glares at you.
					PRINTFORMW 「I totally forgot all about that! Now I'm really mad!」

				CASE 1
					PRINTFORMW 「No way! Apologize like you mean it and maybe I'll forgive you.」

				CASE 2
					PRINTFORMW 「It'll take more than some half-hearted apology to win the forgiveness of the great %NAME:[[リグル]]%!」

				CASE 3
					PRINTFORMDL Wriggle sighs.
					PRINTFORMW 「I wanna forgive you, but... I don't think you really mean it.」

			ENDSELECT

		CASE 0
			SELECTCASE IFRAND("0TO2", 1, "3", TALENT:[[リグル]]:恋慕)
				CASE 0
					PRINTFORML 「The great %NAME:[[リグル]]% has decided to forgive you.」
					PRINTFORMW 「...For now.」
					PRINTFORMDW Wriggle chuckles ominously.

				CASE 1
					CALL PRINT_STRL, @"「Oh, @ITALIC@that's@ why I was mad at you!」"
					PRINTFORMW 「Sure, I forgive you. Just don't do it again, okay?」

				CASE 2
					PRINTFORML 「I guess it wasn't that bad...」
					PRINTFORMW 「Okay, I forgive you.」

				CASE 3
					PRINTFORMW 「I forgive you... but you gotta take me on a nice date tomorrow!」
			ENDSELECT


		CASE 1
			SELECTCASE IFRAND("0TO2", 1, "3", TALENT:[[リグル]]:恋慕)
				CASE 0
					PRINTFORMW 「Aw... I can't stay mad at you when you make that face.」

				CASE 1
					CALL PRINT_STRW, @"「Well, after @ITALIC@that@ I can't @ITALIC@not@ forgive you.」"

				CASE 2
					PRINTFORMW 「Whoa...」
					PRINTFORMW 「I dunno what all those big words mean, but you did call me "the great %NAME:[[リグル]]%".」
					PRINTFORMW 「So I forgive you.」

				CASE 3
					PRINTFORMDL Wriggle gives you a hug.
					PRINTFORMW 「I love you too much to stay mad at you.」

			ENDSELECT

		CASE 2
			SELECTCASE RAND:3
				CASE 0
					PRINTFORMW 「Whoa! A whole cake?! For me?!」
					PRINTFORMDL Wriggle snatches the cake out of your hands.
					PRINTFORMDW Then %HE_SHE([[リグル]])% realizes what %HES_SHES([[リグル]])% doing, blushes, hands it back to you, and gently takes it out of your hands.

				CASE 1
					PRINTFORML 「Honestly, I don't even remember why I was mad at you.」
					PRINTFORMW 「But I'll never say no to free cake!」

				CASE 2
					PRINTFORMW 「Whoa... is that for me?」
					PRINTFORMDW Wriggle looks like %HES_SHES([[リグル]])% starting to drool.
					PRINTFORMW 「Huh? Oh yeah, sure, I forgive you.」
			ENDSELECT
	ENDSELECT
ENDIF
RETURN 1
