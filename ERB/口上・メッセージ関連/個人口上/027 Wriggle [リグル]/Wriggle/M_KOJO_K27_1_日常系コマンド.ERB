					ENDSELECT
				ELSEIF TALENT:[[リグル]]:セフレ || TALENT:[[リグル]]:愛欲
					SELECTCASE RAND:3
						CASE 0
							PRINTFORML 
						CASE 1
							PRINTFORML 
						CASE 2
							PRINTFORML 
					ENDSELECT
				ELSEIF TALENT:[[リグル]]:思慕 || TALENT:[[リグル]]:恋慕
					SELECTCASE RAND:3
						CASE 0
							PRINTFORMW 「You wanna mate again? Sure, gimme one sec...」
							PRINTFORMDW Wriggle raises %HIS_HER([[リグル]])% voice.
							PRINTFORMW 「Guys? I'd like some privacy, please!」
							PRINTFORMDW You see something skitter across the floor out of the corner of your eye.
							PRINTFORMW 「Ah... that's better. Regular bugs might be fine mating with an audience around, but youkai bugs like me aren't!」

						CASE 1
							PRINTFORML 「Oh nooo～ I've been overpowered by \@ IS_NONHUMAN(MASTER) ? %CALLNAME:MASTER%～ # a mere human～\@」
							PRINTFORMDW Wriggle tries and fails to keep %HIS_HER([[リグル]])% grin off %HIS_HER([[リグル]])% face.
							PRINTFORMW 「Ah, I'll never live this down! If only %HE_SHE(MASTER)% wasn't so cute, then I'd be able to fight %HIM_HER(MASTER)% off～」

						CASE 2
							PRINTFORMW 「Hehe... I knew all that teasing would pay off!」
							PRINTFORMW 「And thank goodness for that. I was about to snap and push you down myself...」

					ENDSELECT
				ELSE
					SELECTCASE RAND:3
						CASE 0
							PRINTFORMW 「I guess it's mating season for you, huh?」
							PRINTFORMW 「Well, I don't mind giving you a hand with that. I know just how hard it is to go through that without a partner...」

						CASE 1
							PRINTFORMW 「Wow, you must be really pent up...」
							PRINTFORMW 「If you need me to take care of your urges, I'm fine with that.」
							PRINTFORMW 「The great %NAME:[[リグル]]% is always willing to help %HIS_HER([[リグル]])% friends out!」

						CASE 2
							PRINTFORMW 「Oh, you wanna do it again? Sure thing!」
							PRINTFORMW （Does this mean %HE_SHE(MASTER)% likes me? Oh man... I've got butterflies in my stomach!）
					ENDSELECT
				ENDIF

		ENDSELECT

	ENDIF
ENDIF
