;MARK:反発刻印(3以上=会話不能)(4以上はバグ
;TCVAR:泥酔(1=通常成功or大失敗)
;==================================================
@M_KOJO_EN01_SUCCESS_COM_K27_300
;成否判定
;TFLAG:192(-2=コマンド終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

@M_KOJO_EN01_MESSAGE_COM_K27_300
;コマンド共通メッセージ(TRAIN_MESSAGE) 
;削除すると「～話をした。」とかが消えます。また、削除した場合は自動で口上色が付きません。
;口上メイン呼出
CALL M_KOJO_EN01_MESSAGE_COM_K27_300_1
RETURN RESULT

@M_KOJO_EN01_MESSAGE_COM_K27_300_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF TFLAG:193 > -1
		IF TCVAR:泥酔
			SELECTCASE RAND:6
				CASE 0
					PRINTFORMW 「Why'sh everythin' spinnin'?」
					PRINTFORMW 「'S rude. Tell 'em to make it stop.」
					PRINTFORMW 「'S makin' me feel sick...」
				CASE 1
					PRINTFORMW 「Hehe... thish is way better 'n fermented fruit!」
				CASE 2
					PRINTFORMDW Wriggle grins drunkenly at you.
					PRINTFORMW 「H-Hey, %CALLNAME:MASTER%, your clothes look kinda... uh...」
					PRINTFORMDW %HE_SHE([[リグル]],1)% concentrates.
					PRINTFORMW 「I think you'd look better without 'em. If ya know what I mean...」
				CASE 3
					PRINTFORMW 「Woo! C'mon, next round's on me!」
					PRINTFORMW 「...Crap, I don' have any money.」
					PRINTFORMW 「%CALLNAME:MASTER%, ya got any? I'll pay ya back, promishe...」
				CASE 4
					SELECTCASE RAND:5
						CASE 0
							PRINTFORMW 「"I know, I know the shun ish hot♪"」
							PRINTFORMW 「"Moshquitoes come, suck y'blood♪"」
						CASE 1
							PRINTFORMW 「"Beetlesh, under m'carpet, under m'feet♪"」
							PRINTFORMW 「"Somethin' somethin' somethin' heat♪"」
						;Glass by C-CLAYS
						CASE 2
							PRINTFORMW 「"Summer'sh end passes by peashefully♪」
							PRINTFORMW 「"Th'plumes of th'grash laugh♪」
						;I Wouldn't Mind Not Being Able to Fly Through the Sky by IOSYS
						CASE 3
							PRINTFORMW 「"'F these wings th'let me fly ever got n'my way♪"」
							PRINTFORMW 「"Wouldn' mind not bein' able t'fly again♪"」
						;Stirring an Autumn Moon fanlyrics by lyricalive
						CASE 4
							PRINTFORMW 「"Wha'sh goin' on? Blink an' ish gone♪"」
							PRINTFORMW 「"Why somethin' somethin' can't use♪"」
					ENDSELECT
					PRINTFORMDW Wriggle is singing off-key.
				CASE 5
					PRINTFORMW 「Wha? 'M not drunk, I just gotta nice buzz goin'!」
					PRINTFORMW 「Geddit? Buzz? Cause I'm an insect?」
					PRINTFORMDW Wriggle starts giggling drunkenly.
			ENDSELECT
			RETURN 1
		ELSEIF CHK_DATENOW(CFLAG:TARGET:デート中)

			SELECTCASE RAND:3
				CASE 0
					SELECTCASE CFLAG:MASTER:現在位置 / 100

						CASE 0 ;Hakurei Shrine
							SELECTCASE RAND:3
								CASE 0
									PRINTFORMDW Wriggle bites %HIS_HER([[リグル]])% lip.
									PRINTFORMW 「Uhh... are you sure it's safe here?」
									PRINTFORMW 「One time I came here for a festival, and the whole place caught on fire, just like that!」
									PRINTFORML 「I would've been toast if it hadn't started raining all of a sudden...」
									PRINTFORMW 「And I'm kinda worried it might happen again. Especially since I don't know why it happened the first time...」
								CASE 1
									PRINTFORMW 「Reimu-san started running a fortune-telling service here.」
									PRINTFORML 「I used to think it was all a scam...」
									PRINTFORMW 「But then one time Misty talked me into getting my fortune told, and it all came true!」
									PRINTFORMW 「Even the part about how if I didn't visit the shrine once a week, misfortune would befall me!」
									PRINTFORMDW Wriggle grimaces.
									PRINTFORMW 「I'm not making that mistake again. I make sure to donate at least once a week, no matter what!」
									PRINTFORMW 「We should get our fortunes told before we go.」
									PRINTFORMW 「I wonder if %HE_SHE([[リグル]])%'ll have anything to say about my love life...」
								CASE 2
									PRINTFORMW 「Weird stuff always happens at this shrine.」
									PRINTFORML 「One time, I was visiting for a festival, and all these palm trees showed up out of nowhere!」
									PRINTFORMW 「And it was winter, too!」
									PRINTFORMW 「But it wasn't all bad. I made friends with some giant palm borers that were living in those trees.」
									PRINTFORMW 「Maybe we'll get to meet some new insects today...」
							ENDSELECT

						CASE 1 ;Myouren Temple
							SELECTCASE RAND:3
								CASE 0
									PRINTFORMW 「Something really freaky happened to me the other day.」
									PRINTFORML 「I was heading home after helping Misty and Kyouko-san clean up the temple grounds...」
									PRINTFORMW 「When I looked up, and saw a glowing orange object in the sky, to the east!」
									PRINTFORMW 「It was zipping around in the sky, and then there was this intense light all around me!」
									PRINTFORMW 「The next thing I knew, I was home. Except my wallet was missing.」
									PRINTFORMDW Wriggle frowns.
									PRINTFORMW 「But that's the weirdest part. All the stuff in my wallet was in my pocket, but the wallet itself was gone.」
									PRINTFORMW 「Who the heck does that? Who steals somebody's wallet and leaves the money?」
									PRINTFORMDW %HE_SHE(TARGET,1)% shakes her head.
									PRINTFORMW 「Aliens are weird...」
									IF TALENT:41:恋人 && FIRSTTIME("NueStoleWrigglesWallet",1)
										PRINTFORMDW It looks like you're going to have to have a talk with Nue-chan about stealing other people's things...
										CALLF FIRSTTIME("NueStoleWrigglesWallet")
									ENDIF

								CASE 1
									PRINTFORML 「Misty told me that she read an article about this place in the Bunbunmaru a while back.」
									PRINTFORMW 「It said that when you're an important person in Buddhism, you can hit people with sticks.」
									IF TALENT:TARGET:恋慕 || MARK:TARGET:快楽刻印 == 3
										PRINTFORMW 「...Do you wanna roleplay that sometime?」
									ELSE
										PRINTFORMDW Wriggle's face is getting flushed...
									ENDIF

								CASE 2
									PRINTFORMW %BREAKENG(@"「Byakuren-san says that in Buddhism, monks shouldn't travel when it rains, because they might step on bugs on the road by mistake.」")%
									PRINTFORMW 「That's real nice of them! I wish more people were like that.」
							ENDSELECT

						CASE 2 ;Human Village
							SELECTCASE RAND:4
								CASE 0
									PRINTFORML 「Shouldn't I be wearing a disguise or something?」
									PRINTFORMW 「I don't wanna scare people.」

								CASE 1
									PRINTFORML 「I hope I don't run into that weird girl again.」
									PRINTFORMW 「Last time I met her, she tried to arrest me for vig... viggle... some complicated word.」
									PRINTFORMW 「And I bet she's not even a real police officer, anyway!」

								CASE 2
									PRINTFORMW 「You know Suzunaan? I made a deal with the lady there.」
									PRINTFORML 「I tell all my bookworm friends to eat the wood shavings from the furniture store instead of the books at Suzunaan...」
									PRINTFORMW 「And she'll help me practice reading every week!」
									PRINTFORMDW Wriggle grins.
									PRINTFORML 「The furniture shop guy isn't really happy about it, though.」
									PRINTFORMW 「Last time I saw him, he called me a bunch of rude names.」
									PRINTFORMDW %HE_SHE([[リグル]],1)% folds %HIS_HER([[リグル]])% arms and pouts.
									PRINTFORMW 「Stupid jerk. I should tell my friends to eat his furniture instead.」

								CASE 3
									PRINTFORML 「You know that bar, Geidontei? At night, they reopen it for youkai.」
									PRINTFORMW 「I've been there a couple times with Misty. Their sake is top notch!」
									IF TIME:2 <= 4 ;daytime
										PRINTFORML 「Maybe we should grab a drink there?」
										PRINTFORMW 「I hope I don't need to hide my antennae under a hat to get in...」
									ELSEIF !IS_NONHUMAN(MASTER)
										PRINTFORMW 「But you're a human, so you can't go...」
										PRINTFORMW 「Hey... what if we disguised you as a youkai?」
										PRINTFORMDW Wriggle giggles.
										PRINTFORMW 「I bet %CHAN_KUN([[チルノ]])% and Dai-chan would have a blast making a costume for you!」
									ENDIF
							ENDSELECT

						CASE 3 ;Scarlet Devil Mansion
							SELECTCASE RAND:5
								CASE 0
									PRINTFORMW 「Oh hey, this is where %CHAN_KUN([[チルノ]])% and Dai-chan live!」
									PRINTFORMW 「If we run into %CHAN_KUN([[チルノ]])%, %HE_SHE(14)%'ll probably challenge you to a Danmaku match.」
									PRINTFORMW 「...Go easy on %HIM_HER(14)%, okay? %HE_SHE(14,1)% hates to lose.」

								CASE 1
									PRINTFORMW 「I bet Patchouli-san has lots of cool books about bugs in her library!」
									PRINTFORMW 「But they won't let me into the Mansion. And even if I could, I probably wouldn't be able to read them.」

								CASE 2
									PRINTFORMW 「%CHAN_KUN([[チルノ]])%'s friend Letty-san lives around here, right?」
									PRINTFORML 「%HE_SHE(74,1)%'s real nice and all, but I try to stay away from %HIM_HER(74)%.」
									PRINTFORMW 「It's always so cold around %HIM_HER(74)%!」
									PRINTFORMW 「Which is weird, because I can stand %CHAN_KUN([[チルノ]])%'s cold just fine.」
									PRINTFORMW 「Maybe I just got used to it?」

								CASE 3
									PRINTFORMW 「Don't the Prismriver Sisters live around here?」
									PRINTFORMW 「One time they collaborated with me and my bug friends on a song!」
									PRINTFORMDW Wriggle beams at you.
									PRINTFORMW 「It was the coolest thing ever! Remind me to ask them to do it again for you sometime!」

								CASE 4
									PRINTFORMW 「You know Sakuya-san, the maid who works here?」
									PRINTFORMDW Wriggle glances around and lowers %HIS_HER([[リグル]])% voice.
									PRINTFORMW 「Tewi told me that %HES_SHES(15)% actually a Lunarian vampire hunter! From the Moon!」
									PRINTFORMW %BREAKENG(@"「And %HE_SHE(15)% came to the mansion to kill Remilia-san, but Remilia-san beat %HIM_HER(15)% and forced %HIM_HER(15)% to swear eternal loyalty!」")%
									PRINTFORMW 「And their fight was so violent, it destroyed all of Makai!」
									PRINTFORMDW Wriggle sighs dreamily.
									PRINTFORMW 「I wish I could've seen it...」
							ENDSELECT

						CASE 4 ;Bamboo Forest of the Lost
							SELECTCASE RAND:4
								CASE 0
									PRINTFORML 「Sometimes my friends and I hang out with Tewi when %HE_SHE(53)%'s not working.」
									PRINTFORMW 「%HE_SHE(53,1)% really funny, and %HE_SHE(53)% tells the craziest stories!」
									PRINTFORMDW Wriggle frowns.
									PRINTFORMW 「Just don't buy anything from %HIM_HER(53)%.」

								CASE 1
									PRINTFORML 「Misty's food cart should be around here somewhere.」
									PRINTFORMW 「You wanna get something?」

								CASE 2
									PRINTFORMDW You notice Wriggle is moving very slowly and staring at the ground.
									PRINTFORMDW You ask %HIM_HER([[リグル]])% if something's wrong.
									PRINTFORMW 「Hm? Oh, I'm just checking for snare traps.」
									PRINTFORMDW Snare traps? Around here? Why?
									PRINTFORMDW %HE_SHE([[リグル]],1)% sighs.
									PRINTFORMW 「It's a long story. Remind me to tell you when we head home.」

								CASE 3
									PRINTFORMW 「Did you know Eientei won't do cosmetic surgery?」
									PRINTFORMDW Wriggle frowns.
									PRINTFORMW 「I asked Eirin-san for an antennae extension once, and %HE_SHE(72)% said %HE_SHE(72)% didn't do them.」
									PRINTFORMW 「So then I asked %HIM_HER(72)% for a, um... \@ TALENT:[[リグル]]:バストサイズ > 1 ? reduction # enhancement\@, and %HE_SHE(72)% said %HE_SHE(72)% didn't do those either.」
									PRINTFORMDW %HE_SHE([[リグル]],1)% huffs.
									SIF (TALENT:72:バストサイズ < 2 && TALENT:[[リグル]]:バストサイズ > 1) || (TALENT:72:バストサイズ > 1 && TALENT:[[リグル]]:バストサイズ < 2)
										PRINTFORMW 「Easy for %HIM_HER(TARGET)% to say. %HE_SHE(72)% doesn't need \@ TALENT:[[リグル]]:バストサイズ < 2 ? one... # any...\@」
							ENDSELECT

						CASE 5 ;Forest of Magic
							SELECTCASE RAND:3
								CASE 0
									PRINTFORML 「My friends and I usually hang out at the Big Old Tree.」
									PRINTFORMW 「You wanna go there so they can say hi?」
								CASE 1
									PRINTFORML 「Do you mind if we stop by Kourindou?」
									PRINTFORMW 「Sometimes they have Outside World candy.」
								CASE 2
									PRINTFORML 「There's this really nice clearing not too far from here.」
									PRINTFORMW 「It's a great place for stargazing! We could go there, if you want.」
									IF TIME:2 <= 4 ;daytime
										PRINTFORMDW But it's daytime...
										PRINTFORMW 「No problem!」
										PRINTFORMDW Wriggle grins at you.
										PRINTFORMW 「We can just grab some food and have a picnic there.」
									ENDIF
							ENDSELECT

						CASE 6 ;Sanzu River
							SELECTCASE RAND:3
								CASE 0
									PRINTFORMW 「Hey... do you mind if I go off on my own for a little?」
									PRINTFORMDW Wriggle looks at you.
									PRINTFORMW 「It's just... bugs don't live very long, and I never got a chance to say goodbye to some of my friends...」
								CASE 1
									PRINTFORML 「Didn't the leaders of the Hell Mafia get into a huge fight not too long ago?」
									PRINTFORMW 「They were trying to conquer Gensokyo or something. At least, that's why I heard.」
									PRINTFORMDW Wriggle snorts.
									PRINTFORMW 「C'mon, everyone knows Gensokyo belongs to the bugs!」
								CASE 2
									IF FIRSTTIME("WriggleVsYuyuko")
										PRINTFORMW 「Yuyuko lives around here, right? The ghost lady?」
										PRINTFORMDW Wriggle clenches %HIS_HER([[リグル]])% fists.
										PRINTFORMW 「That jerk keeps trying to eat my best friend! C'mon, %K27_MASTER()%, I want you to watch me kick %HIS_HER(66)% butt!」
										PRINTFORMDW You spend the next few minutes calming Wriggle down...
									ELSE
										PRINTFORML 「Rrrgh... there's gotta be something I can do to teach Yuyuko not to mess with my friends!」
										PRINTFORMW 「Maybe I can send a swarm of ants to eat all %HIS_HER(66)% food?」
									ENDIF
							ENDSELECT

						CASE 7 ;Youkai Mountain (Foot)
							SELECTCASE RAND:3
								CASE 0
									PRINTFORMW 「That weirdo amanojaku lives around here, right?」
									PRINTFORMW 「Didja know %HE_SHE(97)% tried to get me to join %HIS_HER(97)% Яeverse Яevolution back in the day.」
									PRINTFORMW 「I told %HIM_HER(97)% I had no idea what a "Yaverse Yavolution" is.」
									PRINTFORMW 「Then %HE_SHE(97)% explained %HE_SHE(97)% was trying to overthrow society so the weak could overthrow the strong.」
									PRINTFORMDW Wriggle huffs.
									PRINTFORMW 「Who does %HE_SHE(97)% think %HE_SHE(97)% is, calling me weak?!」
									PRINTFORMW 「Maybe if we're talking Spell Card rules, but if I used my full power, I'd be the second-strongest person in Gensokyo!」
									PRINTFORMW 「...After %CHAN_KUN([[チルノ]])%, of course.」
									PRINTFORMW 「So I gave %HIM_HER(97)% a piece of my mind and chased %HIM_HER(97)% away!」
									PRINTFORMW 「And while %HE_SHE(97)% was running away, %HE_SHE(97)% had the nerve to call me a "delusional moron"!」
									PRINTFORMDW Wriggle folds %HIS_HER([[リグル]])% arms and scowls.
									PRINTFORMW %BREAKENG(@"「Well, I'm on a date with \@ TALENT:[[リグル]]:恋人 ? my awesome %PRINT_MALE("boy", MASTER)%friend # a super cute %PRINT_MALE("guy", MASTER)%\@, and %HES_SHES(97)% off sulking somewhere 'cause nobody likes %HIM_HER(97)%.」")%
									PRINTFORMW 「So who's the real moron?!」

								CASE 1
									PRINTFORMW 「I'm trying to save up some money so I can buy a little something from the kappa.」
									PRINTFORMW 「What is it? Um... promise you won't laugh?」
									PRINTFORMDW You promise.
									PRINTFORMW 「It's, well...」
									PRINTFORMDW Wriggle grins sheepishly and pokes the tips of %HIS_HER([[リグル]])% index fingers together.
									PRINTFORMW 「It's a portable fan that'll fit in my cape, so I can make it blow dramatically even when there isn't any wind...」

								CASE 2
									PRINTFORMW 「Kasen-san has loads of animals in %HIS_HER(TARGET)% house.」
									PRINTFORMW 「%HES_SHES(43,1)% got a dragon, a couple eagles, a raijuu, a tiger... but no bugs!」
									PRINTFORMDW Wriggle scowls.
									PRINTFORMW 「C'mon, what's wrong with bugs? They're cute! They're friendly!」
									CALL PRINT_STRL, @"「Someone should give @ITALIC@%HIM_HER(43)%@ a lecture about not being so close-minded.」"
							ENDSELECT

						CASE 8 ;Youkai Mountain (Summit)
							SELECTCASE RAND:3
								CASE 0
									PRINTFORML 「Oh hey, my friend Momoyo works up here!」
									PRINTFORMW 「%HE_SHE([[百々世]],1)% works down in the mines. Maybe we should go down there and say hi!」

								CASE 1
									PRINTFORMW 「If you run into that fox %PRINT_MALE("guy", 139)%, uh...」
									PRINTFORMDW Wriggle shakes %HIS_HER([[リグル]])% head.
									PRINTFORMW 「Crap, I forgot %HIS_HER(139)% name.」
									PRINTFORMW 「Well, anyway, if you run into a fox %PRINT_MALE("guy", 139)% on this mountain, don't buy anything from %HIM_HER(139)%.」
									PRINTFORMW 「I was on my way home after hanging out with Momoyo, and I ran into %HIM_HER(139)%.」
									PRINTFORMW 「%HE_SHE(139,1)% talked me into spending all my money on a "starter deck" of Ability Cards...」
									PRINTFORMW 「And then I found out that the cards stop working if you buy more than one at a time!」
									PRINTFORMDW %HE_SHE([[リグル]],1)% sighs.
									PRINTFORMW 「At least they look pretty. I even got an Advent %CALLNAME:1%!」
									PRINTFORMW 「I didn't know %HE_SHE(1)% used to have purple hair...」

								CASE 2
									PRINTFORML 「Do you think we should pray at the Moriya Shrine as long as we're up here?」
									PRINTFORMW 「Or would that just make the god of the Hakurei Shrine mad at us?」

							ENDSELECT

						CASE 9 ;Underworld
							SELECTCASE RAND:4
								CASE 0
									PRINTFORMW 「I don't wanna be rude, but... can we go somewhere else?」
									PRINTFORMDW Wriggle makes a face.
									PRINTFORMW 「I can't stand it down here. It's way too cold, there are barely any bugs, and the youkai here are... weird.」

								CASE 1
									PRINTFORMW 「I dunno what's up with that lady at the bridge.」
									PRINTFORML 「%HE_SHE([[パルスィ]],1)% always real nice to me whenever we meet...」
									PRINTFORMW 「But somehow, I get the feeling that %HES_SHES([[リグル]])% actually really mad at me.」
									IF TALENT:[[パルスィ]]:恋人
										PRINTFORMW 「Well, %HE_SHE([[パルスィ]])% used to be. I don't really get that feeling anymore.」
										PRINTFORMW 「Is it 'cause you're going out with %HIM_HER([[パルスィ]])%?」
									ELSE
										PRINTFORMW 「I wanna ask %HIM_HER([[パルスィ]])% what I did wrong... but that just feels kinda awkward, you know?」
									ENDIF

								CASE 2
									PRINTFORMW 「It's weird. You know how I always forget stuff?」
									PRINTFORMW 「And you know how people always forget about %CHAN_KUN(38)% unless they know that Satori-san has a sister?」
									PRINTFORMW 「That never happened for me. I still remember the first time I met %HIM_HER(38)%.」
									PRINTFORML 「I ran into %HIM_HER(38)% after the Underworld opened back up and I was looking for rare bugs...」
									CALL PRINT_STRW, @"「And back then, I didn't even know who Satori-san @ITALIC@was@, let alone that %HE_SHE(49)% had a sister!」"
									PRINTFORML 「Maybe my bad memory cancels out %HIS_HER(38)% powers?」
									PRINTFORMW 「Like, I forget about %HIM_HER(38)% so hard that I end up remembering %HIM_HER(38)% instead?」

								CASE 3
									PRINTFORMW 「Whenever I come down here, I always worry that I'll get stuck in one of Yamame-san's webs.」
									PRINTFORMW 「I know youkai aren't supposed to eat each other... but I'm a bug and %HES_SHES(84)% a spider.」
									PRINTFORMW 「What if I look so yummy to %HIM_HER(84)% that %HE_SHE(84)% doesn't care?」
									PRINTFORMDW Wriggle shudders.
							ENDSELECT

						CASE 10 ;Dream World / Moon
							SELECTCASE RAND:3
								CASE 0
									PRINTFORMW 「One time one of my bug friends told me that there was this whole swarm of bugs that traveled from planet to planet!」
									PRINTFORMW 「Apparently they harvest this stuff called "mutagen", and use it to mutate themselves so they can survive in space.」
									PRINTFORMW 「Cool, huh? You think any of them are up here?」

								CASE 1
									PRINTFORML 「So that Junko lady can purify stuff, right?」
									PRINTFORMW 「What happens if she purifies a bug? Do they just become... super "buggy"?」
									PRINTFORMW 「I wonder what that would look like...」

								CASE 2
									PRINTFORML 「They say every time you dream, your dream self becomes active in the Dream World.」
									PRINTFORMW 「I've had some really scary nightmares before... does that mean they all really happened to my dream self?」
									PRINTFORMDW Wriggle swallows and clings to you.

							ENDSELECT

					ENDSELECT

				CASE 1
					GOTO REGULAR_CONVOS

				CASE 2
					SELECTCASE RAND:3
						CASE 0
							PRINTFORMW 「Oooh! %K27_MASTER()%, c'mere, look!」
							PRINTFORMDW Wriggle dashes over to a nearby rock, lifts it up, and scoops a bug into %HIS_HER([[リグル]])% hand.
							PRINTFORMDW %HE_SHE([[リグル]],1)% holds it up to you and beams.
							PRINTFORMW 「They say if you find a cool bug when you're on a date, you and that person are meant to be together!」
							PRINTFORMDW ...Do they?
						CASE 1
							PRINTFORMW 「I hope my bug friends don't start gossiping about us now.」
						CASE 2
							PRINTFORMW （I bet a youkai's gonna attack us. That always happens in the comics when a superhero goes on a date.）
							PRINTFORMW （But no youkai's a match for the great %NAME:[[リグル]]%!）
							PRINTFORMW （It'll be like "Pow! Biff! Socko!" and they'll be runnin' away as fast as they can.）
							PRINTFORMW （And then %K27_MASTER()%'ll swoon in my arms and go "Oh, my hero!" And then %HE_SHE(MASTER)%'ll give me a kiss!）
							PRINTFORMW （Ehehe...）
							PRINTFORMDL Is Wriggle all right?
							PRINTFORMDW You tap %HIM_HER([[リグル]])% on the shoulder.
							PRINTFORML 「Wah!」
							PRINTFORMW 「Sorry, %K27_MASTER()%... what were you saying again?」
					ENDSELECT
			ENDSELECT
