		PRINTFORMDL Wriggle's been glaring at you the whole time during your date...
		PRINTFORMDW But now %HE_SHE([[リグル]])% has a faint smile on %HIS_HER([[リグル]])% face.
		PRINTFORMW 「Thanks. I had fun.」
		RETURN 1
	ENDIF
	PRINTFORML
ENDIF
RETURN 1

;※※※※※※※※※※※※※※※※※※※※※※※※※※
;"EVENT"系イベント
;※※※※※※※※※※※※※※※※※※※※※※※※※※
;==================================================
;Encountering the character in a room
;部屋で遭遇
;==================================================
@M_KOJO_EN01_EVENT_K27_1(ARG,ARG:1)
;口上主はTARGET
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;The player enters a room the character's in
	;MASTERが入ってきた
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		CALL K27_PLAYER_ENCOUNTERS_WRIGGLE(0)
	ENDIF
	;-------------------------------------------------
	;The character enters a room the player's in
	;TARGETが入ってきた
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		CALL K27_PLAYER_ENCOUNTERS_WRIGGLE(1)
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;The character enters a room the player's bathing in and joins them in the bath
	;TARGETが風呂に入ってきて一緒に入る
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		SELECTCASE RAND:3
			CASE 0
				PRINTFORML 「Hey, mind if I join you?」
				PRINTFORMDW Wriggle strips off %HIS_HER([[リグル]])% clothes and joins you in the bath without waiting for an answer.
			CASE 1
				PRINTFORMDL Wriggle gasps.
				PRINTFORML 「%K27_MASTER()%?! Don't you know that assassins love to attack people when they're bathing?!」
				PRINTFORMW 「But don't worry! I'll protect you!」
			CASE 2
				PRINTFORMDW Wriggle turns crimson when %HE_SHE([[リグル]])% sees you're already in the bath.
				PRINTFORMDW The two of you stare at each other for a moment before %HE_SHE([[リグル]])% speaks.
				PRINTFORMW 「Do you... um... mind if I join you?」
				PRINTFORMDL You smile and gesture to her.
				PRINTFORMDW Wriggle's blush deepens, and %HE_SHE([[リグル]])% quickly strips off %HIS_HER([[リグル]])% clothes and joins you in the bath.
		ENDSELECT
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;The character enters a room the player's bathing in and leaves
	;TARGETが風呂に入ってきて出て行った
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 4
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;The character enters a room the player's bathing in and kicks them out of the bath
	;TARGETが風呂に入ってきて追い出された
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 5
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;Encountering the player while they're outside
	;外出先で遭遇した
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 6
		CALL K27_PLAYER_ENCOUNTERS_WRIGGLE
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;Encountering the player while they're on a date with another character
	;ARG:1 is the person the player's on a date with (if you want to have custom dialogue
	;for dating a specific character in front of this character, etc)
	;他キャラとデート中に遭遇した
	;ARG:1にデート相手
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 7
		IF ONCE("DateReaction")
			SELECTCASE ARG:1
			;Rumia, Daiyousei, Cirno, Chen, Eternity
				CASE 12, 13, 14, 24, 118
					IF IS_CHILD(MASTER)
						PRINTFORMW 「Oh hey, guys! What're you up to?」
						PRINTFORMW 「A date? Aww, that's so cute!」
						PRINTFORMDW Wriggle smiles at you and ruffles your hair.
						PRINTFORMW 「Have fun, you two! Jeez, they grow up so fast...」
					ELSE
						PRINTFORML 「Uhh... aren't you a little young to be going on a date with %CALLNAME:MASTER%?」
						PRINTFORMDW Wriggle gives you a dirty look.
					ENDIF
					IF ARG:1 == 12
						CFLAG:[[リグル]]:K27EN_WRIGGLE_RUMIA_DATE = 1
					ELSEIF ARG:1 == 13
						CFLAG:[[リグル]]:K27EN_WRIGGLE_DAIYOUSEI_DATE = 1
					ELSEIF ARG:1 == 14
						CFLAG:[[リグル]]:K27EN_WRIGGLE_CIRNO_DATE = 1
					ELSEIF ARG:1 == 24
						CFLAG:[[リグル]]:K27EN_WRIGGLE_CHEN_DATE = 1
					ELSEIF ARG:1 == 118
						CFLAG:[[リグル]]:K27EN_WRIGGLE_LARVA_DATE = 1
					ENDIF

			;Mystia
				CASE 28
					IF TALENT:[[リグル]]:恋人 && TALENT:28:恋人
						SELECTCASE RAND:3
							CASE 0
								PRINTFORMDW Wriggle frowns as she sees you and Mystia cuddling.
								PRINTFORMW 「I gotta say, Misty, I wish I could cuddle with %K27_MASTER()% the way you do.」
								PRINTFORMW 「You have those nice soft feathers to keep %HIM_HER(MASTER)% warm, but I'm a firefly youkai, so I'm too cold to warm %HIM_HER(MASTER)% up.」
								PRINTFORMDW Mystia chuckles.
								CALL CHARA_TEXT(28,@"「Oh, Wriggle... do you realize〜 your problem's not so daunting after all〜?」","w")
								CALL CHARA_TEXT(28,@"「If you can find someone to sew it, I can give you my feathers to make a blanket.」","w")
								CALL CHARA_TEXT(28,@"「Then you two can cuddle together under there. Snug as two bugs in a rug!」","w")
								PRINTFORML 「Aww, Misty...」
								PRINTFORMDW Wriggle beams at her.
								CALL CHARA_TEXT(28,@"「No, no, it's nothing!」","w")
								PRINTFORMDW Mystia smiles back at her.
								PRINTFORMW 「What are friends for? I'll be there for you〜 When you're feeling glum〜」
								PRINTFORMW 「Is there something I can do for you, too?」
								CALL CHARA_TEXT(28,@"「Well...」","l")
								PRINTFORMDW Mystia holds out a hand.
								CALL CHARA_TEXT(28,@"「I find myself getting jealous of how you can hold %CALLNAME:MASTER%'s hand whenever you want.」","w")
								CALL CHARA_TEXT(28,@"「These talons of mine make it hard to do without hurting %HIM_HER(MASTER)%.」","w")
								CALL CHARA_TEXT(28,@"「And I'm not going to cut them. That would be like you cutting off your antennae!」","w")
								CALL CHARA_TEXT(28,@"「Help me〜 I need your wisdom, Wriggle〜 Help me〜」","w")
								PRINTFORMW 「Uhh...」
								PRINTFORMDW Wriggle thinks for a moment.
								PRINTFORMW 「Oh, I know! I can get my silkworm friends to make you some extra-strength gloves!」
								PRINTFORMDW Mystia's face lights up.
								CALL CHARA_TEXT(28,@"「That'd be wonderful! Thank you, Wriggle!」","w")

							CASE 1
								CALL CHARA_TEXT(28,@"「First you hear it, a sparrow's song, more thrilling than any other〜」","w")
								CALL CHARA_TEXT(28,@"「Then your mind goes, leaving you a slave to your youkai lover〜」","w")
								PRINTFORMDW Wriggle looks a little creeped out.
								PRINTFORMW 「You aren't actually planning on brainwashing %CALLNAME:MASTER%, are you?」
								PRINTFORMDW Mystia giggles.
								CALL CHARA_TEXT(28,@"「Of course not!」","w")
								CALL CHARA_TEXT(28,@"「Not unless %HE_SHE(MASTER)% wants me to, anyway〜」","w")

							CASE 2
								PRINTFORMDW Fireflies form a heart above you as you and Mystia hold hands.
								PRINTFORMW 「Do you guys like 'em?」
								PRINTFORMDW Wriggle grins.
								PRINTFORMW 「I asked them to accompany you two on your date. I figured it'd be super romantic.」
								CALL CHARA_TEXT(28,@"「And you were right!」","w")
								PRINTFORMDW Mystia grins back at her friend.
								CALL CHARA_TEXT(28,@"「I'll have to find a way to pay you back next time you and %CALLNAME:MASTER% go on a date.」","w")
								CALL CHARA_TEXT(28,@"「Maybe I can ask some of my sparrow friends to chirp love songs as you two stroll together?」","w")

						ENDSELECT
					ELSE
						PRINTFORMW 「Oh hey, Misty! Are you on a date with %K27_MASTER()%?」
						PRINTFORMW 「Heh heh... I knew it. Are you gonna share a lamprey with %HIM_HER(MASTER)% so your lips "accidentally" meet?」
						CALL CHARA_TEXT([[ミスティア]], @"「Wriggle!」", "w")
						PRINTFORMDW Mystia blushes.
						CFLAG:[[リグル]]:K27EN_WRIGGLE_MYSTIA_DATE = 1
					ENDIF

			;Yamame
				CASE 84
					PRINTFORMW 「Y... Yamame-san...」
					PRINTFORMDW Wriggle gulps.
					PRINTFORMW 「Uhh, I just remembered I had somewhere to be. Bye!」
					PRINTFORMDW %HE_SHE([[リグル]],1)% dashes off.
					CFLAG:[[リグル]]:現在位置 = KICKOUT()
					PRINTFORMDW Yamame chuckles.
					CALL CHARA_TEXT([[ヤマメ]], @"「Oh, Wriggle-chan... don't you know I don't eat other youkai?」", "w")
					CALL CHARA_TEXT([[ヤマメ]], @"「Although I'd stop by Eientei for a checkup if I were %HIM_HER([[リグル]])%...」", "w")
					CFLAG:[[リグル]]:K27EN_WRIGGLE_YAMAME_DATE = 1

			;Momoyo
				CASE 142
					PRINTFORMW 「Yo, Momoyo! What're you and %K27_MASTER()% up to?」
					PRINTFORMW 「A date? Hehe, that's so cute!」
					PRINTFORMDW Wriggle smiles at you.
					PRINTFORMW 「Just be sure not to kiss %HIM_HER(142)% good night. %HE_SHE(142,1)%'s an oomukade, you know.」
					CFLAG:[[リグル]]:K27EN_WRIGGLE_MOMOYO_DATE = 1

			;Hourai
				CASE 147
					PRINTFORMW 「Really, %CALLNAME:MASTER%? Really? Her?
				; CALL M_KOJO_COLOR_K147
					IF IS_FEMALE(TARGET)
						CALL PRINT_STRW, @"「Yeah, me. %CALLNAME:MASTER% likes girls who actually @ITALIC@look@like girls. Crazy, huh?」"
					ELSE
						PRINTFORMW 「Yeah, me. Maybe if you weren't spending all your time bugchasing, you'd be able to get laid too.」
					ENDIF
					PRINTFORMDW Wriggle glares at %CALLNAME:(ARG:1)% and mutters something under %HIS_HER([[リグル]])% breath.

			;Parsee
				CASE 60
					CALL PRINT_STRW, @"「Wh- the bridge princess? How did @ITALIC@%HE_SHE([[パルスィ]])%@ talk %K27_MASTER()% into dating %HIM_HER([[パルスィ]])%?」"
					TRYCALL M_KOJO_COLOR_K60_VERY_JEALOUS
					PRINTFORMW 「Ngh... I'm so jealous...」
					CALL M_KOJO_EN01_COLOR_K27
					PRINTFORMDW Wriggle bites %HIS_HER([[リグル]])% thumb and glares at Parsee enviously.
					IF GROUPMATCH(K60_ATTITUDE(), 0, 1) || TALENT:[[パルスィ]]:恋慕
						CALL CHARA_TEXT([[パルスィ]], @"「Ah! My apologies, Wriggle-chan! I must have made eye contact with you by accident...」", "w")
						PRINTFORMDW Parsee concentrates for a moment, and Wriggle blinks.
						PRINTFORMW 「Huh. For some reason, I don't feel jealous anymore. Weird...」
					ELSEIF K60_ATTITUDE() == 2
						CALL CHARA_TEXT([[パルスィ]], "「Hmph. Is there anything out there more pathetic than a sore loser?」", "w")
						PRINTFORMDW Parsee smirks at you.
					ELSE
						CALL CHARA_TEXT([[パルスィ]], @"「What's wrong with Wriggle-chan? %HE_SHE([[リグル]],1)% seems to be very upset about something.」", "w")
						PRINTFORMDW You think you see a faint smirk on Parsee's face...
					ENDIF
					RETURN 1

			;Yuyuko
				CASE 66
					PRINTFORMW 「...」
					PRINTFORMDW Wriggle smiles stiffly at you and Yuyuko.
					PRINTFORMW 「...Are you taking %HIM_HER([[幽々子]])% out to eat?」
					PRINTFORMW 「Yeah, that's what I thought.」
					IF FIRSTTIME("WriggleDislikesYuyuko")
						PRINTFORMW 「But if you were thinking of taking %HIM_HER([[幽々子]])% to Misty's food cart... don't. %HES_SHES([[幽々子]],1)% banned.」
						PRINTFORMW 「For trying to eat %HIM_HER([[ミスティア]])%.」
						PRINTFORMDW Wriggle glares at Yuyuko.
					ENDIF

			;Yuuka
				CASE 68
					PRINTFORMW 「Oh, hi, Yuuka-san!」
					PRINTFORMW 「You and %K27_MASTER()% are on a date? Cool! Have fun, then!」
					IF IS_FALLEN(68)
						PRINTFORMW （Wow, is she blushing? I've never seen Yuuka-san blush before. It's kinda cute...）
					ELSE
						PRINTFORMW （Wow, look at that smile! I've never seen Yuuka-san smile like that before. It's kinda cute...）
					ENDIF
					PRINTFORMW 「Wah! Wh-what are you glaring at me for, Yuuka-san? I didn't say anything!」
					CFLAG:[[リグル]]:K27EN_WRIGGLE_YUUKA_DATE = 1

				CASEELSE
					PRINTFORMW 「Oh, hey %K27_MASTER()%! What are you and %CALLNAME:(ARG:1)%-san up to?」
					IF TALENT:[[リグル]]:恋人
						IF VAR_OR_DEFAULT("MORELOVER")
							GOTO DATE_HAVE_FUN
						ELSE
							PRINTFORMW 「...A date? Really?」
							PRINTFORMDW Wriggle folds %HIS_HER([[リグル]])% arms.
							IF FIRSTTIME("WriggleOneLoverDate",1)
								PRINTFORMW 「I guess I can't really get mad at you. Insects don't really do monogamy.」
								PRINTFORMW 「But you'd better make sure I'm number one in your harem! The great %NAME:[[リグル]]% won't settle for anything less!」
								CALLF FIRSTTIME("WriggleOneLoverDate")
							ELSE 
								PRINTFORMW 「Well, you'd better take me out tomorrow, then! I'm in your harem too, y'know!」
							ENDIF
						ENDIF
					ELSEIF TALENT:[[リグル]]:セフレ || TALENT:[[リグル]]:愛欲
						SELECTCASE RAND:3
							CASE 0
								PRINTFORML 
							CASE 1
								PRINTFORML 
							CASE 2
								PRINTFORML 
						ENDSELECT
					ELSEIF TALENT:[[リグル]]:思慕 || TALENT:[[リグル]]:恋慕
						PRINTFORMW 「A date, huh?」
						PRINTFORMW 「...」
						PRINTFORMW 「...Have fun, I guess.」
						PRINTFORMDW Wriggle looks a little disappointed.
					ELSE
						$DATE_HAVE_FUN
						PRINTFORMW 「A date, huh? Hehe, have fun～!」
						IF TALENT:[[リグル]]:恋人
							PRINTFORMW 「And you'd better take me out tomorrow! I'm in your harem too, y'know!」
							PRINTFORMW 「I'm giving you all my love, so the least you can do is give me more love than any of your other lovers!」
						ENDIF
					ENDIF
			ENDSELECT
		ELSE
			IF GROUPMATCH(ARG:1, 66, 147) || (GROUPMATCH(ARG:1, 12, 13, 14, 24, 118) && !IS_CHILD(MASTER))
				PRINTFORMDW Wriggle glares at %CALLNAME:(ARG:1)%.
			ELSE
				PRINTFORML 「Oh hey, you guys again!」
				PRINTFORMDW Wriggle smiles and waves at you and %CALLNAME:(ARG:1)%.
			ENDIF
		ENDIF
	ENDIF
	CALL M_KOJO_EN01_COLOR_K27
	;-------------------------------------------------
	;First greeting of the day on the player's MAIN_MAP (the part of the world map they're living in: ex. The Forest of Magic, the Underworld, the Hakurei Shrine, etc.)
	;Note: after this dialogue is displayed, it will immediately be followed up by the ARG == 1 (the player enters a room the character's in)
	;or ARG == 2 dialogue (the character enters a room the player's in)
	;I think this only displays if the character walked in on you having sex the previous day?
	;MAIN_MAP上で一日最初の挨拶
	;注、このあと通常の遭遇口上、ARG==1 OR ARG==2に接続します
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 8
		PRINTFORML 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;First greeting of the day when the player is not on their MAIN_MAP
	;ARG:1 is the person the player's on a date with. If it's 0, they're not on a date.
	;Note: after this dialogue is displayed, it will immediately be followed up by the ARG == 6 (encountering the player while they're outside)
	;or ARG == 7 dialogue (encountering the player while they're on a date with another character)
	;外出先で一日最初の挨拶
	;ARG:1にデート相手、ARG:1が0の場合は非デート
	;注、このあと通常の外出先で遭遇した口上、ARG==6 OR ARG==7に接続します
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 9
		;If the player is on a date
		;ARG:1とデート中
		IF ARG:1
		;If they're not on a date		
		;一人で外出
		ELSE
		ENDIF
		PRINTFORML 
		RETURN 1
	ENDIF

    ;-------------------------------------------------
	;ENG exclusive: character is going somewhere else, asks if you'd like to tag along
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 97
		PRINTFORML
		RETURN 1
	ENDIF

    ;-------------------------------------------------
	;ENG exclusive: tag along to wherever the character's going
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 98
		PRINTFORML
		RETURN 1
	ENDIF

    ;-------------------------------------------------
	;ENG exclusive: don't tag along to wherever the character's going
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 99
		PRINTFORML
		RETURN 1
	ENDIF
ENDIF
RETURN 1

;==================================================
;When the player wakes up in the morning (good morning dialogue)
;朝起きたとき（おはよう口上）
;==================================================
@M_KOJO_EN01_EVENT_K27_2(ARG,ARG:1)
;口上主はTARGET
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------

IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;The character woke up first, and they aren't living with the player
	;非同棲かつ相手が先に起きてる
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		;-------------------------------------------------
		;The player is in the character's room
		;TARGET私室にMASTERが入っている（恋慕時添い寝中就寝時のみ？
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1 && !ARG:1
			RETURN 1
            [SKIPSTART]
			IF DAYEVENT_TARGET != TARGET || !DAYEVENT_SCENARIO
				IF (TALENT:TARGET:愛欲 || TALENT:TARGET:セフレ) && !RAND:3
					CALL K27_WRIGGLE_MORNING_SEX_EVENTS()
				ENDIF
				RETURN 1
			ENDIF
			RETURN 1
			[SKIPEND]
		ENDIF
		;-------------------------------------------------
		;The character is in the player's room
		;MASTER私室にTARGETが入ってきてる(恋慕無しでも入ってくる可能性有り
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1 && ARG:1 == 1
			RETURN 1
            [SKIPSTART]
			IF DAYEVENT_TARGET != TARGET || !DAYEVENT_SCENARIO
				IF (TALENT:TARGET:愛欲 || TALENT:TARGET:セフレ) && !RAND:3
					CALL K27_WRIGGLE_MORNING_SEX_EVENTS()
				ENDIF
				RETURN 1
			ENDIF
			RETURN 1
			[SKIPEND]
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;The character woke up first, and they are living with the player
	;同棲かつ相手が起きている
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		RETURN 1
		[SKIPSTART]
		IF DAYEVENT_TARGET != TARGET || !DAYEVENT_SCENARIO
			IF TALENT:[[リグル]]:恋人
				IF !RAND:3
					CALL K27_WRIGGLE_MORNING_SEX_EVENTS()
				ELSE
					PRINTFORMW 「Good morning, %K27_MASTER()%～」
					PRINTFORMDW Wriggle smiles at you and kisses you on the cheek.
					PRINTFORMW 「Don't move, okay? Just for a little bit...」
					PRINTFORMDW Wriggle leans over and stares into your eyes.
					CALL HPH_PRINT, @"「You look so cute when you've just woken up, and I wanna make sure I don't forgetHPH」", "W"
				ENDIF
			ENDIF
		ENDIF
		[SKIPEND]
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;The player woke up first, and they are living with the character
	;同棲かつ相手が寝ている
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		PRINTFORMW 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;The player and the character are both awake
	;I think this gets called if either the player or the character run out of strength during sex, or if the character falls asleep during Sleep Together, the player wakes up, and then the character wakes up
	;MASTERが起きていて、相手が起きてきた
	;添い寝時TARGET起床はこちら（TARGET衰弱or添い寝中TARGET睡魔負け後そのままMASTERが起き続けた上で相手が起床した場合限定
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 4
		;-------------------------------------------------
		;Not living together
		;非同棲
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1 && !ARG:1
			PRINTFORMW 
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;Living together
		;同棲中
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 0
		;-------------------------------------------------
		IF LOCAL:1 && ARG:1 == 1
			PRINTFORMW 
			RETURN 1
		ENDIF
		PRINTFORMW 
		RETURN 1
	ENDIF
	;Misc.	
	;その他
	PRINTFORML  
ENDIF
RETURN 1

;==================================================
;When going to sleep at night (good night dialogue)
;夜寝るとき（おやすみ口上）
;==================================================
@M_KOJO_EN01_EVENT_K27_3(ARG,ARG:1)
;口上主はTARGET
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 0
;-------------

IF LOCAL
