;310,尻を撫でる
;TFLAG:193(1=不快(TALENT:臆病なら涙目) 2&&3=恥ずかしがる(TALENT:男嫌い兼MASTERが男なら、身をすくめる) 4=されるがまま)
;CFLAG:うふふ==2&&TCVAR:20(パンツ無し顔面騎乗(70=クンニ強制 71=フェラチオ強制 72=アナル奉仕) 35=スカート内見せつけ 52=素股)
;CFLAG:うふふ==2&&TEQUIP:シックスナイン(パンツありTCVAR:20(70～72)はこちら)
;PREVCOM(305=膝枕
;TFLAG:400(1=デート先or地底のモブが反応する)
;==================================================
@M_KOJO_SUCCESS_COM_K44_310
;成否判定
;TFLAG:192(-2=コマンド終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

@M_KOJO_MESSAGE_COM_K44_310
CALL M_KOJO_MESSAGE_COM_K44_310_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K44_310_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
CFLAG:1891 = 1
IF LOCAL
	IF FLAG:70
	ELSEIF CFLAG:睡眠
	ELSEIF !CFLAG:ブチギレ
		IF TALENT:恋人 && TALENT:恋慕
			IF (OUTROOF(CFLAG:TARGET:現在位置)) || (OPENPLACE(CFLAG:TARGET:現在位置))
				PRINTFORMW 「ちょちょちょちょっと//　誰か来たらどうするのよ//」
			ELSE
				PRINTFORMW 「もー、%CALLNAME:MASTER%ったら本当にえっちなんだから…//」
			ENDIF
		ELSEIF TALENT:恋慕
			IF (OUTROOF(CFLAG:TARGET:現在位置)) || (OPENPLACE(CFLAG:TARGET:現在位置))
				PRINTFORMW 「ちょちょちょちょっと//　誰か来たらどうするのよ//」
			ELSE
				PRINTFORMW 「まったく%CALLNAME:MASTER%ってば。　…特別よ//」
			ENDIF
		ELSEIF TFLAG:193 >= 2
			IF (OUTROOF(CFLAG:TARGET:現在位置)) || (OPENPLACE(CFLAG:TARGET:現在位置))
				PRINTFORMW 「ちょちょちょちょっと！//　こんな所でなにしてるのよ！//」
			ELSE
				IF TFLAG:193 == 4
					PRINTFORMW 「まったく、なにが楽しいんだか」
				ELSE
					PRINTFORMW 「ど、どこ触ってるのよ！　変態！//」
				ENDIF
			ENDIF
		ELSEIF !TALENT:ヤリマン
			PRINTFORMW 「どこ触ってるのよ！この変態！」
		ENDIF
	ENDIF
ENDIF
RETURN 1
;==================================================
;311,抱き付く
;TFLAG:193(1=大成功 0=成功 -1=失敗)
;CFLAG:うふふ==2&&TCVAR:20(32=前から抱きつく 60=ディープキス 73=ぱふぱふ 74=乳合わせ 77=乳を吸わせる ＶＡ性交(85=Ｖ挿入する 87=Ａ挿入する 88=腰振りＶ 89=腰振りＡ) 86=だいしゅきホールド)
;TFLAG:400(1=デート先or地底のモブが反応する)
;==================================================
@M_KOJO_SUCCESS_COM_K44_311
;成否判定
;TFLAG:192(-2=コマンド終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

@M_KOJO_MESSAGE_COM_K44_311
CALL M_KOJO_MESSAGE_COM_K44_311_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K44_311_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF FLAG:70
	ELSEIF CFLAG:睡眠
	ELSEIF !CFLAG:ブチギレ && !MARK:反発刻印
		IF CFLAG:うふふ == 2
			PRINTFORMW 「えへへへ//　あったかーい…//」
		ELSEIF TALENT:恋慕 && TALENT:恋人
			SELECTCASE RAND:2
			CASE 1
				PRINTFORMW 「%CALLNAME:MASTER%に抱かれているとなんだか安心するわ%UNICODE(0x2665)%」
			CASEELSE
				PRINTFORMW 「えへへへ%UNICODE(0x2665)% あったかーい%UNICODE(0x2665)%」
			ENDSELECT
		ELSEIF TALENT:恋慕 || CFLAG:1014 == 1
			SELECTCASE RAND:2
			CASE 1
				PRINTFORMW 「えへへへへ//」
			CASEELSE
				PRINTFORMW （%CALLNAME:MASTER%の匂い…　なんだか落ち着くわ//）
			ENDSELECT
		ELSEIF TALENT:思慕
			PRINTFORMW 「%CALLNAME:MASTER%ってばもー、…しょうがないわね」
		ELSE
			PRINTFORMW 「ちょちょちょちょっと！　なに抱きついてるのよ！//」
		ENDIF
	ENDIF

ENDIF
RETURN 1
;==================================================
;312,キスする
;TFLAG:193(99=拒絶(キス不可) 1=大成功 0=成功 -1=失敗)
;CFLAG:うふふ==2&&TCVAR:20(32=前から抱きつく 50=手淫 60=キス 性交(85=Ｖ挿入する 87=Ａ挿入する 88=腰振りＶ 89=腰振りＡ) 86=だいしゅきホールド)
;PREVCOM(305=膝枕
;TFLAG:400(1=デート先or地底のモブが反応する)
;==================================================
@M_KOJO_SUCCESS_COM_K44_312
;成否判定
;TFLAG:192(-2=コマンド終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

@M_KOJO_MESSAGE_COM_K44_312
CALL M_KOJO_MESSAGE_COM_K44_312_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K44_312_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF FLAG:70
	ELSEIF CFLAG:睡眠
	ELSEIF !CFLAG:ブチギレ && TFLAG:193 != 99 && !MARK:反発刻印
		;ありがとうおしゃぶり霊夢の人！そしてごめんなさい！
		IF EXP:キス経験 == 1
			;ファーストキッス群
			IF TALENT:恋人 && TALENT:恋慕
				PRINTFORMW 「えへへへ//　恋人同士のキスってこんなに幸せなものだったのね%UNICODE(0x2665)%」
				PRINTFORMW 「次はわたしからするわ%UNICODE(0x2665)% ちゅっ%UNICODE(0x2665)%」
				EXP:キス経験 += 4
				EXP:MASTER:キス経験 += 4
				EXP:愛情経験 += 10
			ELSEIF TALENT:恋人 || TALENT:恋慕
				PRINTFORMW 「えへへ//　こんどはわたしの番よ%UNICODE(0x2665)% えいっ%UNICODE(0x2665)%」
				EXP:キス経験 += 1
				EXP:MASTER:キス経験 += 1
			ELSEIF TALENT:思慕
				PRINTFORMW 「えっ？えっ！？えええっ！？」
				PRINTFORMW （まさか%CALLNAME:MASTER%がききききすしてくるなんて//）
				PRINTFORMW （%CALLNAME:MASTER%からキスしてくるってことはももももしかしてわたしのことが好きなの！？//）
				PRINTFORMW （べべべべつに%CALLNAME:MASTER%のことは好きだけれどそれは友達としての好きだし//）
				PRINTFORMW （%CALLNAME:MASTER%もそう思ってると思ってたけどけどけど）
				PRINTFORMW （あーうー//）
				CFLAG:1014 = 1
				TALENT:羞恥心 = 1
			ELSE
				PRINTFORML 「……わたしのファーストキッス～！！」
				PRINTFORMDW エレンは泣きながら怒っている…
				BASE:怒り += 500
				CFLAG:好感度 -= 300
				;マイナスにはならない
				SIF CFLAG:好感度 < 0
					CFLAG:好感度 = 0
			ENDIF
		ELSE
			IF TALENT:恋人 && TALENT:恋慕 && GET_TARGETNUM() == 1
				SELECTCASE RAND:3
				CASE 1
					PRINTFORMW 「次はわたしから%UNICODE(0x2665)% ちゅ～%UNICODE(0x2665)%」
				CASE 2
					PRINTFORMW 「ねえ、もう一回%UNICODE(0x2665)%」
				CASEELSE
					SELECTCASE CFLAG:溜まってる度
					CASE 0 TO 499
						PRINTFORMW 「ちゅっ%UNICODE(0x2665)%　ちゅっ%UNICODE(0x2665)%」
					CASE 500 TO 799
						PRINTFORMW 「ちゅう……んっ//」
					CASE IS > 800
						PRINTFORMDW エレンは上気した顔で%CALLNAME:MASTER%の唇を熱心に求めてる……
					ENDSELECT
				ENDSELECT
	;			EXP:キス経験 += 1
	;			EXP:MASTER:キス経験 += 1
			ELSEIF TALENT:恋慕 && (OUTROOF(CFLAG:TARGET:現在位置)) || (OPENPLACE(CFLAG:TARGET:現在位置))
				PRINTFORMW 「ちゅうっ…ぷはぁ//　ちょっと恥ずかしいわね//」
			ELSEIF TALENT:恋人 && TALENT:恋慕
				PRINTFORMW 「ちゅうっ…ぷはぁ。　あははは%UNICODE(0x2665)% %CALLNAME:MASTER%だあいすき%UNICODE(0x2665)%」
			ELSEIF TALENT:恋慕 || CFLAG:1014 == 1 || TALENT:恋人
				PRINTFORMW 「ちゅうっ…ぷはぁ。　あははは//」
			ENDIF
		ENDIF
	ENDIF

ENDIF
RETURN 1
