;330,スカートめくり
;TFLAG:193(-5=拒絶（ビンタ） -3=拒絶（つねり） -1=いやがる 0=いやがる（嬉しげ） 1=受け入れ)
;TFLAG:193=1&&ABL:露出癖(5以上=人目のある場所で、自らスカートをまくり上げる 4以下=人目のある場所でめくられるさいに弱い抵抗 3以上=人目のない場所で自らスカートをまくり上げる 3未満=弱い抵抗)
;TFLAG:400(1=デート先or地底のモブが反応する)
;後ろからピラリ、ではなく、前からペラって感じ（そうじゃなかったら、めくり上げようとするのを止めて即座にビンタとか無理、めくり上げられた後にしかならないしその状況ならビンタ食らうより普通に弾幕で一発ＫＯにならないほうがおかしい
;==================================================
@M_KOJO_MESSAGE_COM_K44_330
CALL M_KOJO_MESSAGE_COM_K44_330_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K44_330_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
CFLAG:1891 = 1
IF LOCAL
	IF FLAG:70
	ELSEIF !CFLAG:ブチギレ
		IF TALENT:恋慕 || TALENT:恋人
			IF (OUTROOF(CFLAG:TARGET:現在位置)) || (OPENPLACE(CFLAG:TARGET:現在位置))
				PRINTFORMW 「ちょちょちょちょっと//　誰かに見られたらどうするのよ//」
			ELSE
				PRINTFORMW 「もー%CALLNAME:MASTER%ってば、本当にえっちなんだから…//」
			ENDIF
		ELSEIF TALENT:思慕
			IF CFLAG:2 <= 3000
				PRINTFORMW 「ちょ、ちょっと！　なにしてるのよ！」
			ELSEIF CFLAG:2 >= 3001 && CFLAG:2 <= 5000
				PRINTFORMW 「まったく、%CALLNAME:MASTER%ったら//」
			ELSEIF (OUTROOF(CFLAG:TARGET:現在位置)) || (OPENPLACE(CFLAG:TARGET:現在位置))
				PRINTFORMW 「ちょちょちょちょっと//　こんな所でなにしてるのよ！」
			ELSE
				PRINTFORMW 「%CALLNAME:MASTER%ってばもー…//」
			ENDIF
		ELSE
			PRINTFORMW 「なにしてるのよあなた！　魔法使うわよ！！」
		ENDIF
	ENDIF
ENDIF
RETURN 1
