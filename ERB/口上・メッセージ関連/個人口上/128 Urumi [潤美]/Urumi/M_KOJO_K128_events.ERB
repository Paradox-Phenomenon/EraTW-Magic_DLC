;-------------------------------------------------
;custom naming function to use for MASTERNAME:128, taken from Yuugi
;-------------------------------------------------
@NAME_SET_K128
LOCAL = GETCOLOR()
RESETCOLOR
PRINTDL Input a name Urumi should use when referring to you. (Type it in or press a button)
IF !GROUPMATCH(NAME:MASTER, "あなた", "Player")
	LOCALS = %CALLNAME:MASTER%
ELSE
	LOCALS = %NAME:MASTER%
ENDIF
PRINTBUTTON @"[Set to %LOCALS%]", @"%LOCALS%"
PRINTL 　
;名前を入力するループ
$INPUT_LOOP_ONAMAE
INPUTS
; 行頭行尾の空白文字削除
LOCALS = %RESULTS%
REPLACE LOCALS, "\(\^\\s\+\|\\s\+\$)", ""
;10文字以上は受け付けない
IF STRLENS(LOCALS) > 16
	CLEARLINE 1
	REUSELASTLINE Name is too long.
	GOTO INPUT_LOOP_ONAMAE
;空白は受け付けない
ELSEIF RESULTS == ""
	PRINTDL You have to input something.
	GOTO INPUT_LOOP_ONAMAE
ELSE
	PRINTFORML Name will be set to %RESULTS%, confirm?
	CALL ASK_YN
	IF RESULT == 0
		;あなたの名前を%MASTERNAME:64%に格納
		MASTERNAME:128 = %RESULTS%
		PRINTFORML 
	ELSE
		PRINTDL Input your name.
		GOTO INPUT_LOOP_ONAMAE
	ENDIF
ENDIF
SETCOLOR LOCAL

;※※※※※※※※※※※※※※※※※※※※※※※※※※
;"ENCOUNTER" events (extra syntax)
