;==================================================
;410,掃除
;==================================================
@M_KOJO_MESSAGE_COM_K54_410
CALL M_KOJO_MESSAGE_COM_K54_410_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K54_410_1
;初めて
IF FIRSTTIME(SELECTCOM)
	IF TFLAG:193
		PRINTL 「そうね、久しぶりに掃除でもしてみようかしら」
		PRINTFORMW パチュリーは\@ BATHROOM(CFLAG:現在位置) ?帽子を取り、肩口で髪を一つにまとめる # バスタオルを体に巻きつける \@と%CALLNAME:MASTER%の手伝いを始めた
	ELSE
		PRINTFORML 「掃除\@ CFLAG:1004 ? も # が \@\@ CFLAG:MASTER:7 == 1 ? 貴方 # 貴女 \@の仕事なのね……」
		PRINTFORML \@ CFLAG:1003 ? パチュリー # 紫色の髪をした少女 \@は\@ BATHROOM(CFLAG:現在位置) ? 湯船に浸かり # 本に目を落とし \@つつ気だるそうに言った
		;パチュリー私室以外でパチュリー私室の掃除が出来る
		SIF CFLAG:現在位置 != CFLAG:初期位置 && YOGORE:(CFLAG:初期位置) > 500
			PRINTL 「……あぁそうだわ、私の部屋の机とベッド周りの掃除もやっておいて」
		WAIT
	ENDIF
;恋慕
ELSEIF TALENT:恋慕
	SELECTCASE TFLAG:194
		CASE 0
			PRINTL 「ささっと終わらせてもっと楽しいことをしましょう」
			PRINTW パチュリーは率先して掃除を始めた
		CASE 1
			PRINTFORML パチュリーは%CALLNAME:MASTER%にハンカチを渡すと後ろを向いた
			PRINTL 「自分でやるとうまく結べないのよ……結んでくれる？」
			PRINTFORMW %CALLNAME:MASTER%はパチュリーはたまに不器用になるなと微笑み、マスク代わりのハンカチを結んだ
		CASE 2
			PRINTL 「やり甲斐がありそうね……」
			PRINTFORMW %CALLNAME:MASTER%達はくずかごを持って散らばったゴミを拾い始めた
		CASE 3
			PRINTL 「さすがにここまで行くと辟易するわね」
			PRINTFORML パチュリーはゴミの山を眺めながら%CALLNAME:MASTER%にへと言った
			PRINTL 「止まってても仕方ないわね。出来るところまで片付けましょう」
			PRINTFORMW パチュリーは、あとでご褒美を頂戴ねと%CALLNAME:MASTER%に言うのも忘れなかった
	ENDSELECT
;うふふ解禁状態
ELSEIF CFLAG:6 >= 2
	SELECTCASE TFLAG:194
		CASE 0
			PRINTL 「これくらいなら拭くだけでいいわね」
			PRINTW パチュリーはふわふわとした足取りで手近なものを拭いては移動を繰り返した
		CASE 1
			PRINTL 「ハンカチは用意してあるわ」
			PRINTFORMW %CALLNAME:MASTER%が、湿らせた？と問うと湿らせてきてとパチュリーは頼んだ
		CASE 2
			PRINTL 「ゴミが多いわね……魔法で吹き飛ばそうかしら……」
			PRINTW 埃が舞い上がって余計に掃除が大変になるから止めてください
		CASE 3
			PRINTL 「はぁー……やるわよ」
			PRINTFORMW パチュリーは長いため息をつくと%CALLNAME:MASTER%と一緒にゴミの山に立ち向かった
	ENDSELECT
;それ以外で一緒に掃除をする
ELSEIF TFLAG:193
	SELECTCASE TFLAG:194
		CASE 0
			PRINTL 「綺麗なものね……ん？拭くの？」
			PRINTFORML パチュリーは%CALLNAME:MASTER%に言われ、手近なものを拭いてみた
			PRINTW 「……意外とまだ汚れが残っているものなのね」
		CASE 1
			;風呂場以外
			IF !BATHROOM()
				PRINTL 「箒は埃が舞うから嫌なのよね……だからといって放置しておくと気管支に悪いし……」
				PRINTFORMW %CALLNAME:MASTER%は濡らしてから固く絞ったハンカチをマスク代わりにとパチュリーに渡し、当てさせた
			ELSE
				PRINTL 「ブラシは汚れが足に飛ぶから嫌いだわ……」
				PRINTFORMW %CALLNAME:MASTER%が浮きながらやったらどうだろう？と提案すると、それもそうねと返しバスタオルを巻きつけただけの体を宙に浮かせた
			ENDIF
		CASE 2
			PRINTL 「明らかにゴミだと分かるものをゴミ箱に放り込めばいいのね」
			PRINTFORMW %CALLNAME:MASTER%が頷くとパチュリーはゆっくりとした動作でゴミを集め始めた
		CASE 3
			PRINTL 「……見なかったことには出来ないかしら？」
			PRINTFORML %CALLNAME:MASTER%は少し思案し、とりあえず嫌になるまでやろうと言った
			PRINTW 「……早くも嫌になりそうだわ」
	ENDSELECT
;それ以外
ELSE
	SELECTCASE TFLAG:194
		CASE 0
			PRINTL 「そこはもう綺麗じゃない」
			PRINTFORML %CALLNAME:MASTER%は一拭きするとそれをパチュリーに見せた
			PRINTW 「うわ、汚いものを見せないで……」
		CASE 1
			;風呂場以外
			IF !BATHROOM()
				PRINTL 「箒を使うの？こっちまで埃を飛ばさないようにして頂戴」
				PRINTFORMW %CALLNAME:MASTER%はそんな無茶な……と思いつつもパチュリーの方へと埃が舞わないように注意しながら箒をかけた
			ELSE
				PRINTL 「ブラシを使うの？こっちまで飛沫がこないようにして頂戴」
				PRINTFORMW %CALLNAME:MASTER%はパチュリーに飛沫がいかないよう背を向けて床をブラシでこすり始めた
			ENDIF
		CASE 2
			PRINTW 「掃除し甲斐がありそうね……私はやらないわよ」
		CASE 3
			PRINTL 「早めに片付けて……歩きにくくて仕方ないの」
			PRINTFORMW %CALLNAME:MASTER%はパチュリーに乞われるまでもなくゴミの山を崩し始めた
	ENDSELECT
ENDIF
RETURN 1
