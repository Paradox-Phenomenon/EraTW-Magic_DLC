RETURN RESULT

@M_KOJO_MESSAGE_COM_K54_310_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
;初めて
IF FIRSTTIME(SELECTCOM)
	PRINTL 「ひゃっ！？…………いきなりなに？」
	;親密が5以下
	IF ABL:親密 <= 5
		PRINTFORML %CALLNAME:MASTER%がおしりをさわさわと撫でるとパチュリーの目が据わった
		PRINTW 「……いい加減にしないと燃やすわよ」
	ELSE
		PRINTL 可愛い悲鳴をあげパチュリーは自分がそんな声を出したことに頬を染めた
		PRINTW 「こーら、やめなさい！」
	ENDIF
;恋慕
ELSEIF TALENT:恋慕
	;うふふ中(と言うか押し倒されてる)
	IF CFLAG:317
		SELECTCASE TCVAR:20
			;(ディープ)キス
			CASE 30,60
				PRINTFORML %CALLNAME:MASTER%はパチュリーに口腔を舐られながらお尻へと手を伸ばした
				PRINTL 「んふぅっ！……ぁう んっんん」
				PRINTFORMW パチュリーは%CALLNAME:MASTER%にお尻を撫でられ嬉しそうにキスを深くした
			;抱きつかれる
			CASE 31,32
				PRINTFORML パチュリーに抱きつかれながら%CALLNAME:MASTER%は優しくお尻を撫でた
				PRINTL 「ここは優しく抱き返してくれる場面じゃないかしら？」
				PRINTFORMW そう言いつつもパチュリーは%CALLNAME:MASTER%\@ TCVAR:20 == 32 ? の背 # \@に手を回した
			;胸をもまれる
			CASE 36
				PRINTFORML %CALLNAME:MASTER%はパチュリーに胸を揉まれながらも果敢にお尻へと手を伸ばした
				PRINTW 「あら、胸よりもお尻のほうがよかったかしら？」
			;秘所への攻撃
			CASE 50 TO 53
				PRINTL 「っあ…そんな風に……んんっ…反撃してくるのね……」
				PRINTFORML パチュリーに\@ TALENT:MASTER:2 & 2 ? ペニス # 秘所 \@を擦られながら%CALLNAME:MASTER%は優しく撫で回す
				SIF TCVAR:MASTER:107 && !NOWEX:0 && !NOWEX:3
					PRINTL 「でも…んふっ…今回は私の勝ちね……イッちゃえ！」
				WAIT
			;飽きたから次回以降に追加
			CASEELSE
				PRINTL 「もっと……もっと強く触ってもいいわ……」
				PRINTFORMW %CALLNAME:MASTER%はパチュリーの要望どおりお尻を揉む手を強めた
		ENDSELECT
	;大成功
	ELSEIF TFLAG:193 == 1
		PRINT 「あんっ
		SETCOLOR 0xff1493
		FONTITALIC
		PRINTFORM %UNICODE(0x2665)%
		FONTREGULAR
		RESETCOLOR
		TRYCALL SET_KOJOCOLOR(TARGET)
		PRINTL …もう、いきなりなんだから……」
		PRINTFORML パチュリーは%CALLNAME:MASTER%を見て少し口を尖らせた
		PRINTW 「撫でるんだったら……気持ちよくして」
	;大失敗？
	ELSEIF TFLAG:193 == -1
		PRINTFORML %CALLNAME:MASTER%はパチュリーの尻を撫でようと手を伸ばした
		PRINTFORML しかしパチュリーはそれに気付き、%CALLNAME:MASTER%の手を目的である柔肉と自分の手で押さえ込んだ
		PRINTW 「こーら、いきなりお尻を撫でないの！」
	ELSEIF !RAND:4
		PRINTFORML 「%CALLNAME:MASTER%はおしりを撫でるのが好きなの？」
		PRINTFORML %CALLNAME:MASTER%は少し考え、撫でると気持ちがいいからではなく相手の反応を見るのが好きだと言った
		PRINTL 「悪趣味ね……なんでこんな奴を好きになっちゃったんだろう」
		PRINTW そういいつつもパチュリーは楽しそうに笑っていた
	ELSEIF !RAND:3
		PRINTL 「それでね、あっ……」
		PRINTFORMW 話の途中で%CALLNAME:MASTER%がおしりを撫でるとパチュリーは声を途切らせ、潤んだ瞳で見つめてきた
	ELSEIF !RAND:2
		PRINTFORML %CALLNAME:MASTER%がお尻を撫でるとパチュリーは余裕の表情で見返してきた
		PRINTW 「それで満足？……もっとしてもいいわよ」
	ELSE
		PRINTFORML %CALLNAME:MASTER%はパチュリーにお尻を撫でていいかと訊ねた
		PRINTW 「唐突ね……いいわ、好きにして」
	ENDIF
;うふふ中(と言うか押し倒されてる)
ELSEIF CFLAG:317
	PRINTL 「押し倒されたっていうのに果敢ね」
	PRINTFORML パチュリーは%CALLNAME:MASTER%の手を更にお尻へと押し付けさせた
;うふふ解禁状態か親密Lv7以上
ELSEIF CFLAG:6 >= 2 || ABL:9 >= 7
	;大成功
	IF TFLAG:193 == 1
		PRINTL 「私のなんて触って何が面白いのかしら？」
		PRINTFORML %CALLNAME:MASTER%は意外と肉付きがいいから気持ちがいいと答えた
		PRINTL 「意外と、とは失礼な輩ね」
		PRINTW そう言いながらもパチュリーは嬉しそうだった
	;大失敗？
	ELSEIF TFLAG:193 == -1
		PRINTFORML %CALLNAME:MASTER%はパチュリーのお尻を撫で回した
		PRINTW 「ひゃわっ……前も言ったと思うけど、いきなり触らないでもらえる？」
	ELSEIF !RAND:2
		PRINTW 「ぁっ……なに？お尻でも撫でれば私がそんな気分になるとでも思った？」
	ELSE
		PRINTL 「お尻を撫でたいって……欲求不満なの？」
		PRINTFORMW パチュリーはそういいながらも%CALLNAME:MASTER%にお尻を撫でさせることを許可した
	ENDIF
;それ以外
ELSE
	;大成功
	IF TFLAG:193 == 1
		PRINTFORML 「ひゃ……%CALLNAME:MASTER%……私は前に『触るときは許可を取りなさい』と言ったわよね」
		PRINTFORML %CALLNAME:MASTER%を見るパチュリーの頬は少し上気しているようにも見える
		PRINTW 「まぁ今回は……許してあげるわ」
	;大失敗
	ELSEIF TFLAG:193 == -1
		PRINTL 「……いい加減に止めなさい。撫でるにしては強すぎるわ」
		PRINTFORMW パチュリーは据わった目で%CALLNAME:MASTER%を見た
	ELSEIF !RAND:2
		PRINTFORML %CALLNAME:MASTER%がパチュリーのお尻を触るとパチュリーはそれに気付き%CALLNAME:MASTER%の手を止めた
		PRINTW 「レディに触れようとするなら許可を取りなさい」
	ELSE
		PRINTW 「いきなり触るなんて失礼すぎるわ」
	ENDIF
ENDIF
ENDIF
RETURN 1
