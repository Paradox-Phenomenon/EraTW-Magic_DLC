@M_KOJO_MESSAGE_COM_K54_300
;コマンド共通メッセージ(TRAIN_MESSAGE) 
;削除すると「～話をした。」とかが消えます
;口上メイン呼出
CALL M_KOJO_MESSAGE_COM_K54_300_1
RETURN RESULT
@M_KOJO_MESSAGE_COM_K54_300_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;ここに口上書いて下さい
	;初めて
	IF FIRSTTIME(SELECTCOM)
		RESETCOLOR
		DRAWLINE
		TRYCALL SET_KOJOCOLOR(TARGET)
		;お茶は淹れた
		IF TCVAR:354
			;どんなに厳つかろうと不自然であろうと性別ではなく格好で判断する
			PRINTFORML 「それで、あんた、誰？そんな格好してるんだから\@ CFLAG:MASTER:7 == 1 ? 執事 # メイド \@なんだろうけど」
			PRINTFORML お茶を飲み一息ついている少女の問いに%CALLNAME:MASTER%は自分の名前を言った
			PRINTFORML 「ああ、自己紹介もまだだったか……私はパチュリー・ノーレッジ、ただの居候よ」
		ELSE
			PRINTFORML 不審な目を向けてくる少女に%CALLNAME:MASTER%は慌てて、最近ここに来たばかりの\@ CFLAG:MASTER:7 == 1 ? 執事 # メイド \@であることを告げた
			PRINTFORML 「ふーん……まぁいいわ、私はパチュリー・ノーレッジ、ただの魔女よ」
		ENDIF
		PRINTFORMW パチュリーと名乗った少女は%CALLNAME:MASTER%に不敵な表情で笑いかけた
		CFLAG:1003 = 1
	;恋慕
	ELSEIF TALENT:恋慕
		;妊娠(日数によって変化していくと面白いと思う)
	;	IF CFLAG:6
		;怒り分岐
		IF CFLAG:318 && !(TCVAR:353 & 1)
			PRINTL 「いくら仲が良くなったって許せないこともあるのよ」
			PRINTFORML パチュリーは冷ややかな目で%CALLNAME:MASTER%を見ながら言った
			PRINTW 「親しい仲でも礼儀が必要なことを徹底的に教えてあげる」
			TCVAR:353 |= 1
		ELSEIF CFLAG:318
			PRINTL 「ええ、確かに私たちはあんなことを平気で出来るくらいに仲良くはなったわ」
			PRINTFORML パチュリーは%CALLNAME:MASTER%に訥々と語った
			PRINTW 「ああ、まだ足を崩してはダメよ……話は終わっていないわ」
		ELSEIF (BASE:怒り >= (MAXBASE:怒り / 5) * 3) && !(TCVAR:353 & 2)
			PRINTFORML 「今日は趣向を変えて%CALLNAME:MASTER%の罪の数でも数えてみましょうか」
			PRINTFORMW パチュリーは少し据わった目で%CALLNAME:MASTER%を見た
			TCVAR:353 |= 2
		ELSEIF ((BASE:怒り >= MAXBASE:怒り / 5) && (BASE:怒り <= (MAXBASE:怒り / 5) * 3)) && !(TCVAR:353 & 4)
			;怒りが収まってきた
			IF TCVAR:353 & 2
				PRINTL 「罪の数だなんて少し色気の無い話をしたわね」
				PRINTFORML %CALLNAME:MASTER%を見る目を少し緩めてパチュリーは続けた
				PRINTW 「そうね、私達が今までしてきた行為でも振り返ってみましょうか」
			;ちょっとむっとした
			ELSE
				PRINTFORML 「ふふ、%CALLNAME:MASTER%は何をバカなことを言ってるのかしら？」
				PRINTFORMW パチュリーはバシバシと本の表紙で%CALLNAME:MASTER%を叩きながら笑っている
			ENDIF
			TCVAR:353 |= 4
		;会話大成功
		ELSEIF TFLAG:193 == 1
			PRINTFORML パチュリーは饒舌になって%CALLNAME:MASTER%に話を聞かせる
			PRINTDATAW
				DATA 「精霊魔法っていうのは自分の力を精霊に伝えることで力を行使する術のことで……」
				DATA 「魔道書を読み解くにはそれなりの知識が必要になるわけだけど……」
				DATA 「図書館には外界の本もあるのだけれど大抵は役に立たないものばかりだわ……でも面白いわよ」
				DATA 「性的な知識もこの図書館ならほとんど揃っているでしょうね……場所は知らないわよ？」
			ENDDATA
		;会話大失敗
		ELSEIF TFLAG:193 <= -1
			PRINTL パチュリーと話をするが何故か会話に齟齬がある
			PRINTW 「だからそうではなくて……えーっと、なんて言ったら……」
		ELSEIF !RAND:6
			PRINTL 「小悪魔に言われるまで気が付かなかったのだけど……」
			PRINTFORML パチュリーは%CALLNAME:MASTER%へと視線を送り
			PRINTW 「本を読むのに集中しすぎるとふわふわと浮き上がる癖があったらしいわ」
		ELSEIF !RAND:5
			PRINTL 「外の世界ではバレンタインというイベントがあるそうよ。なんでも愛する人にチョコレートを送る日だとか…」
			PRINTFORML パチュリーはいたずらっぽい表情で%CALLNAME:MASTER%に微笑みかける
			PRINTW 「もちろん、私のために材料を探してチョコレートを贈ってくれるわよね？」
		ELSEIF !RAND:4
			PRINTFORML パチュリーは少し眉根を寄せて%CALLNAME:MASTER%に最近あった失敗談を聞かせる
			PRINTW 「この前読んでいた魔道書ははずれだったわ……まさかあそこまで訂正箇所が多いとは思いもしなかった」
		ELSEIF !RAND:3
			PRINTL 「私には本が無ければいけないわ。本の無い私は私ではないのだから」
			PRINTFORML %CALLNAME:MASTER%は少しだけ本のことが羨ましく思えた
			PRINTFORMW 「大丈夫、%CALLNAME:MASTER%のことも必要よ」
		ELSEIF !RAND:2
			PRINTL 「外の世界のグラビア写真集というものを見たわ……」
			PRINTW パチュリーは自分の胸を触りながら「大きくても邪魔なだけだと思うのだけれど」としみじみ言った
		ELSE
			GOTO TALKING2
		ENDIF
	;言葉が見つからない
	ELSEIF TCVAR:302
		;簡易に
		DRAWLINE
		PRINTFORML %CALLNAME:MASTER%は あー……えっと…… などと繰り返し焦り始める
		PRINTL 「……え？ あっ……うん……」
		PRINTW それに対しパチュリーも要領の得ない返事で答えた
	;うふふ解禁状態
	ELSEIF CFLAG:6 >= 2
		$TALKING2
		;怒り
		IF CFLAG:318 && TCVAR:353 != 1
			PRINTL パチュリーの頬は少し膨れているように見える
			PRINTFORMW 「%CALLNAME:MASTER%……さすがにあれはいただけないと思わなかったの？」
			TCVAR:353 |= 1
		ELSEIF CFLAG:318
			PRINTFORML パチュリーは%CALLNAME:MASTER%の方を見ようともせず話も聞いているのか分からない
			PRINTW 「…………。……はぁ」
		;会話大成功
		ELSEIF TFLAG:193 == 1
			PRINTL 「私の好み？……好みからは少し外れるけど私に無いものを持っている人は魅力的ね」
			PRINTFORML パチュリーは遠くを見ていた瞳を%CALLNAME:MASTER%に向ける
			PRINTW 「……あなたがそうなってくれるのかしら？」
		;会話大失敗
		ELSEIF TFLAG:193 <= -1
			PRINTFORML 「ねえ%CALLNAME:MASTER%、その話はどこで聞いたの？」
			PRINTL パチュリーは一見穏やかなようだが声に剣呑さが混じってる
			PRINTW 「さぁ、誰が私の過去をぺらぺらしゃべったのか教えてくれないかしら……ふっふふふ」
		ELSEIF !RAND:4
			PRINTL 「この前渡した本はどうだったかしら？」
			PRINTFORMW パチュリーは%CALLNAME:MASTER%に先日渡した本の感想を求めてきた
		ELSEIF !RAND:3
			PRINTL 「魔女達の実態に関しては何処まで話したかしら……」
			PRINTFORMW 思わず頭を抱えてしまった%CALLNAME:MASTER%に気付かずパチュリーは前回の続きから話し始めた
		ELSEIF !RAND:2
			PRINTFORML 「ねえ、%CALLNAME:MASTER%……あなたの視点から見て面白いと思う本を教えて」
			PRINTFORML %CALLNAME:MASTER%は少し考えると数冊の本のタイトルを挙げた
			PRINTW 「覚えたわ、ありがとう」
		ELSE
			PRINTL 「だから、あれは疲れるだけだと思うわ」
			PRINTFORML %CALLNAME:MASTER%はああすると収まりが良くて好きだと言う
			PRINTW 「そうね……今度確かめてみましょう」
		ENDIF
	;セクハラ解禁状態
	ELSEIF CFLAG:6 == 1
		;怒り
		IF CFLAG:318 && TCVAR:353 != 1
			PRINTL 「…………」
			PRINTFORMW %CALLNAME:MASTER%は必死で話題を探し話すがパチュリーは意に介した様子が無い
			TCVAR:353 |= 1
		ELSEIF CFLAG:318
			PRINTL 「……なんで私が怒っているのかわかっているわよね？」
			PRINTFORMW %CALLNAME:MASTER%ただただ頷くことしか出来ず嵐が過ぎ去るのを待った
		;会話大成功
		ELSEIF TFLAG:193 == 1
			PRINTFORML 「%CALLNAME:MASTER%はどんな人が好みなのかしら？」
			PRINTFORML 唐突な質問に%CALLNAME:MASTER%は焦り、パチュリーのような人と答えてしまった
			PRINTW それを聞きパチュリーは満更ではない様子で笑った
		;会話大失敗
		ELSEIF TFLAG:193 == -1
			PRINTL 「その話はそこまでにしてくれない？」
			PRINTFORML パチュリーは%CALLNAME:MASTER%の話を唐突に止めた
			PRINTW 「ごめんなさい、その話はあまり好きじゃないの」
		ELSEIF !RAND:4
			PRINTL 「私のここでの仕事？……そうね、環境の整備と妹様の管理ね」
			PRINTFORML %CALLNAME:MASTER%の質問にパチュリーはさらりと答え、続けた
			PRINTFORMW 「妹様の精神\@ TALENT:50:恋慕 ? も安定してきて # が安定の兆候を見せ始めたおかげで \@最近はそんなに大変じゃないわ」
		ELSEIF !RAND:3
			PRINTL 「そういえば、あなたは魔女というものがどういうものなのか知ってる？」
			PRINTFORML %CALLNAME:MASTER%は魔術を行使する女の人の総称ではないのかと答えた
			PRINTW 「まぁそれが一般的なものよね……そうだわ、これから魔女について講義してあげる。期間は私が飽きるまでよ」
		ELSEIF !RAND:2
			PRINTFORML 「たまには%CALLNAME:MASTER%もこんな本を読んでみない？」
			PRINTFORMW %CALLNAME:MASTER%はその本をありがたく受け取り、時間があるときに読むことを約束した
		ELSE
			GOTO TALKING1
		ENDIF
	;それ以外
	ELSE
		$TALKING1
		;怒り
		IF CFLAG:318 && TCVAR:353 != 1
			PRINTL 「あなた……人を怒らせるのが得意なのかしら？」
			PRINTFORMW パチュリーは瞳の奥に静かな炎を湛え、%CALLNAME:MASTER%を見た
			TCVAR:353 |= 1
		ELSEIF CFLAG:318
			PRINTL 「……。……………そう」
			PRINTFORMW パチュリーは%CALLNAME:MASTER%の話が途切れるたびに冷ややかな視線を送った
		;会話大成功
		ELSEIF TFLAG:193 == 1
			PRINTL 「へぇー興味を惹く話ね」
			PRINTFORMW パチュリーは%CALLNAME:MASTER%に先を促した
		;会話大失敗
		ELSEIF TFLAG:193 == -1
			PRINTL 「……その話、いつまで続くの？」
			PRINTW パチュリーはあくびをかみ殺し、とても退屈そうだ
		ELSEIF !RAND:4
			PRINTL 「最近またネズミの被害が酷くなってきてるわ……」
			PRINTW パチュリーはため息を吐きつつどうにかしなさいと言ってきた
		ELSEIF !RAND:3
			PRINTFORML %CALLNAME:MASTER%とパチュリーは顔を突き合せて一つの本を見ていた
			PRINTFORMW 「うーん……違う視点の意見も欲しかったのに見解が一緒になるのは意外だわ…」
		ELSEIF !RAND:2
			PRINTFORML 「%CALLNAME:MASTER%はどんな本が好みなのかしら？」
			PRINTFORMW パチュリーは%CALLNAME:MASTER%の興味のある本を聞くと関連書籍のある棚も教えた
		ELSE
			PRINTL 「話し方でその人の頭の回転の程度が分かるみたいね」
			PRINTFORMW 普段読んでいる本より縦に長い本を読みながらパチュリーは独り言かのように%CALLNAME:MASTER%へと言った
		ENDIF
	ENDIF
ENDIF
RETURN 1
;==================================================
;301,お茶を淹れる
;==================================================
@M_KOJO_MESSAGE_COM_K54_301
CALL M_KOJO_MESSAGE_COM_K54_301_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K54_301_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
;初めて
IF FIRSTTIME(SELECTCOM)
	PRINTL 「……あまり美味しくないわね」
	PRINTFORML \@ CFLAG:1003 ? パチュリー # 紫色の髪をした少女 \@は端的に美味しくないことを%CALLNAME:MASTER%に告げた
	PRINTFORMW 「\@ CFLAG:現在位置 == 310 ? そこ # 図書館 \@にお茶の入れ方の本があるから持っていっていいわ」
;美味しかった
ELSEIF TFLAG:193 == 1
	PRINTL 「あら、これは美味しいわ……満点の96点をあげるわ」
	PRINTL パチュリーはとても満足そうにカップを傾けていく
	SIF CFLAG:1004 <= 20
		PRINTL 「この感覚を覚えていつでもこれを出せるように努力して」
	WAIT
;不味い
ELSEIF TFLAG:193 == -1
	PRINTL 「これは……いくらなんでも酷すぎるわ」
	PRINTFORML パチュリーは一口飲んだカップをそのまま突き返し%CALLNAME:MASTER%にも飲ませた
	PRINTL 「ね？美味しくないでしょ？」
	SIF TALENT:恋慕
		PRINTFORML %CALLNAME:MASTER%はお茶は不味かったがパチュリーの飲みかけは美味しかったと言うとパチュリーは顔を真っ赤に染めた
	WAIT
;恋慕(愛でカバーされました)
ELSEIF TALENT:恋慕
	PRINTFORML 「%CALLNAME:MASTER%と一緒にお茶を飲むのは格別ね」
	PRINTL パチュリーは両手でカップを包み込み、少しずつ傾けていく
	IF CFLAG:1004 <= 20
		PRINTW 「これでもう少し美味しければ全く文句は無いわね……アドバイスならいくらでもしてあげるわ」
	ELSE
		PRINTW 「美味しいものを大好きな人と一緒にいただけるのが……こんなに幸せなことだとは思ってもいなかったわ」
	ENDIF
;まだまだ好みが分かっていない
ELSEIF CFLAG:1004 <= 10
	PRINTFORML 「ん……{27 + RAND:3 * CFLAG:1004}点、まだまだね」
	PRINTFORML \@ CFLAG:1003 ? パチュリー # 紫色の髪をした少女 \@は%CALLNAME:MASTER%の淹れたお茶を一口飲むと即座に評価を下した
	SIF CFLAG:1004 == 5
		PRINTL 「咲夜にも教えてもらうといいわよ」
	WAIT
;好みが分かってきた
ELSEIF CFLAG:1004 <= 20
	PRINTFORML 「……{53 + RAND:3 * (CFLAG:1004 / 2)}点、まあまあ美味しくなったわ」
	PRINTFORML %CALLNAME:MASTER%をまっすぐ見てパチュリーは言う
	PRINTFORMW 「茶葉の量は適切になってるわ。あとは蒸らし時間の見極めだけ\@ CFLAG:1004 == 15 ? ……頑張りなさい # \@」
;好みと合致
ELSE
	PRINTL 「うん、美味しいわ」
	PRINTFORML %CALLNAME:MASTER%はパチュリーの評価をありがたく受け入れた
	PRINTW 「あとは安定してこの味が飲めるようになるといいわね」
ENDIF
CFLAG:1004 ++
TCVAR:354 = 1
ENDIF
RETURN 1
