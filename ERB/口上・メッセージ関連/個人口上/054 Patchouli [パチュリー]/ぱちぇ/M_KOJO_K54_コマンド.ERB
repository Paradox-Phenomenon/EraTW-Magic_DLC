	;告白が成功してる
	ELSEIF CFLAG:1 == 1
		PRINTL 「あっ……そうよね、一応恋人なんだしキスくらいは普通よね」
		PRINTFORML パチュリーは%CALLNAME:MASTER%の恋情を受け入れたことを実感しているようだ
		SIF ABL:9 >= 4
			PRINTL 「もう一度……する？」
		WAIT
	;弱味で押し倒されて中
	ELSEIF CFLAG:1 == 2 && CFLAG:317
		SELECTCASE TCVAR:20
			;キス
			CASE 30,60
				PRINTW 「んん～っ……実験台なのにいい度胸ね」
			;ソフトな感じ
			CASE 31 TO 33
				PRINTW 「……っちゅ ああ、そういうのがよかったか」
			;愛撫
			CASE 34,50
				PRINTW 「ゅちぅ……私がこれだけしてるのにキスまでするなんて贅沢だと思わない？」
			CASEELSE
				PRINTW 「あっぅちゅ……実験台は動かないで」
		ENDSELECT
	;告白無しで押し倒されたことがある
	ELSEIF CFLAG:1 == 2
		PRINTL 「あっ……えっと……何かの実験かしら？」
		PRINTFORMW パチュリーは%CALLNAME:MASTER%と交わされた唇を触れながら少し困った表情で尋ねてきた
	;告白成功で押し倒され中
	ELSEIF CFLAG:1 == 3 && CFLAG:317
		SELECTCASE TCVAR:20
			;キス
			CASE 30,60
				PRINTW 「んん～っ……んっキスって暖かいわね」
			;ソフトな感じ
			CASE 31 TO 33
				PRINTW 「……っちゅ あ、キスでもよかったのね」
			;愛撫
			CASE 34,50
				PRINTFORMW 「ちぅ……%CALLNAME:MASTER%とキスまでできるなんて贅沢ね」
			CASEELSE
				PRINTW 「あっ ぅちゅ……うん、キスもいいわね」
		ENDSELECT
	;告白成功でうふふに突入したことがある
	ELSEIF CFLAG:1 == 3
		;キス経験あり
		IF EXP:27
			PRINTL 「そういえばこんな風に何の変哲も無いときにキスってしたことが無かったわね……」
			PRINTFORML %CALLNAME:MASTER%は思い返し同意した
			PRINTW 「……記念にもう一回しましょう」
		ELSE
			PRINTL 「私の初めてよ……」
			PRINTFORML パチュリーは顔を赤く染め、%CALLNAME:MASTER%から目を逸らしつつ言った
			PRINTL 「悪かったわね、100年以上も生きてるのにキスもしたことが無くて」
			PRINTFORMW でも%CALLNAME:MASTER%に捧げられてよかったとパチュリーは嬉しそうに続けた
		ENDIF
	;告白してもいないけど親密だったので思わず…
	ELSEIF ABL:9 >= 7
		PRINTL 「っん！？　……えっと……私、初めてなんだけど……」
		PRINTFORML %CALLNAME:MASTER%はパチュリーを見ていたらいつの間にかしていたと言い訳にもならない弁解をした
		IF BASE:ムード >= 800
			PRINTW 「……いいわ、許してあげる」
		ELSE
			PRINTW 「はぁ……もっとムードとかを考えて欲しかったわ」
		ENDIF
	;その他
	ELSE
		PRINTL 「……サカってるの？そういうのは他の相手を見つけて頂戴」
		PRINTFORMW パチュリーは半目で%CALLNAME:MASTER%を見たがすぐに本へと興味を移した
	ENDIF
;恋慕
ELSEIF TALENT:恋慕
	;押し倒され中
	IF CFLAG:317
		SELECTCASE TCVAR:20
			;キス
			CASE 30,60
				IF RAND:2
					PRINTW 「あむちゅ……んぁ 大好き」
				ELSE
					PRINTW 「んんんっ……ふあみゅ」
				ENDIF
			;後ろから抱きつかれた
			CASE 31
				PRINTFORML %CALLNAME:MASTER%が肩越しにパチュリーを見るとパチュリーはそれを察し唇を寄せた
				PRINTW 「あふぁ……んっむゅ……」
			;前から
			CASE 32
				PRINTFORML %CALLNAME:MASTER%はパチュリーの頬に口付けをするとパチュリーは唇へとそれを促した
				PRINTW 「……はちゅ……んれちゅ……」
			;胸を揉ませる
			CASE 33
				IF RAND:2
					PRINTW 「ふゃっ…んんっ…おっぱいもお口もとろけそう」
				ELSE
					PRINTFORMW 「あふっぁ……んぁぅ…%CALLNAME:MASTER%の指も口も好き…」
				ENDIF
			;愛撫系
			CASE 34,50
				PRINTFORMW 「むちゅ…ぁふふっ、キスが気持ち良さで震えてたわよ」
			CASEELSE
				PRINTFORMW 「ちゅむ……%CALLNAME:MASTER%とのキスはいつでも嬉しいわ」
		ENDSELECT
	;大成功
	ELSEIF TFLAG:193 == 1
		PRINTL 「んっ…ぺちぅっ…れちゃ……」
		PRINTFORML %CALLNAME:MASTER%とパチュリーは相手の唾液をむさぼるようにキスを深くしていく
		PRINTW 「もっと……もっんんんぅー」
	;失敗
	ELSEIF TFLAG:193 == -1
		PRINTFORML %CALLNAME:MASTER%とパチュリーが唇をねぶる様に擦り合わせていると突如血の味が混ざった
		PRINTW 「あむっ…あ、あはは…唇が切れちゃったわ」
	ELSEIF !RAND:4
		PRINTL 「ちゅぴっ…んあ…ちゅっ……」
		PRINTFORMW %CALLNAME:MASTER%とパチュリーは互いに顔を傾けあい、舌で相手の口唇を確かめるようになぞった
	ELSEIF !RAND:3
		PRINTL 「…はちむゅ……あむぅ…」
		PRINTFORML パチュリーと%CALLNAME:MASTER%は相手の唇を優しく食み、舌を唇で扱くように快感を交わした
		PRINTW 「むきゅぅ……」
	ELSEIF RAND:2
		PRINTL 「ん、唇へのキスは幸せの証ね」
		PRINTFORMW パチュリーは%CALLNAME:MASTER%に抱かれながらもっととねだるように口を寄せた
	ELSE
		PRINTFORML 「ちゅ…%CALLNAME:MASTER%…んっ…%CALLNAME:MASTER%…大好き」
		PRINTFORML パチュリーは言葉だけでは表せない気持ちをキスを交えて%CALLNAME:MASTER%に伝えた
		PRINTW 「きゅむ……ぎゅってして……ふちゅぁ」
	ENDIF
;うふふ中(と言うか押し倒されてる)
ELSEIF CFLAG:317
	SELECTCASE TCVAR:20
		;キス
		CASE 30,60
			PRINTW 「んぁ……キス、好きなのね」
		;ソフトなの
		CASE 31 TO 33
			PRINTW 「あふぅ……んちゅ……」
		;愛撫系
		CASE 34,50
			PRINTW 「ん……お口を喜ばせるのが得意なのね……」
		CASEELSE
			PRINTFORMW 「%CALLNAME:MASTER%とのキス……癖になりそうだわ」
	ENDSELECT
;うふふ解禁状態
ELSEIF CFLAG:6 >= 2
	;大成功
	IF TFLAG:193 == 1
		PRINTL 「んぁは……ぅん やっぱりそうね」
		PRINTL パチュリーは唇を離し言う
		PRINTFORMW 「%CALLNAME:MASTER%とのキスって麻薬みたいだわ」
	;失敗
	ELSEIF TFLAG:193 == -1
		PRINTL 「うぐ、ちょっと押し付けすぎよ」
		PRINTFORMW %CALLNAME:MASTER%の胸を押し、離した唇を押さえパチュリーは少し眉根を寄せながらいった
	ELSEIF !RAND:4
		PRINTFORML 「ん、%CALLNAME:MASTER%……」
		PRINTFORMW パチュリーは少しだけ唇を突き出し%CALLNAME:MASTER%にキスを促した
	ELSEIF !RAND:3
		PRINTL 「ちゅっ……んっちょっとむさぼり過ぎじゃない……？」
		PRINTFORMW %CALLNAME:MASTER%は普通じゃないのかと返すとパチュリーもそうかしら？と二人は体を密着させたまま首を捻った
	ELSEIF !RAND:2
		PRINTFORML パチュリーは%CALLNAME:MASTER%から唇を離すとふっと微笑み言った
		PRINTW 「ちょっと強引ね……もう少し優しく出来ないのかしら」
	ELSE
		PRINTL 「ぢゅ……っぱ、あう……」
		PRINTFORML パチュリーは少し惚けた目で%CALLNAME:MASTER%を見る
		PRINTW 「唇を合わせてるだけなのに……快感があるのね」
	ENDIF
;それ以外
ELSE
	;大成功
	IF TFLAG:193 == 1
		PRINTL 「あふっ……っ！？ ち、違うのよ、ちょっと気持ちいいかなって思っただけなの」
		PRINTL パチュリーは自分の出した甘い声に必死に弁解にならない弁解をした
		PRINTW 「ニヤニヤするな！」
	;失敗
	ELSEIF TFLAG:193 == -1
		PRINTL 「んぐっ……げほっげほっ」
		PRINTFORMW パチュリーは%CALLNAME:MASTER%からの突然のキスに驚き、咳き込んでしまった
	;親密4以上
	ELSEIF ABL:9 >= 4
		IF RAND:2
			PRINTL 「……っちゅ、あう」
			PRINTFORMW パチュリーはうつむき、%CALLNAME:MASTER%から赤く染まった顔を隠した
		ELSE
			PRINTL 「キスしたいの？……そうね、あ むゅ……」
			PRINTFORMW %CALLNAME:MASTER%は何かを言いかけたパチュリーの口を自分の口で塞いだ
		ENDIF
	;その他(たぶんこの辺は出ないような気がする)
	ELSE
		IF RAND:2
			PRINTFORML 「ぐっん……%CALLNAME:MASTER%……いい加減、他を探して」
			PRINTFORMW パチュリーは怒気を纏い、いきなりキスをした%CALLNAME:MASTER%を睨みつけた
		ELSE
			PRINTL 「むぐ…………はぁ」
			PRINTFORMW パチュリーは一瞬%CALLNAME:MASTER%を睨むと興味を失ったかのように手元の本を読み始めた
		ENDIF
	ENDIF
ENDIF
ENDIF
RETURN 1
