				IF RAND:2
					PRINTFORMW %CALLNAME:MASTER%はとりあえず聞かなかったことにした
				ELSE
					PRINTFORMW %CALLNAME:MASTER%は胸から顔を離すとパチュリーを抱きなおし、今度は\@ TALENT:100 <= TALENT:MASTER:100 ? 髪 # おへそ \@の香りを堪能した
				ENDIF
			;手淫系
			CASE 34,50
				IF RAND:2
					PRINTL 「そんなに強く抱きしめたら気持ちよく出来ないわよ」
					PRINTFORML パチュリーにそう言われ%CALLNAME:MASTER%は思わずパチュリーを抱く腕を緩めた
					PRINTW 「あら、あははは　うん、気持ちよくしてあげるわね」
				ELSE
					PRINTFORML パチュリーは%CALLNAME:MASTER%の胸に顔を摺り寄せ、更に指を絡めるように撫で上げてくる
					PRINTW 「もっともっと気持ちよくしてあげるわ……」
				ENDIF
			;その他
			CASEELSE
				PRINTFORMW 「むきゅ、もう……%CALLNAME:MASTER%ったら、強すぎよ」
		ENDSELECT
	;大成功
	ELSEIF TFLAG:193 == 1
		PRINTL 「抱きしめるだけ？」
		PRINTFORML パチュリーの上目遣いの催促に%CALLNAME:MASTER%は
		PRINTL 
		PRINTLC [0] キスをする
		PRINTLC [1] 額にちゅー
		PRINTLC [2] 見なかったことにする
		TINPUT 10000,3,0
		IF !RESULT
			PRINTFORML %CALLNAME:MASTER%はパチュリーと口付けをした
			PRINTW 「ちゅ…んっ…大好きよ」
			EXP:MASTER:27 += 1
			EXP:27 += 1
		ELSEIF RESULT == 1
			PRINTL パチュリーの前髪をかき上げ額へとキスをした
			PRINTW 「はぁ…もうちょっと下にして欲しかったんだけどなぁ…」
		ELSEIF RESULT == 2
			PRINTFORML %CALLNAME:MASTER%は見なかったことにしてパチュリーを強く抱きしめた
			PRINTW 「んっ もう！意気地なし……」
		ELSE
			PRINTL 「優柔不断ね……んっ」
			PRINTFORMW パチュリーは%CALLNAME:MASTER%の顔を引き寄せるとそのままキスをした
			EXP:MASTER:27 += 1
			EXP:27 += 1
		ENDIF
	;失敗
	ELSEIF TFLAG:193 == -1
		PRINTFORML %CALLNAME:MASTER%がパチュリーを抱きしめしばらく経つと、どこからかヒューヒューという高い音が聞こえてきた
		PRINTFORML 変な音が聞こえないかとパチュリーに問おうと抱く腕を少し緩めると、パチュリーは%CALLNAME:MASTER%の服の裾を握り締めながら崩れてしまった
		PRINTL どうやら喘息の症状が出てしまったらしい
		PRINTFORMW %CALLNAME:MASTER%はパチュリーを楽な姿勢にさせると急ぎ、薬を取り出し吸引させた
		;時間経過の追加
		TIME += 10
	ELSEIF !RAND:5
		PRINTL 「んっ……いいにおい」
		PRINTFORML %CALLNAME:MASTER%は\@ DAY * 1440 + TIME - CFLAG:MASTER:314 >= 480 ? 汗臭く # 埃っぽく \@ないかと問う
		PRINTW 「そんなこと気にするよりも もっと強く抱きしめて」
	ELSEIF !RAND:4
		PRINTL 「後ろから抱きしめられると私が抱き返せないんだけど……」
		PRINTFORML %CALLNAME:MASTER%は慌てて腕の力を緩めようとするとパチュリーはその腕を抱きしめ、体重を預けてくる
		PRINTW 「やっぱりこのままでいいわ……」
	ELSEIF !RAND:3
		PRINTL 「……横抱きってどんな感じなのかしら？」
		PRINTFORM パチュリーの呟きに%CALLNAME:MASTER%は
		IF TALENT:100 <= TALENT:MASTER:100
			PRINTL 調子に乗ってパチュリーをお姫様抱っこした
			PRINTL 「ひゃっ いきなり持ち上げられたらビックリするに決まってるじゃない！」
		ELSE
			PRINTL ふわふわした感じなんじゃないのかな？と答えた
		ENDIF
		WAIT
	ELSEIF !RAND:2
		PRINTL 「あっ…ちょっと待って…」
		PRINTFORML パチュリーは%CALLNAME:MASTER%から一旦離れ、背を向けると何かごにょごにょして振り返った
		PRINTL 「うん、いいわよ」
		PRINTFORMW そういうと両手を広げ%CALLNAME:MASTER%を迎え入れるように抱きついた
	ELSEIF CFLAG:溜まってる度 < 300
		PRINTFORML パチュリーは抱きしめる%CALLNAME:MASTER%に体を預け、力を抜いた
		PRINTW 「あったかくて……なんだか眠くなってきちゃった……」
	ELSE
		PRINTL 「横から抱きつかれるのはなんだか新鮮ね」
		PRINTFORMW %CALLNAME:MASTER%は堪らなくなりパチュリーの頬にキスをした
	ENDIF
;うふふ中(と言うか押し倒されてる)
ELSEIF CFLAG:317
	SELECTCASE TCVAR:20
		;(ディープ)キス
		CASE 30,60
			PRINTL 「あふ……」
			PRINTFORMW %CALLNAME:MASTER%がパチュリーを抱きしめると息が漏れ、それを飲み込むようにキスを深くした
		;抱きつかれた
		CASE 31,32
			PRINTL 「ふふっ抱きしめ返してくれるんだ……」
			PRINTFORMW %CALLNAME:MASTER%が抱き返すとパチュリーの抱きしめる力も少し強くなった
		;手淫系
		CASE 34,50
			PRINTW 「そんなに強く抱きしめちゃって……気持ちがいいのかしら」
		CASEELSE
			;告白成功してる
			IF CFLAG:1 & 1
				PRINTW 「もっと強くしてもいいわよ……」
			ELSE
				PRINTW 「押し倒されても抱きしめてくれる程度には好かれてるのね」
			ENDIF
	ENDSELECT
;うふふ解禁状態
ELSEIF CFLAG:6 >= 2
	;大成功
	IF TFLAG:193 == 1
		PRINTL 「うん……もっと優しく抱きしめて」
		PRINTFORMW パチュリーは%CALLNAME:MASTER%の服をぎゅっと握って顔を胸に埋めてきた
	;失敗
