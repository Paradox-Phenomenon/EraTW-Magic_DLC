@M_KOJO_MESSAGE_COM_K54_302_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
;初めて
IF FIRSTTIME(SELECTCOM)
	PRINTL 「……っ！？いきなり何？……それ以上触ると怒るわ」
	IF CFLAG:現在位置 == 333
		PRINTFORML 警戒するパチュリーに%CALLNAME:MASTER%は背中を流すだけだと言った
		SIF !CFLAG:6
			PRINTL 「……(変なことをしたら燃やせばいいだけね)……お願いするわ」
		WAIT
	ENDIF
;大浴場
ELSEIF CFLAG:現在位置 == 333
	;恋慕
	IF TALENT:恋慕
		PRINTFORML パチュリーは%CALLNAME:MASTER%に振り返り抱きついた
		PRINTW 「次は私が隅から隅まで流してあげるわ」
	;失敗
	ELSEIF TFLAG:193 == -1
		PRINTL 「……もういいわ。強かったり弱かったりでなんだか雑念が多いみたいね」
		PRINTFORMW パチュリーは%CALLNAME:MASTER%からスポンジを取り上げ自分で体を洗い流し始めた
	;うふふ解禁状態
	ELSEIF CFLAG:6 >= 2
