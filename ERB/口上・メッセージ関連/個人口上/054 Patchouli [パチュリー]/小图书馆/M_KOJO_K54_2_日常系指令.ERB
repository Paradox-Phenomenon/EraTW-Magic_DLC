;850摆脱  由于没有专门的指令所以就自己写了
;-------------------------------------------------
@M_KOJO_小图书馆_SUCCESS_COM_K54_850
IF TCVAR:54:350 == 1
	SELECTCOM = -1
	SIF PREVCOM == SELECTCOM
	SELECTCOM = -2
	;锁定摆脱
	IF FIRSTTIME("初次尝试挣脱")
		PRINTFORML 『THE WORLD』！
		PRINTFORML 不行被捆着根本做不出任何行动
		PRINTFORML 『绯红之王』！
		PRINTFORML 也不行即使是删除了时间肉体依旧无法挣脱这个藤蔓，这就是魔法吗？
		PRINTFORML 可恶！人类的身体还是太弱了
		PRINTFORML 那么只能……
		PRINTFORML 『败者……！』
		PRINTFORML 在%CALLNAME:MASTER%思考挣脱的过程时藤蔓已不知何时将%CALLNAME:MASTER%的手部给完全包裹住
		PRINTFORML 由于手部被缠绕住%CALLNAME:MASTER%完全无法按下大拇指来发动败者食尘，只能任由帕秋莉摆弄
		PRINTFORMW 最后在这种情况下%CALLNAME:MASTER%停止了思考
	ELSEIF ABL:54:16 >= 99;整活向对睿佬帮助所塞的彩蛋正常人应该是刷不出来的
		PRINTFORML 「你什么时候产生了你要摆脱我，而不是更加抱紧我的错觉！」
		PRINTFORML 「桀桀桀，你逃不出魔女的掌控的」
		PRINTFORMW 「现在来更多的取悦我吧！」
	ELSE
		PRINTFORML 都说了挣脱不了不要费劲了
		PRINTFORML 好好享受被性侵的感觉吧
		PRINTFORMW 早知道自机也会被雷普……
	ENDIF
ENDIF
IF TCVAR:54:351 == 1
	SELECTCOM = -1
	SIF PREVCOM == SELECTCOM
	SELECTCOM = -2
	CFLAG:MASTER:317 = 2
	CFLAG:54:317 = 2
	;锁定摆脱
	PRINTFORML 想摆脱的时候被帕秋莉死死抱住
	PRINTFORML 眼神中充斥着情欲
	PRINTFORMW 刚想说明自己是真的累了就又被重新按倒在了地上
ENDIF
;-------------------------------------------------------------------------------------
;491:白色情人节 
;TFLAG:193(0=回礼礼品制作 1～7=礼品种类
;CFLAG:バレンタイン(1～4= 从对方手上收到的礼品 +100已经赠送了回礼品，除了周回之外不会重置标志
;可恶为什么我的模板里没有！愤怒了！
;-------------------------------------------------------------------------------------
@M_KOJO_小图书馆_MESSAGE_COM_K36_491
;白色情人節にTRAIN_MESSAGEはない
CALL M_KOJO_小图书馆_MESSAGE_COM_K36_491_1
RETURN RESULT

@M_KOJO_小图书馆_MESSAGE_COM_K36_491_1
LOCAL = 0
;-------------------------------------------------
IF LOCAL
	SELECTCASE TFLAG:193
		CASE 0
			IF TALENT:54:7;恋人
				PRINTFORML 「嗯？是在给我准备回礼吗？」
				PRINTFORMW 「哼哼~那%CALLNAME:MASTER%可要好好准备呀」
			ELSEIF TALENT:54:3;恋慕
				PRINTFORML 「是在准备回礼吗？」
				PRINTFORML 「……意外很认真嘛」
				PRINTFORML （会有我的吗？）
				PRINTFORML 『帕琪很期待吗』
				PRINTFORML %CALLNAME:MASTER%突然的提问让帕秋莉措手不及了起来
				PRINTFORMW 「说什么呢！谁会在意%CALLNAME:MASTER%的礼物」
			ELSE
				PRINTFORML 「是打算送给谁吗？」
				PRINTFORML 「居然有人被%CALLNAME:MASTER%缠上了」
				PRINTFORMW 「真是不幸」
			ENDIF
		CASE 1
		;黑雷神巧克力
			IF TALENT:54:7;恋人
				PRINTFORML 「……你就给我这个？」
				PRINTFORML 『咳嗯！没办法忘记准备材料了』
				PRINTFORML 『不过下次！下次一定好好给帕琪回礼！』
				PRINTFORML 「不准再有下次了」
				PRINTFORML 「今天%CALLNAME:MASTER%得好好[补偿]我」
				PRINTFORMW 说着帕秋莉看着%CALLNAME:MASTER%舔舐了一下自己的嘴角
			ELSEIF TALENT:54:3;恋慕
				PRINTFORML 「……就只有这个？」
				PRINTFORML 『对不起啊……帕琪』
				PRINTFORML 『实在是没材料了』
				IF CFLAG:54:383 == 4
					PRINTFORML （那我付出的心血算什么）
					PRINTFORML 帕秋莉呆愣的看着眼前的回礼
					PRINTFORMW 说不出由来的心痛涌上心间
				ELSEIF CFLAG:54:383 == 3
					PRINTFORML 「不求%CALLNAME:MASTER%做多好但起码要等价值吧」
					PRINTFORMW 帕秋莉失望的看着你
				ELSE
					PRINTFORMW （……也是毕竟我也没送多好的）
				ENDIF
			ELSE
				PRINTFORML 「很普通啊……」
				PRINTFORML 「嘛也是」
				PRINTFORMW 「毕竟我跟%CALLNAME:MASTER%也没那么熟」
			ENDIF
		CASE 2
		;跳蛋巧克力
			IF TALENT:54:7;恋人
				PRINTFORML 「又做这种奇形怪状的巧克力……」
				PRINTFORML 「而且根本就是jj的形状吧……（小声）」
				PRINTFORML 「想、想看我吃下去？！」
				PRINTFORML 帕秋莉为难的吃了一口
				SIF TALENT:54:0 == 0
				PRINTFORML 「怎么味道都和%CALLNAME:MASTER%的一样啊……」
				SIF TALENT:54:0 == 1
				PRINTFORML 「哕……好难吃」
			ELSEIF TALENT:54:3;恋慕
				PRINTFORML 「好、好奇怪」
				PRINTFORML 「绝对不会好吃的吧」
				PRINTFORMW 「死也不吃」
			ELSE
				PRINTFORML 「送我这个？」
				PRINTFORML 「恶趣味吗……」
				PRINTFORML 「是想看我吃下什么反应吗」
				PRINTFORML 「不过很可惜我是不会吃的」
				PRINTFORMW 帕秋莉当着%CALLNAME:MASTER%的面把巧克力丢到了垃圾桶里
			ENDIF
		CASE 3
		;WD巧克力
		;まだ無い？
		CASE 4
		;手制巧克力曲奇
			IF TALENT:54:7;恋人
				PRINTFORML 「特地给我准备的吗？」
				PRINTFORML 「还专门符合我口味嘛~」
				PRINTFORML 帕秋莉叼着其中一块曲奇引诱着%CALLNAME:MASTER%
				PRINTFORML 「%CALLNAME:MASTER%也来尝尝吧~」
				PRINTFORML 狠狠品尝了帕秋莉牌曲奇
				PRINTFORMW 「哈♥~真美味~」
			ELSEIF TALENT:54:3;恋慕
				PRINTFORML 「呀♪相当不错啊」
				PRINTFORML 「是%CALLNAME:MASTER%亲手做的吗」
				PRINTFORML 「还设计那么多形状，很细心啊」
				PRINTFORML 帕秋莉挑选了一个书本形状的曲奇放在嘴中品尝了起来
				PRINTFORMW 「嗯~很好吃」
			ELSE
				PRINTFORML 「意外的很细心嘛」
				PRINTFORMW 「我就心怀感激的收下了~」
			ENDIF
		CASE 5
		;WD布丁
		;まだ無い？
		CASE 6
		;手制布丁 
			IF TALENT:54:7;恋人
				PRINTFORML 「来一起吃吧」
				PRINTFORML 帕秋莉主动挖了一勺布丁给%CALLNAME:MASTER%
				PRINTFORML 甜丝丝的呢！
				PRINTFORMW 和帕秋莉一人一口把布丁吃完了
			ELSEIF TALENT:54:3;恋慕
				PRINTFORML 「送我的吗」
				PRINTFORML 「嗯嗯~很美味啊」
				PRINTFORMW 「%CALLNAME:MASTER%还是努力了一番嘛」
			ELSE
				PRINTFORML 「布丁嘛……」
				PRINTFORML 「还不错~」
				PRINTFORMW 「看来%CALLNAME:MASTER%在甜食上还是有所建树的嘛」
			ENDIF
		CASE 7
		;装饰蛋糕
			IF TALENT:54:7;恋人
				PRINTFORML 「给我准备的吗？」
				PRINTFORML 「真贴心啊%CALLNAME:MASTER%」
				PRINTFORML 「需要好好奖励%CALLNAME:MASTER%呢~」
				PRINTFORMW 「晚上……来我房间吧♥」
			ELSEIF TALENT:54:3;恋慕
				PRINTFORML 「这是……！」
				PRINTFORML 『怎么样！符不符合心意！』
				PRINTFORML 「咳！只是蛋糕罢了」
				PRINTFORML 「咲夜做的可比%CALLNAME:MASTER%好多了……」
				PRINTFORML 『唉……那我送给别人好了』
				PRINTFORML 「不行！」
				PRINTFORML 帕秋莉一把护在蛋糕前
				PRINTFORML 「送了可就不能收回去了哦！」
				PRINTFORML 『好好好~』
				PRINTFORML 「哼……」
				PRINTFORMW 仔细品尝其中蕴含的心意，帕秋莉不自觉的露出了一抹笑容
			ELSE
				PRINTFORML 「哇……给我送这么好的吗」
				SIF TALENT:MASTER:7
				PRINTFORML 「不怕你女朋友知道生气吗」
				PRINTFORML 「没想能收到这么细心的回礼啊」
				PRINTFORMW 「之后回礼可不好办了啊……」
			ENDIF
	ENDSELECT
ENDIF
RETURN 1

