		;启用（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1 && !ARG:1
			PRINTFORMW 
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;地点在MASTER私室，TARGET在此处睡着了(没有恋慕导致此情况也有可能，比如说无家可归之人
		;启用（=0, 非表示、1, 表示）
