;80,手淫
;==================================================
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_MESSAGE_MESSAGECHECK_COM_K107_80
RETURN 0

@M_KOJO_MESSAGE_COM_K107_80
CALL M_KOJO_MESSAGE_COM_K107_80_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K107_80_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		PRINTFORML 「用手…摩擦吗…？知道了…来吧！」
		PRINTFORMDL 顷刻间，%CALLNAME:MASTER%的阴茎传来剧痛…！
		PRINTFORML 「对、对不起！……疼吗？没事吧？」
		PRINTFORMW 「轻柔一点…慢慢地…慢慢地…！」
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		PRINTFORMW 
		RETURN 1
	;技巧３以上
	ELSEIF ABL:技巧 >= 3
		;今射精した
		IF NOWEX:PLAYER:11
			SELECTCASE RAND:3
				CASE 0
					CALL HPH_PRINT,@"「阴茎膨胀起来了HPH看来，快射了HPH」","L"
					PRINTFORMDL 察觉到射精即将来临，清兰加快了套动的速度。
					PRINTFORMDL 将自己的高潮交给他人，这种感觉实在难以言喻…！
					CALL HPH_PRINT,@"「快点快点HPH快射出来HPH射出来啊HPH」","W"
					
				CASE 1
					CALL HPH_PRINT,@"「啊…HPH嗯HPH嗯嗯…HPH精液…好多…HPH」","L"
					PRINTFORMDL 从%CALLNAME:MASTER%的阴茎射出的大量精液弄脏了清兰的手…！
					CALL HPH_PRINT,@"「呵呵…HPH有点可惜…HPH 嗯…吮吸吮吸HPH」","L"
					PRINTFORMDL 清兰毫无怨言地舔食着沾满手掌的精液…
					CALL HPH_PRINT,@"「没关系的…♪ 是%CALLNAME:MASTER%的嘛HPH」","W"
				CASE 2
					CALL HPH_PRINT,@"「啊…HPH 阴茎…要射了吗？…好的…♪」","L"
					PRINTFORMDL 清兰稍稍用力握住阴茎，加快动作以引发射精。
					CALL HPH_PRINT,@"「%CALLNAME:MASTER%啊HPH快射出来HPH 射出满是污秽的精子HPH」","W"
			ENDSELECT
			RETURN 1
		;其他情况
		ELSE
			SELECTCASE RAND:3
				CASE 0
					CALL HPH_PRINT,@"「%CALLNAME:MASTER%…HPH感觉如何？舒服吗？」","L"
					CALL HPH_PRINT,@"「自己做和我帮忙…哪个更喜欢呢…？HPH」","L"
					PRINTFORMDL 就算自己用手自慰，也无法获得如此快感吧…
					PRINTFORMDW 当说出"清兰的手更好"时，清兰兴奋地颤抖着身体…！
					
				CASE 1
					CALL HPH_PRINT,@"「阴茎，这么硬想要…HPH你到底蓄积了多少污秽啊HPH」","L"
					CALL HPH_PRINT,@"「坏阴茎…我会帮你净化的HPH」","L"
					PRINTFORMDW 清兰用手套动着阴茎，进行着"净化活动"…
				CASE 2
					PRINTFORML 「嘿%CALLNAME:MASTER%…舒服吗？」
					CALL HPH_PRINT,@"「想射精的话，随时告诉我HPH」","W"
			ENDSELECT
			RETURN 1
		ENDIF
	;それ以外
	ELSE
		;今射精した
		IF NOWEX:PLAYER:11
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「诶…要射了！？等、等一下！纸巾―啊！！」
					PRINTFORMDL 尽力忍住却来不及，精液溅在清兰的脸和头发上……
					PRINTFORMW 「呜呀～！沾到精液了…！……好臭啊…！」
				CASE 1
					PRINTFORML 「阴茎，膨胀了…！要射了吗？」
					PRINTFORML 「再快点吗…？ 嗯，知道了…！」
					PRINTFORMDL 朝着高潮迈进，清兰加快了套动的速度…不久%CALLNAME:MASTER%达到了极限―
					PRINTFORMW 「哇、哇！好厉害…！精液原来会这样喷射出来……」
				CASE 2
					PRINTFORML 「啊…！射精了……嗯！呜呜…！…精液沾到手上了……」
					PRINTFORMW 「…………。」
					CALL HPH_PRINT,@"「……舔舔HPH …味道好厉害…HPH」","W"
			ENDSELECT
			RETURN 1
		;其他情况
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「轻柔地…轻柔地…慢慢地…慢慢地…！」
					PRINTFORMDW 清兰小心翼翼地触摸着%CALLNAME:MASTER%的阴茎……让人心痒痒的感觉…！
				CASE 1
					PRINTFORML 「含着口水……嗯……用手摩擦…摩擦…！」
					PRINTFORMDL 清兰用笨拙的动作套动着%CALLNAME:MASTER%的肉棒…
					PRINTFORMDW 边发出拟声边手淫的样子有些可爱，让人难以言喻的心情涌上心头…！
				CASE 2
					PRINTFORML 「%CALLNAME:MASTER%，感觉如何…？舒服吗？」
					CALL HPH_PRINT,@"「…很、很好♪…那就继续吧…HPH」","W"
			ENDSELECT
			RETURN 1
		ENDIF
	ENDIF
ENDIF
RETURN 1
