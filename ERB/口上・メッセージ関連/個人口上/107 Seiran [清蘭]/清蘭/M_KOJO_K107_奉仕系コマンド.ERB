			CALL HPH_PRINT,@"「阴茎…HPH 我来给你清洁一下HPH」","L"
			CALL HPH_PRINT,@"「嗯…啾…HPH 舔…HPH 舔…HPH 啾…HPH 舔啊啊…HPH」","L"
			PRINTFORMDL 清兰热情地舔着%CALLNAME:MASTER%刚刚还在自己体内的东西，认真地清洁着。
			PRINTFORMDW %CALLNAME:MASTER%再次被她的奉献和淫荡所激起…！
			RETURN 1
		ENDIF
	;それ以外
	ELSE
		CALL SEIRAN_FELLATIO
		RETURN 1
	ENDIF
ENDIF
RETURN 1

