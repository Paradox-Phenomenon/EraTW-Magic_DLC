					PRINTFORMDW 回答说变得非常漂亮。
			ENDSELECT
		ENDIF
	ELSEIF TFLAG:211 == 1
		SELECTCASE RAND:2
			CASE 0
				PRINTFORML （泡温泉的时候，感觉有人盯着我看，是错觉吗？）
				PRINTFORMW 「……没事，走吧」
			CASE 1
				PRINTFORML 「这里的温泉有点贵吧？肯定是敲诈―咕噜」
				PRINTFORMDW 我理解你的感受，但这么说有点失礼…
		ENDSELECT
	ENDIF
ENDIF
RETURN 1
