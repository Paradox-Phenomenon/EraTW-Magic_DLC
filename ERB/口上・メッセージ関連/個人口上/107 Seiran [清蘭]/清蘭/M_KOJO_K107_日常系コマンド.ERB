RETURN RESULT

@M_KOJO_MESSAGE_COM_K107_431_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;お風呂初回
	IF FIRSTTIME(SELECTCOM)
		PRINTFORMW 「%CALLNAME:MASTER%啊，你知道那种能喷水咻咻的东西吗，会做吗？」
		PRINTFORMDL 突然说下流话题，我稍微有些慌乱，但清兰的表情却很认真。
		PRINTFORMDW 或许是指水枪吧，%CALLNAME:MASTER%给清兰演示了一下。
		PRINTFORML 「啊，就是那个！之前被铃瑚用那个喷水弄得很郁闷！」
		PRINTFORMW 「我也想用那个来复仇！%CALLNAME:MASTER%！教我水枪吧！」
		PRINTFORMDW %CALLNAME:MASTER%决定教清兰如何使用水枪。
		PRINTFORMDW 少女特训中…
		PRINTFORMW 
		PRINTFORML 「嗯…像挤出空气的感觉…嘿！」
		PRINTFORML 「啊…！成功了！」
		PRINTFORMDW 清兰 学会了 新技能 水枪！
	ELSEIF TALENT:恋慕
		SELECTCASE RAND:5
			CASE 0
				PRINTFORMDW 当%CALLNAME:MASTER%正在享受泡澡时，清兰突然向他泼水。
				PRINTFORML 「呵呵呵…%CALLNAME:MASTER%大意了啊♪」
				PRINTFORMW 「怎么样？经过不断练习，我已经完全掌握了水枪技能！」
				PRINTFORML 「这样就能对铃瑚进行报复了―噗！？」
				PRINTFORMDW 中途说话时，我也回敬了一泼水作为回礼。笑着说“小心大意”。
				PRINTFORMW 「…………♪」
				PRINTFORMDL 就这样，以泡澡间为战场，水枪弹幕对决拉开了序幕。
				PRINTFORMDW 清兰和%CALLNAME:MASTER%玩得不亦乐乎，互相泼水直到快中暑。
			CASE 1
				PRINTFORML 「嗯嗯～～♪澡堂果然很舒服啊！今天也努力了～，就是这种感觉！」
				PRINTFORMDW 清兰伸了个懒腰。身体弯曲之时，虽然胸部不算大但形状好看的地方更加凸显，不自觉地目光被吸引。
				PRINTFORML 「…看、看什么呢。色狼」
				PRINTFORMDW 清兰因为身体浸泡到肩膀以下，无法欣赏她的身体了…
			CASE 2
				PRINTFORMDL 突然%CALLNAME:MASTER%看向清兰。平时盘在一起的长发被整理得不沾水。
				PRINTFORMDW 平时被头发遮住的后颈，此刻清晰可见。那种说不清道不明的诱人气息让我不由自主地——
				PRINTFORML 「——！…%CALLNAME:MASTER%！？等等，没事吧！？」
				PRINTFORMDW …不经意被吸引，结果中暑了。
			CASE 3
				CALL HPH_PRINT,@"「啊啊～～HPH 真舒服～HPH HPH」","L"
				PRINTFORMDW 清兰尽情享受与%CALLNAME:MASTER%一起的泡澡时间。
			CASE 4
				PRINTFORML 「嗯……」
				PRINTFORMDW 清兰一脸认真地摸着自己的胸部。看着她认真的表情，我意识到这并不是出于欲望。
				PRINTFORMW 「%CALLNAME:MASTER%喜欢…胸大的女孩吗？」
				PRINTFORMDW 回答“清兰无论哪种我都喜欢”后，清兰嘟囔着“原来如此”微笑着…好像是这样。
		ENDSELECT
	ELSE
		SELECTCASE RAND:2
			CASE 0
				PRINTFORML 「喂喂…！？别看那个羞耻的地方！」
				PRINTFORMDW 清兰似乎还不习惯被%CALLNAME:MASTER%看到自己的裸体…
			CASE 1
				PRINTFORML 「......唔...！」
				PRINTFORMDW 看来是真的不想被看到裸体。清兰蜷缩在一旁…
		ENDSELECT
	ENDIF
ENDIF
RETURN 1
