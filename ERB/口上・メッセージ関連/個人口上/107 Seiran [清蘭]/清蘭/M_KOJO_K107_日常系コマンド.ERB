@M_KOJO_MESSAGE_COM_K107_300
;コマンド共通メッセージ(TRAIN_MESSAGE) 
;削除すると「～話をした。」とかが消えます。また、削除した場合は自動で口上色が付きません。
;口上メイン呼出
CALL M_KOJO_MESSAGE_COM_K107_300_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K107_300_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;初回会話
	IF FIRSTTIME(SELECTCOM)
		PRINTFORMW 『―嗯嗯。哈哈哈！那是真的吗～～？』
		PRINTFORMDL 初次见面时也是如此，清兰经常朝着虚空说话。
		PRINTFORMDL 看起来像是自言自语，但从她愉快的表情来看，肯定是在和“某人”对话。
		PRINTFORMW 「呼～…所以？你一直盯着我看是怎么回事？」
		PRINTFORMDW 在思考的时候，清兰的“神秘对话”似乎已经结束了。
		PRINTFORML 「和谁在说话呢，嘛…那是我和伊格尔拉维的伙伴用心灵感应在交流」
		PRINTFORMW 「我们玉兔都可以用这种能力即使相隔遥远也能聊天」
		PRINTFORMDW 就像这个世界的手机一样。
		PRINTFORML 「手机？虽然不太懂…总之我们很厉害！明白了？」
		PRINTFORMDW 清兰得意地扯了扯鼻子，显得很自豪。
	;怒り
	ELSEIF CFLAG:318 == 1
		PRINTFORML 『―诶？我并没有生气啊…一切如常』
		PRINTFORMW 『…哈！？%CALLNAME:MASTER%为什么会冒出来！…我不认识他！那个家伙！』
		PRINTFORMDW 清兰正在和伙伴用心灵感应交流，无法被打扰…
	;喋りすぎ
	ELSEIF TCVAR:302
		SELECTCASE RAND:3
			CASE 0
				IF TALENT:恋慕 || TALENT:思慕
					PRINTFORML 「……？…%CALLNAME:MASTER%，没事吗？要一起做饼干吗？」
					PRINTFORMDW 不做…
				ELSE
					PRINTFORMW 「…谈话结束了可以走了吗？我有事要做」
				ENDIF
			CASE 1
				IF TALENT:恋慕 || TALENT:思慕
					PRINTFORMW 「%CALLNAME:MASTER%～！虽然聊天不错，但做其他事情吧？」
				ELSE
					PRINTFORMW 「你作为地上人应该讲些地上有趣的故事给我听」
				ENDIF
			CASE 2
				IF TALENT:恋慕 || TALENT:思慕
					PRINTFORML 『呵呵呵…♪然后%CALLNAME:MASTER%呢…♪』
					PRINTFORMW 「―啊…！哈哈哈…抱歉，刚没听见…」
				ELSE
					PRINTFORML 『哈哈哈哈！这种像笑话一样的事情～！』
					PRINTFORMDW …正在和伙伴交流的清兰看起来非常开心。
				ENDIF
		ENDSELECT
	;酔っ払い時会話
	;ぐでぐで
	ELSEIF BASE:酒気 > (MAXBASE:酒気 / 10) * 8
		IF TALENT:恋慕
			SELECTCASE RAND:5
				CASE 0
					CALL HPH_PRINT,@"「%CALLNAME:MASTER%～～HPH 亲亲HPH 嗯亲～～HPH HPH HPH」","L"
					CALL HPH_PRINT,@"「嘿嘿HPH %CALLNAME:MASTER%亲亲竟然已经变得硬邦邦的♪ 淘气～HPH 」","W"
					PRINTFORMDW 清兰正在热情地亲吻她钟爱的杵…
				CASE 1
					PRINTFORML 「哎呀～？%CALLNAME:MASTER%突然出现了～？」
					PRINTFORMW 「我知道啦～！肉团子变成假货啦～～！？」
					PRINTFORMDW 清兰看起来相当醉了…
				CASE 2
					PRINTFORMDW 清兰突然站起来，抓住%CALLNAME:MASTER%的胳膊，拉着他。
					PRINTFORML 「走吧%CALLNAME:MASTER%！我们去乘坐月亮上的巴士！」
					PRINTFORMW 「我们要打败月亮上的姬魔，成为月之使者～！！哈哈哈哈☆」
					PRINTFORMDW 察觉到危险，%CALLNAME:MASTER%拼命阻止了清兰…
				CASE 3
					PRINTFORMW 『现在～？和%CALLNAME:MASTER%在聊天～♪』
					PRINTFORML 『…嗯～？…嗯，是的～喝了不少呢～…但%CALLNAME:MASTER%很温柔～因此～…』
					PRINTFORMW 『…嗯，……嗯～？……♪……』
					PRINTFORML 「哈哈哈哈哈！%CALLNAME:MASTER%～！大家说你是"恶魔！去地狱吧！"呢～♪」
					PRINTFORMDW 清兰究竟和伙伴谈论了什么呢…
				CASE 4
					PRINTFORML 「所以嘛～！我就在那里，对着苹果狠狠说了一顿～！」
					PRINTFORML 「%CALLNAME:MASTER%～！你在听吗～！？」
					PRINTFORMDW 这个故事我之前听过了…
			ENDSELECT
		ELSE
			SELECTCASE RAND:5
				CASE 0
					PRINTFORML 「好热啊～…哎呀～？不要脱衣服啊！！」
					PRINTFORMDW 拼命阻止清兰脱衣服…
				CASE 1
					PRINTFORML 「喂～%CALLNAME:MASTER%！！现在摸我胸部吧～！！」
					PRINTFORML 「让我软弱，做那件淘气的事情啦～！！」
					PRINTFORMDW 没做任何事情却被无缘无故生气…
				CASE 2
					PRINTFORML 「啊！？不要碰我！别小看我…哎呀」
					PRINTFORMDW 勉强支撑着步履蹒跚的清兰…
				CASE 3;勇者王
					PRINTFORML 「勇者王！！」
					PRINTFORMDW 清兰突然打了我一拳…
				CASE 4
					PRINTFORML 「我～不晕～我～不晕～」
					PRINTFORMDW 清兰摇摇晃晃地站着…
			ENDSELECT
		ENDIF
	;酔いどれ
	ELSEIF BASE:酒気 > (MAXBASE:酒気 / 10) * 5
		PRINTFORMW 「…………。」
		IF TALENT:恋慕
			SELECTCASE RAND:5
				CASE 0
					PRINTFORMW 「好的！我是第一美兰！开始唱歌！！」
						SELECTCASE RAND:4
							CASE 0
								PRINTFORML 「兔子～兔子～♪盯着什么在想～♪」
							CASE 1
								PRINTFORML 「兔子～在舞台上～♪」
							CASE 2;星条旗的小丑
								PRINTFORML 「嘻哈哈嘻～♪嘻哈哈哈哈哈～♪」
							CASE 3;勇者王
								PRINTFORML 「勇者～♪钢铁的战士～♪」
						ENDSELECT
					PRINTFORMDW 清兰突然开始唱歌…
				CASE 1
					PRINTFORML 「哇啊啊啊啊啊啊～！！」
					PRINTFORMDW 清兰突然大喊！%CALLNAME:MASTER%吓了一跳…
				CASE 2
					PRINTFORML 「%CALLNAME:MASTER%～抱～紧！嘿嘿嘿嘿嘿☆」
					PRINTFORMDW 清兰突然拥抱过来…
				CASE 3
					CALL HPH_PRINT,@"「%CALLNAME:MASTER%…喜欢HPH」","L"
					PRINTFORMDW 清兰突然撒娇过来…
				CASE 4
					PRINTFORML 「…再来一杯～！…？嗯～！！再、来、一、杯～！！」
					PRINTFORMDW 清兰要求续杯。能让她再喝吗…
			ENDSELECT
		ELSE
			SELECTCASE RAND:5
				CASE 0
					PRINTFORML 「噗呼…哈哈哈哈哈哈！！」
					PRINTFORMDW 清兰突然笑了起来…
				CASE 1
					PRINTFORML 「……呜呜…哭…呜呜呜呜～！」
					PRINTFORMDW 清兰突然哭了起来…
				CASE 2
					PRINTFORML 「……在盯着看什么呢～！想被戳穿吗～！？」
					PRINTFORMDW 清兰突然生气了…
				CASE 3
					PRINTFORML 「……咕。」
					PRINTFORMDW 清兰突然开始入睡…
				CASE 4
					PRINTFORML 「……嗯」
					PRINTFORMDW 是想要续杯吗，清兰把空杯推了过来…
			ENDSELECT
		ENDIF
	;ほろ酔い
	ELSEIF BASE:酒気 >= 1
		IF TALENT:恋慕
			SELECTCASE RAND:4
				CASE 0
					PRINTFORMW 「ふふふっ…ふふふふっ♪」
				CASE 1
					PRINTFORML 「%CALLNAME:MASTER%…再来一杯吗？」
					PRINTFORMDW %CALLNAME:MASTER%往清兰空杯里倒了酒。
				CASE 2
					PRINTFORML 「其实呢…喝酒有点不太擅长…」
					CALL HPH_PRINT,@"「但是…和%CALLNAME:MASTER%一起喝酒我很喜欢…」","L"
				CASE 3
					CALL HPH_PRINT,@"「%CALLNAME:MASTER%…HPH」","L"
					PRINTFORMDW 清兰用湿润的眼眸凝视着%CALLNAME:MASTER%…
			ENDSELECT
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「嗯～……？」
					PRINTFORMDW 清兰的脸颊已经泛起红晕。或许她并不太能喝酒…
				CASE 1
					PRINTFORMW 「…嗯咯咯～♪喝酒好像有点久违了～」
				CASE 2
					PRINTFORML 「再来一杯吗？…那就来点少许吧…」
					PRINTFORMDW %CALLNAME:MASTER%往清兰空杯里倒了酒。
			ENDSELECT
		ENDIF
	ELSEIF TALENT:恋人
		IF FLAG:约会的对象 == 107
			SELECTCASE RAND:2
				CASE 0
					CALL SEIRAN_DATE
				CASE 1
					SELECTCASE RAND:4
						CASE 0
							CALL SEIRAN_KOIBITO
						CASE 1
							CALL SEIRAN_OTENKI
						CASE 2
							CALL SEIRAN_SEASON
						CASE 3
							CALL SEIRAN_GENSAKU
					ENDSELECT
			ENDSELECT
		ELSE
			SELECTCASE RAND:5
				CASE 0
					CALL SEIRAN_GENSAKU
				CASE 1
					CALL SEIRAN_KOIBITO
				CASE 2
					CALL SEIRAN_SEASON
				CASE 3
					CALL SEIRAN_OTENKI
				CASE 4
					PRINTFORML 「%CALLNAME:MASTER%…今天不出去约会吗？」
					PRINTFORMDW 在清兰的邀请下，一起去哪里逛逛吧……
			ENDSELECT
		ENDIF
	ELSEIF TALENT:恋慕
		IF FLAG:约会的对象 == 107
			SELECTCASE RAND:2
				CASE 0
					CALL SEIRAN_DATE
				CASE 1
					SELECTCASE RAND:4
						CASE 0
							CALL SEIRAN_RENBO
						CASE 1
							CALL SEIRAN_OTENKI
						CASE 2
							CALL SEIRAN_SEASON
						CASE 3
							CALL SEIRAN_GENSAKU
					ENDSELECT
			ENDSELECT
		ELSE
			SELECTCASE CFLAG:現在位置
			;人間の里
				CASE 201,202,203,204,205,206,230,240,210,220,230,240,250,270
					CALL SEIRAN_ODANGO
				CASEELSE
					SELECTCASE RAND:5
						CASE 0
							CALL SEIRAN_GENSAKU
						CASE 1
							CALL SEIRAN_RENBO
						CASE 2
							CALL SEIRAN_SEASON
						CASE 3
							CALL SEIRAN_OTENKI
						CASE 4
							PRINTFORML 「%CALLNAME:MASTER%…今天不出去约会吗？」
							PRINTFORMDW 在清兰的邀请下，一起去哪里逛逛吧……
					ENDSELECT
			ENDSELECT
		ENDIF
	ELSEIF TALENT:思慕
		IF FLAG:约会的对象 == 107
			SELECTCASE RAND:2
				CASE 0
					CALL SEIRAN_DATE
				CASE 1
					SELECTCASE RAND:4
						CASE 0
							CALL SEIRAN_SHIBO
						CASE 1
							CALL SEIRAN_OTENKI
						CASE 2
							CALL SEIRAN_SEASON
						CASE 3
							CALL SEIRAN_GENSAKU
					ENDSELECT
			ENDSELECT
		ELSE
			SELECTCASE CFLAG:現在位置
			;人間の里
				CASE 201,202,203,204,205,206,230,240,210,220,230,240,250,270
					CALL SEIRAN_ODANGO
				CASEELSE
					SELECTCASE RAND:5
						CASE 0
							CALL SEIRAN_GENSAKU
						CASE 1
							CALL SEIRAN_SHIBO
						CASE 2
							CALL SEIRAN_SEASON
						CASE 3
							CALL SEIRAN_OTENKI
						CASE 4
							PRINTFORML 「啊～…有点无聊呢～…要不去别的地方走走吧」
							PRINTFORMDW 在清兰的邀请下，一起去哪里逛逛吧……
					ENDSELECT
			ENDSELECT
		ENDIF
	ELSE
		IF FLAG:约会的对象 == 107
			SELECTCASE RAND:2
				CASE 0
					CALL SEIRAN_NORMAL
				CASE 1
					CALL SEIRAN_OTENKI
			ENDSELECT
		ELSE
			SELECTCASE CFLAG:現在位置
			;人間の里
				CASE 201,202,203,204,205,206,230,240,210,220,230,240,250,270
					CALL SEIRAN_ODANGO
				CASEELSE
					SELECTCASE RAND:2
						CASE 0
							CALL SEIRAN_NORMAL
						CASE 1
							CALL SEIRAN_OTENKI
