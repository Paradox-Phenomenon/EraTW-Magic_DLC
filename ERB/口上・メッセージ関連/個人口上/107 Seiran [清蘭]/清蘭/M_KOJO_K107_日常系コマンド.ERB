				CALL HPH_PRINT,@"「这…这个…HPH 请温柔点…HPH」","W"
				PRINTFORMW 「做…做吧…！！」
				SETCOLOR 0xFE0000
				PRINTFORML
				PRINTFORMW 砰！
				PRINTFORML
				PRINTFORMDW %CALLNAME:MASTER%被清兰狠狠地肘击在背部，痛苦地扭曲着，而清兰则开始自己洗身体…
		ENDSELECT
	;酔いどれ
