;==================================================
@M_KOJO_SUCCESS_COM_K107_301
;成否判定
;TFLAG:192(-2=コマンド終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_MESSAGE_MESSAGECHECK_COM_K107_301
RETURN 0

@M_KOJO_MESSAGE_COM_K107_301
CALL M_KOJO_MESSAGE_COM_K107_301_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K107_301_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF TFLAG:193 == 1
		IF TALENT:恋人
			PRINTFORML 「看%CALLNAME:MASTER%！茶叶起泡了！」
			PRINTFORML 「今天可能会有好事发生哦♪」
			PRINTFORMDW %CALLNAME:MASTER%和清兰一起笑了起来。
	ELSEIF TALENT:恋慕
			PRINTFORML 「啊，茶！%CALLNAME:MASTER%谢谢♪」
			PRINTFORML 「嘿%CALLNAME:MASTER%也来一起喝吧！」
			PRINTFORMDW 清兰和对方一起喘息片刻。
	ELSEIF TALENT:思慕
			PRINTFORML 「给我茶？谢谢♪」
			PRINTFORMW 「……啊，谢谢招待」
	ELSE
			PRINTFORML 「茶？…我收下了」
			PRINTFORML 「……谢谢款待。很好喝」
			PRINTFORMDW 看起来清兰把茶喝光了。
	ENDIF
ELSEIF TFLAG:193 == 0
		IF TALENT:恋人
			PRINTFORML 「嘿%CALLNAME:MASTER%…啊，茶！」
			CALL HPH_PRINT,@"「我正想喝茶呢♪谢谢HPH」","L"
			PRINTFORMDW 清兰开心地开始喝茶。
		ELSEIF TALENT:恋慕
			PRINTFORML 「这边清兰。%CALLNAME:MASTER%，我想喝茶」
			PRINTFORMDW 清兰伸出茶杯，仿佛传递着心灵（？）信息。
		ELSEIF TALENT:思慕
			PRINTFORML 「给我茶？谢谢」
			PRINTFORMW 「……啊，让人心情舒畅」
		ELSE
			PRINTFORML 「茶？…我收下了」
			PRINTFORMW 「嗯，还可以啦」
		ENDIF
	ELSE
		IF TALENT:恋人
			PRINTFORML 「啊，茶！%CALLNAME:MASTER%谢谢♪」
			PRINTFORML 「嗯！？……好，好喝…吗？」
			PRINTFORMDW 看起来清兰不太喜欢。她的笑容有些僵硬…
		ELSEIF TALENT:恋慕
			PRINTFORML 「呵呵♪谢谢%CALLNAME:MASTER%♪」
			PRINTFORML 「哈哈…――！？咳咳！咳咳…」
			PRINTFORMDW 清兰呛到了，我轻轻拍着她的背…
		ELSEIF TALENT:思慕
			PRINTFORML 「嗯。谢谢」
			PRINTFORML 「………谢谢款待」
			PRINTFORMDW 可能不太合口味，清兰只喝了一口…
		ELSE
			PRINTFORML 「什么？这…是茶？给我的？」
			PRINTFORML 「难道里面放了什么奇怪的东西吗…」
			PRINTFORMDW 清兰似乎有点警惕…
		ENDIF
	ENDIF
ENDIF
RETURN 1
