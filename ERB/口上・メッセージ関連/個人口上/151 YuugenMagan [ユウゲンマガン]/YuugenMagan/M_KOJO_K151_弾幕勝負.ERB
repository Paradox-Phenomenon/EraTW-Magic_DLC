;==================================================
;弾幕勝負
;==================================================
;
@M_KOJO_MESSAGE_COM_K151_DANMAKU(ARGS, 相手残機)
#DIM 相手残機
;全体の流れ
;①【戦闘前】→②ダイスロールとプレイヤー選択肢、ハンデをつけた場合は【ハンデ口上】→③対応スキルが発動した場合【スキル口上】→④被弾判定、キャラが被弾したなら【被弾口上】→
;どちらかの残機が0になっていなければ②に戻る→⑤【戦闘後口上】

;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	SIF FLAG:口上色
		TRYCALLFORM M_KOJO_COLOR_K{NO:TARGET}
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;The larger the handicap, the more of a disadvantage the player is at
	;Negative numbers mean the player has an advantage
	;戦闘前
	HANDICAP_FIXED = 0
	HANDICAP_RAND = 0
	;ハンデをつけることができ、数値が大きいほどあなたが不利になる　数値が負ならあなたが有利に
	;キャラの能力に関わらずクッソ強くしたり弱くしたりできる
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "戦闘前"
		IF FIRSTTIME("YMDanmaku")
			SELECTCASE K151_YM_NATURE()
				CASE 0, 1
					PRINTFORMW 「你想要挑战我们进行弹幕对决吗？」
					PRINTFORMDW 幽幻魔眼发出奇怪的笑声
					PRINTFORMW 「我们接受...但已经很多年没有战斗了。我们可能需要一些时间来恢复以前的技能」
					PRINTFORMW 「你就是那个有大玉的人，对吗？」
					PRINTFORMDW ...什么？
					PRINTFORMDW \@ HAS_PENIS(MASTER) ? 确实你有胆量，但...为什么 # 为什么\@她在弹幕比赛之前问你的生殖器？
					PRINTFORMDW 她是在暗示你是个胆小鬼吗？
					PRINTFORMW 「你难道不打算拿出来吗？」
					PRINTFORMDW 你尽量委婉地问她在说什么
					PRINTFORMW 「这不是弹幕比赛的规则吗？」
					PRINTFORMW 「我们用弹幕攻击你，而你用你的大玉攻击我们，同时躲避我们的弹幕和你的大玉」
					PRINTFORMW 「这就是多年以前我们和巫女战斗的方式」
					IF IS_FEMALE(1) && CFLAG:1:既成事実 & 合意_诶嘿嘿
						PRINTFORMDW 好吧，她肯定不是在说睾丸。你知道灵梦没有
					ELSE
						PRINTFORMDW 这真的是灵梦在符卡规则之前解决异变的方式吗？！
					ENDIF
					PRINTFORMDW 你解释了现在的弹幕对决规则，并简要介绍了符卡规则
					PRINTFORMW 「啊，所以这和以前的方式类似...但你也会发射弹幕。我们明白了，明白了」
					PRINTFORMW 「很好，那让我们开始战斗吧」
				CASE 2
					PRINTFORMW 「弹幕，对吧？」
					PRINTFORMW 「当然，听起来很有趣！但是，嗯...请对我手下留情，好吗？我已经几十年没有比赛了...」
					PRINTFORMDW 幽幻魔眼盯着你。她似乎在等待什么
					PRINTFORMW 「你不打算拿你的大玉出来吗？」
					PRINTFORMDW ...什么？
					PRINTFORMDW \@ HAS_PENIS(MASTER) ? 确实你有胆量，但...为什么 # 为什么\@她在弹幕比赛之前问你的生殖器？
					PRINTFORMDW 你尽量委婉地问她在说什么
					PRINTFORMW 「嗯？」
					PRINTFORMW 「这不是弹幕比赛的规则吗？我用我的弹幕攻击你，而你用你的大玉攻击我，同时不被击中」
					PRINTFORMW 「这就是我和灵梦多年前战斗的方式」
					IF IS_FEMALE(1) && CFLAG:1:既成事実 & 合意_诶嘿嘿
						PRINTFORMDW 好吧，她肯定不是在说睾丸。你知道灵梦没有
					ELSE
						PRINTFORMDW 这真的是灵梦在符卡规则之前解决异变的方式吗？！
					ENDIF
					PRINTFORMDW 你解释了现在的弹幕对决规则，并简要介绍了符卡规则
					PRINTFORMW 「哦，好的。所以现在我们都使用弹幕...明白了」
					PRINTFORMW 「好吧，那你准备好了吗？」
			ENDSELECT
		ENDIF
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;Handicap (doesn't apply if the character's handicap is 0)
	;ハンデ
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "ハンデ"
		;ハンデつけなかったら表示されないので無記入でよい
		PRINTFORML 
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;戦闘中TARGET被弾時口上
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "被弾" 
		;別に一律で「やられたー」だけでもいいよ
		SELECTCASE 相手残機
			;残り残機3が表示されるのは【洽覧深識】持ちのみ
			CASE 3
				PRINTFORML 
			CASE 2
				PRINTFORML 
			CASE 1
				PRINTFORML 
			CASE 0
				PRINTFORML 
		ENDSELECT
	ENDIF
	;-------------------------------------------------
	;戦闘中
	;TARGETの【残忍酷薄】発動時
	;ARGはTARGETの残機
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "残忍酷薄"


	ENDIF
	;-------------------------------------------------
	;戦闘中
	;TARGETの【乾坤一擲】発動時
	;ARGはTARGETの残機
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "乾坤一擲"


	ENDIF
	;-------------------------------------------------
	;戦闘中
	;TARGETの【怪力乱神】発動時
	;ARGはTARGETの残機
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "怪力乱神"


	ENDIF


	;-------------------------------------------------
	;戦闘後
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "戦闘後" 
		PRINTFORML 
		;残り残機4が表示されうるのは【洽覧深識】持ちのみ
		;残機が1以上ならあなたの負け、0の場合はあなたの勝利
		SELECTCASE 相手残機
			CASE 4
				PRINTFORML 
			CASE 3
				PRINTFORML 
			CASE 2
				PRINTFORML 
			CASE 1
				PRINTFORML 
			CASE 0
				PRINTFORML 
		ENDSELECT
	ENDIF
	RESETCOLOR
	RESETCOLOR
ENDIF
RETURN 1

