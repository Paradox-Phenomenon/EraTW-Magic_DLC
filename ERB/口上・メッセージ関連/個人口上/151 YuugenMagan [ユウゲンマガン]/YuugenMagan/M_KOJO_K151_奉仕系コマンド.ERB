;==================================================
;80,手淫
;==================================================
@M_KOJO_SUCCESS_COM_K151_80
IF CFLAG:[[ユウゲンマガン]]:K151EN_YM_NATURE == 1 && TCVAR:PLAYER:イきそう && !NOWEX:PLAYER:射精 && EXP:[[ユウゲンマガン]]:手淫経験 > 20
	SELECTCASE RAND:3
		CASE 0
			PRINTFORML 「你已经快要到达高潮了」
			PRINTFORMW 「你的精液应该射在我的子宫里，而不是我的手上」
		CASE 1
			PRINTFORMW 「不行，射在我的子宫里」
		CASE 2
			PRINTFORMW 「我想孕育你的后代，射在我的手上是没有意义的」
	ENDSELECT
	RETURN 0
ENDIF

@M_KOJO_MESSAGE_COM_K151_80
CALL M_KOJO_MESSAGE_COM_K151_80_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K151_80_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && SHIRAHU([[ユウゲンマガン]]) 
		IF FIRSTTIME("YuugenMaganHandjob")
			SELECTCASE K151_YM_NATURE()
				CASE 0, 1
					PRINTFORMW 「你说你想要什么？」
					PRINTFORMDW 幽幻魔眼歪着头表示困惑
					PRINTFORMW 「我们要用手帮你揉捏那个吗？但那不是你们人类交配的方式...」
					PRINTFORMW 「非生殖性交？！是我们错把你逼疯了吗？！」
					PRINTFORMW 「我们并不是来让你享受的！我们是来让你为我们的星之子做父亲的！」
					PRINTFORMDW 经过一些努力，你终于说服幽幻魔眼用手帮你揉捏%FSYN_CN("阴茎")%，直到你快要射精
					PRINTFORMDW 一旦你完全勃起，你会切换到“真正的”交配模式
					PRINTFORMW 「小心不要射出来」
					PRINTFORMDW 幽幻魔眼一边盯着你，一边抚摸着你的%FSYN_CN("阴茎")%
					PRINTFORMW 「不要浪费你的精液，否则我们会不高兴的」
				CASE 2
					PRINTFORMW 「手淫，嗯...」
					PRINTFORMDW 幽幻魔眼握住你的%FSYN_CN("阴茎")%，用拇指摩擦着它
					PRINTFORMW 「我从来没做过这种事...但应该不难吧？」
					PRINTFORMW 「我只需要抚摸它直到你射出来即可」
			ENDSELECT
		ELSE

			SELECTCASE K151_YM_NATURE()
				CASE 0, 1
					IF ABL:TARGET:指 >= 5
						SELECTCASE IFRAND("0TO3", 1, "4TO5", CFLAG:[[ユウゲンマガン]]:K151EN_YM_NATURE == 1)
							CASE 0
								PRINTFORMDL 幽幻魔眼熟练地揉捏你的阴茎，直到你快要高潮...然后她停了下来
								PRINTFORMDW 一旦你开始变软，她就重新开始抚摸你
								PRINTFORML 「记住...你只能在我体内射精」
								PRINTFORMDW 她露出一个邪恶的倒笑
							CASE 2
								PRINTFORMW 「很痛吧？你渴望高潮，却无法实现...」
								PRINTFORMDW 她发出一种奇怪的笑声，你认为那是一种笑声
							CASE 3
								PRINTFORMDW 幽幻魔眼低声说了些什么，\@ CFLAG:[[ユウゲンマガン]]:K151EN_YM_NATURE == 1 ? 感受到一种愉快的刺痛感，%HE_SHE([[ユウゲンマガン]])%抚摸你的%FSYN_CN("阴茎")% # 你感觉到的快感增加得几乎让你感到疼痛\@
								PRINTFORMDW %HE_SHE([[ユウゲンマガン]],1)% smiles %HIS_HER([[ユウゲンマガン]])% strange upside-down smile.
								PRINTFORMW 「你喜欢吗？即使我们不希望你射精，我们也没理由不让你感到愉快」
							CASE 4
								PRINTFORMDL 幽幻魔眼的手淫已经从冷淡、生硬变得顺畅、熟练而性感
								PRINTFORMDW 她不再粗暴地抽动你的阴茎，而是用既不太紧也不太松的稳健握力在你%FSYN_CN("阴茎")%上下滑动
								PRINTFORMDW 她那非人类的眼睛与你对视，你可以在其中看到一丝欲望
								PRINTFORML 「快点勃起」
								PRINTFORMW 「我们想要你进入我们...」
							CASE 5
								PRINTFORMDL 幽幻魔眼伸出手，并为之充电
								PRINTFORMDW 她用指尖触碰你的阴茎。 一种愉快的刺痛感在你的皮肤上蔓延开来，你的%FSYN_CN("阴茎")%也随之僵硬
								PRINTFORMW 「啊...原来这就是秘密」
								PRINTFORMDW %HE_SHE([[ユウゲンマガン]],1)% 继续用带电的手抚摸你的阴茎
								PRINTFORMDW 这感觉就像手淫和有人用电动按摩器刺激你的下体的混合体验
						ENDSELECT
					ELSEIF ABL:TARGET:指 >= 3
						SELECTCASE IFRAND("0TO5", 1, "6TO7", CFLAG:[[ユウゲンマガン]]:K151EN_YM_NATURE == 1)
							CASE 0
								PRINTFORMW 「我们的人...我们不会做这种事」
								PRINTFORMW 「告诉我，我们怎么揉捏你的部位才是愉快的？」
								PRINTFORMDW 幽幻魔眼专心听你解释
								PRINTFORMW 「慢慢开始然后加速...不要太用力...集中在阴茎底部...」
								PRINTFORMDW 她开始更有信心地抚摸你的%FSYN_CN("阴茎")%
							CASE 1
								PRINTFORMW 「你能为我们自慰吗？」
								PRINTFORMW 「如果我们知道你如何自慰，我们将能更有效地取悦你」
								PRINTFORMDW 你躺下来并自慰，幽幻魔眼专注地观察着
								PRINTFORMW 「啊...原来是这么做的」
								PRINTFORMDW 她开始更有信心地抚摸你的%FSYN_CN("阴茎")%，试图模仿她看到的
							CASE 2
								PRINTFORMW 「你觉得这样舒服吗？」
								PRINTFORMDW 幽幻魔眼根据你的反馈调整她的技巧和速度
							CASE 3
								PRINTFORMW 「哪里感觉最舒服？」
								PRINTFORMW 「这个世界的时间越来越短。我们希望你尽快勃起」
							CASE 4
								PRINTFORMW 「啊。噢。是的。感觉真好。操我们的手」
								PRINTFORMDW 幽幻魔眼发出你听过的最不真实的呻吟声，一边抚摸你的%FSYN_CN("阴茎")%
							CASE 5
								PRINTFORMW 「快点。我们想要你进入我们」
								PRINTFORMDW 幽幻魔眼抚摸你的%FSYN_CN("阴茎")%更快更用力
								PRINTFORMDW 她的脸依然面无表情
							CASE 6
								PRINTFORMW 「如果我们知道一些增强你快感的咒语就好了...」
								PRINTFORMDW 幽幻魔眼眯起眼睛，专注于用她冰冷的手刺激你的%FSYN_CN("阴茎")%
							CASE 7
								PRINTFORMDW 幽幻魔眼一边舔你的%FSYN_CN("阴茎")%的头部一边抚摸你的阴茎
								PRINTFORMDW 她的嘴巴和身体其他部分一样冰冷，她的舌头像一块坚硬粗糙的木头
						ENDSELECT
					ELSE
						SELECTCASE IFRAND("0TO5", 1, "6TO7", CFLAG:[[ユウゲンマガン]]:K151EN_YM_NATURE == 1)
							CASE 0
								PRINTFORMW 「为什么你还没有勃起？我们做错了什么？」
								PRINTFORMDW 幽幻魔眼尝试不同的速度和压力，试图找到你喜欢的组合
							CASE 1
								PRINTFORMW 「这比我们预想的要难」
								PRINTFORMW 「告诉我们你的秘密。我们怎样用手让你勃起？」
							CASE 2
								PRINTFORMW 「你不享受吗？」
								PRINTFORMDW 幽幻魔眼听起来有些失望
							CASE 3
								PRINTFORMDW 幽幻魔眼笨拙地上下抽动你的阴茎，就像是在挤奶
								PRINTFORMW 「为什么你还没有勃起？快点好让我们能生你的孩子」
							CASE 4
								PRINTFORMDW 幽幻魔眼有时抓得你的%FSYN_CN("阴茎")%几乎要把它压碎，有时又轻得没有感觉
							CASE 5
								PRINTFORMW 「这真的有必要吗？我们的身体不够漂亮，不能让你自己勃起吗？」
								PRINTFORMDW 幽幻魔眼抱怨着，笨拙地抚摸你的%FSYN_CN("阴茎")%...
							CASE 6
								PRINTFORML 「我们的身体太冷了吗？」
								PRINTFORMW 「要不我们让自己着火？」
							CASE 7
								PRINTFORMDW 幽幻魔眼冰冷的手抚摸你的%FSYN_CN("阴茎")%让你无法勃起
								BASE:MASTER:勃起 = 0
						ENDSELECT
					ENDIF
				CASE 2
					IF ABL:TARGET:指 >= 5
						SELECTCASE RAND:3
							CASE 0
								PRINTFORML 
							CASE 1
								PRINTFORML 
							CASE 2
								PRINTFORML 
						ENDSELECT
					ELSEIF ABL:TARGET:指 >= 3
						SELECTCASE RAND:3
							CASE 0
								PRINTFORML 
							CASE 1
								PRINTFORML 
							CASE 2
								PRINTFORML 
						ENDSELECT
					ELSE
						SELECTCASE RAND:3
							CASE 0
								PRINTFORML 
							CASE 1
								PRINTFORML 
							CASE 2
								PRINTFORML 
						ENDSELECT
					ENDIF
			ENDSELECT
		ENDIF
		RETURN 1
	ENDIF
ENDIF
RETURN 1

