;==================================================
;301,お茶を淹れる
;TFLAG:193(1=大成功 0=成功 -1=失敗)
;==================================================
@M_KOJO_SUCCESS_COM_K151_301
;成否判定
;TFLAG:192(-2=コマンド終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

@M_KOJO_MESSAGE_COM_K151_301
CALL M_KOJO_MESSAGE_COM_K151_301_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K151_301_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF FIRSTTIME("MaganTea")
		SELECTCASE K151_YM_NATURE()
			CASE 0, 1
				PRINTFORML 「茶吗？」
				PRINTFORMDW 幽幻魔眼冷冷地看着杯子
				PRINTFORMW 「那你是怎么使用它的？」
				PRINTFORMDW 你解释说将它倒入口中并吞下
				PRINTFORMW 「你从中获得营养…真是有趣」
				PRINTFORMW 「在我们的世界，我们不需要这种东西」
				PRINTFORMW 「我们只是存在」
				PRINTFORMDW 幽幻魔眼拿起杯子，轻轻啜了一口
				PRINTFORMW 「嗯」
				PRINTFORMDW 她又喝了一口
				PRINTFORMW 「我们无法理解它的魅力…但为了礼貌，我们会继续饮用」
				PRINTFORMW 「我们希望与贵维度的物种培养更好的关系」
			CASE 2
				PRINTFORMW 「茶？嗯？」
				PRINTFORMW 「我一直更喜欢冰咖啡…不过我愿意尝试一下」
				PRINTFORMDW 幽幻魔眼从你手中接过杯子，喝了一口。她的眼睛亮了起来
				PRINTFORMW 「哇，这真的很好喝！」
		ENDSELECT
	ELSE
		SELECTCASE TFLAG:193
			CASE 1
				SELECTCASE K151_YM_NATURE()
					CASE 0, 1
						IF FIRSTTIME("GoodTea")
							PRINTFORMW 「味道变了，某种程度上更吸引人。为什么？」
							PRINTFORMDW 你解释说这只是运气好
							PRINTFORMW 「什么？」
							PRINTFORMDW 幽幻魔眼的声音依然冷淡
							PRINTFORMW 「在你的世界里，行动并不纯粹？它们有…」
							PRINTFORMDW 幽幻魔眼停顿了一下
							PRINTFORMW 「副作用，对吧？相同的输入会产生不同的输出？」
							PRINTFORMW 「你们真是奇怪的生物」
						ELSE
							PRINTFORMW 「你的茶又不纯了，吸引人的那种」
							IF CFLAG:[[ユウゲンマガン]]:K151EN_YM_NATURE == 0
								PRINTFORMDW 幽幻魔眼在对你微笑吗？
								PRINTFORMDW 当她发现你在看她时，笑容立刻消失，回到了她那惯常的冷淡表情
							ENDIF
						ENDIF
					CASE 2
						PRINTFORMW 「哇哦，这真是太棒了！」
						PRINTFORMDW 幽幻魔眼喝干了杯中的茶，并对你露出了笑容
						PRINTFORMW 「你真的得教教我怎么做这种茶」
				ENDSELECT
			CASE 0
				IF TALENT:[[ユウゲンマガン]]:恋人
					SELECTCASE K151_YM_NATURE()
						CASE 1
							SELECTCASE RAND:3
								CASE 0
									PRINTFORMW 「这种物质没有被施加魔法，是吗？」
									PRINTFORML 「...没有？那为什么我们会对它上瘾？」
									PRINTFORMW 「仅仅因为它来自你吗？」
								CASE 1
									PRINTFORML 「你已经给我们泡了多少杯茶了？」
									PRINTFORMW 「一定比宇宙中的星星还多」
									PRINTFORMW 「然而…我们从未对这种体验感到厌倦」
								CASE 2
									PRINTFORMW 「或许我们应该开始向信徒们要求茶作为贡品」
									PRINTFORMW 「不过再想想，还是算了。因为没有人能像你一样泡茶」
							ENDSELECT
						CASE 2
							SELECTCASE RAND:3
								CASE 0
									PRINTFORML 「嘿嘿，舞知道你的茶之后一定会嫉妒死」
									PRINTFORMW 「当然，她的魔法比我厉害多了，但她有个会泡茶的超帅%PRINT_MALE("男", MASTER)%朋友吗？」
									IF TALENT:105:恋人
										PRINTFORMW 「...哦，对，她确实有」
										PRINTFORMDW 幽幻魔眼皱起了眉头
									ENDIF
								CASE 1
									PRINTFORML 「我觉得我开始对你的茶上瘾了」
									PRINTFORMW 「我都不记得上次喝速溶咖啡是什么时候了，我以前可是每天喝四杯！」
								CASE 2
									PRINTFORMW 「你觉得如果我用魔法把这茶弄得像毒药，大家会觉得我很酷吗？」
									PRINTFORMW 「...不行吗？唉…」
							ENDSELECT
					ENDSELECT
				ELSEIF TALENT:[[ユウゲンマガン]]:セフレ || TALENT:[[ユウゲンマガン]]:愛欲
					SELECTCASE K151_YM_NATURE()
						CASE 1
							SELECTCASE RAND:3
								CASE 0
									PRINTFORML 
								CASE 1
									PRINTFORML 
								CASE 2
									PRINTFORML 
							ENDSELECT
						CASE 2
							SELECTCASE RAND:3
								CASE 0
									PRINTFORML 
								CASE 1
									PRINTFORML 
								CASE 2
									PRINTFORML 
							ENDSELECT
					ENDSELECT
				ELSEIF TALENT:[[ユウゲンマガン]]:思慕 || TALENT:[[ユウゲンマガン]]:恋慕
					SELECTCASE IFRAND("0TO1", 1, "2", CFLAG:[[ユウゲンマガン]]:K151EN_YM_NATURE == 0, "3", CFLAG:[[ユウゲンマガン]]:K151EN_YM_NATURE == 1)
						CASE 0
							PRINTFORML 「我们不知道为什么…但我们喜欢上了这个仪式」
							PRINTFORMDW 幽幻魔眼放下杯子，露出她那倒过来的笑容
						CASE 1
							PRINTFORMW 「(真奇怪...这个茶是温暖的，但和在%HIS_HER(MASTER)%身边感受到的温暖不一样...)」
							PRINTFORMDW 幽幻魔眼自言自语着，同时从你手中接过杯子
						CASE 2
							PRINTFORMW 「这还挺不错的」
							PRINTFORMDW 幽幻魔眼对你微微一笑，但当她看到你正看着她时，她的脸恢复了平常的淡漠
						CASE 3
							PRINTFORML 「这是个有趣的仪式」
							PRINTFORMW 「它召唤了怎样的存在？是在我们喝完茶之前，还是之后？」
					ENDSELECT
				ELSE
					SELECTCASE IFRAND("0TO1", 1, "2", CFLAG:[[ユウゲンマガン]]:K151EN_YM_NATURE == 0, "3", CFLAG:[[ユウゲンマガン]]:K151EN_YM_NATURE == 1)
						CASE 0
							PRINTFORML 「啊，所以这是一个旨在促进交流与理解的仪式。多么智慧」
							PRINTFORMDW 没那么深奥啦…
						CASE 1
							PRINTFORMW 「你是如何得出这个仪式的？是神告诉你的吗？」
							PRINTFORMDW 你…其实不知道
							PRINTFORMW 「你称之为…茶艺的技艺，是如此古老，以至于你甚至不记得它的来源？」
							PRINTFORMW 「真是引人入胜…」
						CASE 2
							PRINTFORMW 「可以加点糖…不过应该还行」
						CASE 3
							PRINTFORML 「虽然我们享受你茶的热气，但我们没有给这个身体留味蕾，所以不能真正品味它」
							PRINTFORMDW 幽幻魔眼皱了皱眉
							PRINTFORMW 「茶到底是什么味道的？」
					ENDSELECT
				ENDIF
			CASE -1
				SELECTCASE K151_YM_NATURE()
					CASE 0
						PRINTFORML 「这茶味道好差！」
						PRINTFORMDW 幽幻魔眼把杯子扔到地上，瞪着你
						PRINTFORMW 「你是想用这种变质的饮品侮辱我们吗？！」
					CASE 1
						PRINTFORML 「嗯」
						PRINTFORMDW 幽幻魔眼面无表情地看着你喝茶
						PRINTFORMW 「莫名觉得没那么享受」
					CASE 2
						PRINTFORML 「呃」
						PRINTFORMDW 幽幻魔眼放下杯子，露出一副怪表情
						PRINTFORMW 「我不太清楚是什么原因，但这茶味道…有点不对」
				ENDSELECT
		ENDSELECT
	ENDIF
ENDIF
RETURN 1
;==================================================
;302,スキンシップ
;TFLAG:193(1=大成功 0=成功 -1=失敗)
;==================================================
@M_KOJO_SUCCESS_COM_K151_302
;成否判定
;TFLAG:192(-2=コマンド終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

@M_KOJO_MESSAGE_COM_K151_302
CALL M_KOJO_MESSAGE_COM_K151_302_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K151_302_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF FIRSTTIME("YMSkinship")
		SELECTCASE K151_YM_NATURE()
			CASE 0
				PRINTFORMDW 幽幻魔眼在你抚摸她身体时猛地一跳
				PRINTFORMW 「你-你在干什么？！」
				GOTO ELDRITCH_SKINSHIP
			CASE 1
				PRINTFORMDW 幽幻魔眼茫然地盯着你抚摸她的身体
				PRINTFORMW 「你在干什么？」
				$ELDRITCH_SKINSHIP
				PRINTFORMW 「你说这是亲密接触？」
				PRINTFORMW 「这样做的目的是什么？」
				PRINTFORMW 「这能帮助你的生殖能力，通过让你放松吗？那你可以继续了」
			CASE 2
				PRINTFORMW 「哦，你想摸我？」
				PRINTFORMDW 幽幻魔眼对你露出一个调皮的笑
				PRINTFORMW 「来吧，我都是你的〜」
		ENDSELECT
	ELSE
		SELECTCASE TFLAG:193
			CASE 1
				IF TALENT:[[ユウゲンマガン]]:恋人
					SELECTCASE K151_YM_NATURE()
						CASE 1
							PRINTFORMW 「啊...这感觉真好」
							PRINTFORMDW 幽幻魔眼在你抚摸她的身体时轻声呻吟
						CASE 2
