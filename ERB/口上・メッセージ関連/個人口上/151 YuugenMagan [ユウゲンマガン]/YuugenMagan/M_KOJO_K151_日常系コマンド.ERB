;==================================================
@M_KOJO_SUCCESS_COM_K151_603
;成否判定
;TFLAG:192(-2=コマンド終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

@M_KOJO_MESSAGE_COM_K151_603
CALL M_KOJO_MESSAGE_COM_K151_603_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K151_603_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF FIRSTTIME(SELECTCOM)
		SELECTCASE K151_YM_NATURE()
			CASE 0
				PRINTFORMDW 你握住了幽幻魔眼的手
				PRINTFORMDW 它出奇地柔软…
				PRINTFORMW 「...?」
				PRINTFORMDW 她瞥了你一眼。她是…脸红了？
				PRINTFORMW 「你在干什么？」
				$HANDHOLDING_FINISH
				PRINTFORMW 「我们自己能走得很好」
				PRINTFORMW 「..这是一种表达感情的手势吗？啊」

			CASE 1
				PRINTFORMDW 你一握住幽幻魔眼的手就立刻缩了回来
				PRINTFORMDW 它冰冷而僵硬。就像尸体的手
				PRINTFORMW 「有什么不对劲吗？」
				PRINTFORMDW 幽幻魔眼转过头，用她的七只眼睛盯着你
				PRINTFORMW 「...我们的手很冷？这不是很正常吗？」
				PRINTFORMW 「...嗯，也许我们应该给这副身体设计一个循环系统」
				PRINTFORMW 「不管怎样，你为什么摸它？」
				GOTO HANDHOLDING_FINISH


			CASE 2

			CASE 3
		ENDSELECT
	ELSE
		IF TALENT:151:恋人
			SELECTCASE K151_YM_NATURE()
				CASE 1
					SELECTCASE RAND:3
						CASE 0
							PRINTFORMDW 当你握住她冰冷僵硬的手时，幽幻魔眼对你微笑
							PRINTFORML 「尽管你觉得不舒服，我们很高兴你继续握住我们的手」
							PRINTFORMW 「对我们来说，这感觉…不错」
						CASE 1
							PRINTFORMDL 幽幻魔眼用另一只手搓揉自己的手，试图让它暖和起来
							PRINTFORMW 「这样好一些吗？」
						CASE 2
							PRINTFORML 「这真是太亲密了...」
							PRINTFORMDW 她的话语如耳语一般轻
							PRINTFORMW 「甚至比交配更亲密」
							PRINTFORMDW 她握紧了你的手
					ENDSELECT

				CASE 2
					SELECTCASE RAND:3
						CASE 0
							PRINTFORMDL 幽幻魔眼集中精神，她的脸红消失了
							PRINTFORMW 「消失了吗？」
							PRINTFORMDW 你点点头
							PRINTFORMW 「那就好」
							PRINTFORMDW 她笑了起来
							PRINTFORMW 「我不想暴露身份，但我真的不想放开你的手...」

						CASE 1
							PRINTFORML 「我的手感觉怎么样？太软了吗？不够软？」
							PRINTFORMW 「我也可以改变它的感觉」

						CASE 2
							PRINTFORMW 「你知道吗，在以前……舞总是取笑我即使是雪也会比我先交到%PRINT_MALE("男", MASTER)%朋友」
							PRINTFORMW 幽幻魔眼笑了
							PRINTFORMW 「我敢打赌，如果她现在能看到我，她会嫉妒得立刻变成一个桥姬...」

					ENDSELECT

			ENDSELECT
		ELSEIF TALENT:151:セフレ || TALENT:151:愛欲

			SELECTCASE K151_YM_NATURE()
				CASE 0, 1
					SELECTCASE IFRAND("0TO4", 1, "5", CFLAG:[[ユウゲンマガン]]:K151EN_YM_NATURE == 0)
						CASE 0
							PRINTFORMW 「这个动作已经成为我们的习惯」
							PRINTFORMDW 她意思是"对我们有影响"吗？
							PRINTFORML 「这是正确的用语吗？是的，这就是我们的意思」
							PRINTFORMW 「你可以继续」

						CASE 1
							PRINTFORMW 「虽然对你来说很不愉快，但你还是继续这样做？」
							PRINTFORMW 「...你说不，不是不愉快？」
							PRINTFORMDW 幽幻魔眼瞥了你一眼，她的表情比平时更难以捉摸

						CASE 2
							PRINTFORML 「我们不明白你为什么继续对我们表示关爱」
							PRINTFORMW 「我们是伴侣。仅此而已」

						CASE 3
							PRINTFORML 「你不羞于在公共场合这样做吗？」
							PRINTFORMW 「在你们的文化中，公开交配是禁忌，不是吗？」
							PRINTFORMW 「...是的，但这只是交配的前奏」
							PRINTFORMW 「...嗯，你们的文化真是奇怪...」

						CASE 4
							PRINTFORML 「这是一个无意义的手势...」
							PRINTFORMW 「但不知为何，对我们来说并不感觉无意义」
							PRINTFORMW 「真奇怪。需要进一步研究」

						CASE 5
							PRINTFORMW （希望\@ TALENT:MASTER:性別 == 2 ? 他 # 她\@感觉不到我心跳得有多快...）

					ENDSELECT


				CASE 3

			ENDSELECT
		ELSEIF TALENT:151:思慕 || TALENT:151:恋慕
			SELECTCASE K151_YM_NATURE()
				CASE 0
					PRINTFORMDW 她脸红了吗？
					PRINTFORMDW 幽幻魔眼看到你在看她，脸红更深了
					PRINTFORMW 「我…我们无法控制我们身体的反应！」

				CASE 1

			ENDSELECT
		ELSE
			SELECTCASE K151_YM_NATURE()
				CASE 0

				CASE 1

			ENDSELECT
		ENDIF
	ENDIF
ENDIF
RETURN 1

