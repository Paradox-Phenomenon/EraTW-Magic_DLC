;==================================================
;300,会話
;TFLAG:193(1=大成功 0=成功 -1=失敗 -2=大失敗（TARGETがMASTERより教養が4以上高い)
;TCVAR:302(0=会話可能 1>=非恋慕時会話不能)
;MARK:反発刻印(3以上=会話不能)(4以上はバグ
;TCVAR:泥酔(1=通常成功or大失敗)
;==================================================
@M_KOJO_SUCCESS_COM_K151_300
;成否判定
;TFLAG:192(-2=コマンド終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

@M_KOJO_MESSAGE_COM_K151_300
;コマンド共通メッセージ(TRAIN_MESSAGE) 
;削除すると「～話をした。」とかが消えます。また、削除した場合は自動で口上色が付きません。
;口上メイン呼出
CALL M_KOJO_MESSAGE_COM_K151_300_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K151_300_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;ここに口上書いて下さい
	IF TFLAG:193 > -1
		IF RAND:3
			CALL K151_CONVERSATION_INTERACTION
			SIF RESULT
				RETURN 0
		ENDIF

		IF TALENT:[[ユウゲンマガン]]:恋人
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 
				CASE 1
					PRINTFORML 
				CASE 2
					PRINTFORML 
			ENDSELECT
		ELSEIF TALENT:[[ユウゲンマガン]]:セフレ || TALENT:[[ユウゲンマガン]]:愛欲
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 
				CASE 1
					PRINTFORML 
				CASE 2
					PRINTFORML 
			ENDSELECT
		ELSEIF TALENT:[[ユウゲンマガン]]:思慕 || TALENT:[[ユウゲンマガン]]:恋慕
			$YM_YEARNING_CONVOS
			SELECTCASE RAND:9
				CASE 0
					PRINTFORMDW 幽幻魔眼皱了皱眉
					PRINTFORMW 「最近，每次看到你，血液都会涌向这具身体的脸」
					PRINTFORMW 「你知道这意味着什么吗？这令人困惑」
				CASE 1
					PRINTFORMW 「如何……交朋友？」
					PRINTFORMW 「别人都有朋友，而我们没有，这令人困惑」
					PRINTFORMDW 并非如此。你是她的朋友，不是吗？
					PRINTFORMW 「真的吗？那是什么时候发生的？又是怎么发生的？」
					PRINTFORMDW 你解释友谊就是与某人相处时感到愉快
					PRINTFORMW 「啊……但“愉快”意味着什么？」
					PRINTFORMDW ……这需要一段时间
					PRINTFORMW 经过一番解释后，幽幻魔眼将手放在她的胸前
					PRINTFORMDW 所以我们在你面前感到的那种奇怪感觉……是愉快？
					PRINTFORMW 「那意味着你和我们是朋友？」
					PRINTFORMDW 你点点头，有点烦躁
					PRINTFORMW 「那很好」
					PRINTFORMDW 她露出了一个奇怪的倒笑
					PRINTFORMW 「我……很高兴……你是我们的朋友」

				CASE 2
					PRINTFORML 「什么是太阳？」
					PRINTFORMW 「是女神天照，还是一个炽热的等离子体？」
					PRINTFORMW 「我们听到了一些相互矛盾的说法」

				CASE 3
					PRINTFORMW 「告诉我们关于红线的故事」
					PRINTFORMW 「人人都有命中注定的伴侣吗？」
					CALL ASK_YN("确实有", "并没有")
					IF !RESULT
						PRINTFORMW 「有趣」
						PRINTFORMW 「只有物质生物才会有吗？」
						PRINTFORMW 「……我们很好奇！仅此而已！」
						PRINTFORMDW 但她脸上的红晕却透露了更多……
					ELSE
						PRINTFORMW 「只是迷信吗？那真可惜」
					ENDIF

				CASE 4
					SIF !CFLAG:[[ユウゲンマガン]]:K151EN_YM_NATURE == 0
						GOTO YM_YEARNING_CONVOS
					PRINTFORMW 「我们知道这有点奇怪的问题……」
					PRINTFORMW 「如果你在乎的人对你隐瞒了一个秘密并撒了谎……」
					PRINTFORMW 「如果那个秘密被揭开，你会原谅他吗？」
					CALL ASK_YN("会的", "不会")
					IF !RESULT
						PRINTFORMW 「...」
						PRINTFORMW 「你真善良」
						PRINTFORMW 「我怀疑大多数人都不会这样……」
					ELSE
						PRINTFORMW 「...」
						PRINTFORMW 「我明白了...」
						PRINTFORMDW 幽幻魔眼把目光移开
					ENDIF

				CASE 5
					SIF !TALENT:妊娠
						GOTO YM_YEARNING_CONVOS
					PRINTFORML 「即使我们怀有孩子，我们也没有理由离开」
					SELECTCASE K151_YM_NATURE()
						CASE 0
							PRINTFORMW 「我们必须好好培养它……」
							PRINTFORMDW 幽幻魔眼吞咽了一下
						CASE 1
							PRINTFORMDW 幽幻魔眼露出了她奇怪的倒笑
							PRINTFORMW 「我们渴望有更多的孩子……很多……」
					ENDSELECT

				CASE 6
					SIF !TALENT:妊娠
						GOTO YM_YEARNING_CONVOS
					PRINTFORML 「如果我们的孩子看起来和我们一模一样，请不要惊讶」
					PRINTFORMW 「这是伟大的存在的方式」

				CASE 7
					SIF !FLAG:異常気象 == 7
						GOTO YM_YEARNING_CONVOS
					PRINTFORMW 「内衣在空中飞舞」
					PRINTFORMW 「这在你们的世界是常见的事情吗？」
					PRINTFORMW 「只有在幻想乡？真奇怪……」

				CASE 8
					SIF !BASE:[[ユウゲンマガン]]:体力 < 750
						GOTO YM_YEARNING_CONVOS
					PRINTFORMDW 幽幻魔眼打了个哈欠
					PRINTFORMW 「真烦人……这具身体出了问题」
					PRINTFORMW 「如果我们还有能力，我们会摧毁它再造一个」
					PRINTFORMW 「遗憾的是，我们似乎只能睡觉了」

				CASE 9
					PRINTFORMW 「真奇怪」
					PRINTFORMW 「在*下面*，只要我们的意志够强，我们可以任意改变世界」
					PRINTFORMW 「然而在物质世界，我们不能这样做」
					PRINTFORMW 「你的世界有自己的意志吗？」

			ENDSELECT
		ELSE
			SELECTCASE RAND:7
				CASE 0
					PRINTFORMW 「“下面”是什么样的？」
					PRINTFORMDL 幽幻魔眼笑了。至少你认为那是笑
					PRINTFORMDW 更像是一声吠叫，就像有人告诉她笑是什么样的，但她从未真正听过
					PRINTFORMW 「你不会理解的。让我们看看能否用你的语言来描述…」
					PRINTFORMDW 她停下来思考。她的整个身体僵硬了，几乎就像你刚刚停止了时间一样
					PRINTFORMW 「那里有……漂亮的颜色，但很疼。我们喜欢这里，因为这里不疼」
				CASE 1
					PRINTFORMW 「你喜欢我们的眼睛吗？我们认为那是我们的最佳特征」
					PRINTFORMW 「尽管它们和你的眼睛不同。在我们来自的地方，不需要眼睛也能看见」
					PRINTFORMW 「它们是我们在你的世界中表现自己的方式。我们不知道为什么」
				CASE 2
					PRINTFORMW 「……你见过神绮了吗？」
					PRINTFORMW 「……明白了」
					PRINTFORML 「那个女人是个骗子，不值得信任」
					PRINTFORMW 「不要相信她说的任何话。这只会导致灾难」
					PRINTFORMDW 幽幻魔眼看起来很不安……
				CASE 3
					PRINTFORMW 「那个觉让我们很感兴趣。她的第三只眼真的属于她，还是像我们一样的另一个生物？」
					PRINTFORMW 「我们想调查，但我们不希望她读取我们的心」
					PRINTFORMW 「不是因为我们有任何秘密。我们只是担心她的安全」
					PRINTFORMW 「如果她试图读取我们的心，我们担心那会……很混乱」
				CASE 4
					PRINTFORMW 「萨拉还在守护魔界的大门吗？」
					PRINTFORMDW 幽幻魔眼叹了口气。这让她看起来挺人性的
					PRINTFORMW 「为什么那些年她不和巫女战斗？为什么是我们做她的工作？」
					PRINTFORMW 「好像我们没有足够的理由讨厌她……」
				CASE 5
					PRINTFORMW 「那个未开眼的觉妖怪让我们很感兴趣。我们是五个一体，而她是一个没有心智的个体」
					PRINTFORMW 「如果她没有心智……我们或许可以和她谈论我们世界的事情而不会让她疯狂？」
					PRINTFORMW 「能有一个我们不需要保守秘密的人会很好」
					PRINTFORMDW 幽幻魔眼看起来有些……渴望
				CASE 6
					PRINTFORMW 「那个工程师的恶眼是模仿我们的吗？真有趣」
					PRINTFORMW 「我们必须向她道谢。或许我们会让她成为我们教派的大祭司……」
				CASE 7
					PRINTFORMW 「什么是“div”？」
					PRINTFORMW 「那位桥姬有时会在认为我们不听的时候低声说出来」
					PRINTFORML 「我们猜那不是爱称。也许是侮辱？」
					PRINTFORMW 「无论它是什么，我们都不喜欢被侮辱」
					PRINTFORMDW 幽幻魔眼隐隐露出一丝微笑，但她的眼神冰冷而充满怒火
					PRINTFORMW 「我们会在适当的时候教训她……」
			ENDSELECT
		ENDIF
	ENDIF
ENDIF
RETURN 1
