			;ある程度アナル開発済み
			IF ABL:Ａ感覚 > 3
				PRINTFORML 「だ、ダメっ！ そ、そんなに大きいの…、入らないって！」
				PRINTFORMW そろそろ頃合いと思い%CALLNAME:MASTER%が雛の尻穴に肉棒をあてがうと、雛は否定の声をあげた。
				PRINTFORML 「うっ、くぅっ…！ お、おなかのなか、くるしくてっ……、んん、くうぅっ……！」
				PRINTFORMW 肉棒の先端に愛液を馴染ませながら、ゆっくりと雛の尻穴に肉棒を突き入れていった……。
			ELSE
				PRINTFORML 「ひっ……、やめてっ！ あっ、ぐぅっ……、い、いやぁっ！！」
				PRINTFORMW 未開発のアナルに%CALLNAME:MASTER%の肉棒を突き刺すと、雛は悲鳴をあげた。
				PRINTFORML 「い、いたいいたいっ、ひっぐっ、いだいよぉっ……！」
				PRINTFORMW 尻穴が裂ける強烈な痛みにジタバタと暴れる雛を押さえつけ、%CALLNAME:MASTER%は腸内を蹂躙していった……。
			ENDIF
		ELSE
			IF TALENT:恋慕
				PRINTFORMW 
			ELSE
				PRINTFORMW 
			ENDIF
		ENDIF
	;絶頂判定
	CALL M_KOJO_MESSAGE_EVENT_K79_EX_ORGASM
	RETURN 1
	ENDIF
	;基本セット
	;恋慕
	IF TALENT:恋慕
		PRINTFORMW 
	;屈服3
	ELSEIF MARK:不埒刻印 == 3
		PRINTFORMW 
	;それ以外
	ELSE
		PRINTFORMW 
	ENDIF
	;絶頂判定
	CALL M_KOJO_MESSAGE_EVENT_K79_EX_ORGASM
ENDIF
RETURN 1
