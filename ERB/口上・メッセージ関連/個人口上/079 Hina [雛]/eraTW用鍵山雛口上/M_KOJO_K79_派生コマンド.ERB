;==================================================
;7,挿入子宮口責め
;==================================================
@M_KOJO_MESSAGE_SCOM_K79_7
CALL M_KOJO_MESSAGE_SCOM_K79_7_1
RETURN RESULT
@M_KOJO_MESSAGE_SCOM_K79_7_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;初めて
	IF FIRSTTIME(SELECTCOM)
		IF TALENT:恋慕
			PRINTFORML 「ん、くぅっ…、な、なにこれっ、すごく、ふかくてっ、あっあぁぁっ！！？」
			PRINTFORMW 初めて子宮口を責められ、雛はむず痒そうな表情を浮かべている……。
		ELSE
			PRINTFORML 「うっ…、んんんっ！？ はぁっ、こんなに、ふかいのっ……、んん、あぁぁっ！？」
			PRINTFORMW 雛は子宮口を突かれる感覚に戸惑っているようだ……。
		ENDIF
		;絶頂判定
		CALL M_KOJO_MESSAGE_EVENT_K79_EX_ORGASM
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:時間停止
		PRINTFORMW 
		RETURN 1
	;恋慕の場合開発経験で分岐
	ELSEIF TALENT:恋慕
		IF EXP:TALENT:子宮口開発経験 >= 75
			SELECTCASE RAND:5
				CASE 0
					PRINTFORML 「ん、んぐぅうっ～～%UNICODE(0x2764)% お、おくまで、きてるぅぅっ～～～%UNICODE(0x2764)%」
					PRINTFORMW %CALLNAME:MASTER%の亀頭と雛の子宮口がぶつかり合う柔肉の感覚に、雛はすっかり酔いしれている……。
					PRINTFORML 「あぁぁっ～～%UNICODE(0x2764)% はふぅ、はぁっ%UNICODE(0x2764)% %CALLNAME:MASTER%っ、%CALLNAME:MASTER%っ～～%UNICODE(0x2764)%」
					PRINTFORMW 子宮口から子宮全体を何度も揺さぶられ、雛の心は女として最高の悦びに満たされた……。
				CASE 1
					PRINTFORML 「ふああぁっ%UNICODE(0x2764)% あぅっ、うっ、あああぁっ%UNICODE(0x2764)% んんっ、あっあぁあああっ～～～%UNICODE(0x2764)%」
					PRINTFORMW %CALLNAME:MASTER%の剛直が雛の柔らかい子宮口をグニグニと押し潰す度に、雛は悦びの悲鳴をあげている……。
					PRINTFORML 「しっ、しきゅうぅっ%UNICODE(0x2764)% あぁっ、しきゅうがっ、ひいぃ%UNICODE(0x2764)% きもぢいいのぉおおおっ～～%UNICODE(0x2764)%」
					PRINTFORMW すっかり快楽に飲み込まれた雛は、心身ともに乱れ狂った……。
				CASE 2
					PRINTFORML 「ふぅんんっ%UNICODE(0x2764)% はああぁっ、あっ、あぁっ、%CALLNAME:MASTER%～～%UNICODE(0x2764)%」
					PRINTFORMW 入念な開発のおかげで雛の子宮口は柔らかくなり、時折収縮しながら%CALLNAME:MASTER%の亀頭を優しく受け止めている。
					PRINTFORML 「あっあっ、あぁああっ～%UNICODE(0x2764)% きもちよすぎて、はぁっ%UNICODE(0x2764)% あかちゃん、できちゃううぅ～～%UNICODE(0x2764)%」
					PRINTFORMW 雛の脳裏に『妊娠』という単語がチラつき、雛の興奮はより一層高まっていった……。
				CASE 3
					PRINTFORML 「ああぁっ…、あああぁっ%UNICODE(0x2764)% はっ、ふぅんっ%UNICODE(0x2764)% ら、らめっ、こんなの、こわれひゃうぅっ～%UNICODE(0x2764)%」
					PRINTFORMW 雛の子宮口を%CALLNAME:MASTER%の亀頭でノックすると、雛は全身をガクガクと震わせながら快楽に翻弄されている……。
					PRINTFORML 「ひゃあぅんっ！ ひゃっ、やぁあああぁっ%UNICODE(0x2764)% せっ、せっくしゅっ%UNICODE(0x2764)% きもちっ、ひいよぉっ～～%UNICODE(0x2764)%」
					PRINTFORMW %CALLNAME:MASTER%のペニスがもたらす至高の快楽に陶酔しながら、雛は牝の肉欲に溺れていった……。
				CASE 4
					PRINTFORML 「ふわああぁっ、あっ、%CALLNAME:MASTER%っ、あふぅっ%UNICODE(0x2764)% もっと、もっとっ、ふかいとこまでっ、きてぇぇっ～～%UNICODE(0x2764)%」
					PRINTFORMW 開発された雛の子宮口は吸盤のように%CALLNAME:MASTER%の剛直に吸い付き、%CALLNAME:MASTER%を子宮口の更に奥へと誘おうとしている……。
					PRINTFORML 「ひゃあああぁんっ！ ああぁっ、しきゅうがっ%UNICODE(0x2764)% あああぅっ、あっあああっ、ひぃんっ、きもちいいのっ%UNICODE(0x2764)% 」
					PRINTFORMW %CALLNAME:MASTER%の抽送に合わせて、雛は腰を揺らしながら喘ぎ乱れた……。
			ENDSELECT
		ELSEIF EXP:TALENT:子宮口開発経験 >= 50
			PRINTFORML 「ひっ、ああぁっ…！ ふぅっ、くうぅっ……！ んんっ、ふああぁっ、あっ、あああぁっ！！」
			PRINTFORMW %CALLNAME:MASTER%のペニスで雛の子宮口を小刻みに刺激する毎に、雛は甘く蕩けた声で鳴いている……。
			PRINTFORML 「はふぅっ…… あっ、あああぁあっ！？ ああぁっ、そんなの、らめええええぇぇえぇっ～～」
			PRINTFORMW そして亀頭が子宮口にギュッと押し込まれた瞬間、雛は意識が飛ぶほどの快楽に襲われ、本能のままに叫び狂った……。
		ELSEIF EXP:TALENT:子宮口開発経験 >= 25
			PRINTFORML 「あっ…、うぐっ、あぁっ……！ そ、そんなに、おくっ…、うぅっ、つかないでっ……！」
			PRINTFORMW 徐々に綻び始めた雛の子宮口は%CALLNAME:MASTER%の突きを快楽として認識しようとしている……。
			PRINTFORML 「はぅっ！ ああぁっ…、くぅんっ、あっ……！ だめっ…、おくで、おかしく、なっちゃうっ……！」
			PRINTFORMW %CALLNAME:MASTER%は亀頭で雛の子宮口を更に責め立てていき、雛の子宮口を解きほぐしていった……。
		ELSE
			PRINTFORML 「くぅっ……、うぅっ…！ %CALLNAME:MASTER%っ、そ、そこっ…、ムズムズしてっ、あぁっ…、あああぁっ！」
			PRINTFORMW %CALLNAME:MASTER%のペニスが雛の子宮口を小突くと、腫れ物に触れたようなむず痒さが雛の全身に伝わった……。
			PRINTFORML 「ひっ、あぅっ…、こんなに、ふかいの、ああぁっ……、ううっ、だめぇっ……！」
			PRINTFORMW このむず痒さは快感には至っておらず、雛は未知なる刺激に戸惑っている……。
		ENDIF
	;屈服3
	ELSEIF MARK:不埒刻印 == 3
		PRINTFORML 「はあぁっ…、あっ、あああぁっ…！ おくまで、きててっ……、くうっ…、あああぁっ！！」
		PRINTFORMW 雛は%CALLNAME:MASTER%のペニスによる子宮口責めを受け止めながら、なりふり構わず喘いでいる……。
		PRINTFORML 「だ、だめぇっ……！ ふっ、ふかいとこ、かんじすぎてっ…、あっ、やっ、ふああぁんっ！！」
		PRINTFORMW 子宮口がグイグイと圧迫される度に、雛は息を荒げて嬌声を上げ続けた……。
	;それ以外
	ELSE
		PRINTFORML 「うっ、くぅっ…、あああぁっ！？ はあぁっ、はぁっ……、また、そこっ…！？」
		PRINTFORMW %CALLNAME:MASTER%が雛の子宮口を責めると、雛は堪らず悲鳴をあげた……。
		PRINTFORML 「そこは、ムズムズするからっ……、あ、あんまり、奥までいれないでっ……」
		PRINTFORMW どうやら雛にとって子宮口責めは刺激が強すぎるようだ……。
	ENDIF
	;絶頂判定
	CALL M_KOJO_MESSAGE_EVENT_K79_EX_ORGASM
ENDIF
RETURN 1

