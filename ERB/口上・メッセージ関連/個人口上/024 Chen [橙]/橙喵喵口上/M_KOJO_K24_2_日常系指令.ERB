;410,掃除
;FLAG:70(1=時間停止中
;TFLAG:193(0=钦佩地注视 1=一起帮忙扫地)
;TFLAG:194(3=脏污程度高 2=脏污程度中 1=脏污程度低 0=脏污程度最小
;OUTROOF(CFLAG:300)(野外掃除时、冬天会变成扫雪
;==================================================

@M_KOJO_MOKA_MESSAGE_MESSAGECHECK_COM_K24_410
RETURN 0

@M_KOJO_MOKA_MESSAGE_COM_K24_410
CALL M_KOJO_MOKA_MESSAGE_COM_K24_410_1
RETURN RESULT

@M_KOJO_MOKA_MESSAGE_COM_K24_410_1
;-------------------------------------------------
;启用（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF FLAG:70 ;时停
		SELECTCASE RAND:3
		CASE 0
			PRINTFORMDW 在时间停止之下、哪怕最爱跑的小猫也会静止下来
			PRINTFORMDW	一想到这种情况该多么适合打扫、%CALLNAME:MASTER%就露出了得意的笑容 
		CASE 1
			PRINTFORMDW %CALLNAME:MASTER%完全无视了眼前的橙、拿出了扫把打扫起来
			PRINTFORMDW 哪怕是小猫妖脚底下的灰尘都被%CALLNAME:MASTER%扫得一干二净了
		CASE 2
			IF TFLAG:194 >= 2
			PRINTFORMDW 周围真是一团糟...抱着让橙看着舒服的想法、%CALLNAME:MASTER%立马开始了打扫
			ELSE
			PRINTFORMDW 周围几乎打扫干净、%CALLNAME:MASTER%干脆开始给橙周围的小猫咪们梳毛了
			ENDIF
		ENDSELECT
	ELSEIF CFLAG:24:313 || CFLAG:24:316 ;睡眠或虚弱
			SELECTCASE RAND:4
				CASE 0
					PRINTFORMW 「呜喵～呼呼...zzz...」
				CASE 1
				IF TALENT:24:3 ;恋慕
					PRINTFORMW 「呼...谢谢...%CALLNAME:MASTER%...」
				ELSE
					PRINTFORMW 「呼...谢谢...蓝大人...」
				ENDIF
				CASE 2
				PRINTFORMW 「不要...橙会扫...zzz...」	
				CASE 3
				PRINTFORMW 「嗯唔...zzz...」	
			ENDSELECT
	ELSEIF TALENT:24:15 == -1 ;不高兴
			IF CFLAG:24:1002 >= 1 ;恋慕相关不高兴已触发	
			CFLAG:24:318 = 1
			TALENT:24:15 = -1
			SELECTCASE RAND:3
				CASE 0
					PRINTFORMW 「哼...」
					PRINTFORMDW 即便看到了%CALLNAME:MASTER%拿着扫把正朝自己走来、橙也没有任何让开的意思
					PRINTFORMDW 无可奈何的%CALLNAME:MASTER%只好绕开小猫妖继续打扫  
				CASE 1
				IF TALENT:MASTER:7 && MARK:3 > 1 ;非常生气！
					PRINTFORMW 「那么喜欢在橙的面前扫地的话、就让%CALLNAME:MASTER%扫个够好了！」
					PRINTFORMW 「小家伙们、给我上！」
					PRINTFORMDW 突然不知道从哪冒出来的小猫们、把刚刚收集好的垃圾袋甩得到处都是...
					PRINTFORMDW 等到%CALLNAME:MASTER%收拾完、小猫妖已经不见踪影了
					;ps.或许应该加一点耗费的时间...
					CFLAG:24:320 = 0
					CFLAG:0:320 = 0
					CFLAG:24:300 = CFLAG:24:311
					CALL DOKU_KM_RENEW_TARGET(24)
				ELSE
