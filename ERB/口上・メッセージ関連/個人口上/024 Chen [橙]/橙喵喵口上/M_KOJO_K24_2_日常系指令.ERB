;八云一家
;━━━━━━━━━━━━━━━━━━━━━━━━━

@CHEN_FAMILYTALK
IF ONCE("八云一家")
	IF TALENT:24:7 ;恋人
		SELECTCASE RAND:3
		;猜猜我是谁？
		CASE 0
		CALL CHARA_TEXT,[[蓝]],@"『橙～～到我这边来哦～～』","W"
		PRINTFORMDW 左边是蓝大人亲切的呼唤、橙下意识地转了过去
		CALL CHARA_TEXT,[[蓝]],@"『呵呵、橙～～这边这边～这里才是真的蓝大人哦～』","W"
		PRINTFORMDW 右边又传来一声似乎一模一样的呼唤、橙转过去、又看见了一个蓝大人！
		PRINTFORMW 「哎哎？怎么突然有两个蓝大人了啊！是分身术吗？」
		PRINTFORMDW 小猫妖一下子迷糊了、赶紧凑近了%CALLNAME:MASTER%
		PRINTFORMW 「%CALLNAME:MASTER%肯定知道怎么回事的吧！」 
		PRINTFORMDW 嗯...怎么看、肯定有一个是假的蓝大人吧、那另一个的话、或许是紫大人假扮的
		PRINTFORMDW 不过两个人都是一模一样的金发、还穿着一模一样的衣服、哪怕神色和尾巴数目都是一模一样的...似乎真的没什么破绽呢...
		PRINTFORMDL 难不成要靠直觉吗？
		CALL ASK_YN("左边！","右边！")
		IF !RAND:2
		PRINTFORMW 「嗯！我相信%CALLNAME:MASTER%、嘿～！」
		PRINTFORMDW 小猫妖瞬间扑进了左边的蓝大人怀里、后者果然自然而然地、稳稳当当地接住了橙
		PRINTFORMW 「嗯嗯！果然没错哦、蓝大人接住橙的手法、不会变的哦」
		PRINTFORMW 「%CALLNAME:MASTER%猜的真准啊！」
		ELSE
		PRINTFORMW 「嗯！%CALLNAME:MASTER%的话、我相信哦！嘿～！」 
		PRINTFORMDW 向着右边的蓝大人扑过去的小猫妖、被对方抓住后颈甩了回去
		PRINTFORMW 「哇啊、猜错了！这个是紫大人假扮的！被当成弹幕丢出去了啊————」
		PRINTFORMDW 橙旋转着飞远了... 
		ENDIF 
		CASE 1
		;蓝大人吃醋了
		CALL CHARA_TEXT,[[蓝]],@"『嗯...哎...』","W"
		PRINTFORMDW 看着自己空荡荡的大腿、蓝叹了一口气
		PRINTFORMDW 以往这个时候、橙往往会乖乖地趴在蓝的大腿上、任由蓝来抚摸
		PRINTFORMDW 但是现在、自己的式神更喜欢待在%CALLNAME:MASTER%的大腿上了
		CALL CHARA_TEXT,[[蓝]],@"『...对橙来说、这说不上是坏事...所以也没什么！』","W"
		PRINTFORMDW 蓝的表情虽说还算自然、但是那对放在膝盖上的手却在不自觉间把衣服都揉皱了
		CALL CHARA_TEXT,[[紫]],@"『你们两个、还真是黏在一起了呢』","W"
		PRINTFORMDW 坐在一旁的紫一边喝着%CALLNAME:MASTER%沏的茶、一边看着%CALLNAME:MASTER%和膝上蜷成一团的小猫妖
		CALL CHARA_TEXT,[[紫]],@"『啊、看着简直比以前在蓝怀里还要更亲密啊、不是吗？』","W"
		PRINTFORMDW 紫一边说、一边不时用眼睛瞟着旁边坐立不安的九尾式神
		PRINTFORMDW 这已经不是暗示了、而是明示啊
		PRINTFORMW 「嗯...一边是蓝大人、另一边是%CALLNAME:MASTER%、感觉好难选呢...」
		PRINTFORMDW 橙在%CALLNAME:MASTER%的大腿上翻了个身、看着%CALLNAME:MASTER%的脸
		PRINTFORMW 「不过啊...既然蓝大人以前天天都让橙趴在腿上、那现在橙多在%CALLNAME:MASTER%的腿上也是情有可原的嘛！」
		PRINTFORMW 「所以、蓝大人对不起了哦！嘿嘿、%CALLNAME:MASTER%的手摸得好舒服～～」
		CALL CHARA_TEXT,[[蓝]],@"『啊、橙说的也没错呢、...还有、我完全、完全没有在吃醋哦！』","W"
		PRINTFORMDW 话是这么说...但是蓝的衣服已经快揉成一团了、表情也变得有点吓人了...
		CALL CHARA_TEXT,[[蓝]],@"『紫大人？对不住了哦』","W"
		CALL CHARA_TEXT,[[紫]],@"『嗯？怎么了————啊！』","W"
		CALL CHARA_TEXT,[[紫]],@"『喂喂喂、蓝、代餐可不能当饭吃...』","W"
		PRINTFORMDW 妖怪贤者被自己的式神用尾巴拽到了大腿上、然后被早已躁动不安的双手狠狠“蹂躏”了一番金发
		CASE 2
		;比大小
		PRINTFORMW 「说起来、%CALLNAME:MASTER%有注意过吗？彩虹的颜色是怎么样的？」
		PRINTFORMDW 赤橙黄绿青蓝紫、没错吧？
		PRINTFORMW 「嗯、毕竟这是常识一样的东西呢」
		PRINTFORMW 「而且啊、这里还有个有意思的事情、%CALLNAME:MASTER%发现过吗？」
		PRINTFORMW 「赤 “橙” 黄绿青 “蓝” “紫”、刚好是橙、蓝大人和紫大人从弱到强的排序呢」  
		PRINTFORMW 「不过这样算的话、中间为什么还有三个颜色啊？而且橙后面还有颜色、红色的话...」
		PRINTFORMDW 实在想不出能排在橙之后的红色角色呢（笑）
		ENDSELECT
	ELSEIF TALENT:24:3 ;恋慕
		PRINTFORMDW
	ELSEIF TALENT:24:8 ;思慕
		PRINTFORMW	
	ELSE
		PRINTFORMDW
	ENDIF
ELSE
	SELECTCASE RAND:2
	CASE 0
	CALL CHEN_NORMALTALK
	CASE 1
	CALL CHEN_SEASONTALK
	ENDSELECT
ENDIF

