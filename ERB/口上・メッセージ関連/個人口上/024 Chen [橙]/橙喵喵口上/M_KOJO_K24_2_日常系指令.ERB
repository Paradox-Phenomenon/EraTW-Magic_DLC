;人物互动
;━━━━━━━━━━━━━━━━━━━━━━━━━

@CHEN_TALKWITH_RAN ;蓝
IF ONCE("与蓝的互动")
	IF TALENT:24:7 || TALENT:24:3 ;与蓝的互动（恋人and恋慕）
		SELECTCASE RAND:3
		CASE 0	
			PRINTFORMW 「蓝大人～～！要抱抱～～！」
			PRINTFORMDW 橙一路小跑着凑近了早早张开双臂的蓝大人、后者抱着橙转起圈来
			PRINTFORMDW 真是温馨的一幕啊、%CALLNAME:MASTER%看着放下橙的蓝感慨道
			IF TALENT:25:3 ;蓝为恋慕
				CALL CHARA_TEXT,[[蓝]],@"『呵呵～%CALLNAME:MASTER%、不也来让我抱一抱吗？很舒服的哦～ 』","W"
				PRINTFORMDW 面对蓝敞开胸怀、充满诱惑的提议、%CALLNAME:MASTER%难以提出拒绝、立马把脸埋进了那对柔软之中
				PRINTFORMW 「啊！我也要来抱一抱%CALLNAME:MASTER%！」
				PRINTFORMDW 小猫妖不甘示弱、从背后环腰抱住了%CALLNAME:MASTER%
				PRINTFORMDW 接下来的时间、在主从二人包围一般的拥抱中度过、感觉舒服得要睡着了...
			ELSE
				PRINTFORMW 「啊！差点忘记了、%CALLNAME:MASTER%～～！也要抱抱～～！」
				PRINTFORMDW 看着张开双臂跑过来的小猫妖、%CALLNAME:MASTER%也主动张开双臂作为回应
				PRINTFORMDW 怀里的小猫妖、让%CALLNAME:MASTER%感到了一股别样的温暖感觉...
			ENDIF	
					
		CASE 1
			CALL CHARA_TEXT,[[蓝]],@"『橙～～哦、你在和%CALLNAME:MASTER%在一起呢』","W"
			PRINTFORMDW 九尾的式神一边呼唤着橙的名字、一边凑近了
			PRINTFORMDW 朝%CALLNAME:MASTER%打过招呼后、蓝就示意小猫妖到自己这边来、然后用尾巴紧紧藏住了二人
			PRINTFORMDW %CALLNAME:MASTER%好奇地凑近、可惜只能听到微弱的声音、听不真切
			PRINTFORMDW 不过二人并没有持续多久的谈话、没几分钟小猫妖就自己跑回了%CALLNAME:MASTER%怀里
			CALL CHARA_TEXT,[[蓝]],@"『好了、我就说这些哦、不打扰你们了』","W"
			PRINTFORMDW 蓝朝着%CALLNAME:MASTER%微微欠身、然后走开了
			PRINTFORMW 「%CALLNAME:MASTER%肯定很好奇蓝大人跟我说了什么吧！」
			PRINTFORMW 「不过这些都是很厉害的东西！只能悄悄告诉%CALLNAME:MASTER%哦！」
			PRINTFORMDW %CALLNAME:MASTER%识趣地蹲下来、耳朵靠近小猫妖
			SELECTCASE RAND:14
			CASE 0,6,10
				PRINTFORMW 「蓝大人说、这道菜可以这样做...」
				PRINTFORMDW 学到了烹饪的心得
				EXP:24:76 += 3
				EXP:MASTER:76 += 3
				PRINTL
				PRINTFORMDW 二人的烹饪经验提升了！
			CASE 1,7,11
				PRINTFORMW 「蓝大人说、在那样的地方比较容易找到...」
				PRINTFORMDW 似乎是採集材料的秘诀
				EXP:24:84 += 3
				EXP:MASTER:84 += 3
				PRINTL
				PRINTFORMDW 二人的採集经验提升了！
			CASE 2,8,12
				PRINTFORMW 「蓝大人说、或许这样的设计会让弹幕更有威胁...」
				PRINTFORMDW 是弹幕的知识、定能活用于下次！
				EXP:24:74 += 3
				EXP:MASTER:74 += 3
				PRINTFORMDW 二人的战斗经验提升了！
			CASE 3,9,13
				PRINTFORMW 「...啾❤」
				PRINTFORMDW 秘密并没有如期而至、替代的是小猫妖轻轻吻了%CALLNAME:MASTER%的脸颊
				PRINTFORMW 「嘿嘿、我撒谎了、这回没有什么特别的知识啦！」  
				PRINTFORMW 「但是、%CALLNAME:MASTER%每回都在认真听橙的话、很感谢%CALLNAME:MASTER%哦！」
				EXP:24:41 += 3
				EXP:MASTER:41 += 3
			CASE 4 ;隐藏款1
				PRINTFORMW 「嗯、是、是在做‘那种’事情的时候、橙应该怎么做...」
				PRINTFORMDW 听着橙红着脸讲述着蓝丰富的、某些方面的经验...
				EXP:24:0 += 1
				EXP:24:1 += 1
				EXP:24:2 += 1
				EXP:24:3 += 1
				EXP:24:4 += 1
				PRINTFORMW
			CASE 5 ;隐藏款2
				PRINTFORMW 「蓝大人说、尾巴还可以这样用...」
				PRINTFORMDW 好奇怪的知识...反正%CALLNAME:MASTER%绝对用不到
				EXP:24:56 += 1
				EXP:MASTER:56 += 1
				PRINTFORMDW 奇怪的知识增加了！ 
			ENDSELECT
		CASE 2	
			CALL CHARA_TEXT,[[蓝]],@"『橙～～哦、你果然和%CALLNAME:MASTER%在一起啊』","W"
			PRINTFORMDW 呼喊着橙的名字、蓝快步走到了两人面前、摸着小猫妖的头、长长地吐了一口气
			CALL CHARA_TEXT,[[蓝]],@"『呼～一段时间都没看到橙在我身边、都让我感觉有些心慌了呢』","W"
			CALL CHARA_TEXT,[[蓝]],@"『不过也是呢、现在的橙肯定更喜欢和%CALLNAME:MASTER%待在一块吧？』","W"
			PRINTFORMW 「喵？！才、才没有这种事情！我当然是————呜...」
			PRINTFORMDW 小猫妖下意识地反驳、但是事实又让她刚想说出来的话又咽了回去
			PRINTFORMDW 低下头自己嘀咕了几句后、小猫妖才重新抬起头来
			PRINTFORMW 「那个...橙喜欢%CALLNAME:MASTER%是没有错啦！但是橙、橙也一样喜欢蓝大人！」
			PRINTFORMW 「跟对%CALLNAME:MASTER%的喜欢不一样、橙对蓝大人的喜欢...」  
			PRINTFORMW 「哎呀！！！反正、反正就是一样喜欢啦！」
			PRINTFORMDW 放弃解释自己心里的感情、小猫妖最后只是大喊了一句就钻进了%CALLNAME:MASTER%的怀里、不再说话了  
