;日常系指令
;※※※※※※※※※※※※※※※※※※※※※※※※※
;==================================================
;300,会話
;TFLAG:193(1=大成功 0=成功 -1=失敗 -2=大失敗（TARGET的教养等级比MASTER高出4级以上)
;TCVAR:302(0=会話可能 1>=非恋慕時会話不能)
;MARK:反発刻印(3以上=会話不能)
;TCVAR:泥酔(1=通常成功or大失敗)
;==================================================
@M_KOJO_MOKA_SUCCESS_COM_K24_300
;成否判定
;TFLAG:192(-2=强制中止指令、-1＝強制失敗、0=根据COM文件决定、1=強制成功or大成功
TFLAG:192 =0

;==================================================
;可选项：关于地文描述的显示设置
;如果返回0、则地文与口上都会显示；如果返回1、则地文会隐藏、口上会显示；如果返回2、则地文会显示、口上会隐藏；如果返回3则均会被隐藏
;==================================================
@M_KOJO_MOKA_MESSAGE_MESSAGECHECK_COM_K24_300
	RETURN 0
@M_KOJO_MOKA_MESSAGE_COM_K24_300
;指令共通メッセージ(TRAIN_MESSAGE) 
;4.920之前的指令地文、是使用函数TRAIN_MESSAGE来控制的
;如果删除它、例如「TARGET和你无聊地说着话」这种叙述将不显示、且您的口上不会自动启用口上色
;下面是调用口上的主函数
CALL M_KOJO_MOKA_MESSAGE_COM_K24_300_1
RETURN RESULT

@M_KOJO_MOKA_MESSAGE_COM_K24_300_1
;-------------------------------------------------
;启用（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
IF TALENT:24:15 == -1 ;不高兴
	CALL CHEN_ANGRYTALK
ELSEIF TFLAG:193 == -1 ;聊得太多
	CALL CHEN_BORINGTALK	
ELSEIF CFLAG:25:同室 == 1 && CFLAG:26:同室 == 1 ;八云一家
	CALL CHEN_FAMILYTALK
ELSEIF CFLAG:25:同室 == 1 ;蓝大人互动
	CALL CHEN_TALKWITH_RAN
ELSEIF CFLAG:26:同室 == 1 ;紫大人互动
	CALL CHEN_TALKWITH_YUKARI
ELSEIF CFLAG:36:同室 == 1 ;阿燐互动
	CALL CHEN_TALKWITH_ORIN
ELSEIF TALENT:24:7 ;恋人小事件
	CALL CHEN_LOVERTALK
ELSEIF TALENT:24:3 ;恋慕小事件
	CALL CHEN_LOVETALK
ELSEIF TALENT:24:8 ;思慕小事件
	CALL CHEN_LIKETALK
ELSEIF BASE:24:15 > 0 ;好孩子不喝酒、但万一呢？
	CALL CHEN_DRUNKTALK
ELSEIF TCVAR:24:142 == 1 || CFLAG:24:340 >= 500 ;想要了
	CALL CHEN_SEXYTALK
ELSE ;通常对话
	SELECTCASE RAND:2
	CASE 0
	CALL CHEN_NORMALTALK
	CASE 1
	CALL CHEN_SEASONTALK
	ENDSELECT
ENDIF
ENDIF
RETURN 1
;━━━━━━━━━━━━━━━━━━━━━━━━━
;生气对话
;━━━━━━━━━━━━━━━━━━━━━━━━━

@CHEN_ANGRYTALK
IF CFLAG:24:1002 >= 1 ;恋慕相关不高兴已触发	
	CFLAG:24:318 = 1
	TALENT:24:15 = -1
	TFLAG:193 = -1
	SELECTCASE RAND:3
	CASE 0
		PRINTFORMW 「哼！现在不想看见%CALLNAME:MASTER%！」
		PRINTFORMDW 刚刚凑近橙、橙就把脸别了过去
	CASE 1
	IF TALENT:MASTER:7 && MARK:3 > 1 ;非常生气！
		PRINTFORMW 「%CALLNAME:MASTER%、还要找橙做什么啊！」
		PRINTFORMW 「已经有了喜欢的人的话、就不要再来找我了！」
		PRINTFORMDW 橙突然甩下了话、嗖的一下就不见了
		CFLAG:24:320 = 0
		CFLAG:0:320 = 0
		CFLAG:24:300 = CFLAG:24:311
		CALL DOKU_KM_RENEW_TARGET(24)
	ELSE
		PRINTFORMW 「%CALLNAME:MASTER%、还要找橙干什么啊...」
		PRINTFORMW 「反正%CALLNAME:MASTER%也不会喜欢橙的...」
		PRINTFORMDW 橙避开%CALLNAME:MASTER%的视线、自顾自地说着
	ENDIF
	CASE 2
		PRINTFORMW 「哇啊啊啊！烦死了！」
		PRINTFORMW 「赶紧离我远点！离得越远越好！」
		PRINTFORMDW 橙对着%CALLNAME:MASTER%挥舞着双臂使出了一套猫猫拳、把%CALLNAME:MASTER%赶走了
	ENDSELECT
ELSEIF CFLAG:24:318 == 1 ;发火了
	TFLAG:193 = -1
	IF TALENT:24:7 ;恋人
		PRINTFORMW 「哼！%CALLNAME:MASTER%就是个笨蛋！」
		PRINTFORMW 「赶紧道歉、不然橙不理你了！」
		PRINTFORMDW 橙鼓着脸、直直地瞪着%CALLNAME:MASTER%
	ELSEIF TALENT:24:3 ;恋慕
		PRINTFORMW 「呜～！就算是对%CALLNAME:MASTER%、我也是会生气的！」
		PRINTFORMDW 橙正因为生气而闹别扭
	ELSEIF TALENT:24:8 ;思慕
		PRINTFORMW 「哼！不想理%CALLNAME:MASTER%！」
		PRINTFORMW 「不道歉我们就绝交！」
		PRINTFORMDW 小猫妖气鼓鼓地偏过头去
	ELSE 
		PRINTFORMW 「...哼！」
		PRINTFORMDW 看来不道歉、橙是不会再理你了
	ENDIF
ELSE ;只是不高兴
		PRINTFORMW 「嗯、嗯...」
		PRINTFORMDW 橙不太想说话、只顾着应付%CALLNAME:MASTER%的话
		PRINTFORMDW 看来小猫妖不太高兴呢
ENDIF	

;━━━━━━━━━━━━━━━━━━━━━━━━━
;对话太多
;━━━━━━━━━━━━━━━━━━━━━━━━━

@CHEN_BORINGTALK
	IF TALENT:24:3 != 1 && TALENT:24:8 != 1 ;无陷落状态
	SELECTCASE RAND:3
	CASE 0
		PRINTFORML 「好吵啊、%CALLNAME:MASTER%可以安静一下吗？」
		PRINTFORMDW 橙捂住了耳朵、瞪着%CALLNAME:MASTER%、让%CALLNAME:MASTER%尴尬地笑了笑
	CASE 1
		PRINTFORML 「这个事情%CALLNAME:MASTER%刚刚才说过的啊、难不成就忘记了吗？」
		PRINTFORML 「唔、怎么看%CALLNAME:MASTER%都不像会健忘的人啊」
		PRINTFORMDW 只是没话说了而已啦...
	CASE 2
		PRINTFORML 「...哼♪～～哼♪～哼哼♪」
		PRINTFORMDW 橙居然已经开始哼歌了、看来是完全忽略掉了%CALLNAME:MASTER%的话呢
	ENDSELECT
ELSE
	SELECTCASE RAND:3
	CASE 0
		PRINTFORML 「这个事情、刚刚不是说过了嘛？」
		PRINTFORMW 「%CALLNAME:MASTER%可别把橙当小孩子糊弄啊！」
	CASE 1
		PRINTFORML 「%CALLNAME:MASTER%、如果说不出话的话、要不要和橙玩一会呢？」
		PRINTFORMW 「橙也有些听累了、想活动一下呢」
	CASE 2
		PRINTFORML 「哦...」
		PRINTFORMDW 橙随意地回了一个字、然后两人之间陷入沉默、互相对视起来
		PRINTFORML 「...噗」
		PRINTFORMDW 看来橙先忍不住了
	ENDSELECT
ENDIF	

