                PRINTFORMW "嗯嗯……%UNICODE(0x2665) *1%啾%UNICODE(0x2665) *1%……要出来了吗？精液的气味从深处飘来%UNICODE(0x2665) *1%"
                PRINTFORMW "紫在感受到%CALLNAME:MASTER%的射精后，用灵活的舌头巧妙地引导着。"
            ELSE
                PRINTFORMW "嗯嗯%UNICODE(0x2665) *1%嗯%UNICODE(0x2665) *1%"
                PRINTFORMW "紫在感受到%CALLNAME:MASTER%的射精后，用灵活的舌头巧妙地引导着。"
                PRINTFORMW "这根阳具似乎正要说想要射精了……%UNICODE(0x2665) *1%"
            ENDIF
        ELSE
            IF RAND:3 == 0
                PRINTFORMW "嗯～"
                PRINTFORMW "紫在感受到%CALLNAME:MASTER%的射精后，用灵活的舌头巧妙地引导着。"
                PRINTFORMW "快点让我喝下去%UNICODE(0x2665) *1%"
            ELSEIF RAND:2 == 0
                PRINTFORMW "嗯嗯……再等一会吧"
                PRINTFORMW "紫在感受到%CALLNAME:MASTER%的射精后，用灵活的舌头巧妙地引导着。"
            ELSE
                PRINTFORMW "嗯嗯呛返的雄性味道%UNICODE(0x2665) *1%"
                PRINTFORMW "紫在感受到%CALLNAME:MASTER%的射精后，用灵活的舌头巧妙地引导着。"
            ENDIF
        ENDIF
    ;舌3以上
    ELSEIF ABL:舌 > 2
        ;精液中毒4以上
        IF ABL:精液中毒 > 4
            IF RAND:3 == 0
                PRINTFORMW "嗯……%UNICODE(0x2665) *1%舔%UNICODE(0x2665) *1%"
                PRINTFORMW "喜欢上了阴茎头的味道……%UNICODE(0x2665) *1%"
            ELSEIF RAND:2 == 0
                PRINTFORMW "嗯嗯%UNICODE(0x2665) *1%%UNICODE(0x2665) *1%%UNICODE(0x2665) *1%"
                PRINTFORMW "……让阳具的味道深深刻在我的记忆中%UNICODE(0x2665) *1%"
            ELSE
                PRINTFORMW "嗯嗯%UNICODE(0x2665) *1%舔%UNICODE(0x2665) *1%"
            ENDIF
        ELSE
            IF RAND:3 == 0
                PRINTFORMW "嗯嗯～"
                PRINTFORMW "我习惯了，只用舌头就能让你射精%UNICODE(0x2665) *1%"
            ELSEIF RAND:2 == 0
                PRINTFORMW "嗯嗯……这样好吗%UNICODE(0x2665) *1%"
            ELSE
                PRINTFORMW "嗯嗯味道熟悉了%UNICODE(0x2665) *1%"
            ENDIF
        ENDIF
    ;其他情况
    ELSE
        IF RAND:3 == 0
            PRINTFORMW "嗯……舔……%UNICODE(0x2665) *1%"
            PRINTFORMW "因为没怎么舔过阳具，所以技术可能不太好，你就忍耐一下吧"
        ELSEIF RAND:2 == 0
            PRINTFORMW "……舔……嗯……"
        ELSE
            PRINTFORMW "……嗯……啾……"
            PRINTFORMW "紫有些生涩地含着阴茎。"
        ENDIF
    ENDIF
