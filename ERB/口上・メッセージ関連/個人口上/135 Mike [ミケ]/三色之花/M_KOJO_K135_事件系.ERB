		;行动结束：似乎买完东西了
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;15.说教/被说教
	;要求在室外，非角色工作日；说教者限定映姬，被说教者不会是蓬莱人或神灵（小町和久侘歌除外）
	;干预（去看看情况）：无特殊效果，1/6被映姬发现卷入说教，消耗大量气力
	;说教总时间60~89分钟
	;-------------------------------------------------
	IF ARG == 15
		;-------------------------------------------------
		;行动中：根据被说教者性格倾向而变化
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;行动结束：根据被说教者性格倾向而变化
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;16.挖陷阱/掉进陷阱
	;要求在室外，挖陷阱者限定三月精、琪露诺、皮丝
	;干预（一起恶作剧/去看看情况）：无特殊效果
	;挖陷阱者持续时间40~69分钟，掉进陷阱者持续时间30~49分钟（多深的洞半个多小时才能爬出来啊）
	;-------------------------------------------------
	IF ARG == 16
		;-------------------------------------------------
		;行动中：增加落穴的数量
		;掉入陷阱者的反应根据战斗能力而变化
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;行动结束：双方的反应根据掉入陷阱者的战斗能力而变化/由于谁都没有中招感到很不爽
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;17.堆雪
	;要求在室外可以战斗训练的地方，气力大于500，积雪不少于500，非正在下雪
	;干预（一起堆雪）：消耗少量体力气力
	;持续时间不定，有些角色有特殊堆雪所以消耗时间不同
	;-------------------------------------------------
	IF ARG == 17
		;-------------------------------------------------
		;行动中：正在固定雪
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;行动结束：似乎因完成了作品而感到满足
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;18.钻被炉
	;要求冬季，在有被炉的地方
	;干预（在被炉里放松）：恢复体力气力
	;持续时间：有猫耳者120~179分钟，其他动物耳90~134分钟，否则60~89分钟
	;-------------------------------------------------
	IF ARG == 18
		;-------------------------------------------------
		;行动中：躺在被炉里取暖
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;行动结束：下定决心爬出了被炉
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
ENDIF
RETURN 1

