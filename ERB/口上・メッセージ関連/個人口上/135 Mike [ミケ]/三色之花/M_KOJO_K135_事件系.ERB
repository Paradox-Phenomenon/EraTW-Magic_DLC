;==================================================
;TARGET解除了逆推状态
;--------------------------------------------------
;ERB\イベント関連\EVENTCOMEND2.ERB
;ARG == 1 或 2 的情况由函数 @被逆推終了 管理，路径为 ERB\コマンド関連\COMF\COMF850 抜け出す.ERB
;==================================================
@M_KOJO_三色之花_EVENT_K135_30(ARG, ARG:1)
;口上角色编号 = TARGET
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;TARGET似乎有点疲劳、放开了MASTER
	;-------------------------------------------------
	IF ARG == 1
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGET积攒度释放完毕，放开了MASTER
	;在「TARGET好像已经满足了」时选择第一个选项，或无志气选择第二个选项时TARGET的施虐/MASTER的受虐属性不足
	;-------------------------------------------------
	IF ARG == 2
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在TARGET满足后，MASTER又反过来推倒了
	;非无志气情况下，在「TARGET好像已经满足了」时选择第二个选项
	;-------------------------------------------------
	IF ARG == 3
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;虽然TARGET已经满足了，但MASTER要求继续进攻直到坏掉
	;在「TARGET好像已经满足了」时选择第三个选项，或无志气选择第二个选项判定成功
	;此时会进入随便模式，无法推倒且难以摆脱
	;-------------------------------------------------
	IF ARG == 4
		PRINTFORML
		RETURN 1
	ENDIF
ENDIF
RETURN 1


;==================================================
;一天结束时的呢喃（未面识则不会触发）
;请一定严格控制触发条件，否则每天结束后都会显示，不必要地占据屏幕
;也因为这个原因，默认LOCAL开关设置成了0，请写之前先改为1
;CALL EVENTEND_TSUBUYAKI 的作用是画横线以及显示「TARGET的呢喃」，可以选择删去后自定义
;差分参考使用：CFLAG:オナバレ（被发现自慰，会显示「TARGET把脸埋在了枕头里面」）
;--------------------------------------------------
;ERB\イベント関連\AFTERTRA.ERB
;==================================================
@M_KOJO_三色之花_EVENT_K135_31(ARG, ARG:1)
;口上角色编号 = TARGET
;ARG为没见面的天数
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 0
;-------------
IF LOCAL
	;-------------------------------------------------
	;今日见过面
	;-------------------------------------------------
	IF ARG == 0
		CALL EVENTEND_TSUBUYAKI
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;一周没有见面了（关于未见面天数的差分，请自行设置）
	;-------------------------------------------------
	IF ARG == 7
		CALL EVENTEND_TSUBUYAKI
		PRINTFORML
		RETURN 1
	ENDIF
ENDIF
RETURN 1

;==================================================
;自由行动
;角色在清醒、空闲时（非同行、仕事、妊娠中等）随机从可用的行动种类中选择一种触发
;地文分歧均与充填度相关（是——这样吗）
;部分行动MASTER可以干预，效果根据行动种类变化（但为什么没有口上接口、真讨厌）
;行动开始时也没有口上接口，但幸而有判定函数，所以可以把口上写那里
;连锁行动：与正在自由行动的角色相性大于100的另一名角色可能会加入该行动（做差分可以考虑这个）
;--------------------------------------------------
;ERB\MOVEMENTS\自由行動\MOVEMENT_自由行動.ERB
;==================================================
@M_KOJO_三色之花_EVENT_K135_32(ARG, ARG:1)
;口上角色编号 = TARGET
;Activity_Duration:TARGET 为剩余的时间
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;0.思考事情
	;无任何要求
	;干预（在思考什么）：获得对话经验
	;持续时间20~39分钟
	;-------------------------------------------------
	IF ARG == 0
		;-------------------------------------------------
		;行动中：沉浸在思考之中
		;-------------------------------------------------
		IF ARG:1 == 0
			IF TALENT:恋人
				SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「唔嗯……」
					PRINTFORMDW 少女皺著眉頭思考著，尾巴不自覺地在畫著圈
					PRINTFORML 「……%CALLNAME:MASTER%？……」
					PRINTFORMDW 許是在尋求幫助吧，三花問了你一些事情
				CASE 1
					PRINTFORML 「嗯……」
					PRINTFORMDW 鬍鬚不自覺地跳動著，三花在思考著什麽
					PRINTFORML 「呃……」
					PRINTFORMDW 手指一直玩弄著頭髮，看樣子是陷入了苦戰呵
				CASE 2
					PRINTFORMDL 也不知從何時開始，三花那邊沒了動靜
					PRINTFORMDL 注意到這點之後，立刻往她那邊看去
					PRINTFORMDL 看到的卻是背對著你的三花，一動不動地不知在想什麽
					PRINTFORMW 「……」
					PRINTFORMDW 完全沒被注意到啊
				ENDSELECT
			ELSEIF TALENT:恋人 && TCVAR:発情
			;插入有趣的占位文本
			ELSEIF TCVAR:発情
			;我就是喝高了也想不出來這部分怎樣寫
			ELSE
				SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「這樣嗎？……」
					PRINTFORMDW 下意識地擡頭仰望，三花思考著
				CASE 1
					PRINTFORML 「呃……」
					PRINTFORMDW 三花交叉雙臂地思考著
				CASE 2
					PRINTFORMDL 三花的尾巴有規律地在空中搖晃著，不知在想什麽
					PRINTFORMW 「……」
				ENDSELECT
			;好水啊媽的
			ENDIF
		ENDIF
		;-------------------------------------------------
		;行动结束：似乎结束了思考
		;-------------------------------------------------
		IF ARG:1 == 1
			SELECTCASE RAND:3
			CASE 0
				;過往的幽靈
				IF TALENT:恋人 && TCVAR:発情
					;先不寫這塊，實在想不出發情怎麽思考
				ELSEIF TALENT:恋人
					PRINTFORML 「啊……想不動了……」
					PRINTFORML 「唔嗯嗯~讓我歇息一下吧~」
					PRINTFORMDW 三花結束了思考，靠了過來，倚在你身上閉上了眼
					PRINTFORMDL 「……呐……%CALLNAME:MASTER%有什麽特別在意的過去之類的嗎……」
					PRINTFORMDW 啊啊，那種事情，許是沒有吧
					PRINTFORMW 「沒有嗎……嗯……那就再這樣歇一會兒……」
					PRINTFORMDW 二人沉默，享受著現在的閑暇
					;以後會額外地寫解決過去遺留的差分
				ELSEIF TCVAR:発情
				ELSE
					PRINTFORML 「嗯……如果是這樣……」
					PRINTFORMDW 三花的思考像是有了什麽結果
					PRINTFORML 「嘛……到最後結果是怎樣都無所謂嘛~」
					PRINTFORML 「嘿嘿，浪費了不少時間呢……」
					PRINTFORMDW 自嘲似的，三花笑了兩下
					PRINTFORMW 「哎呀，日子還是一樣過……」
				ENDIF
			CASE 1
				;整明白了！
				IF TALENT:恋人
					PRINTFORML 「哦哦，好像清楚了！」
					PRINTFORML 「呼呼~到最後是這樣嗎……」
					PRINTFORMDW 似乎是想出來了答案，三花看起來很高興
					PRINTFORML 「嗯，那個，%CALLNAME:MASTER%？雖然有點害羞……」
					PRINTFORML 「那個，能誇誇人家嗎？」
					PRINTFORMDW 帶著微笑，你摸了摸她的頭
					PRINTFORMDW 少女則是閉上眼睛，帶著笑享受著
					PRINTFORMW 「嘿嘿……偶爾也想這樣呢……」
				ELSEIF TALENT:恋人 && TCVAR:発情
				ELSEIF TCVAR:発情
				ELSE
					PRINTFORML 「唔哦，好像明白了！」
					PRINTFORMDW 三花攥緊一隻手錘在了另一隻攤開的手的掌心上，臉上的神色明朗了起來
					PRINTFORML 「呼呼……這樣就行了……」
					PRINTFORMDW 結束了思考，少女準備去做別的事情了
				ENDIF
			CASE 2
				;嘛也沒想出來
				IF TALENT:恋人
					PRINTFORML 「唔啊啊————完全想不出來————」
					PRINTFORMDW 看樣子是放棄了思考，三花閉上眼睛，放鬆了整個身體
					PRINTFORML 「……%CALLNAME:MASTER%？……」
					PRINTFORMDL 我在？
					PRINTFORML 「嘿嘿……沒什麽，只是叫叫你……」
					PRINTFORMW 「叫你的名字，感覺想不出來也沒太大問題了~」
					PRINTFORMDW 那你可以多叫叫喔？
					PRINTFORMW 「才不要咧，會上癮的吧~」
				ELSEIF TALENT:恋人 && TCVAR:発情
				ELSEIF TCVAR:発情
				ELSE
					PRINTFORML 「呃……哎呀……」
					PRINTFORMDW 少女咬著大拇指的指甲蓋，擡頭仰望，眉毛擰成一團
					PRINTFORML 「哎呀，算了……」
					PRINTFORML 「就這樣吧，想更多也不會怎樣……呼喵嗯————」
					PRINTFORMDW 結束了思想的漫游，她用看著有些疲憊的樣子伸了伸懶腰
				ENDIF
			ENDSELECT
		ENDIF
	ENDIF
	;-------------------------------------------------
	;1.游玩
	;要求角色持有[幼稚]，所在地点为户外可战斗训练的地方，气力大于500
	;干预（一起玩）：消耗少量体力气力
	;持续时间60~119分钟
	;-------------------------------------------------
	IF ARG == 1
		;-------------------------------------------------
		;行动中：跑来跑去的
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;行动结束：似乎玩累了
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;2.吃饭
	;要求所在地为室内可歇息的地方（不一定可以休息，走廊之类也行），角色空腹状态
	;干预（一起吃饭）：恢复少量体力气力
	;持续时间60~89分钟（细嚼慢咽もぐもぐ）
	;-------------------------------------------------
	IF ARG == 2
		;-------------------------------------------------
		;行动中：正在吃饭
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;行动结束：似乎吃完饭了
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;3.吃小零食
	;与吃饭条件相同，仅限露米娅、幽幽子、紫苑、美铃、恋以及所有妖精
	;干预（一起吃小零食）：恢复少量体力气力
	;持续时间30~59分钟
	;-------------------------------------------------
	IF ARG == 3
		;-------------------------------------------------
		;行动中：在吃小零食
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;行动结束：吃完零食似乎很满足的样子
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;4.扫除
	;要求在私室，气力大于500，且清洁度低于角色污臭耐性的阈值
	;干预（帮忙扫除）：获得清扫经验，消耗少量体力气力
	;持续时间30~49分钟
	;-------------------------------------------------
	IF ARG == 4
		;-------------------------------------------------
		;行动中：清扫着垃圾
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;行动结束：似乎扫除完毕了
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;5.做运动
	;要求角色没有[乐器知识]，在可以战斗训练的地方，气力大于50%，战斗能力不为0
	;干预（一起做运动）：获得战斗经验，消耗少量体力气力
	;持续时间60~119分钟
	;-------------------------------------------------
	IF ARG == 5
		;-------------------------------------------------
		;行动中：充满干劲地在做着运动/正在做弹幕模拟的练习
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;行动结束：结束运动后缓了缓气
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;6.读书
	;要求在可以读书的地方（每个地图的藏书室，或住在主地图的角色私室），气力大于500，教养不为0
	;干预（询问阅读感想）：获得会话和学习经验，消耗少量气力；若距离读完书的时间在30分钟以上则必定失败，只会消耗气力且角色获得少量反感
	;持续时间60~119分钟
	;-------------------------------------------------
	IF ARG == 6
		;-------------------------------------------------
		;行动中：在默默地看着书
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;行动结束：似乎看完书了
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;7.料理
	;要求在可以料理的地方，角色空腹状态，料理技能不为0
	;分为两个阶段：剩余时间大于30分钟为料理中，否则为吃料理
	;干预（帮忙做饭）：获得料理经验，消耗少量体力气力
	;干预（求分点饭菜）：恢复少量体力气力
	;持续时间60~89分钟
	;-------------------------------------------------
	IF ARG == 7
		IF ARG:1 == 0
			;-------------------------------------------------
			;行动中：在轻快地做着饭
			;-------------------------------------------------
			IF Activity_Duration:TARGET > 30
				PRINTFORML
				RETURN 1
			;-------------------------------------------------
			;行动中：在吃自己做好的饭菜
			;-------------------------------------------------
			ELSE
				PRINTFORML
				RETURN 1 
			ENDIF
		ENDIF
		;-------------------------------------------------
		;行动结束：似乎吃完饭了
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;8.演奏
	;要求角色拥有[乐器知识]，在可以战斗训练的地方，气力大于50%
	;干预（协同合奏）：若没有乐器只会消耗少量气力；否则获得演奏经验，消耗少量体力气力
	;持续时间60~89分钟
	;-------------------------------------------------
	IF ARG == 8
		;-------------------------------------------------
		;行动中：在畅快地演奏着
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;行动结束：结束了演奏后缓了缓气
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;9.采集
	;要求在可以采集的地方，气力大于500，采集技能不为0
	;干预（帮忙采集）：获得采集经验，消耗少量体力气力
	;持续时间60~179分钟
	;-------------------------------------------------
	IF ARG == 9
		;-------------------------------------------------
		;行动中：积极地采集着
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;行动结束：似乎结束了采集
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;10.钓鱼
	;要求在可以钓鱼的地方，气力大于500，钓鱼技能不为0
	;干预（一起钓鱼）：若没有钓鱼竿只消耗气力；否则获得钓鱼经验，消耗少量体力气力
	;持续时间60~179分钟
	;-------------------------------------------------
	IF ARG == 10
		;-------------------------------------------------
		;行动中：在悠哉由哉地钓着鱼
		;优哉游哉表示悠闲的样子，悠哉悠哉表示求之不得之苦（敲黑板）（地文一个都没写对）
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;行动结束：似乎钓完鱼了
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;11.做实验
	;要求在角色私室以外可以调和的地方，气力大于500，调和技能不为0
	;干预（帮忙做实验）：获得调和经验，消耗少量体力气力
	;持续时间60~89分钟
	;-------------------------------------------------
	IF ARG == 11
		;-------------------------------------------------
		;行动中：做着可疑的实验
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;行动结束：似乎做完实验了
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;12.休息
	;要求时间为10~16时，在可以休息、不能钻被炉的地方
	;干预（一起放松）：恢复体力气力
	;持续时间60~89分钟
	;-------------------------------------------------
	IF ARG == 12
		;-------------------------------------------------
		;行动中：正在悠闲自在地放着轻松
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;行动结束：似乎休息完了
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;13.晚酌
	;要求时间为20~2时，角色 酒耐性 >= 0，在室内可以歇息的地方
	;干预（陪同喝酒）：消耗少量体力气力，增加酒气
