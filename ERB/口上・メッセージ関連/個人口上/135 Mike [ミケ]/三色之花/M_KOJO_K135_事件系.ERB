;==================================================
;目击了MASTER与其他人的情事
;--------------------------------------------------
;ERB\イベント関連\情事発覚.ERB
;==================================================
@M_KOJO_三色之花_EVENT_K135_6(ARG, ARG:1)
;口上角色编号 = TARGET
;ARG是情事的对象
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;正常进入，情事被迫终止
	;-------------------------------------------------
	IF ARG:1 == 1
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;加入情事
	;-------------------------------------------------
	IF ARG:1 == 2
		;-------------------------------------------------
		;恋人撞见与恋人的情事，强制加入
		;-------------------------------------------------
		IF WITH_恋人()
			PRINTFORML
		;-------------------------------------------------
		;有合意的情况下加入（必须情事中无恋人）
		;-------------------------------------------------
		ELSEIF GETBIT(CFLAG:既成事實, 1)
			PRINTFORML
		;-------------------------------------------------
		;因为合意误认催眠的影响加入
		;-------------------------------------------------
		ELSEIF TALENT:合意誤認
			PRINTFORML
		;-------------------------------------------------
		;其他情况（按理说不应该发生）
		;-------------------------------------------------
		ELSE
			PRINTFORML
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;尴尬地离开
	;-------------------------------------------------
	IF ARG:1 == 3
		;-------------------------------------------------
		;因为催眠影响，没有被抓住把柄
		;-------------------------------------------------
		IF FLAG:催眠強度 >= 75
			PRINTFORML
		;-------------------------------------------------
		;与上面唯一不同之处是TARGET会生气
		;-------------------------------------------------
		ELSEIF FLAG:催眠強度 >= 50
			PRINTFORML
		;-------------------------------------------------
		;非恋人撞见与恋人的情事，强制离开
		;-------------------------------------------------
		ELSEIF WITH_恋人()
			PRINTFORML
		;-------------------------------------------------
		;单纯合意判定不足离开
		;-------------------------------------------------
		ELSE
			PRINTFORML
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;MASTER邀请之后参与进来
	;-------------------------------------------------
	IF ARG:1 == 4
		;-------------------------------------------------
		;由于催眠（放在第一个是因为催眠的地文判定最先）
		;-------------------------------------------------
		IF FLAG:催眠強度 >= 95
			PRINTFORML
		;-------------------------------------------------
		;角色拥有[淫乱]
		;-------------------------------------------------
		ELSEIF TALENT:淫乱
			PRINTFORML
		;-------------------------------------------------
		;角色拥有[风骚]
		;-------------------------------------------------
		ELSEIF TALENT:風騷
			PRINTFORML
		;-------------------------------------------------
		;其他情况（按理说不应该发生）
		;-------------------------------------------------
		ELSE
			PRINTFORML
		ENDIF
		RETURN 1
	ENDIF 
ENDIF
RETURN 1

