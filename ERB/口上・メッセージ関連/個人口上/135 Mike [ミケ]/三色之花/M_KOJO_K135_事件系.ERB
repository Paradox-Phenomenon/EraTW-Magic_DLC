;==================================================
;送礼事件
;--------------------------------------------------
;从礼物ID中提取信息：
;GET_GIFTDATA(GIFT_ID, "回数")：得到/赠予的次数
;GET_GIFTDATA(GIFT_ID, "得点")：角色对该礼物的评价点数
;GET_GIFTDATA(GIFT_ID, "日期")：送礼的日期(1～9999)
;GET_GIFTDATA(GIFT_ID, "場所")：购买礼物的地图编号
;GET_GIFTDATA(GIFT_ID, "形容詞")：礼物形容词的编号
;GET_GIFTDATA(GIFT_ID, "本体")：礼物本体的编号
;--------------------------------------------------
;将编号信息转化为文本：
;CALL GIFTDATA_ADJECT(形容词编号)：形容词文本会存到RESULTS里
;CALL GIFTDATA_MAIN(本体编号)：本体文本会存到RESULTS里
;--------------------------------------------------
;礼物相关的其他操作：
;STRCOUNT(礼物的属性, 需要检定的属性)：寻找礼物中指定属性的强度（出现次数）
;--------------------------------------------------
;ERB\イベント関連\贈り物関連\贈り物.ERB
;==================================================
@M_KOJO_三色之花_EVENT_K135_GIFT(ARG, ARG:1, ARG:2, ARGS, ARGS:1)
;口上角色编号 = TARGET
;ARG:1 是礼物的ID（包含关于礼物的一切信息）
;ARG:2 是TARGET对该礼物的评价点数
;ARGS  是礼物的名称
;ARGS:1是礼物的属性，一个长字符串中礼物的每个属性由「/」隔开，属性的强度由其出现次数决定
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;约会结束时，TARGET送给MASTER礼物
	;在 亲密 >= 5，情绪 >= 1200（四颗心），无反发刻印、非心情差、非愤怒时有几率发生
	;所送的礼物会是TARGET自己喜欢的（评价点 >= 700）
	;-------------------------------------------------
	IF ARG == 1
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在一天结束时，TARGET很喜欢收到的礼物（评价点 >= 700）
	;-------------------------------------------------
	IF ARG == 2
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;是TARGET收到过最喜欢的礼物（需要 评价点 >= 700，会在 ARG == 2 的情况之后显示）
	;-------------------------------------------------
	IF ARG == 3
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在一天结束时，TARGET把礼物收起来了（400 <= 评价点 < 700）
	;-------------------------------------------------
	IF ARG == 4
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在一天结束时，TARGET偷偷把礼物典当了（评价点 < 400）
	;-------------------------------------------------
	IF ARG == 5
		PRINTFORML
		RETURN 1
	ENDIF
ENDIF
RETURN 1

;==================================================
;斗虫相关
;此处并非像其他口上一样使用PRINT系，而是将仅限一行的文本直接存到RESULTS里面
;在地文的语境中，所有口上都是角色所说的话，请不要写成描述类的语句
;部分地方有长度限制，半角字符长度为1，全角字符长度为2，超出限制的会被切断
;名字最长的虫为9个字（长度18），若要使用MUSHI_NAME请注意
;--------------------------------------------------
;ERB\コマンド関連\COMF\日常系\COMF483 ムシバトル.ERB
;ERB\コマンド関連\COMF\日常系\MUSHI_BATTLE.ERB
;==================================================
@M_KOJO_三色之花_MESSAGE_COM_K135_MUSHI_BATTLE(ARGS, ARG)
;口上角色编号 = TARGET
;MUSHI_NAME是虫的名字
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;斗虫开始前（显示斗虫力之后，尚未选择对战开始）
	;-------------------------------------------------
	IF ARGS == "試合前"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;MUSHI_NAME上阵了
	;长度限制80
	;ARG是TARGET剩余的虫数
	;-------------------------------------------------
	IF ARGS == "戦場に出した"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;MUSHI_NAME发起攻击
	;长度限制80
	;ARG是TARGET剩余的虫数
	;-------------------------------------------------
	IF ARGS == "攻撃時"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;MUSHI_NAME被击倒了
	;长度限制80
	;ARG是TARGET剩余的虫数
	;-------------------------------------------------
	IF ARGS == "倒れた時"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGET的所有虫均倒下，败退了
	;长度限制80
	;-------------------------------------------------
	IF ARGS == "敗退時"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在与MASTER的决斗中，TARGET获胜了
	;长度限制40
	;-------------------------------------------------
	IF ARGS == "タイマン：勝ち"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在与MASTER的决斗中，TARGET落败了
	;长度限制40
	;-------------------------------------------------
	IF ARGS == "タイマン：負け"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在3/4人的混战中，TARGET获得了第一名
	;长度限制80
	;-------------------------------------------------
	IF ARGS == "バトルロイヤル：優勝"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在3/4人的混战中，TARGET没有获得第一名
	;长度限制80
	;ARG是取得的名次
	;-------------------------------------------------
	IF ARGS == "バトルロイヤル：２位以下"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在4人团队战中，TARGET所在的队伍获胜了
	;长度限制84
	;-------------------------------------------------
	IF ARGS == "チーム戦：勝ち"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在4人团队战中，TARGET所在的队伍落败了
	;长度限制84
	;-------------------------------------------------
	IF ARGS == "チーム戦：負け"
		RESULTS = 
		RETURN 1
	ENDIF
ENDIF
RETURN 1

;==================================================
;打西瓜相关
;与斗虫一样，是将一句文本存到RESULTS里的形式
;同样，所有口上都是角色所说的话，且只有撞到角色和结束之后的文本会变为口上色，其他都为默认颜色
;除了撞到角色和结束之后，其他文本的长度均不可超过26（半角字符长度为1，全角字符长度为2），否则会被切断
;若RESULTS为空，会自动使用默认口上，但撞到角色和结束之后这两种情况没有默认口上
;因为实在很短，所以使用TEXTR做差分也许反而更简洁一些
;--------------------------------------------------
;打西瓜的一些机制解释：
;游戏区域大小为9*9的方格阵，边长为1步
;MASTER与西瓜在随机地方开始，距离至少为6步（当提到「距离」时，均为曼哈顿距离）
;当MASTER打下时，其实是打到身前一步的地方，下文会将该格称为「AIM」
;当AIM与西瓜重合时打下，便是大成功；若AIM与西瓜距离为1时打下，便是成功，否则为失败（扫帚可以多打一次）
;参加的角色会随机成为「诚实者」或「说谎者」，「诚实者」永远说真话，「说谎者」永远说假话
;==================================================
@M_KOJO_三色之花_MESSAGE_COM_K135_SUIKA(ARGS, ARG)
;口上角色编号 = TARGET
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;就是这里（西瓜与AIM重合，或距离为1）
	;-------------------------------------------------
	IF ARGS == "そこだ！"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;很近了（西瓜与AIM的距离 >= 3）
	;-------------------------------------------------
	IF ARGS == "近い"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;有点远（3 < 西瓜与AIM的距离 < 8）
	;-------------------------------------------------
	IF ARGS == "遠い"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;非常远（西瓜与AIM的距离 >= 8）
	;-------------------------------------------------
	IF ARGS == "かなり遠い"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在前面（西瓜在MASTER前方，但不一定是正前方）
	;-------------------------------------------------
	IF ARGS == "前"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;往前一点点（西瓜在MASTER前方3步内，但不一定是正前方）
	;-------------------------------------------------
	IF ARGS == "少し前"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在后面（西瓜在MASTER后方，但不一定是正后方）
	;-------------------------------------------------
	IF ARGS == "後ろ"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;往后一点点（西瓜在MASTER后方3步内，但不一定是正后方）
	;-------------------------------------------------
	IF ARGS == "少し後ろ"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在右边（西瓜在MASTER右方，但不一定是正右方）
	;-------------------------------------------------
	IF ARGS == "右"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;往右一点点（西瓜在MASTER右方3步内，但不一定是正右方）
	;-------------------------------------------------
	IF ARGS == "少し右"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在左边（西瓜在MASTER左方，但不一定是正左方）
	;-------------------------------------------------
	IF ARGS == "左"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;往左一点点（西瓜在MASTER左方3步内，但不一定是正左方）
	;-------------------------------------------------
	IF ARGS == "少し左"
		RESULTS = 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;撞到角色
	;向场地界限外移动时，会随机撞到一个参加者
	;-------------------------------------------------
	IF ARGS == "衝突"
		RESULTS = 哎呀、不是这边啦！
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;打西瓜结束之后
	;若 ARG == 0，代表TARGET为诚实者
	;若 ARG == 1，代表TARGET为说谎者
	;-------------------------------------------------
	IF ARGS == "結果"
		;-------------------------------------------------
		;失败
		;-------------------------------------------------
		IF TFLAG:193 == -1
			RESULTS = 真遗憾~
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;成功
		;-------------------------------------------------
		IF TFLAG:193 == 0
			RESULTS = 太好了！
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;大成功（使用万宝槌时，成功会变为大成功）
		;-------------------------------------------------
		IF TFLAG:193 == 1
			RESULTS = 太厉害了！
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;使用木刀时大成功
		;-------------------------------------------------
		IF TFLAG:193 == 2
			RESULTS = 切得真漂亮！
			RETURN 1
		ENDIF
	ENDIF
ENDIF
RETURN 1

;==================================================
;炮友契约相关
;--------------------------------------------------
;ERB\コマンド関連\COMF\日常系\COMF357 セフレ契約.ERB
;==================================================
@KOJO_三色之花_SF_CONTRACT_EVENT_K135(ARGS)
;口上角色编号 = TARGET
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;提出契约时
	;-------------------------------------------------
	IF ARGS == "導入"
		PRINTFORML
	ENDIF
	;-------------------------------------------------
	;自定义补正
	;返回的值会与其余的理性判定相加，所以返回正值增加难度，负值降低难度
	;-------------------------------------------------
	IF ARGS == "補正"
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;TARGET接受契约，成为炮友了
	;-------------------------------------------------
	IF ARGS == "成功"
		PRINTFORML
	ENDIF
	;-------------------------------------------------
	;TARGET拒绝了契约（会加很多反感）
	;-------------------------------------------------
	IF ARGS == "失敗"
		PRINTFORML
	ENDIF
ENDIF
RETURN 1

;==================================================
;对角色私室的描写
;--------------------------------------------------
;ERB\ANOTHER_TALK.ERB
;==================================================
@K135_三色之花_ROOM_DESCRIPTION
;口上角色编号 = TARGET
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	IF TALENT:135:恋人 && CFLAG:135:319 == 1 && CFLAG:135:912 > 0
	;戀人，同居并且有孩子
		SELECTCASE RAND:3
		CASE 0
			PRINTFORMDL 你和三花的房間，家庭合照被擺在小被爐桌上
			PRINTFORMDL 西側櫥櫃的門因内容太多而無法合上，裏面都是換季的被褥衣服一類的東西
			PRINTFORMDL 北側墻的時鐘下挂著你們的照片，以及一些三花以前的老舊黑白照片，一棵楓樹的汎黃照片在其中尤爲扎眼
			IF CFLAG:1870 == 5
				PRINTFORMDL 再往下是你們的桌子，上面擺著你們的各種東西，以及一本很厚的相簿
			ELSE
				PRINTFORMDL 再往下是你們的桌子，上面擺著你們的各種東西，還擺了一臺老舊的損毀掉的相機和一本很厚很厚的相薄
			ENDIF
		CASE 1
			PRINTFORMDL 你們的房間，在小被爐桌上擺著家庭的合照
			PRINTFORMDL 北面一扇窗戶的下面有一個小臺子，上面擺著大大小小各種各樣給貓用的東西，還有幾個鍍了金銅質貓小判，沒記錯在哪裏有幾枚真金的
			PRINTFORMDL 你們的被褥枕頭被整整齊齊地曡好放在了角落裏，十分緊凑
			PRINTFORMDL 三花親手做的你們一家的小人也被整整齊齊地放在一個小櫥櫃上
		CASE 2
			PRINTFORMDL 你們一家的房間，你們的合照被擺在了小被爐桌上
			PRINTFORMDL 洗漱臺上的鏡子下的臺子上擺著三花的紅木梳子，上面還帶著幾根頭髮
			PRINTFORMDL 一個小點的梳子也擺在旁邊，那是給孩子用的
			PRINTFORMDL 一個黃布包裹著一把剃刀，那是三花用來剃頭髮的，那黃布看樣子有點年頭了
		ENDSELECT
	ELSEIF TALENT:135:恋人 && CFLAG:135:319 == 1
	;戀人且同居
		SELECTCASE RAND:3
		CASE 0
			PRINTFORMDL 三花和你的房間，裏面有你們兩人的合照
			PRINTFORMDL 在她的地方擺著一張被爐桌，你們的合照就立在上面
			PRINTFORMDL 你們兩人的枕頭被子緊密地挨在一起，旁邊櫥櫃的門則是有點鼓出來
			PRINTFORMDL 北邊的一扇窗戶下的臺子上擺著許多給貓用的諸如針梳的東西，上面還沾著幾根看樣子是三花本人的毛髮
		CASE 1
			PRINTFORMDL 你和三花的房間，你們兩人的合照擺在被爐桌上
			SELECTCASE RAND:3
			CASE 0
				PRINTFORMDL 旁邊的洗漱臺上擺著她的紅木梳子，上面還帶著幾根白色的頭髮
			CASE 1
				PRINTFORMDL 旁邊的洗漱臺上擺著她的紅木梳子，上面還帶著幾根橙色的頭髮
			CASE 2
				PRINTFORMDL 旁邊的洗漱臺上擺著她的紅木梳子，上面還帶著幾根淡棕色的頭髮
			ENDSELECT
			PRINTFORMDL 同時還有一把剃頭髮用的剃刀被老舊的黃布包著擺在那裏，這是三花的
			PRINTFORMDL 一棵楓樹的黑白照片挂在鏡子旁邊的墻上
		CASE 2
			PRINTFORMDL 三花和你的房間，你們兩個人的合照被仔細擺在了被爐桌上
			PRINTFORMDL 在她的地方還有一張你的照片從枕頭下露了出來，上面看樣子是以前被什麽東西打濕過，而且還有彎折的痕跡
			PRINTFORMDL 幾枚鍍金的銅質貓小判被隨意地擺在一個小櫃子上，沒記錯櫃子裏面的某個地方藏著真金做的
