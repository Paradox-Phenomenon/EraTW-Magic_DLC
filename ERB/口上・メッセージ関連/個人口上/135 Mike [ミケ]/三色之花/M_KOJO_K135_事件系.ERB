;==================================================
;回家时
;均需要TARGET住在主地图之外
;--------------------------------------------------
;口上调用的地方非常杂乱，分布在以下三个文件
;ERB\MOVEMENTS\MOVEMENTS2.ERB
;ERB\MOVEMENTS\SLEEP.ERB
;ERB\イベント関連\デート終了タイムアップ処理.ERB（只有一条，其实只是用于应对极端情况的）
;==================================================
@M_KOJO_三色之花_EVENT_K135_20(ARG, ARG:1)
;口上角色编号 = TARGET
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;通常回家
	;-------------------------------------------------
	IF ARG == 1
		;-------------------------------------------------
		;情事中要睡觉所以回去了
		;-------------------------------------------------
		IF CFLAG:诶嘿嘿
			PRINTFORML
		;-------------------------------------------------
		;其他情况下要睡觉所以回去了（衰弱口上在下面）
		;-------------------------------------------------
		ELSE
			PRINTFORML 
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;约会中归宅
	;-------------------------------------------------
	IF ARG == 2
		;-------------------------------------------------
		;情事中
		;-------------------------------------------------
		IF CFLAG:诶嘿嘿
			;-------------------------------------------------
			;太累了所以回去了
			;-------------------------------------------------
			IF CFLAG:衰弱
				PRINTFORML
			;-------------------------------------------------
			;要睡觉所以回去了
			;-------------------------------------------------
			ELSE
				PRINTFORML
			ENDIF
		;-------------------------------------------------
		;正常约会归宅
		;-------------------------------------------------
		ELSE
			PRINTFORML
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在访问TARGET的房间时，或在TARGET自宅位置（可以访问房间的那个地方）结束约会（在玄关处送行）
	;-------------------------------------------------
	IF ARG == 3
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;恋慕/爱人约会结束时，邀请MASTER去房间（因为判定依赖积攒度，所以一旦接受很可能被推倒）
	;若满足 ARG == 3 的条件则不会触发
	;-------------------------------------------------
	IF ARG == 4
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;接受上面去房间的邀请
	;-------------------------------------------------
	IF ARG == 5
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;拒绝去房间的邀请
	;-------------------------------------------------
	IF ARG == 6
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGET说今天晚上不想回去，请求留宿
	;必须 积攒度 >= 800，且欲望高于某个值
	;-------------------------------------------------
	IF ARG == 7
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;同意了留宿请求
	;-------------------------------------------------
	IF ARG == 8
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;拒绝了留宿请求（若与其他角色同居则强制拒绝）
	;-------------------------------------------------
	IF ARG == 9
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGET太累了所以回去了
	;-------------------------------------------------
	IF ARG == 10
		;-------------------------------------------------
		;情事中
		;-------------------------------------------------
		IF CFLAG:诶嘿嘿
			PRINTFORML 
		;-------------------------------------------------
		;其他情况
		;-------------------------------------------------
		ELSE
			PRINTFORML
		ENDIF
		RETURN 1
	ENDIF
ENDIF
RETURN 1

