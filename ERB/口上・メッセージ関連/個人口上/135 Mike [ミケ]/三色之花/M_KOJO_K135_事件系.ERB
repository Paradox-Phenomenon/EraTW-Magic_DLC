@M_KOJO_三色之花_EVENT_K135_ONABARE_3(ARG, ARG:1, ARG:2, ARG:3)
;口上角色编号 = TARGET
;ARG表示前戏部位，1 = 爱抚C（必须 C感觉 >= B感觉），2 = 爱抚B（必须 C感觉 < B感觉），3 = 接吻（若TARGET无接吻经验则一定会选择该选项，并会夺走初吻，否则1/3概率）
;ARG:1表示插入部位，0 = 插入V，1 = 插入A
;ARG:2表示中出的次数
;ARG:3表示注入精液量
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	RETURN 2
ENDIF

;--------------------------------------------------
;这个是主函数哦
;--------------------------------------------------
@M_KOJO_三色之花_EVENT_K135_26(ARG, ARG:1)
;口上角色编号 = TARGET
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;被看见的瞬间
	;口上的调用在描述发现TARGET自慰的地文之后，需要注意
	;-------------------------------------------------
	IF ARG == 0
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;选择「失礼了」，就这样离开
	;-------------------------------------------------
	IF ARG == 1
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;选择「请在我的注视下继续做吧」，判定成功
	;口上的调用在描述TARGET自慰的地文之前，需要注意
	;-------------------------------------------------
	IF ARG == 2
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;选择「请在我的注视下继续做吧」或「比起一个人来说两个人更加舒服哦」，但判定失败被赶出去了
	;本体代码部分没有做这两个选项失败的区分，如有需求请自行在自定义判定函数中用变量记录下选择
	;-------------------------------------------------
	IF ARG == 3
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;选择「比起一个人来说两个人更加舒服哦」，判定成功
	;口上的调用在描述情事的地文之前，需要注意
	;选择这个选项要求 精力 > 最大精力 / 5（所以MASTER为女性的话是选不了的）
	;-------------------------------------------------
	IF ARG == 4
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;获得允许，进行情事，结束之后
	;-------------------------------------------------
	IF ARG == 5
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;事后TARGET请求MASTER留宿，同意了
	;只有不在主地图时才能触发（也就是仅限访问房间时），TARGET必须拥有恋慕
	;-------------------------------------------------
	IF ARG == 6
		PRINTFORML
		RETURN 1
	ENDIF
ENDIF
RETURN 1

;==================================================
;TARGET邀请一起约会/去房间
;分为邀请去房间、单纯约会和一起去宴会
;邀请去房间、单纯约会需要角色拥有恋慕，而邀请去宴会则思慕和恋慕均可
;--------------------------------------------------
;ERB\イベント関連\情事発覚.ERB
;==================================================
@M_KOJO_三色之花_EVENT_K135_27(ARG, ARG:1)
;口上角色编号 = TARGET
;ARG:1是目的地
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;邀请一起去约会时（非宴会）
	;ARG:1为目的地的地图编号
	;选择的目的地一定路途小于60分钟（不知道怎么用，先记在这）
	;-------------------------------------------------
	IF ARG == 0
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;接受了邀请
	;ARG:1为目的地的地图编号
	;-------------------------------------------------
	IF ARG == 1
		;-------------------------------------------------
		;接受了一起去宴会的邀请
		;-------------------------------------------------
		IF CFLAG:宴会参加
			PRINTFORML
		;-------------------------------------------------
		;接受了单纯约会的邀请
		;-------------------------------------------------
		ELSE
			PRINTFORML
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;拒绝了邀请
	;ARG:1为目的地的地图编号
	;-------------------------------------------------
	IF ARG == 2
		;-------------------------------------------------
		;拒绝了一起去宴会的邀请
		;-------------------------------------------------
		IF CFLAG:宴会参加
			PRINTFORML
		;-------------------------------------------------
		;拒绝了单纯约会的邀请
		;-------------------------------------------------
		ELSE
			PRINTFORML
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;邀请去房间
	;需要TARGET住在主地图之外，积攒度高于一定程度
	;ARG:1为TARGET住所的地图编号（仔细想想就会发现这个好像并没有什么用）
	;-------------------------------------------------
	IF ARG == 3
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;接受了去房间的邀请
	;ARG:1为TARGET住所的地图编号
	;-------------------------------------------------
	IF ARG == 4
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;拒绝了去房间的邀请
	;ARG:1为TARGET住所的地图编号
	;-------------------------------------------------
	IF ARG == 5
		PRINTFORML
		RETURN 1
	ENDIF
ENDIF
RETURN 1

;==================================================
;脱衣口上
;--------------------------------------------------
;ERB\コマンド関連\USERCOM_服を脱がせる.ERB
;==================================================
@M_KOJO_三色之花_EVENT_K135_28(ARG, ARG:1)
;口上角色编号 = TARGET
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;脱成全裸
	;在索要胖次以及其他描述脱衣的地文之后才触发
	;-------------------------------------------------
	IF ARG == 0
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;变成只穿内衣的样子
	;-------------------------------------------------
	IF ARG == 1
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;脱到一半PLAY
	;-------------------------------------------------
	IF ARG == 2
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;索要胖次
	;判定顺序从上到下，满足某个条件后便不会再触发下方的
	;-------------------------------------------------
	IF ARG == 3
		;-------------------------------------------------
		;TARGET要求交换胖次，并且MASTER有穿胖次，成功交换了
		;亲密、从顺、欲望均 > 7 时1/4触发
		;-------------------------------------------------
		IF ARG:1 == 0
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;满脸通红的将刚脱下来的胖次亲手递给了MASTER
		;亲密、从顺 > 7
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;勉勉强强的将刚脱下来的胖次交了出来
		;亲密、从顺 > 5
		;-------------------------------------------------
		IF ARG:1 == 2
			;-------------------------------------------------
			;TARGET真的 亲密、从顺 > 5
			;-------------------------------------------------
			IF ABL:従順 > 5 && ABL:親密 > 5
				PRINTFORML
			;-------------------------------------------------
			;其实是因为 催眠强度 > 50
			;-------------------------------------------------
			ELSE
				PRINTFORML
			ENDIF
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;TARGET拒绝交出胖次
		;-------------------------------------------------
		IF ARG:1 == 3
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
ENDIF
RETURN 1

