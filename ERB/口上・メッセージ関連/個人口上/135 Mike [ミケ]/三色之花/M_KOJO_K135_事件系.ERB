;ARG == 1/2 → 3 → 7 → 8 → 9 → 4 → 5 → 6 → 0
;如果触发浴室逐出，ARG == 7 之后的不会触发
;虽然有自带的 CFLAG:時間停止バレ 来表示角色知晓时停，但还是建议自行建立机制
;自带的判定机制会导致出现一些很敷衍的地文，并且无陷落素质时的惩罚非常严重，比如偷一条胖次直接反发3（这倒更贴近真实情况了）
;再加上惩罚是以增加SOURCE的方式，而该处并没有SOURCE的结算，所以会出现不碰就没事，一旦交互就反发的滑稽场景
;当然还要考虑移动到别处解除时停以避开惩罚的可能性，这个漏洞要不要堵看作者自己的选择了
;总绝顶次数计算方式：EX:無自覚Ｃ絶頂 + EX:無自覚Ｖ絶頂 + EX:無自覚Ａ絶頂 + EX:無自覚Ｂ絶頂 + EX:無自覚Ｍ絶頂
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;【谜之快感】（0 < 绝顶次数 <= 20）或【突如其来的快感】（20 < 绝顶次数 <= 40）
	;-------------------------------------------------
	IF ARG == 1
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;【强烈的快感】（40 < 绝顶次数 <= 60）或【击垮神经的快感】（绝顶次数 > 60）
	;-------------------------------------------------
	IF ARG == 2
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;【不寻常的开放感】或【充斥快感的开放感】（失去胖次）
	;偷胖次后反复开启解除时停也会导致不断触发此处口上，建议使用一个自定义TCVR或ONCE()防止当日再次触发
	;当然很残念地文还是会照常反复显示
	;-------------------------------------------------
	IF ARG == 3
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;【无自觉口内射精】
	;-------------------------------------------------
	IF ARG == 4
		;-------------------------------------------------
		;不假思索的吞了下去
		;在 精液中毒 <= 2 时，ARG:1 == 1, 2, 3的情况各有1/3概率触发
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;想办法找机会吐了出来
		;-------------------------------------------------
		IF ARG:1 == 2
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;急忙捂住了嘴巴
		;-------------------------------------------------
		IF ARG:1 == 3
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;精液中毒 > 2，喝了下去
		;地文中有 2 < 精液中毒 <= 4 和 精液中毒 > 4 的两种情况，可酌情照应
		;-------------------------------------------------
		IF ARG:1 == 4
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;浓厚精液时，精液中毒 <= 2，被呛住
		;-------------------------------------------------
		IF ARG:1 == 5
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;浓厚精液时，精液中毒 > 2，喝了下去
		;地文中有 2 < 精液中毒 <= 4 和 精液中毒 > 4 的两种情况，可酌情照应
		;-------------------------------------------------
		IF ARG:1 == 6
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;【无自觉颜面射精】
	;-------------------------------------------------
	IF ARG == 5
		;-------------------------------------------------
		;持有[无知]，精液经验 < 100（没认出来是什么）
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;注意到了粘在脸上的精液、慌忙将其擦掉了
		;-------------------------------------------------
		IF ARG:1 == 2
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;精液中毒 > 2，喝了下去
		;地文中有 2 < 精液中毒 <= 4 和 精液中毒 > 4 的两种情况，可酌情照应
		;-------------------------------------------------
		IF ARG:1 == 3
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;【无自觉手淫射精】
	;-------------------------------------------------
	IF ARG == 6
		;-------------------------------------------------
		;注意到了粘在手掌上的精液、不快地擦掉了
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;精液中毒 > 2，喝了下去
		;地文中有 2 < 精液中毒 <= 4 和 精液中毒 > 4 的两种情况，可酌情照应
		;-------------------------------------------------
		IF ARG:1 == 2
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;【无自觉肛门射精】
	;-------------------------------------------------
	IF ARG == 7
		;-------------------------------------------------
		;A感觉 < 2（突然因为肛门里游走的疼痛而小声悲鸣起来）
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;A感觉 >= 2
		;地文中每2级有一个差分，直到 A感觉 >= 10 共5个（不包含<2的情况），可酌情照应
		;-------------------------------------------------
		IF ARG:1 == 2
			PRINTFORML
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;【无自觉处女/再生处女丧失】
	;EX:処女喪失记号 == 1 时，为处女丧失，否则为再生处女丧失
	;地文中其实还有 V感觉 >= 6 的情况，叫【无自觉敏感处女/再生敏感处女丧失】，但就算了吧谁这样玩啊
	;-------------------------------------------------
	IF ARG == 8
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;【无自觉膣内射精】
	;-------------------------------------------------
	IF ARG == 9
		;-------------------------------------------------
		;未服避孕药（变的脸色苍白、看起来想要掩饰似的身子扭来扭去）
		;-------------------------------------------------
		IF ARG:1 == 1
			PRINTFORML
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;口服避孕药生效中（虽然有些惶惑不过并没有很慌张的样子）
		;-------------------------------------------------
		IF ARG:1 == 2
			PRINTFORML
			RETURN 1
		ENDIF
		IF ARG:1 == 3
			;-------------------------------------------------
			;无自觉处女丧失同时膣内射精
			;-------------------------------------------------
			IF EX:処女喪失记号 == 1 && TALENT:処女 == -1
				PRINTFORML
			;-------------------------------------------------
			;持有[无知]，精液经验 < 100
			;-------------------------------------------------
			ELSEIF TALENT:無知 && EXP:精液経験 < 100
				PRINTFORML
			;-------------------------------------------------
			;持有[无自觉非处女]，但并非本次丧失
			;-------------------------------------------------
			ELSEIF EX:処女喪失记号 == 0
				PRINTFORML
			;-------------------------------------------------
			;某个其他情况（本该正常情况下触发的地文因为bug只能在某个极为特殊的条件下触发）
			;好奇的话可以去感受一下本体的代码有多烂
			;-------------------------------------------------
			ELSE
				PRINTFORML
			ENDIF
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;时间停止解除共通口上
	;会在其他所有情况触发完毕之后显示，请自行设置好条件
	;-------------------------------------------------
	IF ARG == 0
		RETURN 1
	ENDIF
ENDIF
RETURN 1

