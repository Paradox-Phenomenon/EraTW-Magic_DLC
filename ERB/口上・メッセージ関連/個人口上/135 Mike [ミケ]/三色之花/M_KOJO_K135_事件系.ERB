;--------------------------------------------------
;ERB\イベント関連\お出かけイベント\お出かけイベント.ERB
;==================================================
@RUN_INTO_三色之花_EVENT_K135(ARG)
;口上角色编号 = TARGET
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	RETURN 0
ENDIF

;==================================================
;一般依赖的抑制
;如果该函数 RETURN 1 的话，相应编号的依赖不会出现
;--------------------------------------------------
;依赖编号对应表：
; 1 - 帮忙做扫除
; 2 - 给花浇水
; 3 - 一起玩吧
; 4 - 想要学习料理
; 5 - 关于特训
; 6 - 谁来告诉我！
; 7 - 大扫除还没结束
; 8 - 送信
; 9 - 谁的遗失物
;10 - 怎么也找不到（奖励上级素材）
;11 - 怎么也找不到（奖励钱）
;12 - 想要制裁TA！
;13 - 想吃美味的鱼
;14 - 正在砍柴
;15 - 想和MASTER做爱
;16 - 倾听烦恼！
;17 - 我想吃那个！那个叫什么来着？
;18 - 有谁能帮我做一下吗！
;--------------------------------------------------
;ERB\コマンド関連\COMF\依頼\CTRL_IRAI.ERB
;==================================================
@M_KOJO_三色之花_CHECK_K135_IRAI_BLOCKED(ARGS, ARG, ARG:1)
;口上角色编号 = TARGET
;ARG是委托编号
SELECTCASE ARG
	CASE 15,17;禁用15/17号委托
	RETURN 1
ENDSELECT

;==================================================
;引力操作：自定义角色移动
;若在此函数中将 TCVAR:引力点 设置为某个地点编号，角色便会被拉到该地点（若已在该地点则原地不动）
;当角色在主地图以外，引力点在主地图以外，或引力点处由于天气恶劣无法前往时，引力点不生效
;当引力点设置为0时，角色会照常随机移动
;每次判定行动都会调用一次该函数，调用一次也会且仅会影响该次行动
;请注意严格设置条件，否则可能造成角色长期被定在同一个地点
;--------------------------------------------------
;ERB\MOVEMENTS\MOVEMENT_キャラ移動処理.ERB
;==================================================
@M_KOJO_三色之花_EVENT_K135_GRAVITY(ARG)
;口上角色编号 = TARGET
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	TCVAR:引力点 = 0
	RETURN 1
ENDIF

