;==================================================
;当日结束后的自慰
;ARG分歧的判定为 7 → 2 → 3 → 4 → 5 → 6 → 1
;例如在没有无知，有陷落素质、自慰中毒 >= 3，精液中毒 > 0，被射进精液，没有共寝的情况下：
;若 ARG = 7 没有命中概率，继续判定 ARG = 3
;若 ARG = 3 没有命中1/4的概率，继续判定 ARG = 5
;若 ARG = 5 没有命中1/3的概率，继续判定 ARG = 6
;若 ARG = 6 没有命中1/2的概率，则 ARG = 1
;所以在相同的情况下，可能触发的ARG数值也会有多个，需要注意
;--------------------------------------------------
;ERB\イベント関連\AFTERTRA.ERB
;==================================================
@M_KOJO_三色之花_EVENT_K135_22(ARG, ARG:1)
;口上角色编号 = TARGET
;--------------------------------------------------
;是否启用（= 0，不启用；= 1，启用）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;通常自慰
	;所有判定都失败的时候，才会触发这里
	;-------------------------------------------------
	IF ARG == 1
		IF TALENT:恋人
			PRINTFORML 「啊……唔嗯……PHP」
			CALL HPH_PRINT,@"「%CALLNAME:MASTER%……喵嗯……啊HPH」","L"
			CALL HPH_PRINT,@"「要……要去了……喵嗯————HPHHPHHPH」","W"
			CALL HPH_PRINT,@"「哈啊……哈啊……%CALLNAME:MASTER%HPH……」","L"
			PRINTFORMDW 癱在地上，三花的眼神迷離著説出所愛之人的名字，而身子更是變得凌亂不堪
			CALL HPH_PRINT,@"「……再來一次就睡覺……嗯HPH……」","W"
		ELSE
			CALL HPH_PRINT,@"「嗯……哈啊……HPH」","L"
			CALL HPH_PRINT,@"「哦嗯————喵呜……HPH」、","L"
			PRINTFORML 「……」
			PRINTFORMW 「……先到这里吧……」
		ENDIF
	ENDIF
	;-------------------------------------------------
	;在TARGET私室中共寝时自慰（需要有合意）
	;-------------------------------------------------
	IF ARG == 2
		PRINTFORML  
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;被射入精液时自慰
	;在 精液中毒 > 0，V内有精液时，1/4触发
	;地文有 = 1 / = 2, 3 / > 3 三种差分，做不做配套随意，反正这玩意很容易就超过3级了
	;-------------------------------------------------
	IF ARG == 3
		PRINTFORML  
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;持有无知时自慰
	;地文根据 LOCAL:1 = EXP:自慰経験 - EXP:調教自慰経験 的数值有分歧，可以自行翻阅代码
	;无知消除事件也在此处发生，条件为 LOCAL:1 >= 120 - (MIN(ABL:LOCAL:親密, 6) * 10)
	;-------------------------------------------------
	IF ARG == 4
		PRINTFORML  
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在有陷落素质，自慰中毒 >= 3 时，1/3触发
	;ARG:1为自慰的部位，1为C，2为V，3为A（地文里说交替玩V，但其实不加快V珠），4为B，5为无指定部位，概率均等
	;在对应部位敏感或感觉10以上时地文有分歧
	;-------------------------------------------------
	IF ARG == 5
		PRINTFORML  
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;在 自慰中毒 >= 3 时，1/2触发
	;ARG:1为自慰的部位，2为V，3为A（只会触发这两个）
	;曾经有bug导致V自慰实际赋值的是1，所以为了兼容性考虑，可以让ARG:1为1或2的时候均触发V自慰的口上
	;地文分歧与是否为处女和贞操重视程度有关
	;-------------------------------------------------
	IF ARG == 6
		PRINTFORML  
		RETURN 1

	ENDIF
	;-------------------------------------------------
	;忍耐住没有自慰
	;共寝时有合意的情况下，小概率触发
	;-------------------------------------------------
	IF ARG == 7
		PRINTFORML 
		RETURN 1
	ENDIF
ENDIF
RETURN 1

