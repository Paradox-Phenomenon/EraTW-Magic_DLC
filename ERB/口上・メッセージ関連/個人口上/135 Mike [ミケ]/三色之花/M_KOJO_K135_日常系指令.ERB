@M_KOJO_三色之花_SUCCESS_COM_K135_300
;成否判定
;TFLAG:192(-2=强制中止指令、-1＝強制失敗、0=根据COM文件决定、1=強制成功or大成功
IF INROOM(CFLAG:MASTER:現在位置)
TFLAG:192 = 0
ELSE
;屋外頭
	IF TALENT:7 == 0
	;非戀人
		IF TEQUIP:201 == 0
		;沒有在一起打傘
			IF TIME:5 == 4 || TIME:5 == 5 || TIME:5 == 6 || TIME:5 == 7 || TIME:5 == 9 || TIME:5 ==11 || TIME:5 == 12 || TIME:5 == 13
			;一些比較惡劣的天氣
				TFLAG:192 = -1
			ELSE
				TFLAG:192 = 0
			ENDIF
		ELSE
			TFLAG:192 = 0
		ENDIF
	ELSE
		TFLAG:192 = 0
	ENDIF
ENDIF
;==================================================
;可选项：关于地文描述的显示设置
;如果返回0，则地文与口上都会显示；如果返回1，则地文会隐藏，口上会显示；如果返回2，则地文会显示，口上会隐藏；如果返回3则均会被隐藏
;==================================================
