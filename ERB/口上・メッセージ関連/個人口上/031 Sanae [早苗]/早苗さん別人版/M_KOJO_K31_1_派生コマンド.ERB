;==================================================
;6,挿入Ｇスポ責め
;==================================================
@M_KOJO_早苗追加_MESSAGE_SCOM_K31_6
CALL M_KOJO_早苗追加_MESSAGE_SCOM_K31_6_1
RETURN 1
@M_KOJO_早苗追加_MESSAGE_SCOM_K31_6_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL && !FLAG:70
	IF TALENT:恋人 || TALENT:恋慕
		SELECTCASE RAND:3
			CASE 1
				PRINTFORML 「はぁっ…んんっ…っくぅ…%UNICODE(0x2665) *1%　　そこはっ%UNICODE(0x2665) *1%」
				PRINTFORML 「むうっ……%UNICODE(0x2665) *1%　　なかなか適確な動きをっ…%UNICODE(0x2665) *1%」
			CASE 2
				PRINTFORML 「ソコはっ……ぁん……んあっあっ…%UNICODE(0x2665) *1%」
				PRINTFORML 「ふうっ…%UNICODE(0x2665) *1%　　ふふ…その調子ですよ……あっ%UNICODE(0x2665) *1%」
			CASEELSE
				PRINTFORML 「んぁ…%UNICODE(0x2665) *1%　　ふふ……そうです…ソコが気持ちいいんです…%UNICODE(0x2665) *1%」
				PRINTFORML 「いいですか%UNICODE(0x2665) *1%　　きちんと覚えてくださいね%UNICODE(0x2665) *1%　　ふふっ%UNICODE(0x2665) *1%」
		ENDSELECT
	ELSEIF TALENT:思慕
		PRINTFORML 「はぁっ…んんっ…っくぅ…%UNICODE(0x2665) *1%　　そこはっ%UNICODE(0x2665) *1%」
		PRINTFORML 「むうっ……%UNICODE(0x2665) *1%　　なかなか適確な動きをっ…%UNICODE(0x2665) *1%」
	ELSE
		PRINTFORML 「はぁっ…んんっ…っくぅ…%UNICODE(0x2665) *1%　　そこはっ%UNICODE(0x2665) *1%」
	ENDIF
	PRINTFORMW
ENDIF
RETURN 1

;==================================================
;7,挿入子宮口責め
;==================================================
@M_KOJO_早苗追加_MESSAGE_SCOM_K31_7
CALL M_KOJO_早苗追加_MESSAGE_SCOM_K31_7_1
RETURN 1
@M_KOJO_早苗追加_MESSAGE_SCOM_K31_7_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL && !FLAG:70
	IF EXP:子宮口開発経験 > 30
		IF TALENT:恋人 || TALENT:恋慕
			SELECTCASE RAND:3
				CASE 1
					PRINTFORML 「奥にぃ…入ってっ…っくぅ…%UNICODE(0x2665) *1%　　うううっ%UNICODE(0x2665) *1%」
					PRINTFORML 「あっ……%UNICODE(0x2665) *1%　　だめです…%UNICODE(0x2665) *1%　　降りてこられないっ…%UNICODE(0x2665) *4%」
				CASE 2
					PRINTFORML 「ソコっ%UNICODE(0x2665) *1%……んんっ！%UNICODE(0x2665) *1%……すごいっ…%UNICODE(0x2665) *1%」
					PRINTFORML 「ぁっ…%UNICODE(0x2665) *1%　　ぁははぁ%UNICODE(0x2665) *1%……これっ…ほんとにダメですっ%UNICODE(0x2665) *3%」
				CASEELSE
					PRINTFORML 「んぁ…%UNICODE(0x2665) *1%　　これは……強烈ですね……っ%UNICODE(0x2665) *2%」
					PRINTFORML 「何度も突かれてっ%UNICODE(0x2665) *1%　開発されちゃいましたっ%UNICODE(0x2665) *1%　あはぁあ%UNICODE(0x2665) *2%」
			ENDSELECT
		ELSEIF TALENT:思慕
			PRINTFORML 「奥にぃ…入ってっ…っくぅ…%UNICODE(0x2665) *1%　　うううっ%UNICODE(0x2665) *1%」
		ELSE
			PRINTFORML 「はぁっ…んんっ…っくぅ…%UNICODE(0x2665) *1%」
		ENDIF
	ELSEIF EXP:子宮口開発経験 > 15
		IF TALENT:恋人 || TALENT:恋慕 || TALENT:思慕
			SELECTCASE RAND:3
				CASE 1
					PRINTFORML 「奥…入ってるっ……　　ううっ%UNICODE(0x2665) *1%」
					PRINTFORML 「あっ……%UNICODE(0x2665) *1%　だんだん…気持ちよく…%UNICODE(0x2665) *1%」
				CASE 2
					PRINTFORML 「ソコはっ%UNICODE(0x2665) *1%……ん%UNICODE(0x2665) *1%……あれ…%UNICODE(0x2665) *1%」
					PRINTFORML 「どうして……苦しいのにっ%UNICODE(0x2665) *1%……こんなっ%UNICODE(0x2665) *1%」
				CASEELSE
					PRINTFORML 「んぁ…%UNICODE(0x2665) *1%　　これは………っ%UNICODE(0x2665) *2%」
					PRINTFORML 「ふうぅっ……%UNICODE(0x2665) *1%　%CALLNAME:MASTER%さんが何度も突くせいで…%UNICODE(0x2665) *1%　開発されてきてっ%UNICODE(0x2665) *2%」
			ENDSELECT
		ELSE
			PRINTFORML 「はぁっ…んんっ…っくぅ…」
		ENDIF
	ELSE
		IF TALENT:恋人 || TALENT:恋慕 || TALENT:思慕
			SELECTCASE RAND:3
				CASE 1
					PRINTFORML 「奥に……これはっ……　　ううっ」
					PRINTFORML 「さすがに……苦しいですっ…」
				CASE 2
					PRINTFORML 「んんっ！？ぐうぅ…！き、きついですっ…」
				CASEELSE
					PRINTFORML 「あっ…ふうう…ちょっと、奥過ぎですっ…」
					PRINTFORML 「ここは…まだっ…そんなに…」
			ENDSELECT
		ELSE
			PRINTFORML 「ぐぁ…ううぅ…」
		ENDIF
	ENDIF
	PRINTFORMW
ENDIF
RETURN 1
