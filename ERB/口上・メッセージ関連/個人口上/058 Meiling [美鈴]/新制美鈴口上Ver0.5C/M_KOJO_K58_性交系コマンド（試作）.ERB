;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
	SELECTCASE	RAND : 3
	CASE 0
	PRINTFORMW	「啊❤ 那里！！❤」
	PRINTFORMW	「不行❤ 舒服的地方❤」
	CASE 1
	PRINTFORMW	「弱点❤ 啊哈❤ 已经被你❤ 掌握了呢❤」
	PRINTFORMW	「好舒服啊❤ 啊哈！❤ 那里！❤❤」
	CASE 2
	PRINTFORMW	「这样子进攻弱点❤ 很快就❤❤」
	ENDSELECT
	ENDIF
	;-------------------------------------------------
	;挿入継続
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && TCVAR:101 == PLAYER
		;前回射精した
		IF TCVAR:104
			PRINTFORMW 「啊哈❤ 才刚刚射过❤ 现在再进攻弱点❤ 很快就要❤ 啊哈❤」
			RETURN 1
		ELSE
		SELECTCASE	RAND : 3
		CASE 0
		PRINTFORMW	「啊❤ 那里！！❤」
		PRINTFORMW	「不行❤ 舒服的地方❤」
		CASE 1
		PRINTFORMW	「弱点❤ 啊哈❤ 已经被你❤ 掌握了呢❤」
		PRINTFORMW	「好舒服啊❤ 啊哈！❤ 那里！❤❤」
		CASE 2
		PRINTFORMW	「这样子进攻弱点❤ 很快就❤❤」
		ENDSELECT
			RETURN 1
		ENDIF
	ENDIF
	;基本セット
	;恋慕
	IF TALENT:恋慕
		SELECTCASE	RAND : 3
		CASE 0
		PRINTFORMW	「啊❤ 那里！！❤」
		PRINTFORMW	「不行❤ 舒服的地方❤」
		CASE 1
		PRINTFORMW	「弱点❤ 啊哈❤ 已经被你❤ 掌握了呢❤」
		PRINTFORMW	「好舒服啊❤ 啊哈！❤ 那里！❤❤」
		CASE 2
		PRINTFORMW	「这样子进攻弱点❤ 很快就❤❤」
		ENDSELECT 
		RETURN 1
	;屈服3
	ELSEIF MARK:不埒刻印 == 3
		PRINTFORMW 
		RETURN 1
	;それ以外
	ELSE
		PRINTFORMW 
		RETURN 1
	ENDIF
ENDIF
RETURN 1

