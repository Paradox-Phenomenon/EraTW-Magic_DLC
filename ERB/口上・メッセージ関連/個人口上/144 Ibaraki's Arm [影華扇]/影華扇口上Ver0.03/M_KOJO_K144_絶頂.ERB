;~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
;分岐作りに有用そうな変数などのメモ
;~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
;NOWEX:Ｃ絶頂 NOWEX:Ｖ絶頂 NOWEX:Ｂ絶頂 NOWEX:Ａ絶頂 NOWEX:Ｍ絶頂
;各部位の絶頂強度。まず0~3が割り当てられ、多重絶頂により最大16倍される。つまり単部位なら最大3、5重絶頂で最大48
;NOWEX:TotalEX
;多重絶頂補正を受ける前の各部位絶頂強度の合計値。1~15。このテンプレにおける分岐の基準。

;TEQUIP:50
;Ｖに誰の竿が入ってるか。TEQUIP:50 = MASTERであなたが挿入中となる。
;TEQUIP:51
;Ａに誰の竿が入ってるか。TEQUIP:51 = MASTERであなたが挿入中となる。
;NOWEX:射精
;射精量、最大3。たとえばIF NOWEX:MASTER:射精 > 1だと、あなたが大量射精以上した場合となる。
;SYNCED_ORGASM(TARGET)
;相手とあなたが同時に絶頂した場合真となる。絶頂の部位は問わない。

;-------------------------------------------------
;絶頂時の口上
;-------------------------------------------------
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_MESSAGE_PALAMCNG_MESSAGECHECK_B_K144
RETURN 0

@M_KOJO_MESSAGE_PALAMCNG_B_K144
;#DIM TotalEX
;-------------------------------------------------
;噴乳
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 0
;-------------------------------------------------
IF LOCAL && NOWEX:噴乳
	PRINTFORMW 
ENDIF
;-------------------------------------------------
;射精した
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 0
;-------------------------------------------------
IF LOCAL && NOWEX:射精
	PRINTFORMW 
ENDIF
;-------------------------------------------------
;放尿
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 0
;-------------------------------------------------
IF LOCAL && NOWEX:放尿
	PRINTFORMW 
ENDIF
;-------------------------------------------------
;絶頂
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
;合計絶頂数で分岐
;これだけではどの部位が絶頂したかは区別されないため、書き分けたければ任意で分岐を加筆されたし。
IF LOCAL
	SELECTCASE NOWEX:TotalEX
		;最強
		CASE 10 TO 15
			PRINTFORML
			PRINTFORMW 「クゥうううううっ%UNICODE(0x2665) *1% はぁっ%UNICODE(0x2665) *1% ああっ%UNICODE(0x2665) *1% あぁああぁあぁああっ―――%UNICODE(0x2665) *2%」
			PRINTFORMDW 全身を駆け巡る暴力的な快楽に、もはや%CALLNAME:TARGET%は意味のある言葉を吐けずイキ狂った。
			PRINTFORML
		;強
		CASE 5 TO 9
			PRINTFORML
			PRINTFORMW 「んはぁっ、あはぁあああっ！イクっ%UNICODE(0x2665) *1% イクイクイクっ、イクゥうううううっ%UNICODE(0x2665) *1%」
			PRINTFORMDW あまりに強烈な快感に、%CALLNAME:TARGET%は歓喜の悲鳴を響かせた。
			PRINTFORML
		;中
		CASE 2 TO 4
			PRINTFORML
			PRINTFORMW 「っあ…！気持ち、よすぎる……っ！これっ、もう……っ！っああぁああああ%UNICODE(0x2665) *1%」
			PRINTFORMDW %CALLNAME:TARGET%は背中を反らせて絶頂に達し、余韻に体を震わせている。
			PRINTFORML
		;弱
		CASE 1
			PRINTFORML
			PRINTFORMW 「んああっ……い、いいぞ。もう、イクッ――ッひぁああっ」
			PRINTFORMDW 絶頂による快感に対し、%CALLNAME:TARGET%は歯を食いしばっていた。
			PRINTFORML
	ENDSELECT
ENDIF

;-------------------------------------------------
;奴隷の睡眠絶頂時の口上
;-------------------------------------------------
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_MESSAGE_PALAMCNG_MESSAGECHECK_B2_K144
RETURN 0

@M_KOJO_MESSAGE_PALAMCNG_B2_K144
;-------------------------------------------------
;睡眠噴乳
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 0
;-------------------------------------------------
IF LOCAL && NOWEX:噴乳
	PRINTFORMW 
ENDIF
;-------------------------------------------------
;睡眠射精した
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 0
;-------------------------------------------------
IF LOCAL && NOWEX:射精
	PRINTFORMW 
ENDIF
;-------------------------------------------------
;睡眠放尿
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 0
;-------------------------------------------------
IF LOCAL && NOWEX:放尿
	PRINTFORMW 
ENDIF
;-------------------------------------------------
;睡眠絶頂
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 0
;-------------------------------------------------
;合計絶頂数で分岐
;これだけではどの部位が絶頂したかは区別されないため、書き分けたければ任意で分岐を加筆されたし。
IF LOCAL
	SELECTCASE NOWEX:TotalEX
		;強
		CASE 5 TO 15
			PRINTFORMW 
		;中
		CASE 2 TO 4
			PRINTFORMW 
		;弱
		CASE 1
			PRINTFORMW 
	ENDSELECT
ENDIF


