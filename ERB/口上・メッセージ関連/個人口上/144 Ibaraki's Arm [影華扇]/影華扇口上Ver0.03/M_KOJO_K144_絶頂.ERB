@M_KOJO_MESSAGE_PALAMCNG_A_K144_1(ARG)
;-------------------------------------------------
;膣内
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF !TALENT:妊娠 && !TCVAR:ピル && CFLAG:生解禁 == 2
		PRINTFORML 
		PRINTFORML 「あっ、んあぁあっ……中、熱いぃ……」
		PRINTFORML （遠慮なく出しやがって……本気で孕むかもしれないな……%UNICODE(0x2665) *1%）
		PRINTFORMDL どくどくと脈動しながら、%CALLNAME:MASTER%の%TINKO(MASTER)%は%CALLNAME:TARGET%の子宮に押し付けられている。
		PRINTFORMDW そこから一気に流し込まれる精液の熱さから、%CALLNAME:TARGET%は自身を孕ませる意思を感じていた。
		PRINTFORML 
	ELSEIF CFLAG:900 <= 2 || TCVAR:ピル
		PRINTFORML 
		PRINTFORML 「うぐぅううっ……は、果てたか……」
		PRINTFORML 「くくっ、そんなに私の中はよかったか？……」
		PRINTFORMDW %CALLNAME:MASTER%の精液を、%CALLNAME:TARGET%は子宮で受け止めた。
		PRINTFORML  
	ELSEIF CFLAG:生解禁 == 1
		PRINTFORML 「んっ、躊躇なく、出しやがってぇ……」
		PRINTFORML （まさか、本気で私を孕ませる気か……？）
		PRINTFORMDW %CALLNAME:MASTER%の%TINKO(MASTER)%から吐き出された精液は、余さず%CALLNAME:TARGET%の子宮に注ぎ込まれている。
	ELSE
		PRINTFORML 
		PRINTFORML 「私の中に出して……孕んだらどうしてくれる？」 
		PRINTFORMDW 子宮の中の熱を感じつつ、%CALLNAME:TARGET%は%CALLNAME:MASTER%を睨んだ。
		PRINTFORML 
	ENDIF
	RETURN 1
ENDIF
RETURN 1

