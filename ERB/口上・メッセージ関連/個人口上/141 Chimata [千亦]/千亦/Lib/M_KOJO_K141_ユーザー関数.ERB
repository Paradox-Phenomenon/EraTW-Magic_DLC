;月虹市場専用カード陳列関数
;ITEM_SHOPPINGをベースに口上用在庫管理変数に紐付け
;==================================================

@F_KOJO_K141_CARD_SHOPPING(ARG, 説明文, 割引)
#DIMS 説明文
#DIM 割引
#DIM 値段
値段 = ITEMPRICE:ARG * (100 - 割引) / 100
;在庫確認
CALL F_KOJO_K141_CARD_DATA(ARG, "在庫番号")
LOCALS = %金額表示(値段)%
IF CFLAG:[[千亦]]:(RESULT) <= 0
	SETCOLOR C_GRAY
	LOCALS = 没货了
ENDIF
SIF 値段 > MONEY
	SETCOLOR C_GRAY
IF ITEM:ARG >= 所持数制限
	SETCOLOR C_GRAY
	LOCALS = 未持有
ENDIF
LOCALS = [{ARG, 3}] %ITEMNAME_TR(ARG), 22, LEFT% %金額表示(値段)%

PRINTFORML %LOCALS, 48, LEFT%%説明文%
RESETCOLOR


