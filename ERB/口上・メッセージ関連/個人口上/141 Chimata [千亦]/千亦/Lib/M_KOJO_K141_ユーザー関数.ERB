;==================================================
;@F_KOJO_K141_CARD_DATA(アイテム番号,"購入"もしくは"アビリティカード"等のタイプ分け,割引率)
;月虹市場専用カードDATA関数
;ITEMDATA関数がベース
;==================================================

@F_KOJO_K141_CARD_DATA(ARG,ARGS,ARG:1)
SELECTCASE ARG
CASE [[命のカード]]
	SELECTCASE ARGS
		CASE "在庫番号"
			RETURN 1701
		CASE "購入"
			CALL F_KOJO_K141_CARD_BUY(ARG,ARG:1,1701)
		CASE "TYPE:アビリティカード"
			RETURN 1
	ENDSELECT
CASE [[スペルのカード]]
	SELECTCASE ARGS
		CASE "在庫番号"
			RETURN 1702
		CASE "購入"
			CALL F_KOJO_K141_CARD_BUY(ARG,ARG:1,1702)
		CASE "TYPE:アビリティカード"
			RETURN 1
	ENDSELECT
;無効なアイテム
CASEELSE
	RETURN 0
ENDSELECT
;購入時はRESULTを返す
SIF ARGS == "購入"
	RETURN RESULT

;==================================================
;@F_KOJO_K141_CARD_BUY(ARG, 割引,在庫)
;月虹市場専用カード購入関数
;ITEM_MATOMEGAI関数がベース
;==================================================

@F_KOJO_K141_CARD_BUY(ARG, 割引 , 在庫番号)
#DIM 割引
#DIM 値段
#DIM 在庫番号
PRINTFORM 要买几个%ITEMNAME_TR(ARG)%呢？（库存：{CFLAG:[[千亦]]:(在庫番号)}　持有数：{ITEM:ARG}）
PRINTL 
値段 = ITEMPRICE:ARG * (100 - 割引) / 100
;金欠、アイテム数の超過はあとで合わせる
SIF CFLAG:[[千亦]]:(在庫番号)
	PRINTL [ 1] １　　
SIF MIN(CFLAG:[[千亦]]:(在庫番号), 所持数制限 - ITEM:ARG) >= 5
	PRINTL [ 5] ５　　
SIF MIN(CFLAG:[[千亦]]:(在庫番号), 所持数制限 - ITEM:ARG) >= 10
	PRINTL [10] １０　
SIF MIN(CFLAG:[[千亦]]:(在庫番号), 所持数制限 - ITEM:ARG) >= 20
	PRINTL [20] ２０　
SIF MIN(CFLAG:[[千亦]]:(在庫番号), 所持数制限 - ITEM:ARG) >= 50
	PRINTL [50] ５０　
PRINTFORML [{MIN(CFLAG:[[千亦]]:(在庫番号), 所持数制限 - ITEM:ARG), 2}] 全部
PRINTL [ 0] 返回
INPUT
IF INRANGE(RESULT, 1, CFLAG:[[千亦]]:(在庫番号))
	IF 値段 * RESULT > MONEY
		PRINTFORMW 金钱不足…
		RETURN 0
	ELSEIF ITEM:ARG + RESULT > 所持数制限
		PRINTFORMW 拿不下这么些！
		RETURN 0
	ENDIF
	MONEY -= 値段 * RESULT
	CFLAG:[[千亦]]:(在庫番号) -= RESULT
	ITEM:ARG += RESULT
	PRINTFORMW 买了{RESULT}%ITEMNAME_TR(ARG)%个，花了%金額表示(値段 * RESULT)%哦
	RETURN 値段
ENDIF
RETURN 0

;==================================================
;@F_KOJO_K141_CARD_SELL
;月虹市場専用カード販売関数
;酒卸売関数をベースにカード販売専用化
;==================================================

@F_KOJO_K141_CARD_SELL

#DIM 所持数
#DIM 選択した商品
#DIM 売却個数
#DIM 売却額
#DIM 売却率

売却率 = CFLAG:[[千亦]]:1751

WHILE 1 ;商品選択ループ
	DRAWLINE
	PRINTFORML 「哪张卡要卖给我呢？」
	DRAWLINE
	PRINT 嗯……要卖什么呢……
	PRINTFORML 所持金:%金額表示(MONEY)%
	CALL F_KOJO_K141_CARD_VIEW(0, "売却", 売却率)
	IF RESULT == 0 ;キャンセルなら終了
		RETURN -1
	ENDIF
	;選んだ番号にしたがって所持数を格納
	所持数 = ITEM:RESULT
	;所持0の場合 セーフティ
	IF 所持数 <= 0
		PRINTL 
		PRINTW 没有东西可卖啊……
		RETURN -1
	ENDIF
	;所持0で無い場合個数を尋ねる
	;もう一回INPUTを使うため今の値を退避
	選択した商品 = RESULT
	売却個数 = 0
	WHILE 1 ;個数選択ループ
		PRINTFORML 要卖几张%ITEMNAME_TR(選択した商品)%呢……
		PRINTFORML 卖的数量：{売却個数}
		PRINTFORML [-100]　[ -10]　[  -1]　[  +1]　[ +10]　[+100]
		PRINTBUTTON "[全部] ", 999
		PRINTBUTTON " [重置]", -999
		PRINTL 
		SIF 売却個数 > 0
			PRINTBUTTON "[卖掉]", 0
		SIF 売却個数 == 0
			PRINTBUTTON "[卖/放弃]", 0
		INPUT
		IF RESULT == 0
			BREAK ;[売る]→個数選択ループを抜ける
		ELSEIF RESULT == 999
			売却個数 = 所持数
		ELSEIF RESULT == -999
			売却個数 = 0
		ELSE
			売却個数 = LIMIT(売却個数 + RESULT, 0, 所持数)
		ENDIF
		CLEARLINE 6
	WEND
	IF 売却個数 <= 0
		PRINTL 
		PRINTL 还是不卖了呢
		CONTINUE
	ENDIF
	IF 売却個数 > 所持数
		PRINTL 
		PRINTL 没有那么多哦
		CONTINUE ;LIMITで制限されているがセーフティとして
	ENDIF
	;一つあたりの売却額を算出
	売却額 = (ITEMPRICE:選択した商品 * (100 - 売却率)) / 100
	ITEM:選択した商品 -= 売却個数
	MONEY += 売却額 * 売却個数
	;お店は定価の80％で販売
	PRINTFORMW 以%金額表示(売却額 * 売却個数)%的价格卖掉了{売却個数}张%ITEMNAME_TR(選択した商品)%
	;販売個数を増加させる処理 現状必要無し。独自関数処理に後で組み替える
	;ITEMSALES:選択した商品 += 売却個数
	PRINTFORML 「还有什么想卖的吗？」
	CALL ASK_YN()
	SIF RESULT
		RETURN
WEND

;==================================================
;@F_KOJO_K141_CARD_VIEW(表示最低数, 売却モードか, 割引 = 0)
;月虹市場専用カード一覧表示関数
;酒表示一覧をベース
;==================================================

@F_KOJO_K141_CARD_VIEW(ARG, ARGS, 割引 = 0)
;所持数がARG未満だと非表示、ARG以上所有してるカードを選択するとそのアイテム番号をRETURNする
#DIM ITEM_ID
#DIM 割引
#DIM 売るものID


;初期値は固有アイテムIDまでスキップ
FOR ITEM_ID, 398 , 1000
	CALL F_KOJO_K141_CARD_DATA(ITEM_ID, "TYPE:アビリティカード")
	IF RESULT && ITEM:ITEM_ID >= ARG
		IF ARGS == "売却"
			PRINTFORML [{ITEM_ID}]%ITEMNAME_TR(ITEM_ID), 20, LEFT% (%金額表示(ITEMPRICE:ITEM_ID * (100 - 割引)/ 100) , 7, RIGHT% / 所持: {ITEM:ITEM_ID, 3, RIGHT})
		ELSE
			CALL PRINT_ITEM_EXPLANATION(ITEM_ID) ;非売却時にアイテムの説明が出るアレ
		ENDIF
	ENDIF
NEXT

DRAWLINE 
PRINTL [999] 返回
INPUT
SIF RESULT == 999 ;resultに999入ってたら即終了
	RETURN 0
売るものID = RESULT
CALL F_KOJO_K141_CARD_DATA(売るものID, "TYPE:アビリティカード") ;アビカしか売らないチェック ダブルチェック 全てのチェックを手ェェェに入れた男ォォ！！！１１Sunshine…池…崎　イェエエエエエエエ！！！！！！！！１１１　（ZGMF-X09A）ジャスティス！
IF RESULT && ITEM:売るものID >= ARG
	RETURN 売るものID
ELSEIF 売るものID == 999 ;セーフティ
	RETURN 0
ELSE
	RESTART
ENDIF

