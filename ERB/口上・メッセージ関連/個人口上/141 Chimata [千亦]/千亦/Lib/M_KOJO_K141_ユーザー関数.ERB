
;==================================================
;口上独自関数：CFLAG&TCVAR管理
;@F_KOJO_K141_CFLAG_TCVAR_DAILY_UPDATE
;==================================================
;EVENT_1でその日初めて遭遇した判定の時に呼び出して、あなた好感度依存CFLAGをアップデート
;後々なにか追加するかも

@F_KOJO_K141_CFLAG_TCVAR_DAILY_UPDATE
LOCAL = 0 ;LOCALが1ならデバッグ用の表示をする 
	
	IF TCVAR:182 == 1 ;TCVAR:182 今日会ったか

	ELSEIF TCVAR:182 == 0 
		IF !CFLAG:[[千亦]]:1901 ;初邂逅時の相性値等設定後フラグ
			CALL F_KOJO_K141_RELATION
		ENDIF
		IF RAND:100 < 80 && (CFLAG:[[千亦]]:1502 || MARK:[[千亦]]:反発刻印 >= 1) ;おこフラグor反発持ってると８０％で思い出して不機嫌になる
			TALENT:[[千亦]]:機嫌 = -1
		ENDIF
		;CFLAG:TARGET:1001 現在の千亦の口調 (0=好感度499まで 1=好感度500~））
		IF CFLAG:[[千亦]]:2 >= 500 ;好感度500以上
			CFLAG:[[千亦]]:1001 = 1
		ELSE ;好感度499以下
			CFLAG:[[千亦]]:1001 = 0 
		ENDIF
		IF DAY:3 % 7 == 0
			CFLAG:[[千亦]]:1701 +=1 ;カード在庫増加 肥大化したら関数化
			CFLAG:[[千亦]]:1702 +=1 
		ENDIF
	ENDIF
RETURN 0

;==================================================
; @F_KOJO_K141_RELATION
;EBRファイルから相性関係を編集
;相性以外のフラグも纏めて初期化
;RELATION:[主観キャラ]:[対象キャラ]
;相性,139,110;典
;相性,140,120;龍
;相性,142,110;百百世
;~~~~独自解釈~~~~
;相性,125,90 ;女苑
;相性,126,50 ;紫苑
;~~~~~~~~~~~~~~~
;==================================================
@F_KOJO_K141_RELATION
RELATION:[[千亦]]:[[典]] = 110
RELATION:[[千亦]]:[[龍]] = 120
RELATION:[[千亦]]:[[百百世]] = 110
RELATION:[[千亦]]:[[女苑]] = 90
RELATION:[[千亦]]:[[紫苑]] = 50
CFLAG:[[千亦]]:1701 = 3
CFLAG:[[千亦]]:1702 = 3
CFLAG:[[千亦]]:1751 = 70
SIF TALENT:[[千亦]]:性別 == 3
	CFLAG:[[千亦]]:1651 = 1 ;千亦が先天的ふたなり（というか初遭遇時点でふたなり）ならふたなり判定する変数 
CFLAG:[[千亦]]:1901 += 1


;==================================================
; @F_KOJO_K141_PRINTS_RAINBOW("文字列",彩度 = 65,明度 = 100 ,表示形式(0=改行無し,1=改行ありウェイト無し,2=改行ありウェイトあり))
;==================================================

; 1文字ごとに虹色（色相環を一周）させて表示する
@F_KOJO_K141_PRINTS_RAINBOW(L_PRINTS,彩度 = 65,明度 = 100 ,L_表示形式)
#DIMS L_PRINTS ;表示文字列
#DIM L_表示形式
#DIM L_COUNT ;ループカウンタ
#DIM L_N_COLOR ;現在の色
#DIM 色相 
#DIM 彩度 ;デフォルト65
#DIM 明度 ;デフォルト100
#DIM L_P_STR ;文字数
#DIM L_元の文字色 ;元の文字色

L_元の文字色 = GETCOLOR()
L_P_STR = STRLENSU(L_PRINTS)

FOR L_COUNT, 0, L_P_STR
    ; 色相(H)を 0〜359 の範囲で計算
    色相 = L_COUNT * 360 / L_P_STR
    
; HSVからRGBに変換して色を設定
; --- ビジュアル関連_Design.erb内の関数利用。---
;-------------------------------------------------
;HSVカラーをRGBカラーに変換する関数
;HSV_TO_RGB(ARG:0, ARG:1, ARG:2)
;ARG:0=色相(0～359)
;ARG:1=彩度(0～100)
;ARG:2=明度(0～100)
;-------------------------------------------------
    L_N_COLOR = HSV_TO_RGB(色相, 彩度, 明度)
    


    SETCOLOR L_N_COLOR
    PRINTFORM %SUBSTRINGU(L_PRINTS, L_COUNT, 1)%
NEXT
SETCOLOR L_元の文字色
SELECTCASE L_表示形式 ;COLORMESSAGEから丸パクリ
	CASE 0
		PRINTFORM 
	CASE 1
		PRINTFORML 
	CASE 2
		PRINTFORMW 
	CASE 3
		PRINTPLAINFORM
ENDSELECT
