;@F_KOJO_K141_LIST_ITEM(TYPE)
;月虹市場専用LIST_ITEM
;LIST_ITEM関数をベースにしました
;==================================================

@F_KOJO_K141_LIST_ITEM(TYPE = "全て")
#DIMS TYPE
#DIM 表示数

SELECTCASE TYPE
	CASE "全て"
		CALL F_KOJO_K141_LIST_ITEM("アビリティカード")
	CASEELSE
		;398~回す
	表示数 = 0
	FOR LOCAL, 398, 1000
		CALL F_KOJO_K141_CARD_DATA(LOCAL, "TYPE:" + TYPE)
		IF RESULT && ITEM:LOCAL
			PRINTFORMLC %ITEMNAME_TR(LOCAL)%({ITEM:LOCAL})
			表示数 ++
			SIF 表示数 % 4 == 0
				PRINTL 
		ENDIF
	NEXT
	SIF 表示数 % 4 != 0
		PRINTL 
ENDSELECT

;==================================================
;@F_KOJO_K141_GAYA_TALKING
;月虹市場専用色付きガヤ台詞
;左右起点はランダム、同一方向からにならないように台詞を出す
;==================================================

@F_KOJO_K141_GAYA_TALKING
#DIMS L_TEXTLIST,100
LOCAL:0 = 0 ;while＆ブレイク判定
LOCAL:1 = RAND:2 ;左右判定


L_TEXTLIST:0 = 啊啊不行，这里不能乱翻哦！
L_TEXTLIST:1 = 价格谈判，开始！
L_TEXTLIST:2 = 这种卡，我有36张呢
L_TEXTLIST:3 = BA酱，用这张卡和我手上的这所有卡交换吧！
L_TEXTLIST:4 = 买来的能力卡牌不装备的话就没意义了吧？
L_TEXTLIST:5 = 要在这里直接装备上吗？
L_TEXTLIST:6 = 呵呵呵，不☆行
L_TEXTLIST:7 = 要加热吗？
L_TEXTLIST:8 = 我最喜欢的是……价格
L_TEXTLIST:9 = 加了好多添加剂，绝对不会坏掉哦～☆
L_TEXTLIST:10 =

LOCAL:10 = FINDELEMENT(L_TEXTLIST,"",0,VARSIZE("L_TEXTLIST"),1) 
;リスト配列の実質長

DO 
LOCAL:20 = RAND:(LOCAL:10);上のガヤへアクセスする配列数
LOCAL:30 = RAND:(LOCAL:10);下のガヤへアクセスする配列数
LOOP LOCAL:20 == LOCAL:30

WHILE !(LOCAL:0 >= 2) ;一応。2ループ目には抜けるはず
SELECTCASE RAND:7
    CASE 0
        SETCOLOR 0xFF5555 ; 赤
    CASE 1
        SETCOLOR 0xFFAA55 ; 橙
    CASE 2
        SETCOLOR 0xFFFF55 ; 黄
    CASE 3
        SETCOLOR 0x55FF55 ; 緑
    CASE 4
        SETCOLOR 0x55FFFF ; 水色
    CASE 5
        SETCOLOR 0x5555FF ; 青
    CASE 6
        SETCOLOR 0xFF55FF ; 紫
ENDSELECT
	SIF LOCAL:0 ;2回目のループは染色後にBREAK
		BREAK
	SELECTCASE LOCAL:1 ;左右判定
		CASE 0 ;左
			PRINTFORML ＜ %L_TEXTLIST:(LOCAL:20) %
			LOCAL:1 = 1 ;次の行は左右反転
		CASE 1 ;右
			LOCALS = %L_TEXTLIST:(LOCAL:20) % ＞
			LOCAL:2 = ( STRLENS(DRAWLINESTR) - STRLENS(LOCALS) )/ 3
			PRINTFORM %" " * MAX(0,LOCAL:2)%
			PRINTFORML %LOCALS% 
			LOCAL:1 = 0 ;次の行は左右反転
	ENDSELECT
	LOCAL:0 += 1 ;ループ回数判定
WEND
	SELECTCASE LOCAL:1 ;左右判定
		CASE 0 ;左
			PRINTFORML ＜ %L_TEXTLIST:(LOCAL:30) %
		CASE 1 ;右
			LOCALS = %L_TEXTLIST:(LOCAL:30) % ＞
			LOCAL:2 = ( STRLENS(DRAWLINESTR) - STRLENS(LOCALS) )/ 3
			PRINTFORM %" " * MAX(0,LOCAL:2)%
			PRINTFORML %LOCALS% 
	ENDSELECT
RESETCOLOR

