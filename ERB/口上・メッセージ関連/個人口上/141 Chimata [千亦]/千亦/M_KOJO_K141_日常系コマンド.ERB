	;AM6~12 正午前 = 2
	;PM12~3 昼 =3
	;PM3~6 昼下がり = 4
	;PM6~8 夕 = 5
	;PM8~11 夜 = 6
	;PM11~AM4 深夜 = 7
	;------------------
	;CFLAG:141:1002 
	;TEAカウンタ（千亦碳が貴方に感じてるお茶淹れの巧さ ~5:美味しく淹れる印象無し ~25:そこそこな印象 26~:上手な印象
	;------------------
	IF CFLAG:318 == 1 || TALENT:[[千亦]]:機嫌 == -1
		PRINTFORML 「\@ CFLAG:[[千亦]]:1001 >= 1 ? 啜啜…… # …我开动了 \@」
		PRINTFORMDW 虽然一脸不爽，却还是小口啜着茶……
	ELSEIF CFLAG:[[千亦]]:1001 == 1 ;好感度分岐
	;CFLAG:1001为1时，实际上相当于好感度500～，但CFLAG的更新时机是当天第一次见面时，所以就算当天好感度超过500也不会选中这个分支
	;考虑到突然态度大变可能会显得不自然，所以做了这样的处理。可以理解成一种“隐形的陷落资质”之类的东西……
		SELECTCASE TFLAG:193 ;成功度分岐
			CASE 1 ;大成功
				IF TCVAR:[[千亦]]:351 == 0 &&  DAY:2 == 1 && (TIME:2 >= 2 && TIME:2 <= 5 ) && RAND:10 < 7 && CFLAG:[[千亦]]:1002 >= 26 
				;当天还没喝过固有茶、泡茶技术高超、春季6时～20时、70%几率触发新茶（实质上第一年看不到）
					PRINTFORMDL 把新茶倒进茶杯，递给了千亦……
					PRINTFORML 「我开动了……哎呀，买到好茶叶了呢」
					PRINTFORML 「原来已经到新茶的季节了啊。幻想乡的四季轮转真快呢」
					;有点小meta发言
					PRINTFORMDW 和千亦一起品着新茶，愉快地聊着天……
					TCVAR:[[千亦]]:351 += 1 ;固有茶标志

				ELSEIF TCVAR:[[千亦]]:351 == 0 &&  DAY:2 == 4 && (TIME:2 >= 2 && TIME:2 <= 6 ) && RAND:10 < 7 
				;当天还没喝过固有茶、冬季6时～20时、70%几率触发焙茶
					PRINTFORMDL 把焙茶倒进茶杯，递给了千亦……
					PRINTFORML 「暖和又好喝呢，冬天果然还是焙茶最好」
					PRINTFORMW 「呼～……暖到心底了～……」
					TCVAR:[[千亦]]:351 += 1 ;固有茶标志
				
				ELSEIF TCVAR:[[千亦]]:351 == 0 && (TIME:2 >= 2 && TIME:2 <= 3 ) && RAND:10 < 4
				;当天还没喝过固有茶、6时～13时、40%几率触发咖啡
					PRINTFORML 「咖啡香气好闻，又正好提神醒脑呢」
					SIF TIME:2 <= 2 && TIME_PROGRESS(TCVAR:[[千亦]]:空腹時刻) ;12时前且千亦处于空腹时
						PRINTFORMW 「%CALLNAME:MASTER%，要不要加个早餐套餐？呵呵，开玩笑的啦」
					SIF TIME:2 >= 3 ;下午以后
						PRINTFORMW 「谢谢款待。那，下午也继续加油吧」
					TCVAR:[[千亦]]:351 += 1 ;固有茶标志
				ELSEIF TCVAR:[[千亦]]:351 == 0 && (TIME:2 >= 2 && TIME:2 <= 6 ) && RAND:10 < 3
				;当天还没喝过固有茶、30%几率触发路易波士
					IF CFLAG:[[千亦]]:1003 >= 1 && DAY:2 >= 3;秋/冬
						PRINTFORMDL 把热路易波士倒进马克杯，递给了千亦……
						PRINTFORMW 「你给我泡茶了？」
						PRINTFORMW 「好香啊……感觉整个人都放松下来了」
						SIF TIME:2 >= 6
							PRINTFORMW 「无咖啡因的，在这个时间段正好呢……」
						PRINTFORMW 和千亦一起享受着悠闲的下午茶时光……
					ELSEIF CFLAG:[[千亦]]:1003 >= 1 && DAY:2 <= 2 ;春/夏
						PRINTFORMDL 把冰路易波士倒进茶杯，递给了千亦……
						PRINTFORMW 「正好口渴了呢，谢谢」
						PRINTFORMW 「嗯咕……啊，这个是之前你给我喝过的那个吧？」
					ELSE ;初次文本
						PRINTFORMW 「看起来像红茶……但味道完全不一样呢」
						SIF DAY:2 >= 3
							PRINTFORMW 「哦～原来叫路易波士啊。喝着让人安心呢」
						SIF DAY:2 <= 2 
							PRINTFORMW 「哦～原来叫路易波士啊。挺好入口的呢」
						CFLAG:[[千亦]]:1003 += 1; 路易波士初体验完成
					ENDIF
					TCVAR:[[千亦]]:351 += 1 ;固有茶标志
				ELSEIF RAND:100 < 2 ;チャイッ！
					PRINTFORMDL chi-a-茶！印度的庶民饮品！
					PRINTFORMDW 用红茶、砂糖、生姜和牛奶熬煮而成的甜味饮品！
					PRINTFORMW 「欸，刚才那段解说是什么？」
					;チャイッ！
				ELSE
				;都不符合时
					SELECTCASE CFLAG:[[千亦]]:1002 ;TEA计数（千亦觉得你泡茶的本事
						CASE 0 TO 5 ;毫无泡茶好印象
							PRINTFORML 「哎呀，你给我泡茶了？」
							PRINTFORMW 「嗯……意外地好喝呢，谢谢款待」
						CASE 6 TO 25 ;还算可以
							PRINTFORML 「今天也给我泡了？谢谢」
							PRINTFORMW 「呼～……让人平静下来呢」
						CASE IS >= 26 ;很上手
							PRINTFORML 「总是麻烦你了，%CALLNAME:MASTER%」
							PRINTFORMW 「真的很好喝呢……\@ TALENT:MASTER:性別 == 2 ? 你 # 你 \@，干脆拿这个开店算了？」
					ENDSELECT
				ENDIF
				CFLAG:[[千亦]]:1002 += 2 ;大成功所以加2点
			CASE 0 ;成功
				IF 0 == 1 ;目前没有分支。
					ELSE ;都不符合时	
						SELECTCASE CFLAG:[[千亦]]:1002 ;TEA计数（千亦觉得你泡茶的本事～
							CASE 0 TO 5 ;毫无泡出好茶的印象
								PRINTFORML 「哎呀，你给我泡茶了？」
								PRINTFORMW 「嗯……意外地好喝呢，谢谢款待～」
							CASE 6 TO 25 ;还算可以的印象
								PRINTFORML 「今天也给我泡了？谢谢」
								PRINTFORMW 「呼～……让人平静下来呢」
							CASE IS >= 26 ;很上手的感觉
								PRINTFORML 「总是麻烦你了，%CALLNAME:MASTER%」
								PRINTFORMW 「真的很好喝呢……\@ TALENT:MASTER:性別 == 2 ? 你 # 你 \@，干脆拿这个开店算了吧？」
						ENDSELECT
				ENDIF
				CFLAG:[[千亦]]:1002 += 1 ;成功所以加1点

					CASE -1 ;失败
							SELECTCASE CFLAG:[[千亦]]:1002 ;TEA计数（千亦觉得你泡茶的本事～
								CASE 0 TO 5 ;毫无泡出好茶的印象
									PRINTFORML 「好淡呢。是用泡过一次的茶叶吗？」
									PRINTFORMW 「给神明喝的话，至少再多花点心思啊～」
								CASE 6 TO 25 ;还算可以的印象
									PRINTFORMW 「嗯～……有点不行呢」
								CASE IS >= 26 ;很上手的感觉
									PRINTFORML 「啜啜……嗯？总觉得味道怪怪的……泡法出错了吧？」
									PRINTFORMW 「\@ TALENT:MASTER:性別 == 2 ? 你 # 你 \@居然会在泡茶上失手，真是少见呢」
							ENDSELECT
				ENDSELECT

	ELSE	;不匹配（大致用于好感度500以下时）
		SELECTCASE TFLAG:193
			CASE 1 ;大成功
				PRINTFORML 「是茶吗，谢谢……」
				PRINTFORML 「啜啜……哎呀，意外地好喝呢。」
				PRINTFORMDW 看来泡得不错。千亦的脸颊似乎微微放松了……
			CASE 0 ;成功
				PRINTFORML 「是茶吗，谢谢……」
				PRINTFORM 「啜啜……味道不错呢。
				IF CFLAG:MASTER:初期位置 == CFLAG:MASTER:現在位置 
					PRINTFORMW  」
				ELSE ;不在自己房间泡茶时会产生一点小疑问的分支
					PRINTFORML 「……话说，这茶你是藏哪儿的啊？」
					PRINTFORMDW 这是商业机密。
				ENDIF
			CASE -1 ;失败
					PRINTFORML 「我开动了……咳咳！这、这是什么啊！」
					PRINTFORMDW 好像搞错了什么……赶紧递上白开水漱口。
					;嗯！？好像弄错了……
		ENDSELECT
	ENDIF





ENDIF
RETURN 1
