				ELSE
					PRINTFORMW 「真是精彩到不惧神明的人类啊！」
					PRINTFORML 「彩虹马上就要关闭了，最后把你的命也归于虚无吧」
					PRINTFORMW 「到此结束！」
					PRINTFORM 「「
					CALL F_KOJO_K141_PRINTS_RAINBOW("弹幕的庇护所",80,100,0)
					PRINTFORMW 」！！」
					PRINTFORMDW 千亦周遭迸发出极彩色的弹幕……！
				ENDIF
			CASE 0
			IF TCVAR:[[千亦]]:361 == 1
				PRINTFORMW 「骗人的吧——！！！？？」
			ELSEIF TCVAR:[[千亦]]:360 == 1
				PRINTFORMW 「……！」
			ELSE
				PRINTFORMW 「骗人！？居然做到这种地步……！咿呀！」
			ENDIF

		ENDSELECT
	ENDIF
	;-------------------------------------------------
	;戦闘中
	;TARGETの【残忍酷薄】発動時
	;ARGはTARGETの残機
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "残忍酷薄"
		
	ENDIF
	;-------------------------------------------------
	;戦闘中
	;TARGETの【乾坤一擲】発動時
	;ARGはTARGETの残機
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	;スペルのカード使用分岐でのみ乾坤一擲を習得
	IF LOCAL:1 && ARGS == "乾坤一擲"
		PRINTFORMW 「就是现在！来吧，开战！」
		PRINTFORMDL 千亦使用了「符咒卡牌」，弹幕的密度顿时激增……！
	ENDIF
	;-------------------------------------------------
	;戦闘中
	;TARGETの【怪力乱神】発動時
	;ARGはTARGETの残機
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "怪力乱神"
		
	ENDIF
	
	;-------------------------------------------------
	;戦闘後
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "戦闘後" 
		PRINTFORML 
		;残り残機4が表示されうるのは【洽覧深識】持ちのみ
		;残機が1以上ならあなたの負け、0の場合はあなたの勝利
		SELECTCASE 相手残機
		[SKIPSTART]
			CASE 5
				IF 	MARK:[[千亦]]:反発刻印 >= 2 && TCVAR:[[千亦]]:361 == 1
					PRINTFORMDL 在千亦全力以赴的弹幕“游戏”面前，完全动弹不得……
					PRINTFORMW 「……太弱了。这样根本没必要认真啊。」
					PRINTFORMW 「先说清楚，我还没\@ TALENT:MASTER:性別 == 2 ? 原谅你 # 原谅你哦 \@。」
					PRINTFORMDW 视线冷得可怕……不认真道歉的话，恐怕不会被原谅……
					CALL F_KOJO_K141_SUPER_KAIJO(L_素の戦闘能力)
				ELSEIF TCVAR:[[千亦]]:361 == 1
					PRINTFORMDL 在千亦全力以赴的弹幕“游戏”面前，完全动弹不得……
					PRINTFORMW 「哎呀……没想到你居然这么弱？」
					PRINTFORMW 「哈……有点扫兴，不过算了。原谅你啦。」
					PRINTFORMW 「这样一来，\@ TALENT:MASTER:性別 == 2 ? 你的 # 你的 \@不敬就一笔勾销吧。以后继续好好相处哦？」
					PRINTFORMDW 看来被原谅了……
					CALL F_KOJO_K141_SUPER_KAIJO(L_素の戦闘能力)
					CFLAG:[[千亦]]:1502 = 0 ;弹幕战强上后未付款标志解除
					IF MARK:[[千亦]]:反発刻印 == 1 ;除了胜利以外最多只能解除到Lv1
						PRINTFORMDW %CALLNAME:[[千亦]]%失去了反感刻印LV{MARK:[[千亦]]:反発刻印}
