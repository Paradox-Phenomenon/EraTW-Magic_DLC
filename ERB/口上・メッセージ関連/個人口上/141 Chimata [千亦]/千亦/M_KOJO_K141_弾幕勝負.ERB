@M_KOJO_ARIMA_MESSAGE_COM_K141_DANMAKU(ARGS, 相手残機,ARG)
#DIM 相手残機
#DIM L_素の戦闘能力
#DIMS L_喪失固有文
;全体の流れ
;①【戦闘前】→②ダイスロールとプレイヤー選択肢、ハンデをつけた場合は【ハンデ口上】→③対応スキルが発動した場合【スキル口上】→④被弾判定、キャラが被弾したなら【被弾口上】→
;どちらかの残機が0になっていなければ②に戻る→⑤【戦闘後口上】

;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
SIF FLAG:口上色
	TRYCALLFORM M_KOJO_COLOR_K{NO:TARGET}
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;戦闘前
	HANDICAP_FIXED = 0
	HANDICAP_RAND = 0
	;ハンデをつけることができ、数値が大きいほどあなたが不利になる　数値が負ならあなたが有利に
	;キャラの能力に関わらずクッソ強くしたり弱くしたりできる
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1

	;-------------------------------------------------
	;构想：持有「空白的卡牌」（未实装）时会弹出多个选项
	;「好棒的卡牌呢！」「真是个有趣的卡牌呢～（皮肉）」「超～级～棒的卡牌哦～～～超帅气呢（棒读）」「不小心买错了吧……已经想哭了」「最没用的一张卡呢！」
	;基本上不管选哪个，千亦都会生气　预想的是那种职业摔角式的夸张发火方式
	;取得1胜后解禁「千亦认真模式」（相当于强化LV5强度）
	;赢了之后就能买到青汁、易书或者千亦的嘴唇
	;如果因为某些原因把她彻底惹毛了，就会分歧进入「超级千亦模式」
	IF LOCAL:1 && ARGS == "戦闘前"
		IF CFLAG:[[千亦]]:1502 == 1 || MARK:[[千亦]]:反発刻印 >= 1 ;何かしらのおこ状態をorで総当りする
			;因互相碰撞而加深羁绊的友情　受伤并非毫无意义，因此有一定概率让「反感刻印」消失
			;目前应该只在带有反感刻印的状态下才会生效
			PRINTFORMW 「……弹幕战吗。很好，正好让我发泄一下怒火」
			PRINTFORMDL 话音刚落，千亦就把手中的能力卡牌全部发动了！
			PRINTFORMDL 看来对\@ TALENT:MASTER:性別 == 2 ? 这边的 # 这边的 \@所作所为相当火大……这是认真中的认真啊！
			PRINTFORMW 「全部归于虚无吧！以神之不可见之手！」
			L_素の戦闘能力 = ABL:[[千亦]]:戦闘能力 
			CALL F_KOJO_K141_SUPER_CHIMATA()
			;能力的にはデフォルト+1ランク相当に補正、一時的に乾坤一擲,幽愁暗恨を取得。

		ELSEIF TFLAG:GipsLV >= 5 && CFLAG:[[千亦]]:930 >= 1 ;已胜利且玩家侧外骨骼LV设定为5以上（相当于困难模式）时
			PRINTFORML 「弹幕战吗？行啊」
			PRINTFORMDL 要根据角虫养成外骨骼的强度来调整台词吗？
			CALL ASK_M("嗯，来吧", 1 , "不用在意", 1 )
			SELECTCASE RESULT
				CASE 0 
					IF TFLAG:GipsLV >= 5 ; && TFLAG:GipsLV <= 9 ;ルナ実装したら条件追加
						PRINTFORMDL 已设置台词标志。
						PRINTFORML 「我可不会手下留情哦，「献给无主的供物」！」
						CALL COLORMESSAGE("比平常的弹幕要激烈得多！",C_YELLOW,2)
						TCVAR:[[千亦]]:360 = 1 ;ハードモード
					;ELSEIF TFLAG:GipsLV >= 10 ;ルナティック仕様 ;未実装
					;	PRINTFORMDL 台詞フラグを設定しました。
					;	TCVAR:[[千亦]]:360 = 2 ;ルナティックモード
					ELSE
						PRINTFORMDL 本来不该显示的分支＞＜
					ENDIF
				CASE 1
					PRINTFORMDL 台词照常。
					PRINTFORMW 「上吧，认真来啊！」

			ENDSELECT

		ELSEIF CFLAG:[[千亦]]:930 >= 1 ;勝利済みでギプスを付けてない場合
			PRINTFORML 「弹幕对决吗？行啊」
			PRINTFORML 「不过……之前的弹幕战可不是我的全力。今天就让\@ CFLAG:[[千亦]]:1001 >= 1 ? 你见识一下 # 你见识见识 \@我的真本事吧」
			PRINTFORMW 「当然，如果\@ TALENT:MASTER:性別 == 2 ? 你 # 你 \@还没自信的话……\@ CFLAG:[[千亦]]:1001 >= 1 ? 就跟上次一样手下留情哦？ # 保持和之前一样的水平也可以哦？ \@」
			CALL ASK_M("还没准备好", 1 , "来吧！奉陪到底！" , 1 )
			SELECTCASE RESULT
				CASE 0
					PRINTFORML 「那也没办法，就按之前的水平陪你玩吧」
					PRINTFORMW 「不过，我可不会让你轻易躲过去的哦！」
				CASE 1 
					PRINTFORML 「好干脆的回答呢，那我也不藏着掖着了」
					;其实还是有所保留
					PRINTFORML 「那就直接上吧，「献给无主的供物」！」
					CALL COLORMESSAGE("比之前的弹幕激烈太多了！",C_YELLOW,2)
					TCVAR:[[千亦]]:360 = 1 ;ハードモード
					TFLAG:GipsLV = 5 ;ギプスLVを強制的に5に
			ENDSELECT
		ELSEIF CFLAG:[[千亦]]:930 == 0 && ABL:MASTER:戦闘能力 + 1 < ABL:TARGET:戦闘能力 && CFLAG:[[千亦]]:1501 == 0 ;未勝利かつ千亦より２ランク弱くてアビカ試供品イベント未達の場合発生
			PRINTFORML 「哎呀，要和我来弹幕对决？」
			PRINTFORML 「嗯……那在这之前，先送你一套能力卡牌的试用品吧\@ TALENT:MASTER:性別 == 2 ? 给你 # 给你 \@\@ CFLAG:[[千亦]]:1001 >= 1 ? 做礼物！ # 吧。 \@」
			PRINTFORML 「依我看，\@ TALENT:MASTER:性別 == 2 ? 你 # 你 \@和我战斗力差了不少，但用了这个，应该能打得有来有回哦？」
			PRINTFORMDW 听起来很诱人，但是……
			CALL ASK_M("收下", 1 , "不要施舍" , 1 )
			SELECTCASE RESULT
				CASE 0
					PRINTFORML 「真老实，好事哦，给你」
					CALL COLORMESSAGE("获得了能力卡牌・新手套牌！",C_YELLOW,1)
