					PRINTFORMW 「来吧，好好运用它们！开战！」
				CASE 1
					PRINTFORML 「这样啊？明明第一次是免费的呢。」
					PRINTFORMW 「这份气势我收下了。来吧，开战！」
			ENDSELECT
			CFLAG:[[千亦]]:1501 += 1 ;
		ELSE
			PRINTFORML 「哎呀，要和我来弹幕对决？」
			PRINTFORMW 「好啊，认真来吧！」
		ENDIF

		RETURN 0
