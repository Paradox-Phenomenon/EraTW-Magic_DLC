@M_KOJO_ARIMA_MESSAGE_COM_K141_0_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;新規分岐作成
	;-------------------------------------------------
	;時間停止＞恋慕/思慕＞陥落素質なしの優先度で記述
	;-------------------------------------------------
	IF FLAG:70 ;時間停止
	ELSEIF TALENT:[[千亦]]:恋慕 || TALENT:[[千亦]]:思慕
		IF TEQUIP:50 == PLAYER ;V挿入
			IF NOWEX:PLAYER:11 ;射精した
				PRINTFORMW 
			ELSE
				PRINTFORMW 
			ENDIF
		ELSEIF TEQUIP:51 == PLAYER ;A挿入
			IF NOWEX:PLAYER:11 ;射精した
				PRINTFORMW 
			ELSE
				PRINTFORMW 
			ENDIF
		ELSE ;挿入無し
			PRINTFORML 
		ENDIF
	ELSE ;陥落素質無し
		PRINTFORMW 
	ENDIF
	RETURN 1
ENDIF


