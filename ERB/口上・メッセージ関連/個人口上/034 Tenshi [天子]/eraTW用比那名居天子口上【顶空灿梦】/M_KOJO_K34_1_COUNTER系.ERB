@M_KOJO_顶空灿梦_MESSAGE_COUNTER_K34_1
CALL EVENT_COUNTER_MESSAGE
CALL M_KOJO_顶空灿梦_MESSAGE_COUNTER_K34_1_1
RETURN RESULT
@M_KOJO_顶空灿梦_MESSAGE_COUNTER_K34_1_1
IF TALENT:7
    SELECTCASE RAND:3
        CASE 2
            PRINTFORMW 「%CALLNAME:MASTER%，靠近一点吧？来嘛――」
        CASE 1
            PRINTFORMW 「嗯？靠的很近…？诶……我倒是觉得不如再近一些呢」
            PRINTFORMDW 天子这么说着进一步拉近了距离
        CASE 0
            PRINTFORMW 「呐呐～♪稍微靠近一点吧」
    ENDSELECT
ELSEIF TALENT:3
    SELECTCASE RAND:3
        CASE 2
            PRINTFORMW 「嗯？感觉靠的太近了…？什么嘛，这样也没有关系吧？」
        CASE 1
            PRINTFORMW 「～～♪」
            PRINTFORMDW 天子若无其事的拉近了一些距离
        CASE 0
            PRINTFORMW 「『为什么要靠那么近』…？奇怪的问题，只是因为我想这么做而已哦？」
    ENDSELECT
ELSE
    SELECTCASE RAND:2
        CASE 1
            PRINTFORMW 「……」
            PRINTFORMDW 不知不觉间天子似乎靠近了一些……但是天子看起来没有并没有怎么在意的样子
        CASE 0
            PRINTFORMW 「嗯？『是不是靠太近了』…？嘛，大概是你的错觉吧」
    ENDSELECT
ENDIF 
RETURN 1

