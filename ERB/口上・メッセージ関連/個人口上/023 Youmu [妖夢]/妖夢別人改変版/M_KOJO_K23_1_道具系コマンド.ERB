;※※※※※※※※※※※※※※※※※※※※※※※※※
;==================================================
;40,ローター
;==================================================
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_別人版_MESSAGE_MESSAGECHECK_COM_K23_40
RETURN 0

@M_KOJO_別人版_MESSAGE_COM_K23_40
CALL M_KOJO_別人版_MESSAGE_COM_K23_40_1
RETURN RESULT

@M_KOJO_別人版_MESSAGE_COM_K23_40_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;時姦中
	IF FLAG:70
		PRINTFORMW
		RETURN 1
	;泥酔
	ELSEIF TCVAR:泥酔 == 1
		IF TALENT:恋慕
			PRINTFORML 「んんぅ……%CALLNAME:MASTER%さん、それは……」
			CALL HPH_PRINT,@"「すごい音ですねぇ～、何に――ぃい！？　ほおﾞぉおおHPH」","W"
		ELSE
			PRINTFORML 「ん、う……なに、この音……」
			PRINTFORMW 「……？　そんな物、何に――ぃ、いﾞぁああ！？」
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		IF CFLAG:23:2004 == 0
			IF TALENT:恋慕
				PRINTFORML 「あれ？　それって……」
				PRINTFORMDW %CALLNAME:MASTER%が取り出したローターに妖夢が不思議そうに首を傾げる
				PRINTFORML
				PRINTFORML 「生き物……ですよね？　どうしてそんなものを……？」
				PRINTFORMDW どうやら妖夢はそこかしこで見かけるローターを本当に生物であると誤解しているようだ
				PRINTFORMDW %CALLNAME:MASTER%は彼女にこの道具の正体と用途をきちんと説明した……
				PRINTFORML
				PRINTFORMW 「は？　……？？　……ええ！？　これそういう玩具だったんですか！？」
				PRINTFORML 「いやっ、だって……普通に草むらとかにいますし、何なら釣れた事だって……！」
				PRINTFORMW 「……？　…………？？？」
				PRINTFORML
				PRINTFORMDL 余程衝撃的だったのか、狼狽する妖夢は記憶と情報の整合性が取れずに打ちひしがれている
				PRINTFORMDW 立ち直るまで眺めているのも面白そうだが、%CALLNAME:MASTER%は気付けも兼ねてローターの使い方を実践する事にした
				PRINTFORML
				PRINTFORMW 「付喪神の一種……ん？　この音は……」
				CALL HPH_PRINT,@"「ひいぃっ！？　ぁ、なっ、そ、そんなに震えている物を、押し付けるっ、のはぁああHPH」","W"
			ELSE
				PRINTFORML 「……それは……」
				PRINTFORMDW %CALLNAME:MASTER%が取り出したローターに妖夢が訝しげに目を細める
				PRINTFORML
				PRINTFORML 「何故そんな生き物を……？」
				PRINTFORMDW どうやら妖夢はそこかしこで見かけるローターを本当に生物であると誤解しているようだ
				PRINTFORMDW %CALLNAME:MASTER%は彼女にこの道具の正体と用途を説明した……
				PRINTFORML
				PRINTFORMW 「は？　……？？　……ええ！？　これそういう玩具だったんですか！？」
				PRINTFORML 「いやっ、だって……普通に草むらとかにいますし、何なら釣れた事だって……！」
				PRINTFORMW 「……？　…………？？？」
				PRINTFORML
				PRINTFORMDL 余程衝撃的だったのか、狼狽する妖夢は記憶と情報の整合性が取れずに打ちひしがれている
				PRINTFORMDW 立ち直るまで眺めているのも時間の無駄なので、%CALLNAME:MASTER%は気付けも兼ねてローターの使い方を実践する事にした
				PRINTFORML
				PRINTFORMW 「そんな馬鹿な事が……ん？　この音は……」
				PRINTFORMW 「ううぁっ！？　つ、ぁ、こ、こんなに震えるなんてっ、聞いてな、いぃい！？」
			ENDIF
		ELSE
			IF TALENT:恋慕
				PRINTFORMW 「そ、それは……！」
				PRINTFORML 「……%CALLNAME:MASTER%さんのおかげでその手の玩具である事は理解できたのですが」
				PRINTFORMW 「余計にこれが幻想郷に普通に生息しているのが不可解で……あ、いえ、天然か養殖かは別に……」
				CALL HPH_PRINT,@"「えっと、では胸に――えっ！？　ぇ、わ、そ、そっちには刺激が……ぅあ、あああぁHPH」","W"
			ELSE
				PRINTFORMW 「ぅ、それは……」
				PRINTFORML 「……本来の用途を教えていただけた事は感謝しています。この場以外で恥をかかずに済んだので」
				PRINTFORMW 「しかし……付喪でもない道具が山河を跋扈しているなんて、やはり異常としか」
				PRINTFORMW 「新たな異変の予兆なのでは――なっ！？　そ、そっちは違っ、うっ、ぅああぁ！」
			ENDIF
		ENDIF
		CFLAG:23:2004 = 1
		RETURN 1
	ENDIF

	;VA挿入
	IF TEQUIP:50 == PLAYER || TEQUIP:51 == PLAYER
		;射精した
		IF NOWEX:PLAYER:11
			;C感覚5以上、且つV挿入ならV感覚5以上、A挿入ならA感覚5以上
			IF ABL:Ｃ感覚 > 4 && ((TEQUIP:50 == PLAYER && ABL:Ｖ感覚 > 4) || (TEQUIP:51 == PLAYER && ABL:Ａ感覚 > 4))
				IF TALENT:恋慕
					SELECTCASE RAND:3
						CASE 0
							CALL HPH_PRINT,@"「えへ、えへへぇ……HPH 一緒にかき回されると、ぃ、んおっ……ぁ、頭のほうま、でぇえﾞえHPH」","L"
						CASE 1
							CALL HPH_PRINT,@"「ひぎっ、あぁあ、ぅあﾞああHPH わ、わらひっ、おかしく……ぅんう、うﾞううぅHPH」","L"
						CASE 2
							CALL HPH_PRINT,@"「んお、おおﾞぉ、ど、どっちかにしてぇHPH いぎ、ふあ、あぁっ……ああﾞあぁぁHPH」","L"
					ENDSELECT
					PRINTFORMDL 開発された肉穴がローターに苛まれる陰核に同調し、媚肉を震わせ子種を切望している
					PRINTFORMDW 存分に悦楽を享受し乱れる妖夢の様に劣情を煽られ、%CALLNAME:MASTER%は絶頂の瞬間ローターと指で挟んだクリトリスを抓り上げた
				ELSE
					PRINTDATAL
						DATAFORM 「ひっ、ぃ、やあぁあ……っ……も、もうっ、やめてぇえﾞええっ！」
						DATAFORM 「っ、んんぐ……ど、どうして、自分じゃ……うっ、ぁあ、あﾞああぁっ！」
					ENDDATA
					PRINTFORMDL 既に叩き付けられる悦楽へ抗う事を止めた肉穴と陰核に本人の意思が介在する余地は無い
					PRINTFORMDW 苦しそうな息遣いの中に潜む色情を確かに感じた%CALLNAME:MASTER%は、絶頂の瞬間クリトリスを潰さんばかりにローターを押し付けた
				ENDIF
			ELSE
				IF TALENT:恋慕
					SELECTCASE RAND:2
						CASE 0
							CALL HPH_PRINT,@"「んっ、あぅ、こ、これが両方だと、なかなか……ううぅ……HPH」","L"
						CASE 1
							CALL HPH_PRINT,@"「ぁ、%CALLNAME:MASTER%さんっ、道具の方は一旦……ぅあっ、そんな所は……！HPH」","L"
					ENDSELECT
					PRINTFORMDL 徐々に激しくなる腰使いと無機質な振動を同時に受け止めるには、まだ些か余裕が足りないらしい
					PRINTFORMDW %CALLNAME:MASTER%は陰核にローターを当てる角度を変えつつ、射精を促そうとする媚肉の奉仕に身を任せた
				ELSE
					PRINTDATAL
						DATAFORM 「ぐっ、うっ、ぅ……いい、加減にぃ……！」
						DATAFORM 「つぅ、いっ……や、めっ……このぉ……ッ」
					ENDDATA
					PRINTFORMDL 同時に責められている状況において、妖夢にはローターからの刺激は未だ過剰なきらいがある
					PRINTFORMDW %CALLNAME:MASTER%は渋々ローターを押し付ける力を緩め、漸く程よくなった肉穴の締め付けで吐精した
				ENDIF
			ENDIF
		ELSE
			IF ABL:Ｃ感覚 > 4 && ((TEQUIP:50 == PLAYER && ABL:Ｖ感覚 > 4) || (TEQUIP:51 == PLAYER && ABL:Ａ感覚 > 4))
				IF TALENT:恋慕
					SELECTCASE RAND:3
						CASE 0
							CALL HPH_PRINT,@"「うっ、んぅう……ひいぃHPH き、気持ちよくなって、いただけていますかっ、んうぅHPH」","L"
							PRINTFORMDL ローターの振動が媚肉を通じてナカに収まった怒張まで伝わってくる
							PRINTFORMDW 陰核への絶え間ない責めでビクビクと震える\@ TEQUIP:50 == PLAYER ? 肉襞 # 腸壁 \@が的確な奉仕を続けている
						CASE 1
							CALL HPH_PRINT,@"「ひんっ、ふぅ、おﾞぉおHPH そっ、そんなに、すると……くぅ、いいぃHPH」","L"
							PRINTFORMDW 勃起した陰核がローターに苛まれ、肉棒を包む媚肉がビクビクと小刻みに震えている
						CASE 2
							CALL HPH_PRINT,@"「はぁ、はあ……はぁあHPH 挿れていただきながらというのは、一人ではできませんので……HPH」","L"
							CALL HPH_PRINT,@"「ああぁ、いっ、ぎぃいHPH こ、この感じがっ……かはっ、ああﾞああぁHPH」","W"
					ENDSELECT
				ELSE
					PRINTDATAL
						DATAFORM 「ぐ、あっ、そっ……そんな、物をぉ……！」
						DATAFORM 「っ、んん……は、はやく、放してぇ……ッ」
					ENDDATA
					PRINTFORMDL 妖夢がどれほど感じているかは\@ TEQUIP:50 == PLAYER ? 絡みつく肉襞 # 蠕動する腸壁 \@が代弁してくれている
					PRINTFORMDW %CALLNAME:MASTER%は陰核への刺激で小刻みに痙攣する妖夢の肉穴をじっくりと楽しんだ
				ENDIF
			ELSE
				IF TALENT:恋慕
					SELECTCASE RAND:2
						CASE 0
							CALL HPH_PRINT,@"「んぅ、うっ……HPH こ、これは……どちらかという訳には……？」","L"
						CASE 1
							CALL HPH_PRINT,@"「っ、うぁ……っHPH し、振動が……ちょっと強すぎるのでは……」","L"
					ENDSELECT
					PRINTFORMDL どちらもという状況に慣れないからか、妖夢の様子からは戸惑いが窺える
					PRINTFORMDW %CALLNAME:MASTER%は動きを緩め、周章する肢体に少しずつ快感を刷り込んでいく事にした
				ELSE
					PRINTDATAL
						DATAFORM 「ぐぁ、あっ……はな、せ……！」
						DATAFORM （うっ、うぅ……ぬ、抜けださないと……ッ）
					ENDDATA
					PRINTFORMDW ローターからの振動で身を捩る妖夢の動きが怒張に思わぬ快感を伝えてくる……
				ENDIF
			ENDIF
		ENDIF

	;基本セット
	;恋慕
	ELSEIF TALENT:恋慕
		IF ABL:Ｃ感覚 > 4
			SELECTCASE RAND:3
				CASE 0
					CALL HPH_PRINT,@"「んんぅう、ああっ、ひぃいんHPH こ、これっ……自分の指よりぃ、いいですぅうﾞううHPH」","L"
					PRINTFORMDW ローターが発する容赦無い顫動の全てが快感となって、妖夢の陰核を機械的に責め立てる
				CASE 1
					CALL HPH_PRINT,@"「あはっ、すごっ、いいぃHPH ぐりぐりされるとぉ、気持ちよくて……イっ、ぁああﾞあHPH」","L"
					PRINTFORMDL 強く陰核に押し付けられたローターで溢れた愛液が涎の如く秘唇を滴る
					PRINTFORMDW 卑しい粘液が樹脂製の無機質な光沢をも装飾し、酷く官能的な様相を作り出している……
				CASE 2
					PRINTFORML 「え……えぇ！？　そ、それが天然か養殖か、ですか……？」
					CALL HPH_PRINT,@"「……見た目が違ったり――うああぁ！？HPH こっ、これじゃ、集中なんて、む、りぃぃいﾞいHPH」","L"
					PRINTFORMDW 実のところ%CALLNAME:MASTER%にもその違いは分からないのだが、絶え間無い責めに晒されつつも妖夢は律儀に考えているようだ
			ENDSELECT
		ELSEIF ABL:Ｃ感覚 > 2
			SELECTCASE RAND:2
				CASE 0
					CALL HPH_PRINT,@"「んんぅ、ぅあ、これは……お、思ったより、いぃっ、かもぉ……HPH」","L"
				CASE 1
					CALL HPH_PRINT,@"「ちょっと激しいとは思いますけど……っ、あ、自分では、こうは……いきませんからぁあHPH」","L"
			ENDSELECT
			PRINTFORMDW 妖夢は己の指では成し得ない規則的な振動に快感を見出し始めたようだ
		ELSE
			PRINTDATAL
				DATAFORM 「うぅ、くっ……も、もう少し弱くは、できませんかね……？」
				DATAFORM 「ひっ、な……ちょっ、ちょっと強すぎるのでは……っ」
			ENDDATA
			PRINTFORMDW 未だ性感に慣れない陰核にとって、ローターの無機質な振動は些か刺激が強いようだ……
		ENDIF
	;それ以外
	ELSE
		IF ABL:Ｃ感覚 > 4
			PRINTDATAW
				DATAFORM 「っ、んん、いっ……そ、それ、止めてぇ……！」
				DATAFORM 「く、あっ……これ以上、強くはっ、ぃ、ん、んんんぅ……！」
				DATAFORM 「いっ、や……うぁ……感じたく、な……ぃい……！」
			ENDDATA
		ELSE
			PRINTDATAW
				DATAFORM 「そ、そんな物を使うなら、せめて弱く……っ、ぁ、ぐぅう……！」
				DATAFORM 「ひっ……そんな所に押し付け、ゃ、なっ、うあ……！」
			ENDDATA
		ENDIF
	ENDIF
	CFLAG:23:2004 = 1
ENDIF
RETURN 1

