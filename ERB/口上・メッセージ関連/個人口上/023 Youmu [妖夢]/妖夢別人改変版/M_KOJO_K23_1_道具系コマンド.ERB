@M_KOJO_別人版_MESSAGE_COM_K23_49_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;時姦中
	IF FLAG:70
		PRINTFORMW
		RETURN 1
	;泥酔
	ELSEIF TCVAR:泥酔 == 1
		IF TALENT:恋慕
			PRINTFORML 「んんぅ……%CALLNAME:MASTER%さん、それは……」
			CALL HPH_PRINT,@"「すごい音ですねぇ～、何に――ぃあ！？　ち、ちくびがああぁHPH」","W"
		ELSE
			PRINTFORML 「ん、う……なに、この音……」
			PRINTFORMW 「……？　そんな物、何に――ぃ、なっ、うあぁ！？」
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		IF CFLAG:23:2004 == 0
			IF TALENT:恋慕
				PRINTFORML 「あれ？　それって……」
				PRINTFORMDW %CALLNAME:MASTER%が取り出したローターに妖夢が不思議そうに首を傾げる
				PRINTFORML
				PRINTFORML 「生き物……ですよね？　どうしてそんなものを……？」
				PRINTFORMDW どうやら妖夢はそこかしこで見かけるローターを本当に生物であると誤解しているようだ
				PRINTFORMDW %CALLNAME:MASTER%は彼女にこの道具の正体と用途をきちんと説明した……
				PRINTFORML
				PRINTFORMW 「は？　……？？　……ええ！？　これそういう玩具だったんですか！？」
				PRINTFORML 「いやっ、だって……普通に草むらとかにいますし、何なら釣れた事だって……！」
				PRINTFORMW 「……？　…………？？？」
				PRINTFORML
				PRINTFORMDL 余程衝撃的だったのか、狼狽する妖夢は記憶と情報の整合性が取れずに打ちひしがれている
				PRINTFORMDW 立ち直るまで眺めているのも面白そうだが、%CALLNAME:MASTER%は気付けも兼ねてローターの使い方を実践する事にした
				PRINTFORML
				PRINTFORMW 「付喪神の一種……ん？　この音は……」
				CALL HPH_PRINT,@"「うわあぁ！？　えっ、んぅ、そ、そうやって使うんっ、です、かぁあああHPH」","W"
			ELSE
				PRINTFORML 「……それは……」
				PRINTFORMDW %CALLNAME:MASTER%が取り出したローターに妖夢が訝しげに目を細める
				PRINTFORML
				PRINTFORML 「何故そんな生き物を……？」
				PRINTFORMDW どうやら妖夢はそこかしこで見かけるローターを本当に生物であると誤解しているようだ
				PRINTFORMDW %CALLNAME:MASTER%は彼女にこの道具の正体と用途を説明した……
				PRINTFORML
				PRINTFORMW 「は？　……？？　……ええ！？　これそういう玩具だったんですか！？」
				PRINTFORML 「いやっ、だって……普通に草むらとかにいますし、何なら釣れた事だって……！」
				PRINTFORMW 「……？　…………？？？」
				PRINTFORML
				PRINTFORMDL 余程衝撃的だったのか、狼狽する妖夢は記憶と情報の整合性が取れずに打ちひしがれている
				PRINTFORMDW 立ち直るまで眺めているのも時間の無駄なので、%CALLNAME:MASTER%は気付けも兼ねてローターの使い方を実践する事にした
				PRINTFORML
				PRINTFORMW 「そんな馬鹿な事が……ん？　この音は……」
				PRINTFORMW 「ううっ！？　っ、ゃ、じ、実例なんて、要りませんからぁ……！」
			ENDIF
		ELSE
			IF TALENT:恋慕
				PRINTFORMW 「そ、それは……！」
				PRINTFORML 「……%CALLNAME:MASTER%さんのおかげでその手の玩具である事は理解できたのですが」
				PRINTFORMW 「余計にこれが幻想郷に普通に生息しているのが不可解で……あ、いえ、天然か養殖かは別に……」
				CALL HPH_PRINT,@"「ただ使う場所が場所なので、覚悟が……えっ、そっちは胸――いっ、んああぁHPH」","W"
			ELSE
				PRINTFORMW 「ぅ、それは……」
				PRINTFORML 「……本来の用途を教えていただけた事は感謝しています。この場以外で恥をかかずに済んだので」
				PRINTFORMW 「しかし……付喪でもない道具が山河を跋扈しているなんて、やはり異常としか」
				PRINTFORMW 「……おっと、どこに使うかさえ分かっていれば――うっ！？　む、胸の方なんてっ、くうぅ……ッ」
			ENDIF
		ENDIF
		CFLAG:23:2004 = 1
		RETURN 1
	ENDIF

	;VA挿入
	IF TEQUIP:50 == PLAYER || TEQUIP:51 == PLAYER
		;射精した
		IF NOWEX:PLAYER:11
			IF TALENT:恋慕
				;B感覚5以上、且つV挿入ならV感覚5以上、A挿入ならA感覚5以上
				IF ABL:Ｂ感覚 > 4 && ((TEQUIP:50 == PLAYER && ABL:Ｖ感覚 > 4) || (TEQUIP:51 == PLAYER && ABL:Ａ感覚 > 4))
					SELECTCASE RAND:2
						CASE 0
							CALL HPH_PRINT,@"「んいぃ、ぅ、震えてるのが……深くまでっ、くぁ、ああぁあんHPH」","L"
						CASE 1
							CALL HPH_PRINT,@"「はっ、あうぅHPH ち、乳首が、しびれてぇ……ひぃいんHPH」","L"
					ENDSELECT
					PRINTFORMDL 胸の先端を弄する顫動が伝播し、絶えぬ怡悦に歓喜した媚肉がうねる
					PRINTFORMDW 暫し手元に集中していた%CALLNAME:MASTER%は、登り詰めた子種を肉壺からの奉仕に任せ深くへと放った
				ELSE
					SELECTCASE RAND:2
						CASE 0
							CALL HPH_PRINT,@"「んん、くっ……どっちも、震えてる……ぁHPH」","L"
						CASE 1
							CALL HPH_PRINT,@"「わっ、う……む、胸が、少し強いかも……っHPH」","L"
					ENDSELECT
					PRINTFORMDL 肉穴への抽挿と胸への責め、いずれもを快感として享受できるまでには開発が至れていないらしい
					PRINTFORMDW %CALLNAME:MASTER%は妖夢の乳首に当てたローターを若干離し、確かに震えている媚肉の動きに吐精を委ねた
				ENDIF
			ELSE
				PRINTDATAW
					DATAFORM 「ぐぅ、こ、こんな……辱めを受ける謂れは……ッ」
					DATAFORM 「ぎ、ぁ……うっ……？　ナカで、震えて……」
				ENDDATA
			ENDIF
		ELSE
			IF TALENT:恋慕
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「ひうっ、ああぁ！HPH は、挿入ってますから、あっ……くぅうHPH」","L"
						PRINTFORMDL 腰の動きを緩めローターの振動に愛撫を委ねる
						PRINTFORMDW 小刻みな刺激が硬く勃った乳首を責め立て、妖夢が身を捩る度に肉壺が痙攣している
					CASE 1
						CALL HPH_PRINT,@"「あっ……はぁHPH 胸の、奥のほうが……ふう、んん……HPH」","L"
						PRINTFORMDL 抽挿を止め手元のローターをなだらかな双丘へと満遍なく這わせる
						PRINTFORMDW 妖夢の零す婀娜やかな吐息に中てられ、ナカに収めた剛直が硬度を増すのを感じる……
				ENDSELECT
			ELSE
				PRINTFORML 「くっ、ぎ……こ、こんな……ぐあぁ……ッ」
				PRINTFORMDW 妖夢はローターの振動から逃れようとしているものの、串刺しにされた体勢がその行為を許さない
			ENDIF
		ENDIF

	;基本セット
	;恋慕
	ELSEIF TALENT:恋慕
		;B感覚5以上
		IF ABL:Ｂ感覚 > 4
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「あ……ろ、ローター……！」
					CALL HPH_PRINT,@"「思ったより、ええと……クるので相応の心構えが、あぅっ！？　ま、まって、まだ、んうぁHPH」","W"
				CASE 1
					CALL HPH_PRINT,@"「ひんっ、んんぅ、いいっHPH あっ、ぅ、ゆっくりにぃ……うく、ああっHPH」","L"
					PRINTFORMDL 震え続けるローターと指で自己主張する乳首を挟み、満遍なく振動が伝わるように表面を撫で擦る
					PRINTFORMDW 角度を変える度に妖夢の躰と添えられた手がびくりと跳ね、素直な反応が逐一%CALLNAME:MASTER%を楽しませる
				CASE 2
					PRINTFORML 「え……えぇ！？　そ、それが天然か養殖か、ですか……？」
					CALL HPH_PRINT,@"「……見た目が違ったり――んんぅ！？HPH ふっ、るえ方が、違ったり、はぁああHPH」","L"
					PRINTFORMDW 実のところ%CALLNAME:MASTER%にもその違いは分からないのだが、絶え間無い責めに晒されつつも妖夢は律儀に考えているようだ
			ENDSELECT
		;B感覚3以上
		ELSEIF ABL:Ｂ感覚 > 2
			SELECTCASE RAND:2
				CASE 0
					CALL HPH_PRINT,@"「ん……添えるくらいなら丁度……うぅ！？　そ、そこまでは……ぁHPH」","L"
				CASE 1
					CALL HPH_PRINT,@"「ぁ、んうっ……まだ、強いとは感じますが、意外と……はあぁHPH」","L"
			ENDSELECT
			PRINTFORMDW 順応し始めた妖夢には機械的な顫動に対して快感を得る余裕が生まれてきたようだ
		ELSE
			PRINTDATAL
				DATAFORM 「う、ぁ……ち、近付けるだけでも、かなり……」
				DATAFORM 「っ、ひ……こ、これが普通の強さなんですか……？」
			ENDDATA
			PRINTFORMDW 未だ性感に慣れない乳房にとって、ローターの無遠慮な振動は過剰ですらあるらしい……
		ENDIF
	;それ以外
	ELSE
		PRINTDATAW
			DATAFORM 「そんな物を使ってまで……っ、う……」
			DATAFORM 「なっ……何故こんな辱めを……ぐっ、ぅ、やめ……！」
		ENDDATA
	ENDIF
	CFLAG:23:2004 = 1
ENDIF
RETURN 1
