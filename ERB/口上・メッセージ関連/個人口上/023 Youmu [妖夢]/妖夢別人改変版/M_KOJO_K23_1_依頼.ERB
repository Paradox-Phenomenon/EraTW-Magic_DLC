SELECT CASE SCENE
CASE "依頼提示時"
    PRINTFORMW 「这种事本该亲自去办，可是府上的事忙得团团转……」
    RETURN 1
CASE "依頼非受託時"
    RETURN 0
CASE "依頼受託時"
    RETURN 0
CASE "依頼確認時"
    RETURN 0
CASE "依頼破棄時"
    RETURN 0
CASE "依頼実行直前"
    ;○在这个请求中，是被击败的一方的开场白
    IF CANNOT_DANMAKU() == 1
        ;在室内时（无法进行战斗）
        ;【◆开场白】
        ;【W 出去挑战吧…】
        RETURN 0
    ELSEIF CANNOT_DANMAKU() == 2
        ;正在工作中（无法进行战斗）
        ;【◆开场白】
        ;【W 正在忙碌中…】
        RETURN 0
    ELSEIF CANNOT_DANMAKU() == 3
        ;您疲劳时（无法进行战斗）
        ;【◆开场白】
        ;【W 现在有点疲劳…】
        RETURN 0
    ELSEIF CANNOT_DANMAKU() == 4
        ;主角疲劳时（无法进行战斗）
        ;【◆开场白】
        ;【W 现在挑战是不公平的…】
        RETURN 0
    ELSEIF CANNOT_DANMAKU() == 5
        ;已经进行了一次弹幕战斗今天（无法进行战斗）
        ;【◆开场白】
        ;【W 今天已经不能再挑战了…】
        RETURN 0
    ELSE
        ;【◆开场白】
        ;【W 战斗开始！！】
        ;【接下来将调用弹幕开场白】
        ;愤怒
        IF CFLAG:318 == 1 || MARK:23:反発刻印 > 1
            PRINTFORMW 「……是来惩罚我的吗？」
            PRINTFORMW 「……」
            PRINTFORMW 「要感谢委托者才行」
        ELSE
            PRINTFORMW 「啊，是要代替我受罚吗？」
            PRINTFORMW 「委托者是不是有什么紧急的事情呢……？」
            ;爱慕
            IF TALENT:恋慕
                PRINTFORMW 「总之，即使是%CALLNAME:MASTER%先生，我也不会手下留情的！」
            ELSE
                PRINTFORMW 「总之，可能是增加了锻炼的机会吧！」
            ENDIF
        ENDIF
        RETURN 1
    ENDIF
CASE "依頼実行直後"
    ;○在这个请求中，是被击败的一方的开场白
    IF CFLAG:CLIENT_ID:依頼状況 == 2
        IF CANNOT_DANMAKU() == 0
            ;失败的情况
            ;【从上面的开场白继续】
            ;【L ［她］没能成功讨伐……】
            ;【W ……这样的话，只能另行计划了】
            ;【◆开场白】
            IF CFLAG:318 == 1 || MARK:23:反発刻印 > 1
                PRINTFORMW 「虽然有点期待能稍微释怀一点……」
            ELSE
                PRINTFORMW 「请告诉委托者」
                PRINTFORMW 「下次请亲自前来吧」
            ENDIF
            RETURN 1
        ELSE
            ;不能挑战的情况
            ;【从上面的开场白继续】
            ;【◆开场白】
            RETURN 0
        ENDIF
    ELSEIF CFLAG:CLIENT_ID:依頼状況 == 3
        ;胜利的情况
        ;【从上面的开场白继续】
        ;【W ［她］被成功讨伐了！】
        ;【◆开场白】
        IF CFLAG:318 == 1 || MARK:23:反発刻印 > 1
            PRINTFORMW 「呃……我输了」
        ELSE
            PRINTFORMW 「没有送达吗……全力挑战，不会找借口的」
            PRINTFORMW 「有什么可以作为证明的东西吗……啊，不要拿出半灵来！？」
        ENDIF
        RETURN 1
    ENDIF
CASE "成功報告時"
    ;报酬：奖金（市值）

    RETURN 0
CASE "失敗報告時"

    RETURN 0
;CASE "依頼報告不要"
;＜この依頼にはありません＞
;	RETURN 0
END SELECT

