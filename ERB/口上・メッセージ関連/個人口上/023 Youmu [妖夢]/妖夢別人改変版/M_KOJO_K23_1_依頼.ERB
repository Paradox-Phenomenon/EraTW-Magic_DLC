    RETURN 0
CASE "依頼受託時"
    RETURN 0
CASE "依頼確認時"
    RETURN 0
CASE "依頼破棄時"
    RETURN 0
CASE "依頼実行直前"
    IF IS_LIBRARY(CFLAG:MASTER:現在位置) && TARGET == CLIENT_ID
        ;[调查物]和[我来告诉你]重叠的情况
        ;【◆开场白】
        ;【L 您是为了回答［她］的问题而访问［当前位置］的】
        ;【L 这里可能会找到有用的资料】
        ;【输入（调查物/我来告诉你）】
        ;【调查物＞您和［她］在［当前位置］进行了调查】
        ;【▼直接到下面的开场白】
        ;【我来告诉你＞跳到［我来告诉你］】

        RETURN 0
    ELSEIF IS_LIBRARY(CFLAG:MASTER:現在位置)
        ;当进行[调查物]时，不是委托者的开场白主体是TARGET的情况
        ;【◆开场白】
        ;【您在［当前位置］进行了调查】
        ;【▼直接到下面的开场白】

        RETURN 0
    ELSE
        ;[我来告诉你]时（委托者是TARGET）
        ;【◆开场白】
        ;【L 您回答了［她］的问题】
        ;【成功：［她］的疑问解决了！】
        ;【失败：［她］似乎无法接受……】
        ;【▼直接到下面的开场白】

        RETURN 0
    ENDIF
CASE "依頼実行直後"
    ;【▲从上面的开场白继续】
    ;【◆开场白】
    SELECTCASE CFLAG:CLIENT_ID:依頼状況
    CASE 2
        ;进行[调查物]时
        IF ROLE == "CLIENT"
            ;一起进行[调查物]时
