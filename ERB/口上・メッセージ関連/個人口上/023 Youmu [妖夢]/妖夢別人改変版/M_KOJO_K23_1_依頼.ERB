;==================================================
;依頼口上・各依頼で共通の口上
;==================================================
@M_KOJO_別人版_IRAI_K23(ROLE, SCENE, IRAI_ID)
#DIMS ROLE     ;キャラの立場、依頼者かそうでないか
#DIMS SCENE    ;セリフの表示されるタイミング
#DIM  IRAI_ID  ;依頼自体のID
#DIM  CLIENT_ID;依頼者IDだけ抜き出したもの
#DIM  CHK_ID   ;依頼IDだけ抜き出したもの
#DIMS IRAI_NAME;依頼名
CHK_ID    = IRAI_ID % 1000
CLIENT_ID = IRAI_ID_TO_CLIENT(IRAI_ID)
IRAI_NAME = STR_DATA_IRAI(IRAI_ID, "依頼名", CLIENT_ID)
RESULT = 0
IF CHK_ID > 100
	TRYCALLFORM M_KOJO_別人版_IRAI_%IRAI_NAME%_K23(ROLE, SCENE, CLIENT_ID)
ELSE
	TRYCALLFORM M_KOJO_別人版_IRAI_{CHK_ID}_K23(ROLE, SCENE, CLIENT_ID)
ENDIF
SIF RESULT
	RETURN 1
;--------------------------------------------------
;ここにあるのは各依頼で共通の口上です
;依頼ごとの口上を表示した場合は共通の口上は表示されません
;【】で囲ってあるのは口上前後の地の文や発生する処理です
;WAITをするか等の目安にしてください（L,WはそれぞれPRINTFORML,PRINTFORMWの略）
;--------------------------------------------------
SELECTCASE SCENE
CASE "依頼提示時"
;●依頼を持ちかけられる時
;【W どうやら［彼女］は［あなた］に頼み事があるようだ】
;【◆口上】
;【依頼データ表示】
;【INPUT（受託するかY/N）】
	PRINTFORMW 「请问，%CALLNAME:MASTER%，可以帮个忙吗？」
CASE "依頼非受託時"
;●内容だけ見て受託しなかった時
;【L ［あなた］は丁重にお断りした】
;【◆口上】
;【W ［彼女］は残念そうな顔をしている】
	PRINTFORMW 「这样啊……突然被请求确实让人困扰」
CASE "依頼受託時"
;●依頼を受託した時
;【W ［あなた］は［彼女］の依頼を受けた】
;【◆口上】
	PRINTFORMW 「您愿意接受吗？非常感谢！」
CASE "依頼確認時"
;●[366]で依頼内容を依頼人に確認した時
;【◆口上】
;【依頼データ表示】
;【INPUT（破棄するかY/N）】
	PRINTFORMW 「需要确认吗？不能保持模棱两可哦」
CASE "依頼破棄時"
;●受託した依頼を破棄する時
;【◆口上】
;【W 依頼を破棄しました。】
	PRINTFORMW 「您无法安排时间吗……不，请不要在意」
CASE "依頼実行直前"
;●[367]で依頼を実行する時、実行処理の前に呼び出される
;※依頼によって状況が大きく異なるので共通口上は非推奨
;【◆口上】
;【実行時の地の文・ソース等】
;【▼下の口上に続く】
	IF ROLE == "CLIENT"
	;（共通）CLIENT：依頼実行の対象と依頼主（口上主）が同一の場合（主に特訓系ですが一緒に捜索等をした場合も含まれます）

	ELSEIF ROLE == "TARGET"
	;（共通）TARGET：口上主が依頼実行の対象である場合（主に配達系ですが捜索等をした際、TARGETにしていた場合も含まれます）

	ENDIF
CASE "依頼実行直後"
;●[367]で依頼を実行する時、実行処理の後に呼び出される
;※依頼によって状況が大きく異なるので共通口上は非推奨
;【▲上の口上から続き】
;【◆口上】
;【達成時・CLIENT：▼下の口上に続く】
;【達成時・TARGET：忘れずに［依頼主］に報告しよう】
	IF ROLE == "CLIENT"
	;（共通）CLIENT：依頼実行の対象と依頼主（口上主）が同一の場合（主に特訓系ですが一緒に捜索等をした場合も含まれます）
		SELECTCASE CFLAG:CLIENT_ID:依頼状況
		CASE 2
		;実行後未解決

		CASE 3
		;実行後達成

		CASE 6
		;実行後失敗（現在「06_誰か教えて！」のみ）

		ENDSELECT
	ELSEIF ROLE == "TARGET"
	;（共通）TARGET：口上主が依頼実行の対象である場合（主に配達系ですが捜索等をした際、TARGETにしていた場合も含まれます）
		SELECTCASE CFLAG:CLIENT_ID:依頼状況
		CASE 2
		;実行後未解決

		CASE 3
		;実行後達成

		CASE 6
		;実行後失敗（現在「06_誰か教えて！」のみ）

		ENDSELECT
	ENDIF
CASE "成功報告時"
;●報告時（成功）
;【依頼実行と報告が同時の時：▲上の口上から続き】
;【◆口上】
;【ソースの入手・アイテム等の報酬獲得】
	PRINTFORML 「非常感谢！」
	PRINTFORMW 「虽然只是小小的感谢……」
CASE "失敗報告時"
;○直接失敗報告は現在「06_誰か教えて！」のみ
;●報告忘れ・期限切れになった際、遭遇時の最後に呼び出される
;（遭遇時）【挨拶等】→【機嫌の良し悪し】→【劣情察知】→【祭日イベント】→【◆ココ！】（尚、依頼失敗判定があるとデートのお誘いは発生しません）
;【◆口上】
;○機嫌の変化や追加のペナルティ等は口上側で処理してください
	PRINTFORML 「%CALLNAME:MASTER%，关于我提出的请求……」
	PRINTFORMW 「啊，忘记了吗……关于委托不应该那么随便」
CASE "依頼報告不要"
;○一般依頼では現在「02_お花に水をあげて」「09_誰かの落とし物」のみ
;●起床時、報告不要依頼を達成していた場合に呼ばれる口上
;（起床時）【起床メッセージ】→【X時間寝た等】→【◆ココ！】→【おみくじ・補充等】→【一日開始】
;○地の文はありません
;○口上主がその場にいなくても表示されます（MASTERが寝る時のイベント口上と同じタイプ）

ENDSELECT
RETURN 1

;==================================================
;依頼口上・一般依頼01：掃除を手伝って
;==================================================
@M_KOJO_別人版_IRAI_1_K23(ROLE, SCENE, CLIENT_ID)
#DIMS ROLE     ;キャラの立場、依頼者かそうでないか
#DIMS SCENE    ;セリフの表示されるタイミング
#DIM  CLIENT_ID;依頼者IDだけ抜き出したもの
;--------------------------------------------------
;RETURN 0 の部分は共通の口上が表示されます
;依頼ごとの口上を表示する部分は RETURN 0 を RETURN 1 にしてください
;--------------------------------------------------
SELECTCASE SCENE
CASE "依頼提示時"
	PRINTFORMW 「我家的房间打扫得很困难，如果能搭把手就好了……」
	RETURN 1
CASE "依頼非受託時"

	RETURN 0
CASE "依頼受託時"
	IF TALENT:恋慕
		PRINTFORMW 「太感谢了！和%CALLNAME:MASTER%一起，应该可以很快收拾好」
	ELSE
		PRINTFORMW 「本来应该一个人收拾的……真是丢脸」
	ENDIF
	RETURN 1
CASE "依頼確認時"

	RETURN 0
CASE "依頼破棄時"

	RETURN 0
CASE "依頼実行直前"
;○この依頼は依頼主がTARGETです
	IF YOGORE:(GET_CHARAHOME(TARGET)) < 1000
	;先に掃除してしまっていた場合
	;【◆口上】
	;【W ［彼女］の部屋は十分にきれいだ】
	;【▼そのまま下の口上へ】
		PRINTFORMW 「咦？已经变得干净了……」
		PRINTFORML
		RETURN 1
	ELSE
	;一緒に掃除する場合
	;【◆口上】
	;【W ［あなた］は［彼女］と協力して部屋の掃除を行なった】
	;【▼そのまま下の口上へ】
		IF TALENT:恋慕
			PRINTFORMW 「嗯……那边的事情我来处理，其他方面可以拜托你吗？」
			PRINTFORML
		ELSE
			PRINTFORMW 「我个人物品不多，请无需顾虑！」
			PRINTFORML
		ENDIF
		RETURN 1
	ENDIF
CASE "依頼実行直後"
;○この依頼は必ず実行後達成します
;【▲上の口上から続き】
;【◆口上】
;【▼そのまま下の口上へ】
	IF TALENT:恋慕
		PRINTFORML 「变得很干净了呢，非常感谢！」
		PRINTFORMW 「え゛っ……没、没有奇怪的东西哦。什么都没有」
	ELSE
		PRINTFORMW 「这样就可以了吗？非常感谢！」
	ENDIF
	RETURN 1
CASE "成功報告時"
;報酬：低級素材
;【▲上の口上から続き】
;【◆口上】
;【報酬獲得】
	PRINTFORML
	PRINTFORML 「不过话说回来，这种东西究竟是什么时候混进来的呢……？」
	PRINTFORMW 「您对此有兴趣吗？如果是的话，请毫不犹豫地拿走吧，我似乎无法利用它」
	RETURN 1
CASE "失敗報告時"

	RETURN 0
;CASE "依頼報告不要"
;＜この依頼にはありません＞
;	RETURN 0
ENDSELECT

;==================================================
;依頼口上・一般依頼02：お花に水をあげて
;==================================================
@M_KOJO_別人版_IRAI_2_K23(ROLE, SCENE, CLIENT_ID)
#DIMS ROLE     ;キャラの立場、依頼者かそうでないか
#DIMS SCENE    ;セリフの表示されるタイミング
#DIM  CLIENT_ID;依頼者IDだけ抜き出したもの
;--------------------------------------------------
;RETURN 0 の部分は共通の口上が表示されます
;依頼ごとの口上を表示する部分は RETURN 0 を RETURN 1 にしてください
;--------------------------------------------------
SELECTCASE SCENE
CASE "依頼提示時"
	PRINTFORMW 「昨天忘记给一盆植物浇水了……」
	RETURN 1
CASE "依頼非受託時"

	RETURN 0
CASE "依頼受託時"
	PRINTFORML 「非常抱歉给您添麻烦了……」
	PRINTFORMW 「我想土壤应该是干了，应该很容易分辨出是哪一盆」
	RETURN 1
CASE "依頼確認時"

	RETURN 0
CASE "依頼破棄時"

	RETURN 0
CASE "依頼実行直前"
;【◆口上】
;【W ［あなた］は［依頼主］の家の鉢植えや植木に水をあげた】
;【▼そのまま下の口上へ】
	IF ROLE == "CLIENT"
	;水やりした時、依頼主である口上主がTARGETの場合

		RETURN 0
	ELSEIF ROLE == "TARGET"
	;水やりした時、依頼主ではない口上主がTARGETの場合

		RETURN 0
	ENDIF
CASE "依頼実行直後"
;○この依頼は必ず実行後達成します
;【▲上の口上から続き】
;【◆口上】
	IF ROLE == "CLIENT"
	;水やりした時、依頼主である口上主がTARGETの場合
	;この場合はそのまま下の口上へ続きます
		SELECTCASE RAND:3
			CASE 0
				PRINTFORML 「这个盆栽本来不需要太多水，也很容易照顾的」
				PRINTFORMW 「作为观赏用植物，可以评为优等生呢」
			CASE 1
				PRINTFORML 「这个盆栽有点难搞……还好没有枯萎」
				PRINTFORMW 「精心培养的植物，无论何时都是美丽的」
			CASE 2
				PRINTFORML 「当然，每种植物对土壤湿度的要求都不同」
				PRINTFORMW 「这个盆栽……啊，不用特别关照也没关系」
		ENDSELECT
		RETURN 1
	ELSEIF ROLE == "TARGET"
	;水やりした時、依頼主ではない口上主がTARGETの場合

		RETURN 0
	ENDIF
CASE "成功報告時"
;報酬：\500

	RETURN 0
CASE "失敗報告時"

	RETURN 0
CASE "依頼報告不要"

	RETURN 0
ENDSELECT

