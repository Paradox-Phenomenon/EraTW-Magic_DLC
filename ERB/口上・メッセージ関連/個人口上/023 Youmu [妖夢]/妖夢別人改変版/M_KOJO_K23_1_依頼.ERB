;==================================================
;依頼口上・一般依頼04：料理上手になりたい
;==================================================
@M_KOJO_別人版_IRAI_4_K23(ROLE, SCENE, CLIENT_ID)
#DIMS ROLE     ;キャラの立場、依頼者かそうでないか
#DIMS SCENE    ;セリフの表示されるタイミング
#DIM  CLIENT_ID;依頼者IDだけ抜き出したもの
;--------------------------------------------------
;RETURN 0 の部分は共通の口上が表示されます
;依頼ごとの口上を表示する部分は RETURN 0 を RETURN 1 にしてください
;--------------------------------------------------
SELECTCASE SCENE
CASE "依頼提示時"
	PRINTFORML 「如果能够学到%CALLNAME:MASTER%先生的技术，我会感到非常荣幸的」
		IF TALENT:恋慕
			PRINTFORMW 「因为我想要为%CALLNAME:MASTER%先生和幽幽子做出让两位满意的料理！」
		ELSE
			PRINTFORMW 「为了让幽幽子满意，我还需努力修行！」
		ENDIF
	RETURN 1
CASE "依頼非受託時"
	PRINTFORMW 「嗯……是啊，%CALLNAME:MASTER%先生您也有自己的安排吧……」
	RETURN 1
CASE "依頼受託時"

	RETURN 0
CASE "依頼確認時"

	RETURN 0
CASE "依頼破棄時"
	PRINTFORMW 「嗯……是啊，%CALLNAME:MASTER%先生您也有自己的计划吧……」
	RETURN 1
CASE "依頼実行直前"
;○この依頼は依頼主がTARGETです
;【◆口上】
;【L ［あなた］は［彼女］と一緒に料理をした】
;【W ［料理名］を作ります】
;【▼そのまま下の口上へ】
    PRINTFORML  "那么，请您指导了"
    PRINTFORMW  "做什么料理就交给%CALLNAME:MASTER%先生决定吧"
	PRINTFORML
	RETURN 1
CASE "依頼実行直後"
;○この依頼は必ず実行後達成します
;【▲上の口上から続き】
;【◆口上】
;【▼そのまま下の口上へ】
    PRINTFORML 「这就完成了」
    PRINTFORMW 「嗯……真是精湛的手艺」
	PRINTFORML
	RETURN 1
CASE "成功報告時"
;報酬：\500
;【▲上の口上から続き】
;【◆口上】
;【報酬獲得】
;【L できた料理は二人でいっしょに頂いた】
;【食事効果（料理採点）】
	IF TALENT:恋慕
		PRINTFORML 「这道料理作为报酬……有点令人憧憬呢」
		PRINTFORMW 「啊，绝对不能在%CALLNAME:MASTER%先生面前说出这么大的话」
	ELSE
		PRINTFORML 「非常感谢！那么要表达感谢的话……」
		PRINTFORMW 「诶，就这样就好吗？有点不好意思呢……」
	ENDIF
	RETURN 1
CASE "失敗報告時"

	RETURN 0
;CASE "依頼報告不要"
;＜この依頼にはありません＞
;	RETURN 0
ENDSELECT

;==================================================
;依頼口上・一般依頼05：特訓につきあって
;==================================================
@M_KOJO_別人版_IRAI_5_K23(ROLE, SCENE, CLIENT_ID)
#DIMS ROLE     ;キャラの立場、依頼者かそうでないか
#DIMS SCENE    ;セリフの表示されるタイミング
#DIM  CLIENT_ID;依頼者IDだけ抜き出したもの
;--------------------------------------------------
;RETURN 0 の部分は共通の口上が表示されます
;依頼ごとの口上を表示する部分は RETURN 0 を RETURN 1 にしてください
;--------------------------------------------------
SELECTCASE SCENE
CASE "依頼提示時"
    PRINTFORML  "普段感觉需要进行更接近实战的训练"
    PRINTFORMW  "非常希望能够与%CALLNAME:MASTER%先生搭档！"
    RETURN 1
CASE "依頼非受託時"
    IF GROUPMATCH(TIME:5,5,9,13)
        PRINTFORML  "嗯……确实是这种天气啊"
        PRINTFORMW  "那就老老实实改天吧……"
    ELSE
        PRINTFORMW  "嗯……是的，%CALLNAME:MASTER%先生您也有自己的计划吧……"
    ENDIF
    RETURN 1
CASE "依頼受託時"
    PRINTFORMW  "非常感谢！准备好了就请告诉我"
    RETURN 1
CASE "依頼確認時"

    RETURN 0
CASE "依頼破棄時"
    PRINTFORMW  "嗯……是的，%CALLNAME:MASTER%先生您也有自己的安排吧……"
    RETURN 1
CASE "依頼実行直前"
;○这个请求的委托人是TARGET
;【◆开场白】
;【W ［你］和［她］进行弹幕对决的特训】
;【▼继续下面的开场白】
	IF OUTROOF(CFLAG:現在位置) && DAY:2 == 4
        PRINTFORML  "什么是这堆雪球啊……雪仗吗？"
        PRINTFORML  "我要做的可是——咳！？"
        PRINTFORMW  "唔，做到了呢……你也是这样的话我可也没办法了！"
    ELSE
        PRINTFORMW  "我来了%CALLNAME:MASTER%先生，毫不手软哦！"
    ENDIF
    RETURN 1
CASE "依頼実行直後"
;○这个请求一定在执行后完成
;【▲上面的开场白继续】
;【◆开场白】
;【▼继续下面的开场白】
	IF OUTROOF(CFLAG:現在位置) && DAY:2 == 4
        PRINTFORML
        PRINTFORML  "哈啊，哈啊……意外地沉浸其中了……"
        PRINTFORMW  "……嘛，确实有些地方和弹幕对决有相似之处"
    ELSE
        PRINTFORML
        PRINTFORML  "唔，确实有点强啊……"
        PRINTFORMW  "但正因如此，得到的训练效果也很多，非常感谢"
    ENDIF
    RETURN 1
CASE "成功報告時"
;报酬：\500
;【▲上面的开场白继续】
;【◆开场白】
;【报酬获得】
	IF OUTROOF(CFLAG:現在位置) && DAY:2 == 4
        PRINTFORML
        PRINTFORML  "虽然和预期有很大差距，但这就是谢礼"
        PRINTFORMW  "……确实是一次有收获的锻炼，谢谢"
    ELSE
        PRINTFORML
        PRINTFORML  "那么就当作谢礼了……"
        PRINTFORMW  "诶，就这样就好吗？有点不好意思呢……"
    ENDIF
    RETURN 1
CASE "失敗報告時"

    RETURN 0
;CASE "依頼報告不要"
;＜この依頼にはありません＞
;	RETURN 0
ENDSELECT

;==================================================
;依頼口上・一般依頼06：誰か教えて！
;==================================================
@M_KOJO_別人版_IRAI_6_K23(ROLE, SCENE, CLIENT_ID)
#DIMS ROLE     ;キャラの立場、依頼者かそうでないか
#DIMS SCENE    ;セリフの表示されるタイミング
#DIM  CLIENT_ID;依頼者IDだけ抜き出したもの
;--------------------------------------------------
;RETURN 0 の部分は共通の口上が表示されます
