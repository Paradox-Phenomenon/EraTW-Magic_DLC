;==================================================
;依赖口上・一般依頼04：想要学习料理
;==================================================
@M_KOJO_别人版_IRAI_4_K23(ROLE, SCENE, CLIENT_ID)
#DIMS ROLE     ;角色の立场、依赖者かそうでないか
#DIMS SCENE    ;セリフの表示されるタイミング
#DIM  CLIENT_ID;依赖者IDだけ抜き出したもの
;--------------------------------------------------
;RETURN 0 の部分は共通の口上が表示されます
;依赖ごとの口上を表示する部分は RETURN 0 を RETURN 1 にしてください
;--------------------------------------------------
SELECTCASE SCENE
CASE "依頼提示時"
	PRINTFORML 「如果能够学到%CALLNAME:MASTER%大人的技术，我会感到非常荣幸的」
	IF TALENT:恋慕
		PRINTFORMW 「因为我想要为%CALLNAME:MASTER%大人和幽幽子做出让两位满意的料理！」
	ELSE
		PRINTFORMW 「为了让幽幽子满意，我还需努力修行！」
	ENDIF
	RETURN 1
CASE "依頼非受託時"
	IF TALENT:恋慕
		PRINTFORMW 「诶……难、难道您已经有安排了？那我改天再来……」
	ELSE
		PRINTFORMW 「嗯……是啊，%CALLNAME:MASTER%大人您也有自己的安排吧……」
	ENDIF
	RETURN 1
CASE "依頼受託時"
	
	RETURN 0
CASE "依頼確認時"
	
	RETURN 0
CASE "依頼破棄時"
	IF TALENT:恋慕
		PRINTFORMW 「诶……难、难道打扰到您了？那我改天再来……」
	ELSE
		PRINTFORMW 「嗯……是啊，%CALLNAME:MASTER%大人您也有自己的计划吧……」
	ENDIF
	RETURN 1
CASE "依頼実行直前"
;○この依赖は依赖主がTARGETです
;【◆口上】
;【L ［你］は［彼女］と一绪に料理をした】
;【W ［料理名］を作ります】
;【▼そのまま下の口上へ】
	IF TALENT:恋慕
		PRINTFORML 「虽然是现成的材料，但我们已经准备好了」
		PRINTFORMW 「包括能用这些材料做出什么，都请您多多指教了」
	ELSE
		PRINTFORML 「那么，请您多多指教了」
		PRINTFORMW 「做什么也全权交给%CALLNAME:MASTER%大人您决定了」
	ENDIF
	PRINTFORML
	RETURN 1
CASE "依頼実行直後"
;○この依赖は必ず实行后达成します
;【▲上の口上から续き】
;【◆口上】
;【▼そのまま下の口上へ】
	IF TALENT:恋慕
		PRINTFORML 「真是叹为观止的手艺啊，%CALLNAME:MASTER%大人！」
		PRINTDATAW
			DATAFORM 「您教我的东西之后得记下来才行……」
			DATAFORM 「加钱再教我一道菜……不、不行吧」
		ENDDATA
	ELSE
		PRINTFORML 「这样就完成了呢」
		PRINTFORMW 「嗯嗯……真是精湛的手艺」
	ENDIF
	PRINTFORML
	RETURN 1
CASE "成功報告時"
;报酬：\500
;【▲上の口上から续き】
;【◆口上】
;【报酬获得】
;【L できた料理は二人いっしょに顶いた】
;【吃饭效果（料理打分）】
	IF TALENT:恋慕
		PRINTFORML 「这道菜就是报酬……我有点憧憬说出这句台词呢」
		PRINTFORMW 「怎么会，在%CALLNAME:MASTER%大人面前我可不敢说这种大话」
	ELSE
		PRINTFORML 「谢谢您！那么作为谢礼……」
		PRINTFORMW 「哎，只要这些就够了吗？我、我有点不好意思……」
	ENDIF
	RETURN 1
CASE "失敗報告時"
	
