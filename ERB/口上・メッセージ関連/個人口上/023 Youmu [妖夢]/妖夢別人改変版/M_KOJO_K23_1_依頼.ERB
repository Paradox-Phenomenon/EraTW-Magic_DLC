;==================================================
;一般依頼の抑制
;==================================================
;ARGは依頼番号
;この関数が1を返すと、その依頼はこのキャラクターには発生しない
;依頼の発生を抑制したい場合は、該当するARGを受け取った際に「RETURN 1」とすること
;ARG = 1,  掃除を手伝って（発生条件：TARGETがメインマップ在住）
;ARG = 2,  お花に水をあげて（発生条件：TARGETがMASTER侵入可能の自宅住まいかつ、メインマップ在住かつ、親密２以上）
;ARG = 3,  いっしょにあそぼ（発生条件：TARGETがTALENT:幼稚持ち）
;ARG = 4,  料理上手になりたい（発生条件：TARGETの料理技能がMASTER未満かつ、MASTERの料理技能が２以上かつ、親密が３以上）
;ARG = 5,  特訓につきあって（発生条件：TARGETの戦闘能力がMASTER以下かつ、親密が２以上かつ人里以外）
;ARG = 6,  誰か教えて！（発生条件：TARGETの教養がMASTER以下）
;ARG = 7,  大掃除が終わらない（発生条件：TARGETがメインマップ在住かつ、冬の15日から31日までかつ、親密が３以上）
;ARG = 8,  手紙を届けて（発生条件：TARGETの信頼度が30以上かつ、TARGETに文通相手が設定されている（FUNC_IRAI.ERBの965目以降に存在）
;ARG = 9,  誰かの落とし物（発生条件：TARGETの信頼度が30以上）
;ARG = 10, どうしてもみつからない(そのまま落ちてる)（発生条件：TARGETの信頼度が30以上）
;ARG = 11, どうしてもみつからない(誰かが拾ってる)（発生条件：TARGETの信頼度が30以上）
;ARG = 12, 懲らしめて！（発生条件：TARGETのCSVに戦闘能力が１以上ある場合）
;ARG = 13, うまい魚が食べたいなぁ（発生条件：わかさぎ姫以外）
;ARG = 14, 薪を切らしてる（未実装）
;ARG = 15, あなたに抱かれたい（発生条件：セフレor愛欲かつ溜まってる度700以上 or ヤリマン）
;ARG = 16, お悩み相談（発生条件：MASTERの話術技能が1以上）
@M_KOJO_別人版_CHECK_K23_IRAI_BLOCKED(ARGS,ARG,ARG:1)
; SIF GROUPMATCH(ARG, 2)
;     RETURN 1

;==================================================
;依頼口上・各依頼で共通の口上
;==================================================
@M_KOJO_別人版_IRAI_K23(ROLE, SCENE, IRAI_ID)
#DIMS ROLE     ;キャラの立場、依頼者かそうでないか
#DIMS SCENE    ;セリフの表示されるタイミング
#DIM  IRAI_ID  ;依頼自体のID
#DIM  CLIENT_ID;依頼者IDだけ抜き出したもの
#DIM  CHK_ID   ;依頼IDだけ抜き出したもの
#DIMS IRAI_NAME;依頼名
CHK_ID    = IRAI_ID % 1000
CLIENT_ID = IRAI_ID_TO_CLIENT(IRAI_ID)
IRAI_NAME = %STR_DATA_IRAI(IRAI_ID, "依頼名", CLIENT_ID)%
RESULT = 0
IF CHK_ID > 100
	TRYCALLFORM M_KOJO_別人版_IRAI_%IRAI_NAME%_K23(ROLE, SCENE, CLIENT_ID)
ELSE
	TRYCALLFORM M_KOJO_別人版_IRAI_{CHK_ID}_K23(ROLE, SCENE, CLIENT_ID)
ENDIF
SIF RESULT
	RETURN 1
;--------------------------------------------------
;ここにあるのは各依頼で共通の口上です
;依頼ごとの口上を表示した場合は共通の口上は表示されません
;【】で囲ってあるのは口上前後の地の文や発生する処理です
;WAITをするか等の目安にしてください（L,WはそれぞれPRINTFORML,PRINTFORMWの略）
;--------------------------------------------------
SELECTCASE SCENE
CASE "依頼提示時"
;●依頼を持ちかけられる時
;【W どうやら［彼女］は［あなた］に頼み事があるようだ】
;【◆口上】
;【依頼データ表示】
;【INPUT（受託するかY/N）】
	IF TALENT:恋慕
		PRINTFORMW 「%CALLNAME:MASTER%さん、もしお手隙でしたらご依頼したい事がありまして……」
	ELSE
		PRINTFORMW 「%CALLNAME:MASTER%さん、少しよろしいでしょうか？」
	ENDIF
CASE "依頼非受託時"
;●内容だけ見て受託しなかった時
;【L ［あなた］は丁重にお断りした】
;【◆口上】
;【W ［彼女］は残念そうな顔をしている】
	IF TALENT:恋慕
		PRINTFORMW 「いきなりではご都合も付きませんよね……申し訳ありませんでした」
	ELSE
		PRINTFORMW 「そうですか……いきなり頼まれても困りますよね」
	ENDIF
CASE "依頼受託時"
;●依頼を受託した時
;【W ［あなた］は［彼女］の依頼を受けた】
;【◆口上】
	IF TALENT:恋慕 && RAND:2 == 0
		PRINTFORMW 「ありがとうございます！　では、頼りにさせていただきますね」
	ELSE
		PRINTFORMW 「受けていただけますか？　ありがとうございます！」
	ENDIF
CASE "依頼確認時"
;●[366]で依頼内容を依頼人に確認した時
;【◆口上】
;【依頼データ表示】
;【INPUT（破棄するかY/N）】
	IF TALENT:恋慕 && RAND:2 == 0
		PRINTFORMW 「確認は大事ですよね。私も買い出しの際には気を付けています」
	ELSE
		PRINTFORMW 「確認ですか？　有耶無耶なままではいけませんからね」
	ENDIF
CASE "依頼破棄時"
;●受託した依頼を破棄する時
;【◆口上】
;【W 依頼を破棄しました。】
	IF TALENT:恋慕
		PRINTFORMW 「もしやご予定に余裕が……？　でしたら遠慮なくそちらを優先されて下さい」
	ELSE
		PRINTFORMW 「ご都合が付きませんでしたか……いえ、気になさらないで下さい」
	ENDIF
CASE "依頼実行直前"
;●[367]で依頼を実行する時、実行処理の前に呼び出される
;※依頼によって状況が大きく異なるので共通口上は非推奨
;【◆口上】
;【実行時の地の文・ソース等】
;【▼下の口上に続く】
	IF ROLE == "CLIENT"
	;（共通）CLIENT：依頼実行の対象と依頼主（口上主）が同一の場合（主に特訓系ですが一緒に捜索等をした場合も含まれます）
		
	ELSEIF ROLE == "TARGET"
	;（共通）TARGET：口上主が依頼実行の対象である場合（主に配達系ですが捜索等をした際、TARGETにしていた場合も含まれます）
		
	ENDIF
CASE "依頼実行直後"
;●[367]で依頼を実行する時、実行処理の後に呼び出される
;※依頼によって状況が大きく異なるので共通口上は非推奨
;【▲上の口上から続き】
;【◆口上】
;【達成時・CLIENT：▼下の口上に続く】
;【達成時・TARGET：忘れずに［依頼主］に報告しよう】
	IF ROLE == "CLIENT"
	;（共通）CLIENT：依頼実行の対象と依頼主（口上主）が同一の場合（主に特訓系ですが一緒に捜索等をした場合も含まれます）
		SELECTCASE CFLAG:CLIENT_ID:依頼状況
		CASE 2
		;実行後未解決
			
		CASE 3
		;実行後達成
			
		CASE 6
		;実行後失敗（現在「06_誰か教えて！」のみ）
			
		ENDSELECT
	ELSEIF ROLE == "TARGET"
	;（共通）TARGET：口上主が依頼実行の対象である場合（主に配達系ですが捜索等をした際、TARGETにしていた場合も含まれます）
		SELECTCASE CFLAG:CLIENT_ID:依頼状況
		CASE 2
		;実行後未解決
			
		CASE 3
		;実行後達成
			
		CASE 6
		;実行後失敗（現在「06_誰か教えて！」のみ）
			
		ENDSELECT
	ENDIF
CASE "成功報告時"
;●報告時（成功）
;【依頼実行と報告が同時の時：▲上の口上から続き】
;【◆口上】
;【ソースの入手・アイテム等の報酬獲得】
	PRINTFORML 「ありがとうございました！」
		IF TALENT:恋慕
			PRINTFORMW 「謝意とするにはささやかではありますが……お納め下さい」
		ELSE
			PRINTFORMW 「ささやかなお礼ではありますが……」
		ENDIF
CASE "失敗報告時"
;○直接失敗報告は現在「06_誰か教えて！」のみ
;●報告忘れ・期限切れになった際、遭遇時の最後に呼び出される
;（遭遇時）【挨拶等】→【機嫌の良し悪し】→【劣情察知】→【祭日イベント】→【◆ココ！】（尚、依頼失敗判定があるとデートのお誘いは発生しません）
;【◆口上】
;○機嫌の変化や追加のペナルティ等は口上側で処理してください
	PRINTFORML 「%CALLNAME:MASTER%さん、ご依頼した件なんですけど……」
		IF TALENT:恋慕
			PRINTFORMW 「ぇ……そ、そうでしたか。次はその旨をご一報いただければと……」
		ELSE
			PRINTFORMW 「え、忘れてたって……そこはいい加減にするべきじゃないと思います」
		ENDIF
CASE "依頼報告不要"
;○一般依頼では現在「02_お花に水をあげて」「09_誰かの落とし物」のみ
;●起床時、報告不要依頼を達成していた場合に呼ばれる口上
;（起床時）【起床メッセージ】→【X時間寝た等】→【◆ココ！】→【おみくじ・補充等】→【一日開始】
;○地の文はありません
;○口上主がその場にいなくても表示されます（MASTERが寝る時のイベント口上と同じタイプ）
	
ENDSELECT
RETURN 1

;==================================================
;依頼口上・一般依頼01：掃除を手伝って
;==================================================
@M_KOJO_別人版_IRAI_1_K23(ROLE, SCENE, CLIENT_ID)
#DIMS ROLE     ;キャラの立場、依頼者かそうでないか
#DIMS SCENE    ;セリフの表示されるタイミング
#DIM  CLIENT_ID;依頼者IDだけ抜き出したもの
;--------------------------------------------------
;RETURN 0 の部分は共通の口上が表示されます
;依頼ごとの口上を表示する部分は RETURN 0 を RETURN 1 にしてください
;--------------------------------------------------
SELECTCASE SCENE
CASE "依頼提示時"
	IF TALENT:恋慕
		PRINTFORMW 「恥ずかしながら一人ではかなり時間がかかりそうでして、お力添えいただければと……」
	ELSE
		PRINTFORMW 「自室の掃除に手こずっていまして、手をお借りできればと……」
	ENDIF
	RETURN 1
CASE "依頼非受託時"
	
	RETURN 0
CASE "依頼受託時"
	IF TALENT:恋慕
		PRINTFORMW 「ありがとうございます！　%CALLNAME:MASTER%さんと二人でならきっとすぐに片付けられますね」
	ELSE
		PRINTFORMW 「本来は一人で片付けるべきなんでしょうが……面目ありません」
	ENDIF
	RETURN 1
CASE "依頼確認時"
	
	RETURN 0
CASE "依頼破棄時"
	
	RETURN 0
CASE "依頼実行直前"
;○この依頼は依頼主がTARGETです
	IF YOGORE:(GET_CHARAHOME(TARGET)) < 1000
	;先に掃除してしまっていた場合
	;【◆口上】
	;【W ［彼女］の部屋は十分にきれいだ】
	;【▼そのまま下の口上へ】
		PRINTFORMW 「あれ？　綺麗になってる……」
		PRINTFORML
		RETURN 1
	ELSE
	;一緒に掃除する場合
	;【◆口上】
	;【W ［あなた］は［彼女］と協力して部屋の掃除を行なった】
	;【▼そのまま下の口上へ】
		IF TALENT:恋慕
			PRINTFORMW 「ええと……あの辺りは私がやりますので、そこ以外を中心にお願いできますか？」
			PRINTFORML
		ELSE
			PRINTFORMW 「私物は少ない方ですので、遠慮なくお願いします！」
			PRINTFORML
		ENDIF
		RETURN 1
	ENDIF
CASE "依頼実行直後"
;○この依頼は必ず実行後達成します
;【▲上の口上から続き】
;【◆口上】
;【▼そのまま下の口上へ】
	IF TALENT:恋慕
		PRINTFORML 「綺麗になりましたね、ありがとうございました！」
		PRINTFORMW 「えﾞっ……べ、別に妙な物はありませんよ。何もありませんとも」
	ELSE
		PRINTFORMW 「こんなところでしょうか？　ありがとうございました」
	ENDIF
	RETURN 1
CASE "成功報告時"
;報酬：低級素材
;【▲上の口上から続き】
;【◆口上】
;【報酬獲得】
	PRINTFORML
	PRINTFORML 「それにしても、こんな物一体いつ紛れ込んだのでしょう……？」
	PRINTFORMW 「関心がおありですか？　でしたら気兼ねなくお持ち下さい、私では活かせそうもありませんので」
	RETURN 1
CASE "失敗報告時"
	
	RETURN 0
;CASE "依頼報告不要"
;＜この依頼にはありません＞
;	RETURN 0
ENDSELECT

;==================================================
;依頼口上・一般依頼02：お花に水をあげて
;==================================================
@M_KOJO_別人版_IRAI_2_K23(ROLE, SCENE, CLIENT_ID)
#DIMS ROLE     ;キャラの立場、依頼者かそうでないか
#DIMS SCENE    ;セリフの表示されるタイミング
#DIM  CLIENT_ID;依頼者IDだけ抜き出したもの
;--------------------------------------------------
;RETURN 0 の部分は共通の口上が表示されます
;依頼ごとの口上を表示する部分は RETURN 0 を RETURN 1 にしてください
;--------------------------------------------------
SELECTCASE SCENE
CASE "依頼提示時"
	PRINTFORMW 「昨日水やりを忘れてしまった鉢がありまして……」
	RETURN 1
CASE "依頼非受託時"
	
	RETURN 0
CASE "依頼受託時"
	PRINTFORML 「こんな些事を申し訳ありません……」
		IF TALENT:恋慕
			PRINTFORML 「恐らく土が乾いているので、どの鉢かはすぐに分かると思います」
			PRINTFORMW 「不安でしたら私が改めて見ますので、必要な時は声をおかけ下さい」
		ELSE
			PRINTFORMW 「土が乾いていると思いますので、どの鉢かはすぐ分かるかと」
		ENDIF
	RETURN 1
CASE "依頼確認時"
	
	RETURN 0
CASE "依頼破棄時"
	
	RETURN 0
CASE "依頼実行直前"
;【◆口上】
;【W ［あなた］は［依頼主］の家の鉢植えや植木に水をあげた】
;【▼そのまま下の口上へ】
	IF ROLE == "CLIENT"
	;水やりした時、依頼主である口上主がTARGETの場合
		
		RETURN 0
	ELSEIF ROLE == "TARGET"
	;水やりした時、依頼主ではない口上主がTARGETの場合
		
		RETURN 0
	ENDIF
CASE "依頼実行直後"
;○この依頼は必ず実行後達成します
;【▲上の口上から続き】
;【◆口上】
	IF ROLE == "CLIENT"
	;水やりした時、依頼主である口上主がTARGETの場合
	;この場合はそのまま下の口上へ続きます
		SELECTCASE RAND:(TALENT:恋慕 ? 5 # 3)
			CASE 0
				PRINTFORML 「この鉢は本来そこまで水も要らず、世話も簡単なんですよ」
				PRINTFORMW 「観賞用としては優等生と評せるかもしれませんね」
			CASE 1
				PRINTFORML 「これは中々気難しい鉢で……枯れてなくて良かった」
				PRINTFORMW 「手塩にかけて育てた草木は、いつ見ても美しいものです」
			CASE 2
				PRINTFORML 「当然ながら、植物毎に適した土の湿り気は様々です」
				PRINTFORMW 「この鉢は……あ、これは大味でも大丈夫ですね」
			CASE 3
				PRINTFORML 「水が要るのは……この鉢とその鉢とあの鉢と――」
				PRINTFORMW 「こ、こっちの鉢もです。我ながら疎かにし過ぎですね……」
			CASE 4
				PRINTFORML 「うんうん……お上手ですよ、%CALLNAME:MASTER%さん」
				PRINTFORMW 「案外気を遣う作業ですからね、やりすぎると根腐れの原因にもなってしまいますので」
		ENDSELECT
		RETURN 1
	ELSEIF ROLE == "TARGET"
	;水やりした時、依頼主ではない口上主がTARGETの場合
		PRINTFORML 「おや、%CALLNAME:MASTER%さんが水やりを？」
			IF MAIN_MAP == 6 && CFLAG:MASTER:現在位置 == 623
				PRINTFORMW 「……成程、幽々子様から。仕事を代わっていただいてしまいましたね、ありがとうございます」
			ELSE
				PRINTFORMW 「……成程、頼まれていたのですね。お疲れ様です」
					SELECTCASE RAND:5
						CASE 0, 1
							PRINTFORMW 「それにしてもこの鉢をよく手入れされていますね、大切に育てられているみたいです」
						CASE 2, 3
							PRINTFORMW 「それにしてもこの鉢は……部屋主はなかなか珍しい物を育てているようです」
						CASE 4
							PRINTFORMW 「しかし、これは一体……？　こ、こんな植物は私も見た事が……」
					ENDSELECT
			ENDIF
		RETURN 1
	ENDIF
CASE "成功報告時"
;報酬：\500
	
	RETURN 0
CASE "失敗報告時"
	
	RETURN 0
CASE "依頼報告不要"
	
	RETURN 0
ENDSELECT

