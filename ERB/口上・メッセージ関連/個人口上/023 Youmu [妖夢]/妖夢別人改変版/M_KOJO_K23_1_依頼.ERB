@M_KOJO_别人版_CHECK_K23_IRAI_BLOCKED(ARGS,ARG,ARG:1)
; SIF GROUPMATCH(ARG, 2)
;     RETURN 1
;==================================================
;依赖口上・各依赖で共通の口上
;==================================================
@M_KOJO_别人版_IRAI_K23(ROLE, SCENE, IRAI_ID)
#DIMS ROLE     ;角色の立场、依赖者かそうでないか
#DIMS SCENE    ;セリフの表示されるタイミング
#DIM  IRAI_ID  ;依赖自体のID
#DIM  CLIENT_ID;依赖者IDだけ抜き出したもの
#DIM  CHK_ID   ;依赖IDだけ抜き出したもの
#DIMS IRAI_NAME;依頼名
CHK_ID    = IRAI_ID % 1000
CLIENT_ID = IRAI_ID_TO_CLIENT(IRAI_ID)
IRAI_NAME = %STR_DATA_IRAI(IRAI_ID, "依頼名", CLIENT_ID)%
RESULT = 0
IF CHK_ID > 100
	TRYCALLFORM M_KOJO_别人版_IRAI_%IRAI_NAME%_K23(ROLE, SCENE, CLIENT_ID)
ELSE
	TRYCALLFORM M_KOJO_别人版_IRAI_{CHK_ID}_K23(ROLE, SCENE, CLIENT_ID)
ENDIF
SIF RESULT
	RETURN 1
;--------------------------------------------------
;ここにあるのは各依赖で共通の口上です
;依赖ごとの口上を表示した场合は共通の口上は表示されません
;【】で囲ってあるのは口上前后の地の文や发生する处理です
;WAITをするか等の目安にしてください（L,WはそれぞれPRINTFORML,PRINTFORMWの略）
;--------------------------------------------------
SELECTCASE SCENE
CASE "依頼提示時"
;●依赖を持ちかけられる时
;【W どうやら［彼女］は［你］に赖み事があるようだ】
;【◆口上】
;【依赖データ表示】
;【INPUT（受托するかY/N）】
	IF TALENT:恋慕
		PRINTFORMW 「%CALLNAME:MASTER%大人，如果您有空的话，有件事想拜托您……」
	ELSE
		PRINTFORMW 「%CALLNAME:MASTER%大人，可以稍微打扰一下吗？」
	ENDIF
CASE "依頼非受託時"
;●内容だけ见て受托しなかった时
;【L ［你］は丁重にお断りした】
;【◆口上】
;【W ［彼女］は残念そうな颜をしている】
	IF TALENT:恋慕
		PRINTFORMW 「突然这样说您可能也安排不开……真是抱歉」
	ELSE
		PRINTFORMW 「这样啊……突然被请求确实让人困扰」
	ENDIF
CASE "依頼受託時"
;●依赖を受托した时
;【W ［你］は［彼女］の依赖を受けた】
;【◆口上】
	IF TALENT:恋慕 && RAND:2 == 0
		PRINTFORMW 「谢谢您！那么就拜托您了」
	ELSE
		PRINTFORMW 「您愿意接受吗？非常感谢！」
	ENDIF
CASE "依頼確認時"
;●[366]で依赖内容を依赖人に确认した时
;【◆口上】
;【依赖データ表示】
;【INPUT（破弃するかY/N）】
	IF TALENT:恋慕 && RAND:2 == 0
		PRINTFORMW 「确认是很重要的呢。我采购的时候也会注意的。」
	ELSE
		PRINTFORMW 「确认吗？含糊不清可不行呢。」
	ENDIF
CASE "依頼破棄時"
;●受托した依赖を破弃する时
;【◆口上】
;【W 依赖を破弃しました。】
	IF TALENT:恋慕
		PRINTFORMW 「莫非您日程上没有空闲了……？那请您尽管优先处理那边的事情。」
	ELSE
		PRINTFORMW 「您不方便吗……不，请别在意。」
	ENDIF
CASE "依頼実行直前"
;●[367]で依赖を实行する时、实行处理の前に呼び出される
;※依赖によって状况が大きく异なるので共通口上は非推奖
;【◆口上】
;【实行时の地の文・ソース等】
;【▼下の口上に续く】
	IF ROLE == "CLIENT"
	;（共通）CLIENT：依赖实行の对象と依赖主（口上主）が同一の场合（主に特训系ですが一绪に捜索等をした场合も含まれます）
		
	ELSEIF ROLE == "TARGET"
	;（共通）TARGET：口上主が依赖实行の对象である场合（主に配达系ですが捜索等をした际、TARGETにしていた场合も含まれます）
		
	ENDIF
CASE "依頼実行直後"
;●[367]で依赖を实行する时、实行处理の后に呼び出される
;※依赖によって状况が大きく异なるので共通口上は非推奖
;【▲上の口上から续き】
;【◆口上】
;【达成时・CLIENT：▼下の口上に续く】
;【达成时・TARGET：忘れずに［依赖主］に报告しよう】
	IF ROLE == "CLIENT"
	;（共通）CLIENT：依赖实行の对象と依赖主（口上主）が同一の场合（主に特训系ですが一绪に捜索等をした场合も含まれます）
		SELECTCASE CFLAG:CLIENT_ID:依頼状況
		CASE 2
		;实行后未解决
			
		CASE 3
		;实行后达成
			
		CASE 6
		;实行后失败（现在「06_谁来告诉我！」のみ）
			
		ENDSELECT
	ELSEIF ROLE == "TARGET"
	;（共通）TARGET：口上主が依赖实行の对象である场合（主に配达系ですが捜索等をした际、TARGETにしていた场合も含まれます）
		SELECTCASE CFLAG:CLIENT_ID:依頼状況
		CASE 2
		;实行后未解决
			
		CASE 3
		;实行后达成
			
		CASE 6
		;实行后失败（现在「06_谁来告诉我！」のみ）
			
		ENDSELECT
	ENDIF
CASE "成功報告時"
;●报告时（成功）
;【依赖实行と报告が同时の时：▲上の口上から续き】
;【◆口上】
;【ソースの入手・道具等の报酬获得】
	PRINTFORML 「非常感谢！」
		IF TALENT:恋慕
			PRINTFORMW 「作为谢意可能微不足道……请收下」
		ELSE
			PRINTFORMW 「虽然只是小小的感谢……」
		ENDIF
CASE "失敗報告時"
;○直接失败报告は现在「06_谁来告诉我！」のみ
;●报告忘れ・期限切れになった际、遭遇时の最后に呼び出される
;（遭遇时）【挨拶等】→【心情の良し恶し】→【色欲察觉】→【祭日イベント】→【◆ココ！】（尚、依赖失败判定があると约会のお诱いは发生しません）
;【◆口上】
;○心情の变化や追加のペナルティ等は口上侧で处理してください
	PRINTFORML 「%CALLNAME:MASTER%大人，关于我拜托您的那件事……」
		IF TALENT:恋慕
			PRINTFORMW 「诶……是、是这样啊。下次请您提前告知一声……」
		ELSE
			PRINTFORMW 「哎，您忘了……我觉得这种事不应该敷衍了事。」
		ENDIF
CASE "依頼報告不要"
;○一般依頼では现在「02_给花浇水」「09_谁的遗失物」のみ
;●起床时、报告不要依赖を达成していた场合に呼ばれる口上
;（起床时）【起床メッセージ】→【X时间寝た等】→【◆ココ！】→【神签・补充等】→【一日开始】
;○地の文はありません
;○口上主がその场にいなくても表示されます（MASTERが寝る时のイベント口上と同じタイプ）
	
ENDSELECT
RETURN 1

;==================================================
;依赖口上・一般依頼01：帮忙做扫除
;==================================================
@M_KOJO_别人版_IRAI_1_K23(ROLE, SCENE, CLIENT_ID)
#DIMS ROLE     ;角色の立场、依赖者かそうでないか
#DIMS SCENE    ;セリフの表示されるタイミング
#DIM  CLIENT_ID;依赖者IDだけ抜き出したもの
;--------------------------------------------------
;RETURN 0 の部分は共通の口上が表示されます
;依赖ごとの口上を表示する部分は RETURN 0 を RETURN 1 にしてください
;--------------------------------------------------
SELECTCASE SCENE
CASE "依頼提示時"
	IF TALENT:恋慕
		PRINTFORMW 「说来惭愧，我一个人可能要花很长时间，如果能得到您的帮助的话……」
	ELSE
		PRINTFORMW 「我家的房间打扫得很困难，如果能搭把手就好了……」
	ENDIF
	RETURN 1
CASE "依頼非受託時"
	
	RETURN 0
CASE "依頼受託時"
	IF TALENT:恋慕
		PRINTFORMW 「非常感谢！有%CALLNAME:MASTER%大人和我两个人的话，一定能很快收拾好」
	ELSE
		PRINTFORMW 「本来应该一个人收拾的……真是丢脸」
	ENDIF
	RETURN 1
CASE "依頼確認時"
	
	RETURN 0
CASE "依頼破棄時"
	
	RETURN 0
CASE "依頼実行直前"
;○この依赖は依赖主がTARGETです
	IF YOGORE:(GET_CHARAHOME(TARGET)) < 1000
	;先に扫除してしまっていた场合
	;【◆口上】
	;【W ［彼女］的房间は十分にきれいだ】
	;【▼そのまま下の口上へ】
		PRINTFORMW 「咦？已经变得干净了……」
		PRINTFORML
		RETURN 1
	ELSE
	;一绪に扫除场合
	;【◆口上】
	;【W ［你］は［彼女］と协力して房间の扫除を行なった】
	;【▼そのまま下の口上へ】
		IF TALENT:恋慕
			PRINTFORMW 「那个……我来负责那边，您可以主要负责其他地方吗？」
			PRINTFORML
		ELSE
			PRINTFORMW 「我个人物品不多，请无需顾虑！」
			PRINTFORML
		ENDIF
		RETURN 1
	ENDIF
CASE "依頼実行直後"
;○この依赖は必ず实行后达成します
;【▲上の口上から续き】
;【◆口上】
;【▼そのまま下の口上へ】
	IF TALENT:恋慕
		PRINTFORML 「变得很干净了呢，非常感谢！」
		PRINTFORMW 「唉……没、没有奇怪的东西哦。什么都没有」
	ELSE
		PRINTFORMW 「这样就可以了吗？非常感谢！」
	ENDIF
	RETURN 1
CASE "成功報告時"
;报酬：低级素材
;【▲上の口上から续き】
;【◆口上】
;【报酬获得】
	PRINTFORML
	PRINTFORML 「话说回来，这种东西到底是什么时候混进来的呢……？」
	PRINTFORMW 「您感兴趣吗？那请您尽管拿走吧，我好像也用不上。」
	RETURN 1
CASE "失敗報告時"
	
	RETURN 0
;CASE "依頼報告不要"
;＜この依赖にはありません＞
;	RETURN 0
ENDSELECT

;==================================================
;依赖口上・一般依頼02：给花浇水
;==================================================
@M_KOJO_别人版_IRAI_2_K23(ROLE, SCENE, CLIENT_ID)
#DIMS ROLE     ;角色の立场、依赖者かそうでないか
#DIMS SCENE    ;セリフの表示されるタイミング
#DIM  CLIENT_ID;依赖者IDだけ抜き出したもの
;--------------------------------------------------
;RETURN 0 の部分は共通の口上が表示されます
;依赖ごとの口上を表示する部分は RETURN 0 を RETURN 1 にしてください
;--------------------------------------------------
SELECTCASE SCENE
CASE "依頼提示時"
	PRINTFORMW 「昨天忘记给一盆植物浇水了……」
	RETURN 1
CASE "依頼非受託時"
	
	RETURN 0
CASE "依頼受託時"
	PRINTFORML 「抱歉让您做这种小事……」
		IF TALENT:恋慕
			PRINTFORML 「土应该是干的，所以哪个花盆应该很快就能分辨出来。」
			PRINTFORMW 「如果您不放心的话，我可以再检查一遍，需要的时候请叫我。」
		ELSE
			PRINTFORMW 「我想土壤是干的，所以哪个花盆应该很快就能分辨出来。」
		ENDIF
	RETURN 1
CASE "依頼確認時"
	
	RETURN 0
CASE "依頼破棄時"
	
	RETURN 0
CASE "依頼実行直前"
;【◆口上】
;【W ［你］は［依赖主］的家の鉢植えや植木に水をあげた】
;【▼そのまま下の口上へ】
	IF ROLE == "CLIENT"
	;浇水した时、依赖主である口上主がTARGETの场合
		
		RETURN 0
	ELSEIF ROLE == "TARGET"
	;浇水した时、依赖主ではない口上主がTARGETの场合
		
		RETURN 0
	ENDIF
CASE "依頼実行直後"
;○この依赖は必ず实行后达成します
;【▲上の口上から续き】
;【◆口上】
	IF ROLE == "CLIENT"
	;浇水した时、依赖主である口上主がTARGETの场合
	;この场合はそのまま下の口上へ续きます
		SELECTCASE RAND:(TALENT:恋慕 ? 5 # 3)
			CASE 0
				PRINTFORML 「这个盆栽本来就不怎么需要水，照顾起来也很简单哦」
				PRINTFORMW 「作为观赏用植物，或许可以称得上是优等生呢」
			CASE 1
				PRINTFORML 「这个盆栽相当难伺候呢……没枯萎真是太好了」
				PRINTFORMW 「亲手精心培育的花草树木，无论何时看都那么美丽」
			CASE 2
				PRINTFORML 「当然，每种植物适合的土壤湿度都各不相同」
				PRINTFORMW 「这个盆栽是……啊，这个即使粗放一点也没关系呢」
			CASE 3
				PRINTFORML 「需要浇水的是……这个盆栽和那个盆栽和那个盆栽——」
				PRINTFORMW 「这、这边的盆栽也是。连我自己都觉得太疏忽了呢……」
			CASE 4
				PRINTFORML 「嗯嗯……您做得很好哦，%CALLNAME:MASTER%大人」
				PRINTFORMW 「这意外地是个需要细心的活儿呢，浇太多水会导致烂根的」
		ENDSELECT
		RETURN 1
	ELSEIF ROLE == "TARGET"
	;水やりした時、依頼主ではない口上主がTARGETの場合
		PRINTFORML 「哎呀，是%CALLNAME:MASTER%大人在浇水吗？」
			IF MAIN_MAP == 6 && CFLAG:MASTER:現在位置 == 623
				PRINTFORMW 「……原来如此，是幽幽子大人吩咐的啊。让您代劳了，谢谢您」
			ELSE
				PRINTFORMW 「……原来如此，是受人所托啊。您辛苦了」
				SELECTCASE RAND:5
					CASE 0, 1
						PRINTFORMW 「话说回来，这个盆栽您打理得真好呢，看起来像是被精心培育的」
					CASE 2, 3
						PRINTFORMW 「话说回来这个盆栽是……房间主人似乎在养殖相当稀有的东西呢」
					CASE 4
						PRINTFORMW 「但是，这到底是什么……？这、这种植物我还是第一次见……」
				ENDSELECT
			ENDIF
		RETURN 1
	ENDIF
CASE "成功報告時"
;报酬：\500
	
	RETURN 0
CASE "失敗報告時"
	
	RETURN 0
CASE "依頼報告不要"
	
	RETURN 0
ENDSELECT

