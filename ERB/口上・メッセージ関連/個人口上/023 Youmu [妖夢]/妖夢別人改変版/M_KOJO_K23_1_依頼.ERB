        ;【▼直接到失败报告时的开场白】
        PRINTFORMW 「嗯嗯？ 那么事情的矛盾在哪里呢……？」
        PRINTFORML
        RETURN 1
	ENDSELECT
CASE "成功報告時"
    ;报酬：\500
    RETURN 0
CASE "失敗報告時"
    PRINTFORML 「非常抱歉给您添麻烦了……」
    PRINTFORMW 「我会再次自己调查一下」
    RETURN 1
