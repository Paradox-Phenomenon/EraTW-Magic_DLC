;==================================================
;依頼口上・固有依頼101：
;固有依頼の仕様はキャラによって異なりますが依頼番号は101～で共通です
;"依頼名"部分に依頼名を入れて下さい
;==================================================
@M_KOJO_別人版_IRAI_カリスマ切れ_K23(ROLE, SCENE, CLIENT_ID)
#DIMS ROLE     ;キャラの立場、依頼者かそうでないか
#DIMS SCENE    ;セリフの表示されるタイミング
#DIM  CLIENT_ID;依頼者IDだけ抜き出したもの
;--------------------------------------------------
;RETURN 0 の部分は共通の口上が表示されます
;依頼ごとの口上を表示する部分は RETURN 0 を RETURN 1 にしてください
;--------------------------------------------------
SELECTCASE SCENE
CASE "依頼提示時"
	IF TALENT:恋慕
		PRINTFORML 「ええと……大変申し上げづらいのですが、%CALLNAME:MASTER%さんしか頼れる方がいなくて……」
	ELSE
		PRINTFORML 「%CALLNAME:MASTER%さん、折り入ってお願いしたい事が……」
	ENDIF
	PRINTFORMW 「……余っていたらで構いませんので、カリスマを売っていただけませんか？」
	RETURN 1
CASE "依頼非受託時"
	IF TALENT:恋慕
		PRINTFORMW 「ぁ……も、申し訳ありません。些か甘えが過ぎました……」
	ELSE
		PRINTFORMW 「そうですよね……とても無理強いはできません……」
	ENDIF
	RETURN 1
CASE "依頼受託時"
	IF TALENT:恋慕
		PRINTFORMW 「あ……ありがとうございます！　ですが決してご無理はなさらないで下さいね？」
	ELSE
		PRINTFORMW 「ほ、本当に良いんですか？　頼んでおいてなんですが結構な量ですよ？」
	ENDIF
	RETURN 1
CASE "依頼確認時"
	
	RETURN 0
CASE "依頼破棄時"
	IF TALENT:恋慕
		PRINTFORMW 「元はと言えば私の自業自得ですので……どうかお気になさらないで下さい」
	ELSE
		PRINTFORMW 「そうですよね……そう簡単に工面できる量では……」
	ENDIF
	RETURN 1
CASE "依頼実行直前"
	;カウントが4溜まっている
	IF CFLAG:23:2002 >= 4
		PRINTFORML 「では代金はこちらに……%CALLNAME:MASTER%さん？」
		PRINTFORMDW 妖夢にカリスマを渡す直前、とある不安が脳裏を過り思わず%CALLNAME:MASTER%は手を止める
		PRINTFORMDL 今はしっかり取引をしているが繰り返す内に味を占め、
		PRINTFORMDL いずれ妖夢がカリスマをせびるワルい女になってしまうのではないか、と
		PRINTFORMDW 果たしてこのまま素直にカリスマを渡してしまっていいのだろうか……
		PRINTFORML
		;選択肢
		CALL ASK_YN("少し灸を据える","杞憂だろう")
			SELECTCASE RESULT
				;少し灸を据える
				CASE 0
					;2回目以降
					IF CFLAG:23:2005 == 1
						PRINTFORMDL 『喉元過ぎれば熱さを忘れる』という諺もある、彼女とて例外ではないかもしれない
						PRINTFORMDL ならばそろそろ一度あの羞恥を思い出しておくべき頃合いだろう
						PRINTFORMDW %CALLNAME:MASTER%は手を引っ込めて紙を取り出し、さっと筆を走らせて代わりに妖夢へそれを手渡した
						PRINTFORML
						PRINTFORML 「……ん？　これは…………うっ！？　こ、この口に出すのも憚られる恥ずかしい文面はまさか……！」
						PRINTFORMW 「ま、またこんな台詞を？　そんなぁ……」
						PRINTFORML （もうやらないって言ったのに！　本当にイジワルな人……！）
						PRINTFORMW （……ただ何度もお世話になっているのは事実だし、既にカリスマは用意してもらえてるみたいだし……）
						PRINTFORML
						PRINTFORMDW 僅かな逡巡の後、紙面から顔を上げた妖夢の眼からは並ならぬ決意とある種の諦念が見て取れる
						PRINTFORML
						PRINTFORML 「……分かりました。他ならぬ%CALLNAME:MASTER%さんが仰るのでしたら、私も覚悟を決めましょう……！」
					;初回
					ELSE
						PRINTFORMDL 真面目であると同時に愚直なきらいもある彼女は間違った方向に突き進んで行きかねない
						PRINTFORMDL ここは多少恥ずかしい目にあって、これが本来リスクを伴う行為である事を思い出しておくべきだろう
						PRINTFORMDW %CALLNAME:MASTER%は手を引っ込めて紙を取り出し、さっと筆を走らせて代わりに妖夢へそれを手渡した
						PRINTFORML
						PRINTFORML 「へ……？　なんでしょう、この恥ずかしい文面は……」
						PRINTFORMW 「…………うぇっ！？　こ、この台詞を、私が……？」
						PRINTFORML （は……えっ！？　これを読み上げなくちゃいけないの……！？　それは、流石に……）
						PRINTFORMW （……けど、既にカリスマを用意していただいている手前、ここで断るのは途方もない非礼……）
						PRINTFORML
						PRINTFORMDW 僅かな逡巡の後、紙面から顔を上げた妖夢の眼からは並々ならぬ決意が滲み出している
						PRINTFORML
						PRINTFORML 「……わ、分かりました。普段良くしていただいているのですから、私も相応の覚悟を見せましょう！」
					ENDIF
					
					PRINTFORMDW %CALLNAME:MASTER%は折角なのでその気になった妖夢に幾つか演技指導をしてみる事にした……
					PRINTFORMW
						SELECTCASE RAND:4
							CASE 0
								PRINTFORMW 「あまりにも棒過ぎる？　こんな台詞に感情移入するなんて無理ですよぉ……」
							CASE 1
								PRINTFORMW 「もっと甘ったるい声で？　ど、どうすれば……あっ、ちょうど飴なら持ってますよ！」
							CASE 2
								PRINTFORMW 「もっと身振り手振りを？　あ、ぅ……な、なら抱きついちゃいますよ！？　いいですねっ！？」
							CASE 3
								PRINTFORMW 「声が小さすぎる？　こ、こんなのが周りに聞こえてしまったら、私の体裁が大変な事に……」
						ENDSELECT
					PRINTFORML
					PRINTFORMDW ……
					PRINTFORMDL …
					PRINTFORMW
					PRINTFORML 「……で、ではいきますよ！　%TEXTR("これっきりですからね/一回しかやりませんからね/")%！？」
					PRINTFORMDL 練習を経た妖夢の纏う気迫はまさに戦場へと臨むそれである
					PRINTFORMDW この数分間の成果はどれほどなのだろうか、%CALLNAME:MASTER%は息を呑んで妖夢の次の一声を待った
					PRINTFORML
					PRINTFORMW 「…………」
						SELECTCASE RAND:6
							CASE 0
								PRINTFORMW 「――よ」
								PRINTFORML
								CALL HPH_PRINT,@"「妖夢ぅHPH ちょっとカリスマが足りなくなっちゃってぇ～HPH おにーさぁんHPH 妖夢にカリスマ、分けて欲しいなぁ～？HPH」","W"
							CASE 1
								PRINTFORMW 「――お」
								PRINTFORML
								CALL HPH_PRINT,@"「おにーさぁんHPH 妖夢にカリスマ分けてくれたらぁHPH イ・イ・コ・トぉHPH してあげちゃおっかなぁ～？HPH」","W"
							CASE 2
								PRINTFORMW 「――こ」
								PRINTFORML
								CALL HPH_PRINT,@"「これでもいいけどぉ、もうちょっとだけオマケして欲しいかもぉHPH そしたらぁHPH 二時間だけおにーさんとデートしてあげちゃうよぉ？HPH」","W"
							CASE 3
								PRINTFORMW 「――わ」
								PRINTFORML
								CALL HPH_PRINT,@"「わぁあHPH すごぉーいHPH こぉ～んなに分けてくれるのぉ？HPH 妖夢ぅ、おにーさんのコトだぁーい好きだよHPH」","W"
							CASE 4
								PRINTFORMW 「――や」
								PRINTFORML
								CALL HPH_PRINT,@"「やっぱりぃHPH おにーさんから貰うカリスマが一番キュンキュンする～HPH だから妖夢ぅ、もぉ～っとキュンってしたいなぁ～？HPH」","W"
							CASE 5
								PRINTFORMW 「――こ」
								PRINTFORML
								CALL HPH_PRINT,@"「こぉ～んなに分けてくれるなんてぇHPH おにーさん妖夢のコト好きすぎだよぉHPH 妖夢はぁ、おにーさんのコトぉ……あ～んHPH 恥ずかしくて言えなぁ～いHPH」","W"
						ENDSELECT
					PRINTFORML
					PRINTFORMDW ……
					PRINTFORMDL …
					PRINTFORMW
					PRINTFORMDL 暫し間を置いて、%CALLNAME:MASTER%は無言で深く頷き今度こそ妖夢へカリスマを手渡した
					PRINTFORMDW これ以上ないほど顔を真っ赤にした涙目の妖夢は、黙ってそれを受け取り小刻みに震えつつ代金を差し出した
					PRINTFORMDW 半霊は死んだように横たわったまま動かなかった
				;杞憂だろう
				CASE 1
					IF CFLAG:23:2005 == 1
						PRINTFORMDL 以前の様子を思い出すに相当堪えていたようなので、暫くはその心配も無い筈だ
					ELSE
						PRINTFORMDL 考え過ぎだろう、到底彼女に腹芸が出来るとは思えない
					ENDIF
					PRINTFORMDW %CALLNAME:MASTER%は気を取り直してカリスマを渡し、妖夢から代金を受け取った
					;カウントを-1に
					CFLAG:23:2002 = -1
			ENDSELECT
	ELSE
		IF TALENT:恋慕
			PRINTFORMW 「新聞は取っていないので、ちょっと相場が曖昧ですけど……これで大丈夫でしょうか？」
		ELSE
			PRINTFORMW 「わっ、すごい……では代金はこちらで……」
		ENDIF
	ENDIF
	RETURN 1
CASE "依頼実行直後"
	
	RETURN 0
CASE "成功報告時"
;報酬：
	IF CFLAG:23:2002 < 0
		PRINTFORML 「ありがとうございます%CALLNAME:MASTER%さん！　自分ではあまりカリスマが集まらなくて、本当に助かりますよ」
		PRINTFORMW （一瞬不穏な気配がした気もするけど、多分気のせいよね……？）
		CFLAG:23:2002 = 0
	ELSEIF CFLAG:23:2002 >= 4
		PRINTFORMW 「…………その」
		PRINTFORML 「こちらもお渡ししますので、%TEXTR("今の出来事は綺麗に忘れて/ここ数分の記憶を全て失くして/")%いただけると……」
		PRINTFORMDW 更に懐から20000円を取り出した妖夢は、有無を言わさずそれを%CALLNAME:MASTER%へ手渡した
		MONEY += 20000
		;カウントをリセット
		CFLAG:23:2002 = 0
	ELSE
		IF TALENT:恋慕
			IF CFLAG:23:2002 > 0 && RAND:2 == 0
				PRINTFORM 「いつもすみません、
			ELSE
				PRINTFORM 「ありがとうございました！　
			ENDIF
			PRINTFORMW あまり褒められた事でないと自覚してはいるのですが……」
			
			;カウント3未満、且つ100カリスマ以上所持
			IF CFLAG:23:2002 < 3 && MONEY:2 >= 100
				PRINTFORML
				CALL ASK_YN("追加で100カリスマ渡す","渡さない")
					SELECTCASE RESULT
						CASE 0
							PRINTFORML 「えっ、まだ交換して下さるんですか？　ありがとうございます！　実はもう少し確保しておきたかったので助かりますよ」
							PRINTFORMDW %CALLNAME:MASTER%は喜色を浮かべる妖夢に100カリスマ手渡し、20000円受け取った
							MONEY:2 -= 100
							MONEY += 20000
							;カウントを追加
							CFLAG:23:2002 += 1
							
							;2段階目
							IF CFLAG:23:2002 < 3 && MONEY:2 >= 100
								PRINTFORML
								CALL ASK_YN("もう100カリスマ渡す","渡さない")
									SELECTCASE RESULT
										CASE 0
											PRINTFORML 「え……？　は、はぁ……とてもありがたいのですが、こんなに交換していただいて良いのでしょうか……？」
											PRINTFORMDW %CALLNAME:MASTER%は若干困惑している妖夢に100カリスマ手渡し、20000円受け取った
											MONEY:2 -= 100
											MONEY += 20000
											;カウントを追加
											CFLAG:23:2002 += 1
											
											;3段階目
											IF CFLAG:23:2002 < 3 && MONEY:2 >= 100
												PRINTFORML
												CALL ASK_YN("更に100カリスマ渡す","渡さない")
													SELECTCASE RESULT
														CASE 0
															PRINTFORML 「えぇ！？　ちょ、ちょっと待って下さい！　ご厚意は大変嬉しいのですが私の手持ちもありますし、今はこの辺りで……！」
															PRINTFORMDW %CALLNAME:MASTER%は狼狽する妖夢に100カリスマ手渡し、20000円受け取った
															PRINTFORML
															PRINTFORMW （よ、400カリスマも……慎重に、慎重に使わなければ……）
															MONEY:2 -= 100
															MONEY += 20000
															;カウントを追加
															CFLAG:23:2002 += 1
														CASE 1
															PRINTFORMW （合計300カリスマ、これだけあれば暫くは大丈夫な筈……多分、恐らく、きっと……）
													ENDSELECT
											ELSE
												PRINTFORMW （合計300カリスマ、これだけあれば暫くは大丈夫な筈……多分、恐らく、きっと……）
											ENDIF
										CASE 1
											PRINTFORMW （合わせて200カリスマ、ちょっと気が大きくなっちゃうかも……）
									ENDSELECT
							ELSE
								PRINTFORMW （合わせて200カリスマ、ちょっと気が大きくなっちゃうかも……）
							ENDIF
						CASE 1
							PRINTFORMW 「……えﾞ。使い道は……た、大切には使いますので！　そこは%TEXTR("間違いありません/肝に銘じています/")%ので！」
					ENDSELECT
			ELSE
				PRINTFORMW 「……えﾞ。使い道は……た、大切には使いますので！　そこは%TEXTR("間違いありません/肝に銘じています/")%ので！」
			ENDIF
			
			;カウントを追加
			CFLAG:23:2002 += 1
		ELSE
			PRINTFORML 「ありがとうございました！　%CALLNAME:MASTER%さんに相談して良かったです」
			PRINTFORMW 「……えﾞ。な、何に使うかは……あ、あはは……」
		ENDIF
	ENDIF
	RETURN 1
CASE "失敗報告時"
	
	RETURN 0
CASE "依頼報告不要"
	
	RETURN 0
ENDSELECT

