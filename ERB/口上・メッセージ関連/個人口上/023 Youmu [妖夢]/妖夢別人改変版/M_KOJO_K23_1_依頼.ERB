;==================================================
;依赖口上・一般依頼16：お恼み相谈
;==================================================
@M_KOJO_别人版_IRAI_16_K23(ROLE, SCENE, CLIENT_ID)
#DIMS ROLE     ;角色の立场、依赖者かそうでないか
#DIMS SCENE    ;セリフの表示されるタイミング
#DIM  CLIENT_ID;依赖者IDだけ抜き出したもの
;--------------------------------------------------
;RETURN 0 の部分は共通の口上が表示されます
;依赖ごとの口上を表示する部分は RETURN 0 を RETURN 1 にしてください
;--------------------------------------------------
SELECTCASE SCENE
CASE "依頼提示時"
	IF TALENT:恋慕 && RAND:2 == 0
		PRINTFORMW 「虽然说不上有多烦恼，不过我想听听%CALLNAME:MASTER%大人的意见……」
	ELSE
		PRINTFORMW 「虽然是些微小的事情，但我实在无法决定……」
	ENDIF
	RETURN 1
CASE "依頼非受託時"
	
	RETURN 0
CASE "依頼受託時"
	
	RETURN 0
CASE "依頼確認時"
	PRINTFORMW 「并不是很重要，所以不用太过拘谨……」
	RETURN 1
CASE "依頼破棄時"
	PRINTFORML 「诶，诶？好的，我明白了……」
	PRINTFORMW （这个请求真的这么困难吗……？）
	RETURN 1
CASE "依頼実行直前"
	
	RETURN 0
CASE "依頼実行直後"
	IF TFLAG:193 == 1
		;正解の选择肢
		PRINTFORML 「嗯嗯，确实……」
		PRINTFORMW 「您说得没错，您的眼光真敏锐」
	ELSEIF TFLAG:193 == 2
		;ハズレの选择肢だったが逆に正解
		PRINTFORML 「嗯，那确实有点……」
		PRINTFORMW 「但再次被提到，感觉也没那么不妥呢……」
	ELSEIF TFLAG:193 == -1
		;ハズレの选择肢
		PRINTFORMW 「嗯……感觉有点不合适呢……」
	ELSEIF TFLAG:193 == -2
		;正解の选择肢だったが逆にハズレ
		PRINTFORMW 「一开始我也是这么想的，但渐渐觉得不太对劲了……」
	ENDIF
	RETURN 1
CASE "成功報告時"
;报酬：野菜か果物
	
	RETURN 0
CASE "失敗報告時"
	PRINTFORMW 「让您花费时间真是抱歉……」
	RETURN 1
;CASE "依頼報告不要"
;＜この依赖にはありません＞
;	RETURN 0
CASE "口上委託率"
;＜この依赖特有の分岐です。(RESULT:100の值)％の概率で"口上専用"が发生します＞
	RESULT:100 = 0

;＜RESULT:YYに0以外の数值を入れると、该当のお恼みを发生させなくできます（詳しくは一般依頼16_お恼み相谈参照）＞
;1,2:弹幕ごっこの恼み 3,4:晩酌の恼み 5,6:本の恼み 7,8:香料の恼み
;9,10:音乐の恼み 11,12:服の恼み 13:发型の恼み 14:参拝の恼み 15:ダイエットの恼み
;16,17:菜园の恼み 18:休日の恼み 19:人气の恼み 20:集中力の恼み 21:御三家の恼み 22:进化の恼み
	RESULT:1 = 0
	RESULT:2 = 0
	RETURN 1
CASE "口上専用"
;＜この依赖特有の分岐です。(口上委托率)％の概率で发生します＞
;16,お恼み相谈 の场合
;RESULT        发生判定,0だと发生しません
;RESULT:1      正解の选择肢（ただしRESULT:2が0だと、一定概率で逆にハズレる）
;RESULT:2      逆张り正解／ハズレ判定の消去,1だと逆张りが无くなります
;RESULTS:0     お恼み文章（自动で『』で囲まれます）
;RESULTS:1～3  选择肢１～３
;何も发生しない状态になると无限ループになるので注意してください
;●追记メモ
;RESULT:1を4～6にするとそれぞれ1～3がハズレ（残り2つが正解）になります
;RESULT:1を7にするとどれも正解になります
;RESULT:1を8にするとどれもハズレになります
;1～3以外の场合は逆张り判定が自动で无くなります
	RESULT = 0

;▼サンプル
[SKIPSTART]
	SELECTCASE RAND:5
	CASE 0
		;このお恼みは、恋慕で发生し、親密によって正解が变わります
		SIF TALENT:恋慕
			RESULT = 1
		RESULTS:0 = 赤ちゃん作るなら何人がいいかな？
		RESULTS:1 = ５人で浴室ケチームを作ろう
		RESULTS:2 = ９人で野球チームを作ろう
		RESULTS:3 = １１人でサッカーチームを作ろう
		IF ABL:親密 >= 100
			RESULT:1 = 3
		ELSEIF ABL:親密 >= 20
			RESULT:1 = 2
		ELSE
			RESULT:1 = 1
		ENDIF
	CASE 1
		;このお恼みは、无条件で发生し、正解は绝对に2番で固定化されます
		SIF 1
			RESULT = 1
		RESULTS:0 = どのジョブがいいかな？
		RESULTS:1 = かっ恋ナイト
		RESULTS:2 = シーフが便利だよ
		RESULTS:3 = 青魔道士最强！
		RESULT:1 = 2
		RESULT:2 = 1
	CASE 2
		;このお恼みは、夏之月に发生し、正解がランダムで变わります
		SIF DAY:2 == 2
			RESULT = 1
		RESULTS:0 = どの水着を买おうかな？
		RESULTS:1 = 可爱的連衣裙
		RESULTS:2 = クールなセパレート
		RESULTS:3 = 色っぽい比基尼
		RESULT:1 = RAND:3 + 1
	CASE 3
		;このお恼みは、无条件で发生し、1番と3番が正解になります（5 - 3 = 2番がハズレになります）
		SIF 1
			RESULT = 1
		RESULTS:0 = ワンちゃんの名前は何にしよう？
		RESULTS:1 = ボロンゴ
		RESULTS:2 = ゲレゲレ
		RESULTS:3 = プックル
		RESULT:1 = 5
	CASE 4
		;このお恼みは、无条件で发生し、どれを选んでも正解になります
		SIF 1
			RESULT = 1
		RESULTS:0 = 夕饭は何がいい？
		RESULTS:1 = 土豆炖肉
		RESULTS:2 = 可乐饼
		RESULTS:3 = 烧鱼
		RESULT:1 = 7
	ENDSELECT
[SKIPEND]

	SIF !RESULT
		RESTART
	RETURN 1
ENDSELECT

