;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_別人版_MESSAGE_MESSAGECHECK_COM_K23_81
RETURN 0

@M_KOJO_別人版_MESSAGE_COM_K23_81
CALL M_KOJO_別人版_MESSAGE_COM_K23_81_1
RETURN RESULT

@M_KOJO_別人版_MESSAGE_COM_K23_81_1
#DIM 挿入
VARSET 挿入
IF MASTER_POSE(SET_V,SET_P,1)
	挿入 = MASTER_POSE(SET_V,SET_P,1)
ELSEIF MASTER_POSE(SET_A,SET_P,1)
	挿入 = MASTER_POSE(SET_A,SET_P,1)
ENDIF
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;時姦中
	IF FLAG:70
		PRINTFORMW
		RETURN 1
	;泥酔
	ELSEIF TCVAR:泥酔 == 1
		PRINTFORMW
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		IF TALENT:恋慕
			PRINTFORMW 「用嘴巴……！？　哇、哇……有没有什么步骤、礼仪之类……」
			PRINTFORML 「——啊、完全没有那种东西吗……既然如此，那就该实际试一次才对吧…………啊姆」
			PRINTFORMW （呜、含得还算巧妙吗……？　说不定我的嘴巴比自己想象中还要小……）
		ELSE
			PRINTFORML 「要是被要求含住的话，本来是打算麻烦紫大人出手的」
			PRINTFORMW 「被你这么认真低头拜托，反而让我有点泄气呢……我可不是服从，只是打从心底觉得无语才勉强配合而已哦」
			PRINTFORMDW 把命根子递到这么明显具备攻击性的器官之前，多少还是需要一点诚意的吧……
		ENDIF
		RETURN 1
	ENDIF

	;お掃除
	IF TCVAR:MASTER:112 == 1 || TCVAR:MASTER:112 == 2
		IF TALENT:恋慕
			IF ABL:精液中毒 > 4
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「啊……HPH　……包在我身上，清理污秽本来就是从者的职责」","L"
						CALL HPH_PRINT,@"「嗯欸、舔……啾啵、啾噜——啾噜噜噜HPH　噗啊……希望里面也已经弄干净了……HPH」","L"
						PRINTFORMDW 那股想要把肉棒内残留的精液全部吸干净的吸力，贪婪得仿佛要把一度退去的射精感硬生生拖出来……
					CASE 1
						CALL HPH_PRINT,@"「舔、啾噜HPH　……光用舌头好像会花太多时间……啊姆、啾噜噜、咕啵……HPH」","L"
						CALL HPH_PRINT,@"（好浓烈的味道……HPH　简直像在舔舐整个房间的空气一样……）","L"
						CALL HPH_PRINT,@"（黏在喉咙上，肺部深处发麻，脑子都被搅乱了……这就是房事的滋味吗……HPH）","W"
				ENDSELECT
			ELSE
				PRINTFORML 「哈、哈、……？　欸、那个…………舔干净就好了对吧……」
				PRINTFORML （……好、好夸张。刚才这东西还插在里面……？　……咕咚）
				PRINTFORMDW 在%CALLNAME:PLAYER%再次开口前，妖梦一直瞪圆眼睛，死死盯着才从体内拔出沾满体液的肉棒
			ENDIF
		ELSE
			IF ABL:精液中毒 > 4 && RAND:2 == 0
				PRINTFORML 「…………哈。舔就行了是吧？」
				PRINTFORML 「我好歹也有眼力见的……不过这东西很恶心，能不能稍微收回去一点？」
				PRINTFORMDW 瞥了一眼伸到面前、还沾满两人爱液的肉棒，妖梦的表情更加阴沉，极不情愿地开始伸出舌头……
			ELSE
				PRINTFORMW 「……呜……欸、哈？　要、要舔……这个……？」
				PRINTFORML 「……不是吧，这黏糊糊的东西？　…………啊啊真是的！　我会做的，别再硬塞过来了！」
				PRINTFORMW （可、可恶，太屈辱了…又要吞下那种…！　不过好在这也不是单纯地侍奉…姑且这么想心情会不会稍微好一点……？）
			ENDIF
		ENDIF
	;MASTERが射精する
	ELSEIF NOWEX:MASTER:11
		IF TALENT:恋慕
			;TARGETに挿入中
			IF 挿入 == TARGET
				IF ABL:舌 > 2 && EXP:口淫経験 > 15 && ((TCVAR:V挿入管理FLAG == PLAYER && ABL:Ｖ感覚 > 4) || (TCVAR:A挿入管理FLAG == PLAYER && ABL:Ａ感覚 > 4))
					SELECTCASE RAND:3
						CASE 0
							CALL HPH_PRINT,@"「唔、嗯啊HPH　那、那么、激烈地……哈啊……咿嗯HPH」","L"
						CASE 1
							CALL HPH_PRINT,@"「啊，又变大了……HPH　比刚才更、深入……嗯哦HPH」","L"
						CASE 2
							CALL HPH_PRINT,@"「咿咕，再、再深一点HPH　啊、呜啊、里面……哈咿HPH」","L"
					ENDSELECT
					SELECTCASE RAND:3
						CASE 0
							CALL HPH_PRINT,@"「哈、哈啊……HPH　……啊、啊哈啊……HPH　……哈！？」","W"
						CASE 1
							CALL HPH_PRINT,@"「呼、呼呜……HPH　……欸、诶嘿、嘿……HPH　……嘿！？」","W"
						CASE 2
							CALL HPH_PRINT,@"「咿、哈……HPH　……哦、哦哦哦……HPH　……啊！？」","W"
					ENDSELECT
					PRINTFORMW 「对、对不起！　那、那个、太舒服了，有点失去理智……如果想要用嘴巴的话，我马上……嗯、啾噜噜……」
				ELSE
					PRINTDATAL
						DATAFORM 「嗯呜……咕……呜啊……欸、啊……！？」
						DATAFORM 「呜、啊……嗯……哈……、欸……！？」
					ENDDATA
					PRINTFORMW 「啊、%CALLNAME:TARGET%大人，这样……可以吗？　……嘿！？　用、用嘴巴是吧，马上……嗯姆呜……！」
				ENDIF
			ELSEIF ABL:舌 > 2
				SELECTCASE RAND:(ABL:精液中毒 > 4 ? 5 # 3)
					CASE 0
						CALL HPH_PRINT,@"「啾噜、舔、嗯～……、哈啊啊HPH　啊姆……啾啾、嗯啵……啾噜噜HPH」","L"
						PRINTFORMDL 妖梦用力吸吮怒张的肉棒，甚至故意发出夸张的声音来刺激兴奋
						PRINTFORMDW 不知是否正中下怀，那水声从耳畔流入，溶解理性，把本能的高潮一点点拉近……
					CASE 1
						PRINTFORMDL 妖梦像第一次拿到玩具的孩子般，兴致冲冲地埋头吸吮肉棒
						PRINTFORMDL 可那景象没有半点稚童般的可爱，只有沉醉于恋慕侍奉的少女，吐露出的妖艳喜悦
						PRINTFORMDW %CALLNAME:PLAYER%不由自主地微微抬腰，少女欣喜地眯起眼睛，舌头动作变得更加激烈……
					CASE 2
						CALL HPH_PRINT,@"（……HPH　我的舌头让%CALLNAME:PLAYER%大人舒服了……HPH）","L"
						CALL HPH_PRINT,@"（哪里比较敏感，已经大致摸清楚了。继续这样侍奉下去，我怕是要上瘾了……HPH）","L"
						PRINTFORMDW 舌尖仔细地沿着冠状沟打圈，被点燃的快感从阴囊根部咕嘟咕嘟地把精液向上推挤
					CASE 3
						CALL HPH_PRINT,@"「咕啵、啾啵、啾噜……HPH　请千万别勉强忍耐哦……？HPH」","L"
						CALL HPH_PRINT,@"（啊……马上就要、就这样HPH　就这样射进嘴巴里了……HPH）","L"
						PRINTFORMDW 为了最后一推，她毫不吝惜地用舌头和嘴唇，主动准备用口腔接住%CALLNAME:PLAYER%的兽欲……
					CASE 4
						CALL HPH_PRINT,@"「可以让我喝下去对吧……HPH　希望能一点都不洒出来……啾HPH」","L"
						PRINTFORMDL 她怜爱地亲吻充血的龟头，随即将那膨胀到怒张的肉棒深深含下
						PRINTFORMDW 只用舌头和嘴唇的灵巧侍奉，似乎是为了用喉咙箍住龟头、确保不会漏吞而做的准备
				ENDSELECT
			ELSE
				PRINTDATAL
					DATAFORM 「嗯、舔……咕啵……嗯、嗯姆……」
					DATAFORM 「啾噜……嗯嗯、姆……啊姆……啾啵……」
				ENDDATA
				PRINTDATAL
					DATAFORM （我自己都觉得好没出息，变得畏畏缩缩的……得快点习惯才行……？　在颤抖、变大了——）
					DATAFORM 「……啾啵、呜姆……实际上到底做得好不好……欸、差不多要去了——？」
				ENDDATA
				PRINTFORMDW 被胆怯的舌尖缓慢培养起来的射精感，已经逼近忍耐的极限……
			ENDIF
		ELSE
			IF 挿入 == TARGET
				PRINTFORML 「咕……啊咕…………、呜啊！？」
				PRINTFORMW 「哈、呜……结、结束了……？　……哈啊！？　用嘴巴……啊啊真是的……！」
			ELSEIF ABL:舌 > 2 && RAND:2 == 0
				PRINTFORML 「嗯、咕……姆……嗯……」
					IF ABL:精液中毒 > 4 && RAND:2 == 0
						PRINTFORMDL 虽然不愿对视，但敌意似乎没那么强烈了，对含住这件事的厌恶感也许已经淡了
						PRINTFORMDW 一使眼色示意快要高潮，妖梦便不满地白了一眼，却还是皱起眉头把充血到绷紧的龟头含入口腔深处
					ELSE
						PRINTFORML （总之先让他满足一次……快射的时候总会有什么反应，在那之前应该还好……）
						PRINTFORMDW 这么好不容易练出来的舌技，就这么草草结束也太可惜了吧……于是%CALLNAME:MASTER%打定主意一动不动地忍耐到高潮边缘。
					ENDIF
			ELSE
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML （这黏黏的先走汁，就是那个吧……？　味道好重……）
						PRINTFORML （感觉比刚才量变多了，不吞下去也快不行了……！　等等，这该不会要——）
					CASE 1
						PRINTFORML （这到底要做到什么时候，味道也超难闻……？）
						PRINTFORML （比开始时大了一圈…………！？　糟、糟了，来不及——）
				ENDSELECT
				PRINTFORMDW 还没来得及出声，白浊已经涌向铃口，即将喷进妖梦的嘴里……
			ENDIF
		ENDIF

	;基本セット
	;恋慕
	ELSEIF TALENT:恋慕
		IF ABL:舌 > 2 && EXP:口淫経験 > 15
			;勃起しきっていない
			IF BASE:MASTER:勃起 < 1000 && RAND:3 == 0
				PRINTFORML 「咦？　好像有点没精神……」
				PRINTFORML 「…………啊！　是我太迟钝了，对不起，不会耽误您太久的……嗯啵…滋噜」
				PRINTFORMDW 那小小的嘴巴展示出难以想象的淫靡舌技，原本疲软的肉棒正急速地鼓胀起来……
			ELSE
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「嗯、啾噜……有时候也会想，是不是该找类似的东西先练习一下」
						CALL HPH_PRINT,@"「不过果然，还是直接用大人的肉棒来练习最能学到东西……HPH」","L"
						CALL HPH_PRINT,@"「哪里比较敏感，还是得直接问身体才知道……啊HPH　这里好像很舒服呢……HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「嗯姆、啾……姆……咕啵、啾噜……嗯啵……HPH」","L"
						PRINTFORML （就算含得很深也不会让牙齿碰到的技巧，已经掌握了……经验和习惯果然不会骗人）
						CALL HPH_PRINT,@"（味道方面……虽然难以形容，但不可思议地让人想一直含下去……HPH）","W"
					CASE 2
						CALL HPH_PRINT,@"「舔、嗯姆、啾……舔……呼、嗯……HPH」","L"
						PRINTFORMDL 妖梦不时用眼神窥探%CALLNAME:PLAYER%的反应，兴高采烈地继续用舌头侍奉
						PRINTFORMDW 那张还带着稚气的脸庞贴近血管毕露的狰狞肉棒，那副反差刺激得得让人忘了呼吸……
				ENDSELECT
			ENDIF
		ELSE
			SELECTCASE RAND:2
				CASE 0
					PRINTFORML （需要避免哪些行为还不太能抓住要领……暂时还是别含得太深比较好）
					PRINTFORML （要是牙齿碰到，会超级愧疚的……）
					PRINTFORMDW 或许正因为还在摸索自己的方法，舔弄龟头的舌尖动作始终非常克制
				CASE 1
					PRINTFORML 「嗯姆……嗯……舔…………姆呜」
					PRINTFORML （到底该怎么舔才是正确的……或许该找形状类似的东西来练习才对……）
					PRINTFORMDW 舌尖小心翼翼地戳着各个部位试探，从中强烈传来因不熟练而生的顾虑
			ENDSELECT
		ENDIF
	;それ以外
	ELSE
		IF ABL:舌 > 2 && EXP:口淫経験 > 30 && RAND:3 == 0
			PRINTFORML 「——哈？　好、好厉害……？」
			PRINTFORML 「…………谢谢。不过一点都不开心」
			PRINTFORMW （偏偏这种时候一脸诚恳，搞得我节奏全乱了……）
		ELSE
			PRINTFORML 「…………嗯……姆……哈啊」
			PRINTDATAL
				DATAFORM （现在实在不想去想象从一旁看自己是何种丑态……）
				DATAFORM （虽然姑且接受了，但人家到底为什么要做这种事……）
			ENDDATA
			PRINTFORMDW 虽然完全没有掩饰厌恶的表情，但目前为止还没看到任何想要伤害命根子的迹象
		ENDIF
	ENDIF
ENDIF
RETURN 1

