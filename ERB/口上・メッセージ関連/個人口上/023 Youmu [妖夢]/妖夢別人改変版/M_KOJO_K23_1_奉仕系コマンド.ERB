;奉仕系コマンド
;※※※※※※※※※※※※※※※※※※※※※※※※※
;==================================================
;80,手淫
;==================================================
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_別人版_MESSAGE_MESSAGECHECK_COM_K23_80
RETURN 0

@M_KOJO_別人版_MESSAGE_COM_K23_80
CALL M_KOJO_別人版_MESSAGE_COM_K23_80_1
RETURN RESULT

@M_KOJO_別人版_MESSAGE_COM_K23_80_1
;地の文と映姫様口上を参考に予め関数を定義
#DIM 挿入
VARSET 挿入
IF MASTER_POSE(SET_V,SET_P,1)
	挿入 = MASTER_POSE(SET_V,SET_P,1)
ELSEIF MASTER_POSE(SET_A,SET_P,1)
	挿入 = MASTER_POSE(SET_A,SET_P,1)
ENDIF
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;時姦中
	IF FLAG:70
		PRINTFORMW
		RETURN 1
	;泥酔
	ELSEIF TCVAR:泥酔 == 1
		PRINTFORMW
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		IF TALENT:恋慕
			PRINTFORMW 「欸、那个……用手指揉搓就行吗？」
			PRINTFORML 「毕竟完全没经验，若是力道拿捏不好，请毫不客气地指正……」
			PRINTFORMW （哇，一碰就抖了一下……咿、一上来就搞错了吗……！？）
		ELSE
			PRINTFORMW 「……就算我有错也罢了，为什么非得碰这种东西」
			PRINTFORML 「——哦？想法一样啊？真巧呢？　行啊，我也想赶紧结束这糟糕透顶的时间」
			PRINTFORMW （干脆捏碎算了……果然还是不行，之后会留下讨厌的触感吧）
		ENDIF
		RETURN 1
	ENDIF

	;MASTERが射精する
	IF NOWEX:MASTER:11
		IF TALENT:恋慕
			;TARGETに挿入中 上回合插入，这回合射精
			IF 挿入 == TARGET
				;bugfixes 手淫或其他侍奉指令回合，TEQUIP:50V性交与TEQUIP:51A性交绝对不可能侦测成功，因为该指令并非插入
				;IF ABL:技巧 > 3 && EXP:手淫経験 > 15 && ((TEQUIP:50 == PLAYER && ABL:Ｖ感覚 > 4) || (TEQUIP:51 == PLAYER && ABL:Ａ感覚 > 4))
				IF ABL:技巧 > 3 && EXP:手淫経験 > 15 && ((TCVAR:V挿入管理FLAG == PLAYER && ABL:Ｖ感覚 > 4) || (TCVAR:A挿入管理FLAG == PLAYER && ABL:Ａ感覚 > 4))
					SELECTCASE RAND:3
						CASE 0
							CALL HPH_PRINT,@"「唔、嗯啊HPH　那、那么、激烈地……咿嗯HPH」","L"
						CASE 1
							CALL HPH_PRINT,@"「啊，又变大了……HPH　比刚才更、深入……嗯哦HPH」","L"
						CASE 2
							CALL HPH_PRINT,@"「咿咕，再、再深一点HPH　啊、呜啊、里面……哈咿HPH」","L"
					ENDSELECT
					SELECTCASE RAND:3
						CASE 0
							CALL HPH_PRINT,@"「哈、哈啊……HPH　……啊、啊哈啊……HPH　……哈！？」","W"
						CASE 1
							CALL HPH_PRINT,@"「呼、呼呜……HPH　……欸、诶嘿、嘿……HPH　……嘿！？」","W"
						CASE 2
							CALL HPH_PRINT,@"「咿、哈……HPH　……哦、哦哦哦……HPH　……啊！？」","W"
					ENDSELECT
					PRINTFORMW 「我、我一个人满足了可不行对吧……也快点给我吧……！」
				ELSE
					PRINTDATAL
						DATAFORM 「嗯呜……咕……呜啊……欸、啊……！？」
						DATAFORM 「呜、啊……嗯……哈……、欸……！？」
					ENDDATA
					PRINTFORMW 「啊、%CALLNAME:TARGET%大人，这样……可以吗？　……嘿！？　啊、用手是吧，明白了……！」
				ENDIF
			ELSEIF ABL:技巧 > 3
				SELECTCASE RAND:(ABL:精液中毒 > 4 ? 5 # 3)
					CASE 0
						PRINTFORML 「从指尖传来的感觉……您正在享受对吧……」
						CALL HPH_PRINT,@"「努力总有回报真是令人欣慰，尤其是能让%CALLNAME:TARGET%大人愉悦的成果HPH」","L"
						CALL HPH_PRINT,@"「请千万别忍耐，随时朝我这边宣泄吧……HPH」","W"
					CASE 1
						PRINTFORML 「……嗯，虽然具体说明还是很难」
						PRINTFORML 「但多亏经验积累，总算有点抓到诀窍的自负了」
						CALL HPH_PRINT,@"「比如……这里用这个力道揉搓的话，应该能让您舒服到高潮……HPH」","W"
					CASE 2
						CALL HPH_PRINT,@"「啊，又变粗了……要稍微加快一点哦……HPH」","L"
						PRINTFORMDL 原本仔细爱抚坚硬棒身的手掌忽然离开，和另一只手一起轻轻托住阴囊根部按压
						PRINTFORMDW 冰凉的掌心包裹住发烫的囊袋，产生收缩的错觉，精液瞬间被向上推挤……
					CASE 3
						CALL HPH_PRINT,@"「……啊……嗯。差不多、要来了吧……？HPH」","L"
						PRINTFORMDL 指尖沿着凸起的血管游走，渐渐改为用整个手掌搾取肉棒
						PRINTFORMDW 早已尝过侍奉滋味、渴望着赏赐的妖梦，表情藏不住那股雌性的媚态
					CASE 4
						CALL HPH_PRINT,@"「…………哈啊……啊…………嗯……HPH」","L"
						PRINTFORMDL 少女双颊潮红，沉醉其中，一心一意用手指侍奉，吐息与淫靡水声不停在空间回荡
						PRINTFORMDW %CALLNAME:TARGET%的手已经没了梳理银丝的从容，迫不及待地将唇凑近，像要含住龟头般靠近……
				ENDSELECT
			ELSE
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 「整体……要均匀地动才好吗……？　嗯、嗯……？」
						PRINTFORML 「——嘿！？　就、就这样继续下去吗……哇、根部在跳动——！」
					CASE 1
						PRINTFORML （果然……经验不足让我好痛心……虽然完全不可能跟%CALLNAME:TARGET%大人以外的人积累这种经验啦）
						PRINTFORML （唔唔…正因如此才更想让%CALLNAME:TARGET%大人舒服……咦，感觉比刚才更大了——？）
				ENDSELECT
				PRINTFORMDW 还没等有些困惑的妖梦反应过来，白浊已从尿道冲上，从马眼决堤般喷出
			ENDIF
		ELSE
			IF 挿入 == TARGET
				PRINTFORML 「咕……住手…………、呜啊！？」
				PRINTFORMW 「哈、哈……结、结束了……？　……啊！？　让、让我握住什么……」
			ELSEIF ABL:技巧 > 3 && RAND:2 == 0
				IF ABL:精液中毒 > 4 && RAND:2 == 0
					PRINTFORML 「……我再重复一次，我只想赶紧结束这件事」
					PRINTFORML 「这么用力地揉应该也不会痛吧？」
					PRINTFORMDW 不知是巧合还是无意识，铃口正对着妖梦的嘴，仿佛随时要喷射…
				ELSE
					PRINTFORML 「……快到极限的话请用言语告知」
					PRINTFORML 「要是乱喷的话，善后会很麻烦」
					PRINTFORMDW 冷淡的目光正俯视着即将高潮、细微颤抖的肉棒……
				ENDIF
			ELSE
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML （为什么毫无回报，还要我来伺候这种下流玩意儿……）
						PRINTFORM （我能保持无我的心境，也就只为了主人而已……
					CASE 1
						PRINTFORML 「…………这苦差事还要做到什么时候」
						PRINTFORM （虽然几乎是被迫的，但自己也未免太惨了……
				ENDSELECT
				PRINTFORMW 呜、开始抽动了……）
			ENDIF
		ENDIF

	;基本セット
	;恋慕
	ELSEIF TALENT:恋慕
		IF ABL:技巧 > 3 && EXP:手淫経験 > 15
			;勃起しきっていない
			IF BASE:MASTER:勃起 < 1000 && RAND:3 == 0
				PRINTFORML 「咦？　好像……还没有很硬呢……」
				PRINTFORML 「啊……对、对了呢！　我也稍微习惯一点了，应该很快就能让您精神起来的……！」
				PRINTFORMDW 纤细灵巧的指尖每次滑过表面，都能感觉到血液正不断地涌向正在勃起的肉棒……
			ELSE
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「呵呵，感觉如何呢？」
						CALL HPH_PRINT,@"「慢慢地我也明白了，有时候那种隔靴搔痒的感觉，反而也会变成快感……HPH」","L"
						PRINTFORMDW 从阴囊一路向上抚摸到龟头前端的指尖，正以极度缓慢的速度不断抬高射精感……
					CASE 1
						PRINTFORML 「……要再稍微激烈一点，对吧？　包在我身上」
						CALL HPH_PRINT,@"「就算动作快一点，只要保持足够的润滑，就绝对不会弄伤的……嗯欸……HPH」","L"
						PRINTFORMDW 妖梦伸出的舌尖滴落的唾液拉出细丝，一路垂落，和先走汁混合，在指缝间发出咕啾咕啾的淫靡水声
					CASE 2
						PRINTFORML （只是轻轻碰着而已，就能感觉到它在跳动……）
						PRINTFORML （简直就像完全独立的生物一样，可明明又是%CALLNAME:TARGET%大人的一部分，这样一想就——）
						PRINTFORMDW 不知不觉凑近的湿润嘴唇微微张开，带着少女体温的吐息，像在舔舐一般搔弄着完全裸露的龟头
				ENDSELECT
			ENDIF
		ELSE
			SELECTCASE RAND:2
				CASE 0
					PRINTFORML 「……如、如何呢……？」
					PRINTFORML 「我自己都还没能完全掌握到诀窍……如果觉得痛的话请务必责骂我哦？」
					PRINTFORMDW 正相反却是太过小心、有些不够到位的力道，不过那冰凉指尖滑动的触感却是让人舒服到无法出声指点
				CASE 1
					PRINTFORML （……这、这个程度应该可以吧？）
					PRINTFORML （简直就像跟%CALLNAME:PLAYER%大人是完全不同的分身之物一样，所以才会格外小心翼翼……！）
					PRINTFORMDW 老实说其实有点用力过头了，但这种时候贸然出声感觉反而会有生命危险……
			ENDSELECT
		ENDIF
	;それ以外
	ELSE
		IF ABL:技巧 > 3 && EXP:手淫経験 > 30 && RAND:3 == 0
			PRINTFORML 「——哈？　变、变厉害了？」
			PRINTFORML 「…………应该是错觉吧，我的手法完全没变哦」
			PRINTFORMW （…妖梦你…已经习惯了吗？　不知不觉间，竟然对这种胡闹的事情……）
		ELSE
			SELECTCASE RAND:2
				CASE 0
					PRINTFORML 「——有点痛，是吗？」
					PRINTFORML 「被强迫握住这种东西，力道自然会加重嘛」
					PRINTFORMW 「……只是“有点痛”就了事，算你走运了对吧？」
				CASE 1
					PRINTFORML 「——嗯，握力不够是吧」
					PRINTFORML 「要我去抚摸一件根本不想碰的东西，当然会变得畏畏缩缩啊」
					PRINTFORMW 「……不过呢，如果你真的想要我再用力一点的话，我可是完全不会手下留情的哦」
			ENDSELECT
		ENDIF
	ENDIF
ENDIF
RETURN 1

