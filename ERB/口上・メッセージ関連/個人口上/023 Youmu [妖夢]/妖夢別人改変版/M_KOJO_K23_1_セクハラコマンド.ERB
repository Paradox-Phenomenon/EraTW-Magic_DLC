							DATAFORM 「……ぉ……お気に召されましたか？　でしたら、もう少しだけなら……」
						ENDDATA
					ENDIF
				ELSE
					PRINTDATAW
						DATAFORM 「これの何が楽しいんですか……」
						DATAFORM 「他でもこんな事を？　いつか張り倒されますよ……」
					ENDDATA
				ENDIF
		ENDSELECT
	ENDIF
ENDIF
RETURN 1
