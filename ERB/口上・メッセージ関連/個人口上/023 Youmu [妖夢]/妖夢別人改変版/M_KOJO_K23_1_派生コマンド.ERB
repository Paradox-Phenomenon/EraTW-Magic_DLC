;==================================================
;5,手淫口交
;==================================================
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_别人版_MESSAGE_MESSAGECHECK_SCOM_K23_5
RETURN 0

@M_KOJO_别人版_MESSAGE_SCOM_K23_5
CALL M_KOJO_别人版_MESSAGE_SCOM_K23_5_1
RETURN 1
@M_KOJO_别人版_MESSAGE_SCOM_K23_5_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;時姦中
	IF FLAG:70
		PRINTFORMW
		RETURN 1
	;泥酔
	ELSEIF TCVAR:泥酔 == 1
		PRINTFORMW
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(TFLAG:50 + 500)
		IF TALENT:恋慕
			PRINTFORML 「手指和嘴巴……两边一起用的话，肯定会让您更舒服吧？」
			PRINTFORMW 「如果我有足够的技巧就好了……啊-唔……」
			PRINTFORMW （注意力只放在一边可不行，手这边就先保持这样……？）
		ELSE
			PRINTFORML 「这种脏东西，有必要这么毕恭毕敬地侍奉吗？」
			PRINTFORMW 「要是你非要磨磨蹭蹭地，故意延长时间折辱我的话，下场会很惨哦……」
			PRINTFORMW （拜托的方式倒还算有诚意，既然都这样了，一次的话……呜…恶…）
		ENDIF
		RETURN 1
	ENDIF

	;MASTERが射精する
	IF NOWEX:MASTER:11
		IF TALENT:恋慕
			IF (ABL:技巧 > 3 && EXP:手淫経験 > 15) && (ABL:舌 > 2 && EXP:口淫経験 > 15)
				SELECTCASE RAND:(ABL:精液中毒 > 4 ? 5 # 3)
					CASE 0
						PRINTFORML 「虽然经验丰富这个说法可能不太恰当……不过对%CALLNAME:PLAYER%大人好像也变得相当熟悉了呢」
						PRINTFORML 「——嗯，确实有种变得亲近的感觉。毕竟…被教了好多东西嘛？」
						CALL HPH_PRINT,@"「%CALLNAME:PLAYER%大人的极限已经很近了之类的～舔……像这样舔着这边再撸撸这里的话，好像就会忍不住了之类的…呼呼…HPH」","W"
					CASE 1
						PRINTFORMDL 在充满情欲喘息的空间里，少女正一心一意地继续侍奉着%CALLNAME:PLAYER%
						PRINTFORMDL 沾满彼此情欲的健壮男根被纤细手指揉搓发出的黏腻水声，以及妖梦毫不在意体面地吮吸肉棒的妖艳模样……
						PRINTFORMDW 那与稚气未脱的少女容颜不符的性技令人深陷其中，不知不觉间，高潮已攀升到无法抑制的顶点
					CASE 2
						PRINTFORML 「啊……任何事情要是草草收尾，都会被责备的吧」
						CALL HPH_PRINT,@"「……不过既然双手和嘴巴都能用，一定能让您满足才对HPH…阿姆…嗯姆、咕啵、啾噜噜HPH」","L"
						PRINTFORMDW 精准刺激敏感部位的指尖与舌尖，转眼间就把逐渐膨胀的射精感猛地激发出来
					CASE 3
						CALL HPH_PRINT,@"「啾噜、呜……HPH　啊姆、嗯咕……咕啵、啾啵HPH」","L"
						CALL HPH_PRINT,@"（味道变得更浓了……HPH　好想要，快点……HPH）","L"
						PRINTFORMDW 手指的动作变成像挤奶般从肉棒根部开始挤榨，随时都会爆发的鼓胀蟒头被妖梦深深吞入喉咙深处……
					CASE 4
						PRINTFORML 「……嘴巴也好手指也好，我都能掌握您的反应了，怎么可能察觉不到……」
						CALL HPH_PRINT,@"「%CALLNAME:PLAYER%大人…滋啵滋啵…啾啵HPH啾……别再吊着我了，好不好……？HPH」","L"
						PRINTFORMDW 仿佛要榨出肉棒根部积蓄的射精感般，少女香舌沿着鼓胀的背筋向上撩拨，还没来得及忍耐，白浊就猛地喷进了妖梦的口中
				ENDSELECT
			ELSE
				PRINTDATAL
					DATAFORM 「嗯、嗯姆……唔……舔、呜……」
					DATAFORM 「……呜姆……嗯啵、啾噜……」
				ENDDATA
				PRINTDATAL
					DATAFORM （怎么说呢，总觉得不太对劲……明明觉得自己还能做得更熟练才对……嗯？这个反应……难道是——）
					DATAFORM 「哈啊……那个，%CALLNAME:PLAYER%大人。要是太舒服的话……欸，马上就要？　哈、好的——」
				ENDDATA
				PRINTFORMDW 虽然技巧上还有些不足，但那份全心全意的侍奉姿态本身所带来的快感，已经足够让人舒爽地高潮一次了
			ENDIF
		ELSE
			IF (ABL:技巧 > 3 && EXP:手淫経験 > 30) && (ABL:舌 > 2 && EXP:口淫経験 > 30) && RAND:2 == 0
				PRINTFORML 「……哼。不知你根据什么这么觉得，我可丝毫没有自认为熟练哦」
					IF ABL:精液中毒 > 4 && RAND:2 == 0
						PRINTFORMDL 对%CALLNAME:PLAYER%毫无恶意的称赞，妖梦完全不予理会，一脸厌烦地继续手指与舌头的侍奉
						PRINTFORMDW 察觉到高潮很快将近，指尖贴上根部开始榨取，不耐烦地紧闭双眼、将肉棒深深含入口腔准备接纳……
					ELSE
						PRINTFORML 「啾噜滋啵……或许…嗯滋…是为了把这无聊的苦差事哪怕缩短一秒，啵～也自然而然地…效率化了吧？」
						PRINTFORMDW 妖梦的心中早已烙印下侍奉的肌肉记忆，像处理事务般淡漠地用熟练的侍奉将肉棒推向高潮……
					ENDIF
			ELSE
				PRINTFORML 「……呜……姆咕…咕滋…嗯……」
				PRINTDATAL
					DATAFORM （居然要脸贴着这种东西，还得去碰它……我是不是该在哪积点德啊，宅邸附近应该就有石头能堆……）
					DATAFORM （恶…快点结束不行吗，靠想着%TEXTR("搭理庭院的事/明天的菜单/")%来分散注意力也快到极限了……）
				ENDDATA
				PRINTFORMDW 妖梦茫然地动着手和舌头，完全没注意到肉棒已在高潮边缘痉挛颤抖
			ENDIF
		ENDIF

	;基本セット
	;恋慕
	ELSEIF TALENT:恋慕
		IF (ABL:技巧 > 3 && EXP:手淫経験 > 15) && (ABL:舌 > 2 && EXP:口淫経験 > 15)
			SELECTCASE RAND:4
				CASE 0
					CALL HPH_PRINT,@"「无论只用哪一边，我这边也会有些不满足呢…呋呋…HPH」","L"
					PRINTFORML 「『明明两边一起用，就能更好地侍奉了』的说……一想到这个就忍不住」
					CALL HPH_PRINT,@"「……是因为还不够成熟才这样无耐性地焦躁吗？不过HPH既然您也提出了这样的要求！……啾噜、啾啵……HPH」","W"
				CASE 1
					CALL HPH_PRINT,@"「咕啵、啾噜、嗯啊……啊姆、啾噜……嗯、舔……HPH」","L"
					CALL HPH_PRINT,@"（手指和舌头都自然而然地动起来了，或许已经达到了值得自豪的领域……HPH）","L"
					PRINTFORMDW 或许是对自身技巧有了自信，妖梦抚慰着反翘肉棒的动作流畅得毫无滞涩
				CASE 2
					CALL HPH_PRINT,@"「嗯～……舔、啾HPH　啾噜、嗯姆……啾……HPH」","L"
					PRINTFORMDL 舌尖留下的唾液痕迹，被白瓷般的手掌均匀地推抹开来，仔细抚弄着肉棒
					PRINTFORMDW 与此同时，青涩少女那娇嫩的唇瓣一刻不停地啄吻着龟头，撩拨起带着背德感的征服快意……
				CASE 3
					PRINTFORML 「——欸？　很熟练吗？　啊……谢谢您」
					CALL HPH_PRINT,@"「本来就习惯了分心进行不同动作，所以被您这么一说HPH……啾HPH」","L"
					PRINTFORMDW 因夸奖红着脸的娇羞可爱模样，与并未停下吸吮侍奉肉棒的淫靡姿态——两者都完美地存在于眼前的少女身上……
			ENDSELECT
		ELSE
			SELECTCASE RAND:2
				CASE 0
					PRINTFORML 「嗯、啾……啊……对、对不起，%TEXTR("舌头/手指/")%好像没怎么用上……」
					PRINTFORML （咕……振作一点啊魂魄妖梦！至少两手进行不同动作这种事，你应该早就习惯了吧！）
					PRINTFORMW （要是总也进步不了，就暂时把用嘴挥刀的练习也加进锻炼里吧……！）
				CASE 1
					PRINTFORML 「……呼啊、嗯姆……呜……姆、姆呜……？」
					PRINTFORML （动作一旦不够完美，就会不由自主地转移注意力去补足……这跟同时二刀流的心得也许是相通的……）
					PRINTFORMDW 妖梦探寻肉棒的手指与舌头的协调，仿佛也在试探着自己目前的技巧极限
			ENDSELECT
		ENDIF
	;それ以外
	ELSE
		IF (ABL:技巧 > 3 && EXP:手淫経験 > 30) && (ABL:舌 > 2 && EXP:口淫経験 > 30) && RAND:3 == 0
			PRINTFORML 「——欸？　……什么……咕姆」
			PRINTFORMDL 尽管她侍奉时的厌恶感无疑是真实的，但经由侍奉磨练出的指技与舌技同样真实不虚
			PRINTFORMDW 坦率地给予称赞后，妖梦只是尴尬地别开视线，什么也没说
		ELSE
			SELECTCASE RAND:2
				CASE 0
					PRINTFORML 「哈？　%TEXTR("舌头/手指/")%没在动什么的……」
					PRINTFORML 「要求还真多呢……别忘了，我可是很不情愿地在做这件事哦」
				CASE 1
					PRINTFORML 「…………啾噜……呜呕……」
					PRINTFORML （又难吃又臭还黏糊糊的……好想快点去漱口洗手……）
			ENDSELECT
			PRINTFORMDW 虽然眉间的皱纹深得仿佛能夹进一张纸，但或许因为诚恳央求的缘故，她并没有用牙齿或指甲去伤人
		ENDIF
	ENDIF
ENDIF
;未記入
;CALLFORM M_KOJO_別人版_MESSAGE_COM_K23_{SELECTCOM}_1
RETURN 1

