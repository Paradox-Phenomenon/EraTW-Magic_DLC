;==================================================
;7,插入子宫口玩弄
;==================================================
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_别人版_MESSAGE_MESSAGECHECK_SCOM_K23_7
RETURN 0

@M_KOJO_别人版_MESSAGE_SCOM_K23_7
CALL M_KOJO_别人版_MESSAGE_SCOM_K23_7_1
RETURN 1
@M_KOJO_别人版_MESSAGE_SCOM_K23_7_1
;-------------------------------------------------
;记入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;时奸中
	IF FLAG:70
		PRINTFORMW
		RETURN 1
	;烂醉
	ELSEIF TCVAR:烂醉 == 1
		PRINTFORMW
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;记入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(TFLAG:50 + 500)
		IF TALENT:恋慕
			PRINTFORML 「哦、啊咕！？　这、这样做的话……要、要被压坏……」
			PRINTFORMDW 那仿佛要贯穿入子宫内的肉棒所带来的异样感觉、让妖梦翻起了白眼
		ELSE
			PRINTFORML 「哦……嘎！？　这、这么深的地方……绝对不行……！」
			PRINTFORMDW 妖梦对试图侵犯到子宫内部的肉棒所带来的违和感感到困惑
		ENDIF
		RETURN 1
	ENDIF

	;基本セット
	IF EXP:子宮口開発経験 > 50
		IF TALENT:恋慕
			;种付けプレス
			IF TEQUIP:TARGET:体位 == 1 && (BEDROOM(CFLAG:PLAYER:現在位置) || (BATHROOM() && ITEM:20))
				;精液量1200以上
				IF EX:膣内精液 >= 1200
					SELECTCASE RAND:3
						CASE 0
							CALL HPH_PRINT,@"「哦、啊……咕HPH 明明是、好不容易、才射进来的……咿咕、呜啊啊啊啊HPH」","L"
							PRINTFORMDL 被大量注入而膨胀的下腹部被%CALLNAME:PLAYER%的身体压扁、每次抽插都会从阴肉的缝隙中喷出精液
