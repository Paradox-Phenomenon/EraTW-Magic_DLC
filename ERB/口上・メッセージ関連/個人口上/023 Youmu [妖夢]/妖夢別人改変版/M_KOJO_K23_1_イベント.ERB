	;一緒に入ってくれた
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		IF CFLAG:318 == 1 || (MARK:23:反発刻印 == 1 && RAND:2 == 0) || MARK:23:反発刻印 > 1
			PRINTFORML 「……丁度身体を洗おうとは思っていたので」
			PRINTFORMDW 他意は無いとばかりにするすると衣服を脱いだ妖夢は、%CALLNAME:MASTER%には目もくれず浴場に入って行った……
		ELSEIF TALENT:恋慕
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「い、一緒にですかっ？　あ、ゎ……わ、私で良ければ、お供します……」
					PRINTFORMDW 湯船につかる前から半霊がのぼせたようにふらふらしている……
				CASE 1
					PRINTFORML 「これから湯浴みに？　でしたら私は……私もっ！？」
					PRINTFORMW 「ぅ、ぁ……は、はいぃ……では僭越ながら、お背中を……」
				CASEELSE
					PRINTFORM 「で、では……私はあっちで
						IF CFLAG:1 > 0
							PRINTFORML 服を脱いできますので……」
							PRINTFORMW 「――う！？　それはっ、全く以て、その通りなんですけどっ……！」
							PRINTFORMW 「幾らそういうコトの経験があったとしても、恥ずかしいものは恥ずかしいんですよぅ……」
						ELSE
							PRINTFORMDL 準備をしてきますので……」
							PRINTFORMDW そわそわと端の方へ移動した妖夢は半霊を盾にして服を脱ぎ始めた
							PRINTFORMW （意中の殿方に自ら肌を晒すには、並大抵の覚悟では……！！）
						ENDIF
			ENDSELECT
		ELSE
			PRINTFORML 「一緒に？　……まあ、ついでですし……すぐに上がるなら……」
			PRINTFORMW （……私って流されやすいのかしら……？）
		ENDIF
		RETURN 1
	ENDIF
	;その他
	PRINTFORML  
ENDIF
RETURN 1
