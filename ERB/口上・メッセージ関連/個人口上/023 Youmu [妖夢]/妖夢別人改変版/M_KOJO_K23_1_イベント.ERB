;==================================================
;相手からデートのお誘い
;基本恋慕以上で発生し、思慕の時は宴会への誘いのみのようだ
;==================================================
@M_KOJO_別人版_EVENT_K23_27(ARG,ARG:1)
;口上主はLOCAL
;ARG:1は目的地
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	SELECTCASE ARG
		;-------------------------------------------------
		CASE 0
		;誘い文句
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1
			IF TALENT:恋慕
				PRINTFORML 「%CALLNAME:MASTER%さん、この後ご予定はありますでしょうか？」
					;振られている状態
					IF CFLAG:23:2001 == 1
						PRINTFORMW 「差し障りなければ、私にお時間をいただければと……」
					ELSE
						PRINTFORMW 「ええと、よろしければ一緒にお出掛けしたいなぁ……なんて……」
					ENDIF
			ELSEIF TALENT:思慕
				PRINTFORMW 「もし%CALLNAME:MASTER%さんも参加されるなら、折角なのでご一緒できればと……」
			ENDIF
			RETURN 1
		ENDIF
		;-------------------------------------------------
		CASE 1
		;受けた
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1
			IF TALENT:恋慕
				IF CFLAG:23:2001 == 1
					PRINTFORML 「お付き合いいただけますか？　……お優しいのですね、ありがとうございます」
					PRINTFORMW （……それが憐れみだとしても……構わない）
				ELSE
					PRINTFORML 「ありがとうございます！　それでは早速参りましょう」
					PRINTFORMDW 弾んでいる半霊を見るに相当喜んでくれているようだ
				ENDIF
			ELSEIF TALENT:思慕
				PRINTFORML 「で、では始まるまで時間を潰していましょうか」
				PRINTFORMW （我ながら大胆な……大胆よね……？）
			ENDIF
			RETURN 1
		ENDIF
		;-------------------------------------------------
		CASE 2
		;断った
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1
			IF TALENT:恋慕
				IF CFLAG:23:2001 == 1
					PRINTFORML 「……そう、ですよね。図々しいお願いでした、申し訳ありません」
					PRINTFORMDW 妖夢は目を伏せると一歩%CALLNAME:MASTER%から距離を置いた……
				ELSE
					PRINTFORML 「う……唐突過ぎましたよね、どうか気になさらないで下さい」
					PRINTFORMW （少し……いや、かなり気が逸ってしまった……）
				ENDIF
			ELSEIF TALENT:思慕
				PRINTFORML 「ぁ、あー……行くにしても始まってからでいいですもんね……」
				PRINTFORMW （慣れない事はするべきじゃなかったかも……）
			ENDIF
			RETURN 1
		ENDIF
		;-------------------------------------------------
		CASE 3
		;部屋に誘われた
		;合意有、且つ欲求不満が高い場合に発生だろうか？
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1
			IF TALENT:恋慕
				IF CFLAG:23:2001 == 1
					PRINTFORML 「%CALLNAME:MASTER%さん、私の部屋にお越しになりませんか？」
					PRINTFORMW 「侘しい部屋ではありますが、お好きなように使っていただいて構いませんので……」
				ELSE
					PRINTFORML 「あああ、あの……わ、私の部屋にお越しになりませんか？」
					PRINTFORMW 「つまらない部屋ですけど、だからこそ却ってゆっくりお話しできるのではないかと……」
				ENDIF
			ENDIF
			RETURN 1
		ENDIF
		;-------------------------------------------------
		CASE 4
		;部屋に誘われたのを受けた
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1
			IF TALENT:恋慕
				IF CFLAG:23:2001 == 1
					PRINTFORML 「ご足労いただけるなんて光栄です」
					PRINTFORMW 「……ええ。お好きなように、使って下さい」
				ELSE
					PRINTFORML 「良かったぁ……お茶請けくらいは用意できますので、寛いでいかれて下さい」
					PRINTFORMW （部屋に着くまでに頭の中を整理しないと……）
				ENDIF
			ENDIF
			RETURN 1
		ENDIF
		;-------------------------------------------------
		CASE 5
		;部屋に誘われたのを断った
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1
			IF TALENT:恋慕
				IF CFLAG:23:2001 == 1
					PRINTFORML 「……そう、ですか」
					PRINTFORMW 「慎みを欠いた提案でした、お許し下さい」
				ELSE
					PRINTFORML 「う……わ、分かりました」
					PRINTFORMW 「あ、いえっ、私の方こそもっとご足労の甲斐がある場所にお誘いするべきでした……」
				ENDIF
			ENDIF
			RETURN 1
		ENDIF
	ENDSELECT
ENDIF
RETURN 1

;==================================================
;脱衣口上
;==================================================
@M_KOJO_別人版_EVENT_K23_28(ARG,ARG:1)
;口上主はTARGET
;ARGに脱がし方選択
;ARG:1（ARG=3の場合のみあり）地の文の反応
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	SELECTCASE ARG
		;-------------------------------------------------
		CASE 0
		;全裸にする
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1
			;時間停止時
			IF FLAG:70
			;通常
			ELSEIF TALENT:恋慕
				IF TALENT:処女
					PRINTFORMW 「――は、はい。暫しお待ち下さい」
					PRINTFORMW （信じられないほど恥ずかしいけど、%CALLNAME:MASTER%さんになら……）
					PRINTFORMDW ぎこちない動作で妖夢が脱衣を終えると、仄かに紅潮した白い肢体が%CALLNAME:MASTER%の前に晒された
				ELSEIF OUTROOF(CFLAG:現在位置)
					PRINTFORML 「えぇ！？　た、確かに汗その他諸々を気にする必要は無くなりますけど……」
					PRINTFORMW （それとはまた別の懸念が……誰か来たらどうしよう……！？）
				ELSE
					SELECTCASE RAND:2
						CASE 0
							PRINTFORML 「躊躇いなく殿方に肌を許す私を昔の自分が見れば、紛い物と断じて斬ってかかられるかもしれませんね」
							CALL HPH_PRINT,@"「ですが、こういう時は何も着ていない方が都合が良いですから……HPH」","W"
						CASE 1
							PRINTFORMDL %CALLNAME:MASTER%の意に沿い妖夢が身に付けた布地を手際よく脱いでいく
							PRINTFORMDW 目の前に晒された白磁の肌へ思わず伸ばした指が触れると、小さく声を上げた妖夢が恥ずかしそうに身を捩った
					ENDSELECT
				ENDIF
			ELSE
				PRINTFORML 「…………脱ぎますから、その視線をどうにかしてくれませんか」
				PRINTFORMW （何を考えていればそんな眼ができるのか……知りたくもないわ）
			ENDIF
			RETURN 1
		ENDIF
		;-------------------------------------------------
		CASE 1
		;下着姿にする
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1
			;時間停止時
			IF FLAG:70
			;通常
			ELSEIF TALENT:恋慕
				IF TALENT:処女
					PRINTFORMW 「――へ？　下着はそのままで？　わ、分かりました」
					PRINTFORMW （これはこれで恥ずかしいけど、全裸ではない分まだ辛うじて安心できる……）
				ELSEIF OUTROOF(CFLAG:現在位置)
					PRINTFORML 「え！？　ぁ……そ、そうですよね、ここで全裸はまずいですもんね」
					PRINTFORMW （下着があればまだ誰か来ても取り繕え……いや無謀では……？）
				ELSE
					SELECTCASE RAND:2
						CASE 0
							PRINTFORML 「あー……下着には特に拘りが無くて。お目汚しにならなければ良いのですが……」
							PRINTFORMW （どうしても動きやすさ重視になってしまう……周りはどうしてるのかしら？）
						CASE 1
							PRINTFORML 「…………」
							PRINTFORMDL %CALLNAME:MASTER%の要望通り下着だけの姿になった妖夢は、自らの身体を無言で見下ろしている……
							PRINTDATAW
								DATAFORM （自分で言うのもどうかと思うけど…………色気が足りない……！）
								DATAFORM （何故、今……幽々子様がお持ちの凄まじい下着の数々を思い出してしまったんだろう……）
							ENDDATA
					ENDSELECT
				ENDIF
			ELSE
				PRINTFORML 「……大層なご趣味ですね？　ふん……」
				PRINTFORMW （温情のつもり？　……ありえないか）
			ENDIF
			RETURN 1
		ENDIF
		;-------------------------------------------------
		CASE 2
		;半脱ぎ
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1
			;時間停止時
			IF FLAG:70
			;通常
			ELSEIF TALENT:恋慕
				IF TALENT:処女
					PRINTFORMW 「――少しはだける程度で？　えっと……こ、これくらいでいかがでしょう？」
					PRINTFORMW （気を遣って下さったのかな……？　ならこの機会に私も少しは落ち着かないと……）
				ELSEIF OUTROOF(CFLAG:現在位置)
					PRINTFORML 「ぅ……まあ、この程度ならほぼ着ていると言えなくもありませんか……」
					PRINTFORMW （乱れている部分は縺れて転んだ事にすれば……見付かっても誤魔化せるかも）
				ELSE
					SELECTCASE RAND:2
						CASE 0
							PRINTFORML 「少しやり辛い感は否めませんが……手早く身形を戻せるのは良い点ですよね」
							CALL HPH_PRINT,@"「ただあまり激しくされるのでしたら、ナニをしていたかバレちゃうかも……HPH」","W"
						CASE 1
							PRINTFORML 「むぅ……どの程度はだけるべきか、自分では中々に悩ましいところ」
							PRINTFORMW 「――こ、これでは三分の%TEXTR("一/二/")%脱ぎ？　やはり難しいですねこれ……」
					ENDSELECT
				ENDIF
			ELSE
				PRINTFORML 「……皴にしないで下さいよ」
				PRINTFORMW （汚されるくらいなら全裸の方がまだマシね……）
			ENDIF
			RETURN 1
		ENDIF
		;-------------------------------------------------
		CASE 3
		;パンツちょうだい
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1
			SELECTCASE ARG:1
				;-------------------------------------------------
				CASE 0
				;交換です
				;記入チェック（=0, 非表示、1, 表示）
				LOCAL:1 = 1
				;-------------------------------------------------
				IF LOCAL:1
					IF TALENT:恋慕
						PRINTFORML 「……そのぉ……もしよろしければ、私も%CALLNAME:MASTER%さんの下着が欲しかったり……」
						PRINTFORML 「あ、いや！　特にいただいた後の事は考えていないのですがっ、折角なので……」
						PRINTFORMW 「――そ、そうです！　こういう秘密は共有している方がより親密になれると思いませんか！？」
					ELSE
						PRINTFORML 「…………ふむ」
						PRINTFORML 「構いませんよ。そちらの下着と交換なら、ですが」
						PRINTFORMW （……少しは私の屈辱を味わってみればいい）
					ENDIF
					RETURN 1
				ENDIF
				;-------------------------------------------------
				CASE 1
				;OK（嬉々
				;記入チェック（=0, 非表示、1, 表示）
				LOCAL:1 = 1
				;-------------------------------------------------
				IF LOCAL:1
					IF TALENT:恋慕
						SELECTCASE RAND:2
							CASE 0
								PRINTFORML 「はい、承知しました。……あ、ですけど」
								PRINTFORML 「どうせお渡しするのなら、やはり綺麗に洗濯してある下着の方が良いですよね。次は……」
								PRINTFORMW 「――へ、履いた物でないと？　は、はあ……そういう事でしたら……」
							CASE 1
								PRINTFORML 「お譲りする事に異論はないのですが……私の下着など一体何に使われるんですか？」
								PRINTFORML 「人目に触れないよう保管するのは大変でしょうし、手直しして他の物にするとしても……」
								PRINTFORMDW 本当の用途を教えてもそれはそれで混乱されそうだ……
						ENDSELECT
					ELSE
						PRINTFORML 「…………はぁ」
						PRINTFORML 「引き下がる気が無いのは知ってますよ、ならこの問答はさっさと終わらせましょう。お好きにどうぞ」
						PRINTFORMW （狂人の思考を理解しようとするだけ無駄ね）
					ENDIF
					RETURN 1
				ENDIF
				;-------------------------------------------------
				CASE 2
				;OK（渋々
				;記入チェック（=0, 非表示、1, 表示）
				LOCAL:1 = 1
				;-------------------------------------------------
				IF LOCAL:1
					IF TALENT:恋慕
						PRINTFORML 「……え？　ぇ、えっと……」
						PRINTFORML 「……%CALLNAME:MASTER%さんがご所望でしたら……ど、どうぞ」
						PRINTFORMW （つい渡しちゃったけど、この後どうしよう……）
					ELSE
						PRINTFORML 「…………は？」
						PRINTFORML 「…………引く気もなさそうですね、何が良いんだか……」
						PRINTFORMW （今すぐこの時間が終わってくれるなら、喜んで譲ってあげるけど）
					ENDIF
					RETURN 1
				ENDIF
				;-------------------------------------------------
				CASE 3
				;嫌です
				;記入チェック（=0, 非表示、1, 表示）
				LOCAL:1 = 1
				;-------------------------------------------------
				IF LOCAL:1
					IF TALENT:恋慕
						PRINTFORML 「……？　……えﾞっ」
						PRINTFORMW 「いえ、それはちょっと……履く物が無くなっちゃいますし、そこは見逃していただけると……」
					ELSE
						PRINTFORML 「……はぁ？」
						PRINTFORMW 「自制と言う単語を覚えてはいかがでしょう。それとも恥に塗れすぎて何が恥かも分からなくなりましたか？」
					ENDIF
					RETURN 1
				ENDIF
				RETURN 1
			ENDSELECT
		ENDIF
	ENDSELECT
ENDIF
