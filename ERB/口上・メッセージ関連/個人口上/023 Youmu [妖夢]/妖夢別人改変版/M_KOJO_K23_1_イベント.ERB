;==================================================
;贈り物イベント
;==================================================
@M_KOJO_別人版_EVENT_K23_GIFT(ARG, GIFT_ID, 評価点, GIFT_NAME, SENSE)
#DIM GIFT_ID
#DIM 評価点
#DIMS GIFT_NAME
#DIMS SENSE
;---------------------------------------------------------------------------------------------------
;評価点       贈り物の評価点（1～999）,口上主があげた場合でも口上主の評価点
;GIFT_NAME    贈り物の名称
;SENSE        贈り物に設定された属性。STRCOUNT(SENSE, "ほげほげ/")を使うと特定の属性を判定できます。
;GIFT_ID      これ単体では使いません。以下の式内関数を使うとデータを抽出できます（こだわりたい人用）
;　GET_GIFTDATA(GIFT_ID, "回数")    貰った（あげた）回数
;　GET_GIFTDATA(GIFT_ID, "得点")    得点（1～999）,口上テンプレ内では用意されてます。
;　GET_GIFTDATA(GIFT_ID, "日付")    貰った（あげた）日付（1～9999）
;　GET_GIFTDATA(GIFT_ID, "場所")    買った場所（デートの行き先）
;　GET_GIFTDATA(GIFT_ID, "形容詞")  形容詞番号（贈り物_形容詞.erb参照）
;　GET_GIFTDATA(GIFT_ID, "本体")    本体番号（贈り物_本体.erb参照）
;--------------------------------------------------------------------------------------------------
;デート帰りに口上主があなたに贈り物を渡す（陥落や好感度に関わらず親密5以上から発生）
;評価点は701～999（渡すキャラ本人の評価）
;--------------------------------------------------------------------------------------------------
IF ARG == 1
	PRINTFORML 「%CALLNAME:MASTER%さん、よろしければこちらを」
		IF TALENT:恋慕
			PRINTFORML 「日頃のお礼……とするには全然足りないんですけど」
			PRINTFORMW 「こういった機会にお渡ししていかないと、お返ししきれなくなってしまいますから……」
			PRINTFORML
			PRINTFORMDL %CALLNAME:MASTER%が感謝を伝えると、妖夢は緊張を解いて安堵の息を吐いた
			PRINTFORMW 「そう仰っていただけて光栄です」
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 「もしお気に召しましたら、是非その旨をお聞かせ下さい」
						PRINTFORMW 「次は更に吟味して、もっと気に入っていただける品をご用意しますので！」
					CASE 1
						PRINTFORML 「あ……ですがもしご趣味に合わなければ遠慮なくご指摘下さい」
						PRINTFORMW 「次はちゃんと%CALLNAME:MASTER%さんのお気に召す品を選べるよう、勉強しておきますので！」
				ENDSELECT
		ELSE
			PRINTFORML 「え、っと……確か%GIFT_NAME%、だったと思います」
			PRINTFORMW 「こういった事は不得手なので、ちゃんとしたお礼になっていれば良いのですが……」
		ENDIF
	RETURN 1
;--------------------------------------------------------------------------------------------------
;一日の終わりに今日貰った贈り物を大事にする（700点以上）
;--------------------------------------------------------------------------------------------------
ELSEIF ARG == 2
	;IF STRCOUNT(SENSE, "かわいい/")
	;	PRINTFORMW 「かわいいプレゼントを貰っちゃった」
	;ELSEIF 評価点 >= 800
	;	PRINTFORMW 「とっても素敵なプレゼントを貰っちゃった」
	;ELSE
	;	PRINTFORMW 「素敵なプレゼントを貰っちゃった」
	;ENDIF

	IF TALENT:恋慕
		PRINTFORML 「こんなに素敵な物を、その上%CALLNAME:MASTER%さんからいただけるなんて！」
		PRINTFORML 「幸せすぎて何時まででも眺めていられそう……」
		PRINTFORMW 「ああ、見れば見るほど……」
		PRINTFORML
		PRINTFORMW 「うふふ……えへへ……ふへへ……」
		PRINTFORMW 「――へっ、外が薄っすら明るく！？　す、すぐ寝ないと……！！」
	ELSE
		PRINTFORML 「まさかこんなに素晴らしい物をもらってしまうとは……」
		PRINTFORMW 「……適当そうでいて、しっかり見てくれてはいるんですね」
		PRINTFORMW 「…………」
		PRINTFORMW 「いけない、そろそろ寝なきゃ……」
	ENDIF
	RETURN 1
;--------------------------------------------------------------------------------------------------
;一日の終わりに今日貰った贈り物をお気に入りにする（↑の大事にするから続き）（700点以上かつ最高得点）
;--------------------------------------------------------------------------------------------------
ELSEIF ARG == 3
	;IF STRCOUNT(SENSE, "身につける/")
	;	PRINTFORMW 「明日からこれを付けて行こうっと」
	;ELSE
	;	PRINTFORMW 「明日からこれを持って行こうっと」
	;ENDIF

	IF TALENT:恋慕
		PRINTFORML 「……よしよし、これで安心して持ち歩けるなら睡眠時間など安いものです」
		PRINTFORMW 「万一落としてあの店主の売り物にでもされたら、今度こそ叩き斬ってしまうでしょうし……」
	ELSE
		PRINTFORML 「……や、やっぱりもう少しだけ」
		PRINTFORMW 「むむぅ……これほどの逸品が……」
	ENDIF
	RETURN 1
;--------------------------------------------------------------------------------------------------
;一日の終わりに今日貰った贈り物をとりあえず保管する（400～699点）
;--------------------------------------------------------------------------------------------------
ELSEIF ARG == 4
	IF TALENT:恋慕
		PRINTFORML 「ふふっ、%CALLNAME:MASTER%さんからの贈り物……」
		PRINTFORML 「……私には普通のお土産にしか見えませんが」
		PRINTFORMW 「今日という日を形にした物だと考えると、なんだかすごく価値があるような気がします」
		PRINTFORMW 「失くさないようにちゃんとしまっておかないと……」
	ELSE
		PRINTFORML 「%CALLNAME:MASTER%さんからもらったお土産……」
		PRINTFORML 「多分良い物……なんだと思う」
		PRINTFORMW 「私が価値に聡ければ、これの意味する事を訳なく汲めたのでしょうか？」
		PRINTFORMW 「……一先ずしまっておこう」
	ENDIF
	RETURN 1
;--------------------------------------------------------------------------------------------------
;一日の終わりに今日貰った贈り物をこっそり質に入れる（400点未満）
;--------------------------------------------------------------------------------------------------
ELSEIF ARG == 5
	IF TALENT:恋慕
		PRINTFORMW 「……だ、ダメです」
		PRINTFORML 「私の部屋では飾るにしても添えるにしても悪目立ちしてしまう……」
		PRINTFORMW 「かといって身に付けている訳にも……」
		PRINTFORML
		PRINTFORML 「うぅ……申し訳ありません、%CALLNAME:MASTER%さん」
		PRINTFORMW 「これは私には過ぎたる物のようです……」
	ELSE
		PRINTFORML 「あれから必死に使い道を考えてみたけど……」
		PRINTFORML 「……さっぱり思いつかない」
		PRINTFORMW 「…………」
		PRINTFORMW 「収納の肥やしにしてしまうくらいなら、次の買い出しの時にでも……」
	ENDIF
	RETURN 1
ENDIF
RETURN 1


;==================================================
;ムシバトル
;ムシバトルの口上は少し特殊で、PRINTを使うのではなく、
;台詞一行のみをRESULTSに入れてください
;ムシの名前は %MUSHI_NAME% で表示できます
;ムシの名前の最長はアレキサンドラトリバネアゲハの全角14文字です
;文字数制限があります。はみ出ないように気をつけてください
