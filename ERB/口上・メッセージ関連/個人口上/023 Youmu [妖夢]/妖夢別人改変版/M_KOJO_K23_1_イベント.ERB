;==================================================
;お仕事中
;==================================================
@M_KOJO_別人版_EVENT_K23_13(ARG,ARG:1)
;口上主はTARGET
;ARG:1に残っている仕事量
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------

IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;仕事開始（職場へ移動する）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		;うふふ中断
		IF TFLAG:102 > 1
			IF TALENT:恋慕
				SELECTCASE RAND:3
					CASE 0
						PRINTFORMW 「ぁ、え？　……ご、ごめんなさい、かい出しに……」
					CASE 1
						PRINTFORMW 「はぁ、は、あ……いかないと、お屋敷の、食糧が……」
					CASE 2
						PRINTFORMW 「うそっ、時間……わたし……んんっ……」
				ENDSELECT
			ELSE
				PRINTFORMW 「……！　かっ、買い出しの時間ですので私はこれで……」
			ENDIF
			PRINTFORMDW 急いで身形を整えた妖夢は\@ TALENT:恋慕 ? 、疼く身体を引き摺って商家町へと向かった # そそくさと商家町へ向かって行った \@
		
		;ブチギレ
		ELSEIF CFLAG:318 == 1
			PRINTFORML 「…………」
			PRINTFORMDW 妖夢は何も言わず足早に商家町へと向かって行った……
		
		;反発刻印有
		ELSEIF (MARK:23:反発刻印 == 1 && RAND:2 == 0) || MARK:23:反発刻印 > 1
			PRINTFORML 「……私はこれで」
			PRINTFORMDW 妖夢はそれだけ告げると、大八車を押しながら商家町へと向かった
		
		;荒天時に分岐できるだろうか
		ELSEIF GROUPMATCH(TIME:5,5,9,13)
			PRINTFORML 「うっ、この天気……道中も鍛錬と思えば……！」
			PRINTFORMDW ぴしゃりと頬を叩いて気合を入れ、妖夢は荒天の中商家町へと向かった
		ELSEIF TALENT:恋慕
			PRINTFORML 「あっ、こんな時間……すみません、買い出しがあるので……」
			PRINTFORMDW 妖夢は申し訳なさそうに頭を下げると、大八車を押して商家町へと向かって行った
		ELSE
			PRINTFORML 「そろそろ買い出しに行かないと……失礼しますね」
			PRINTFORMDW 妖夢はどこから用意したのか、大八車を押しながら商家町へと向かった
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;業務中
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		SELECTCASE RAND:7
			CASE 0
				PRINTFORMDW 荷物を載せた半霊が忙しなく往復している
			CASE 1
				PRINTFORMW 「お米はよし、後は%TEXTR("肉/鳥肉/")%と%TEXTR("野菜/果物/")%と%TEXTR("茶菓子/お酒/")%と――」
			CASE 2
				PRINTFORMW 「はい、支払いの方はいつもと同じように――」
			CASE 3
				PRINTFORMW 「そこにある分は荷台にお願いします」
			CASE 4
				PRINTFORMW 「はい、残りはまた後日受取に来ますので――」
			CASE 5
				PRINTFORMW 「あれ？　数が合わない……すみません、もう一度確認を――」
			CASEELSE
				PRINTFORMW 「えっ、差し入れ？　ありがとうございます、一先ずそこの半霊に――」
		ENDSELECT
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;仕事終了
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		PRINTDATAW
			DATAFORM 「よし、これで全部……終わりましたね」
			DATAFORM 「リストの抜けは……無いですね」
			DATAFORM 「積荷の固定は……問題無し」
			DATAFORM 「支払いはこれで……大丈夫」
		ENDDATA
		;手伝った
		IF TCVAR:23:手伝った量
			;ブチギレ
			IF CFLAG:318 == 1
				PRINTFORML 「…………」
			
			;反発刻印有
			ELSEIF (MARK:23:反発刻印 == 1 && RAND:2 == 0) || MARK:23:反発刻印 > 1
				PRINTFORML 「……ありがとうございました」
			
			;早く終わった
			ELSEIF TIME < 960
				IF TALENT:恋慕 && RAND:2 == 0
					PRINTFORM 「%CALLNAME:MASTER%さんと二人でなら“これしきの雑務”と啖呵も切れそうです
				ELSEIF TALENT:思慕 && RAND:2 == 0
					PRINTFORM 「一人の時より随分と楽をさせていただけましたよ
				ELSE
					PRINTFORM 「おかげで首尾良く片付きましたよ
				ENDIF
				PRINTFORML 、ありがとうございました！」
			ELSE
				PRINTFORML 「%TEXTR("手伝って/お力添え/")%いただき、ありがとうございました」
			ENDIF
			PRINTFORMDW 妖夢は深々と%CALLNAME:MASTER%にお辞儀をした
		;手伝ってない
		ELSE
			PRINTFORMDW 仕事を終えた妖夢は軽く体をほぐしている
		ENDIF
		RETURN 1
	ENDIF
	;その他
	PRINTFORML  
ENDIF
RETURN 1

