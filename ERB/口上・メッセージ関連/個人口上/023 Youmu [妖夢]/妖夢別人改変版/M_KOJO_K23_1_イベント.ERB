;==================================================
;お仕事中
;==================================================
@M_KOJO_別人版_EVENT_K23_13(ARG,ARG:1)
;口上主はTARGET
;ARG:1に残っている仕事量
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------

IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;仕事開始（職場へ移動する）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		;中断
		IF TFLAG:102 > 1
			SELECTCASE RAND:3
				CASE 0
					PRINTFORMW 「啊，诶？……抱歉，走神了……」
				CASE 1
					PRINTFORMW 「呀，呀，啊……不赶快的话，家里的食物……」
				CASE 2
					PRINTFORMW 「抱歉，时间……我……嗯嗯……」
			ENDSELECT
			PRINTFORMW 妖梦匆匆整理了一下形象，拖着的身体朝商家町走去

		;发飙
		ELSEIF CFLAG:318 == 1
			PRINTFORML 「…………」
			PRINTFORMW 妖梦默不作声，快步走向商家町……

		;有反発刻印
		ELSEIF (MARK:23:反発刻印 == 1 && RAND:3 == 0) || (MARK:23:反発刻印 > 1 && RAND:3 != 0)
			PRINTFORML 「……就这样了」
			PRINTFORMW 妖梦仅此一句，推着拉货车向商家町走去

		;恶劣天气时分歧是否可行
		ELSEIF GROUPMATCH(TIME:5,5,9,13)
			PRINTFORML 「唔，这天气……如果把路上的艰难当作锻炼的话……！」
			PRINTFORMW 妖梦扑哧一声拍打脸颊，鼓舞精神，奋力走向商家町
		ELSE
			PRINTFORML 「差不多该去购物了……告辞了」
			PRINTFORMW 妖梦不知从哪里弄来的拉货车，推着它朝商家町走去
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;工作中
	;填写检查（=0, 隐藏，1, 显示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		SELECTCASE RAND:5
			CASE 0
				PRINTFORMW 载货的半灵来回匆忙地穿梭着
			CASE 1
				PRINTFORMW 「大米OK，还有%TEXTR("肉/鸡肉/")%、%TEXTR("蔬菜/水果/")%和%TEXTR("茶点/酒/")%……」
			CASE 2
				PRINTFORMW 「好的，付款方式还是像往常一样……」
			CASE 3
				PRINTFORMW 「剩下的货物请放在货车上」
			CASE 4
				PRINTFORMW 「好的，剩下的我会在稍后过来取的……」
		ENDSELECT
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;工作结束
	;填写检查（=0, 隐藏，1, 显示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		PRINTDATAW
			DATAFORM 「好了，全部搞定……」
			DATAFORM 「清单没有漏项……」
			DATAFORM 「货物固定得……没有问题」
		ENDDATA
		;帮忙了
		IF TCVAR:23:手伝った量
			;发飙
			IF CFLAG:318 == 1
				PRINTFORML 「…………」
			
			;有反発刻印
			ELSEIF (MARK:23:反発刻印 == 1 && RAND:3 == 0) || (MARK:23:反発刻印 > 1 && RAND:3 != 0)
				PRINTFORML 「……谢谢你」
			
			;提前完成
			ELSEIF TIME < 960
				PRINTFORML 「多亏有你，一切都顺利解决了，谢谢！」
			ELSE
				PRINTFORML 「感谢你的帮助！」
			ENDIF
			PRINTFORMW 妖梦深深地向%CALLNAME:MASTER%鞠了一躬
		;没帮忙
		ELSE
			PRINTFORMW 完成工作后，妖梦轻松地舒展了一下身体
		ENDIF
		RETURN 1
	ENDIF
	;その他
	PRINTFORML  
ENDIF
RETURN 1

