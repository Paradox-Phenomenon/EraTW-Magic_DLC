@M_KOJO_別人版_SPEVENT_K23_1(ARG,ARG:1)
;口上主はTARGET
;地の文表示
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	PRINTFORML
	PRINTFORMDW 触れていた唇がどちらからともなく離れる
	PRINTFORMDW あまりに自然な動作で口付けられた%CALLNAME:MASTER%は、数瞬何をされたのか理解が及ばなかった
	PRINTFORMDW だがそれは相手も同じようで、妖夢は未だ熱に浮かされたようにぼんやりと%CALLNAME:MASTER%を見詰めている
	PRINTFORML
	PRINTFORMW 「……ぇ、あ……私…………っ？！？」
	PRINTFORML
	PRINTFORMDW 徐々に自分が何をしたのか気付き始めた妖夢は顔を真っ赤にして一歩後ずさった
	PRINTFORML
	PRINTFORML 「すすすすすみません%CALLNAME:MASTER%さん！！　こんな、不意打ちめいた事を……！」
	PRINTFORML 「あ、あのですね、デートが終わってしまうと思ったら勝手に身体が動いたと言いますか、我慢できなかったと言いますか」
	PRINTFORMW 「や、ちがっ……違わないんですけど……！」
	PRINTFORML
	PRINTFORMDL そう捲し立て終える頃には隣の半霊が地面でのぼせ上ったかの如く伸びていた
	PRINTFORMDW 果たしてあれは大丈夫なんだろうか……
	PRINTFORML
	PRINTFORML 「あああああぁ……」
	PRINTFORMW 「ご、ごめんなさいぃぃ……」
	PRINTFORML
	PRINTFORMDW 妖夢はよろよろと半霊を路傍まで引き摺って行くと、そこで暫く頭を抱えて蹲っていた
	PRINTFORML
	PRINTFORMW 「もっと場所とか雰囲気とか、色々あった筈なのにぃ……！」
	;キスをキャンセルしたい場合は以下を開放
	;TCVAR:キスキャンセル = 1
ENDIF
RETURN 1

;==================================================
;デート帰りに告白（恋人が付く）
;==================================================
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_別人版_SPEVENT_MESSAGECHECK_K23_2
RETURN 0

@M_KOJO_別人版_SPEVENT_K23_2(ARG,ARG:1)
;口上主はTARGET
;地の文表示
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;告白内容
	;この告白内容表示後に受けるかどうかの選択分が表示されます
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 0
		;初回
		IF FIRSTTIME("告白")
			PRINTFORMW 「%CALLNAME:MASTER%さん」
			PRINTFORMW 「少しだけお時間をいただいてもよろしいでしょうか？」
			PRINTFORML
			PRINTFORMDL いつの間にか立ち止まっていた妖夢の声に%CALLNAME:MASTER%は釣られて振り返る
			PRINTFORMDW 語調こそ軽いがこちらに向けられた蒼い瞳は何処までも真剣だった
			PRINTFORML
			PRINTFORMW 「……ありがとうございます」
			PRINTFORML 「私は隠し事が下手なので、貴方にはもう筒抜けなのかもしれません」
			PRINTFORMW 「ですがどうしても、この気持ちは自分の言葉で伝えたいんです」
			PRINTFORML
			PRINTFORMDL そこで妖夢は言葉を切ると深く息を吸い込み、静かに吐き出す
			PRINTFORMDW 彼女が次に口を開くまでの時間が、酷く長く感じられた
			PRINTFORML
			PRINTFORMW 「好きです、%CALLNAME:MASTER%さん」
			PRINTFORML
			PRINTFORMW 「今日こうしてご一緒できて、隣にいられて私はずっと幸せでした」
			PRINTFORMW 「だからでしょうか……この先もずっと貴方の隣にいられたらと、そう思ってしまったんです」
			PRINTFORML
			PRINTFORMW 「身勝手だとは承知しています」
				IF TALENT:66:恋慕
					PRINTFORMW 「……私など足元にも及ばないほど素敵な方が%CALLNAME:MASTER%さんに想いを寄せている事も」
				ELSE
					PRINTFORMW 「……%CALLNAME:MASTER%さんの周りの方々と比べて、私が女性的な魅力に乏しい事も」
				ENDIF
			PRINTFORMW 「それでもこの気持ちだけは伝えておかないと、いつか絶対に後悔してしまうから」
			PRINTFORML
			PRINTFORMW 「……%CALLNAME:MASTER%さんの気持ちを、聞かせていただけませんか？」
		;二回目以降
		ELSE
			PRINTFORMW 「%CALLNAME:MASTER%さん、ごめんなさい……」
			PRINTFORML
			PRINTFORMDW 歩調を緩めていた妖夢が不意に後ろから%CALLNAME:MASTER%の袖を引く
			PRINTFORMDW それは一歩進めば離れてしまうほど些細な力だったが、%CALLNAME:MASTER%が歩みを止めるには十分すぎた
			PRINTFORML
			PRINTFORMW 「もう断られているのに……未練がましすぎて自分でも笑えてくるんです」
			PRINTFORMW 「でも……それでも、貴方への想いを絶ち斬るなんて、私には……っ」
			PRINTFORML
			PRINTFORMW 「好きです、%CALLNAME:MASTER%さん……どうしようもないくらい」
			PRINTFORML
			PRINTFORMW 「どうか……お傍にいさせて下さい」
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;告白オッケー（恋人が付く）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		PRINTFORMW 「え……い、今……夢じゃ……ないんですよね……？」
		PRINTFORML
		PRINTFORMDW %CALLNAME:MASTER%は呆然とする妖夢に一歩歩み寄ると、その肩をそっと抱き寄せた
		PRINTFORMDW 腕の中に収まった華奢な体躯が小さく震える
		PRINTFORML
			;初回
			IF FIRSTTIME("返答")
				PRINTFORMW 「……きっと断られると思っていました」
				PRINTFORMW 「私のような未熟者では%CALLNAME:MASTER%さんに相応しくないと……」
			ELSE
				PRINTFORMW 「……本当は怖かったんです」
				PRINTFORMW 「まだ遊びに誘っていただける関係さえ壊してしまうんじゃないかって……」
				CFLAG:23:2001 = 2
			ENDIF
		PRINTFORMW 「けれど貴方は、そんな不安もこうして優しく抱き留めて下さるんですね……」
		PRINTFORML
		PRINTFORMDW 控えめに%CALLNAME:MASTER%の背に回された腕に力が籠もる
		PRINTFORML
		PRINTFORMW 「%CALLNAME:MASTER%さん……ずっとお慕いしていました」
		PRINTFORML
		PRINTFORMDW 胸元から微かに聞こえ始めた嗚咽に、%CALLNAME:MASTER%はその半人半霊の少女を強く抱き締めた
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;告白失敗
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		;初回
		IF FIRSTTIME("返答")
			PRINTFORMW 「…………そう、ですよね」
			PRINTFORMW 「いえ、大丈夫です。私では貴方に吊り合えないと、分かっていましたから」
			PRINTFORML
			PRINTFORML 「ただ%CALLNAME:MASTER%さんに知っておいて欲しかったんです」
			PRINTFORMW 「私の気持ちを」
			PRINTFORML
			PRINTFORMDW 気丈にも笑顔を浮かべながら、妖夢は%CALLNAME:MASTER%に感謝を告げた
			PRINTFORMDW %CALLNAME:MASTER%はその眦に浮かんだ涙を、直視する事ができなかった
			CFLAG:23:2001 = 1
		;二回目以降
		ELSE
			PRINTFORMW 「…………当然ですよね」
			PRINTFORMW 「こんなしつこい女、拒まれて当然です」
			PRINTFORML
			PRINTFORML 「だからそんな顔をなさらないで下さい」
			PRINTFORMW 「%CALLNAME:MASTER%さんには、何の非もないんですから」
			PRINTFORML
			PRINTFORMDW そう言って妖夢は気丈にも笑顔を浮かべてみせた
			PRINTFORMDW 見覚えのあるその表情は、いつか見たそれよりもずっと悲痛だった
		ENDIF
		RETURN 1
	ENDIF
ENDIF
RETURN 1

