	;反発刻印3>2レベルダウンイベント
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		PRINTFORML 「――ッ」
		PRINTFORMDW 鋭い風切り音が%CALLNAME:MASTER%の鼓膜を震わせる
