@M_KOJO_別人版_SPEVENT_K23_3(ARG,ARG:1)
;口上主はTARGET
;地の文表示
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;通常帰宅
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 0
		IF TCVAR:泥酔 == 1
			PRINTFORML
		ELSEIF CFLAG:318 == 1
			PRINTFORML 「…………」
			PRINTFORMDW 妖夢は何も告げず足早に%CALLNAME:MASTER%から離れて行った……
		ELSEIF (MARK:23:反発刻印 == 1 && RAND:2 == 0) || MARK:23:反発刻印 > 1
			PRINTFORML 「……それでは」
			PRINTFORMDW 妖夢はそれだけ告げると静かに%CALLNAME:MASTER%から離れて行った……
		ELSEIF TALENT:恋慕
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「%CALLNAME:MASTER%さん、今日はありがとうございました」
						;振られている状態
						IF CFLAG:23:2001 == 1
							PRINTFORMW 「……また、私は誘っていただけますか？」
						ELSE
							PRINTFORMW 「ふふっ……次の機会が待ち遠しくなってしまいますね」
						ENDIF
				CASE 1
					IF CFLAG:23:2001 == 1
						PRINTFORML 「……%CALLNAME:MASTER%さん、ありがとうございました。貴重なお時間をいただけただけで、私は嬉しいです」
					ELSE
						PRINTFORML 「楽しい時間はあっという間です……名残惜しいですが……」
					ENDIF
						PRINTFORMDW 妖夢は%CALLNAME:MASTER%の掌に控えめに添えていた\@ CFLAG:23:2001 == 1 ? 指 # 手 \@をゆっくりと離した
				CASE 2
					PRINTFORML 「%CALLNAME:MASTER%さんは今日のデートはいかがでしたか？」
						IF CFLAG:23:2001 == 1
							PRINTFORML 「……私は、ずっと幸せでしたよ。この時間が終わってしまう事が、怖いくらいに」
							PRINTFORMDW 儚げに微笑した妖夢は%CALLNAME:MASTER%から一歩下がると、静かに頭を下げた
						ELSE
							PRINTFORML 「え、私は……た、多分顔に出てしまっていますので」
							PRINTFORMDW %CALLNAME:MASTER%が覗き込むと、妖夢は顔を真っ赤にして緩んだ口元を隠してしまった
						ENDIF
			ENDSELECT
		ELSEIF TALENT:思慕
			SELECTCASE RAND:2
				CASE 0
					PRINTFORML 「こういう機会も良いものですね、ありがとうございました」
					PRINTFORMW 「……またご一緒できたら嬉しいです」
				CASE 1
					PRINTFORML 「いい気分転換になりましたよ、ありがとうございました」
					PRINTFORMW （%CALLNAME:MASTER%さんにも楽しんでいただけたかな……？）
			ENDSELECT
		ELSE
			PRINTFORML 「ええと……ありがとうございました……？」
			PRINTFORMW （結局、よく分からないまま付いて行ってしまった……）
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;反発刻印消去イベント
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		PRINTFORML 「……そうですね、%CALLNAME:MASTER%さんの謝意は伝わりました」
		PRINTFORMDL 妖夢は表情から険を抜き、小さく溜息を吐いた
		PRINTFORMW 「これからは、あまりからかいすぎないで下さいね？」
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;反発刻印2>1レベルダウンイベント
	;記入チェック（=0, 非表示、1, 表示）
