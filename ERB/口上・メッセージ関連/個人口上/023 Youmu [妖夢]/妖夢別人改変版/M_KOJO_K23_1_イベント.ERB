		RETURN 1
	ELSEIF CFLAG:318 == 1
		PRINTFORML 「…………」
		PRINTFORMDW 妖夢は何も告げず足早に去って行った……
		RETURN 1
	ELSEIF (MARK:23:反発刻印 == 1 && RAND:2 == 0) || MARK:23:反発刻印 > 1
		PRINTFORML 「……それでは」
		PRINTFORMDW 妖夢は淡々と頭を下げると足早に立ち去った
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;通常帰宅
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		IF CFLAG:うふふ
			;うふふ中に眠くて帰る
			IF TALENT:恋慕
				PRINTFORML 「……ぁ、うぇっ！？　こ、こんな時間……！」
				PRINTFORMW 「申し訳ありません、%CALLNAME:MASTER%さん……流石に戻らないと明日が怖いので……」
			ELSE
				PRINTFORML 「……っ！　じ、時間ですから、私はこれで……」
				PRINTFORMDW 妖夢は身形を整えるとそそくさと去って行った……
			ENDIF
		ELSE
			IF TALENT:恋慕
				PRINTFORML 「あっ、もうこんな時間……私、そろそろお暇しますね」
				PRINTFORML 「おやすみなさい、%CALLNAME:MASTER%さん」
				PRINTFORMDW 妖夢は半霊と共に%CALLNAME:MASTER%へ深く一礼して去って行った
			ELSEIF TALENT:思慕
				PRINTFORML 「時間も遅いので、私はこれで……失礼します」
				PRINTFORMDW 妖夢は時折%CALLNAME:MASTER%の方を窺いながら去って行った
			ELSE
				PRINTFORML 「時間も遅いので、私はこれで」
				PRINTFORMDW 妖夢は%CALLNAME:MASTER%に軽く会釈して去って行った
			ENDIF
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;デート中帰宅＠TW映姫口上参考
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		IF CFLAG:現在位置 == OMANEKIBEYA()
			IF CFLAG:うふふ
				IF CFLAG:衰弱
					;うふふ中に疲れて帰る
					PRINTFORML 「す、すみません……体力が、もう……」
					PRINTFORMDW 疲弊しきった妖夢は布団に倒れ込むとすぐに寝息を立て始めた……
				ELSE
					;うふふ中に眠くて帰る
					PRINTFORML 「……ぁ、うぇっ！？　こ、こんな時間……！」
					PRINTFORMW  「申し訳ありません、%CALLNAME:MASTER%さん……流石にこれ以上は明日が怖いので……」
				ENDIF
			ELSE
				PRINTFORML 「楽しい時間はあっという間ですね……残念ですが、そろそろお開きにしないと」
				PRINTFORMW 「%CALLNAME:MASTER%さんも明日に響かない内にお休み下さい」
				;泊まれる、そのまま持ってきてしまったがこちらでも定義できるだろうか
				SIF !TCVAR:(CFLAG:MASTER:お招き):連泊禁止 && NEMUKE() < 720
					PRINTFORMW 「……その、ご覧の通りの部屋ですので、もう一組布団を敷くくらいなら造作もないんですけど……」
			ENDIF
		ELSE
			IF CFLAG:うふふ
				IF CFLAG:衰弱
					PRINTFORML 「す、すみません……体力が、もう……」
						IF TALENT:恋慕
							PRINTFORMW （我ながら、情けない……もっと体力を付けないと……）
						ELSE
							PRINTFORMW （つ、使い潰されるところだった……！）
						ENDIF
				ELSEIF TALENT:恋慕
					PRINTFORML 「……ぁ、うぇっ！？　こ、こんな時間……！」
					PRINTFORMW 「申し訳ありません、%CALLNAME:MASTER%さん……流石に戻らないと明日が怖いので……」
				ELSE
					PRINTFORML 「……っ！　じ、時間ですから、私はこれで……」
					PRINTFORMDW 妖夢は身形を整えるとそそくさと去って行った……
				ENDIF
			ELSE
				PRINTFORMW 「あっ、時間が……」
					IF TALENT:恋慕
						PRINTFORML 「申し訳ありません、そろそろ戻らないといけませんので……」
						PRINTFORMW 「%CALLNAME:MASTER%さん、今日はご一緒させていただきありがとうございました」
					ELSE
						PRINTFORML 「もう遅いので、私はこれで失礼します」
						PRINTFORMW 「%CALLNAME:MASTER%さんも気を付けてお帰り下さい」
					ENDIF
			ENDIF
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;玄関先でお見送り（キャラの自宅位置、またはキャラの部屋でデート終了）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		IF TALENT:恋慕
			PRINTFORML 「ここまでしていただけるなんて……自分が使用人である事を忘れてしまいそうです」
			PRINTFORMW 「……%CALLNAME:MASTER%さん、今日は本当にありがとうございました」
			PRINTFORMDW 妖夢は%CALLNAME:MASTER%へ照れくさそうに小さく手を振った
		ELSE
			PRINTFORML 「送っていただけるとはなんだか恐縮です……」
			PRINTFORMW 「%CALLNAME:MASTER%さん、今日はありがとうございました」
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;デート終了時に部屋に来ないかと誘う（～から部屋に来ないかと誘われた）
	;（来訪キャラのみ,自宅が無いキャラでも発生します）
	;発生条件：恋慕or愛人、溜まってる度が55～85％以上(素質：羞恥心で変化)
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 4
		PRINTFORML 「え、えーと……少しお疲れではありませんか？」
		PRINTFORMW 「%CALLNAME:MASTER%さんのご都合さえつけば、私の部屋でご休憩されていっては……」
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;部屋に来ないか→「行く」を選択（～に誘われるまま、【MASTER】は【TARGET】の部屋へと向かった……）
	;（これが発生すると十中八九押し倒されます）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 5
		PRINTFORML 「大それたおもてなしはできませんが、遠慮なく寛がれて下さいね」
		CALL HPH_PRINT,@"「それでは、布団を準備しますので……HPH」","W"
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;部屋に来ないか→「やめとく」を選択（～は心なしか寂しそうだ……）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 6
		PRINTFORMW 「そうですか……ご予定があるなら無理強いはできませんね」
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;今夜は帰りたくないと言い出す（～は今夜は帰りたくないと言い出した…）
	;（来訪キャラの帰宅時に欲求不満と欲望が高いと発生）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 7
		IF TALENT:恋慕
			PRINTFORML 「立場上こんな事を言うのはまずいと分かってはいるのですが……」
			PRINTFORMW 「……今日は、もう少し%CALLNAME:MASTER%さんとご一緒したいんです」
		ELSE
			PRINTFORML 「……%CALLNAME:MASTER%さん、一晩だけ泊めていただけないでしょうか？」
			PRINTFORMW 「ちょっとこの辺りに用事がありまして、宿が必要で……」
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;今夜は帰りたくない→「泊める」を選択（～は【MASTERの自室】に泊まっていくことになりました）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 8
		IF TALENT:恋慕
			PRINTFORML 「あ……ありがとうございます！」
			PRINTFORMW 「他の幽霊が上手く回してくれるので、お屋敷の仕事なら大丈夫です……きっと」
		ELSE
			PRINTFORML 「よろしいんですか？　助かりました……」
			PRINTFORMW 「これで私もようやく……い、いえ、こちらの話です」
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;今夜は帰りたくない→「泊めない」を選択、または家主が居る（【MASTER】は丁重に断った）
	;（家主が居る＝MASTERの私室に他のキャラの私室を設定している）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
