;==================================================
;一日の終了時(AFTERTRAニーの前)、面識がなければ呼び出されない
;==================================================
@M_KOJO_別人版_EVENT_K23_31(ARG,ARG:1)
;口上主はTARGET
;ARGは会ってない日数
;何日以上会ってなかったら愚痴を言うとかできます
;CFLAG:オナバレで分岐入れてもよさそう
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;今日会っていない
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG
		;口上を表示する前の誰のものか判別するための発生文です,変更したい場合は削除した上で独自に作成してください
		;CALL EVENTEND_TSUBUYAKI
		IF !MARK:反発刻印
			IF TALENT:恋慕
				;半月
				IF ARG == 15
					CALL EVENTEND_TSUBUYAKI
					PRINTFORMW 「……も、もう半月も%CALLNAME:MASTER%さんにお会いできていないなんて」
						IF MAIN_MAP == 6
							PRINTFORML （もしかして、気付かない内に何か粗相を……？　だとしたら原因が……）
							PRINTFORMW （こういう時こそご本人に伺ってみるべきだけど、それで更に状況を悪くしてしまったら……）
							PRINTFORML 「どうすれば……うう～……っ！」
							PRINTFORMDW 妖夢は半霊と共に布団の上を悶々と転がり回っている……
						ELSE
							PRINTFORML （ご多忙な方なのだから、会いたいのならこちらが赴かなければいけない事など分かり切っている筈なのに！）
							PRINTFORMW 「……たとえ短慮と謗られようと、都合の良い展開に期待するのは止めです」
							PRINTFORML 「よしっ、明日は何としても時間を作ってみせる……！」
							PRINTFORMDW 妖夢は布団の上で半霊と顔を見合わせ意気込んでいる……
						ENDIF
						CFLAG:23:翌日来訪 = 1
				;一週間
				ELSEIF ARG == 7
					CALL EVENTEND_TSUBUYAKI
					PRINTFORMW 「……最近、%CALLNAME:MASTER%さんをお見かけしていない……」
						IF MAIN_MAP == 6
							IF INRANGE(CFLAG:MASTER:初期位置, 623, 625)
								PRINTFORM （同じ屋敷に住んでいる筈
							ELSE
								PRINTFORM （近くにお住いの筈
							ENDIF
							PRINTFORML なのに……ご多忙なのかもしれないし、迷惑にはなりたくないけど）
							PRINTFORML 「明日は……お会いできるかな……？」
						ELSE
							PRINTFORML （少しの間お会いしていないだけなのに……こんなに心がざわつくなんて。私、本当に……）
							PRINTFORML 「明日……時間、作れるかな……」
						ENDIF
					PRINTFORMDW 布団の中で妖夢が零した小さな呟きが、夜の帳へ溶けていく……
					CFLAG:23:翌日来訪 = 1
				ENDIF
			ELSEIF TALENT:思慕
				IF ARG == 7
					CALL EVENTEND_TSUBUYAKI
					PRINTFORML 「……そういえば、最近%CALLNAME:MASTER%さんを見かけていないような……」
						IF MAIN_MAP == 6
							SELECTCASE RAND:2
								CASE 0
									IF INRANGE(CFLAG:MASTER:初期位置, 623, 625)
										PRINTFORM （屋敷の中でも会わないなんて
									ELSE
										PRINTFORM （近くにお住いの筈だけど
									ENDIF
									PRINTFORMW ……単に私の間が悪いだけなのかしら……？）
								CASE 1
									PRINTFORMW （ご自身の用事が立て込んでいるのかも……なんだか少し、寂しいけれど……）
							ENDSELECT
						ELSE
							SELECTCASE RAND:2
								CASE 0
									PRINTFORMW （確かお住いは……あ、丁度近くに用事があった筈……）
									CFLAG:23:翌日来訪 = 1
								CASE 1
									PRINTFORMW （……まあ、だからと言って用事も無いのに会いに行くなんて、きっと変よね……）
							ENDSELECT
						ENDIF
				ENDIF
			ELSE
				IF ARG == 7
					CALL EVENTEND_TSUBUYAKI
					PRINTFORML 「……そういえば、最近あの人を見かけていないような」
					PRINTDATAW
						DATAFORM （もしや妖怪に亡き者にされていたりは……流石にそこまで無防備じゃないか）
						DATAFORM （まあ、そこまで親しい訳でもないし……あまり気にしすぎる事でもないか）
					ENDDATA
				ENDIF
			ENDIF
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;今日会っている
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 0
		CALL EVENTEND_TSUBUYAKI
		RETURN 1
	ENDIF
ENDIF
RETURN 1

