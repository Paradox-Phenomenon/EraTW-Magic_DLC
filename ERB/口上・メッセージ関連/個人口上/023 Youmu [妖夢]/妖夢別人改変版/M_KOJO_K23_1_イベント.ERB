@M_KOJO_別人版_SPEVENT_MESSAGECHECK_K23_1
RETURN 0

@M_KOJO_別人版_SPEVENT_K23_1(ARG,ARG:1)
;口上主はTARGET
;地の文表示
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	PRINTFORML
	PRINTFORMW 双方的嘴唇相触，然后不知何故分开。
	PRINTFORMW 被自然动作亲吻的%CALLNAME:MASTER%，一时之间无法理解发生了什么。
	PRINTFORMW 但对方似乎也是一样的情况，妖梦仍然呆呆地盯着%CALLNAME:MASTER%。
	PRINTFORML
	PRINTFORMW 「……诶，啊……我…………？」
	PRINTFORML
	PRINTFORMW 渐渐意识到自己做了什么的妖梦，脸变得通红，一步踉后退。
	PRINTFORML
	PRINTFORMW 「对、对、对、对不起%CALLNAME:MASTER%先生！！像这样，突如其来的事情……！」
	PRINTFORML 「那个，你知道吗，我想如果约会结束了就自己身体动了起来，好像无法忍耐一样」
	PRINTFORMW 「那、那不……不是这样的……！」
	PRINTFORML
	PRINTFORML 就在这时，旁边的半灵仿佛感到了什么一样，在地上伸展了开来?
	PRINTFORMW 那样会不会有问题呢……
	PRINTFORML
	PRINTFORMW 「啊啊啊啊啊……」
	PRINTFORMW 「对、对不起啊啊啊……」
	PRINTFORML
	PRINTFORMW 妖梦摇摇晃晃地把半灵拖到路边，然后在那里抱头蹲了一会儿。
	PRINTFORML
	PRINTFORMW 「明明应该有更多的地方和氛围，各种各样的事情的……！」
	;キスをキャンセルしたい場合は以下を開放
	;TCVAR:キスキャンセル = 1
ENDIF
RETURN 1

;==================================================
;デート帰りに告白（恋人が付く）
;==================================================
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_別人版_SPEVENT_MESSAGECHECK_K23_2
RETURN 0

@M_KOJO_別人版_SPEVENT_K23_2(ARG,ARG:1)
;口上主はTARGET
;地の文表示
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;告白内容
	;この告白内容表示後に受けるかどうかの選択分が表示されます
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 0
		;初回
		IF FIRSTTIME("告白")
			PRINTFORMW 「%CALLNAME:MASTER%」
			PRINTFORMW 「能不能给我一点时间？」
			PRINTFORML
			PRINTFORML 在不知何时停下的妖梦的声音吸引着%CALLNAME:MASTER%，他回过头去。
			PRINTFORMW 尽管语气轻松，但她朝这里投来的蓝色眼眸充满了认真。
			PRINTFORML
			PRINTFORMW 「……谢谢」
			PRINTFORML 「我不擅长隐瞒，也许你早就看穿了我的心思」
			PRINTFORMW 「但无论如何，我想用自己的言语表达这份感情」
			PRINTFORML
			PRINTFORML 于是，妖梦截断了言语，深吸一口气，悄悄呼出。
			PRINTFORMW 等到她再次开口，时间仿佛变得异常漫长。
			PRINTFORML
			PRINTFORMW 「喜欢你，%CALLNAME:MASTER%」
			PRINTFORML
			PRINTFORMW 「今天能够被你邀请，一直在你身边，我一直很幸福」
			PRINTFORMW 「也许是因为这样……我希望将来一直能够待在你身边，我不禁这样想」
			PRINTFORML
			PRINTFORMW 「我知道这有点自私」
				IF TALENT:66:恋慕
					PRINTFORMW 「……我对%CALLNAME:MASTER%有着这样的感情，却没有能够与之相提并论的人」
				ELSE
					PRINTFORMW 「……与%CALLNAME:MASTER%周围的人相比，我在女性魅力方面可能有所不足」
				ENDIF
			PRINTFORMW 「尽管如此，我只是想表达这份感情，否则迟早会后悔的」
			PRINTFORML
			PRINTFORMW 「……%CALLNAME:MASTER%，能告诉我你的心意吗？」
		;二回目以降
		ELSE
			PRINTFORMW 「%CALLNAME:MASTER%，对不起……」
			PRINTFORML
			PRINTFORMW 步伐放缓的妖梦突然从%CALLNAME:MASTER%的后面拉起袖子。
			PRINTFORMW 虽然力量微弱到一步迈开就会离开，但对于%CALLNAME:MASTER%来说足够让他停下脚步。
			PRINTFORML
			PRINTFORMW 「明明已经被拒绝了……我自己也觉得太过执着」
			PRINTFORMW 「但是……即便如此，对你的感情我无法斩断」
			PRINTFORML
			PRINTFORMW 「喜欢你，%CALLNAME:MASTER%……喜欢到无可救药」
			PRINTFORML
			PRINTFORMW 「拜托了……让我一直待在你身边」
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;告白オッケー（恋人が付く）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		PRINTFORMW 「啊……现在……这，这不是梦吧……？」
		PRINTFORML
		PRINTFORMW %CALLNAME:MASTER% 一步踏向呆愣的妖梦，轻轻将她的肩膀拥入怀中
		PRINTFORMW 被纳入怀抱的纤细身躯微微颤抖
		PRINTFORML
			;初次
			IF FIRSTTIME("回应")
				PRINTFORMW 「……我本以为你会拒绝的」
				PRINTFORMW 「像我这样的新手可能不配与%CALLNAME:MASTER%相伴……」
			ELSE
				PRINTFORMW 「……其实我挺害怕的」
				PRINTFORMW 「怕会破坏我们之间还能一起玩的关系……」
				CFLAG:23:1001 = 2
			ENDIF
		PRINTFORMW 「但是你，却温柔地拥抱着我，解开了我的不安……」
		PRINTFORML
		PRINTFORMW 轻轻抱紧%CALLNAME:MASTER%的背后，她略显谦卑
		PRINTFORML
		PRINTFORMW 「%CALLNAME:MASTER%，我一直很仰慕你」
		PRINTFORML
		PRINTFORMW 在微弱的啜泣声中，%CALLNAME:MASTER% 紧紧拥抱着这个半人半灵的少女
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;告白失敗
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		;初回
		IF FIRSTTIME("回应")
			PRINTFORMW 「…………是的，没错」
			PRINTFORMW 「不，没关系的。我早就知道，我无法与你………」
			PRINTFORML
			PRINTFORML 「只是希望%CALLNAME:MASTER%知道」
			PRINTFORMW 「我的心意」
			PRINTFORML
			PRINTFORMW 妖梦坚定地微笑着，向%CALLNAME:MASTER%表达感激之情
			PRINTFORMW %CALLNAME:MASTER%无法直视她眼角的泪水
			CFLAG:23:1001 = 1
		;二回目以降
		ELSE
			PRINTFORMW 「…………当然了」
			PRINTFORMW 「像我这样纠缠不休的女孩，被拒绝也是理所当然的」
			PRINTFORML
			PRINTFORML 「所以，请不要露出那种表情」
			PRINTFORMW 「%CALLNAME:MASTER%，你并没有任何错」
			PRINTFORML
			PRINTFORMW 这样说着，妖梦坚定地露出笑容
			PRINTFORMW 这个熟悉的表情，比曾经见过的更加悲痛
		ENDIF
		RETURN 1
	ENDIF
ENDIF
RETURN 1

