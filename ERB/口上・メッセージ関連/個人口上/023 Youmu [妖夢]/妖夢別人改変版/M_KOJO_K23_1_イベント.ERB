;※※※※※※※※※※※※※※※※※※※※※※※※※※
;"EVENT"系イベント
;※※※※※※※※※※※※※※※※※※※※※※※※※※
;==================================================
;部屋で遭遇
;==================================================
@M_KOJO_別人版_EVENT_K23_1(ARG,ARG:1)
;口上主はTARGET
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;MASTERが入ってきた
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		$YOMU_ENCOUNTER
		;既に会っている場合は非表示
		IF !TCVAR:23:今日会ったか
			;怒り
			IF CFLAG:318 == 1
				PRINTFORML
				PRINTFORML 「…………」
				PRINTFORMW 妖梦看到%CALLNAME:MASTER%，默不作声地切断了对话……
			
			;反発刻印为1的三分之一，为2的三分之二
			ELSEIF (MARK:23:反発刻印 == 1 && RAND:3 == 0) || (MARK:23:反発刻印 > 1 && RAND:3 != 0)
				PRINTFORML
				PRINTFORML 「…………」
				PRINTFORMW 妖梦默默地向%CALLNAME:MASTER%点头示意
			
			;情人节
			ELSEIF (DAY:2 == 4 && DAY:3 == 14 && CFLAG:2 >= 1000)
				CALL SPECIALDAY_EVENT_K23
			
			;台风
			ELSEIF FLAG:異常気象 == 9
				PRINTFORML
				PRINTFORML 「呜，风好大……半灵都差点被刮飞了……」
				PRINTFORMW 「%CALLNAME:MASTER%，因为这种天气最好还是不要外出……」
			
			;暴风雪
			ELSEIF FLAG:異常気象 == 10
				PRINTFORML
				PRINTFORML 「这么大的暴风雪让我想起了那一天的事……」
				PRINTFORMW 「%CALLNAME:MASTER%，在这种天气最好还是在家里安静待着！」
			
			;不高兴
			ELSEIF TALENT:機嫌 == -1
			
			;正常情况
			ELSE
				SELECTCASE TIME:2
					;早上
					CASE 1,2
						PRINTFORML
						PRINTFORML 「早上好，%CALLNAME:MASTER%」
							IF TALENT:恋慕
								PRINTFORMW 妖梦对%CALLNAME:MASTER%微笑着行了一个%TEXTR("愉快地/高兴地/")%鞠躬
								PRINTFORMW 「今天的计划已经确定了吗？」
							ELSEIF TALENT:思慕
								PRINTFORMW 妖梦向%CALLNAME:MASTER%点头示意
							ELSE
								PRINTFORMW 妖梦轻轻点头示意%CALLNAME:MASTER%
							ENDIF
					;中午
					CASE 3,4
						PRINTFORML
						PRINTFORML 「你好，%CALLNAME:MASTER%」
							IF TALENT:恋慕
								PRINTFORMW 妖梦对%CALLNAME:MASTER%微笑着行了一个%TEXTR("愉快地/高兴地/")%鞠躬
								PRINTFORMW 「已经中午了呢。悠闲地度过时间，转眼就会天黑了」
							ELSEIF TALENT:思慕
								PRINTFORMW 妖梦向%CALLNAME:MASTER%点头示意
							ELSE
								PRINTFORMW 妖梦轻轻点头示意%CALLNAME:MASTER%
							ENDIF
					;晚上
					CASE 5,6,7
						PRINTFORML 「晚上好，%CALLNAME:MASTER%」
							IF TALENT:恋慕
								PRINTFORMW 妖梦对%CALLNAME:MASTER%微笑着行了一个%TEXTR("愉快地/高兴地/")%鞠躬
									;定义住在白玉楼并在白玉楼内的情况
									IF INRANGE(CFLAG:MASTER:初始位置, 623, 625) && INRANGE(CFLAG:MASTER:当前位置, 620, 629)
										PRINTFORMW 「有什么事要外出吗？如果是这样，欢迎回来」
									ELSE
										PRINTFORMW 「四周都很暗，要小心脚下哦？」
									ENDIF
							ELSEIF TALENT:思慕
								PRINTFORMW 妖梦向%CALLNAME:MASTER%点头示意
							ELSE
								PRINTFORMW 妖梦轻轻点头示意%CALLNAME:MASTER%
							ENDIF
				ENDSELECT
			ENDIF
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGETが入ってきた
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		;既に会っている場合は非表示
		IF !TCVAR:23:今日会ったか
			;ブチギレ
			IF CFLAG:318 == 1
				PRINTFORML
				PRINTFORML 「…………」
				PRINTFORMW 觉察到视野内的%CALLNAME:MASTER%的妖梦默默地切断了言语……

			;反弹刻印有 1为三分之一，2为三分之二
			ELSEIF (MARK:23:反弹刻印 == 1 && RAND:3 == 0) || (MARK:23:反弹刻印 > 1 && RAND:3 != 0)
				PRINTFORML
				PRINTFORML 「…………」
				PRINTFORMW 妖梦注意到了%CALLNAME:MASTER%，默默地点了点头。

			;情人节
			ELSEIF (DAY:2 == 4 && DAY:3 == 14 && CFLAG:2 >= 1000)
				CALL SPECIALDAY_EVENT_K23

			;台风
			ELSEIF FLAG:异常气象 == 9
				PRINTFORML
				PRINTFORML 「嗯，风好大……半灵似乎都要吹走了……」
				PRINTFORMW 「%CALLNAME:MASTER%先生，因为天气这么糟，请慎重外出……」

			;大风雪
			ELSEIF FLAG:异常气象 == 10
				PRINTFORML
				PRINTFORML 「这样猛烈的暴风雪让我想起了那天的事情……」
				PRINTFORMW 「%CALLNAME:MASTER%先生，在这样的日子最好呆在房间里，别出去！」
			
			;心情不好
			ELSEIF TALENT:機嫌 == -1

			;正常情况
			ELSE
				SELECTCASE TIME:2
					;早上
					CASE 1,2
						PRINTFORML
						PRINTFORML 「啊，%CALLNAME:MASTER%先生。早上好」
							IF TALENT:恋慕
								PRINTFORMW 察觉到%CALLNAME:MASTER%的妖梦%TEXTR("愉快地/高兴地/露出笑容地/")%鞠了一躬
								PRINTFORMW 「……嗯，今天好像会是个不错的一天」
							ELSEIF TALENT:思慕
								PRINTFORMW 察觉到%CALLNAME:MASTER%的妖梦鞠了一躬
							ELSE
								PRINTFORMW 察觉到%CALLNAME:MASTER%的妖梦轻轻点头示意
							ENDIF
					;中午
					CASE 3,4
						PRINTFORML
						PRINTFORML 「啊，%CALLNAME:MASTER%先生。下午好」
							IF TALENT:恋慕
								PRINTFORMW 察觉到%CALLNAME:MASTER%的妖梦%TEXTR("愉快地/高兴地/露出笑容地/")%鞠了一躬
								PRINTFORMW 「如果可以的话，要不要稍微休息并聊聊天……」
							ELSEIF TALENT:思慕
								PRINTFORMW 察觉到%CALLNAME:MASTER%的妖梦鞠了一躬
							ELSE
								PRINTFORMW 察觉到%CALLNAME:MASTER%的妖梦轻轻点头示意
							ENDIF
					;晚上
					CASE 5,6,7
						IF TALENT:恋慕
							PRINTFORML
							PRINTFORML 「啊……%CALLNAME:MASTER%先生，原来在这里啊」
							PRINTFORMW 察觉到%CALLNAME:MASTER%的妖梦渐渐失去了往日的神采
								IF INRANGE(CFLAG:MASTER:初始位置, 623, 625) && INRANGE(CFLAG:MASTER:当前位置, 620, 629)
									PRINTFORMW 「您出门了吗？ 欢迎回来。」
								ELSE
									PRINTFORMW 「虽然已经很晚了，但很高兴见到您。」
								ENDIF
						ELSE
							PRINTFORML
							PRINTFORML 「啊，%CALLNAME:MASTER%先生。晚上好」
								IF TALENT:思慕
									PRINTFORMW 察觉到%CALLNAME:MASTER%的妖梦鞠了一躬
								ELSE
									PRINTFORMW 察觉到%CALLNAME:MASTER%的妖梦轻轻点头示意
								ENDIF
						ENDIF
				ENDSELECT
			ENDIF
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGETが風呂に入ってきて一緒に入る
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		;发飙
		IF CFLAG:318 == 1
			PRINTFORML 「――啊」
			PRINTFORMW 妖梦一瞬间愣住，但开始无视%CALLNAME:MASTER%，准备洗澡。

		ELSEIF TALENT:恋慕
			PRINTFORML 「诶，啊……抱、抱歉！」
			PRINTFORMW 「…………」
			PRINTFORMW 「那个……如果%CALLNAME:MASTER%先生不介意的话，能一起吗……？」
		ELSE
			PRINTFORMW 「…………」
			PRINTFORML （这、被情况逼迫只好一起了……）
			PRINTFORMW （……真是羞死人了……！！）
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGETが風呂に入ってきて出て行った
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 4
		;发飙
		IF CFLAG:318 == 1
			PRINTFORML 「――啊」
			PRINTFORMW 妖梦一瞬间愣住，然后急忙离开了那个地方。
		ELSE
			PRINTFORMW 「诶」
			PRINTFORML 「…………对、对、对、对不起啊！！」
			PRINTFORMW 脸涨得通红的妖梦飞快地离开后，留下的半灵尴尬地飘到浴室外面。
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGETが風呂に入ってきて追い出された
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 5
		PRINTFORML
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;外出先で遭遇した
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 6
		GOTO YOMU_ENCOUNTER
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;他キャラとデート中に遭遇した
	;ARG:1にデート相手
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 7
		;发飙
		IF CFLAG:318 == 1
			PRINTFORML 「…………」
			PRINTFORMW 妖梦瞥了%CALLNAME:MASTER%一眼，然后大大地叹了口气。

		;约会对象是幽幽子
		ELSEIF FLAG:约会对象 == 66
			IF TALENT:恋慕
				PRINTFORMW 「%CALLNAME:MASTER%先生，还有……幽々子大人……」
				PRINTFORML （……你们两个关系好是应该高兴的事情……）
				PRINTFORML （可是……可是，为什么……）
				PRINTFORMW 妖梦低头按压着胸口，面容难以捉摸……
			ELSEIF TALENT:思慕
				PRINTFORMW 「幽々子大人和%CALLNAME:MASTER%先生……」
				PRINTFORML （你们两个关系好是应该高兴的事情，可是……）
				PRINTFORMW 妖梦小心翼翼地鞠了一躬，目送着%CALLNAME:MASTER%一行人离开。
			ELSE
				PRINTFORMW 「啊，幽々子大人！还有%CALLNAME:MASTER%先生？」
				PRINTFORML （幽々子大人，难道是对那位感兴趣吗……不行，不可以这样想！）
				PRINTFORMW 妖梦带着疑惑的目光看着%CALLNAME:MASTER%，然后像被弹开一样鞠了一躬。
			ENDIF
		
		;其他情况
		ELSE
			IF TALENT:恋慕
				PRINTFORML 「%CALLNAME:MASTER%先生，还有……」
				PRINTFORML 「在、在这里碰上你们真是巧合啊，两位」
				PRINTFORMW 妖梦似乎装得很冷静，但动作显得有些生硬。
			ELSEIF TALENT:思慕
				PRINTFORML 「两位一起出门吗？」
				PRINTFORML （有点，有点不爽……）
				PRINTFORMW 妖梦微微歪头，同时向%CALLNAME:MASTER%一行人点了点头。
			ELSE
				PRINTFORMW 妖梦注意到%CALLNAME:MASTER%和%CALLNAME:(ARG:1)%，轻轻点了点头。
			ENDIF
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;MAIN_MAP上で一日最初の挨拶
	;注、このあと通常の遭遇口上、ARG==1 OR ARG==2に接続します
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 8
		PRINTFORML 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;外出先で一日最初の挨拶
	;ARG:1にデート相手、ARG:1が0の場合は非デート
	;注、このあと通常の外出先で遭遇した口上、ARG==6 OR ARG==7に接続します
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 9
		;ARG:1とデート中
		IF ARG:1
		;一人で外出
		ELSE
		ENDIF
		PRINTFORML 
		RETURN 1
	ENDIF
ENDIF
RETURN 1

;==================================================
;特別な日イベント用関数
;==================================================
;-------------------------------------------------
@SPECIALDAY_EVENT_K23
;-------------------------------------------------
	;バレンタインデー
	IF DAY:2 == 4 && DAY:3 == 14 && CFLAG:2 >= 1000
		PRINTFORML
		IF TALENT:恋慕
			PRINTFORMW 「那个……%CALLNAME:MASTER%先生，有东西想交给您」
		ELSEIF TALENT:思慕
			PRINTFORMW 「%CALLNAME:MASTER%先生，请收下这个」
		ELSE
			PRINTFORMW 「%CALLNAME:MASTER%先生，请这边」
		ENDIF

		SELECTCASE CFLAG:好感度
			;巧克力
			CASE 1000 TO 3000
				PRINTFORMW 「是幽々子大人要求大量购买的糖果」
				PRINTFORMW 「我也尝了一些，所以想分享给您」
			;普通巧克力
			CASE 3001 TO 5000
				PRINTFORMW 「平时受到您照顾，虽然只是一点心意……」
				PRINTFORMW 妖梦递给%CALLNAME:MASTER%手中的巧克力
			CASE IS > 5000
				;手工制作
				IF EXP:愛情経験 >= 100
					PRINTFORMW 「这个巧克力是我认真制作的」
					PRINTFORMW 「我自己尝过了……味道应该不错」
					PRINTFORMW 「……可以收下吗？」
				ELSE
					PRINTFORMW 「这是当地有名的巧克力」
					PRINTFORMW 「幽々子大人分享给我的，口感应该不错！」
					PRINTFORMW 妖梦递给%CALLNAME:MASTER%手中精美包装的巧克力
				ENDIF
		ENDSELECT

	ENDIF
