#DIM 順位
SELECTCASE ARGS
CASE "試合前"
	;-------------------------------------------------
	;キャラセレクト時,ARGは使えません
	;全角50文字くらいまで
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1
		SELECTCASE RAND:3
			CASE 0
				RESULTS = 「あ、ある意味精鋭揃いですよ！」
			CASE 1
				RESULTS = 「生き残っていたのは運だけではない筈……！」
			CASE 2
				RESULTS = 「うぅ……あまり自信はありませんが……」
		ENDSELECT
	ENDIF
CASE "戦場に出した"
