@M_KOJO_別人版_MESSAGE_COM_K23_410_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF CFLAG:睡眠 || FLAG:70 || TCVAR:泥酔 == 1
		PRINTFORML
	;うふふ中
	ELSEIF CFLAG:うふふ
		IF TALENT:恋慕
			PRINTFORML ......是啊，打扫，对...打扫...清扫吗？
			PRINTFORMW 现在开始？...嗯，好的，我来帮忙...
		ELSE
			PRINTFORML ......既然这样，不如我们就顺便把这里也整理完吧？
			PRINTFORMW 我才不会让东西这么脏乱呢
		ENDIF
	;手伝う
	ELSEIF TFLAG:193 == 1
		;发火
		IF CFLAG:318 == 1 || (MARK:23:反発刻印 == 1 && RAND:3 == 0) || (MARK:23:反発刻印 > 1 && RAND:3 != 0)
			PRINTFORML 「…………」
			PRINTFORMW %CALLNAME:MASTER%和妖梦默默地完成了清理，一言不发……
		;铲雪
		ELSEIF OUTROOF(CFLAG:現在位置) && DAY:2 == 4
			;污垢多
			IF TFLAG:194 >= 3
				SELECTCASE RAND:2
					CASE 0
						PRINTFORMW 「不管雪有多深，只要我们两个一起清理，马上就――」
						PRINTFORML 「马、上……」
						PRINTFORMW 「……」
						PRINTFORMW 「……加油吧……」
					CASE 1
						PRINTFORMW 「这点雪算什么……！」
						PRINTFORML 「那时候庭院也是！ 垃圾场前面也是！」
						PRINTFORMW 「我一个人搞定的时候可是这样啊！！」
						PRINTFORMW 一脸凶猛的妖梦正在与雪激烈战斗……
				ENDSELECT
			;污垢中以下
			ELSE
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 「看起来好像很熟练？」
						PRINTFORMW 「嗯，嗯，其实……对铲雪有点不喜欢」
					CASE 1
						PRINTFORML 「呼，差不多就没问题了――好、冷！？」
						PRINTFORMW 「……那个，%TEXTR("雪人的头/大雪兔/")%那个难道是……」
				ENDSELECT
			ENDIF
		;白玉楼敷地内
		ELSEIF MAIN_MAP == 6 && INRANGE(CFLAG:MASTER:現在位置, 620, 629)
			;白玉楼庭
			IF CFLAG:MASTER:現在位置 == 621
				IF TFLAG:194 >= 3
					PRINTFORML 「庭院……！」
					PRINTFORMW 「怎么会这样……明明只是修剪产生的垃圾而已……」
					PRINTFORML 「唉……不管怎么说，这是我作为园艺师的懒惰……」
					PRINTFORMW %CALLNAME:MASTER%一边安慰着泪眼汪汪的妖梦，一边清理庭园
				ELSE
					PRINTFORML 哎呀，有点乱了呢……
