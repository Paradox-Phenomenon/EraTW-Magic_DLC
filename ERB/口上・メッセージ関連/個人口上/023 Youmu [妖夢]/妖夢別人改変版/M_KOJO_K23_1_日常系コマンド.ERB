RETURN RESULT

@M_KOJO_別人版_MESSAGE_COM_K23_351_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;TARGET連れ出し
	IF CFLAG:同行 == 60
		;醉醺醺
		IF ALCOHOL_FACE(23) == "酔いどれ" || ALCOHOL_FACE(23) == "ぐでぐで"
			PRINTFORML 「啊，诶？ ……稍微晒晒太阳，想要感受一下风……」
			PRINTFORMW 似乎觉得情况不妙，妖梦毫不犹豫地握住了%CALLNAME:MASTER%的手
		ELSEIF CFLAG:318 == 1 || MARK:23:反発刻印 > 1
			PRINTFORML 「…………」
			PRINTFORMW 似乎勉强会跟着过来……
		;恋慕
		ELSEIF TALENT:恋慕
			IF CAN_IRAI_CHARA_GO_TOGATHER(TARGET)
				PRINTFORMW 「立刻问我吗？ 太感谢了！」
			ELSE
				SELECTCASE RAND:3
					CASE 0
						PRINTFORMW 「要去哪里？ 我会陪同的！」
					CASE 1
						PRINTFORMW 「如果我能帮上忙的话」
					CASE 2
						PRINTFORMW 「稍微跟在后面……有点可惜呢」
				ENDSELECT
			ENDIF
		ELSE
			IF CAN_IRAI_CHARA_GO_TOGATHER(TARGET)
				PRINTFORMW 「啊，嗯……在这里可能有点困难呢」
			ELSE
				SELECTCASE RAND:3
					CASE 0
						PRINTFORMW 「有事找我吗？」
					CASE 1
						PRINTFORMW 「嗯，有什么事吗？」
					CASE 2
						PRINTFORMW 「我不介意……要去哪里？」
				ENDSELECT
			ENDIF
		ENDIF
	;TARGET以外連れ出し(TARGET同行中のみ
	ELSE
	ENDIF
ENDIF
RETURN 1
