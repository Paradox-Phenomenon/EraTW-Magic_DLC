						SELECTCASE RAND:2
							CASE 0
								PRINTFORMW 「誤魔化せてませんよ！？　茶葉が少なかっただけですよね！」
							CASE 1
								PRINTFORMW 「まあ、%CALLNAME:MASTER%さんが仰るのであれば……」
						ENDSELECT
					ENDIF
			CASE 1
				PRINTFORML 「ッ？！？　に、苦っ……！！」
				PRINTFORMDW 加減を間違えてしまったが、そういう茶葉だと誤魔化せた……
					IF TALENT:思慕 || TALENT:恋慕
						SELECTCASE RAND:2
							CASE 0
								PRINTFORMW 「誤魔化せてませんけど！？　茶葉が多すぎただけでしょう！」
							CASE 1
								PRINTFORMW 「こ、こんなお茶があるんですか。私にはちょっと……」
						ENDSELECT
					ENDIF
		ENDSELECT

	;荒天時、外
	ELSEIF GROUPMATCH(TIME:5,5,9,13) && OUTROOF(CFLAG:現在位置)
		PRINTFORMW 「えっ！？　こんな天気に外でお茶を……！？」
			IF TALENT:恋慕
				PRINTFORML 「お気持ちは大変嬉しいのですが、屋根のある場所の方が……」
				PRINTFORMW 「……い、いただきます！　いただきますから、そんな顔をなさらないで下さい……！」
			ELSE
				PRINTFORML 「お、お気持ちはありがたいのですが、せめて場所を移すべきでは……」
				PRINTFORMW 「う……では、一杯だけいただきます……」
			ENDIF

	;仕事時　宴会参加中にお茶は出せない筈なので恐らく齟齬は出ない…
	ELSEIF CFLAG:行動 == 5
		SELECTCASE RAND:3
			CASE 0
				IF TALENT:思慕 || TALENT:恋慕
					IF TCVAR:23:手伝った量
						PRINTFORMW 「差し入れですか？　%CALLNAME:MASTER%さんもご無理はなさらないで下さいね？」
					ELSE
						PRINTFORMW 「差し入れですか？　ついでに人手も欲しいな～……な、なんて」
					ENDIF
				ELSE
					PRINTFORMW 「差し入れですか？　お心遣い感謝します」
				ENDIF
			CASE 1
				PRINTFORMW 「あっ、ありがとうございます！　飲み物は助かりますね」
			CASE 2
				PRINTFORMW 「息抜きも大事ですからね。折角ですし一服させてもらいます」
		ENDSELECT

	;食後
	ELSEIF (PREVCOM == 414 || PREVCOM == 415) && TCVAR:23:前回料理評価値
		IF TCVAR:23:前回料理評価値 < 400
			PRINTFORML 「……すみません。丁度口の中をすっきりさせたかったので、遠慮なく」
			PRINTFORMDW %CALLNAME:MASTER%からお茶を受け取った妖夢は、それを飲み干すと静かに長く息を吐いた……
			SIF TALENT:機嫌 < 0
				TALENT:機嫌 = 0
		ELSEIF TALENT:恋慕
			PRINTFORML 「食事にお茶まで用意していただけるなんて、何から何まで申し訳ありません……」
			PRINTFORMW 「……ん……ありがとうございます。この瞬間もまた、紛れもなく至福の一時ですよ」
		ELSE
			PRINTFORML 「おお……食後のお茶まで」
			PRINTFORMW 「いち使用人として倣うべき心遣いですね、ありがとうございます」
		ENDIF

	;大成功
	ELSEIF TFLAG:193 == 1
		IF TALENT:恋慕
			SELECTCASE RAND:2
				CASE 0
					PRINTFORML 「%CALLNAME:MASTER%さんがお茶を淹れる所作はかなり洗練されてますよねぇ」
					PRINTFORML 「目で唸らせるという点でも、或いは既に茶道の域なのでしょうか？」
					PRINTFORMDW 妖夢は感心した様子で湯呑を傾けている
				CASE 1
					PRINTFORML 「この一杯は絶妙ですね……」
					PRINTFORML 「何か普段より配慮した手順があれば、是非聞かせていただきたいです」
					PRINTFORMDW %CALLNAME:MASTER%は淹れ方のコツについて暫し妖夢と談笑した
			ENDSELECT
		ELSE
			SELECTCASE RAND:2
				CASE 0
					PRINTFORML 「私も幽々子様に、これくらい美味しいお茶を淹れて差し上げられると良いのですが……」
					PRINTFORMDW しみじみと呟きながら、妖夢は味と香りに賞賛を送っている
				CASE 1
					PRINTFORML 「わぁ……美味しいです。いつでもこんな逸品を用意できるよう研鑽されているんですね」
					PRINTFORMDW 妖夢の眼差しから尊敬の念を感じる……
			ENDSELECT
		ENDIF

	;恋慕
	ELSEIF TALENT:恋慕
		SELECTCASE RAND:5
			CASE 0
				PRINTFORML 「いつもありがとうございます……ふふっ」
				PRINTFORMW 「いえ、貴方にこうしてお茶をいただけるのがなんだか嬉しくて」
			CASE 1
				PRINTFORML 「能力でも手品でも、%CALLNAME:MASTER%さんのお点前に疑いようはありません」
				PRINTFORMW 「あまり些事に拘りすぎるのも無粋と悟れたんです」
			CASE 2
				PRINTFORML 「んん……美味しい……」
				PRINTFORMW 「実はおやつに%TEXTR("お饅頭/最中/羊羹/わらび餅/カステラ/")%を忍ばせていまして、%CALLNAME:MASTER%さんもいかがですか？」
			CASE 3
				PRINTFORML 「一応知識としては茶道の心得も無い事はないのですが、作法に沿って茶を点てるのもじっと待つのもどうもむず痒くて……」
				PRINTFORMW 「私にはこうして気軽にいただけるお茶の方が性に合っているようです……ふぅ、結構なお手前で」
			CASEELSE
				SELECTCASE DAY:2
					CASE 2
						PRINTFORML 「こ、これは……適度に冷やされたお茶！　こんなお誂え向きの物まで用意されてしまうとは……！」
						PRINTFORMW 「いやぁ、半分は幽霊と言っても暑い陽気は暑いですからね。お心遣いありがとうございます」
					CASE 4
						PRINTFORML 「冷え込みに吹雪……その後に残される雪掻きと、なんとも頭の痛い事の多い季節ではありますけど」
						PRINTFORMW 「こうして%CALLNAME:MASTER%さんからいただける熱いお茶は、冬の数少ない心からの楽しみですよ。ありがとうございます」
					CASEELSE
						PRINTFORML 「過ごしやすい季節だからでしょうか、一服すると必要以上に気が抜けてしまうような……」
						PRINTFORMW 「あぁ……部屋でお茶を啜りつつのんびり、なんて一日にも心惹かれてしまいますねぇ……」
				ENDSELECT
		ENDSELECT

	;思慕その他
	ELSE
		SELECTCASE RAND:3
			CASE 0
				PRINTFORML 「ありがとうございます」
				PRINTFORMW 「丁度喉が渇いていたんです」
			CASE 1
				PRINTFORML 「……お茶を淹れる程度の能力……？」
				PRINTFORMW 「い、いえ、なんでもありません！」
			CASE 2
				PRINTFORML 「ふう、一服すると落ち着けますね。ご馳走様でした」
					IF TALENT:思慕
						PRINTFORMW 「……ようやくこのお茶とも打ち解けられてきましたよ」
					ELSE
						PRINTFORMW （……やっぱりお茶の出所が気になって落ち着かない……！）
					ENDIF
		ENDSELECT
	ENDIF
ENDIF
RETURN 1
