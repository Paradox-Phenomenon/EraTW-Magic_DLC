;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;Activity_Type =0考え事/=1遊ぶ/=2食事/=3つまみ食い/=4掃除/=5運動/=6読書/=7料理
	;				=8セッション/=9採集/=10釣り/=11調合/=12休憩/=13晩酌/=14買い物/=15説教/=16落とし穴
	;ブチギレor反発刻印有
	IF CFLAG:318 == 1 || (MARK:23:反発刻印 == 1 && RAND:3 == 0) || (MARK:23:反発刻印 > 1 && RAND:3 != 0)
		PRINTFORML 「…………」
		PRINTFORMDW 妖夢は%CALLNAME:MASTER%をいない者として見ているようだ……
	ELSE
		SELECTCASE Activity_Type:TARGET
			CASE 0
				;▼考え事［なに考えてるの］
				;TFLAG:193,-1=はぐらかされる
				IF TFLAG:193 == -1
					PRINTFORMW 「――へ？　あっ、こ、これは%CALLNAME:MASTER%さんだけには教えられないと言いますか……」
				ELSE
					SELECTCASE RAND:3
						CASE 0
							PRINTFORML 「明日の夕飯の献立を考えていまして」
							PRINTFORMW 「気が早い？　いやいや、決してそんな事はないんです……」
						CASE 1
							PRINTFORML 「次はどんな形に庭木を剪定してみようかと……」
							PRINTFORMW 「そうです！　%CALLNAME:MASTER%さん、ご要望があれば可能な限りお応えしますよ？」
						CASE 2
							PRINTFORML 「次回の買い出しの確認をと思いまして」
							PRINTFORMW 「大仕事ですので事前の準備は幾らでもしておきたいですからね」
					ENDSELECT
				ENDIF
			CASE 2
				;▼食事［一緒に食事する］
				;TFLAG:193,-1=MASTERはお腹が空いてなかった
				IF TFLAG:193 == -1
					PRINTFORMW 「ええ……？　でしたら無理矢理詰め込まなくても……」
				ELSEIF TALENT:恋慕
					SELECTCASE RAND:2
						CASE 0
							PRINTFORML 「ささやかな間食ではありますが……余分に持ち歩いていて正解でした」
							PRINTFORMW 「多少の空腹は繕えましたでしょうか？」
						CASE 1
							PRINTFORML 「普段いただいてばかりですし、お茶は私が用意しますね」
							PRINTFORMW 「……いかがでしょうか？　上手く淹れられていると良いのですが……」
					ENDSELECT
				ELSE
					PRINTFORML 「えっ、これを分けて欲しい？」
					PRINTFORMW 「構いませんけど……元々が少ないのであまり差し上げられませんよ？」
				ENDIF
			CASE 4
				;▼掃除［掃除を手伝う］
				;※[掃除係]持ちまたは汚臭耐性-1以下のみ
				;冬の屋外
				IF OUTROOF(CFLAG:現在位置) && DAY:2 == 4
					PRINTFORML 「こうも雪が積もっていては往来に支障が出ます！」
					PRINTFORMW 「誰かが転ぶ前に一緒に片付けてしまいましょう」
				;白玉楼庭
				ELSEIF MAIN_MAP == 6 && CFLAG:MASTER:現在位置 == 621
					PRINTFORML 「庭園の景観を保つためにも日々の清掃は欠かせません」
					PRINTFORMW 「まあ、結局こうしてお手を煩わせてしまっているのですが……お恥ずかしい限りです」
				ELSE
					SELECTCASE RAND:2
						CASE 0
							PRINTFORML 「使用人のサガなのか、細かい汚れが気になってしまいまして」
								IF MAIN_MAP == 6 && INRANGE(CFLAG:MASTER:現在位置, 620, 629)
									PRINTFORMW 「%CALLNAME:MASTER%さんの手をお借りできましたが、他の幽霊は何をしているんでしょう……？」
								ELSE
									PRINTFORMW 「勝手に掃除していいのかちょっと不安ですが、綺麗になって気分を損ねる人はいませんよ……多分」
								ENDIF
						CASE 1
							PRINTFORML 「この辺りは良さそうですね。では次はあちらに……」
								IF ABL:MASTER:清掃技能 >= ABL:清掃技能
									PRINTFORMD %CALLNAME:MASTER%は妖夢に指示を出しつつ
								ELSE
									PRINTFORMD %CALLNAME:MASTER%は妖夢から指示を受けつつ
								ENDIF
