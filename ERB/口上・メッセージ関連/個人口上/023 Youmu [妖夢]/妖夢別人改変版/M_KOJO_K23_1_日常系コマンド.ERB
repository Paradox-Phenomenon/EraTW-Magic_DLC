			PRINTFORMW 「……刀をぬかなきゃ、追いはらえませんかねぇ」
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「たんれんも、お酒も……げんかいを見あやまっては、いけないというのにぃ……」
				CASEELSE
					PRINTFORML 「%TEXTR("ぎぼぢわるいﾞぃ/のびずぎだぁ/やﾞっちゃっだぁ/うぼぁー/")%……ご用なら、あとにしていたらけるとぉ……」
			ENDSELECT
			
			SELECTCASE RAND:(TALENT:思慕 ? 3 # 2)
