IF LOCAL
	IF TCVAR:泥酔 == 1
		PRINTFORMW
		RETURN 1
	ELSEIF CFLAG:318 == 1 || (MARK:23:反発刻印 == 1 && RAND:2 == 0) || MARK:23:反発刻印 > 1
		PRINTFORML 「…………」
		PRINTFORMDW 妖夢は%CALLNAME:MASTER%から離れて網で素振りをしている……
		RETURN 1
	ELSEIF FIRSTTIME(SELECTCOM)
		;冥界の虫は基本幽霊だが、細かい事を気にしてはいけない
		PRINTFORML 「虫を捕りたい、ですか……うーん、お力になれるよう努力はしますが」
		PRINTFORMW 「生きている虫は剪定の際に巻き込んで刻んでしまうので、生け捕りは慣れていないんですよね……」
		PRINTFORML
	ENDIF

	SELECTCASE TFLAG:193
		CASE -2
			CALL K23_REACTION_MUSHI
			PRINTFORML
			PRINTFORMW 「えっ！？　%CALLNAME:MASTER%さん、なにを……！」
				IF TALENT:恋慕
					PRINTFORML 「こ、この虫をご所望なんですかっ？　差し上げますから、一旦冷静に……あっ！？」
					PRINTFORML 「あぁ、虫が……もう……」
					PRINTFORMDW 妖夢の恨めしそうな視線が%CALLNAME:MASTER%へ突き刺さる……
				ELSE
					PRINTFORML 「こ、この虫が欲しいっ？　本当に欲しいならご自身で捕まえるべきでは……うわ！？」
					PRINTFORML 「あぁ、虫が……もうっ……！」
					PRINTFORMDW 妖夢の非難の視線が%CALLNAME:MASTER%へと突き刺さる……
				ENDIF
		CASE -1
			CALL K23_REACTION_MUSHI
			PRINTFORML
			PRINTFORMW 「ふう……やはり生け捕りにするのは苦労させられますね」
				IF TALENT:恋慕
					PRINTFORML 「えっ、この虫をご所望ですか？　むむむ……」
					PRINTFORMW 「……やはり、自身で捕まえられた時の達成感あってこそのものだと思いますので」
					PRINTFORML 「%CALLNAME:MASTER%さんならもっと凄い虫を捕まえられますよ！」
					PRINTFORMDW 虫は譲ってもらえなかったが、妖夢から激励してもらえた
				ELSE
					PRINTFORML 「……はあ、この虫を譲って欲しいと」
					PRINTFORML 「申し訳ありませんがそれは承諾しかねますね……ちょっと試してみたい事もありますし」
					PRINTFORMDW 思いの外意志は固そうだ、今回は諦めるべきだろう……
				ENDIF
		CASE 0
			PRINTFORML （くっ、%TEXTR("小賢しい/素早い/")%……ならこちらもその気で……！）
			PRINTFORMW 「……%TEXTR("はあっ/そこだ/捉えた/")%！　……あﾞ」
			PRINTFORML
			PRINTFORML 「お、惜しかったのになぁ～……あっ、もしや%CALLNAME:MASTER%さんも成果が？」
			PRINTFORML 「私もあと一歩だったのですけど、まんまと逃げられてしまいまして……あは、あはは……」
			PRINTDATADW
				DATAFORM 何故か妖夢は口元を引き攣らせて苦笑している……
				DATAFORM 隣の半霊が若干蒼褪めているように見える……
			ENDDATA
		CASE 1
			CALL K23_REACTION_MUSHI
			PRINTFORML
			PRINTFORMW 「おお……こうも容易く生け捕りにしてしまうなんてお見事です！」
				IF (TALENT:思慕 || TALENT:恋慕) && ABL:MASTER:戦闘能力 > 3 && RAND:2 == 0
					PRINTFORML 「%CALLNAME:MASTER%さんほどの技量であれば、峰打ちなど造作もありませんでしたね」
					PRINTFORMDW 何故か妖夢と半霊は感慨深そうに頷いている
				ELSE
					PRINTFORML 「虫相手に手加減はなかなか難儀させられまして……もう少し頑丈だと助かるのですが」
					PRINTFORMDW 妖夢は虫捕りを模擬戦か何かと勘違いしているのだろうか……
				ENDIF
		CASE 2
			CALL K23_REACTION_MUSHI
			PRINTFORML
			PRINTFORMW 「ふう……やはり生け捕りにするのは苦労させられますね」
				IF TALENT:恋慕
					PRINTFORMW 「ですけど%CALLNAME:MASTER%さんにお褒めいただけるのであれば、まだまだ修練のし甲斐がありそうです！」
				ELSE
					PRINTFORMW 「些細な成果でも褒めていただけるのは嬉しいですよ、ありがとうございます」
				ENDIF
		CASE 3
			CALL K23_REACTION_MUSHI
			PRINTFORML
			PRINTFORMW 「ふう……やはり生け捕りにするのは苦労させられますね」
				IF TALENT:恋慕
					PRINTFORML 「えっ、この虫をご所望に？」
					PRINTFORML 「あ、う……ぁ、%CALLNAME:MASTER%さんが仰るのでしたら、どうぞ……」
					PRINTFORMDW 妖夢は捕まえた虫を名残惜しそうに%CALLNAME:MASTER%へ差し出した
				ELSE
					PRINTFORML 「……はあ、この虫を譲って欲しいと」
					PRINTFORML 「わ、分かりましたよ。そんな目で見られたら断りづらいですし……」
					PRINTFORMDW 妖夢は捕まえた虫を渋々%CALLNAME:MASTER%へ差し出した
				ENDIF
		CASE 4
			CALL K23_REACTION_MUSHI
			PRINTFORML
			PRINTFORMW 「ふう……やはり生け捕りにするのは苦労させられますね」
				IF TALENT:恋慕
					PRINTFORML 「えっ、この虫をご所望に？　承知しました」
					PRINTFORML 「私ではちゃんと世話できないと思いますので、%CALLNAME:MASTER%さんの下に行く方が幸せでしょうから」
					PRINTFORMDW 妖夢は捕まえた虫を笑顔で%CALLNAME:MASTER%へ差し出した
				ELSE
					PRINTFORML 「……はあ、この虫を譲って欲しいと。構いませんよ」
					PRINTFORML 「捕まえはしたものの、どうしようか悩んでいたんです。助かりますよ」
					PRINTFORMDW 妖夢は捕まえた虫をすんなり%CALLNAME:MASTER%へ差し出した
				ENDIF
	ENDSELECT
ENDIF
RETURN 1
