					;思慕以上的情况下，1/2 的几率糊弄不过去
					IF TALENT:思慕 || TALENT:恋慕
						SELECTCASE RAND:2
							CASE 0
								PRINTFORMW 「糊弄不过去吧！？ 茶叶少了而已吧！」
							CASE 1
								PRINTFORMW 「嘛，如果%CALLNAME:MASTER%说的话……」
						ENDSELECT
					ENDIF
			CASE 1
				PRINTFORML 「什、什么？！？　这、这是苦的……！！」
				PRINTFORMW 虽然调配失误，但由于是这种茶叶，还能糊弄过去……
