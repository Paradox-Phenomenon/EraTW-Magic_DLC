;==================================================
;626,土産屋＠TW映姫、TWマイ口上を参考に何とか理解したい
;TFLAG:194(行動結果(-2=ひやかし -1=ウィンドウショッピング 1=400点未満（BAD） 2=～699点（NOMAL） 3=700点以上（GOOD）
;CFLAG:性格傾向による地の文分岐あり
;==================================================
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_別人版_MESSAGE_MESSAGECHECK_COM_K23_626
RETURN 0

@M_KOJO_別人版_MESSAGE_COM_K23_626
CALL M_KOJO_別人版_MESSAGE_COM_K23_626_1
RETURN RESULT

@M_KOJO_別人版_MESSAGE_COM_K23_626_1
;下記の2行を忘れると定義できなかった
#DIMS 品名
#DIMS 属性
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;贈っていたら本体名と属性を取得しておく
	IF TFLAG:194 > 0
		CALL GIFTDATA_MAIN(GET_GIFTDATA(TCVAR:23:今日の贈り物, "本体"))
		品名 = %RESULTS%
		IF STRFIND(RESULTS:1, "握住") >= 0
			SIF STRFIND(RESULTS:1, "装飾") >= 0
				属性 = 穿戴
			属性 = 握住
		ELSEIF STRFIND(RESULTS:1, "抱住") >= 0
			属性 = 抱住
		ELSEIF STRFIND(RESULTS:1, "穿戴") >= 0
			属性 = 穿戴
		ELSE
			属性 = 觀賞
		ENDIF
	ENDIF

	SIF TCVAR:泥酔 == 1
		RETURN 1
	SELECTCASE TFLAG:194
		;ひやかし
		CASE -2
			;香霖堂内を定義したい
			IF MAIN_MAP != 5 && CFLAG:MASTER:現在位置 == 520
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 咕噜咕噜，那店老板......！
						PRINTFORMW ......不，应该是我失礼了。我忍不住......
					CASE 1
						PRINTFORML 我们也有错，但那家店也是那家店！
						PRINTFORMW 非卖品太多了！
				ENDSELECT
			ELSEIF TALENT:恋慕
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 哎呀……我太投入了。
						PRINTFORMW 给店家添麻烦了……
					CASE 1
						PRINTFORML 糟糕，我忘了时间……
						PRINTFORMW 我也太专注于挑选了……哎，啊，请别介意。
				ENDSELECT
			ELSE
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 你似乎太过烦恼了……
						PRINTFORMW 虽然制定计划是关键，但也要顾及店里的安排哦。
					CASE 1
						PRINTFORML 你是不是花了太多时间……
						PRINTFORMW 看起来你挺紧张的，你在找什么呢？
				ENDSELECT
			ENDIF
		;やっぱりやめる（見送り）
		CASE -1
			IF MAIN_MAP != 5 && CFLAG:MASTER:現在位置 == 520
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 这是明理的判断，%CALLNAME:MASTER%先生。
						PRINTFORMW 反正这里只有废旧物品而已。
					CASE 1
						PRINTFORML 贸然去问那个店老板那些我无法理解的东西，恐怕不是好主意。
						PRINTFORMW 更别提用那些我无法理解的莫名其妙的理由浪费宝贵时间了。
				ENDSELECT
			ELSEIF TALENT:恋慕
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 虽然对店家很抱歉，但只是看看商品本身就很愉快吧。
						PRINTFORMW %CALLNAME:MASTER%你有看到什么感兴趣的物品吗？
					CASE 1
						PRINTFORML 看到剑或刀就会忍不住多看几眼。
						PRINTFORMW 如果使用半妖之力，连四刀都能轻易挥舞，真希望有一天能用别的方式来展现……
				ENDSELECT
			ELSE
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 啊，这样可以吗？
						PRINTFORMW 毕竟买下来却用不上也是可惜的，就随性点买下来吧。
					CASE 1
						PRINTFORML 如果你在找什么，我也会帮忙的。
						PRINTFORMW 我对这种投机取巧的事情并没有那么自信……
				ENDSELECT
			ENDIF
		;400点未満（BAD）
		CASE 1
			PRINTDATAL
				DATAFORM 「那个，是给我的...？不，等等，那个...」
				DATAFORM 「%CALLNAME:MASTER%大人的兴趣是那种...吗？嗯，是指我吗？」
				DATAFORM 「嗯...？这个是我，我...？」
			ENDDATA
			PRINTFORML 啊，非常感谢……
				IF TALENT:恋慕
					PRINTFORMW 妖夢虽然笑着接过礼物，但嘴角微微抽搐……
						IF MAIN_MAP != 5 && CFLAG:MASTER:現在位置 == 520
							PRINTFORML （%CALLNAME:MASTER%先生，居然让我卖这种东西……）
							PRINTFORMW （……不行，不能在%CALLNAME:MASTER%先生面前露出这种样子。）
						ELSE
							PRINTFORMW （怎、怎么办……我怎么能拿自己的喜好让%CALLNAME:MASTER%先生难堪呢……）
						ENDIF
				ELSE
					PRINTFORMW 妖夢似乎对这个过于出乎意料的礼物感到困惑……
						IF MAIN_MAP != 5 && CFLAG:MASTER:現在位置 == 520
							PRINTFORMW （我居然对这个废弃机械仓库还抱有期待，自己真是愚蠢……！）
						ELSE
							PRINTFORMW （说不定这不只是礼物，还隐藏着什么重要意图……？）
						ENDIF
				ENDIF
		;400点～699点（NOMAL）
		CASE 2
			PRINTDATAL
				DATAFORM 「这是刚才被买走的...我可以接受吗？」
				DATAFORM 「虽然有点兴趣，但没想到能这样得到...」
				DATAFORM 「哇哇，有点不好意思...不，这种时候就不同了」
			ENDDATA
			PRINTFORML 非常感谢，%CALLNAME:MASTER%先生。
				IF TALENT:恋慕
					PRINTFORMW 妖夢接过%CALLNAME:MASTER%的礼物后深深鞠躬，
						IF MAIN_MAP != 5 && CFLAG:MASTER:現在位置 == 520
							PRINTFORMW 能在这种废弃仓库里找到有价值的东西，真是了不起！
						ELSE
							PRINTFORMW 我很高兴您如此关心，我会好好珍惜的。
						ENDIF
				ELSE
					PRINTFORMW 妖夢接过礼物时鞠躬，
						IF MAIN_MAP != 5 && CFLAG:MASTER:現在位置 == 520
							PRINTFORMW ……看来确实混杂着可以当作商品的东西。
						ELSE
							PRINTFORMW 因为自己很少有机会买这类东西，所以感觉很奢侈。
						ENDIF
				ENDIF
		;700点以上（GOOD）
		CASE 3
			;形容詞+本体名を取得
			CALL GIFTNAME(TCVAR:23:今日の贈り物)
			PRINTFORML 啊……这是……%RESULTS%……！？
			PRINTFORML 不不不！说不喜欢什么的，完全相反……！
				IF MAIN_MAP != 5 && CFLAG:MASTER:現在位置 == 520
					PRINTFORML 竟然能从这堆垃圾中发掘出如此杰作，您真有识人之明呢！
				ELSEIF TALENT:恋慕
					PRINTFORML 我太开心了，一时说不出话来……应该怎样致谢才好……
				ELSE
					PRINTFORML 竟然能如此准确地猜中我的喜好……我太感动了！
				ENDIF
			PRINTFORMW 妖夢一副感动的样子收下礼物，深深地向%CALLNAME:MASTER%鞠躬。
			PRINTFORML
				SELECTCASE 属性
					;懐剣、護刀はいずれも眺める
					CASE "觀賞"
						IF 品名 == "懐剣" || 品名 == "護刀"
							IF TALENT:恋慕
								PRINTFORML 我会马上把刀插回鞘，放回房间里！
								PRINTFORMW ――不行啦！？ 如果考虑到可能会在实战中损坏，我就害怕得无法……
							ELSE
								PRINTFORML 啊，真想早点试斩一下……
								PRINTFORMW ……嗯，我还是要忍一忍。如果真的搞砸了，我也无法启齿了。
							ENDIF
						ELSE
							PRINTFORMW 我的房间东西不多，随便放哪应该都能显眼地展示出来。
						ENDIF
					CASE "抱住"
						PRINTFORMW 为了防止不小心落下，我得紧紧抱住……
					CASE "握住"
						PRINTFORMW 它手感太好了，甚至让我误以为是自己的东西……忍不住想随身携带。
					CASE "穿戴"
						IF TALENT:恋慕
							PRINTFORML 你想看看我穿上它吗？这个嘛……嗯，现在就原谅你吧。
							PRINTFORMW 其实我有点紧张，可能会晕倒……
						ELSE
							PRINTFORML 你是不是很好奇我穿上后的样子？
							PRINTFORMW ……因为害羞，所以还是改天再……
						ENDIF
				ENDSELECT
			PRINTFORMW ……真的非常感谢你，%CALLNAME:MASTER%。我一定会报答您的恩情的。
	ENDSELECT
ENDIF
RETURN 1
