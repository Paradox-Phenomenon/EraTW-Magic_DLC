					CASE 0
						PRINTFORML 「%TEXTR("ひゃっ/わっ/")%！？　ぁ、%CALLNAME:MASTER%さん……？」
						CALL HPH_PRINT,@"「た、確かに……色々流すには便利ですけどっ、もう少し忍ぶべきではぁ……っHPH」","W"
					CASE 1
						PRINTFORML 「%TEXTR("ひゃっ/わっ/")%！？　い、今は……どうか一旦っ、一旦冷静に……！」
						CALL HPH_PRINT,@"「このままだと誰か入ってきたら一目で、ぁ、ああぁHPH」","W"
				ENDSELECT
			;振られた状態＆2分の1
			ELSEIF CFLAG:23:2001 == 1 && RAND:2 == 0
				PRINTFORMW 「身体だけでも求めていただけるのは、幸せだと思ってしまうんです」
				PRINTFORMW 「……貴方の腕の中で、何もかも忘れさせて下さい」
			ELSE
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「……愛しています、%CALLNAME:MASTER%さん」
						PRINTFORMW 「幾度言葉にしても足りないくらい」
					CASE 1
						PRINTFORML 「貴方に愛されていると実感できるなら、色事に浸るのも悪くはないかなと……」
						CALL HPH_PRINT,@"「ですので、また刻み付けて下さい……HPH」","W"
					CASE 2
						PRINTFORML 「初めてではないとはいえ、未だに少し緊張してしまいますね……」
						PRINTFORMDW %CALLNAME:MASTER%が優しく抱きしめると、妖夢は安心したように身体から力を抜いた
				ENDSELECT
			ENDIF
		ELSEIF TALENT:思慕
			PRINTDATAL
				DATAFORM 「……恋仲でもないのに、絶対おかしいのに」
				DATAFORM 「……なさるなら、せめて手早くお願いします」
			ENDDATA
			PRINTFORMW （一度許してしまってから、私も線引きが曖昧に……）
		ELSE
			PRINTDATAL
				DATAFORM 「どうしてこんな事に……？」
				DATAFORM 「私、そんなつもりは……」
			ENDDATA
			PRINTFORMW 「…………分かり、ました」
		ENDIF
	ENDIF
ENDIF
