@M_KOJO_別人版_MESSAGE_COM_K23_405_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;TARGETとデート
	IF CFLAG:同行
		IF CFLAG:318 == 1 || MARK:23:反発刻印 > 1
			PRINTFORML 「......」
			PRINTFORMW 妖夢虽然皱着眉，但似乎愿意一起出门了……
		ELSEIF TCVAR:泥酔 == 1
			PRINTFORML
		ELSEIF TALENT:恋慕
			IF CFLAG:23:1001 == 1 && RAND:3 == 0
				PRINTFORML 和我约会...我明白了，让我加入吧。
				PRINTFORMW （......还不想放弃......）
			ELSE
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 能被邀请真开心！
						PRINTFORMW 如果需要便当，我会准备好的，请随意吩咐。
					CASE 1
						PRINTFORML 今天我们会去哪里玩呢？
						PRINTFORMW 请带我去%CALLNAME:MASTER%先生喜欢的地方吧。
				ENDSELECT
			ENDIF
		ELSEIF TALENT:思慕
			SELECTCASE RAND:2
				CASE 0
					PRINTFORML 和我一起……嗯，嗯，我有时间。
					PRINTFORMW （这是通常所说的约会吗……？）
				CASE 1
					PRINTFORML 你要出去吗？……啊，我也要去吗……
					PRINTFORMW （嗯，突然有点在意起来了……）
			ENDSELECT
		ELSE
			PRINTFORML 你可以出去吗？……嘿，我也可以吗？
			PRINTFORMW 是的，没问题……
		ENDIF
	;TARGET以外とデート
	ELSEIF CFLAG:MASTER:同行
	;お出かけお見送り
	ELSE
		IF CFLAG:318 == 1 || MARK:23:反発刻印 > 1 || TCVAR:泥酔 == 1
			PRINTFORML
		ELSEIF TALENT:恋慕
			PRINTFORML 你要出门吗？请自便。
			PRINTFORMW 妖夢向%CALLNAME:MASTER%鞠躬后目送他离开
		ELSEIF TALENT:思慕
			PRINTFORML 出门时请小心。
			PRINTFORMW 妖夢轻轻挥手，目送%CALLNAME:MASTER%
		ELSE
			PRINTFORMW 你可以出门吗？请务必小心。
		ENDIF
	ENDIF
ENDIF
RETURN 1
