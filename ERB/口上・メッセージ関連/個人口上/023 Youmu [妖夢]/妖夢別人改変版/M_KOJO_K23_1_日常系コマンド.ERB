	ELSEIF PREVCOM == 414 || PREVCOM == 415
		PRINTFORML 「哦哦……连饭后的茶也有」
		PRINTFORMW 「真是照顾得像一名仆人，非常感谢」
	
	;大成功
	ELSEIF TFLAG:193 == 1
		IF TALENT:恋慕
			SELECTCASE RAND:2
				CASE 0
					PRINTFORML 「%CALLNAME:MASTER% 您泡茶的动作相当精致呢」
					PRINTFORML 「甚至连眼神的交流都很了得，或许已经达到茶道的境地了吧？」
					PRINTFORMW 妖梦对此表示赞叹，一边喝着茶
				CASE 1
					PRINTFORML 「这一杯喝得恰到好处……」
					PRINTFORML 「如果有什么比平时更体贴入微的步骤，我想请教一下」
					PRINTFORMW %CALLNAME:MASTER% 与妖梦愉快地聊起了泡茶的技巧……
			ENDSELECT
		ELSE
			SELECTCASE RAND:2
				CASE 0
					PRINTFORML 「如果我也能泡出这么美味的茶送给幽幽子大人就好了……」
					PRINTFORMW 妖梦感叹着，对味道和香气表示赞赏
				CASE 1
					PRINTFORML 「哇……好喝。您随时都能准备出这样的好茶吗？」
					PRINTFORMW 从妖梦的眼神中可以感受到尊敬之情……
			ENDSELECT
		ENDIF
	
	;恋慕
	ELSEIF TALENT:恋慕
		SELECTCASE RAND:3
			CASE 0
				PRINTFORML 「一直都非常感谢……呵呵」
				PRINTFORMW 「不知怎么的，能从您这里喝到茶真的让我很高兴」
			CASE 1
				PRINTFORML 「无论是能力还是魔法，%CALLNAME:MASTER% 您的泡茶都是毫无疑问的」
				PRINTFORMW 「我也理解了过分拘泥于琐事是无趣的道理」
			CASE 2
				PRINTFORML 「嗯嗯……好喝」
				PRINTFORMW 「实际上，我在点心里放了%TEXTR("红豆包/花生糖/巧克力/饼干/")%，%CALLNAME:MASTER% 您要尝尝吗？」
		ENDSELECT
	
	;思慕和其他
	ELSE
		SELECTCASE RAND:3
			CASE 0
				PRINTFORML 「谢谢您」
				PRINTFORMW 「正好喉咙有点渴」
			CASE 1
				PRINTFORML 「……有泡茶的能力吗……？」
				PRINTFORMW 「不、不是，什么都没有！」
			CASE 2
				PRINTFORML 「呼，稍微休息一下就感觉平静了。谢谢款待」
					IF TALENT:思慕
						PRINTFORMW 「……终于能和这杯茶打成一片了」
					ELSE
						PRINTFORMW （……茶的来源还是让我有点不安……！）
					ENDIF
		ENDSELECT
	ENDIF
ENDIF
RETURN 1
