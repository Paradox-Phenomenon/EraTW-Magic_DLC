;日常系コマンド
;※※※※※※※※※※※※※※※※※※※※※※※※※
;==================================================
;300,会話
;TFLAG:193(1=大成功 0=成功 -1=失敗 -2=大失敗（TARGETがMASTERより教養が4以上高い)
;TCVAR:302(0=会話可能 1>=非恋慕時会話不能)
;MARK:反発刻印(3以上=会話不能)(4以上はバグ
;TCVAR:泥酔(1=通常成功or大失敗)
;==================================================
@M_KOJO_別人版_SUCCESS_COM_K23_300
;成否判定
;TFLAG:192(-2=コマンド終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_別人版_MESSAGE_MESSAGECHECK_COM_K23_300
RETURN 0

@M_KOJO_別人版_MESSAGE_COM_K23_300
;コマンド共通メッセージ(TRAIN_MESSAGE) 
;削除すると「～話をした。」とかが消えます。また、削除した場合は自動で口上色が付きません。
;口上メイン呼出
CALL M_KOJO_別人版_MESSAGE_COM_K23_300_1
RETURN RESULT

@M_KOJO_別人版_MESSAGE_COM_K23_300_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;ブチギレ
	IF CFLAG:318 == 1
		PRINTFORML 「…………」
		PRINTFORMW 妖梦默默地将手放在刀柄上……
	
	;泥酔
	ELSEIF TCVAR:烂醉 == 1
		PRINTFORML
	
	;反発刻印有　1で3分の1、2で3分の2で選択されるようにしたい
	ELSEIF (MARK:23:反発刻印 == 1 && RAND:3 == 0) || (MARK:23:反発刻印 > 1 && RAND:3 != 0)
		PRINTDATAW
			DATAFORM 「……请不要轻易和我交谈」
			DATAFORM 「……这是浪费时间」
			DATAFORM 「……可以考虑收拾一下离开吗？」
		ENDDATA
		PRINTFORMW 无法隐藏烦躁，妖梦不悦地瞪着%CALLNAME:MASTER%……
	
	;不機嫌　3分の1で選択
	ELSEIF TALENT:心情 == -1 && RAND:3 == 0
		IF TALENT:恋慕
			PRINTDATAW
				DATAFORM 「……对不起，我现在没什么兴致……」
				DATAFORM 「……抱歉，现在有点……」
			ENDDATA
		ELSE
			PRINTFORMW 「……そうです%TEXTR("か/ね/")%」
		ENDIF
		PRINTFORMW 尽管面带佛系表情，妖梦似乎并没有完全忽略%CALLNAME:MASTER%的谈话
	
	;无法交谈
	ELSEIF TCVAR:302
		IF TALENT:恋慕
			PRINTFORML 「……谢谢你关心我，让我感到很开心」
			PRINTFORMW 「但我现在这样已经足够了……明白吗？」
		ELSE
			PRINTFORML 「嗯？那个话题刚才不是已经……」
			PRINTFORMW 察觉到话题的重复，妖梦表情有些尴尬……
		ENDIF
	
	;失败
	ELSEIF TFLAG:193 == -1
		SELECTCASE RAND:2
			CASE 0
				PRINTFORML 「嗯……那个……嗯，怎么了？」
				PRINTFORMW 妖梦一脸疑惑，似乎不太明白发生了什么……
			CASE 1
				PRINTFORML 「…………诶？抱歉，我，刚才没听清楚」
				PRINTFORMW 似乎是被忽略了，妖梦有点尴尬地歪着头……
		ENDSELECT
	
	;大成功
	ELSEIF TFLAG:193 == 1
		SELECTCASE RAND:2
			CASE 0
				PRINTFORML 「这是什么，就算是我也……哈哈哈！」
				PRINTFORMW 这个玩笑非常受欢迎
			CASE 1
				PRINTFORML 「嗯嗯……原来如此……」
				PRINTFORMW 妖梦对这个不经意提到的话题似乎产生了出乎意料的兴趣
		ENDSELECT
	
	;恋慕　まず20は書き出したい
	ELSEIF TALENT:恋慕
		SELECTCASE RAND:21
			CASE 0
				PRINTFORML 「其实半灵也是能够在一定程度上独自行动的」
				PRINTFORMW 「所以如果%CALLNAME:MASTER%有什么要求的话，我可以借给你一天」
				PRINTFORML 「……诶？ 食物？ 散步？」
				PRINTFORMW 「喂！我可不是宠物！」
			CASE 1
				PRINTFORML 「给半灵起个名字？」
				PRINTFORML 「嗯，毕竟它是我的一部分。我并没有特意去意识到它」
				PRINTFORMW 「……所以」
				PRINTFORMW 「它可不是狗或者猫，明白了吗！」
			CASE 2
				PRINTFORML 「周围的氛围已经适应了，但那股奇怪的风格总是让我不舒服」
				PRINTFORMW 「特别是被击中的感觉——」
				PRINTFORMW （啊，用那种不检点的心情，可能见不到%CALLNAME:MASTER%了……！）
			CASE 3
				PRINTFORML 「我的祖父是我的剑术师，同时也是先代的园艺师」
				PRINTFORMW 「有一天突然辞去职务隐居了，此后就不知所踪了……」
				PRINTFORMW 「……我希望有一天能介绍给你认识。我一直这么想着」
			CASE 4
				PRINTFORML 「真是的，如果总是说些随便的话，你可能会对我失去兴趣的哦？」
				PRINTFORMW 妖梦愉快地听着%CALLNAME:MASTER%的故事
				PRINTFORMW 「虽然我已经习惯了♪」
			CASE 5
				PRINTFORML 「——好像有这样的事情。是不是很了不起？」
				PRINTFORMW 「嘿嘿嘿……嗯，其实是个谎言」
					IF (ABL:教養 >= ABL:MASTER:教養) && RAND:3 == 0
						PRINTFORML 「呼呼，看你的样子好像相信了呢。怎么样，就算是我——」
						PRINTFORMW 「啊不好意思太得意了，所以半灵是咻咻！？」
					ELSE
						PRINTFORML 「……哎呀？嗯，好像露馅了？为什么……？」
						PRINTFORMW %CALLNAME:MASTER%选择对身旁那个看起来不自然而焦躁的半灵保持沉默
					ENDIF
			CASE 6
				PRINTFORMW 「由于幽幽子大人根本不来练习，我对『指南者』这个头衔开始感到危机感」
				PRINTFORML 「所以%CALLNAME:MASTER%，对剑术有兴趣吗？」
				PRINTFORMW 「即使不是剑术也没关系。只要你提出来，我会尽量陪你练！」
			CASE 7
				PRINTFORMW 「不知道是哪个妖怪训练的，这楼观剑几乎能斩断任何东西！」
				PRINTFORML 「快乐？盘念？那是什么？」
				PRINTFORMW 「嗯，呃……？大概不会变成大炮吧，但……？」
			CASE 8
				IF CFLAG:23:1001 == 1
					PRINTFORMW 「……或许我还没有握有白楼剑的资格吧」
					PRINTFORML 「不得不放弃的情感，一直缠绕着」
					PRINTFORMW 「甚至，我希望它能够变成一片无所谓的模糊……」
					PRINTFORMW 「……抱歉，说了这些让你困扰的事」
					PRINTFORMW 「请忘记吧」
				ELSE
					PRINTFORML 「这把白楼剑曾经有些力不从心」
					PRINTFORMW 「但现在我已经解决了一些疑虑，能够灵活运用了」
					PRINTFORML 「……感兴趣吗？」
					PRINTFORMW 「呵呵——%CALLNAME:MASTER%大人，我可不会告诉你」
				ENDIF
			CASE 9
				PRINTFORML 「%CALLNAME:MASTER%先生也完全融入幻想乡了呢」
				PRINTFORMW 「多亏了一些奇怪的朋友吧……」
				PRINTFORMW 「我也有一些奇怪的朋友，因为他，我度过了难以替代的时光」
			CASE 10
				IF ABL:MASTER:料理技能 > 3
					PRINTFORML 「%CALLNAME:MASTER%先生的厨艺真是一绝啊」
					PRINTFORMW 「那么你应该能够理解每天增加菜谱的辛苦吧？」
					PRINTFORML 「所以，下次希望你能教我一些食谱」
					PRINTFORMW 「我也会从中学到东西，而且两个人一起做的话，相互之间也会有所发现的吧」
				ELSE
					PRINTFORML 「%CALLNAME:MASTER%先生，有什么想吃的吗？」
					PRINTFORMW 「如果有的话，我们下次一起做吧。失败了也没关系，下次可以借鉴经验」
					PRINTFORMW 「哪怕是慢慢进步，那也是非常有趣的事情哦！」
				ENDIF
			CASE 11
				PRINTFORML 「虽然有点沮丧，但成为真正的行家还有很长的路要走」
				PRINTFORMW 「%CALLNAME:MASTER%先生眼中，我是不是还是半吊子呢？」
					;合意前後で分岐させられるだろうか？
					IF CFLAG:1 > 0
						PRINTFORMW 「如果是这样的话……我想请你多多教导我」
						PRINTFORMW 妖梦静静地微笑着看向%CALLNAME:MASTER%，眼中似乎有一丝妖异的光芒……
					ELSE
						PRINTFORMW 「如果是这样的话，请多多教导我，日日精进！」
					ENDIF
			CASE 12
				IF CFLAG:66:現在位置 == CFLAG:23:現在位置
				;恋慕でも2分の1でおやつを献上
					IF TALENT:66:恋慕 && RAND:2 == 0
						PRINTFORMW 「啊，幽々子大人。看起来心情不错啊！」
						PRINTFORML 「……那个，%CALLNAME:MASTER%先生离我好近……啊啊！你在做什么啊！？」
						PRINTFORMW （果然连幽々子大人也……但我也……！）
					ELSE
						PRINTFORML 「啊，幽々子大人。发生了什么事吗？」
						PRINTFORMW 「……诶，点心？」
						PRINTFORML 「怎么办……唔，那么就用这个%TEXTR("お饅頭/最中/羊羹/わらび餅/カステラ/")%当作代替吧……」
						PRINTFORMW 从她犹豫的表情看，那应该是她自己的点心吧……
					ENDIF
				ELSE
					IF TALENT:66:恋慕
						PRINTFORML 「%CALLNAME:MASTER%先生在幽々子大人那里可是很受欢迎呢」
						PRINTFORMW 「每当幽々子大人谈论你的时候，她的表情都显得很开心哦？」
						PRINTFORMW （……也许我表现得更加明显吧）
					ELSE
						PRINTFORML 「虽然是身为使用人的我说这种话有点奇怪，但是幽々子大人还真是个神秘的人物」
						PRINTFORMW 「用难以捉摸来形容她可能更合适……在这方面也许和%CALLNAME:MASTER%先生更合得来」
						PRINTFORMW 「她经常想要和我一起玩，和你一样」
					ENDIF
				ENDIF
			CASE 13
				PRINTFORML 「%CALLNAME:MASTER%先生，对刀有兴趣吗？」
				PRINTFORMW 「不仅能派上用场，而且就算不善于使用，佩戴它也能在一定程度上保护自己」
				PRINTFORMW 「而且%CALLNAME:MASTER%先生，无论是佩戴、挥舞还是背负，绝对都很合适！」
			CASE 14
				PRINTFORML 「虽然我已经清楚你并非那种人……」
				PRINTFORML 「但请%CALLNAME:MASTER%先生」
				PRINTFORMW 「即便捡到了别人的东西也不要考虑将它变卖」
				PRINTFORMW 「请小心。在幻想乡确实存在那样的商人，会实施这种行为」
			CASE 15
				IF ABL:戦闘能力 > 4
					PRINTFORML 「听我说%CALLNAME:MASTER%先生！我对『斩雨』这种感觉已经有了相当的掌握！」
					PRINTFORMW 「但总是挥舞刀剑也不现实，结果伞还是一直需要……」
					PRINTFORML 「……连雨云一起？」
					PRINTFORMW 「哦哦……那确实是下一个目标，也是相当不错的目标」
				ELSE
					PRINTFORML 「据说要学会斩雨需要三十年」
					PRINTFORMW 「虽然现在似乎已经触摸到了那个层次」
					PRINTFORMW 「如果能够掌握深意，那么雨天也许就不需要伞了吧？」
				ENDIF
			CASE 16
				IF ABL:戦闘能力 > 4
					PRINTFORML 「最近挥舞空剑的时候，突然感觉到『空气被切割』的瞬间」
					PRINTFORMW 「呼呼，其实我一直觉得五十年内就可以做到」
					PRINTFORML 「……唔，如果问我能否在实战中挥舞，那……嗯，确实是个问题」
					PRINTFORMW 「那就等着吧。等我炉火纯青时，第一个向%CALLNAME:MASTER%先生展示！」
				ELSE
					PRINTFORML 「据说要学会斩空需要五十年」
					PRINTFORMW 「对于这一点我仍然不太明白……好吧！？现在就能做到吗！？」
					PRINTFORML 「嗯，首先是这样……？」
					PRINTFORMW 「……那个，难道这样就叫做『切开空气』了吗？」
				ENDIF
			CASE 17
				PRINTFORML 「师父说，要学会斩时光需要二百年」
				PRINTFORMW 「可惜和红魔馆的女仆战斗并没有太大的收获」
				PRINTFORML 「……虽然这只是毫无根据的直觉」
				PRINTFORMW 「但如果和%CALLNAME:MASTER%先生在一起，似乎有些东西能够掌握的感觉……」
			CASE 18
				PRINTFORML 「学到真理是通过斩来的，师父是这么教导我的」
				PRINTFORML 「虽然有一段时间我为了领悟这一教诲而做了一些冒险……」
				PRINTFORMW 「…………」
				PRINTFORMW 「现在，或许能更冷静地面对这个教诲了」
			; Let's catch bugs!
			CASE 19
				PRINTFORML 「从什么时候开始，在冥界飞着一些不可思议的蝴蝶」
				PRINTFORMW 「不，好像紫女士也用过类似的弹幕……？」
				PRINTFORMW 「一眼就能看出带有相当危险咒术的蝴蝶，修剪时如果飞过附近就感到有些担心……」
				PRINTFORML 「除了夜晚外，其他时间都看不到，而且不知为何在春天时咒术也变得淡薄」
				PRINTFORMW 「虽然不至于认真警戒，但还是会感到有些担心」
			CASE 20
				PRINTFORMW 「嗯嗯嗯……你说得对」
				PRINTFORML 「确实买菜本来不是我作为园艺师的职责，但」
				PRINTFORMW 「自从为了迎合幽々子大人的要求学会了炊事以后，感觉分派给我的工作增加了不少……？」
		ENDSELECT
	
	;思慕その他
	ELSE
		SELECTCASE RAND:13
			CASE 0, 1
				PRINTFORMW 「这个半灵引起了您的注意吗？正因为是我的另一半，所以在许多方面都很方便呢」
					SELECTCASE RAND:4
						CASE 0
							PRINTFORML 「……嗯，不能用来炼制材料吗？你，你说什么呢！？」
							PRINTFORMW 看来它似乎无法取代徘徊的灵魂
						CASE 1
							PRINTFORML 「――像个大年糕一样？」
							PRINTFORML 「…………不要试图吃掉哦」
							PRINTFORMW 虽然只是轻松的评论，但却被怀疑地露骨地戒备着
						CASE 2
							PRINTFORML 「它能变成交通工具吗？」
							PRINTFORML 「啊，毕竟不是魔理沙的扫帚，普通飞行可能更快……」
							PRINTFORMW 「啊，但是当双手被占用时，还可以搭载物品呢」
						CASE 3
							PRINTFORML 「当然，也可以当武器使用！把它扔向对手是最快的方式」
							PRINTFORML 「……要试试吗？」
							PRINTFORMW %CALLNAME:MASTER% 礼貌地拒绝了
					ENDSELECT
			CASE 2
				PRINTFORML 「最近，偶尔会吹来奇怪的风」
				PRINTFORMW 「个人而言，非常在意，但不能被指派调查，这是不同于异变的事情吗？」
				PRINTFORMW 「……即使如此，发现有人的内衣挂在树枝上时，心情仍然相当复杂」
			CASE 3
				PRINTFORML 「%CALLNAME:MASTER% 先生在烹饪时，可能会被幽幽子大人打扰」
				PRINTFORMW 「因为她有点……贪吃，对食物的气味非常敏感」
				PRINTFORMW 「即使食物被吃掉，希望您能宽容一些……」
			CASE 4
				PRINTFORML 「哎呀，居然发生过那样的事！？真是厉害啊……」
				PRINTFORMW 「……嗯，开玩笑？」
					IF TALENT:思慕
						PRINTFORML 「真是的！请不要取笑我！」
						PRINTFORMW 尽管提出抗议，但并没有感受到妖梦的愤怒气息
					ELSE
						PRINTFORMW 「真是的！再取笑我我就生气了！」
					ENDIF
			CASE 5
				PRINTFORML 「哦……我不知道这个，必须记住才行」
				PRINTFORMW 「……嗯，是在开玩笑？」
					IF TALENT:思慕
						PRINTFORML 「唔，又来这种马虎的事情……！」
						PRINTFORMW 虽然表面上有点生气，但并没有感受到妖梦的愤怒气息
					ELSE
						PRINTFORMW 「嗯，要是记错了怎么办！会被嘲笑的！」
					ENDIF
			CASE 6
				PRINTFORML 「正如之前所说，我是白玉楼的园丁。也负责幽幽子大人的护卫和剑术指导」
				PRINTFORMW 「……虽然是受委托的，但本人并不怎么感兴趣」
				PRINTFORML 「每次想要练习，她总是不见了」
				PRINTFORMW 「只有在这个时候准备了点心，她才不会回来……」
			CASE 7
				PRINTFORMW 「这把楼观剑是妖怪锻造的，几乎没有什么刀剑斩不断的！」
				PRINTFORML 「……是哪个妖怪锻造的？」
				PRINTFORMW 「那个，嗯……对不起。我应该问问师傅的……」
			CASE 8
				PRINTFORML 「这把刀叫白楼剑，可以斩断被斩者的犹豫」
				PRINTFORMW 「虽然斩妖除魔能轻松些，但我被阎魔大人责备过斩得太多……」
				PRINTFORML 「――要是能不在意就好了」
				PRINTFORMW 决定装作没有听到什么危险的低语
			CASE 9
				IF TALENT:思慕
					PRINTFORML 「在这里的生活适应了吗？」
					PRINTFORMW 「如果一切顺利的话，倒也不错，但一松懈就会被奇怪的家伙利用」
					PRINTFORMW 「认识一些奇怪的朋友，是吧……啊，你为什么看着我……？」
				ELSE
					PRINTFORML 「在这里的生活怎么样？」
					PRINTFORMW 「外来人很少见，所以一不留神就会被妖怪吃掉」
					PRINTFORMW 「大家都是好人……吗。果然名声不错，是些奇怪的人呢」
				ENDIF
			CASE 10
				IF TALENT:思慕 && ABL:MASTER:料理技能 > 1
					PRINTFORML 「前几天从幽々子大人那里了解到，%CALLNAME:MASTER%先生似乎对各种料理都很了解呢」
					PRINTFORMW 「……如果可以的话，能不能教我一点食谱呢？」
					PRINTFORML 「而且，最好不是写下来，而是实际教授，这样更容易理解呢，嗯――」
					PRINTFORMW 妖梦投过来的眼神让人感到有些不好意思……
				ELSEIF ABL:MASTER:料理技能 > 2
					PRINTFORML 「%CALLNAME:MASTER%さん的烹饪技能似乎相当了得呢……」
					PRINTFORMW 「虽然我不是专业的，但也有一些心得」
					PRINTFORML 「能够按照自己的想法做出料理，有一种……成就感吧」
					PRINTFORMW 妖梦深有感触地点了点头
				ELSE
					PRINTFORML 「学会自己做饭真的很有趣哦」
					PRINTFORMW 「虽然学会的过程很辛苦，也很费时，但在意想不到的时候可能会救你一命」
					PRINTFORMW 「比如说――遇到空腹的幽々子大人的时候」
				ENDIF
			CASE 11
