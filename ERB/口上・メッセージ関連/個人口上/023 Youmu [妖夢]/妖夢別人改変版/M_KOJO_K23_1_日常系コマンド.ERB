					PRINTFORML %CALLNAME:MASTER%和妖梦一起改变步伐在周围走动
			ENDSELECT
			PRINTFORMW
			PRINTFORML 「辛苦了！%CALLNAME:MASTER%，%TEXTR("干得漂亮/")%！」
			PRINTFORMW 感觉这次的训练比平时要好……
			EXP:MASTER:戦闘経験 += 1
		ENDIF
	ENDIF
ENDIF
