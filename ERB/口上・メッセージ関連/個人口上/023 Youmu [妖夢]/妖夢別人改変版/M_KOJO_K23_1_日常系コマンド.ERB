	;				=8セッション/=9採集/=10釣り/=11調合/=12休憩/=13晩酌/=14買い物/=15説教/=16落とし穴
	;ブチギレor反発刻印有
	IF CFLAG:318 == 1 || (MARK:23:反発刻印 == 1 && RAND:3 == 0) || (MARK:23:反発刻印 > 1 && RAND:3 != 0)
		PRINTFORML 「…………」
		PRINTFORMW 妖夢对%CALLNAME:MASTER%视而不见……
	ELSE
	SELECTCASE Activity_Type:TARGET
		CASE 0
			;▼考え事［なに考えてるの］
			;TFLAG:193,-1=はぐらかされる
				IF TFLAG:193 == -1
					PRINTFORMW 「——诶？啊，这个，%CALLNAME:MASTER%，您说这个只能告诉您一个人吗……」
				ELSE
					SELECTCASE RAND:3
						CASE 0
							PRINTFORML 「我在考虑明天晚餐的菜单」
							PRINTFORMW 「我这是心急吗？不不，绝对不是这样的……」
						CASE 1
							PRINTFORML 「下次要怎样修剪花园里的树木呢……」
							PRINTFORMW 「是的！%CALLNAME:MASTER%，如果您有要求，我会尽量满足的哦？」
						CASE 2
							PRINTFORML 「我在确认下次购物清单」
							PRINTFORMW 「因为是大工程，提前做好准备是很重要的」
					ENDSELECT
				ENDIF
		CASE 2
			;▼用餐［一起用餐］
			;TFLAG:193,-1=MASTER没有饿
				IF TFLAG:193 == -1
					PRINTFORMW 「诶……？那就不勉强塞下去了吧……」
				ELSEIF TALENT:恋慕
					SELECTCASE RAND:2
						CASE 0
							PRINTFORML 「虽然只是简单的小吃……多带一点是正确的选择」
							PRINTFORMW 「稍微解决了点饥饿感吗？」
						CASE 1
							PRINTFORML 「平日只是接受别人准备的，茶水我来泡吧」
							PRINTFORMW 「……怎么样？泡得好喝的话就好了……」
					ENDSELECT
				ELSE
					PRINTFORML 「啊，你想要分一点吗？」
					PRINTFORMW 「没关系啦……本来就不多，给不了太多啦？」
				ENDIF
		CASE 4
			;▼打扫卫生［帮忙打扫卫生］
			;※[打扫卫生员]或[嗅觉耐性-1以下]才能
				;冬天户外
				IF OUTROOF(CFLAG:現在位置) && DAY:2 == 4
					PRINTFORML 「积雪这么厚会影响通行！」
					PRINTFORMW 「在有人摔倒之前一起清理吧」
				;白玉楼庭院
				ELSEIF MAIN_MAP == 6 && CFLAG:MASTER:現在位置 == 621
					PRINTFORML 「为了保持庭院的景观，日常清洁是必不可少的」
					PRINTFORMW 「嗯，终究还是让您帮忙了，真是有些不好意思」
				ELSE
					SELECTCASE RAND:2
						CASE 0
							PRINTFORML 「是仆人的责任吗，我有点在意细微的脏污」
								IF MAIN_MAP == 6 && INRANGE(CFLAG:MASTER:現在位置, 620, 629)
									PRINTFORMW 「虽然得到了%CALLNAME:MASTER%的帮助，其他幽灵在做些什么呢……？」
								ELSE
									PRINTFORMW 「自作主张清理有点不安，但清洁后应该没人会不开心……大概」
								ENDIF
						CASE 1
							PRINTFORML 「这里看起来不错呢。那么下一个地方是……」
								IF ABL:MASTER:清掃技能 >= ABL:清掃技能
									PRINTFORM %CALLNAME:MASTER%在指导妖梦的同时
								ELSE
									PRINTFORM %CALLNAME:MASTER%在听从妖梦的指示
								ENDIF
							PRINTFORMW 两人一起开始周围的清洁工作
					ENDSELECT
				ENDIF
		CASE 5
			;▼運動［一緒に運動する］
			;※[音楽知識]持ちは除く（演奏になる）
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 「感觉还需要更多的锻炼」
							IF TALENT:恋慕
								PRINTFORMW 「能够和%CALLNAME:MASTER%一起真是我意料之外的幸运！」
							ELSE
								PRINTFORMW 「有对话对象的话，内容会更加丰富，所以很感激」
							ENDIF
					CASE 1
						PRINTFORML 「利用空闲时间稍微放松身体，即使是这样也会在关键时刻起到作用」
						PRINTFORMW 「太过投入会使人筋疲力尽，适度才是关键哦」
				ENDSELECT
		CASE 6
			;▼阅读［听取对书籍的感想］
			;TFLAG:193,-1=专心阅读无法回答
				IF TFLAG:193 == -1
					PRINTFORMW 「…………%TEXTR("嗯嗯/嗯嗯嗯/哦/")%」
				ELSE
					PRINTFORMW 「%CALLNAME:MASTER%，您对这本书也感兴趣吗？」
						SELECTCASE RAND:3
							CASE 0
								PRINTFORML 「看到自己不知道的料理，光是在纸面上看就让人兴奋」
								PRINTFORMW 「保持这份热情，想要尝试挑战一些大胆的料理呢……并不是外表看起来危险的意思」
							CASE 1
								PRINTFORML 「外面有这么多让我惊叹不已的花园啊……」
								PRINTFORMW 「嗯，下次也试着和红魔馆的门卫交流一下吧……嗯，有点像是半个园丁呢」
							CASE 2
								PRINTFORML 「想要向幽幽子大人请教练习的方法，正在查找书籍」
								PRINTFORMW 「连食物都没有效果，前途一片暗淡……不过，不能轻易放弃对吧」
						ENDSELECT
				ENDIF
		CASE 7
			;▼料理［帮忙料理］→［分享料理］
			;TFLAG:193,2=帮忙料理,0=吃掉做好的料理,-1==MASTER没有饿（吃的时候）
				IF TFLAG:193 == 2
					PRINTFORML 「正在尝试用手头的食材做些什么」
					PRINTFORMW 「慢慢地变得有趣起来了……%CALLNAME:MASTER%，您要一起吗？」
					PRINTFORMW %CALLNAME:MASTER%与妖梦一起投入到料理创作中
				ELSEIF TFLAG:193 == -1
					PRINTFORMW 「诶……？那就不勉强塞下去了吧……」
				ELSE
					IF TALENT:恋慕
						SELECTCASE RAND:2
							CASE 0
								PRINTFORML 「作为即席料理已经足够了！只是量有点少有点遗憾……」
								PRINTFORMW 「稍微解决了点饥饿感吗？」
							CASE 1
								PRINTFORML 「平日只是接受别人准备的，茶水我来泡吧」
								PRINTFORMW 「……怎么样？泡得好喝的话就好了……」
						ENDSELECT
					ELSE
						PRINTFORML 「凑合做的还算是可以的料理！」
						PRINTFORMW 「本来就不多，所以没办法分给你太多啦……」
					ENDIF
				ENDIF
		CASE 9
			;▼採集［採集を手伝う］
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 「并没有特别想要的材料」
						PRINTFORMW 「如果能简单地找到当季食材，会有点开心呢」
					CASE 1
						PRINTFORML 「只是随意寻找，如果非要说的话，想要一些可以用来做食材的东西」
						PRINTFORMW 「可以自己带着，如果能多采集一些，在府邸也能用得上」
				ENDSELECT
		CASE 10
			;▼钓鱼［一起钓鱼］
			;TFLAG:193,-1=没有钓竿只是看着
				IF TFLAG:193 == -1
					PRINTFORML 「唔……只被看着还挺让人不安的」
					PRINTFORMW 「要是有两根钓竿就好了……」
				ELSE
					SELECTCASE RAND:2
						CASE 0
							PRINTFORML 「什么也不做，只是垂钓，也是个不错的放松方式」
							PRINTFORMW 「呼呼……要注意不要被鱼竿带走了」
						CASE 1
							PRINTFORML 「好了，既然这么好，就去钓个大家伙吧！」
							PRINTFORMW 「如果能钓到漂亮的鱼，下次买东西时就能轻松一些！」
					ENDSELECT
				ENDIF
		CASE 11
			;▼实验［帮忙实验］
			;PRINTFORMW 
		CASE 12
			;▼悠闲［一起悠闲］
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「咦，%CALLNAME:MASTER%，您也在休息吗？」
						PRINTFORMW 「紧绷的神经也不好，该休息的时候就休息吧」
					CASE 1
						PRINTFORML 「很宁静呢……嗯，您怎么了？」
						PRINTFORMW %CALLNAME:MASTER%在妖梦身边，忍住了想要把半灵抱作枕头的冲动……
					CASE 2
						PRINTFORML 「呼……哦，您泡了茶给我吗」
						PRINTFORMW 「谢谢。那我虽然少量，也请您享用点心……」
				ENDSELECT
		CASE 13
			;▼饮酒［一起喝酒］
			;※酒耐性需大于0
				IF TALENT:恋慕 && RAND:3 == 0
					PRINTFORML （……这、这种氛围让人有点醉了……）
					PRINTFORMW 妖梦脸红着为%CALLNAME:MASTER%斟酒
				ELSE
					SELECTCASE RAND:2
						CASE 0
							PRINTFORML 「这让人感到一天努力工作后的实感，这个时刻很不错」
							PRINTFORMW 「要注意不要喝太多，明天也要加油……」
						CASE 1
							PRINTFORML 「能陪伴您吗？我也觉得有个聊天伴很开心」
							PRINTFORMW 「啊……但请不要说太过荒谬的笑话」
							PRINTFORMW 「一醉方休，可能会全盘接受了呢……」
					ENDSELECT
				ENDIF
		CASE 14
			;▼购物［帮忙购物］
				IF TALENT:恋慕 && RAND:3 == 0
					PRINTFORML 「不能让您费心的购物，但……」
					PRINTFORMW 「%CALLNAME:MASTER%，您需要什么吗？我可以帮您拿东西！」
				ELSE
					SELECTCASE RAND:2
						CASE 0
							PRINTFORML 「购物时没能买到的东西，就这样在另一个机会带回来了」
							PRINTFORMW 「这点东西不需要用货车搬运」
						CASE 1
							PRINTFORML 「嗯嗯嗯……除了工作之外，其他的东西让人眼花缭乱」
							PRINTFORMW 「但只买必要的东西……不能浪费」
					ENDSELECT
				ENDIF
		CASE 15
			;▼説教［様子をうかがう］
			;※神霊・蓬莱人は除く
			;TFLAG:193,-1
			;PRINTFORMW 
		CASE 16
			;▼落とし穴［いたずらに付き合う］or［様子をうかがう］
			;※三月精・チルノ・クラウンピースのみ
			;それ以外は落ちる側
			;PRINTFORMW 
		CASE 17
			;▼雪だるま作り［一緒に雪作り］
			;※冬の月のみ
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 「堆积起来玩也有雪的风情啊……」
						PRINTFORMW 「……如果说是在收集整理的意义上，这也算是在铲雪吧？」
					CASE 1
						PRINTFORML 「要做的话就做得有气势一点！」
						PRINTFORMW 「是追求造型还是追求大小呢……挺让人犹豫的」
				ENDSELECT
		CASE 18
			;▼被炉上悠闲［在被炉上放松］
			;※仅限冬月
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「在被炉取暖是冬天的乐趣之一呢……」
						PRINTFORMW 「一待就不想出去了，这是个难点……啊，就连这些小事都让人略感烦恼……」
					CASE 1
						PRINTFORML 「有时会有人在冥界担心黄泉炉的食物，但对我来说，被炉才是真正可怕的地方」
						PRINTFORMW 「如果吃了橘子或冰淇淋，即便那岐命想爬出来也会很困难吧」
					CASE 2
						PRINTFORML 「能更多地享受这片刻的幸福，感觉有点优越……」
						PRINTFORMW 妖梦与半灵一起享受着被炉的温暖……
				ENDSELECT
		ENDSELECT
	ENDIF
ENDIF
RETURN 1

