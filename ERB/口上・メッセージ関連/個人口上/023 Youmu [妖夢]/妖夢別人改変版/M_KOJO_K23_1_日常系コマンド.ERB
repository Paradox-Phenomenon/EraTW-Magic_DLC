;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;時間停止中
	IF FLAG:70
	;睡眠中、泥酔
	ELSEIF CFLAG:睡眠 || TCVAR:泥酔 == 1
	;通常
	;ブチギレ
	ELSEIF CFLAG:318 == 1
		PRINTFORML 「…………」
		PRINTFORMDW 鞘から刀身が覗いたのを見て%CALLNAME:MASTER%は反射的に手を引っ込めた……
	;反発刻印有
	ELSEIF (MARK:23:反発刻印 == 1 && RAND:2 == 0) || MARK:23:反発刻印 > 1
		PRINTFORML 「……やめて下さい」
		PRINTFORMDW 妖夢は%CALLNAME:MASTER%の手をにべもなく払い除けた……
	;失敗
	ELSEIF TFLAG:193 == -1
		IF TALENT:恋慕
			PRINTFORML 「わわ……%CALLNAME:MASTER%さん、抑えていただけると……」
			PRINTFORMDW 些か強く撫ですぎてしまった……
		ELSE
			PRINTFORML 「人の頭を軽々しく……」
			PRINTFORMDW 妖夢は警戒した様子だ……
		ENDIF
	;恋慕
	ELSEIF TALENT:恋慕
		SELECTCASE RAND:4
			CASE 0
				PRINTFORML 「こうして撫でられるとまるで褒められているみたいで……」
				PRINTFORMW 「……ちょっと癖になりそうです」
			CASE 1
				PRINTFORMDW %CALLNAME:MASTER%が妖夢を撫でていると半霊が物欲しそうに近寄ってきた
				PRINTFORML 「ちが、そういう訳じゃ……ない事も、ないんですけど……」
				PRINTFORMDW %CALLNAME:MASTER%は空いている手で半霊も撫でてあげた
			CASE 2
				PRINTFORML 「ん……」
				PRINTFORMDW 妖夢は目を細めて%CALLNAME:MASTER%の手に身を委ねている
			CASE 3
				PRINTFORML 「優しくして下さるなら……好きなだけ」
				PRINTFORMDW 妖夢は%CALLNAME:MASTER%が撫でやすいようそれとなく身体を寄せた
		ENDSELECT
	;親密6以上
	ELSEIF ABL:親密 > 5
		SELECTCASE RAND:3
			CASE 0
				PRINTFORML 「せめてカチューシャには気を使っていただけると……」
				PRINTFORMDW 居心地悪そうにしているものの、今のところ振り払おうとする気配はない
			CASE 1
				PRINTFORML 「……子供じゃないんですから」
				PRINTFORMDW 妖夢は不服そうにしているが、一応髪には触らせてくれている
			CASE 2
				PRINTFORML 「楽しいんですか？　……それなら、まあ」
				PRINTFORMDW 妖夢は訝しげだがそこまで嫌そうにはしていない
		ENDSELECT
	;その他
	ELSE
		PRINTDATAL
			DATAFORM 「え、は！？　い、いきなり何を……！」
			DATAFORM 「い……驚かすにしても他に方法が……」
		ENDDATA
		PRINTFORMDW 妖夢は%CALLNAME:MASTER%から一歩大きく後退った……
	ENDIF

ENDIF
RETURN 1
