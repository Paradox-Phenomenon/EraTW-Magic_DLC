				IF ABL:MASTER:料理技能 > 4
					PRINTFORMW 「……并不是怀疑您的厨艺，只是希望能有所借鉴……好的」
				ENDIF
			PRINTFORMW 「那么我开始了……我先开动了」
		ENDIF
	ENDIF
	PRINTFORML
	CALL K23_TASTE_DISH
ENDIF
RETURN 1
;-------------------------------------------------
;食事の反応＠TW映姫口上参考
;-------------------------------------------------
@K23_TASTE_DISH
;失敗
IF TFLAG:193 == -1
	IF DISHNAME == "白玉みつまめ"
		PRINTFORML 「……这个白玉，相当粉状呢」
		PRINTFORMW 「而且这边水可能放多了，都快要溶解了」
			SELECTCASE DAY:2
				CASE 2
					PRINTFORMW 「怎么会变成这种奇怪的情况呢……？」
				CASEELSE
					PRINTFORMW 「心态也是重要的材料之一，这次算是个教训……」
			ENDSELECT
	ELSEIF DISHNAME == "泡菜"
		PRINTFORML 「嗯嗯？ %CALLNAME:MASTER%，这个……」
		PRINTFORMW 「不，这不是浅漬，甚至不是」
		PRINTFORMW 「……生菜？」
	ELSEIF STRCOUNT(DISH_TASTE, "グロテスク") || STRCOUNT(DISH_TASTE, "謎料理")
		PRINTFORMW 「…………」
		PRINTFORML 「可惜了，我会吃完的」
		PRINTFORMW 「我对这类料理不擅长，请务必记住……」
	ELSEIF TALENT:恋慕
		IF DISH_ASSI == 23
			PRINTDATAL
				DATAFORM 「……哪里出错了呢……？」
				DATAFORM 「……是漏掉了什么步骤吗……？」
			ENDDATA
			PRINTFORMW 「无论如何这都是个问题……我也会学习的」
		ELSE
			PRINTFORMW 「……味道，很好吃，的，呢？」
			PRINTFORML 「……抱歉」
			PRINTFORMW 「如果能模仿舌头的动作就好了……」
		ENDIF
	ELSE
		IF DISH_ASSI == 23
			PRINTFORML 「…………嗯嗯嗯」
			PRINTFORMW （明明我也看着的……竟然犯了致命的错误……？）
		ELSE
			PRINTFORML 「……非常难以启齿的是」
			PRINTFORMW 「稍微……不，其实很大程度上与我的口味相悖呢……」
		ENDIF
	ENDIF
;普通or成功
ELSE
	IF DISHNAME == "白玉みつまめ"
		SELECTCASE RAND:2
			CASE 0
				PRINTFORML 「……QQ弹牙感和顺滑的口感……白玉必须是这样的」
					SELECTCASE DAY:2
						CASE 2
							PRINTFORMW 「进一步改进的话，说不定能成为名副其实的名菜呢！」
						CASEELSE
							PRINTFORMW 「美味的东西不分时间地点，这次可算是确凿的证据了！」
					ENDSELECT
			CASE 1
				PRINTFORML 「嗯嗯……我真是太棒了，能够自夸自乐起来」
				PRINTFORMW 「……嗯？」
				PRINTFORML 「……如果你那么想尝一尝的话，那就拿去吧。来吧！ 来吧！！」
				PRINTFORMW 差点被半灵吞下……
		ENDSELECT
	ELSEIF DISHNAME == "泡菜"
		IF DISH_ASSI == 23
			PRINTFORML 「太厉害了……真是好吃的泡菜」
			PRINTFORMW （为什么这么快……难道地点和天气也有关系……？）
		ELSE
			PRINTFORML 「搭配白米真是绝佳。这个腌制了多久？」
			PRINTFORMW 「……刚腌的？ 又来这种玩笑……」
		ENDIF
	ELSEIF STRCOUNT(DISH_TASTE, "グロテスク") || STRCOUNT(DISH_TASTE, "謎料理")
		PRINTFORML 「咦，意外地……」
		PRINTFORMW 「……虽然不算糟糕，但也不会特意去制作和品尝」
	ELSEIF TALENT:恋慕
		IF DISH_ASSI == 23
			PRINTFORML 「好吃！ 做得这么好真是太好了」
				IF ABL:MASTER:料理技能 > 4
					PRINTFORMW 「为了不辱没旁边烹饪的人，我也要更加努力」
				ELSEIF ABL:MASTER:料理技能 > 1
					PRINTFORMW 「正因如此，下次要朝着更高水准努力了呢」
				ELSE
					PRINTFORMW （爱心果然……爱心能解决一切……！）
				ENDIF
		ELSE
			PRINTFORML 「哇，好好吃！ 这是我喜欢的味道」
				IF ABL:MASTER:料理技能 > 4
					PRINTFORMW 「下次想请教一下这道菜的窍门。还有%CALLNAME:MASTER% 您喜欢的口味」
				ELSE
					PRINTFORMW 「单凭心意就足够了，但并不容易实现。您的厨艺真是了不起」
				ENDIF
		ENDIF
	ELSE
		IF DISH_ASSI == 23
			PRINTFORML 「……嗯，做得不错让我放心了」
				IF ABL:MASTER:料理技能 > 4
					PRINTFORMW 「%CALLNAME:MASTER% 您这样的人，难道做不好的事情更难吗？」
				ELSEIF ABL:MASTER:料理技能 > 1
					PRINTFORMW 「如果要招待其他人，更要注意口味的匹配」
				ELSE
					PRINTFORMW （总算能帮上忙了吧……）
				ENDIF
		ELSE
			IF ABL:MASTER:料理技能 > 4
				PRINTFORML 「……哦。这道菜，果然很好吃」
				PRINTFORMW 「即使说您在人间开店，我也会相信，毫无怀疑」
			ELSE
				PRINTFORML 「……哦。这道菜，很好吃」
				PRINTFORMW 「特意迎合我的口味？ 那我就感到很高兴了」
			ENDIF
		ENDIF
	ENDIF
ENDIF
RETURN 1
