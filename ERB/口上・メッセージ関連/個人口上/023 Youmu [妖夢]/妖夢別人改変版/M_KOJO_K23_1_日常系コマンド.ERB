@M_KOJO_別人版_MESSAGE_COM_K23_445_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF TCVAR:泥酔 == 1
		PRINTFORML
	ELSEIF CFLAG:318 == 1
		PRINTFORML 「…………」
		PRINTFORMDW 妖夢は%CALLNAME:MASTER%から離れた場所で黙々と手を動かしている……
	ELSEIF (MARK:23:反発刻印 == 1 && RAND:2 == 0) || MARK:23:反発刻印 > 1
		PRINTFORML 「……お手伝いはしますが」
		PRINTFORMDW ぎこちない空気の中、%CALLNAME:MASTER%は妖夢と採集に打ち込んだ……
	ELSEIF TFLAG:193 == 0
		IF (TALENT:思慕 || TALENT:恋慕) && RAND:3 == 0
			PRINTFORML 「なかなか使えそうな物がありませんね……ん？」
			PRINTFORMW 「……はっ！？　%CALLNAME:MASTER%さん、それは私の半霊……もうっ、分かっててやってますね！」
		ELSE
			SELECTCASE RAND:2
				CASE 0
					PRINTFORML 「むむぅ……目ぼしい物が見当たりません」
					PRINTFORMW 「どれほど慣れていようと現物が無ければどうしようもないので、こればかりは運次第ですか」
				CASE 1
					PRINTFORML 「こちらには無し、あちらにも無し……ままならないものです……」
					PRINTFORMDW 妖夢と半霊は別々の場所を探しているものの、使えそうな素材は見付からないようだ
			ENDSELECT
		ENDIF
	ELSE
		SELECTCASE TFLAG:193
			CASE 600
				PRINTFORML 「おや、それは食べられるキノコですね」
				PRINTFORMW 「煮ても焼いても美味しいですし、つくづく良い食材ですよ」
			CASE 601
				PRINTFORML 「む……それは毒キノコですね」
				PRINTFORMW 「決して食用と誤らないよう、キノコ採りは最低限の知識を付けた上で慢心せず臨みたいものです」
			CASE 602
				PRINTFORML 「やけにネバネバしたキノコですね……なめこではなさそうですが」
				PRINTFORMW 「ここまでだと持ち運びにも苦労しそうです……」
			CASE 603
				PRINTFORML 「えﾞっ……虫からキノコが……！？」
				PRINTFORMW 「も、持っていかれるんですか？　確かに薬にはなりそうですけど……」
			CASE 604
				PRINTFORML 「……本能が警鐘を鳴らしてくるキノコです、白黒が大喜びしそうな程度には」
				PRINTFORMW 「識者にとってば有用な素材なんでしょうけど、ここまでくると私には斬り心地の違いでしかありませんね」
			CASE 605
				PRINTFORML 「魔法使いには重宝されているキノコのようですね」
				PRINTFORMW 「私には何に使うかサッパリなので……食材になりそうには思えませんし」
			CASE 607, 608, 613
				PRINTFORML 「薬草……なのは間違いないのですけど、私には質までは……」
				PRINTFORMW 「どれくらいの効能があるかはご自身で判断して下さると助かります……」
			CASE 611
				PRINTFORML 「旬の山菜は探し甲斐のある食材ですよねぇ」
				PRINTFORMW 「癖の少ない物は意外な料理と合ったりもするので、そういう面でも楽しさがありますよ」
			CASE 612
				PRINTFORML 「山菜採りでの事故は何も妖怪や動物、滑落や遭難だけではありません」
				PRINTFORMW 「今でも間違って食べた毒草で冥界にやってくる幽霊は偶にいるんですよね……」
			CASE 614
				PRINTFORML 「彼岸では馴染み深い花ですね。此岸では再思の道が著名でしょうか？」
				PRINTFORML 「……ただ、その先の無縁塚には一輪たりとも咲かないんです」
					IF TALENT:恋慕 && RAND:2 == 0
						PRINTFORMW 「あの墓地に眠る者はこの花にさえ弔われません。どうか……%CALLNAME:MASTER%さんもお気を付け下さい」
					ELSE
						PRINTFORMW 「この花にも弔われない彼らには、ほんの少しだけ同情させられますよ……」
					ENDIF
			CASE 616
				PRINTFORML 「折らずに掘ろうとすると難しいんですよねえ、今回は上手くいきましたよ」
				PRINTFORMW 「どんな料理に……へ？　食材にはしない？　……？？　そ、そうですか……」
			CASE 617
				PRINTFORML 「へぇ～、これがあのドリンクの原料になるんですねぇ」
				PRINTFORMW 「人里へ薬を売りに来る方の兎が購入者に渋い顔をしているのを何度か見たので、私は使った事ないんですけど……」
			CASE 618
				PRINTFORML 「これは貴重品らしいですね……私としては普通のニンジンの方がありがたいですけど」
				PRINTFORMW 「薬膳にするにしても専門の知識は必要になりますからねえ……」
			CASE 619
				PRINTFORML 「葉や茎よりも、こういった根っこの方が強い薬になる印象があります」
				PRINTFORMW 「まあ飽くまで私の印象なので……詳しい事は専門家に訊ねてみて下さい」
			CASE 620
				PRINTFORML 「――はあっ！」
				PRINTFORMW 「成程、抜いた瞬間首を落としてしまえば何ともありませんね……楽しくなってきたのでもう少し採って行きませんか？」
			CASE 626
				PRINTFORML 「そのままでも手を加えても美味しく食べられますよねぇ」
				PRINTFORMW 「道端で赤く実っている姿を見付けると、つい嬉しくなってしまいますよ」
			CASE 627
				PRINTFORML 「私は専ら食材としてですが、それ以外にも用途が多い事は流石に知っていますよ。しかし――」
				PRINTFORMW 「今気にすべきは、追って来ている蜂をどう撒くか、です……っ！」
			CASE 628
				PRINTFORML 「これも立派な秋の味覚ですねぇ、見付けたアケビをその場でいただくというのもなんだか通な気分になれます」
				PRINTFORMW 「可愛い花を咲かせるので観賞用としてもいいものですよ」
			CASE 629
				PRINTFORML 「立派なタケノコでしたがなんとか綺麗に掘り出せましたね」
				PRINTDATAW
					DATAFORM 「灰汁抜きにも手間はかかりますけど、その苦労に見合う素晴らしい旬の味覚ですよ！」
					DATAFORM 「……キノコかタケノコか？　はあ、どちらも良い食材だと思いますよ……？」
				ENDDATA
			CASE 630
				PRINTFORML 「希少品には違いありませんけど、天人達はこればかり食べているらしいですよ。飽きたりは――」
				PRINTFORMW 「あっ、あ～……そういえば飽きたとか言ってるのがいましたねぇ……」
			CASE 631
				PRINTFORML 「素材になりそうと理解していても、拾い集めるのは気が進みません……」
				PRINTFORMW 「……あるべき物はあるべき場所に埋まっている事を祈りたいです」
			CASE 636
				PRINTFORML 「うっ……%CALLNAME:MASTER%さん、それを持ち帰るおつもりで……？」
				PRINTFORMW 「園芸には欠かせない物になるとはいえ現物は気後れしますね……」
			CASE 638
				PRINTDATAL
					DATAFORM 「この気性の荒さ、恐らく旧地獄の怨霊ですね。抜け出してきたのでしょう」
					DATAFORM 「この落ち着きの無さ、恐らく死神の目を盗んで逃げ出してきましたね」
					DATAFORM 「……これは、ちょっと困りましたね。今のところ大人しく成仏する気が無さそうです……」
				ENDDATA
				PRINTFORML 「とりあえず私が一旦連れて帰りますので……は？　そ、素材に？」
				PRINTFORMW （ええぇ……閻魔様に叱られたりしないのかな……？）
			CASE 639
				PRINTFORML 「……？　……？？　確かに、そこにあるのに……」
				PRINTFORMW 「形容しがたいと言うより、理解してはいけないような……うっ、頭が……」
			CASE 647
				PRINTFORML 「……ほうほう、これがアビリティカードの原料に」
				PRINTFORMW 「あのカード、斬った時の手応えが気持ち良いんですよねえ。%CALLNAME:MASTER%さんも機会があれば是非お試し下さい」
			CASE 665
				PRINTFORML 「そのままでも充分食べられますが、個人的には手を加える方がお勧めですね」
				PRINTFORML 「葉が綺麗に紅葉するので眺める分にも趣がありますよ」
				PRINTFORMW 「……そういえば、ブドウの紅葉も秋神様の管轄なのでしょうか……？」
			CASE 666
				IF ABL:MASTER:教養 >= 3
					PRINTFORML 「……これが珍しいワインに？　凄い発想があるんですね……」
					PRINTFORMW 「でしたらもう少し集めてみましょうか、萎びた粒ではそれなりの数は必要そうです」
				ELSE
					PRINTFORML 「あっ……このブドウ、かびて萎びてしまっています」
					PRINTFORMW 「……いやぁ、これは流石に採って行っても使い道が……」
				ENDIF
			CASE 706
				PRINTFORML 「捕まえるくらいなら特に思う事もないのですけど」
				PRINTFORMW 「素材、特に食材としては些か遠慮させていただきたいですね……」
			CASEELSE
				PRINTFORML 「んん、この素材は……？」
				PRINTFORMW 「何に使えるのでしょう……%CALLNAME:MASTER%さんはご存じでしょうか？」
		ENDSELECT
	ENDIF
ENDIF
RETURN 1
