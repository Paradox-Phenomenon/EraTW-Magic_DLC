;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	SELECTCASE TFLAG:193
		CASE 6
		;大成功（酔い）
			IF TALENT:恋慕
				PRINTFORML 「えへへぇ、そうなんですよぉ～♪」
				CALL HPH_PRINT,@"「やっぱりぃ、%CALLNAME:MASTER%さんは話の分かるステキな方ですねぇHPH」","W"
			ELSE
				PRINTFORML 「あはは！　その通りです！」
				PRINTFORMW 「やはり%CALLNAME:MASTER%さんはデキる方だと思ってたんですよぉ♪」
			ENDIF
		CASE 5
		;成功（酔い）
			IF TALENT:恋慕
				PRINTFORML 「えへへぇ、そうですよねぇ♪」
				CALL HPH_PRINT,@"「%CALLNAME:MASTER%さんならちゃんと聞いてくれると信じてましたよぉHPH」","W"
			ELSE
				PRINTFORML 「ですよねぇ……そう思いますよねぇ」
				PRINTFORMW 「%CALLNAME:MASTER%さんは話の分かる方ですねぇ♪」
			ENDIF
		CASE 4
		;失敗（酔い）
			IF TALENT:恋慕
				PRINTFORML 「――%CALLNAME:MASTER%さんまでそんな事を仰るのですか」
			ELSE
				PRINTFORML 「――私の話、聞いてませんよね？」
			ENDIF
			PRINTFORMDW 突如真顔になった妖夢が刀に手をかけようとするのを%CALLNAME:MASTER%は既の所で食い止めた……
		CASE 3
		;大成功
			SELECTCASE RAND:2
				CASE 0
					PRINTFORMW 「屋敷の幽霊は私にばかり仕事を押し付けて！」
						IF TALENT:恋慕
							PRINTFORML 「――――ぷっ、あはは！　それは良い脅し文句ですね」
							PRINTDATAW
								DATAFORM 「『%CALLNAME:MASTER%さんに素材にしてもらう』だなんて、きっと震え上がって働き出しますよ」
								DATAFORM 「次怠けている幽霊を見かけたら早速試させていただきます、いい案をありがとうございました」
							ENDDATA
						ELSE
							PRINTFORML 「――――おお、閻魔様に」
							PRINTFORMW 「確かに頼めばお説教してもらえそうですけど、間違いなく私も巻き添えですよね……」
						ENDIF
				CASE 1
					PRINTFORMW 「皆私を半人前半人前と馬鹿にして！」
						IF TALENT:恋慕
							PRINTFORML 「――――えっ……ぁ……」
							PRINTFORMW 「ぁ、あー……%CALLNAME:MASTER%さんがそう仰るのでしたら、暫くは半人前のままでいいかも……」
						ELSE
							PRINTFORML 「――――そう、その通りです！」
							PRINTFORMW 「今半人前ならもっと伸びしろがあるんです、%CALLNAME:MASTER%さんはそこを分かって下さるなんて！」
						ENDIF
			ENDSELECT
		CASE 2
		;成功
			PRINTDATAW
				DATAFORM 「屋敷の幽霊は私にばかり仕事を押し付けて！」
				DATAFORM 「皆私を半人前半人前と馬鹿にして！」
			ENDDATA
				IF TALENT:恋慕
					PRINTFORML 「――――あっ、す、すみません。こんなつまらない話を」
					PRINTFORMW 「真剣に聞いて下さるのでつい長々と……お付き合いいただきありがとうございました」
				ELSE
					PRINTFORML 「――――あっ、す、すみません。長々と話してしまって」
					PRINTFORMW 「茶化さず聞いて下さるのでつい……おかげで気分が晴れましたよ」
				ENDIF
		CASE 1
		;失敗
			SELECTCASE RAND:2
				CASE 0
					PRINTFORMW 「屋敷の幽霊は私にばかり仕事を押し付けて！」
					PRINTFORML 「せめて掃除か買い出しくらいは……メイド妖精でさえ最低限の働きはしているのに」
					PRINTFORMW 「あぁ、妬ましい……妬ましい……！！」
				CASE 1
					PRINTFORMW 「皆私を半人前半人前と馬鹿にして！」
					PRINTFORML 「そんな事は私自身が一番自覚しているというのに、何度も何度も……」
					PRINTFORMW 「うぅ～……思い出したらまた……！」
			ENDSELECT
	ENDSELECT
ENDIF
RETURN 1
