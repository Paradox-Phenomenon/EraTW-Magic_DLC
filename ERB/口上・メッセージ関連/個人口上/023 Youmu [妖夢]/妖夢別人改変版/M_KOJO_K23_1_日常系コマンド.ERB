;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF CFLAG:睡眠 || FLAG:70 || TCVAR:烂醉
		PRINTFORML
	;嘻嘻中
	ELSEIF CFLAG:23:诶嘿嘿
		PRINTFORML 「……打扫，是吧……打扫？」
		PRINTFORMW 「现在吗？ ……好，我帮忙……」
	;帮忙
	ELSEIF TFLAG:193 == 1
		;发火
		IF CFLAG:318 == 1 || (MARK:23:反発刻印 == 1 && RAND:3 == 0) || (MARK:23:反発刻印 > 1 && RAND:3 != 0)
			PRINTFORML 「…………」
			PRINTFORMW %CALLNAME:MASTER%和妖梦默默地完成了清理，一言不发……
		;铲雪
		ELSEIF OUTROOF(CFLAG:現在位置) && DAY:2 == 4
			;污垢多
			IF TFLAG:194 >= 3
				SELECTCASE RAND:2
					CASE 0
						PRINTFORMW 「不管雪有多深，只要我们两个一起清理，马上就――」
						PRINTFORML 「马、上……」
						PRINTFORMW 「……」
						PRINTFORMW 「……加油吧……」
					CASE 1
						PRINTFORMW 「这点雪算什么……！」
						PRINTFORML 「那时候庭院也是！ 垃圾场前面也是！」
						PRINTFORMW 「我一个人搞定的时候可是这样啊！！」
						PRINTFORMW 一脸凶猛的妖梦正在与雪激烈战斗……
				ENDSELECT
			;污垢中以下
			ELSE
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 「看起来好像很熟练？」
						PRINTFORMW 「嗯，嗯，其实……对铲雪有点不喜欢」
					CASE 1
						PRINTFORML 「呼，差不多就没问题了――好、冷！？」
						PRINTFORMW 「……那个，%TEXTR("雪人的头/大雪兔/")%那个难道是……」
				ENDSELECT
			ENDIF
		;白玉楼庭
		ELSEIF MAIN_MAP == 6 && CFLAG:MASTER:現在位置 == 621
			IF TFLAG:194 >= 3
				PRINTFORML 「庭院……！」
				PRINTFORMW 「怎么会这样……明明只是修剪产生的垃圾而已……」
				PRINTFORML 「唉……不管怎么说，这是我作为园艺师的懒惰……」
				PRINTFORMW %CALLNAME:MASTER%一边安慰着泪眼汪汪的妖梦，一边清理庭园
			ELSE
				PRINTFORML 「嗯，有点乱了呢……」
				PRINTFORMW 「抱歉，一个人的话很难处理细节」
					IF TALENT:恋慕
						PRINTFORML 「如果%CALLNAME:MASTER%成为我的专属，我就可以专心照料了呢……」
						PRINTFORMW 从妖梦的眼神中感受到一种威压……
					ELSE
						PRINTFORMW 「有%CALLNAME:MASTER%的帮助真是太好了」
					ENDIF
			ENDIF
		ELSE
			IF TFLAG:194 >= 3
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 「哇……真是让人惊讶，居然到了这个地步」
						PRINTFORMW 「如果任其不管，也许会有一些看点……」
						PRINTFORMW %CALLNAME:MASTER%与妖梦一起面对着污垢的堆积……
					CASE 1
						PRINTFORML 「……有时候赶走了妖精群，这样的景象就会蔓延开来」
						PRINTFORMW 「到底是从哪里冒出来的呢……？」
						PRINTFORMW %CALLNAME:MASTER%想着要不要推荐黑色闪电，但觉得可能会引来更多妖精，于是停了下来
				ENDSELECT
			ELSE
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「打扫的时候，不禁让人想尝试一些事情」
						PRINTFORMW 「……将周围的垃圾全部砍碎，算不算打扫呢？」
					CASE 1
						PRINTFORML 「打扫是每天的例行事项，屋子的清理也由我来做！」
						PRINTFORMW 「……嗯？ 但是好像还有负责打扫的幽灵在其他地方……？」
					CASE 2
						PRINTFORML 「好了，差不多就到这里吧。变得很干净了！」
						PRINTFORMW 「嗯……不禁让人想挥舞一下剑的爽快感」
				ENDSELECT
			ENDIF
		ENDIF
	;不帮忙
	ELSE
		IF CFLAG:318 == 1 || (MARK:23:反発刻印 == 1 && RAND:3 == 0) || (MARK:23:反発刻印 > 1 && RAND:3 != 0)
			PRINTFORML 「…………」
			PRINTFORMW 妖梦站在一旁，看着%CALLNAME:MASTER%打扫……
		ELSE
			PRINTFORML 「……我也来帮忙」
				IF OUTROOF(CFLAG:現在位置) && DAY:2 == 4
					PRINTFORMW 「我对于清扫雪的辛苦也有所了解」
				ELSE
					PRINTFORMW 「让%CALLNAME:MASTER%独自清扫感觉有些对不起……」
				ENDIF
			PRINTFORMW 最初，妖梦只是观察着%CALLNAME:MASTER%的工作，但很快就伸出了援手
		ENDIF
	ENDIF
ENDIF
RETURN 1
