	ELSEIF CFLAG:MASTER:同行
	;お出かけお見送り
	ELSE
		IF CFLAG:318 == 1 || MARK:23:反発刻印 > 1 || TCVAR:泥酔 == 1
			PRINTFORML
		ELSEIF TALENT:恋慕
			PRINTFORML 「お出掛けですか？　%TEXTR("いってらっしゃいませ/道中お気を付け下さい/")%」
