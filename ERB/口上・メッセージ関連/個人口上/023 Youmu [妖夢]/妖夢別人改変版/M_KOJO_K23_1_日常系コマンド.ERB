;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF CFLAG:睡眠 || FLAG:70 || TCVAR:烂醉
		RETURN 1
	;怒り
	ELSEIF CFLAG:318 == 1 || (MARK:23:反発刻印 == 1 && RAND:3 == 0) || MARK:23:反発刻印 > 1
		PRINTFORML 「…………」
		PRINTFORMW 妖梦默默地完成了烹饪……

	;特有
	ELSEIF DISHNAME == "白玉みつまめ"
		IF FIRSTTIME("妖夢固有料理")
			PRINTFORML 「想要向我学习食谱，呃……其实更希望是我教给你」
			PRINTFORMW 「嗯……」
			PRINTFORML 「……对了！」
			PRINTFORMW
			PRINTFORML 「前段时间有点意识到半灵的存在，尝试着做了一些增加白玉的糖饼」
			PRINTFORML 「结果做得相当不错，我自己都觉得很出色」
				;夏天
				SELECTCASE DAY:2
					CASE 2
						PRINTFORML 「外观看起来也很凉爽，所以我觉得正适合这个季节」
				;其他季节
					CASEELSE
						PRINTFORML 「嘛，如果问我现在想吃吗，有点疑问……」
				ENDSELECT
			PRINTFORMW
			PRINTFORML 「……你有兴趣吗？如果是的话，我们马上来做吧」
			PRINTFORMW 「首先是准备白玉——」
			PRINTFORML 「呜哇！？为什么突然拿着半灵的……」
			PRINTFORML 「所以说！只是意识到而已，不是真的用到实物！」
			PRINTFORMW
			PRINTFORML 之后认真地从妖梦那里接受了指导……
			PRINTFORMW 「好了，完成了！再强调一下，白玉的煮熟程度要小心哦？」
		ELSEIF STRCOUNT(DISH_TASTE, "練習")
			PRINTFORML 「任何事情都需要反复练习才能掌握」
			PRINTFORMW 「直到%CALLNAME:MASTER%满意为止，我都会教给你的！」
			PRINTFORML 「……请不要用半灵！」
			PRINTFORMW 已经在之前强调过了……
		ELSE
			PRINTFORML 「你喜欢吗？如果是的话，我会很高兴！」
			PRINTFORMW
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 「……你一直在看着呢」
						PRINTFORMW 「如果半灵的大小和白玉一样，%CALLNAME:MASTER%你能吃完吗？」
					CASE 1
						SELECTCASE DAY:2
							CASE 2
								PRINTFORML 「在这个季节来说，凉爽的甜味真是让人感激」
								PRINTFORMW 「如果你故意选择了它，我会有点得意的」
							CASEELSE
								PRINTFORML 「……虽然这么说了，但季节感还是有点不对劲呢……」
								PRINTFORMW 「但如果你考虑到这点还是想吃的话，我会很高兴的」
						ENDSELECT
				ENDSELECT
		ENDIF
	;漬物
	ELSEIF DISHNAME == "漬物"
		PRINTFORMW 「嗯嗯……是泡菜吗？」
		PRINTFORML 「在府邸我做的话完全不好吃」
		PRINTFORMW 「但是这么短的时间里确实泡得很入味……有什么窍门吗？」
	;怪异或神秘料理
	ELSEIF STRCOUNT(DISH_TASTE, "グロテスク") || STRCOUNT(DISH_TASTE, "謎料理")
		PRINTFORMW 「嗯……！？」
		PRINTFORML 「明明自己也帮忙了，这料理到底……？」
		PRINTFORMW 「……那个，我还是免了吧……」
	;普通
	ELSE
		IF TALENT:恋慕
			PRINTFORML 「料理吗，好的，我们一起来做吧！」
			PRINTFORMW
				SELECTCASE RAND:5
					CASE 0
						IF ABL:MASTER:料理技能 > 4
							PRINTFORML 「哇，熟练的手法……」
							PRINTFORMW 「在你旁边看，我觉得自己还有很长的路要走」
							PRINTFORMW 「所以，请再教我一次吧♪」
						ELSEIF ABL:MASTER:料理技能 > 1
							PRINTFORML 「两个人一起做确实会发现很多地方」
							PRINTFORML 「如果以此为课题，下次一定会更好」
							PRINTFORMW 「我们能做得更好！」
						ELSE
							PRINTFORML 「啊，%CALLNAME:MASTER%你还太……！」
							PRINTFORMW 「那、那没关系，我会努力的！」
						ENDIF
					CASE 1
						PRINTFORML 「爱情是最好的调味料，常听说这样说」
						PRINTFORMW 「这是真的吗……吃完这道菜告诉我吧」
					CASE 2
						PRINTFORML 「虽然不仅限于这道菜」
						PRINTFORML 「我做的菜总是会有一种让人背脊微凉的味道……」
						PRINTFORMW 「明明没有放奇怪的东西，为什么呢……？」
					CASE 3
						PRINTFORML 「两个人一起做让心情变得愉快」
						PRINTFORML 「%CALLNAME:MASTER%你如果每餐都和我一起站在厨房……」
						PRINTFORMW 妖梦眺望着远处，眼中带着一丝遥远的眼神……
					CASE 4
						PRINTFORML 「摆盘是这样……完成了！」
						PRINTFORMW 「怎么样？形象也很重要哦」
				ENDSELECT
		ELSE
			PRINTFORML 「做菜吗，我也来帮忙！」
			PRINTFORMW
				SELECTCASE RAND:4
					CASE 0
						IF ABL:MASTER:料理技能 > 4
							PRINTFORML 「太、太厉害了……」
							PRINTFORMW 「你到底在哪里学到这么高超的技术？请务必教教我……」
						ELSEIF ABL:MASTER:料理技能 > 1
							PRINTFORML 「旁边有个懂得自己喜好的人真是令人欣慰」
							PRINTFORMW 「%CALLNAME:MASTER%，对炊事有没有兴趣？」
						ELSE
							PRINTFORML 「诶，%CALLNAME:MASTER%你还太……！」
								IF TALENT:思慕
									PRINTFORMW 「嗯、嗯，我还能搞定，放弃可不行！」
								ELSE
									PRINTFORMW （怎、怎么办……虽然觉得不至于吃不了，但……）
								ENDIF
						ENDIF
					CASE 1
						PRINTFORML 「府邸里有专门负责做饭的幽灵」
						PRINTFORMW 「而我有这方面的心得，原因……请自行脑补」
					CASE 2
						PRINTFORMW 「其实，白玉楼的花费有九成都花在食物上」
						PRINTFORML 「……开玩笑的啦？」
						PRINTFORMW 妖梦一脸茫然的看着……
					CASE 3
						PRINTFORML 「快、省、好吃。这是食物达到的最高点之一」
						PRINTFORMW 「如果我也能在这方面有所造诣的话……」
				ENDSELECT
		ENDIF
	ENDIF
ENDIF
RETURN 1
