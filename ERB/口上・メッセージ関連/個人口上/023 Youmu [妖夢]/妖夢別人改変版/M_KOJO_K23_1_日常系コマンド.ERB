;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF TCVAR:泥酔 == 1
		PRINTFORML
	ELSE
		SELECTCASE TFLAG:193
			;失敗
			CASE -1
				;ブチギレor反発
				IF CFLAG:318 == 1 || (MARK:23:反発刻印 == 1 && RAND:2 == 0) || MARK:23:反発刻印 > 1
					PRINTFORMDL 湯呑に顔を近付けてスンと鼻を鳴らした妖夢は、すぐさま眉を顰めて%CALLNAME:MASTER%を睨み付けた
					PRINTFORMW 「随分と素敵なお茶ですね？　畏れ多くて口など付けられませんよ」
				ELSE
					PRINTDATAL
						DATAFORM 「……えﾞ、あの……この色は一体……？」
						DATAFORM 「こ、これがお茶……？　とても口に含んで良い物には……」
					ENDDATA
					IF TALENT:恋慕
						PRINTFORMW 「幾ら%CALLNAME:MASTER%さんからのご厚意とはいえ、申し訳ないのですが……」
					ELSE
						PRINTFORMW 「……どうしてもと言うのなら、一口中身を飲んで見せて下さい」
					ENDIF
				ENDIF
			;成功
			CASEELSE
				;ブチギレor反発
				IF CFLAG:318 == 1 || (MARK:23:反発刻印 == 1 && RAND:2 == 0) || MARK:23:反発刻印 > 1
					PRINTFORML 「…………」
					PRINTFORMDL 訝しげに湯呑を眺めていた妖夢は渋々ながらもそれに口を付けた
					PRINTFORMDW 直に薬が効いてくるだろう……
				ELSE
					PRINTFORMW 「ありがとうございます、いただきますね。んっ……」
					PRINTFORML
						;媚薬
						IF TCVAR:媚薬 == 210
							PRINTFORML 「……ぁ、れ？　……ぅ……？」
								IF TALENT:恋慕
									PRINTFORML （……どうしよう。%CALLNAME:MASTER%さんに対するよからぬ妄想が次々と……ざ、雑念を抑えないと）
								ELSE
									PRINTFORML （身体が、熱い……なにが……？）
								ENDIF
							PRINTFORMDW 妖夢が頬を上気させつつ庇うように身体を抱いている。薬が効いているようだ
						;利尿剤
						ELSEIF TCVAR:利尿剤 == 210
							PRINTFORML 「…………ん？　…………！？」
								IF TALENT:恋慕 && RAND:2 == 0
									PRINTFORML （～～……っ！　な、なんでこんな時に……この様子だと長く我慢は……）
								ELSE
									PRINTFORML （の、飲み過ぎたのかしら……？　近くに厠は……）
								ENDIF
							PRINTFORMDW 妖夢がその場でそわそわと足を動かしている。薬が効いているようだ
						;惚れ薬
						ELSEIF TCVAR:惚れ薬 == 210
							PRINTFORML 「……んっ？　あれ……なんだか……」
								IF TALENT:恋慕
									PRINTFORML （%CALLNAME:MASTER%さんが普段より一段と素敵に見える……ふっ、私がこうも変わるとは）
									PRINTFORMDW 何故か妖夢と半霊はやれやれと首を振っている。薬は効いているのだろうか……
								ELSE
									PRINTFORML （目が離せない……%CALLNAME:MASTER%さんって、こんなに……？）
									PRINTFORMDW 妖夢がぼんやりと%CALLNAME:MASTER%を眺めている。薬が効いているようだ
								ENDIF
						;睡眠薬
						ELSEIF TCVAR:睡眠薬強度 == 2
							PRINTFORML 「……っ……？　……ご、ごめんなさい……少し……」
								IF TALENT:恋慕 && RAND:2 == 0
									PRINTFORML （こんな時に眠気なんて……%CALLNAME:MASTER%さんの前なのに、間が悪いにも……）
								ELSE
									PRINTFORML （疲れてるの……？　時間を見付けて仮眠ぐらいは、取るべきかも……）
								ENDIF
							PRINTFORMDW 妖夢は目元に手を当て俯いている。薬が効いているようだ
						ENDIF
				ENDIF
			ENDSELECT
	ENDIF
ENDIF
RETURN 1
