@M_KOJO_MESSAGE_COM_K95_80
CALL M_KOJO_MESSAGE_COM_K95_80_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K95_80_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		PRINTFORMW 
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		PRINTFORMW 
		RETURN 1
	;出す直前
	ELSEIF BASE:PLAYER:2 > 8000
		IF RAND:3 == 0
			PRINTFORMW 「…呵呵…涨得硬邦邦的…好奇怪啊…%"♥" *1%」
			PRINTFORMW 「已经可以出来喽～%"♥" *1%」
		ELSEIF RAND:2 == 0
			PRINTFORMW 「哇…变大了…%"♥" *1%」
			PRINTFORMW 「变得滑溜溜的很舒服…%"♥" *1%」
		ELSE
			PRINTFORM 「
			CALL MASTER_CALLNAME_K95
			PRINTFORMW 、我慢汁要出来喽～♪」
			PRINTFORMW 「这一块舒服吗…%"♥" *1%」
		ENDIF
	;恋慕
	ELSEIF TALENT:恋慕
		IF RAND:3 == 0
			PRINTFORMW 「嘻嘻…小鸡鸡握在手里的时候很老实…%"♥" *1%」
		ELSEIF RAND:2 == 0
			PRINTFORMW 「我会让你舒服的…%"♥" *1%」
		ELSE
			PRINTFORMW 「嗯…再激烈一点好吗？」
		ENDIF
	;屈服3
	ELSEIF MARK:不埒刻印 == 3
		IF RAND:3 == 0
			PRINTFORM 「
			CALL MASTER_CALLNAME_K95
			PRINTFORMW 舒服的表情、我很喜欢…」
		ELSEIF RAND:2 == 0
			PRINTFORMW 「…嗯…这样的手法舒服吗…%"♥" *1%」
		ELSE
			PRINTFORMW 「我的手指、舒服吗？」
		ENDIF
	;それ以外
	ELSE
		IF RAND:3 == 0
			PRINTFORMW 「…我想知道它是否会像古琴一样…」
		ELSEIF RAND:2 == 0
			PRINTFORMW 「用手指让它舒服舒服…%"♥" *1%」
		ELSE
			PRINTFORMW 「快点大量的射出来吧%"♥" *1%」
		ENDIF
	ENDIF
ENDIF
RETURN 1

