@M_KOJO_POWERED_BY_DARKMAN_MESSAGE_COM_K140_0_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
CALL M_KOJO_POWERED_BY_DARKMAN_COLOR_K140
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		PRINTFORMW 「再更加兴奋一些吧…%UNICODE(0x2665) *1%」
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;挿入中
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	;V挿入
	IF LOCAL:1 && TEQUIP:50 == PLAYER
		;射精した
		IF NOWEX:PLAYER:11
			PRINTFORMW 「啊%UNICODE(0x2665) *1%嗯%UNICODE(0x2665) *1%」
			RETURN 1
		ELSE
			PRINTFORMW 「嗯嗯%UNICODE(0x2665) *1%嗯啊%UNICODE(0x2665) *1%」
			RETURN 1
		ENDIF
	;A插入
	ELSEIF LOCAL:1 && TEQUIP:51 == PLAYER
		;射精了
		IF NOWEX:PLAYER:11
			PRINTFORMW 「哦%UNICODE(0x2665) *1%啊%UNICODE(0x2665) *1%」
			RETURN 1
		ELSE
			PRINTFORMW 「嗯嗯%UNICODE(0x2665) *1%嗯啊%UNICODE(0x2665) *1%」
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;ふたなり
	;記入チェック
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && (TALENT:2 & 3) == 3
		PRINTFORMW 
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		PRINTFORMW 
		RETURN 1
	;恋慕
	ELSEIF TALENT:恋慕
		PRINTFORMW 
		RETURN 1
	;屈服3
	ELSEIF MARK:不埒刻印 == 3
		PRINTFORMW 
		RETURN 1
	;それ以外
	ELSE
		IF RAND:3 == 0
			PRINTFORMW 「嗯%UNICODE(0x2665) *1%再更多一点%UNICODE(0x2665) *1%」
			PRINTFORMW 「更多地戏弄我%UNICODE(0x2665) *1%」
		ELSEIF RAND:2 == 0
			PRINTFORMW 「嗯%UNICODE(0x2665) *1%再多触摸一下%UNICODE(0x2665) *1%」
		ELSE
			PRINTFORMW 「啊%UNICODE(0x2665) *1%嗯%UNICODE(0x2665) *1%啊%UNICODE(0x2665) *1%」
		ENDIF
	ENDIF
ENDIF
RETURN 1
