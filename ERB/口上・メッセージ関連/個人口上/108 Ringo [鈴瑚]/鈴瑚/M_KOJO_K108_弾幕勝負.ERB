;==================================================
;弾幕勝負 
;==================================================
;ブチギレ口上はナイトメアダイアリー風
@M_KOJO_MESSAGE_COM_K108_DANMAKU(ARGS, 相手残機)
#DIM 相手残機
;全体の流れ
;①【戦闘前】→②ダイスロールとプレイヤー選択肢、ハンデをつけた場合は【ハンデ口上】→③対応スキルが発動した場合【スキル口上】→④被弾判定、キャラが被弾したなら【被弾口上】→
;どちらかの残機が0になっていなければ②に戻る→⑤【戦闘後口上】

;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
SIF FLAG:口上色
	TRYCALLFORM M_KOJO_COLOR_K{NO:TARGET}
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;戦闘前
	HANDICAP_FIXED = 0
	HANDICAP_RAND = 0
	;ハンデをつけることができ、数値が大きいほどあなたが不利になる　数値が負ならあなたが有利に
	;キャラの能力に関わらずクッソ強くしたり弱くしたりできる
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "戦闘前"
		IF ALCOHOL_FACE(108) == "酔いどれ" || ALCOHOL_FACE(108) == "ぐでぐで"
			;PRINTFORML 「言っとくけど、酔っぱらった程度で負ける程ヤワじゃないよ」
			PRINTFORML 「我事先告诉你、只是喝醉到这种程度我还不至于输给你」
		ELSEIF TALENT:108:心情 == -1 || CFLAG:108:ブチギレ || MARK:108:反発刻印 >= 3
			;PRINTFORML 「兎符『ストロベリー大ダンゴ』」
			PRINTFORML 「兔符『草莓大团子』」
			SETCOLOR 0xC07070
			;PRINTFORMW 鈴瑚はこちらが身構える前に襲い掛かってきた！！
			PRINTFORMW 铃瑚在我摆好架势之前就袭击了过来！！
		;あなた戦闘能力1以下
		ELSEIF ABL:MASTER:戦闘能力 < 1
			;PRINTFORML 「%CALLNAME:MASTER%、私が何者なのか判っているの？」
			PRINTFORML 「%CALLNAME:MASTER%、你知道我是什么人吗？」
			SELECTCASE RAND:3
				CASE 0
					;PRINTFORMW 「下っ端だと思って甘く見てると痛い目見るよ」
					PRINTFORMW 「如果认为我只是个小喽啰就轻视我的话可是会吃苦头的」
				CASE 1
					;PRINTFORMW 「まあいいや。さっさと終わらせて休憩しようかな」
					PRINTFORMW 「嘛、算了。还是赶紧结束然后去休息吧」
				CASE 2
					;PRINTFORMW 「私達は月の兎の調査部隊<イーグルラヴィ>。穢れた地上人には負けないわ」
					PRINTFORMW 「我们可是月兔调查部队<Eagle rabbit>。绝不会输给污秽的地上人的」
			ENDSELECT
		ELSE
			SELECTCASE RAND:3
				CASE 0
					;あなた戦闘能力4以上
					IF ABL:MASTER:戦闘能力 >= 4
						;PRINTFORML （へぇ…%CALLNAME:MASTER%のこの強さ…！）
						PRINTFORML （哎…%CALLNAME:MASTER%的这个强度…！）
						;PRINTFORMW 「こりゃあ面白い！手加減無しで遊べそうね！」
						PRINTFORMW 「这下子有意思了！可以不用手下留情的玩耍了！」
					ELSE
						;PRINTFORML 「%CALLNAME:MASTER%の戦闘能力、調査開始っと」
						PRINTFORML 「%CALLNAME:MASTER%的战斗能力调查、开始」
					ENDIF
				CASE 1
					;鈴瑚戦闘能力3以上
					IF ABL:戦闘能力 >= 3
						;PRINTFORML 「%CALLNAME:MASTER%、私に手加減はいらないよ」
						PRINTFORML 「%CALLNAME:MASTER%、不需要对我手下留情」
						;PRINTFORMW 「強くなったのはキミだけじゃないって事さ！」
						PRINTFORMW 「变得更强的可不只有你一个人！」
					ELSE
						;PRINTFORML 「%CALLNAME:MASTER%の戦闘能力、調査開始っと」
						PRINTFORML 「%CALLNAME:MASTER%的战斗能力调查、开始」
					ENDIF
				CASE 2
					;PRINTFORML 「一回の被弾<ミス>でも許されない、月の流儀<ルナティック>に度肝を抜くが良い！」
					PRINTFORML 「一回中弹的<错误>都不被允许、月的流派<ルナティック>让人胆战心惊！」
			ENDSELECT
		ENDIF
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;ハンデ
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "ハンデ"
		;ハンデつけなかったら表示されないので無記入でよい
		PRINTFORML 
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;戦闘中TARGET被弾時口上
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "被弾"
		IF 相手残機 == 2
			IF TALENT:108:心情 == -1 || CFLAG:108:ブチギレ || MARK:108:反発刻印 >= 3
			;本当はこの時点ではまだ使えないけど
				;PRINTFORML 「兎符『ダンゴ三姉妹』」
				PRINTFORML 「兔符『团子三姐妹』」
				;PRINTFORMDW この弾幕は躱せない…！諦めかけた瞬間、%CALLNAME:MASTER%の脳内に声が響いた…
				PRINTFORMDW 这个弹幕是躲不开的…！就快要放弃的瞬间、%CALLNAME:MASTER%的脑内响起了声音…
				;PRINTFORMDW ――低速移動を二度押しすると、一定距離瞬間移動するぞ――
				PRINTFORMDW ――连续按下两次低速移动的按键、就可以瞬间移动一定的距离哦――
			ELSE
				;あなたの戦闘能力4以上でスペルカード増加
				IF ABL:MASTER:戦闘能力 >= 4
					;CALL COLORMESSAGE("「やっぱりキミは強いね……だからこそ、倒しがいがあるってもんさ！」", C_ORANGE, 0, 0)
					CALL COLORMESSAGE("「果然你很强大啊……但也正因如此、这样的你才有打倒的价值啊！」", C_ORANGE, 0, 0)
					SETCOLOR 0xFFFF00
					PRINTFORML MGMG
				ELSE
					;CALL COLORMESSAGE("「やるねぇ…そろそろこっちも本気出していこうかな」", C_ORANGE, 0, 0)
					CALL COLORMESSAGE("「可以啊…我也差不多该拿出真本事来了」", C_ORANGE, 0, 0)
					SETCOLOR 0xFFFF00
					PRINTFORML MGMG
				ENDIF
				SETCOLOR 0xEE9900
				;PRINTFORMDW 鈴瑚が手に持っている団子を食べる度、鈴瑚の力が増幅していく……！
				PRINTFORMDW 铃瑚每次吃掉手中的团子、铃瑚的力量就会变得更加强大……！
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 「たんと食らいな！」
						IF ABL:MASTER:戦闘能力 >= 4
							;PRINTFORMW 「兎符『%TEXTR("ストロベリーダンゴ/ベリーベリーダンゴ")%』！」
							PRINTFORMW 「兔符『%TEXTR("草莓团子/浆果浆果团子")%』！」
						ELSE
							;PRINTFORMW 「兎符『ストロベリーダンゴ』！」
							PRINTFORMW 「兔符『草莓团子』！」
						ENDIF
					CASE 1
						;PRINTFORML 「キミにこれが見切れるかな？」
						PRINTFORML 「你能看穿这个吗？」
						PRINTFORMW 「兔符『团子影响力』！」
				ENDSELECT
			ENDIF
		ENDIF
	ENDIF
	IF LOCAL:1 && ARGS == "被弾"
		IF 相手残機 == 1
			IF TALENT:108:心情 == -1 || CFLAG:108:ブチギレ || MARK:108:反発刻印 >= 3
				;PRINTFORMW 「団子『ダンゴフラワー』」
				PRINTFORMW 「团子『团子花』」
				;PRINTFORMDL  %CALLNAME:MASTER%はテレポーテーションを習得した！
				PRINTFORMDL  %CALLNAME:MASTER%学会了瞬间移动！
				;PRINTFORMDW  鈴瑚の弾幕を掻い潜り、何とか接近することに成功した…！
				PRINTFORMDW  穿梭在铃瑚的弹幕中、总算是接近成功了…！
			ELSE
				;あなたの戦闘能力4以上でスペルカード増加
				SELECTCASE RAND:2
				CASE 0
					IF ABL:MASTER:戦闘能力 >= 4
						;PRINTFORMW （……もう後がないね…今の%CALLNAME:MASTER%に勝つには、奥の手を使うしかないか…！）
						PRINTFORMW （……已然没有退路了…现在的%CALLNAME:MASTER%想要取胜、就只能使出绝招了吧…！）
						;PRINTFORML 「すぅ……ッ！あぁ―」
						PRINTFORML 「呜……呃！啊―」
						;PRINTFORMDL 鈴瑚は何処からか大量の団子を取り出し、大きく口を開けてそれらを全て丸呑みした…！
						PRINTFORMDL 铃瑚不知从哪里取出大量的团子、张大嘴把其全部吞下了…！
						;PRINTFORMDW 団子を嚥下した途端、鈴瑚から感じる力が先程までとは比べ物にならない程に強くなった！
						PRINTFORMDW 刚咽下团子的时候、铃瑚就感受到自己逐渐变强的力量变得和先前完全无法相比了！！
						;PRINTFORML 「んぐっ…ふぅ……さあ！これで最後だ！」
						PRINTFORML 「呜咕…嗯……来吧！这就是最后一次了！」
						;PRINTFORMW 「月見酒『ルナティックセプテンバー』！！」
						PRINTFORMW 「赏月酒『月狂的九月』！！」
					ELSE
						;PRINTFORMW （…別に勝たなくていい、とは言っても…負けるのは癪だからね…！）
						PRINTFORMW （…虽说即使不赢也没关系…但输了的话还是会很气愤…！）
						;PRINTFORML 「あー…もぐもぐモグモグMGMG…」
						PRINTFORML 「啊ー…嗼呼嗼呼嗼咕嗼咕MGMG…」
						;PRINTFORMDW 鈴瑚は最後のスペルカードを宣言するため、手に持った団子を全て平らげて力を蓄えた…！
						PRINTFORMDW 铃瑚为了宣告最后的符卡、将手中所有的团子吃光开始积蓄力量…！
						;PRINTFORMW 「けふっ……さあいくよ！ 月見『セプテンバーフルムーン』！」
						PRINTFORMW 「那么……要来了！ 赏月『九月的满月』！」
					ENDIF
				CASE 1
					;PRINTFORMW （…別に勝たなくていい、とは言っても…負けるのは癪だからね…！）
					PRINTFORMW （…虽说即使不赢也没关系…但输了的话还是会很气愤…！）
					;PRINTFORML 「あー…もぐもぐモグモグMGMG…」
					PRINTFORML 「啊ー…嗼呼嗼呼嗼咕嗼咕MGMG…」
					;PRINTFORMDW 鈴瑚は最後のスペルカードを宣言するため、手に持った団子を全て平らげて力を蓄えた…！
					PRINTFORMDW 铃瑚为了宣告最后的符卡、将手中所有的团子吃光开始积蓄力量…！
					;PRINTFORMW 「けふっ……さあいくよ！ 月見『セプテンバーフルムーン』！」
					PRINTFORMW 「那么……要来了！ 赏月『九月的满月』！」
				ENDSELECT
			ENDIF
		ENDIF
	ENDIF
	IF LOCAL:1 && ARGS == "被弾"
		IF 相手残機 == 0
			IF TALENT:108:心情 == -1 || CFLAG:108:ブチギレ || MARK:108:反発刻印 >= 3
				PRINTFORML  「………………。」
				;PRINTFORMDW 鈴瑚の攻撃が止んだと同時に%CALLNAME:MASTER%は意識を失った……
				PRINTFORMDW 铃瑚攻击停下来的同时%CALLNAME:MASTER%失去了意识……

			ELSE
				SELECTCASE RAND:2
					CASE 0
						;PRINTFORMW 「%CALLNAME:MASTER%やるじゃん。強いわね」
						PRINTFORMW 「%CALLNAME:MASTER%不错啊。好强哦」
					CASE 1
						;PRINTFORMW 「団子が無くて…力が出ない……」
						PRINTFORMW 「没有团子了…使不出力气了……」
				ENDSELECT
			ENDIF
		ENDIF
	ENDIF
ENDIF
	;-------------------------------------------------
	;戦闘中
	;TARGETの【残忍酷薄】発動時
	;ARGはTARGETの残機
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "残忍酷薄"
		
	ENDIF
	;-------------------------------------------------
	;戦闘中
	;TARGETの【乾坤一擲】発動時
	;ARGはTARGETの残機
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "乾坤一擲"
		
	ENDIF
	;-------------------------------------------------
	;戦闘中
	;TARGETの【怪力乱神】発動時
	;ARGはTARGETの残機
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "怪力乱神"
		
	ENDIF
	
	;-------------------------------------------------
	;戦闘後
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "戦闘後" 
		PRINTFORML 
		;残り残機4が表示されうるのは【洽覧深識】持ちのみ
		;残機が1以上ならあなたの負け、0の場合はあなたの勝利
		;あなた勝利
		IF 相手残機 == 0
			IF TALENT:108:心情 == -1 || CFLAG:108:ブチギレ || MARK:108:反発刻印 >= 3
				;PRINTFORMDL 気が付くと、%CALLNAME:MASTER%は元の場所にいた。瞬間移動も使えなくなっていた。
				PRINTFORMDL 注意到的时候、%CALLNAME:MASTER%还停留在原来的地方。瞬间移动也不能使用了。
				;PRINTFORMDL 鈴瑚と喧嘩したせいであんな悪夢を見たのかもしれない。後日ちゃんと謝ったほうがいいだろう……
				PRINTFORMDL 或许是因为和铃瑚打架才做了那样的噩梦。等日后好好向对方道歉比较好吧……
			ELSE
				PRINTFORML 
				;PRINTFORMDW 勝負が終わると、鈴瑚は地面に大の字になって寝転んだ。
				PRINTFORMDW 弹幕勝負结束后、铃瑚以大字的方式躺下了。
				SELECTCASE RAND:2
					CASE 0
						;PRINTFORML 「あ痛たた…ハハ…ちょっと張り切りすぎちゃった…」
						PRINTFORML 「啊疼疼疼…哈哈…稍微有点太紧张了…」
						;PRINTFORMW 「あ…手貸してくれるの？ありがと…キミは優しいね…♪」
						PRINTFORMW 「啊…能帮帮我吗？谢谢啦…你很温柔呢…♪」
						;PRINTFORMW （……%CALLNAME:MASTER%は確かに強いけど、月を脅かす程ではない。警戒しなくてよし……っと）
						PRINTFORMW （……%CALLNAME:MASTER%虽然确实很强、但还不至于威胁到月亮。不用进行警戒……突然）
						PRINTFORML
						SETCOLOR 0xFFE9A9
						PRINTFORML      STAGE CLEAR
						PRINTFORMDL      Clear Bonus
						PRINTFORMDL       10,000,000
						PRINTFORMDW 
					CASE 1
						;あなたが鈴瑚より格下だと台詞変化 実際に勝てるかどうかは知らん
						;PRINTFORML 「いやー驚いたよ。まさか、ここまでやられるとはね……」
						PRINTFORML 「哎呀吓我一跳呢。真没想到、能打到这种地步……」
						IF ABL:MASTER:戦闘能力 < 1
							;PRINTFORMW 「キミ、見かけによらず強いね。将来有望だよ」
							PRINTFORMW 「你还真是人不可貌相呢。将来肯定很有前途呢」
							;PRINTFORML （本当にこのまま力をつけていったら、月を脅かす存在になるかもしれないね……）
							PRINTFORML （如果真的就这样继续努力的话、说不定真的会成为能够威胁到月亮的存在呢……）
						ELSE
							;PRINTFORMW 「%CALLNAME:MASTER%本当に強いね。私じゃ敵わないよ」
							PRINTFORMW 「%CALLNAME:MASTER%真的好强啊。我这下子敌不过你了」
							;PRINTFORML （本当に…玉兎程度じゃ束になっても勝てそうに無いね）
							PRINTFORML （真的…即使不约束力量的程度也赢不了对方呢）
						ENDIF
						;PRINTFORMW （……%CALLNAME:MASTER%…要警戒、っと……）
						PRINTFORMW （……%CALLNAME:MASTER%…是要警戒的对象、突然……）
						PRINTFORML
						SETCOLOR 0xFFE9A9
						PRINTFORML      STAGE CLEAR
						PRINTFORMDL      Clear Bonus
						PRINTFORMDL       10,000,000
						PRINTFORMDW 
				ENDSELECT
			ENDIF
		;鈴瑚勝利
		ELSE
			IF ALCOHOL_FACE(108) == "酔いどれ" || ALCOHOL_FACE(108) == "ぐでぐで"
				;PRINTFORMW 「言ったでしょ？酔っぱらった程度じゃ負けないって」
				PRINTFORMW 「我不是说过了吗？即使喝醉到这种程度我也不会输」
			ELSEIF TALENT:108:心情 == -1 || CFLAG:108:ブチギレ || MARK:108:反発刻印 >= 3
				PRINTFORMW 「………………。」
				;PRINTFORMDL 鈴瑚は%CALLNAME:MASTER%に目もくれずに去っていった。
				PRINTFORMDL 铃瑚连看都不看一眼%CALLNAME:MASTER%就离开了。
				;PRINTFORMDL あれは本当に鈴瑚なのか？これは自分が見ている悪夢ではないのか？
				PRINTFORMDL 那真的是铃瑚吗？确定不是我自己做的噩梦吗？
				;PRINTFORMDW そんな考えを巡らせているうち、%CALLNAME:MASTER%は目の前が真っ暗になった……
				PRINTFORMDW 在这样的想法中、%CALLNAME:MASTER%的眼前变得一片漆黑……
			ELSE
				IF ABL:MASTER:戦闘能力 < 1
					SELECTCASE RAND:2
						CASE 0
							;CALL COLORMESSAGE("「これがホントの朝飯前ってね」", C_ORANGE, 0, 0)
							CALL COLORMESSAGE("「这可还真是轻而易举呢」", C_ORANGE, 0, 0)
							SETCOLOR 0xFFFF00
							PRINTFORMW MGMG
						CASE 1
							;CALL COLORMESSAGE("「相手の力量も計れないようじゃ、キミいつか死ぬよ」", C_ORANGE, 0, 0)
							CALL COLORMESSAGE("「连对方的实力都无法估量的话、你总有一天会白白送死的」", C_ORANGE, 0, 0)
							SETCOLOR 0xFFFF00
							PRINTFORMW MGMG
					ENDSELECT
				ELSE
					SELECTCASE RAND:3
						CASE 0
							;あなた戦闘能力4以上
							IF ABL:MASTER:戦闘能力 >= 4
								;PRINTFORMW 「%CALLNAME:MASTER%油断したね？それとも、わざと負けたの？」
								PRINTFORMW 「%CALLNAME:MASTER%疏忽大意了吗？还是说、是故意输的吗？」
							ELSE
								;CALL COLORMESSAGE("（聞いてた程の強さじゃなかったな……）", C_ORANGE, 0, 0)
								CALL COLORMESSAGE("（没有听说的那么强啊……）", C_ORANGE, 0, 0)
								SETCOLOR 0xFFFF00
								PRINTFORML MGMG
							ENDIF
						CASE 1
							;鈴瑚戦闘能力3以上
							IF ABL:戦闘能力 >= 3
								;CALL COLORMESSAGE("「どうだい？これが私の能力。私は日々進化しているんだよ」", C_ORANGE, 0, 0)
								CALL COLORMESSAGE("「怎么样？这就是我的能力。我可是每天都在进化的哦」", C_ORANGE, 0, 0)
								SETCOLOR 0xFFFF00
								PRINTFORMW MGMG
							ELSE
								;CALL COLORMESSAGE("「勝利の後に食べる団子は格別だねぇ」", C_ORANGE, 0, 0)
								CALL COLORMESSAGE("「胜利之后吃团子的感觉很特别呢」", C_ORANGE, 0, 0)
								SETCOLOR 0xFFFF00
								PRINTFORMW MGMG
							ENDIF
						CASE 2
							;CALL COLORMESSAGE("「勝利の後に食べる団子は格別だねぇ」", C_ORANGE, 0, 0)
							CALL COLORMESSAGE("「胜利之后吃团子的感觉很特别呢」", C_ORANGE, 0, 0)
							SETCOLOR 0xFFFF00
							PRINTFORMW MGMG
					ENDSELECT
				ENDIF
			ENDIF
		ENDIF
	ENDIF
RESETCOLOR
RETURN 1

