;==================================================
;6,挿入Ｇスポ責め
;==================================================
@M_KOJO_MESSAGE_SCOM_K7_6
CALL M_KOJO_MESSAGE_SCOM_K7_6_1
RETURN 1
@M_KOJO_MESSAGE_SCOM_K7_6_1
;moved from M_KOJO_MESSAGE_COM_K7_72_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
	ENDIF
	;-------------------------------------------------
	;挿入継続
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && TCVAR:100 == PLAYER
		;前回射精した
		IF TCVAR:102
			PRINTFORML 
		ELSE
			PRINTFORML 
		ENDIF
	ENDIF
	;基本セット
	;恋慕
	IF TALENT:恋慕
			SELECTCASE RAND:3
				CASE 1
					PRINTFORML 「もっと、もっと%CALLNAME:MASTER%を刻み込んでっ%UNICODE(0x2665) *1%」
					PRINTFORMW 
				CASE 0
					PRINTFORML 「エンリョしちゃダメ%UNICODE(0x2665) *1%そっ、そうっもっと%UNICODE(0x2665) *1%」
					PRINTFORMW 
				CASEELSE
					PRINTFORML 「やあぁっ%UNICODE(0x2665) *1%」
					PRINTFORMW 
			ENDSELECT
		RETURN 1
	;屈服3
	ELSEIF MARK:不埒刻印 == 3
			SELECTCASE RAND:3
				CASE 1
					PRINTFORML 「あっ…そこっ、いい%UNICODE(0x2665) *1%」
					PRINTFORMW 
				CASE 0
					PRINTFORML 「もっと抉るまで突いてっ…%UNICODE(0x2665) *1%あっ、はあぁ%UNICODE(0x2665) *1%」
					PRINTFORMW 
				CASEELSE
					PRINTFORML 「ンンッ%UNICODE(0x2665) *1%ハジけて散っちゃいそう…%UNICODE(0x2665) *1%」
					PRINTFORMW 
			ENDSELECT
		RETURN 1
	;それ以外
	ELSE
			SELECTCASE RAND:3
				CASE 1
					PRINTFORML 「キャッ！ンンンッ%UNICODE(0x2665) *1%」
					PRINTFORMW 
				CASE 0
					PRINTFORML 「あぅ…そこばっかり責めちゃっ%UNICODE(0x2665) *1%」
					PRINTFORMW 
				CASEELSE
					PRINTFORML 「ンッ…ちょっと強すぎっ…！」
					PRINTFORMW 
			ENDSELECT
		RETURN 1
	ENDIF
ENDIF
RETURN 1

