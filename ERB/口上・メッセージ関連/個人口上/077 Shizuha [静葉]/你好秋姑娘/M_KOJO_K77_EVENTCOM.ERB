; 在指令回合结束之后触发
@M_KOJO_EVENT_K77_EVENTCOMEND(ARGS,ARG,ARG:1)
#LOCALSIZE 1
#LOCALSSIZE 1
SIF CFLAG:77:998 || TFLAG:現在的TARGET != 77
	RETURN 0

IF FLAG:時間停止

ELSEIF !SHIRAHU(77)

ELSEIF CFLAG:77:诶嘿嘿

ELSEIF IS_ANGRY(77)

ELSEIF BATHCHECK(CFLAG:MASTER:300)

ELSE
	SIF TFLAG:约会道中 && CFLAG:77:好感度 > 100 && FIRSTTIME("K77_GETCAMERA",,77)
		CALL K77_GETCAMERA
	IF GROUPMATCH(SELECTCOM, 301, 331) && INROOM(CFLAG:MASTER:300) && !GETBIT(TCVAR:77:MAKING_WEIRDTEA, 0)
		SIF TALENT:77:恋人 && K77_PROB(3, 7)
			CALL K77_MAKING_WEIRDTEA_SHIZUHA(1)
		SIF TALENT:77:恋慕 && K77_PROB(2, 7)
			CALL K77_MAKING_WEIRDTEA_SHIZUHA(1)
	ENDIF
ENDIF

