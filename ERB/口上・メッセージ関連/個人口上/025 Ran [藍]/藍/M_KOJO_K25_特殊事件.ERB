;平安夜问候
@M_KOJO_EVENT_K25_CHRISTMAS_EVE_1
IF !CFLAG:25:1009
    PRINTFORML 「%CALLNAME:MASTER%，收礼物的袜子准备好了吗？」
    PRINTFORML 「在平安夜，圣诞老人会给好孩子送礼物哦~」
    PRINTDL [0] 我很期待呢
    PRINTDL [1] 圣诞老人什么的，是大人假扮的吧
    $INPUT_EVENT_21
    INPUT
    SELECTCASE RESULT
    CASE 0
        PRINTFORMW 「像%CALLNAME:MASTER%这样的乖孩子，一定能收到很棒的礼物吧，真为你感到高兴呢」
    CASE 1
        PRINTFORML 「%CALLNAME:MASTER%懂的很多呢，其实，我也是“圣诞老人”哦」
        PRINTFORML 「今晚，要和我一起，去给那些相信圣诞的孩子们送礼物吗？」
        PRINTDL [0] 好啊
        PRINTDL [1] 算了吧
        $INPUT_EVENT_22
        INPUT
        SELECTCASE RESULT
        CASE 0
            PRINTFORML 「呼呼，一言为定哦~」
            PRINTFORMW （即使自己不相信圣诞老人，也愿意守护其他孩子们的幻想吗？%CALLNAME:MASTER%真是善良呢）
            TCVAR:25:354 += 1
        CASE 1
            PRINTFORMW 「哎呀，有点扫兴呢」
        CASEELSE
            GOTO INPUT_EVENT_22
        ENDSELECT
        CFLAG:25:1009 = 1
    CASEELSE
        GOTO INPUT_EVENT_21
    ENDSELECT
ELSE
    PRINTFORML 「%CALLNAME:MASTER%，今晚是平安夜哦~」
    PRINTFORML 「要和我一起，去给孩子们送礼物吗？」
    PRINTDL [0] 好啊
    PRINTDL [1] 算了吧
    $INPUT_EVENT_23
    INPUT
    SELECTCASE RESULT
    CASE 0
        PRINTFORMW 「呼呼，今年也要加油哦，“圣诞老人”先生~」
        TCVAR:25:354 += 1
    CASE 1
        PRINTFORMW 「哎呀，有点扫兴呢」
    CASEELSE
        GOTO INPUT_EVENT_23
    ENDSELECT
ENDIF

