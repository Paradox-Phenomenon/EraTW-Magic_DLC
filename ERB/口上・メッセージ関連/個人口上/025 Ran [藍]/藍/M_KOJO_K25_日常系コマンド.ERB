;				CALL RAN_DATESKINSHIP
;			ELSE
;				CALL RAN_NORMALSKINSHIP
;			ENDIF
		ENDIF
	ELSEIF TALENT:思慕
		SELECTCASE RAND:10
		CASE 0
			PRINTFORML 「嘛，算了。想摸的话就随便摸吧」
			PRINTFORMW 她苦笑着允许了
		CASE 1
			PRINTFORML 「年轻的时候我还用这指甲理发呢」
			PRINTFORML 「稍微有点不整齐了。别动哦——」
			PRINTFORMW 我在近距离确认了像名刀一样锋利的指甲
		CASE 2
			PRINTFORML 「不错不错。再往外侧一点」
			PRINTFORMW %CALLNAME:MASTER%从她肩膀的僵硬程度感受到了蓝的繁忙
		CASE 3
			PRINTFORML 「你知道吗。即使只是手和手，也能玩出很有趣的游戏」
			PRINTFORML 蓝的指尖在我的手掌和手背上细腻地描绘着
			PRINTFORMW 我明白了是什么意思，但是模仿起来似乎很难
		CASE 4
			PRINTFORML 我用大拇指的指腹用力按压着随意坐下的蓝的腰部
			PRINTFORML 「你很厉害嘛，%CALLNAME:MASTER%。很清楚我的弱点」
			PRINTFORMW 如果对方是美女，动力也会提高
		CASE 5
			PRINTFORML 「怎么了怎么了，揉我的胳膊肘很开心吗？」
			PRINTFORML 我听说胳膊肘和欧派一样柔软，不知道是不是真的
		CASE 6
			PRINTFORML 我试着捏了捏蓝的耳垂
			PRINTFORMW 她的头渐渐地向我这边倾斜
		CASE 7
			PRINTFORML 我若无其事地像恋人一样搂住她的腰
			PRINTFORMW 她没有丝毫抵抗，若无其事地接受了
		CASE 8
			PRINTFORML 「嗯嗯。然后呢？」
			PRINTFORMW 在谈话的过程中，蓝自然地握住了%CALLNAME:MASTER%的手
		CASE 9
			PRINTFORML 「我喜欢你？ 别得意忘形了，笨蛋」
			PRINTFORML 我的鼻尖被她轻轻地捏了一下
		ENDSELECT
	ELSE
		SELECTCASE RAND:10
		CASE 0
			PRINTFORML 我得到了许可，抚摸了她的一条尾巴
			PRINTFORML 和普通的狐狸不同，蓝的毛发蓬松柔软，手感非常好……
			PRINTFORML 「怎么样。我引以为傲的尾巴」
		CASE 1
			PRINTFORML 我用手轻轻地捧起她金色的头发，欣赏着它的光泽
			PRINTFORML 「你意外地会做一些很风雅的事情呢」
			PRINTFORMW 蓝若无其事地一带而过
		CASE 2
			PRINTFORML 我恭敬地握住蓝的手，低下头亲吻
			PRINTFORML 「你是法兰西控吗？ 嘴唇只是靠近才是正确的礼仪」
			PRINTFORMW 果然，这种程度的身体接触似乎并不会让她感到害羞或困惑
		CASE 3
			PRINTFORML 「你还真是不客气，到处乱摸」
			PRINTFORML 我试着轻轻地抚摸了一下她的背，结果被她用半睁的眼睛瞪了一眼
		CASE 4
			PRINTFORML 「唔姆。力道还不错」
			PRINTFORML 我给她揉了揉肩膀，得到了好评
		CASE 5
			PRINTFORML 「揉腰的话，果然还是……唔，唔姆」
			PRINTFORML 我眼前的尾巴微微颤动。似乎感觉还不错
		CASE 6
			PRINTFORML 「我发现了一根分叉的头发。要帮你剪掉吗？」
			PRINTFORML 蓝的指甲在离我的脸很近的地方锐利地伸长
		CASE 7
			PRINTFORML 「不要太突然地靠近，很危险的」
			PRINTFORML 「我可能会用尾巴把你弹飞」
			PRINTFORMW 我隐约地感觉受到了威胁
		CASE 8
			PRINTFORML 「即使不麻烦你，我也能完美地保养尾巴」
			PRINTFORML 确实，完全没有必要用梳子梳理
		CASE 9
			PRINTFORML 「我不会说不让你碰，但是要先说一声」
			PRINTFORML 我感受到了她委婉的拒绝
		ENDSELECT
	ENDIF
	PRINTL 
ENDIF
RETURN 1
