			PRINTFORML 蓝的手触碰到股间，温暖的活力涌入
			PRINTFORML …………总觉得股间稍微变重了
			PRINTL 
			PRINTFORML 精力＋300
			SIF !TALENT:MASTER:120
				TALENT:MASTER:120 = 1
			CALL BUFF_BASE(MASTER,BASE_精力,300)
			TCVAR:25:353 = 1
			;BASE:MASTER:精力 = MIN(MAXBASE:MASTER:精力,BASE:MASTER:精力 + 300)
		CASE 3
		;从USERCOM_脱掉衣服 复制粘贴处理
			PRINTFORML 「……确实听到了。你这个色鬼」
			PRINTFORML 脸颊泛红的蓝用左右手提起裙子，露出白皙修长的腿
			PRINTFORML 唰地脱下，从脚尖抽出，在%CALLNAME:MASTER%面前展示了刚脱下来的胖次
			PRINTL 
			PRINTFORML %CALLNAME:MASTER%得到了蓝的%PANTSNAME(EQUIP:TARGET:下半身内衣２, TARGET)%！
			CALL PANTS_GET(TARGET,"もらう")
			TCVAR:25:353 = 1
		CASE 4
			PRINTFORML 「确实听到了……但是啊」
			PRINTFORML 「明明不用每次都取得许可的」
			PRINTFORML 飞扑过去的%CALLNAME:MASTER%的身体被九条尾巴轻柔地接住
			PRINTFORML 在梦境般的感觉中尽情地抚摸，%CALLNAME:MASTER%补充了生存的活力
			PRINTL 
			PRINTFORML 体力・気力＋150 愛情経験＋5
			BASE:MASTER:体力 = MIN(MAXBASE:MASTER:体力,BASE:MASTER:体力 + 150)
			BASE:MASTER:気力 = MIN(MAXBASE:MASTER:気力,BASE:MASTER:気力 + 150)
			EXP:TARGET:愛情経験 += 5
			TCVAR:25:353 = 1
		CASEELSE
