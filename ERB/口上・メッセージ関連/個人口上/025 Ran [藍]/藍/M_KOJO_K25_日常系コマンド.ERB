			PRINTFORML 「…………」
			PRINTFORMW 看来我在泡茶的时候犯了什么错误
		CASE 2
			PRINTFORML 「建议？ 不，没什么特别的」
			PRINTFORMW 暂时看来我没有犯什么明显的错误
		ENDSELECT
	ENDIF
	PRINTL 
ENDIF
RETURN 1
