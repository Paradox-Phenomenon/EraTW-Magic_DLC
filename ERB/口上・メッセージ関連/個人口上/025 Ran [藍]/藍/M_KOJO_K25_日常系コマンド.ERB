@M_KOJO_MESSAGE_COM_K25_300_1
;-------------------------------------------------
;记入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
;時間停止口上を追加する场合は”&& !FLAG:70”を削除し、”IF FLAG:70 == 1”または”IF FLAG:時間停止”などで分岐
IF LOCAL && !FLAG:70
	IF TCVAR:302
		PRINTFORMW 「好啦，冷静点。别那么慌张地说」
	ELSE
		;应该是恋慕以上
		IF CFLAG:陪睡中
			SELECTCASE RAND:5
			CASE 0
				PRINTFORML 「别在意尾巴。像你这点重量，压上去也不会痛的」
				PRINTFORMW 「再靠近我一点」
			CASE 1
				PRINTFORML 「在被窝里懒洋洋的也不错」
				PRINTFORMW 「一个人的话，会觉得像是在偷懒」
			CASE 2
				PRINTFORML 「409。421。433。来来，接下来是什么？」
				PRINTFORMW 和蓝玩数字游戏是不可能赢的
			CASE 3
				PRINTFORML 「为什么要看我的鼻孔，喂！」
				PRINTFORMW 像小孩子一样和蓝嬉闹
			CASE 4
				PRINTFORML 「……嗯，不，我不困」
				PRINTFORMW 彼此闭上眼睛，额头相抵
			ENDSELECT
			;配置变更＆よりわかりやすい感じに
			;CFLAG:12からFLAG:73に变更。また约会中でも概率で通常会话を呼び出すように
			;约会中に季节会话まで呼び出すと约会会话が出てこなさすぎるので季节会话は通常会话と并用
		ELSEIF TALENT:恋慕
			IF FLAG:约会的对象 == 25
				SELECTCASE RAND:2
				CASE 0
					CALL RAN_DATETALK
				CASE 1
					CALL RAN_NORMALTALK
				ENDSELECT
			ELSEIF !TCVAR:25:354
				SELECTCASE RAND:2
				CASE 0
					CALL RAN_NORMALTALK
				CASE 1
					CALL RAN_SEASONTALK
				ENDSELECT
			ELSE
				CALL RAN_NORMALTALK
			ENDIF
;		;恋慕が付いてから本番。分岐が增えすぎたので别の函数に分けました。スッキリ
;		;引っ越しに伴う场所IDや约会中フラグの变化が把握出来ずこのような形に
;			;神社から引っ越してた场合
;			IF MAIN_MAP >= 1
;				;现在地が引っ越した先のMap内
;				IF GET_MAPID(CFLAG:現在位置) == MAIN_MAP
;					CALL RAN_NORMALTALK
;				;そうじゃなかったら外。どっかで偶然出会った场合でも约会会话になるけど今は妥协
;				ELSE
;					CALL RAN_DATETALK
;				ENDIF
;			;以下は神社在住（默认）时
;			ELSE
;				IF CHK_DATENOW(CFLAG:约会中)
;					CALL RAN_DATETALK
;				ELSE
;					CALL RAN_NORMALTALK
;				ENDIF
;			ENDIF
		ELSEIF TALENT:思慕
			SELECTCASE RAND:10
			CASE 0
				PRINTFORML 蓝窥视着般地看着%CALLNAME:MASTER%的脸
				PRINTFORML 「话说，你有没有觉得我可怕过？」
				PRINTFORML 「如果一次都没有，那就稍微有点问题了」
				PRINTFORMW 从温和的举止背后，感觉锐利的獠牙正在窥视
			CASE 1
				PRINTFORML 「哈哈哈，担心我真是多管闲事。还是先照顾好自己吧」
				PRINTFORML 当我说『您总是很忙，很辛苦吧』时，她用长辈的从容回答了我
				PRINTFORML 虽然是滴水不漏的回答，但总觉得比以前距离更近了
				PRINTFORMW 「嗯？怎么了？」
			CASE 2
				PRINTFORML 「钻研不会白费。料理和打扫也是出色的技能」
				PRINTFORML 「即使是砍价，也有不让店主露出厌恶表情的程度」
				PRINTFORMW 蓝得意地传授了各种技巧
			CASE 3
				PRINTFORML 「人和妖怪即使交往也不会合为一体」
				PRINTFORML 「这种常识也正在成为过去。时代变了」
				PRINTFORMW 蓝眺望着远方嘟囔着，然后看着%CALLNAME:MASTER%
			CASE 4
				PRINTFORML 「到底有什么不同呢……」
				PRINTFORML 「不，只是我自己的话」
				PRINTFORMW 蓝对歪着头的%CALLNAME:MASTER%露出了苦笑
			CASE 5
				PRINTFORML 「想看我的弹幕吗」
				PRINTFORMW 「呵呵。如果站在对面就没有时间看入迷了哦」
			CASE 6
				PRINTFORML 「不是被博丽使唤了吗？」
				PRINTFORMW 「那家伙没有顾虑这种东西。不要什么都答应，适当地拒绝哦」
			CASE 7
				PRINTFORML 「玉藻前？华阳夫人？抱歉，认错狐狸了」
				PRINTFORMW 虽然嘴上这么说，但蓝却朝着完全相反的方向看去
			CASE 8
				PRINTFORML 「嗯？你在目不转睛地看着哪里呢？」
				PRINTFORMW 我不禁被蓝的微笑弄得狼狈不堪
			CASE 9
				PRINTFORML 「以前每次去人里都会改变姿态」
				PRINTFORMW 「根据用途制作不同的人物形象，分别管理容貌的变化和人际关系」
				PRINTFORMW 「虽然说不上麻烦，但最近省事了很多，真是感激」
			ENDSELECT
		ELSE
			PRINTFORML 蓝听着你的话，轻快地应和着
			PRINTDATA
				DATAFORM 「嗯，然后呢？」
				DATAFORM 「哦哦」
				DATAFORM 「你也辛苦了啊」
				DATAFORM 「不用那么烦恼。小事小事」
				DATAFORM 「哈哈哈，我非常理解你的心情」
				DATAFORM 「啊，我也经历过类似的事情」
				DATAFORM 「谁都会失败的」
				DATAFORM 「不，那边的店更便宜」
				DATAFORM 「你不懂。你不懂油豆腐的真正价值」
				DATAFORM 「关于我的主人？想知道什么就去问她本人吧」
				;10
				DATAFORM 「猫还是狗？当然是猫！」
				DATAFORM 「蘑菇还是竹笋？我的话会把两者都放进油豆腐什锦饭里」
				DATAFORM 「君子不立危墙之下。不战也是一种强大」
				DATAFORM 「喂喂。你在热心地看着哪里啊」
				DATAFORM 「想跳进这条尾巴里？会弄乱毛发的，不行」
				DATAFORM 「即使戴着帽子，听力也不差哦」
				DATAFORM 「不要想太多。偶尔当个笨蛋也没关系」
				DATAFORM 「毕竟，人里住着白泽。没有不会被揭穿的罪行」
				DATAFORM 「哦，做得很好。乖孩子乖孩子」
				DATAFORM 「过去的事情吗……年轻气盛。别问了」
				;20
				DATAFORM 「从外界迷路进来的人中也有服装专家。今年的新作也值得期待」
				DATAFORM 「最近内衣好像卖得很好」
				DATAFORM 「要充分小心狸猫哦。因为很坏心眼」
				DATAFORM 「不要贸然去危险的地方。博丽之名也不是绝对的」
				DATAFORM 「不用说也知道。是稻荷寿司」
				DATAFORM 「我会控制不让掉毛的」
				DATAFORM 「真和平啊」
				DATAFORM 「谢绝勾搭哦」
				DATAFORM 「即使是别人的家，乱糟糟的也会让人感到不舒服。你也是吗？」
				DATAFORM 「对我的式出手的人我绝不饶恕」
				;30
			ENDDATA
		ENDIF
		PRINTL 
	ENDIF
ENDIF
RETURN 1
;━━━━━━━━━━━━━━━━━━━━━━━━━
;以下自作函数。影狼口上を参考にさせて顶きました
;蓝样通常会话（恋慕前提）
;━━━━━━━━━━━━━━━━━━━━━━━━━
@RAN_NORMALTALK
	;通常会话のうち四季を问わない物をこちらへ集约
	;季节によっては烂れた生活が～とか见れないのが嫌だったんです……
	SELECTCASE RAND:32
	CASE 0
		IF TALENT:恋人
			PRINTFORML 「你真是个好男人啊，%CALLNAME:MASTER%」
			PRINTFORML 蓝看到突然被夸奖而不知所措的%CALLNAME:MASTER%，开朗地笑了
			PRINTFORMW 「但是，你的举止还不够典雅。我会彻底地磨练你的」
		ELSE
			PRINTFORML  「……………」
			PRINTFORML 谈话途中突然沉默，蓝的眼睛紧紧地盯着%CALLNAME:MASTER%
			PRINTFORML 然后，突然啪地一声拍了一下额头
			PRINTFORML 「这是对你所作所为的报应。我是不会道歉的」
			PRINTFORMW %CALLNAME:MASTER%想要反击咯咯笑着的蓝，却被轻易地躲开了
		ENDIF
	CASE 1
		IF TCVAR:25:352 == 1
			PRINTFORML 「自古以来狐狸就会迷惑人」
			PRINTFORML 「%CALLNAME:MASTER%不认为自己被我骗了吗？」
			PRINTFORMW 「……是吗。嗯，我问了个愚蠢的问题」
		ELSE
			PRINTFORML 「前几天我教了橙。有时候错误的答案才是正确的答案」
			PRINTFORMW 「%CALLNAME:MASTER%觉得这块石头像什么？」
			$INPUT_LOOP_01
			PRINTL [0] 钻石
			PRINTL [1] 碳的结晶
			PRINTL [2] 叶子
			INPUT
			SELECTCASE RESULT
			CASE 0
				PRINTFORML 「很遗憾。它的真面目只是一片叶子」
				PRINTFORML 「无论怎么回答都是错误的。也就是说，那就是我，提问者所寻求的正确答案」
				PRINTFORMW 「坦率的解答很好。你很会倾听呢」
			CASE 1
				PRINTFORML 「很遗憾。这是玻璃的赝品」
				PRINTFORML 「正如你所察觉的，不可能有正确答案。一旦明白这一点，人们就会想要窥探对方的内心」
				PRINTFORMW 「想要给出扭曲的答案才是最大的错误」
			CASE 2
				PRINTFORML 「很遗憾。其实是真的」
				PRINTFORML 「虽说如此，正确与否是次要的。这东西的真假又有什么意义呢？」
				PRINTFORMW 「哎呀，钻石被风吹走了」
			CASEELSE
			GOTO INPUT_LOOP_01
			ENDSELECT
			TCVAR:25:352 = 1
		ENDIF
	CASE 2
		IF TALENT:恋人
			PRINTFORML 「与八云为敌的人盯上你是必然的趋势吧」
			PRINTFORML 「变强吧。力量和智慧都还远远不够」
			PRINTFORMW 蓝小声嘟囔着：不要让我抛弃你
		ELSE
			PRINTFORML 「明明只是自杀行为，却时不时会出现想要打破大结界的人」
			PRINTFORML 「大多是略懂法术的人类。要么就是在幻想乡出生的年轻妖怪」
			PRINTFORML 「在和平中长大的人不知道它的价值。会主动寻求危险和考验」
			PRINTFORML 「所以，我会给予他们这些」
			PRINTFORMW 露出一个略带虐待的笑容。也许是释放压力的一种方式
		ENDIF
	CASE 3
		IF TALENT:恋人
			PRINTFORML 「之后也请陪橙一起练习」
			PRINTFORMW 「约定好在她独当一面的时候，我会送她道士服」
		ELSE
			PRINTFORML 「橙说想要我穿的这种衣服」
			PRINTFORML 「给她做一件也不是不行，但总觉得还是作为某种奖励比较好」
			PRINTFORMW 「生日礼物，还是给她布置一个难题呢。唔——」
		ENDIF
	CASE 4
		PRINTFORML 「实际上，狐狸是不会发出“konkon”的声音的」
		PRINTFORMW 「正确的示范？ ……kyung—」
	CASE 5
		PRINTFORML 「那么，之后得去收衣服了……」
		PRINTFORMW 「嗯？ 并不是什么要紧事。家务可是我的休息」
		PRINTFORMW 她真是个高规格的式神
	CASE 6
		PRINTFORML 「善狐也好恶狐也好，都是无所谓的区分」
		PRINTFORMW 「我只是一介式神。只要紫大人下令，我就会成为任何一方」
	CASE 7
		PRINTFORML 「想从远处和我说话的时候，可以用狐狗狸」
		PRINTFORMW 「一个字一个字太麻烦了，我会用念话回复的」
	CASE 8
		IF TALENT:恋人
			PRINTFORML 「既然你和我关系親密，你也会被视为八云的关系者」
			PRINTFORML 「为了以防万一，准备好保护自己的手段」
			SIF TALENT:26:恋慕
				PRINTFORML 「因为你对紫大人来说也是唯一的弱点」
			PRINTFORMW 蓝一脸认真地这样警告道
		ELSE
			PRINTFORML 「紫大人的想法是其他人无法揣测的」
			PRINTFORML 「话虽如此，她也不是任何时候都像贤者一样凛然地行動」
			PRINTFORML 「在家就和橙一起抱我的尾巴……」
			PRINTFORMW 不知从何处飞来的水桶“咣当”一声直接击中了蓝
		ENDIF
	CASE 9
		IF TALENT:恋人
			PRINTFORML 「果然还是玩花牌比较轻松」
			PRINTFORMW 「那么……要不要试试输了就脱一件的规则？」
		ELSE
			PRINTFORML 「我想推广麻将和花牌这种“公平”的游戏」
			PRINTFORML 「这是人妖一起玩的方法。只要有契机和新意，就能简单地推广开来……」
			PRINTFORMW 在考察各种要素的蓝的旁边，%CALLNAME:MASTER%想了一些没用的事情
			PRINTFORMW 「那么，你想到导入脱衣规则的优点了吗？」
		ENDIF
	CASE 10
		PRINTFORML 「我也喜欢甜食哦。就算再喜欢油豆腐，也不能只吃那个啊」
		PRINTFORMW 「我经常自己做日式点心。下次要不要带些萩饼给你？」
	CASE 11
		PRINTFORML 「我不擅长的东西？」
		PRINTFORML 「不好意思，害怕狼已经是尾巴只有一条时候的事了」
		PRINTFORMW 「现在的话……是小孩子的哭声吧」
	CASE 12
		PRINTFORML 「科学说，爱只不过是脑内物质引起的现象」
		PRINTFORML 「那么，不依赖大脑思考的存在就无法产生爱吗？」
		PRINTFORML 「%CALLNAME:MASTER%。你怎么认为？」
		PRINTFORMW 什么也没说，彼此交换了笑容
	CASE 13
		PRINTFORML 「我最后一次哭是什么时候呢」
		PRINTFORML 「……啊啊，这么说来最近经常被你弄哭呢」
		PRINTFORMW 我苦笑着回应了这样盯着我说的蓝
	CASE 14
		PRINTFORML 「这是个秘密的爱好，我对内衣的选择很讲究」
		PRINTFORMW 「虽然看款式最多的人是你，有什么感想吗？」
	CASE 15
		IF ABL:MASTER:戦闘能力 >= 4
			PRINTFORML 「你的成长真是了不起」
			PRINTFORML 「在这么短的时间里就和幻想乡的一流高手并肩了。可以为此感到自豪」
			PRINTFORMW 即使如此，还是感觉无法战胜蓝。能和她并肩站立的日子还很遥远
		ELSEIF ABL:MASTER:戦闘能力 == 3
			PRINTFORML 「%CALLNAME:MASTER%也比以前强了很多」
			PRINTFORML 「但是，要记住弹幕的技巧和战斗的实力是不同的。鬼就是一个很好的例子」
			PRINTFORMW 即使是弹幕游戏，我也觉得她很强，如果她拿出真本事会怎么样呢
		ELSE
			PRINTFORML 「战斗的基础是格斗。不能依赖法术」
			PRINTFORML 「即使肉体虚弱也很强的家伙，充其量也就是魔女了」
			PRINTFORMW 我想起了那个挥舞着精装书的少女
		ENDIF
	CASE 16
		IF TALENT:恋人
			PRINTFORML 「最近，在人里被搭讪的次数减少了」
			PRINTFORML 「明白是什么意思吗？ 晚上走路要小心哦——」
			PRINTFORMW %CALLNAME:MASTER%不由自主地环顾四周
		ELSE
			PRINTFORML 「啊啊，是啊。经常被男人搭讪哦」
			PRINTFORMW 「虽然我已经习惯拒绝了，但是当看起来很纯真的少年拿着花来的时候，真的会很困扰」
			PRINTFORMW 「因为太可爱了，一不小心就点头答应了……啊哈哈，当真了？」
		ENDIF
	CASE 17
		;紫大人的恋慕的有无
		IF TALENT:恋人
			PRINTFORML 「呐，要不要搬到迷途之家来？」
			IF TALENT:26:恋慕
				PRINTFORML 「如果是%CALLNAME:MASTER%的话，紫大人也会欢迎的吧」
				SIF TALENT:24:恋慕
					PRINTFORML 「橙也不需要在意我的眼光了」
				PRINTFORML 「怎么样。要不要过一年两年，腻在一起的糜烂生活？」
				PRINTFORMW %CALLNAME:MASTER%只是说了句“我会考虑的”，蓝就咯咯地笑了
			ELSE
				PRINTFORML 「紫大人没问题的。她绝对会觉得很有趣的」
				PRINTFORML 「人手增加了，我的工作也会减少，和你相处的时间也会增加」
				PRINTFORMW 「如果能考虑一下就太好了」
			ENDIF
		ELSE
			PRINTFORML 「最近紫大人总是取笑我。说我像个少女一样飘飘然的」
			IF TALENT:26:恋慕
				PRINTFORML 「她自己也说不了别人」
				PRINTFORML 「这也是你的错，要好好负责哦」
				PRINTFORMW 在耳边轻声说“两个人一起”，%CALLNAME:MASTER%一时语塞
			ELSE
				PRINTFORML 「有那么明显吗？ 我化没化妆和平时一样啊」
				PRINTFORMW %CALLNAME:MASTER%说“笑容变得可爱了”，蓝大大地红了脸
			ENDIF
		ENDIF
	CASE 18
		PRINTFORML 「我当然是狐狸乌冬面」
		PRINTFORML 「退一步说，腐皮乌冬面也可以」
		PRINTFORML 「那么你，总不会说是狸猫乌冬面吧？」
		PRINTFORMW 进行了愚蠢的对话，我切实地感受到我们关系变好了
	CASE 19
		PRINTFORML 「啊哈哈哈，为了袜子为什么要做到这种地步！」
		PRINTFORMW 因为一些没什么内容的蠢话，蓝发出了爽朗的笑声
	CASE 20
		PRINTFORML 「旋转那么多圈，眼睛不会晕吗？」
		PRINTFORMW 「完全没问题。每次攻击都摇摇晃晃的，那就没法战斗了吧」
		PRINTFORMW 「可以自由自在地进行瞬间的方向转换和急停。如果以为只是单纯的冲撞，可是会吃苦头的哦」
	CASE 21
		PRINTFORML 「喂……不要这么明目张胆地问女人的敏感带」
		PRINTFORMW 「而且，就算不说你也应该知道吧。比如嘴唇和尾巴根，还有这下面附近」
	CASE 22
		PRINTFORML 「『如果和伊吹殿战斗的话』，你又提出了一个让我难以回答的话题」
		PRINTFORML 「我不会单方面地输掉。我不会说更多了。绝对不会」
	CASE 23
		PRINTFORML 「…………嗯。怎么了？」
