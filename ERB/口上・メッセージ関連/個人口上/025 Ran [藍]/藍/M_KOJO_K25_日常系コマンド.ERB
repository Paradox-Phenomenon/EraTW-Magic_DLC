;蓝样通常身体接触（恋慕前提）
;━━━━━━━━━━━━━━━━━━━━━━━━━
@RAN_NORMALSKINSHIP
	;お澡堂场身体接触
;	IF TALENT:恋慕 && (CFLAG:現在位置 == 13 || CFLAG:現在位置 == 24 || CFLAG:現在位置 == 30 || CFLAG:現在位置 == 39)
	IF BATHCHECK(CFLAG:MASTER:現在位置) && IN_HOME(CFLAG:MASTER:現在位置)
		SELECTCASE RAND:5
		CASE 0
			PRINTFORML 「让你帮忙了，不好意思。接下来轮到你那边了」
			PRINTFORMW 我们分工合作，清洗着总共九条尾巴
			PRINTFORMW 虽然和期待的不一样，但是仅仅是共同护理蓝的重要部位，就让人感到快乐
		CASE 1
			PRINTFORML 我让蓝用小法术隐藏起尾巴，从背后清洗她白皙柔嫩的肌肤
			PRINTFORML 纤细的腰肢，从腋下窥视到的乳房，压在椅子上改变形状的臀部，都显得妖娆
			PRINTFORMW 「呵呵，我能清楚地知道你在看哪里哦」
		CASE 2
			PRINTFORML 在蓝护理尾巴的时候，%CALLNAME:MASTER%负责清洗她的身体前方
			PRINTFORML 从脖子开始向下，向下。到处都是起伏，真是很有清洗的价值
			PRINTFORML 「嗯，喂。不要光洗胸部……」
		CASE 3
			PRINTFORML 我注意着力道，用毛巾描绘着蓝苗条的背部
			PRINTFORML 弹水的肌肤细腻光滑，在适度的肌肉衬托下，紧致的线条非常美丽
			PRINTFORML 「可以拜托你这边也洗一下吗，%CALLNAME:MASTER%？」
		CASE 4
		;玩弄毛发 五分之一的概率，可能不太容易出现
			IF CFLAG:25:1006 == 1
				PRINTFORML 突然，%CALLNAME:MASTER%的目光停留在蓝的股间
				PRINTFORMW 以前自己护理过的地方。现在的状态是……
				$INPUT_LOOP_02
				PRINTL [0] 还是一如既往的白虎
				PRINTL [1] 开始长出一些细毛
				PRINTL [2] 已经长满了毛
				INPUT
				SELECTCASE RESULT
				CASE 0
					PRINTFORMW 像儿童一样光溜溜的耻丘。保持着美丽的无毛状态
					PRINTFORML 蓝似乎按照%CALLNAME:MASTER%的吩咐，维持着白虎的状态
					PRINTFORML 「我大概隔一天剃一次。为了让你高兴」
					PRINTFORMW 虽然我很开心，但是%CALLNAME:MASTER%偷偷地想，我也想看看长出绒毛的过程
				CASE 1
					PRINTFORML 随意地长着一些金色的绒毛
					PRINTFORML 「不让我护理……我又不是没有羞恥心」
					PRINTFORML %CALLNAME:MASTER%把脸颊发红，瞪着自己的蓝向后推倒
					PRINTFORML 用打桩机姿势牢牢地固定住她，甚至露出了肛门和周围的毛发
					PRINTFORMW 看着蓝因为极度的羞辱而前所未有地脸红的样子，我小心翼翼地操纵着剃刀……
				CASE 2
					PRINTFORML 「如你所见，已经长全了。恢复原样了」
					PRINTFORML 长出了柔软而富有光泽的金发，被优雅地整理过
					PRINTFORMW 用手指缠绕着难以置信是阴毛的角质层，乐在其中
					CFLAG:25:1006 = 0
				CASEELSE
				GOTO INPUT_LOOP_02
				ENDSELECT
			ELSE
				PRINTFORML 突然，%CALLNAME:MASTER%的目光停留在蓝的股间
				PRINTFORML 修剪成漂亮形状的金色的阴毛被汤水浸湿，闪耀着光芒
				PRINTFORML 「？ 怎么了%CALLNAME:MASTER%，看得这么仔细」
				PRINTFORMW 「现在才觉得稀奇吗？」
				$INPUT_LOOP_03
				PRINTL [0] 也想在那里用洗发水
				PRINTL [1] 想把毛全部剃掉
				PRINTL [2] 想帮忙打理
				INPUT
				SELECTCASE RESULT
				CASE 0
					PRINTFORML 「呼——嗯。那就拜托%CALLNAME:MASTER%了」
					PRINTFORML 蓝没有反问那是什么，而是带着从容的笑容答应了
					PRINTFORML 她将身体转向这边，慢慢地左右打开膝盖
					PRINTFORML %CALLNAME:MASTER%从正面将手伸向茂密的区域，涂上大量的泡沫
					PRINTFORMW 洗刷着和自己的完全不同质感的柔软阴毛
				CASE 1
					PRINTFORML 「哇啊，原来是这种打算啊。你这变态」
					PRINTFORML 蓝虽然嘴上这么说，但还是苦笑着答应了
					PRINTFORML 她仰面躺在铺好的毛巾上，大大地张开了双腿
					PRINTFORML 坐在她面前的%CALLNAME:MASTER%拿着剃刀，将脸凑近了私处
					PRINTFORMW 将长全的阴毛全部干净地剃掉，让蓝变成了白虎
					CFLAG:25:1006 = 1
				CASE 2
					PRINTFORML 「诶？ 不，我自己弄就好了……」
					PRINTFORML 「……也就是说想改变下面毛发的形状吗。你还真是有些奇怪的性癖啊」
					PRINTFORML 蓝虽然嘴上这么说，但还是笑着答应了
					PRINTFORML 她仰面躺在铺好的毛巾上，大大地张开了双腿
					PRINTFORML 坐在她面前的%CALLNAME:MASTER%拿着剃刀，将脸凑近了私处……
					IF RAND:4 == 0
						PRINTFORMW 将蓝的阴毛剃成可爱的爱心形状
					ELSEIF RAND:3 == 0
						PRINTFORMW 将蓝的阴毛剃成菱形
					ELSEIF RAND:2 == 0
						PRINTFORMW 将蓝的阴毛剃成标准的椭圆形
					ELSE
						PRINTFORMW 将蓝的阴毛剃成小小的倒三角形
					ENDIF
				CASEELSE
				GOTO INPUT_LOOP_03
				ENDSELECT
			ENDIF
		ENDSELECT
	ELSE
		SELECTCASE RAND:10
		CASE 0
			PRINTFORML 「来，抬起头。好好地让我看看你的脸」
			PRINTFORMW 不知不觉间攻守逆转，蓝好好地疼爱了%CALLNAME:MASTER%
		CASE 1
			PRINTFORML 用指尖描绘着轮廓，抚摸着蓝的脸颊
			PRINTFORMW 「痒痒的。我也要对你做」
		CASE 2
			PRINTFORML 趁其不备，戳了戳蓝的肋部
			PRINTFORML 「哇，你这家伙，恶作剧的小鬼」
			PRINTFORMW 扭动身体的蓝开心地笑着
		CASE 3
			PRINTFORML 「在人前太腻歪的话，我的威严会……好好好，给你手」
			PRINTFORMW 即使被当成狗对待也不会生气的蓝，她的包容心深不见底
		CASE 4
			PRINTFORML 蓝的尾巴只在%CALLNAME:MASTER%面前才会坦率地摇动
			PRINTFORML 「嗯——」
			PRINTFORMW 似乎很喜欢被抚摸背部
		CASE 5
			PRINTFORML 用指腹轻轻地抚摸下巴
			PRINTFORML 「别以为我是犬科的就……呜嗯」
			PRINTFORMW 有些害羞地配合的蓝非常可爱
		CASE 6
			PRINTFORML 「哇呜！ 啊哈哈，别、别挠了！ 痒痒！」
			PRINTFORMW 一直挠着她纤细的腰部，直到她哭着求饶
		CASE 7
			PRINTFORML 用手像梳子一样梳理着顺滑的金发。顺便闻了闻味道
			PRINTFORML 「能被你说漂亮，我最开心了」
			PRINTFORMW 蓝握住那只手，像要掩饰自己泛红的脸颊一样按了上去
		CASE 8
			PRINTFORML 什么也没说，用双手一把抓住蓝的脸
			PRINTFORML 「！？」
			PRINTFORMW 用手掌揉捏着她的脸颊，让它暖和起来
		CASE 9
			PRINTFORML 倾诉着爱意，和蓝进行親密的肌肤接触
			PRINTFORMW 「嗯，我也爱你哦」
		ENDSELECT
	ENDIF
RETURN 1
