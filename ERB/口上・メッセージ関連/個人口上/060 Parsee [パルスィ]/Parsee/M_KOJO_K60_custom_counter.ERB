;[[パルスィ]]→[[パルスィ]]

;==================================================
;Play With Ears
;==================================================
;固有カウンター可否
@UNIQUE_COUNTER1_ABLE_K60
RETURN 1

;固有カウンターの種別と頻度
@UNIQUE_COUNTER1_FREQUENCY_K60
RESULTS = 着衣
RETURN 10

;テキスト
@UNIQUE_COUNTER1_MESSAGE_K60
;PRINTFORMD Parsee 
PRINTFORMD パルスィは
SELECTCASE RAND:2
    CASE 0
        SELECTCASE K60_ATTITUDE()
            CASE 0, 1, 3
                ;PRINTFORMD asks you to play with her ears
                PRINTFORMD あなたに耳を触ってほしいと頼んできた
            CASE 2
                ;PRINTFORMD demands that you play with her ears
                PRINTFORMD あなたに耳を触るように求めてきた
        ENDSELECT
    CASE 1
        SELECTCASE K60_ATTITUDE()
            CASE 0, 1, 3
                ;PRINTFORMD gently guides your hand to her ear
                PRINTFORMD あなたの手をそっと自らの耳に導いた
            CASE 2
                ;PRINTFORMD grabs your hand and places it on her ear
                PRINTFORMD あなたの手を掴んで自らの耳に触れさせた
        ENDSELECT
ENDSELECT
;PRINTFORMDL ...
PRINTFORMDL ……

;固有カウンターのソース等
@UNIQUE_COUNTER1_SOURCE_K60
SOURCE:TARGET:誘惑 += 100
SOURCE:TARGET:強要 += 100
SOURCE:TARGET:征服 += 200
SOURCE:TARGET:快Ｍ += 25 ;where the hell do you put pleasure gems for an ear massage