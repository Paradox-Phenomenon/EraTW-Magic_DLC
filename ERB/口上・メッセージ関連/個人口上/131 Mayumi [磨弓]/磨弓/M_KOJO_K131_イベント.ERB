;脱衣口上
;==================================================
@M_KOJO_EVENT_K131_28(ARG,ARG:1)
;口上主はTARGET
;ARGに脱がし方選択
;ARG:1（ARG=3の場合のみあり）地の文の反応
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	SELECTCASE ARG
		;-------------------------------------------------
		CASE 0
		;全裸にする
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1
			;時間停止時
			IF FLAG:70
				PRINTFORMDL 磨弓の服を全て脱がせ、全裸にした。
				PRINTFORMDW 人間の女性と遜色ない磨弓の肢体に、袿姫の並々ならぬ情熱を感じた…！
			;通常
			ELSE
				IF TALENT:恋人 || TALENT:恋慕
					SELECTCASE RAND:(TALENT:恋人 ? 4 # 3)
						CASE 0
							PRINTFORML 「…恥ずかしいから、あまり見るな…！」
							PRINTFORMDW 磨弓は両腕で身体を隠してモジモジしている…！
						CASE 1
							PRINTFORML 「なあ…私の身体、変じゃないか…？」
							PRINTFORMW 黙ってないで、何か言ってくれ…！
						CASE 2
							CALL HPH_PRINT,@"（%CALLNAME:MASTER%の…！もう、あんなに…HPH）","L"
							PRINTFORMDW 磨弓の視線は、%CALLNAME:MASTER%の股間に釘付けだ…！
						;恋人のみ
						CASE 3
							CALL HPH_PRINT,@"「ん…HPHちゅ…HPH」","L"
							CALL HPH_PRINT,@"「今日こそは、お前を鳴かせてやるぞ…HPH」","L"
							PRINTFORMDW 磨弓は挑発的な笑みを浮かべている…！
					ENDSELECT
				ELSE
					SELECTCASE RAND:2
						CASE 0
							PRINTFORML 「服を脱いだが…ここからどうするんだ？」
							PRINTFORMDW 磨弓は行為の意味を理解していないようだ…
						CASE 1
							PRINTFORML （私の身体とは、結構違うんだな…）
							PRINTFORMDW 磨弓にまじまじと身体を見られ、少し恥ずかしくなった…
					ENDSELECT
				ENDIF
			ENDIF
		RETURN 1
		ENDIF
		;-------------------------------------------------
		CASE 1
		;下着姿にする
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1
			;時間停止時
			IF FLAG:70
				PRINTFORMDL 磨弓の鎧と服を外し、下着姿にした。
				SELECTCASE RAND:2
					CASE 0
						PRINTFORMDW 明らかに現代のものとは違う、古いデザインの下着だ…
					CASE 1
						PRINTFORMDW 以外と可愛らしい下着を付けているが、袿姫の趣味だろうか？
				ENDSELECT
			;通常
			ELSE
				IF TALENT:恋人 || TALENT:恋慕
					SELECTCASE RAND:(TALENT:恋人 ? 4 # 3)
						CASE 0
							PRINTFORML 「袿姫様に、下着くらいは可愛いのを着けろと言われてな…」
							CALL HPH_PRINT,@"「…に、似合うか？HPH」","L"
							PRINTFORMDW 下着姿の磨弓が、上目遣いで見つめてくる…！
						CASE 1
							PRINTFORML 「…なんだその目は！」
							PRINTFORML 「どうせ脱ぐんだからいいじゃないか…！」
							PRINTFORMDW いつの時代の人だと言いたくなるような、古いデザインの下着だ…
						CASE 2
							CALL HPH_PRINT,@"「…ここから、どうするんだ？HPH」","L"
							PRINTFORMDW 磨弓の目は、期待に満ちている…！
						;恋人のみ
						CASE 3
							CALL HPH_PRINT,@"「ふぅ…♪少し、熱くなってきたな…HPH」","L"
							PRINTFORMDW 下着姿になった磨弓は、頬を赤らめている…！
					ENDSELECT
				ELSE
					SELECTCASE RAND:2
						CASE 0
							PRINTFORML 「%CALLNAME:MASTER%の下着は、私のとは随分違うな」
						CASE 1
							PRINTFORML 「この格好は、少し肌寒いな…」
					ENDSELECT
					PRINTFORMDW 磨弓にまじまじと身体を見られ、少し恥ずかしくなった…
				ENDIF
			ENDIF
		RETURN 1
		ENDIF
