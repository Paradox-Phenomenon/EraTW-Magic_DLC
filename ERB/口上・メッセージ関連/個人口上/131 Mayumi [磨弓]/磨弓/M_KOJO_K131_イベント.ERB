							CALL HPH_PRINT,@"「今日は着たままするのか…？HPH」","L"
							CALL HPH_PRINT,@"「助平な奴だ…HPH」","L"
							PRINTFORMDW 磨弓は興奮しているのか、息が少し荒い…！
					ENDSELECT
				ELSE
					SELECTCASE RAND:2
						CASE 0
							PRINTFORML 「…………。」
						CASE 1
