		CALL HPH_PRINT,@"「ま…待て！今はまだ敏感で…あぁっHPH HPH」","L"
		CALL HPH_PRINT,@"「ま、待ってぇHPHこのままじゃまたっHPHまた、まけるぅっHPH HPH」","W"
	RETURN 1
	ENDIF
	;-------------------------------------------------
	;記入チェック（=0, 非表示、1, 表示）
