						PRINTFORML （人間の文化は、よく分からないな…）
					ENDIF
					PRINTFORMDW 磨弓と下着を交換した。
					RETURN 1
				ENDIF
				;-------------------------------------------------
				CASE 1
				;OK（嬉々
				;記入チェック（=0, 非表示、1, 表示）
				LOCAL:1 = 1
				;-------------------------------------------------
				IF LOCAL:1
					IF TALENT:恋人 || TALENT:恋慕
						CALL HPH_PRINT,@"「…袿姫様には、内緒だぞ？HPH」","L"
					ELSE
						PRINTFORML 「お前、こんな物が欲しいのか？」
					ENDIF
					PRINTFORMDW 磨弓から下着を貰った。
					RETURN 1
				ENDIF
				;-------------------------------------------------
				CASE 2
				;OK（渋々
				;記入チェック（=0, 非表示、1, 表示）
				LOCAL:1 = 1
				;-------------------------------------------------
				IF LOCAL:1
					IF TALENT:恋人 || TALENT:恋慕
						CALL HPH_PRINT,@"「お前が…そう言うなら…HPH」","L"
					ELSE
						PRINTFORML 「…何を企んでいるんだ…？」
						PRINTFORML （まあ、下着程度でどうこう出来るとは思えんが…）
					ENDIF
					PRINTFORMDW 磨弓はおずおずと下着を渡してきた。
					RETURN 1
				ENDIF
				;-------------------------------------------------
				CASE 3
				;嫌です
				;記入チェック（=0, 非表示、1, 表示）
				LOCAL:1 = 1
				;-------------------------------------------------
				IF LOCAL:1
					IF TALENT:恋人 || TALENT:恋慕
						PRINTFORML 「い…いくらお前の頼みでも、それは…！」
						PRINTFORMDW 磨弓は下着をくれなかった…
					ELSE
