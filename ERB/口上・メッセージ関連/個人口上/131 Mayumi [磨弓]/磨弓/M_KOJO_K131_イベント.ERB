;==================================================
@M_KOJO_SPEVENT_MESSAGECHECK_K131_3
RETURN 0

@M_KOJO_SPEVENT_K131_3(ARG,ARG:1)
;口上主はTARGET
;地の文表示
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;通常帰宅
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 0
		IF CFLAG:318 == 1
			PRINTFORML 「…………。」
			PRINTFORMDW 気まずい空気の中、磨弓と共に帰宅した……
		ELSEIF TALENT:恋慕
			SELECTCASE RAND:5
				CASE 0
					CALL HPH_PRINT,@"「ふふっ…HPH今日も楽しかったな、%CALLNAME:MASTER%…HPH」","L"
					PRINTFORMDW 磨弓はデートを楽しんでくれたようだ。
				CASE 1
					PRINTFORML 「む…もう着いてしまったか」
					PRINTFORMW 「%CALLNAME:MASTER%と居ると、本当に時間が経つのが早く感じるな…♪」
				CASE 2
					PRINTFORML 「今日は…ゆっくり帰るとしようか」
					CALL HPH_PRINT,@"「少しでも長く、お前と一緒に居たいからな…HPH」","L"
					PRINTFORMDW 磨弓と手を繋ぎながら帰路についた。
				CASE 3
					PRINTFORML 「次に行きたい所か？そうだな…♪」
					PRINTFORMDW 磨弓と次のデートの計画を立てながら帰路についた。
				CASE 4
					PRINTFORML 「なあ、%CALLNAME:MASTER%…」
					IF TALENT:恋人
						CALL HPH_PRINT,@"「今夜…部屋で待ってるぞ…HPH」","L"
						PRINTFORMDW 磨弓が潤んだ瞳で見つめてきた…！
					ELSE
						PRINTFORML 「…その…また、誘ってくれるか…？」
						PRINTFORMDW 次も磨弓をデートに誘ってみようか…？
					ENDIF
			ENDSELECT
		ELSEIF TALENT:思慕
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「もうそんな時間か？では帰るとしよう」
					PRINTFORMDW 磨弓と一緒に帰った。
				CASE 1
					PRINTFORML 「なに！？もうこんな時間か…%CALLNAME:MASTER%！後ろに乗れ！」
					PRINTFORML 「振り落とされるなよ！しっかり掴まっているんだぞ！」
					PRINTFORMDW 急ぎの用事でもあったのか、磨弓の馬型埴輪に乗って慌ただしく帰った。
				CASE 2
					PRINTFORML 「今日は楽しかったぞ%CALLNAME:MASTER%！また誘ってくれ♪」
					PRINTFORMDW デート先から帰り、磨弓と笑顔で別れた。
			ENDSELECT
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「袿姫様が心配だ…早く帰らねば」
					PRINTFORMDW 早めに帰ろうとする磨弓を慌てて追いかけた…
				CASE 1
					PRINTFORML 「遊ぶ、というのはよく分からないが…」
					PRINTFORML 「良い時間を過ごせた。礼を言うぞ%CALLNAME:MASTER%」
					PRINTFORMDW 磨弓はデートを楽しんでくれたようだ。
				CASE 2
					PRINTFORML 「戻ったぞ！袿姫様はお変わりないか？」
					PRINTFORMDW デート先から帰るなり、磨弓は埴輪兵からの報告を聞いて（？）いる。
			ENDSELECT
		ENDIF
	ENDIF
	RETURN 1
	;-------------------------------------------------
	;反発刻印消去イベント
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		PRINTFORML 「……%CALLNAME:MASTER%」
		PRINTFORMDL 帰り道、磨弓が話しかけてきた。
		PRINTFORMDW 埴輪兵士たちの姿は見えないが、周辺からは殺気を感じる…
		PRINTFORML 「もうあんな事はしないと、約束できるか？」
		PRINTFORMDW %CALLNAME:MASTER%ははっきりと言葉に出して約束した。
		PRINTFORMDW すると、近くに隠れているであろう埴輪兵士たちの殺気は消え、磨弓の顔に少しだけ笑顔が戻った。
		PRINTFORML 「分かった…なら、私も許そう…♪」
		PRINTFORMDW 磨弓が差し出してきた右手をしっかりと握り、握手を交わした…！
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;反発刻印2>1レベルダウンイベント
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		PRINTFORML 「…………。」
		PRINTFORMDW 磨弓に話しかけようとしたが、埴輪兵士たちに阻まれて近づくことすら出来なかった…
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;反発刻印3>2レベルダウンイベント
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		PRINTFORML 「……ふん！」
		PRINTFORMDW 磨弓に謝ろうとしたが、埴輪兵士たちに刃を向けられたため諦めた…
		RETURN 1
	ENDIF
	PRINTFORML
ENDIF
RETURN 1

