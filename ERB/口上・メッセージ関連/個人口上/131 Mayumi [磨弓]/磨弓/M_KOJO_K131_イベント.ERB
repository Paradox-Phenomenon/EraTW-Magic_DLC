			CALL HPH_PRINT,@"「お゛ぶう゛ぅっHPH HPHう゛ぐぅ…！」","L"
			CALL HPH_PRINT,@"「ぐっ…ご、くっHPHごきゅっHPHごくっHPH…はぁ…HPH」","L"
