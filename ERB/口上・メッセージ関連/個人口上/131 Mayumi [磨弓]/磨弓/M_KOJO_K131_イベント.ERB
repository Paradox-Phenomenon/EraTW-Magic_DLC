@M_KOJO_EVENT_K131_3(ARG,ARG:1)
;口上主はTARGET
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------

IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;自室に帰って寝る（～は【現在地】から【キャラの自室】に戻りました）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		IF ARG:1
			;デート中に眠くて帰って寝る（拠点キャラのみ）
			PRINTFORML 「すっかり遅くなってしまった…そろそろ帰らねば」
			IF TALENT:恋慕 || TALENT:思慕
				PRINTFORML 「また明日な、%CALLNAME:MASTER%♪」
			ELSE
				PRINTFORML 「今日は楽しかったぞ。また誘ってくれ」
			ENDIF
			PRINTFORMDW 磨弓は帰っていった。
		ELSEIF CFLAG:うふふ
			;うふふ中に眠くて自室に帰って寝る（拠点キャラのみ）
			PRINTFORML 「いかん…！もう帰らないと…！」
			PRINTFORML 「%CALLNAME:MASTER%、またなっ！」
			PRINTFORMDW 磨弓は服を整え、慌てて帰っていった…
		ELSE
			SELECTCASE RAND:2
				CASE 0
					PRINTFORML 「おやすみ、%CALLNAME:MASTER%」
					PRINTFORML 「夜更かしは程々にするんだぞ？」
				CASE 1
					PRINTFORML 「む…？もうこんな時間か…」
					PRINTFORML 「私はそろそろ帰るよ。おやすみ、%CALLNAME:MASTER%」
			ENDSELECT
			PRINTFORMDW 磨弓は帰っていった。
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;眠そうにしている（～は眠そうにしている）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		SELECTCASE RAND:3
			CASE 0
				PRINTFORML 「…大丈夫…だ…気に…する…な…」
				PRINTFORMDW 磨弓の目が虚ろだ……
			CASE 1
				PRINTFORML 「…………。」
				PRINTFORML 「―はっ！な、何か言ったか！？」
				PRINTFORMDW 磨弓はどこか上の空だ……
			CASE 2
				PRINTFORML 「私は埴輪兵士だからな…眠らなくても、平気…だ…！」
				PRINTFORML 「…おい、%CALLNAME:MASTER%…！聞いているのか…！？」
				PRINTFORMDW 磨弓は寝ぼけているのか、埴輪兵を%CALLNAME:MASTER%と間違えているようだ…
		ENDSELECT
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;睡眠中（～は眠っている）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		PRINTFORML 「…………。」
		PRINTFORMDW 磨弓は%TEXTR("目を閉じた/目を開けた")%まま、微動だにしない…
	RETURN 1
	ENDIF
	;-------------------------------------------------
	;イタズラ中
	;記入チェック（=0, 非表示、1, 表示）
	;LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 4
		SELECTCASE RAND:3
			CASE 0
				CALL HPH_PRINT,@"「…んっ…HPH」","W"
			CASE 1
				CALL HPH_PRINT,@"「は…HPHあ…んんっ…HPH」","W"
			CASE 2
				CALL HPH_PRINT,@"「あ…♪う…HPH」","W"
			ENDSELECT
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;衰弱して寝る（体力500以下,うふふ時はうふふ強制終了）
	;（キャラの自室以外：～を【現在地】から【キャラの自室】に運びました）
