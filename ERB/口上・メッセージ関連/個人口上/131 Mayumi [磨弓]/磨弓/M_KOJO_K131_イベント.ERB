@M_KOJO_EVENT_K131_20(ARG,ARG:1)
;口上主はLOCALS or RESULT
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;通常帰宅
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		IF CFLAG:うふふ
			;うふふ中に眠くて帰る
			PRINTFORML 「なっ！？もう、こんな時間か！」
			PRINTFORML 「%CALLNAME:MASTER%、続きは待たなっ！」
			PRINTFORMDW 磨弓は服を整えると、慌てて帰っていった…
		ELSEIF TALENT:恋人 || TALENT:恋慕
			PRINTFORML 「なあ、%CALLNAME:MASTER%…私と霊長園で…」
			PRINTFORML 「…何でもない！また、明日な…♪」
			PRINTFORMDW 磨弓は少し寂しそうに帰っていった。
		ELSE
			PRINTFORML 「%CALLNAME:MASTER%。今度は霊長園に遊びに来るといい」
			IF TALENT:132:恋慕 || TALENT:132:思慕
				PRINTFORML 「袿姫様も、きっとお喜びになるぞ♪」
			ELSE
				PRINTFORML 「その時は、私が案内してやるぞ♪」
			ENDIF
			PRINTFORMDW 磨弓と手を振って別れた。
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;デート中帰宅
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		IF CFLAG:うふふ
			PRINTFORML 「なっ！？もう、こんな時間か！」
			PRINTFORML 「%CALLNAME:MASTER%、続きは待たなっ！」
			PRINTFORMDW 磨弓は服を整えると、慌てて帰っていった…
		ELSEIF TALENT:恋人 || TALENT:恋慕
			PRINTFORML 「ありがとう%CALLNAME:MASTER%！今日は凄く楽しかったぞ♪」
			PRINTFORML 「次もまた、誘ってくれ！」
		ELSE
			PRINTFORML 「%CALLNAME:MASTER%、今日は楽しかったぞ。また誘ってくれ」
		ENDIF
			PRINTFORMDW 磨弓と手を振って別れた。
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;玄関先でお見送り（キャラの自宅位置、またはキャラの部屋でデート終了）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 3
		IF CFLAG:132:面識 == 1
			PRINTFORML 「%CALLNAME:MASTER%、袿姫様に会っていかないのか？」
		ELSE
			PRINTFORML 「待て%CALLNAME:MASTER%。袿姫様にご挨拶を…」
		ENDIF
		PRINTFORMDW また今度と言い、磨弓と別れた。
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;デート終了時に部屋に来ないかと誘う（～から部屋に来ないかと誘われた）
	;（来訪キャラのみ,自宅が無いキャラでも発生します）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 4
		IF TALENT:恋人
			PRINTFORML 「%CALLNAME:MASTER%、これから霊長園に来ないか？」
			PRINTFORML 「袿姫様も、お前なら大歓迎だと言っていたぞ♪」
			PRINTFORMDW 磨弓の誘いを受けようか…？
		ELSEIF TALENT:恋慕
			PRINTFORML 「な…なあ、%CALLNAME:MASTER%！」
			PRINTFORML 「一緒に霊長園に行かないか？」
			PRINTFORML 「…その…そうだ！その方が、袿姫様もお喜びになる筈だ…♪」
			PRINTFORMDW どうやら磨弓は、一緒に来てほしいようだ。
		ELSE
			PRINTFORML 「%CALLNAME:MASTER%、これから時間はあるか？」
			PRINTFORML 「袿姫様が、お前に会いたいと言っていたんだが…」
			PRINTFORMDW 磨弓の誘いを受けようか…？
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;部屋に来ないか→「行く」を選択（～に誘われるまま、【MASTER】は【TARGET】の部屋へと向かった……）
	;（これが発生すると十中八九押し倒されます）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 5
		IF TALENT:恋人
			CALL HPH_PRINT,@"「即答か…♪お前のそういう所が好きなんだ…HPH」","L"
		ELSEIF TALENT:恋慕
			PRINTFORML 「そ…そうか！よし…♪」
		ELSE
			PRINTFORML 「よし！そうと決まれば…」
		ENDIF
		PRINTFORMDL 磨弓が口笛を吹くと、何処からか馬型埴輪が現れた。
		PRINTFORML 「さあ乗れ！振り落とされないように、私にしっかり掴まっているんだぞ？」
		PRINTFORMDW 磨弓の馬型埴輪に乗せてもらい、霊長園へと向かった。
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;部屋に来ないか→「やめとく」を選択（～は心なしか寂しそうだ……）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 6
		IF TALENT:恋人
			PRINTFORML 「なんだと！？恋人よりも大事な用があるというのか！？」
		ELSEIF TALENT:恋慕
			PRINTFORML 「…そうか…」
		ELSE
			PRINTFORML 「ふむ…そうか…」
		ENDIF
		PRINTFORMDW 誘いを断られて、磨弓は寂しそうだ…
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;今夜は帰りたくないと言い出す（～は今夜は帰りたくないと言い出した…）
	;（来訪キャラの帰宅時に欲求不満と欲望が高いと発生）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 7
		IF TALENT:恋人 || TALENT:恋慕
			CALL HPH_PRINT,@"「%CALLNAME:MASTER%…今夜は、お前と一緒にいたいんだ…HPH」","L"
			PRINTFORML 「…駄目か…？」
			PRINTFORMDW 磨弓はまだ帰りたくないようだ…
		ELSE
			PRINTFORML 「磨弓が口笛を吹くと、何処からか馬型埴輪が現れた。」
			PRINTFORML 「今夜はお前の護衛に付こうと思うんだが、良いか？」
			PRINTFORMDW 磨弓はまだ帰るつもりはないようだ…
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;今夜は帰りたくない→「泊める」を選択（～は【MASTERの自室】に泊まっていくことになりました）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 8
		IF TALENT:恋人
			CALL HPH_PRINT,@"「ふ…♪お前ならそう言ってくれると思っていたぞ…HPH」","L"
			PRINTFORMDW 今夜は磨弓と過ごす事にした…！
		ELSEIF TALENT:恋慕
			CALL HPH_PRINT,@"「そ、そうか！…ありがとう…HPH」","L"
			PRINTFORMDW 今夜は磨弓と過ごす事にした…！
		ELSE
			PRINTFORML 「よし！そうと決まれば…埴輪兵！」
			PRINTFORML 「%CALLNAME:MASTER%、少し待っていてくれ。こいつらに指示を出したらすぐに行く」
			PRINTFORMDW 今夜は、磨弓や埴輪兵たちと過ごす事になりそうだ…
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;今夜は帰りたくない→「泊めない」を選択、または家主が居る（【MASTER】は丁重に断った）
	;（家主が居る＝MASTERの私室に他のキャラの私室を設定している）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 9
		IF TALENT:恋人
			PRINTFORML 「…私がいたら不味い事でもあるのか？」
			PRINTFORMDW 磨弓は疑いの視線を向けている…
		ELSEIF TALENT:恋慕
			PRINTFORML 「…そうか…」
			PRINTFORMDW 誘いを断られて、磨弓は寂しそうだ…
		ELSE
			PRINTFORML 「お、おい待て！何かあってからでは遅いんだぞ！？」
			PRINTFORMDW その後も磨弓が折れるまで、暫く押し問答が続いた…
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;疲れて帰宅（疲れきった～は帰って行きました）
	;（～は疲れ切っている→（入り口）まで送るよ でも発生）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 10
		IF CFLAG:うふふ
			;うふふ中に疲れて帰る
			PRINTFORML 「す、すまん%CALLNAME:MASTER%…これ以上は…！」
			PRINTFORMDW よほど疲れたのか、磨弓は埴輪兵に運ばれて帰っていった…
		ELSE
			PRINTFORML 「ま…不味い…この…ままでは…」
			PRINTFORML 「すまん%CALLNAME:MASTER%…！この埋め合わせは…必ず…！」
			PRINTFORMDW よほど疲れたのか、磨弓は埴輪兵に運ばれて帰っていった…
		ENDIF
		RETURN 1
	ENDIF
ENDIF
RETURN 1
