@M_KOJO_SPEVENT_K131_1(ARG,ARG:1)
;口上主はTARGET
;地の文表示
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	PRINTFORML 
	PRINTFORML 「なあ…%CALLNAME:MASTER%は、キス…？というものをした事はあるか？」
	PRINTFORMDL 帰り道を歩いていると、磨弓が急に話を振ってきた。
	PRINTFORML 「…いや、その…袿姫様に"キスはしたのか"と聞かれたんだが、どういうものかよく分からなくてな…」
	PRINTFORMDW キスが何かを知らないらしい磨弓に、%CALLNAME:MASTER%は説明する事にした。
	PRINTFORMW 「…唇を…こうか？…んっ」
	PRINTFORMDW 磨弓の唇が、ほんの一瞬だけ%CALLNAME:MASTER%と触れ合った…
	PRINTFORMW 「…"どきどき"？すまん、やはり私にはよく分からない…」
	PRINTFORMDL その後は、お互い会話する事無く帰宅した。
	PRINTFORMDW 向こうに着くまでの間、磨弓は何度も自分の唇を指で触っていた…
	;キスをキャンセルしたい場合は以下を開放
	;TCVAR:キスキャンセル = 1
ENDIF
RETURN 1


;==================================================
;デート帰りに告白（恋人が付く）
;==================================================
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;（任意）:通常の地の文を表示するかスキップするか決定する。
;RETURN 0;通常地の文と口上を表示
;RETURN 1;口上のみ表示
;RETURN 2;通常地の文のみ表示
;RETURN 3;どちらも表示しない
;==================================================
@M_KOJO_SPEVENT_MESSAGECHECK_K131_2
RETURN 1

@M_KOJO_SPEVENT_K131_2(ARG,ARG:1)
;口上主はTARGET
;地の文表示
;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;告白内容
	;この告白内容表示後に受けるかどうかの選択分が表示されます
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 0
		PRINTFORML 
		;袿姫様に恋人or恋慕あり
		IF TALENT:132:恋人 || TALENT:132:恋慕
			PRINTFORML （今日こそ言うんだ…！この想いを…断ち切る為に…！）
			PRINTFORML 「…%CALLNAME:MASTER%！」
			PRINTFORMDW 磨弓に呼び止められ、%CALLNAME:MASTER%は立ち止まって振り返る。
			PRINTFORML 「…その！…えっと、だな…」
			PRINTFORMDL どうやら言いたい事があるようだが、口ごもっている…
			PRINTFORMDW 急かすのは逆効果だと思い、%CALLNAME:MASTER%は彼女の次の言葉を静かに待った。
			PRINTFORML （今だけは、無礼をお許しください…袿姫様…！）
			PRINTFORML 「お…お…」
			PRINTFORMW 「―お前が好きなんだっ！！」
			PRINTFORML （ああ…言ってしまった…！もう、引き返せない…）
			PRINTFORML （頼む%CALLNAME:MASTER%…！断ってくれ！私を、拒絶してくれ…！）
			PRINTFORMDL 磨弓は、様々な想いがない交ぜとなった表情を%CALLNAME:MASTER%に向けている。
			PRINTFORMDW 彼女の告白に%CALLNAME:MASTER%は…
		ELSE
			PRINTFORML （…よしっ…！）
			PRINTFORML 「…%CALLNAME:MASTER%！」
			PRINTFORMDW 磨弓に呼び止められ、%CALLNAME:MASTER%は立ち止まって振り返る。
			PRINTFORML 「…その！…えっと、だな…」
			PRINTFORMDL どうやら言いたい事があるようだが、口ごもっている…
			PRINTFORMDW 急かすのは逆効果だと思い、%CALLNAME:MASTER%は彼女の次の言葉を静かに待った。
			PRINTFORML 「お…お…」
			PRINTFORMW 「―お前が好きなんだっ！！」
			PRINTFORMDL 磨弓の瞳が少し潤んでいる。
			PRINTFORMDL 戦う事しか知らなかった彼女にとって、他人への告白は初めてなのだろう…
			PRINTFORMDW 彼女の告白に%CALLNAME:MASTER%は…
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;告白オッケー（恋人が付く）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 1
		IF TALENT:132:恋人 || TALENT:132:恋慕
			PRINTFORML 「…っ！！」
			PRINTFORML 「…何故だ…？何故断ってくれない…！」
			IF TALENT:132:恋人
				PRINTFORMW 「私はっ…！己の主の想い人を寝取ろうと企てる、浅ましい女なんだぞ！？」
			ELSE
				PRINTFORMW 「お前には…！私以上に相応しい方が…っ…！」
			ENDIF
			PRINTFORMDL 磨弓は様々な想いが爆発し、錯乱し始めている。
			PRINTFORMDL 今の彼女にも分かるよう、言葉以上の返事が必要だ。
			PRINTFORMDW %CALLNAME:MASTER%は磨弓を少し強引に抱き寄せ、自らの唇を重ねた―
			PRINTFORMW 「んむっ…！？…んん…っ…！…うぅ…！」
			PRINTFORML （申し訳ございません…袿姫様…！）
			PRINTFORML （私は…！最低の女です…！）
			PRINTFORMDW 磨弓は涙を流しながらも、%CALLNAME:MASTER%から唇を離そうとはしなかった…
		ELSE
			PRINTFORML 「…%CALLNAME:MASTER%！」
			PRINTFORML 「ほ…本当か？本当に、良いのか…？」
			PRINTFORMW 「私は…戦う事しか能の無い、埴輪兵士なんだぞ…！？」
			PRINTFORMDL 現実に起こっている事が信じられないといった様子の磨弓。
			PRINTFORMDL 今の彼女にも分かるよう、言葉以上の返事が必要だ。
			PRINTFORMDW %CALLNAME:MASTER%は磨弓を少し強引に抱き寄せ、自らの唇を重ねた―
			CALL HPH_PRINT,@"「んむっ！？…んん…HPH」","W"
			PRINTFORMW （…ありがとう…！%CALLNAME:MASTER%…♪）
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;告白失敗
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 2
		IF TALENT:132:恋人 || TALENT:132:恋慕
			PRINTFORML 「…っ！！…そうか…そうだったな…」
			PRINTFORML （お前の心は、あの方に…）
			PRINTFORML 「…変な事を言ってすまなかった、%CALLNAME:MASTER%！」
			PRINTFORML 「私は安心したぞ！お前の袿姫様への愛は本物なのだと、確信できたんだからな！」
			PRINTFORML 「…っ…いいか%CALLNAME:MASTER%！」
			PRINTFORML 「袿姫様以外の女に浮気でもしたら、この私が許さないぞ！」
			PRINTFORMDW %CALLNAME:MASTER%が頷くと、磨弓はとても晴れやかな笑顔をみせてくれた。
		ELSE
			PRINTFORML 「…っ！！…そうか…」
			PRINTFORML 「…%CALLNAME:MASTER%！そんな顔をするな！お前は何も悪くないだろう？」
			PRINTFORML 「私はお前に選ばれなかった。ただ、それだけだ…♪」
			PRINTFORMDW 磨弓は%CALLNAME:MASTER%に、これまでと変わらない笑顔を作ってみせた。
		ENDIF
		;レイセン口上からお借りしました告白禁止フラグ
		SETBIT CFLAG:[[磨弓]]:デート後イベントフラグ , 1
		RETURN 1
	ENDIF
ENDIF
RETURN 1
