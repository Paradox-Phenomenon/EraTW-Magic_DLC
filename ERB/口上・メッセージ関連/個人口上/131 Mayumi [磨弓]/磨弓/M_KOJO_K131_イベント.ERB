			CALL HPH_PRINT,@"「んぶっHPH HPH…ごくっHPHごくっHPH」","L"
			CALL HPH_PRINT,@"「んっ…♪はぁ…HPH」","L"
			PRINTFORMDW 磨弓は口内に出現した精液を、動じる事無く飲み干した…！
