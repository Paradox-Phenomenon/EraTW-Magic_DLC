	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 5
		IF CFLAG:うふふ
			;うふふ中にダウン
			CALL HPH_PRINT,@"「はにゃあぁ～…HPH」","L"
			PRINTFORMDW 磨弓は目を回して気絶してしまった…
		ELSE
			PRINTFORML 「もう…これ以上は…」
			PRINTFORMDW 磨弓は気絶してしまった…
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;MASTERがダウン（恋慕のみ,そのまま一日が終了）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 6
		;お酒でダウン
		IF BASE:MASTER:酒気 >= MAXBASE:MASTER:酒気
			IF ARG:1
				;自室でダウン,（～が【MASTER】をベッド（布団）へと運んでくれた…）
				PRINTFORML 「ん…？%CALLNAME:MASTER%…？おい、大丈夫か！？」
				PRINTFORML 「…ふぅ…飲みすぎて酔いつぶれただけか…」
				PRINTFORML 「まったく、世話の焼ける奴だな…」
				PRINTFORML 「布団を敷いてやるから、今日はもう寝ろ」
				PRINTFORMDW 磨弓に寝床まで運んでもらった…
			ELSE
				;部屋まで運ばれる,（～が【MASTER】を私室へと運んでくれた…）
				PRINTFORML 「ん…？%CALLNAME:MASTER%…？おい、大丈夫か！？」
				PRINTFORML 「…ふぅ…飲みすぎて酔いつぶれただけか…」
				PRINTFORML 「埴輪兵！%CALLNAME:MASTER%を家まで運んでやれ！」
				PRINTFORML 「お、おい…もう少し優しくしてやってくれ…」
				PRINTFORMDW 埴輪兵に揺られたせいか、少し気分が悪くなった…
			ENDIF
		;体力切れでダウン
		ELSE
			IF ARG:1
				;自室でダウン,（～が【MASTER】をベッド（布団）へと運んでくれた…）
				PRINTFORML 「ん…？%CALLNAME:MASTER%…？おい、大丈夫か！？」
				PRINTFORML 「…少し熱があるな…疲れが溜まっているのか…？」
				PRINTFORML 「布団を敷いてやるから、今日はゆっくり休め」
				PRINTFORMDW 磨弓に寝床まで運んでもらった…
			ELSE
				;部屋まで運ばれる,（～が【MASTER】を私室へと運んでくれた…）
				PRINTFORML 「ん…？%CALLNAME:MASTER%…？おい、大丈夫か！？」
				PRINTFORML 「…少し熱があるな…疲れが溜まっているのか…？」
				PRINTFORML 「埴輪兵！%CALLNAME:MASTER%を家まで運んでやれ！」
				PRINTFORML 「こ、こら！もう少し優しくだな…！」
				PRINTFORMDW 埴輪兵に自宅まで運んでもらった…
			ENDIF
		ENDIF
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;TARGETが寝るために自室まで戻ってきた
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 7
		;-------------------------------------------------
		;そのまま着替えて寝た（【TARGET】が部屋に戻ってきた→寝間着へと着替え、寝床に潜った）
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1 && ARG:1 == 0
			PRINTFORML 「ん…？%CALLNAME:MASTER%か…」
			PRINTFORML 「お前も早く寝ないと、明日に差し支えるぞ…？」
			PRINTFORMDW 磨弓は%CALLNAME:MASTER%が自室に居ても、特に構うことなく眠ってしまった…
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;部屋から追い出して寝た（眠そうな【TARGET】に追い出された…）
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1 && ARG:1 == 1
			PRINTFORML 「…%CALLNAME:MASTER%。私の部屋で何をしている…？」
			PRINTFORML 「埴輪兵！%CALLNAME:MASTER%をつまみ出せ！」
			PRINTFORMDW 埴輪兵士に部屋から追い出されてしまった…
			RETURN 1
		ENDIF
		;-------------------------------------------------
		;他キャラとのＨを止めさせて寝た（【TARGET】が部屋に戻ってきた→唇をとがらせる【TARGET】に、【MASTER】は渋々【Ｈの相手】から離れた）
		;記入チェック（=0, 非表示、1, 表示）
		LOCAL:1 = 1
		;-------------------------------------------------
		IF LOCAL:1 && ARG:1 == 2
			IF ARG == 130;八千慧
				PRINTFORML 「%CALLNAME:MASTER%…！吉弔八千慧を連れ込んで何をしている…！？」
				PRINTFORML 「出ていけーっ！！」
				PRINTFORMDW 磨弓にに部屋から追い出されてしまった…
			ELSEIF ARG == 132;袿姫様
				PRINTFORML 「…け、袿姫様…誠に申し上げにくいのですが…」
				PRINTFORML 「そういう事は、自室でなされた方がよろしいかと…」
				PRINTFORMDW 磨弓に情事を見られ、気まずそうに部屋を出た…
			ELSEIF ARG == 133;早鬼
				PRINTFORML 「%CALLNAME:MASTER%…！驪駒早鬼を連れ込んで何をしている…！？」
				PRINTFORML 「出ていけーっ！！」
				PRINTFORMDW 磨弓にに部屋から追い出されてしまった…
			ELSEIF ARG == 143;尤魔
				PRINTFORML 「%CALLNAME:MASTER%…！饕餮尤魔を連れ込んで何をしている…！？」
				PRINTFORML 「出ていけーっ！！」
				PRINTFORMDW 磨弓にに部屋から追い出されてしまった…
			ELSE
				PRINTFORML 「%CALLNAME:MASTER%…！私の部屋に、女を連れ込んで何をしている…！？」
				PRINTFORML 「出ていけーっ！！」
				PRINTFORMDW 磨弓に部屋から追い出されてしまった…
			ENDIF
			RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;来訪キャラが拠点で休憩（～は疲れ切っている→ちょっと休んでいきなよ）
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARG == 8
		PRINTFORML 「いや…私は別に…」
		PRINTFORML 「お、おい！…分かった！分かったから押すな！」
		PRINTFORMDW 磨弓と一緒に、%CALLNAME:MASTER%の家へと向かった。
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;寝室に居る状態でその場で寝る（～は眠気に負け、眠りについた…）
	;記入チェック（=0, 非表示、1, 表示）
