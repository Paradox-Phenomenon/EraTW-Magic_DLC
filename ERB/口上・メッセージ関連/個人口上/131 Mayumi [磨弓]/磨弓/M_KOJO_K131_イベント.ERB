	;-------------------------------------------------
	IF LOCAL:1 && ARG == 4
	;壊れるまでしてあげる
		CALL HPH_PRINT,@"「な…！？こ、壊れるまでって…！？HPH」","L"
		CALL HPH_PRINT,@"（私は一体…どうなってしまうんだ…？HPH）","L"
		PRINTFORMDW 磨弓の目は、期待と情欲で燃え上がっている…！
	RETURN 1
	ENDIF
ENDIF
RETURN 1

