@M_KOJO_MESSAGE_COM_K131_300
;コマンド共通メッセージ(TRAIN_MESSAGE) 
;削除すると「～話をした。」とかが消えます。また、削除した場合は自動で口上色が付きません。
;口上メイン呼出
CALL M_KOJO_MESSAGE_COM_K131_300_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K131_300_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;初回会話
	IF FIRSTTIME(SELECTCOM)
		PRINTFORML 「…ん？埴輪兵士に興味があるのか？」
		PRINTFORMDL 磨弓の傍らに佇む埴輪兵士と目（？）が合った。
		PRINTFORMDL %CALLNAME:MASTER%の知る埴輪と同じく間の抜けた顔をしているが、近くで見ると妙な威圧感がある…
		PRINTFORML 「この埴輪兵士も、袿姫様の手によって造り出されたものだ」
		PRINTFORML 「兵長である私の指示通りに動く、とても優秀な兵士達だぞ！」
		PRINTFORMDL "達"と言うからには、まだ他にもいるのだろう。
		PRINTFORMDW どれだけの数がいるのかは分からないが、彼女に手を出すのは危険かもしれない…
	;怒り
	ELSEIF CFLAG:318 == 1
		PRINTFORML 「五月蝿い。静かにしろ」
		PRINTFORMDW 磨弓に話しかけたら怒られた……
	;喋りすぎ
	ELSEIF TCVAR:302
		IF TALENT:恋慕 || TALENT:思慕
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「…無理に話そうとしなくていいんだぞ？」
					PRINTFORMDW 話題が尽きてしまった……
				CASE 1
					PRINTFORML 「……？」
					PRINTFORML 「すまん。よく分からないから、埴輪で例えてくれないか？」
					PRINTFORMDW 磨弓は首を傾げている……
				CASE 2
					PRINTFORMDL "戦いは数だよ磨弓！"
					PRINTFORML 「あ、ああ…私もそう思うが…急にどうした？」
					PRINTFORMDW %CALLNAME:MASTER%の物真似は、磨弓には受けなかった……
			ENDSELECT
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「…ふぅ…」
					PRINTFORMDW 磨弓はつまらさそうに話を聞いている……
				CASE 1
					PRINTFORML 「…話は終わったのか？」
					PRINTFORMDW 会話が途切れてしまい、気まずい空気になった……
				CASE 2
					PRINTFORML （さっきから妙に絡んでくるな…やはり奴等の仲間なのか…？）
					PRINTFORMDW 磨弓は%CALLNAME:MASTER%を警戒している……
			ENDSELECT
		ENDIF
	;酔っ払い時会話　磨弓は酒に強い
	;ぐでぐで
	ELSEIF BASE:酒気 > (MAXBASE:酒気 / 10) * 8
		SELECTCASE RAND:5
			CASE 0
				PRINTFORMW 「%CALLNAME:MASTER%大丈夫か？少し飲みすぎだぞ……」
			CASE 1
				PRINTFORMW 「まだ飲むのか！？もう止めておいたほうが……」
			CASE 2
				PRINTFORMW 「ああ、分かった！分かったからそう絡むな！」
			CASE 3
				PRINTFORML 「ほら%CALLNAME:MASTER%。水だ」
				PRINTFORML 「それを飲んで、少し酔いを覚ませ」
				PRINTFORMDW 磨弓から水を受け取り、一気に飲み干した。
			CASE 4
				PRINTFORMW 「とてもじゃないが、今の%CALLNAME:MASTER%は袿姫様には見せられんな…」
		ENDSELECT
	;酔いどれ
	ELSEIF BASE:酒気 > (MAXBASE:酒気 / 10) * 5
		SELECTCASE RAND:5
			CASE 0
				PRINTFORML 「飲むのは構わないが、程々にしておくんだぞ？」
				PRINTFORMW 「"酒は飲んでも呑まれるな"というやつだ」
			CASE 1
				PRINTFORML 「私は酒には強いようでな。これくらいでは酔わないさ」
				PRINTFORML 「んくっ…ぷはぁーっ！美味い！」
				PRINTFORMDW 磨弓の飲むペースはとても早い…！
			CASE 2
				PRINTFORMW 「危ないから、酒瓶は振り回すなよ？」
			CASE 3
				PRINTFORMW 「おっ？%CALLNAME:MASTER%、いい飲みっぷりじゃないか！」
			CASE 4
				PRINTFORML 「んっ…はぁ…♪美味いな…♪」
				PRINTFORMDW 磨弓は%CALLNAME:MASTER%の酒を気に入ったのか、美味しそうに飲んでいる。
		ENDSELECT
	ELSEIF TALENT:恋人
		IF FLAG:デート相手 == 113
			SELECTCASE RAND:2
				CASE 0
					CALL MAYUMI_DATE
				CASE 1
					SELECTCASE RAND:4
						CASE 0
							CALL MAYUMI_KOIBITO
						CASE 1
							CALL MAYUMI_OTENKI
						CASE 2
							CALL MAYUMI_SEASON
						CASE 3
							CALL MAYUMI_FREETALK
