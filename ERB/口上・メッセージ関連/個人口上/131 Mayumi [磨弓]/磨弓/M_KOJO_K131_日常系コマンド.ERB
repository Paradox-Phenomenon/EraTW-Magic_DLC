;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;怒り
	IF CFLAG:318 == 1
		IF TALENT:恋慕 || TALENT:思慕
			PRINTFORML 「…止めろ。今はそんな気分じゃない」
			PRINTFORMDW 磨弓に腕を払われてしまった…
		ELSE
			PRINTFORML 「その腕…切り落とされたいのか？」
			PRINTFORMDW 磨弓は仕込み刀に手をかけた…
		ENDIF
	;お風呂
	ELSEIF BATHCHECK(CFLAG:MASTER:現在位置) && IN_HOME(CFLAG:MASTER:現在位置)
		SELECTCASE RAND:4
			CASE 0
				IF TALENT:恋人
					PRINTFORML 「%CALLNAME:MASTER%の背中は…以外とっ、大きいんだな…♪」
				ELSE
					PRINTFORML 「痛かったら、我慢せず言ってくれよ…？」
