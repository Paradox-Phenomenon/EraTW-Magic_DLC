			SELECTCASE RAND:3
				CASE 0
					;おーい！はに丸
					PRINTFORMDL "こうしてはに丸は、お供のひんべえと……"
					PRINTFORML 「%CALLNAME:MASTER%、%CHILDNAME:131:(TALENT:131:育児中)%は結構前から眠っていたぞ」
					PRINTFORML 「ふ…♪そんな顔をするな。とても上手だったぞ♪」
					CALL HPH_PRINT,@"「明日も頑張れよ？…父上HPH」","L"
					PRINTFORMDW %CHILDNAME:131:(TALENT:131:育児中)%に読み聞かせていた本を磨弓に渡し、%CALLNAME:MASTER%も目を閉じた……
				CASE 1
					PRINTFORML 「偶にはこうして、%CHILDNAME:131:(TALENT:131:育児中)%を挟んで寝るのも悪くないな…%CALLNAME:MASTER%？」
					PRINTFORML 「何だもう寝たのか…子供みたいな奴だ…♪」
					PRINTFORMW 「おやすみ…♪みんな、明日も元気な姿を見せてくれよ……」
				CASE 2
					PRINTFORML 「良かったな%CHILDNAME:131:(TALENT:131:育児中)%…今日は父上と母上が一緒だぞ…♪」
					PRINTFORMDL 「%CHILDNAME:131:(TALENT:131:育児中)%が左右に顔を向けると、父と母の顔が間近にあった。」
					PRINTFORMDW そのまま二人から頭を撫でられ、%CHILDNAME:131:(TALENT:131:育児中)%はくすぐったそうな笑みを浮かべながら目を閉じた……
			ENDSELECT
		ELSE
			IF TALENT:恋人
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「%CALLNAME:MASTER%、私の添い寝は必要無いのか？」
						PRINTFORMW 「…なんてな、おやすみ♪」 
					CASE 1
						PRINTFORML 「待て%CALLNAME:MASTER%。大事な事を忘れているぞ」
						CALL HPH_PRINT,@"「ちゅっHPH…おやすみ♪」","W"
					CASE 2
						PRINTFORML 「…%CALLNAME:MASTER%、眠れないのか？」
						PRINTFORML 「心配するな！私がいる限り、お前が寝込みを襲われる事など万が一にも有り得ん！」
						PRINTFORMDW 傍らに座る磨弓が気になって、寝付くまでに時間がかかった……
				ENDSELECT
			ELSEIF TALENT:恋慕
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 「何だ%CALLNAME:MASTER%？…そ、添い寝！？」
						PRINTFORML 「莫迦なこと言ってないで、早く寝てしまえー！」
						PRINTFORMDW 磨弓に怒られてしまった……
					CASE 1
						PRINTFORML 「…%CALLNAME:MASTER%？…寝てしまったのか…？」
						CALL HPH_PRINT,@"「……ちゅっHPH…おやすみ…♪」","W"
				ENDSELECT
			ELSE
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 「ああ…おやすみ」
						PRINTFORML 「私も、もう少ししたら休む事にするよ」
						PRINTFORMDW 磨弓に就寝の挨拶をし、目を閉じた……
					CASE 1
						PRINTFORMW 「おやすみ。ゆっくり休むんだぞ」
				ENDSELECT
			ENDIF
		ENDIF
	ELSE
		IF TALENT:恋人 || TALENT:恋慕
			SELECTCASE RAND:5
				CASE 0
					PRINTFORML 「すまないな%CALLNAME:MASTER%…今日は添い寝をしてやれないんだ」
					PRINTFORML 「代わりに埴輪兵士を置いていくから、私だと思って一緒に寝てくれ」
					PRINTFORMDW 流石に無理がある……
				CASE 1
					PRINTFORML 「おやすみ、%CALLNAME:MASTER%」
					CALL HPH_PRINT,@"「ちゅっHPH…夜更かしするんじゃないぞ？」","L"
					PRINTFORMDW 頬に磨弓からのキスを貰い、眠りについた…
				CASE 2
					PRINTFORMW 「おやすみ%CALLNAME:MASTER%！また明日も会いに来るからな…♪」
				CASE 3
					PRINTFORML 「%CALLNAME:MASTER%。気休め程度だが、埴輪兵士を置いていくぞ」
					PRINTFORML 「これで寝込みを襲われても大丈夫だ！安心して休んでくれ」
					PRINTFORMDW 磨弓なりに心配してくれているのだと自分に言い聞かせ、埴輪兵に見守られながら目を閉じた……
				CASE 4
					PRINTFORML 「%CALLNAME:MASTER%、もう寝るのか？…おやすみ」
					PRINTFORML 「名残惜しいが、私もそろそろ帰るとするか…」
					PRINTFORMDW 磨弓は少し寂しそうに帰っていった…
			ENDSELECT
		ELSEIF TALENT:思慕
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「%CALLNAME:MASTER%の奴…布団がはだけているじゃないか」
					PRINTFORMW 「ふぅ、これでよし！風邪を引いたら大変だからな…おやすみ…♪」
				CASE 1
					PRINTFORML 「おやすみ%CALLNAME:MASTER%」
					PRINTFORML 「念の為、護衛に埴輪兵士を付けておこうか？」
					PRINTFORMDW 心配しすぎだろう…
				CASE 2
					PRINTFORMW 「眠れない時は、埴輪を数えると良いらしいぞ？…おやすみ」
			ENDSELECT
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「ああ、おやすみ。ゆっくり休め」
				CASE 1
					PRINTFORML 「そうか…お前は寝る必要があるんだったな。おやすみ、%CALLNAME:MASTER%」
				CASE 2
					PRINTFORML 「それじゃあな%CALLNAME:MASTER%。おやすみ」
			ENDSELECT
			PRINTFORMDW 磨弓に就寝の挨拶をし、眠りについた…
		ENDIF
	ENDIF
ENDIF
RETURN 1
