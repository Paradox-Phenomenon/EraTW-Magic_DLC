					CASE 1
						CALL HPH_PRINT,@"「やはり…まぐわうなら、こっちだな…HPH」","W"
				ENDSELECT
			ENDIF
		;だいしゅきホールド
		CASE 86
			SELECTCASE RAND:2
				CASE 0
					CALL HPH_PRINT,@"「あ…HPHふふ…♪もうっHPH限界、か…？HPH」","L"
					CALL HPH_PRINT,@"「なら…お前の精液っHPH私のなかにHPH全部、吐き出せぇっHPH HPH」","L"
				CASE 1
					CALL HPH_PRINT,@"「射精すのなら、私の中だ…HPH」","L"
					CALL HPH_PRINT,@"「外に射精すなんて、許さんからな…っHPH」","L"
			ENDSELECT
			PRINTFORMDW 磨弓は足を絡め、%CALLNAME:MASTER%にしがみついてきた…！
		;87=Ａ挿入する
		CASE 87
			IF TCVAR:Ａ破瓜
				CALL MAYUMI_SEX
			ELSE
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「助平のお前には、こっちの穴がふさわしいな…HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「尻で致そうとしているのに、なにを興奮しているんだお前は…HPH」","W"
				ENDSELECT
			ENDIF
		;88=腰振りＶ 89=腰振りＡ
		CASE 88, 89
			SELECTCASE RAND:3
				CASE 0
					CALL HPH_PRINT,@"「あぁっHPHあぁHPH気持ちいいっHPH気持ちいいのHPHもっと欲しいっHPH HPH」","L"
				CASE 1
					CALL HPH_PRINT,@"「くぅっHPHんっHPHふぅっHPHあっHPHひっHPHあぁっHPH」","L"
				CASE 2
					CALL HPH_PRINT,@"「あぁHPHあっHPHあんっHPHあっHPH%CALLNAME:MASTER%っHPH%CALLNAME:MASTER%っHPH HPH」","L"
			ENDSELECT
			PRINTFORMDW 磨弓は嬌声を上げながら、夢中で腰を振っている…！
		CASEELSE
			SELECTCASE RAND:3
				CASE 0
					CALL HPH_PRINT,@"「いいか？赤子みたいに、乳を吸うんだ…HPH」","W"
				CASE 1
					CALL HPH_PRINT,@"「%CALLNAME:MASTER%…HPH今の間は、私がお前の母親だ…HPH」","W"
				CASE 2
					CALL HPH_PRINT,@"「…吸うか？HPH」","L"
					PRINTFORMDW 磨弓の乳首が唇まで近付けられた…！
			ENDSELECT
	ENDSELECT
ENDIF
