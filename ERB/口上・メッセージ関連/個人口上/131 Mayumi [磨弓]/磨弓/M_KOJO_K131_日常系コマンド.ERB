@M_KOJO_MESSAGE_COM_K131_368_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	SELECTCASE Activity_Type:TARGET
		CASE 0
			;▼考え事［なに考えてるの］
			;TFLAG:193,-1=はぐらかされる
			IF TFLAG:193 == -1
				PRINTFORML 「霊長界の警備の事だ」
				PRINTFORMW 「もっと強化しないと、異変の時の様にまた突破されるかもしれん……」
			ELSE
				SELECTCASE RAND:6
				CASE 0
					PRINTFORML 「霊長界の警備の事だ」
					PRINTFORMW 「もっと強化しないと、異変の時の様にまた突破されるかもしれん……」
				CASE 1
					PRINTFORML 「袿姫様の事だ」
					PRINTFORMW 「あの方は今、素晴らしい作品を造られているに違いない…♪」
				CASE 2
					PRINTFORML 「ああ、里で新しく出たらしい甘味…」
					PRINTFORML 「―の事など考えていない！！」
					PRINTFORMDW 磨弓は急に声を荒らげた……
				CASE 3
					PRINTFORML 「畜生界の頭目共の事だ…」
					PRINTFORMW 「早急に手を打たねば、また袿姫様が危険な目に…」
				CASE 4
					PRINTFORML 「我々、埴輪兵団の強化についてだ」
					PRINTFORML 「袿姫様の手を借りずに、強くなる方法は無いだろうか？」
					PRINTFORMDW 磨弓の相談に乗って、色々なアイデアを出し合った。
				CASE 5
					PRINTFORML 「……そうだな。こういう事は、本人に聞いた方が早い」
					PRINTFORML 「%CALLNAME:MASTER%。お前%TEXTR("は何が好きな/の趣味はな/は普段、何をしてる/の欲しい物はな")%んだ？」
					PRINTFORMDW 磨弓の色々な質問に答えた。
				ENDSELECT
			ENDIF
		CASE 1
			;▼遊ぶ［一緒に遊ぶ］
			;※[幼稚]持ちのみ
			;TFLAG:193,1=大いに盛り上がる,-1=あまり盛り上がらない
			;PRINTFORMW 
		CASE 2
			;▼食事［一緒に食事する］
			;TFLAG:193,-1=MASTERはお腹が空いてなかった
			IF TFLAG:193 == -1
				PRINTFORMW 「何だ、腹が空いてないのか」
			ELSE
				SELECTCASE RAND:3
					CASE 0
						PRINTFORMW 「仕方ないな…少しだけだぞ？」
					CASE 1
						PRINTFORMW 「%CALLNAME:MASTER%、美味いか？」
					CASE 2
						PRINTFORMW 「…"あーん"？そんな恥ずかしい事出来るか！」
				ENDSELECT
			ENDIF
		CASE 3
			;▼つまみ食い［一緒につまみ食い］
			;※[妖精]持ちとルーミア、こいし、幽々子、紫苑のみ
			;TFLAG:193,-1=MASTERはお腹が空いてなかった
			;PRINTFORMW 
		CASE 4
			;▼掃除［掃除を手伝う］
			;※[掃除係]持ちまたは汚臭耐性-1以下のみ
			SELECTCASE RAND:5
				CASE 0
					PRINTFORML 「ほら%CALLNAME:MASTER%。今度はこっちだ」
				CASE 1
					PRINTFORML 「全く…誰なんだ？こんなに散らかしたのは…」
				CASE 2
					PRINTFORML 「手伝ってもらって悪いな、%CALLNAME:MASTER%」
				CASE 3
					PRINTFORML 「%CALLNAME:MASTER%、手が止まっているぞ」
				CASE 4
					PRINTFORML 「おっと、こんな所にもゴミがあったか…」
			ENDSELECT
			PRINTFORMDW 磨弓と一緒に掃除した。
		CASE 5
			;▼運動［一緒に運動する］
			;※[音楽知識]持ちは除く（演奏になる）
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「いち、にっ、さん、しっ…」
				CASE 1
					PRINTFORML 「%CALLNAME:MASTER%頑張れ！あと十回だ！」
				CASE 2
					PRINTFORML 「ふう…♪身体を動かすと気持ちがいいな！」
			ENDSELECT
			PRINTFORMDW 磨弓と一緒に運動した。
		CASE 6
			;▼読書［本の感想を聞く］
			;TFLAG:193,-1=集中していて返事してくれない
			IF TFLAG:193 == -1
				PRINTFORML 「%TEXTR("ああ/そうだな/そうか")%……」
				PRINTFORMDW 磨弓は読書に集中しているようだ……
			ELSE
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「私も、もう少し教養を身に付けんとな…」
						PRINTFORMDW 磨弓は何やら難しそうな本を読んでいる。
					CASE 1
						PRINTFORML 「後で%CALLNAME:MASTER%も読んでみるか？」
						PRINTFORMDW 磨弓と本を交換しながら読書をした。
					CASE 2
						PRINTFORMW 「たまには読書も良いものだな…♪」
				ENDSELECT
			ENDIF
		CASE 7
			;▼料理［料理を手伝う］→［料理を分けてもらう］
			;TFLAG:193,2=料理を手伝う,0=作った料理を食べる,-1==MASTERはお腹が空いてなかった（食べる時）
			IF TFLAG:193 == 2
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「袿姫様に喜んでもらう為に、少しでも料理の練習しておかねば…！」
					CASE 1
						PRINTFORML 「包丁を使う時は…猫の手…猫の手…！」
					CASE 2
						PRINTFORML 「塩はどっちだ…？」
				ENDSELECT
				PRINTFORMDW 見かねた%CALLNAME:MASTER%は、磨弓の料理を手伝う事にした。
			ELSEIF TFLAG:193 == 0
				SELECTCASE RAND:2
					CASE 0
						PRINTFORML 「%CALLNAME:MASTER%、味見をしてくれ」
					CASE 1
						PRINTFORML 「ど…どうだ？美味いか？」
					ENDSELECT
					PRINTFORMDW 磨弓の作った料理を食べた。
			ELSEIF TFLAG:193 == -1;腹いっぱい
				PRINTFORMW 「何だ、腹が減っていないのか…」
			ENDIF
		CASE 8
			;▼演奏［セッションする］or［伴奏する］
			;※[音楽知識]持ちのみ（TALENT:音楽知識で変化）
			;TALENT:音楽知識,1=演奏してる,2=歌ってる,3=踊ってる
			;TFLAG:193,1=ノリノリ,0=成功,-1=失敗,-2=楽器がなくて見てるだけ
			;PRINTFORMW 
		CASE 9
			;▼採集［採集を手伝う］
		CASE 10
			;▼釣り［一緒に釣りをする］
			;TFLAG:193,-1=釣り竿がなくて見てるだけ
			;PRINTFORMW 
		CASE 11
			;▼実験［実験を手伝う］
			
		CASE 12
			;▼のんびり［一緒にのんびりする］
			;自発的に休むので、磨弓もリラックスしている
			SELECTCASE RAND:5
				CASE 0
					PRINTFORML 「見るのは別に構わないが、迂闊に触ると怪我をするぞ」
					PRINTFORMDW 磨弓は自分の武器を鋭く研ぎ澄ませている。
				CASE 1
					PRINTFORML 「……悪いが、話しかけないでくれ。集中したいんだ」
					PRINTFORML 「……%TEXTR("この辺りをもう少し/ここを、こうして/うーん…次は、と")%……」
					PRINTFORMDW 磨弓は熱心に何かを作っているようだ。
				CASE 2
					PRINTFORML 「…出来た！見ろ%CALLNAME:MASTER%！」
					PRINTFORML 「私が作った、袿姫様の埴輪だ！」
					PRINTFORML 「本物には遠く及ばないが、中々の出来だろう？」
					PRINTFORMDW 辛うじて人の形をしている不気味な埴輪を、磨弓は嬉しそうに見せてきた……
				CASE 3
					PRINTFORML 「…？%CALLNAME:MASTER%、何だその顔は」
					PRINTFORML 「人間の休息という物は、こうして横になる事なのだろう？」
					PRINTFORMDW 磨弓は、真顔で床に横たわっている……
				CASE 4
					PRINTFORML 「…埴輪と同じ顔を？……わ、笑うなよ？」
					PRINTFORML 「…………。」
					PRINTFORML 「…も、もういいだろう！」
					PRINTFORMDW 是非とも写真に収めたくなるような表情だった。
			ENDSELECT
		CASE 13
			;▼晩酌［晩酌に付き合う］
			;※酒耐性0以上のみ
			SELECTCASE RAND:3
				CASE 0
					PRINTFORMW 「あぁ…美味い…♪」
				CASE 1
					PRINTFORML 「お…%CALLNAME:MASTER%、中々いける口じゃないか！」
				CASE 2
					PRINTFORMW 「ふ…♪乾杯！」
			ENDSELECT
		CASE 14
			;▼買い物［買い物を手伝う］
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「助かるよ、%CALLNAME:MASTER%」
					PRINTFORML 「ここの卵は安いが、お一人様一つまでだからな」
					PRINTFORMDW 磨弓の買い物を手伝った。
				CASE 1
					PRINTFORML 「…無理して持たなくても、埴輪兵がいるから平気だぞ？」
					PRINTFORMDW 両手に大きく膨れた買い物袋を持って、磨弓の後を追った。
				CASE 2
					PRINTFORMW 「%CALLNAME:MASTER%も何か買うのか？」
			ENDSELECT
		CASE 15
			;▼説教［様子をうかがう］
			;※神霊・蓬莱人は除く
			;TFLAG:193,-1
			;PRINTFORMW 
		CASE 16
			;▼落とし穴［いたずらに付き合う］or［様子をうかがう］
			;※三月精・チルノ・クラウンピースのみ
			;それ以外は落ちる側
			;PRINTFORMW 
		CASE 17
			;▼雪だるま作り［一緒に雪作り］
			;※冬の月のみ
