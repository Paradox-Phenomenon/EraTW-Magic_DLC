@M_KOJO_MESSAGE_COM_K131_301_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF FIRSTTIME(SELECTCOM)
		PRINTFORML 「お茶か。いただこう」
		PRINTFORML 「…念の為に言っておくが、私に毒の類は通用しないぞ？」
		PRINTFORMDW 磨弓はそう言ってから、%CALLNAME:MASTER%の淹れたお茶を飲んだ……
	ELSEIF CFLAG:318 == 1
		PRINTFORML 「悪いが、今は要らん…」
		PRINTFORMDW 磨弓はお茶を飲む気分ではないようだ……
	ELSEIF TFLAG:193 == 1
		SELECTCASE RAND:5
			CASE 0
				PRINTFORML 「…んー…これは…」
				PRINTFORMDW 口に合わなかったのか、磨弓は顔をしかめている……
			CASE 1
				PRINTFORML 「%CALLNAME:MASTER%、お茶が冷めてしまっているぞ」
				PRINTFORML 「お前らしくもないな、何か悩み事か？」
				PRINTFORMDW 磨弓が心配そうな表情を向けてきた……
			CASE 2
				PRINTFORML 「…このお茶、間違っても袿姫様に出すんじゃないぞ？」
				PRINTFORMDW 磨弓にとって、今回のお茶はあまり美味しくなかったようだ……
			CASE 3
				PRINTFORML 「…うぅ…！」
				PRINTFORML （正直これは…しかし、せっかく淹れて貰った物を無下には出来んしなぁ……）
				PRINTFORMDW 磨弓はお茶をちびちびと飲んでいる。美味しくなかったのかもしれない……
			CASE 4
				PRINTFORML 「うおっ！？大丈夫か！？」
				PRINTFORML 「ああ、私は平気だが…お前意外とそそっかしいんだな…」
				PRINTFORMDL うっかりお茶をこぼしてしまい、磨弓の手にかかってしまった。
				PRINTFORMDW 結構な温度だったはずだが、磨弓は平然としている……
		ENDSELECT
	ELSEIF TFLAG:193 == 0
		SELECTCASE RAND:5
			CASE 0
				PRINTFORML 「ああ、ありがとう。頂くよ」
				PRINTFORMW 「…うん。美味いな…♪」
			CASE 1
				PRINTFORML 「ずず……はぁ…美味い…♪」
				PRINTFORMDL かなり熱く淹れてしまったお茶を、磨弓は美味しそうに飲んでいる。
				PRINTFORMDW 埴輪だけあって、熱には強いのかもしれない……
			CASE 2
				PRINTFORML 「ふぅ……ご馳走様。美味い茶だったぞ」
				PRINTFORMDW 磨弓は%CALLNAME:MASTER%から手渡されたお茶を受け取り、一気に飲み干した。
			CASE 3
				PRINTFORML 「ありがとう。%CALLNAME:MASTER%も一緒に飲むか？」
				PRINTFORMDW 磨弓の物と同じお茶を淹れ、一息ついた。
			CASE 4
				PRINTFORML 「むう……」
				PRINTFORML （また%CALLNAME:MASTER%が茶を淹れる瞬間を見逃してしまった……）
				PRINTFORMDW 磨弓は難しい顔でお茶を飲んでいる……
		ENDSELECT
	ELSE
		SELECTCASE RAND:5
			CASE 0
				PRINTFORML 「見ろ%CALLNAME:MASTER%！茶柱が埴輪の形をしてるぞ！」
				PRINTFORML 「…ははっ♪なんてな！冗談だ…♪」
				PRINTFORMDW 珍しく磨弓にからかわれた。よほど機嫌がいいらしい…
			CASE 1
				PRINTFORML 「美味い…♪」
				PRINTFORML 「…私がこれくらい美味い茶を淹れられれば、袿姫様に喜んでもらえるだろうか…？」
				PRINTFORMDW 今度、磨弓にお茶の淹れ方を教えるのも良いかもしれない。
			CASE 2
				PRINTFORML 「おお、お茶か！ありがとう！」
				PRINTFORMW 「%CALLNAME:MASTER%は本当に気が利くな…♪」
			CASE 3
				PRINTFORML 「美味いっ！」
				PRINTFORML 「%CALLNAME:MASTER%、おかわりを貰えるか？」
				PRINTFORMDW 磨弓の物と同じお茶を淹れ、一息ついた。
			CASE 4
				PRINTFORML 「おお…！湯呑みが埴輪の形になっている…♪」
				PRINTFORMDW 偶然見つけた物だったが、磨弓は大層気に入ってくれたようだ。
		ENDSELECT
	ENDIF
ENDIF
RETURN 1
