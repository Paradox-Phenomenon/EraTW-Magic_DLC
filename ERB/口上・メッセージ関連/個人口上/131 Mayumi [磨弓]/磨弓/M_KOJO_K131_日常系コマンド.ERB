							PRINTFORML 「当然、協力は惜しまないよな？」
							PRINTFORMDW モデルにされるだけで済めばいいが…
						ENDIF
					ELSE
						PRINTFORML 「%CALLNAME:MASTER%。袿姫様が、お前と一度会ってみたいと仰っていた」
						PRINTFORML 「後で一緒に挨拶に行くか？」
						PRINTFORMDW 気が向いたら行くとしよう…
					ENDIF
			ENDSELECT
		ENDIF
	ELSEIF TALENT:恋慕
		IF FLAG:デート相手 == 113
			SELECTCASE RAND:2
				CASE 0
					CALL MAYUMI_DATE
				CASE 1
					SELECTCASE RAND:4
						CASE 0
							CALL MAYUMI_RENBO
						CASE 1
							CALL MAYUMI_OTENKI
						CASE 2
							CALL MAYUMI_SEASON
						CASE 3
							CALL MAYUMI_FREETALK
					ENDSELECT
			ENDSELECT
		ELSE
			SELECTCASE RAND:5
				CASE 0
					CALL MAYUMI_FREETALK
				CASE 1
					CALL MAYUMI_RENBO
				CASE 2
					CALL MAYUMI_SEASON
				CASE 3
					CALL MAYUMI_OTENKI
				CASE 4
					;袿姫と遭遇済
					IF CFLAG:132:面識 == 1
						IF TALENT:132:恋人 || TALENT:132:恋慕
							PRINTFORML 「…%CALLNAME:MASTER%。お前と袿姫様は…」
							PRINTFORML 「…口が滑った。聞かなかった事にしてくれ…」
							PRINTFORMDW 磨弓は何だか元気が無いようだ…
						ELSE
							PRINTFORML 「%CALLNAME:MASTER%！袿姫様が今度、お前を元にした埴輪を作りたいそうだ！」
							PRINTFORML 「当然、協力は惜しまないよな？」
							PRINTFORMDW モデルにされるだけで済めばいいが…
						ENDIF
					ELSE
						PRINTFORML 「%CALLNAME:MASTER%。袿姫様が、お前と一度会ってみたいと仰っていた」
						PRINTFORML 「後で一緒に挨拶に行くか？」
						PRINTFORMDW 気が向いたら行くとしよう…
					ENDIF
			ENDSELECT
		ENDIF
	ELSEIF TALENT:思慕
		IF FLAG:デート相手 == 113
			SELECTCASE RAND:2
				CASE 0
					CALL MAYUMI_DATE
				CASE 1
					SELECTCASE RAND:4
						CASE 0
							CALL MAYUMI_SHIBO
						CASE 1
							CALL MAYUMI_OTENKI
						CASE 2
							CALL MAYUMI_SEASON
						CASE 3
							CALL MAYUMI_FREETALK
					ENDSELECT
			ENDSELECT
		ELSE
			SELECTCASE RAND:5
				CASE 0
					CALL MAYUMI_FREETALK
				CASE 1
					CALL MAYUMI_SHIBO
				CASE 2
					CALL MAYUMI_SEASON
				CASE 3
					CALL MAYUMI_OTENKI
				CASE 4
					;袿姫と遭遇済
					IF CFLAG:132:面識 == 1
						PRINTFORML 「%CALLNAME:MASTER%！袿姫様が今度、お前を元にした埴輪を作りたいそうだ！」
						PRINTFORML 「当然、協力は惜しまないよな？」
						PRINTFORMDW モデルにされるだけで済めばいいが…
					ELSE
						PRINTFORML 「%CALLNAME:MASTER%。袿姫様が、お前と一度会ってみたいと仰っていた」
						PRINTFORML 「後で一緒に挨拶に行くか？」
						PRINTFORMDW 気が向いたら行くとしよう…
					ENDIF
			ENDSELECT
		ENDIF
	ELSE
		IF FLAG:デート相手 == 113
			SELECTCASE RAND:2
				CASE 0
					CALL MAYUMI_NORMAL
				CASE 1
