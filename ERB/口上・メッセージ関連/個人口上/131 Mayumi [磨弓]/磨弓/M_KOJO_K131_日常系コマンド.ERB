@M_KOJO_MESSAGE_COM_K131_410_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF CFLAG:睡眠
		PRINTFORMDW 磨弓を起こさないように、静かに掃除をした。
	ELSEIF FLAG:時間停止
		PRINTFORMDW 静止した時間の中で掃除をした。能力の有効活用というやつだ。
	ELSEIF CFLAG:131:うふふ
		PRINTFORMW 「…気持ちは分らんでもないが、後でもいいんじゃないか？」
	;一緒に掃除
	ELSEIF TFLAG:193 == 1
		;ブチギレ
		IF CFLAG:318 == 1
			PRINTFORML 「どけ、邪魔だ」
			PRINTFORMDW 機嫌の悪い磨弓と一緒に掃除をした……
		ELSE
			;汚れ高
			IF TFLAG:194 >= 3
				SELECTCASE RAND:6
					CASE 0
						PRINTFORML 「ふぅ…この辺りで一度切り上げるか」
						PRINTFORMDW 磨弓が手伝ってくれたお陰か、ゴミは粗方片付いた。
					CASE 1
						PRINTFORML 「全く…これではキリがないな」
						PRINTFORMDW 埴輪兵たちも手伝ってくれているが、まだまだゴミは残っている……
					CASE 2
						PRINTFORML 「まだゴミは残っているが、少し休憩にしよう」
						PRINTFORML 「少し休んだら、また再開だ」
						PRINTFORMDW 一旦掃除を切り上げ、磨弓と休憩した。
					CASE 3
						PRINTFORML 「…思えば、創作が煮詰まっている時の袿姫様の部屋もこんな風に…」
						PRINTFORML 「―あっ！？い、今のは忘れろ！いいな！？」
						PRINTFORMDW 磨弓が凄い剣幕で迫ってきた……
					CASE 4
						PRINTFORML （む…？あいつ動きがおかしいな…ゴミでも詰まったか？）
						PRINTFORML 「あの埴輪兵を見てくる。ここは任せるぞ」
						PRINTFORMDW 磨弓は、動きがギクシャクしている埴輪兵へと駆け寄った……
					CASE 5
						PRINTFORML 「燃えるゴミはこっちだ！燃えないゴミは向こうへ固めておけ！」
						PRINTFORML 「…%CALLNAME:MASTER%！お前も見てないで手伝わんか！」
						PRINTFORMDW 磨弓は掃除をしつつ、埴輪兵たちにテキパキと指示を出している。
				ENDSELECT
			;汚れ中以下
			ELSE
				SELECTCASE RAND:6
					CASE 0
						PRINTFORML 「なまじ綺麗な分、余計にゴミが目立ってしまうな」
						PRINTFORMDW ぽつぽつと落ちているゴミを、磨弓と拾い集めた。
					CASE 1
						PRINTFORML 「どうだ？我々にかかればこんなものだ！」
						PRINTFORMDW 武器を掃除用具に持ち替えた埴輪兵団により、ゴミはあっという間に片付いた。
					CASE 2
						PRINTFORML 「%CALLNAME:MASTER%。高いところを掃除したいなら、埴輪兵に肩車してもらうといいぞ」
						PRINTFORMDW 埴輪兵がしゃがんでスタンバイしているが、遠慮しておいた……
					CASE 3
						PRINTFORML 「%CALLNAME:MASTER%、なんだそのチリトリの構え方は！」
						PRINTFORML 「もっと腰を入れて踏ん張れ！そんな事ではゴミを取りこぼすぞ！」
						PRINTFORMDW 磨弓にチリトリの使い方を厳しく叩き込まれた……
					CASE 4
						PRINTFORML 「ふぅ…♪綺麗になると、気持ちがいいな！」
						PRINTFORMDW 辺りはすっかり綺麗になり、磨弓は満足そうだ。
					CASE 5
						PRINTFORML 「待て！%TEXTR("雑誌は燃えるゴミじゃないぞ/それは燃えないゴミだ！")%」
						PRINTFORML 「面倒だからといって、横着してはならん！」
						PRINTFORMDW 磨弓に叱られ、渋々ゴミを分別した……
				ENDSELECT
			ENDIF
		ENDIF
	;見てるだけ
	ELSE
		IF CFLAG:318 == 1
			PRINTFORML 「…………。」
			PRINTFORMDW 磨弓は武器の手入れをしている。掃除を手伝う気は無いようだ……
		ELSE
			;汚れ高
			IF TFLAG:194 >= 3
				PRINTFORML 「…流石にこの量のゴミを前にして、何もするなと言われてもなぁ……」
			;汚れ中以下
			ELSE
				PRINTFORML 「%CALLNAME:MASTER%…心配しなくても、私は別に休まなくても平気だぞ？」
			ENDIF
		ENDIF
		PRINTFORML 「やっぱり私も手伝う―」
		PRINTFORML 「な…！？おい！何故お前達まで止めようとするんだ！？」
		PRINTFORMDW 掃除を手伝おうとする磨弓の前に、埴輪兵たちが立ちはだかった。
	ENDIF
ENDIF
RETURN 1
