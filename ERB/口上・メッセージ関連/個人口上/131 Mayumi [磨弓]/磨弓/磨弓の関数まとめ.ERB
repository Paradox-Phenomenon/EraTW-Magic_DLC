			CALL HPH_PRINT,@"「ちゅぷHPHじゅるHPHぢゅHPHちゅぱっHPHど、どうした？何故口を離す！」","L"
			PRINTFORMDW 磨弓の激しいキスで、危うく酸欠になる所だった…
		CASE 5
			CALL HPH_PRINT,@"「んっHPHちゅる…HPHちゅHPHはむHPHぢゅHPHちゅっHPHれるぉっHPH HPH」","L"
			PRINTFORMDW 磨弓は積極的に舌を絡め、ディープキスをしてきた…！
	ENDSELECT
;それ以外
ELSE
	SELECTCASE RAND:3
		CASE 0
			CALL HPH_PRINT,@"「ん…！ん…ちゅ…HPH」","L"
			PRINTFORMDW 磨弓は少し緊張しているようだ。
		CASE 1
			CALL HPH_PRINT,@"「んんっHPHちゅ…HPHんん…HPH」","L"
			PRINTFORMDW 磨弓は体を強ばらせながらも、キスを受け入れている。
		CASE 2
			CALL HPH_PRINT,@"「ちゅ…HPHん……」","L"
			PRINTFORMW 「やはり…接吻は、少し恥ずかしい…」
	ENDSELECT
ENDIF


