;-------------------------------------------
;刻印取得
;-------------------------------------------
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_MESSAGE_MARKCNG_MESSAGECHECK_K131
RETURN 0

@M_KOJO_MESSAGE_MARKCNG_K131
;苦痛刻印
;
IF !FLAG:70 && !CFLAG:MASTER:イタズラ
	IF TFLAG:苦痛刻印取得 == 1
		PRINTFORML 「痛っ…！おい！何をするんだ！？」
		PRINTFORMDL 少し強く叩き過ぎた気がしたが、磨弓の反応はそれ程ではない。
		PRINTFORMDW 戦闘を前提に造られた埴輪兵士は、痛みに強いという事なのだろうか…？
	ELSEIF TFLAG:苦痛刻印取得 == 2
		PRINTFORML 「うぐぅっ！！」
		IF TALENT:恋慕 || TALENT:思慕
			PRINTFORML 「…%CALLNAME:MASTER%…！何…を…？」
		ELSE
			PRINTFORML 「き…貴様ぁ…っ…！」
		ENDIF
		PRINTFORMDW 突然殴られた為か、磨弓は殺意を込めた目で%CALLNAME:MASTER%を睨んでいる……
	ELSEIF TFLAG:苦痛刻印取得 == 3
		PRINTFORML 「ぐあっ！がっ！がはっ！…%CALLNAME:MASTER%…！や、止め…ろ…！」
		PRINTFORML 「これ…以上…ハ…！…壊……レ…！」
		PRINTFORMDL 手が痛みで痺れる程に力を込めて、%CALLNAME:MASTER%は何度も拳を振るい続けた。
		PRINTFORMDW 磨弓の顔には、殴られた箇所からヒビが入り始めている…！
	ENDIF
ENDIF

;時姦刻印
IF TFLAG:時姦刻印取得 == 1
	PRINTFORMDL 鎧を取り外し、一糸纏わぬ姿となった磨弓が目の前にある。
	PRINTFORMDL 高名な彫刻家が造った裸像を隣に並べても、今の磨弓の前では霞んで見えてしまうだろう。
	PRINTFORMDW 袿姫の芸術センスに改めて敬意を表し、磨弓の肢体を隅々まで撫で回した……！
ELSEIF TFLAG:時姦刻印取得 == 2
	PRINTFORMDL いくら強力な埴輪兵団と言えど、身動き一つ取れない%CALLNAME:MASTER%の世界においては文字通りの人形に過ぎない。
	PRINTFORMDL そんな埴輪兵たちの中でも最高傑作とされる磨弓の肉体を、リスクを負うこと無くしゃぶり尽くせるのは正しく強者の特権だ。
	PRINTFORMDW 唯一にして最大の欠点は、脱がした鎧を再び付け直さなければならない事である……
ELSEIF TFLAG:時姦刻印取得 == 3
	PRINTFORMDL 磨弓の心は袿姫に絶対の忠誠を誓っている…が、彼女の身体は違う。
	PRINTFORMDL その証拠に%CALLNAME:MASTER%が軽く触れただけで、乳首は勃起し秘裂は愛液で濡れそぼる。
	PRINTFORMDL もはや磨弓の身体は、完全に%CALLNAME:MASTER%によって造り替えられたと言っても過言では無いだろう。
	PRINTFORMDW 袿姫が心血を注いで造り上げたであろう最高の作品を、自らの手で汚す背徳感に%CALLNAME:MASTER%は独り身震いするのだった…！
ENDIF

;快楽刻印
IF TFLAG:23 == 1
	CALL HPH_PRINT,@"「ん…HPHあっHPHぅっHPHんっHPHうぅっHPH」","L"
	CALL HPH_PRINT,@"「んん…！んっHPHくぅ…っ…ぅっHPHんん…っHPH」","L"
	PRINTFORMDL 磨弓は思わず出てしまう嬌声を、唇を閉じて必死に堪えている。
	PRINTFORMDW 戦いしか知らない埴輪兵士に色事を教えてやろうと、%CALLNAME:MASTER%は更に激しく攻め立てた…！
ELSEIF TFLAG:23 == 2
	CALL HPH_PRINT,@"「ああぁぁっ……HPH HPHはぁー…HPHはぁー…HPH」","L"
	CALL HPH_PRINT,@"（す…凄い…！こんなに気持ち良くなるなんて…HPH）","L"
	PRINTFORML （まるで…夢のような―）
	PRINTFORML 「へぇ…？ま…まて！今はまだ―」
	CALL HPH_PRINT,@"「あぐうぅっっHPH HPHいっHPHんんっHPHああぁぁぁHPH HPH HPH」","L"
	PRINTFORMDW 磨弓は情事の快楽を受け入れ始めているのか、嬌声を上げる事への抵抗が薄れているようだ。
ELSEIF TFLAG:23 == 3
	CALL HPH_PRINT,@"「あぁっHPHあっHPHひぐぅっHPHあっHPHあぁぁHPH HPH」","L"
	CALL HPH_PRINT,@"「いいっHPHきもちいいHPHきもちいいのっHPHもっとほしいぃHPH HPH」","L"
	PRINTFORMDW 磨弓は%CALLNAME:MASTER%との情事による快感だけでは飽き足らず、自ら性感帯を弄っている…！
ENDIF

;不埒刻印
;快楽、屈服、恭順による刻印
;LV1
IF TFLAG:24 == 11 || TFLAG:24 == 31
	IF CFLAG:うふふ
		CALL HPH_PRINT,@"「はぁ…！はっHPHふぅ…やはり…お前のは、大きい…な…！」","L"
		CALL HPH_PRINT,@"「こんなに…大きい物が、私の中に全部入ってしまうとは…HPH」","L"
		PRINTFORML 「やはり、袿姫様の技術は素晴らしい…♪」
		PRINTFORMDL 磨弓との情事は気持ち良いが、どうも何かが物足りない…
		PRINTFORML 「何…？お前のは、"おちんぽ"…私のは、"おまんこ"…と言うのか？」
		PRINTFORML 「…お…お、おちん…！」
		PRINTFORML 「―言えるか！！」
		PRINTFORMDW 磨弓から拳骨を喰らってしまった。まだ彼女には少し早かったようだ……
	ELSE
		PRINTFORML 「…よし…！…%CALLNAME:MASTER%！！」
		PRINTFORMDL 突然名前を呼ばれて驚き、上ずった声で返事をしてしまう。
		PRINTFORMDL 呆気に取られていると、磨弓は%CALLNAME:MASTER%の手を取って自分の胸元へと押し当てた。
		PRINTFORML 「分かるか…？私はお前と一緒に居るだけで、こんなにも胸が…！」
		PRINTFORML 「…何だその顔は？」
		PRINTFORMDW セラミックスで出来た鎧の、硬く冷たい感触しか伝わってこない…
	ENDIF
;LV2
ELSEIF TFLAG:24 == 12 || TFLAG:24 == 32
	IF CFLAG:うふふ
		CALL HPH_PRINT,@"「はぁ…HPHはぁ…HPHあっHPHふく、らんでる…HPH」","L"
		CALL HPH_PRINT,@"「あHPHあぁっHPHこれ…HPHもうすぐ…HPH」","L"
		PRINTFORML 「……！？お、おい！何で止め…」
		PRINTFORML 「その顔…！い、言えば良いんだろう！？」
		PRINTFORML 「お……おち…！」
		PRINTFORML 「おちんぽで、私のおまんこをイかせてくれっ！！」
		CALL HPH_PRINT,@"「あ゛ぁっHPH……ぁ…は……っHPH HPH HPH」","L"
		PRINTFORMDW おねだりに応えて腰を大きく突き上げると、磨弓は身体を大きく仰け反らせた…！
	ELSE
		PRINTFORML 「…なあ%CALLNAME:MASTER%…今日は、その…しない…のか…？」
		PRINTFORML 「…えっ？だから…その…！…も、もういい！莫迦っ！」
		PRINTFORML （駄目だ駄目だ！こんな時に情事の話など不純だぞ！杖刀偶磨弓～～！！）
		PRINTFORMDW 磨弓は頭を抱えながら、隅の方でうずくまっている。体調が悪いのだろうか…？
	ENDIF
;LV3
ELSEIF TFLAG:24 == 13 || TFLAG:24 == 33
	IF CFLAG:うふふ
		CALL HPH_PRINT,@"「はぁHPHはぁっHPHほらぁっHPH HPHどうした？%CALLNAME:MASTER%っHPHもっと腰を動かせぇっHPH HPH」","L"
		CALL HPH_PRINT,@"「いつもみたいに、おまんこ犯してみろぉHPHそんな情けないおちんぽじゃっHPH私は満足しないぞぉっHPH HPH」","L"
		CALL HPH_PRINT,@"「あぁ…っHPH ああぁぁぁHPH HPHこれっHPHこれだぁっHPH HPHこのおちんぽ、さいこおぉHPH HPH」","L"
		CALL HPH_PRINT,@"「もっとHPHもっとおまんこHPHいっぱいきもちよくしてぇっHPH HPH」","L"
		PRINTFORMDL 磨弓は卑猥な言葉を恥じらいもなく口にしながら、%CALLNAME:MASTER%との情事にふけっている。
		PRINTFORMDW 普段の凛とした彼女からは考えられない乱れ振りに、%CALLNAME:MASTER%の肉棒は更に硬さを増していく……！
	ELSE
		PRINTFORML 「%CALLNAME:MASTER%…ここ、触ってみろ…♪」
		PRINTFORMDL 磨弓は%CALLNAME:MASTER%に耳打ちすると、鎧のスカート部分の一点を指差した。
		PRINTFORMDL 言われるがままそこに触れると、短冊状の装甲の一部がスライドして磨弓の下着があらわになった…！
		PRINTFORML 「どうだ…？袿姫様に内緒で、こっそりと手を加えておいたんだ...♪」
		CALL HPH_PRINT,@"「これでいつでも、私のおまんこを弄れるぞ…？HPH」","L"
		CALL HPH_PRINT,@"「あぁっHPHさ、早速か…？本当にしょうがない奴だ…HPH」","W"
	ENDIF
ENDIF

;反発刻印
IF TFLAG:反発刻印取得 == 1
	PRINTFORML 「%CALLNAME:MASTER%！今のは私への宣戦布告か！？」
	PRINTFORMDW 磨弓に胸ぐらを掴まれ、身動きが取れない……
ELSEIF TFLAG:反発刻印取得 == 2
	PRINTFORML 「%CALLNAME:MASTER%お前、畜生界の連中に何か吹き込まれたか？」
	PRINTFORML 「まあいい…どんな事情が有るにせよ、私や袿姫様に仇なす者は―」
	PRINTFORML 「排除する！！」
	PRINTFORMDW 明らかに殺意を込めて追いかけてきた磨弓から何とか逃げ出した……
ELSEIF TFLAG:反発刻印取得 == 3
	PRINTFORML 「消えろ」
	PRINTFORML 「私にも、袿姫様の前にも二度と姿を見せるな」
	PRINTFORMDW 磨弓も含めた埴輪兵団が、一斉にこちらへ刃を向けてきた……
ENDIF