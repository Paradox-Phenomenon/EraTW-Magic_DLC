;==================================================
;弾幕勝負 
;==================================================
@M_KOJO_MESSAGE_COM_K131_DANMAKU(ARGS, 相手残機)
#DIM 相手残機
;全体の流れ
;①【戦闘前】→②ダイスロールとプレイヤー選択肢、ハンデをつけた場合は【ハンデ口上】→③対応スキルが発動した場合【スキル口上】→④被弾判定、キャラが被弾したなら【被弾口上】→
;どちらかの残機が0になっていなければ②に戻る→⑤【戦闘後口上】

;磨弓はスキル未実装ですが、一応書いてます。念のためにOFF

;--------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------
IF LOCAL
SIF FLAG:口上色
	TRYCALLFORM M_KOJO_COLOR_K{NO:TARGET}
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;戦闘前
	HANDICAP_FIXED = 0
	HANDICAP_RAND = 0
	;ハンデをつけることができ、数値が大きいほどあなたが不利になる　数値が負ならあなたが有利に
	;キャラの能力に関わらずクッソ強くしたり弱くしたりできる
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "戦闘前"
		IF ALCOHOL_FACE(131) == "酔いどれ" || ALCOHOL_FACE(131) == "ぐでぐで"
			PRINTFORML 「勝負だと？いいだろう！」
			PRINTFORML 「酔い醒ましの運動には丁度良い！」
			PRINTFORMDL 磨弓の声に応える様に、埴輪兵士の大軍が姿を現した…！
			PRINTFORMW 「『がらんどうの無尽兵団』よ！%CALLNAME:MASTER%を討ち取れ！！」
		ELSEIF TALENT:131:機嫌 == -1 || CFLAG:131:ブチギレ || MARK:131:反発刻印 >= 3
			PRINTFORML 「ふん…丁度良い」
			PRINTFORML 「"私達"も、お前に灸を据えてやろうと思っていたところだ…！」
			PRINTFORMDL 磨弓の声に応える様に、埴輪兵士の大軍が姿を現した…！
			PRINTFORMW 「『がらんどうの無尽兵団』！奴の曲がった性根を叩き直してやれ！！」
		;あなた戦闘力3以下
		ELSEIF ABL:MASTER:戦闘能力 < 3
			PRINTFORML 「止めておいた方が身のためだと思うが…」
			PRINTFORML 「お前は口で言っても分からんだろうからな」
			PRINTFORMDL 磨弓の声に応える様に、埴輪兵士の大軍が姿を現した…！
			PRINTFORMW 「『がらんどうの無尽兵団』！勇気と蛮勇の違いを、嫌と言うほど教えてやれ！！」
		ELSE
			PRINTFORML 「勝負だと？いいだろう！」
			;磨弓戦闘能力5以上
			IF ABL:戦闘能力 >= 5
				PRINTFORML 「ただし…以前の"私達"と同じだと思うなよ？」
				PRINTFORML 「出でよ！『不敗の無尽兵団』！！」
				PRINTFORMDL 磨弓の声に応える様に、埴輪兵士が次々と姿を現す…
				PRINTFORMDL 以前の埴輪兵団とは、数も質も段違いだ…！
				PRINTFORMW 「袿姫様から賜った新たな力で、お前に雪辱を果たす！！」
			ELSE
				PRINTFORML 「"私達"が相手をしてやる！」
				PRINTFORMDL 磨弓の声に応える様に、埴輪兵士の大軍が姿を現した…！
				PRINTFORMW 「『がらんどうの無尽兵団』よ！%CALLNAME:MASTER%を討ち取れ！！」
			ENDIF
		ENDIF
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;ハンデ
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "ハンデ"
		;ハンデつけなかったら表示されないので無記入でよい
		PRINTFORML 
		RETURN 0
	ENDIF
	;-------------------------------------------------
	;戦闘中TARGET被弾時口上
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "被弾"
		SELECTCASE 相手残機
			;残り残機3が表示されるのは【洽覧深識】持ちのみ
			CASE 3
			CASE 2
				PRINTFORML 「怯むな！騎兵隊、前進！弓兵隊は援護しろ！」
				PRINTFORMW 「残った剣士隊は、弓兵隊を護れ！」
			CASE 1
				PRINTFORML 「…くっ！……ならば私が！」
				PRINTFORML 「――！」
				PRINTFORMDL 磨弓が口笛を吹くと、一体の馬型埴輪が現れる。
				PRINTFORMDL それに颯爽と跨ると、磨弓はセラミックス製の剣を構えた！
				PRINTFORML 「行くぞ%CALLNAME:MASTER%！最後の勝負だあぁぁぁ！！」
				PRINTFORMDW 磨弓は%CALLNAME:MASTER%の弾幕を恐れることなく、突撃してきた！
			CASE 0
				PRINTFORML 「%TEXTR("つ、強い…！これ程とは…！/やはり私達は…生身の人間には勝てないのか…？/袿姫……様……")%」
				PRINTFORMDW 馬型埴輪は砕け散り、磨弓は地面へと投げ出された……
		ENDSELECT
	ENDIF
ENDIF
	;-------------------------------------------------
	;戦闘中
	;TARGETの【残忍酷薄】発動時
	;ARGはTARGETの残機
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "残忍酷薄"
		PRINTFORML 「%TEXTR("さあ、この状況…お前はどうする？/よし！このまま押し切るぞ！/今だ！包囲しろ！")%」
		PRINTFORMDW 人海戦術で抑え込もうとしてくる埴輪兵士達を、ボムで吹き飛ばした！
	ENDIF
	;-------------------------------------------------
	;戦闘中
	;TARGETの【乾坤一擲】発動時
	;ARGはTARGETの残機
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "乾坤一擲"
		SELECTCASE RAND:2
			CASE 0
				PRINTFORML 「弓兵隊、撃ち方用意！…てーーっ！！」
				PRINTFORMDW 磨弓の号令と同時に、大量の矢が飛んできた！
			CASE 1
				PRINTFORML 「騎兵隊、突撃ーーっ！」
				PRINTFORMDW 多数の騎兵埴輪が、%CALLNAME:MASTER%目掛けて突進してきた！
		ENDSELECT
	ENDIF
	;-------------------------------------------------
	;戦闘中
	;TARGETの【怪力乱神】発動時
	;ARGはTARGETの残機
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "怪力乱神"
		SELECTCASE RAND:2
			CASE 0
				PRINTFORML 「弓兵隊、撃ち方用意！…てーーっ！！」
				PRINTFORMDW 弓兵埴輪による矢の弾幕に、攻撃をかき消された！
			CASE 1
				PRINTFORML 「剣士隊！前進して守りを固めろ！」
				PRINTFORMDW %CALLNAME:MASTER%の攻撃は、剣士埴輪たちに防がれてしまった！
		ENDSELECT
	ENDIF
	;-------------------------------------------------
	;戦闘後
	;記入チェック（=0, 非表示、1, 表示）
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && ARGS == "戦闘後" 
		PRINTFORML 
		;残り残機4が表示されうるのは【洽覧深識】持ちのみ
		;残機が1以上ならあなたの負け、0の場合はあなたの勝利
		;あなた勝利
		IF 相手残機 == 0
			IF TALENT:131:機嫌 == -1 || CFLAG:131:ブチギレ || MARK:131:反発刻印 >= 3
				PRINTFORML 「…次は負けん…！」
				PRINTFORMDW 磨弓は%CALLNAME:MASTER%の手を借りずに立ち上がった…
			ELSE
				;磨弓に勝利済み
				IF CFLAG:131:弾幕勝負勝利
					PRINTFORML 「……ぅ…！く…うぅ…！」
					;磨弓戦闘能力5以上
					IF ABL:戦闘能力 >= 5
						PRINTFORML 「くそぉっ！あれだけの軍勢を持ってしても勝てないなんて…！」
					ELSE
						PRINTFORML 「くそぉっ！また……負けてしまった…！」
					ENDIF
					PRINTFORMW 「これでは…袿姫様に合わせる顔が無い…！」
					PRINTFORMDL よほど悔しかったのか、磨弓は腕で目を覆いながら涙を流している。
					PRINTFORMDW 取り敢えず落ち着かせようと%CALLNAME:MASTER%は手を伸ばすが……
					PRINTFORMW 「うるさい！！あっち行け！私に構うな！！」
					PRINTFORMDL とうとう癇癪を起こし始めた磨弓に、%CALLNAME:MASTER%は声をかける。
					PRINTFORMDW "美味しいものでも食べに行こう"
					PRINTFORML 「…………。」
					PRINTFORMDW 磨弓はぐしぐしと目をこすりながら、ゆっくりと立ち上がった……
					SETCOLOR 0xFFE9A9
					PRINTFORML      STAGE CLEAR
					PRINTFORMDL      Clear Bonus
					PRINTFORMDL       5,000,000
					PRINTFORMDW 
				;磨弓に初勝利
				ELSE
					PRINTFORML 「はぁ……」
					PRINTFORML 「あいつらに続いて、%CALLNAME:MASTER%にまで負けてしまうとは…私は兵長失格だ……」
					PRINTFORMDW "たまたま運が良かったから勝てただけだ"と励ましながら、%CALLNAME:MASTER%は倒れる磨弓へ手を差し伸べた。
					PRINTFORML 「…ふっ…♪……お前は本当に優しい奴だな……」
					PRINTFORML 「―次は負けんぞ！」
					PRINTFORMDW そう言って%CALLNAME:MASTER%の手を取り立ち上がる磨弓の表情は、とても晴れやかだった。
					SETCOLOR 0xFFE9A9
					PRINTFORML      STAGE CLEAR
					PRINTFORMDL      Clear Bonus
					PRINTFORMDL       5,000,000
					PRINTFORMDW 
				ENDIF
			ENDIF
		;磨弓勝利
		ELSE
			IF TALENT:131:機嫌 == -1 || CFLAG:131:ブチギレ || MARK:131:反発刻印 >= 3
				PRINTFORMW 「少しは反省したか？」
			ELSE
				;あなた戦闘力3以下
				IF ABL:MASTER:戦闘能力 < 3
					PRINTFORML 「…ほら、立てるか？」
					PRINTFORMW 「私に勝ちたいのなら、しっかり鍛錬して強くなる事だ」
				ELSE
					PRINTFORML 「うおおおおぉぉぉ！！！」
					PRINTFORMDW 地面に倒れ伏しながら、磨弓の勝鬨を聞いた……
				ENDIF
			ENDIF
		ENDIF
	ENDIF
RESETCOLOR
RETURN 1

