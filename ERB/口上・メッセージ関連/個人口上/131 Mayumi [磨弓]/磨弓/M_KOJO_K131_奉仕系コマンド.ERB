				CALL HPH_PRINT,@"「れろぉ…HPHちろちろ…♪ふふ…もどかしいか？HPH」","L"
				CALL HPH_PRINT,@"「焦らすのも可哀想だしな…あぁー…HPH」","L"
				PRINTFORMDW 磨弓は大口を開け、ペニスを口に含んだ…！
			CASE 2
				CALL HPH_PRINT,@"「さあ%CALLNAME:MASTER%…HPH今日も精液を飲ませてもらうぞ…HPH」","L"
				CALL HPH_PRINT,@"「あぁむ…HPHじゅ…ぼ、おぉ…HPH HPH」","L"
				PRINTFORMDL 磨弓は口をすぼめて%CALLNAME:MASTER%のペニスをご奉仕している。
