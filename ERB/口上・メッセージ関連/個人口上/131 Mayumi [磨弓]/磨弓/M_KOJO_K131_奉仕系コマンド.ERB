		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		PRINTFORMW 
		RETURN 1
	ELSEIF ABL:技巧 >= 3 && ABL:サドっ気 >= 3
		;今射精した
		IF NOWEX:PLAYER:11
			SELECTCASE RAND:4
				CASE 0
					CALL HPH_PRINT,@"「さあいくぞ%CALLNAME:MASTER%…HPH準備はいいか？」","L"
					PRINTFORML 「それっ♪」
					PRINTFORMDW 磨弓がペニスを踏みつけると、精液が勢いよく吹き出した―
				CASE 1
					CALL HPH_PRINT,@"「なんだ%CALLNAME:MASTER%、もうイキそうなのか？HPH」","L"
					CALL HPH_PRINT,@"「足だけで気持ちよくなる助平には、私のおまんこはもう必要無いな…？HPH」","L"
					PRINTFORMDW 言葉責めにゾクゾクと身体を震わせながらも、磨弓は足コキを更に続けた…！
				CASE 2
					CALL HPH_PRINT,@"「ふふふ……HPHんっHPHイキそう……なのねぇ…？HPH」","L"
					CALL HPH_PRINT,@"「私もイク…HPHイクっ…HPHイっ…！んんんーっHPH HPH HPH」","L"
					PRINTFORMDW へカーティアが達するのとほぼ同時に、%CALLNAME:MASTER%も果てた―
				CASE 3
					PRINTFORMDL %CALLNAME:MASTER%が射精しようとした瞬間、ペニスの根元が締め付けられる感触がした。
					PRINTFORMDL 見ると磨弓の足の指が、ペニスを挟み込んでいた…！
					CALL HPH_PRINT,@"「%CALLNAME:MASTER%っHPHもう少し、我慢してくれぇっHPH」","L"
					CALL HPH_PRINT,@"「わたし…もっHPHイクHPHイクから…ああぁーっHPH HPH」","L"
					PRINTFORMDW 磨弓が絶頂して仰け反った拍子に、足が%CALLNAME:MASTER%のペニスから離れた―
			ENDSELECT
			RETURN 1
		;それ以外
		ELSE
			SELECTCASE RAND:4
				CASE 0
					PRINTFORML 「足で擦られて悦ぶとは…♪」
					CALL HPH_PRINT,@"「お前は、とんだ変態だな…HPH」","L"
					PRINTFORMDW 磨弓の足コキと言葉責めで、肉棒は更に硬さを増していく…！
				CASE 1
					CALL HPH_PRINT,@"「ふふ…♪こうして…これならどうだっ？HPH」","L"
					PRINTFORMDW 磨弓は器用に足を動かして、%CALLNAME:MASTER%のペニスを扱いてきた…！
				CASE 2
					PRINTFORML 「最近、力加減が分かってきたんだ…♪」
					CALL HPH_PRINT,@"「どうだ？気持ちいいだろう？HPH」","L"
					PRINTFORMDL %CALLNAME:MASTER%は足でペニスを踏まれている。
					PRINTFORMDW 絶妙な力加減のおかげか、痛みよりも快感が勝っている…！
				CASE 3
					CALL HPH_PRINT,@"「はぁ…HPHあっ…HPH手が空いていると便利だな…HPH」","L"
					PRINTFORMDW 磨弓は足コキをする傍ら、空いた手で乳房と秘所を弄っている…！
			ENDSELECT
			RETURN 1
		ENDIF
	;それ以外
	ELSE
		;今射精した
		IF NOWEX:PLAYER:11
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「%CALLNAME:MASTER%…これ、先端の方が膨らんできてないか…？」
					CALL HPH_PRINT,@"「ああ、そうか…♪これは射精の合図か…HPH」","L"
					PRINTFORMDW 磨弓は足の動きを加速させ、射精を促してきた…！
				CASE 1
					CALL HPH_PRINT,@"「ほ、本当に…足で気持ちよくなるものなんだな…HPH」","L"
					PRINTFORMDW 磨弓はどこか嬉しそうにしながら、扱く速さを早めた…！
				CASE 2
					PRINTFORML 「そろそろか…？では、もう少し強くして―」
					PRINTFORML 「うわっ！？」
					PRINTFORMDW ペニスから勢いよく発射された精液が、磨弓の足を汚した…
			ENDSELECT
			RETURN 1
		;それ以外
		ELSE
			SELECTCASE RAND:4
				CASE 0
					PRINTFORML 「足腰には自信がある方だが…」
					PRINTFORML 「これはっ…！結構、難しいな…！」
					PRINTFORMDW 磨弓は拙い動きで足コキをしている…
				CASE 1
					PRINTFORML 「%CALLNAME:MASTER%、大丈夫か？痛くないか…？」
					PRINTFORMDW 磨弓はこちらの様子を伺いながら足コキをしている。
				CASE 2
					PRINTFORML 「い、痛いのか！？す、すまん…」
					PRINTFORML 「…やっぱり、手の方がいいんじゃないか…？」
					PRINTFORMDW 磨弓は、まだ足コキに慣れていないようだ…
				CASE 3
					PRINTFORML 「うう…！」
					PRINTFORML （なんだか、私まで変な気分に…）
					PRINTFORMDW 磨弓は身体をモゾモゾさせながら足コキをしている…
			ENDSELECT
			RETURN 1
		ENDIF
	ENDIF
ENDIF
RETURN 1
