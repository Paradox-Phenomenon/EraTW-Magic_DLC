			SELECTCASE RAND:4
				CASE 0
					PRINTFORMW 「んっ…！ふぅっ…！結構…難しいな…！」
				CASE 1
					PRINTFORML 「…なあ、%CALLNAME:MASTER%。本当にこのやり方でいいのか？」
