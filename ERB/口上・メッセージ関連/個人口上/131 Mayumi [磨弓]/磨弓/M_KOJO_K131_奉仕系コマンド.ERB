			CASE 3
				CALL HPH_PRINT,@"「そういえば…こっちの玉も舐められるのも気持ちいいらしいな…？HPH」","L"
				CALL HPH_PRINT,@"「お前さえよければやってやるが…どうする？HPH」","L"
				PRINTFORMDW 磨弓は睾丸に指を這わせながら舌なめずりをしている…！
		ENDSELECT
		RETURN 1
