				CASE 2
					PRINTFORMW 「ふっ…んんっ…ふぅっ…んぅ…っ…！」
				CASE 3
					PRINTFORMW 「成程…胸とは、こうして使うものだったんだな…♪」
			ENDSELECT
			RETURN 1
		ENDIF
	ENDIF
