;80,手淫
;==================================================
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_MESSAGE_MESSAGECHECK_COM_K131_80
RETURN 0

@M_KOJO_MESSAGE_COM_K131_80
CALL M_KOJO_MESSAGE_COM_K131_80_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K131_80_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		PRINTFORML 「…これを、手で？」
		PRINTFORML 「わかった、やってみよう…」
		PRINTFORMDW 磨弓がおずおずとペニスを握ってきた…
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		PRINTFORMW 
		RETURN 1
	;技巧３以上
	ELSEIF ABL:技巧 >= 3
		;今射精した
		IF NOWEX:PLAYER:11
			SELECTCASE RAND:4
				CASE 0
					CALL HPH_PRINT,@"「もう、か…？しょうがない奴だな…HPH」","L"
					CALL HPH_PRINT,@"「まあいい…♪しっかり受け止めてやるぞ…ほら…HPH」","L"
					PRINTFORMDW 磨弓は手のひらで、精液を受け止める体勢に入った…！
				CASE 1
					CALL HPH_PRINT,@"「そうだ…♪…こうして、と…HPH」","L"
					CALL HPH_PRINT,@"「どうだ？愛液で扱かれるのも、悪くないだろう？HPH」","L"
					PRINTFORMDL 磨弓は自らの秘裂から垂れた愛液を手に塗りたくると、再び扱き始めた。
					PRINTFORMDW ぬるぬるとした感触と程よい温かさで、%CALLNAME:MASTER%の快感は絶頂へと達した…！
				CASE 2
					CALL HPH_PRINT,@"「…っHPHああ…分かった…♪」","L"
					CALL HPH_PRINT,@"「お前の好きな所にかけていいぞ…HPH」","L"
					PRINTFORMDW %CALLNAME:MASTER%は欲望のままに、磨弓を精液で染め上げた…！
				CASE 3
					CALL HPH_PRINT,@"「%CALLNAME:MASTER%…HPHおちんぽ、もう限界か？HPH」","L"
					PRINTFORML 「それじゃあ、もっと擦るぞ？…それっ♪」
					PRINTFORMDL 磨弓の手の動きが更に加速し、絶頂へと導く。
					PRINTFORMDW %CALLNAME:MASTER%は耐え切れず、小さな呻き声と共に射精した―
			ENDSELECT
			RETURN 1
		;それ以外
		ELSE
			SELECTCASE RAND:4
				CASE 0
					PRINTFORML 「自分でするのと私がするのとでは、やはり感覚が違うものなのか？」
					CALL HPH_PRINT,@"「…ふっ…♪そうか…HPH」","L"
					CALL HPH_PRINT,@"「では、私の手でしか射精出来なくなるくらい虜にしてやるぞ…HPH」","L"
					PRINTFORMDW %CALLNAME:MASTER%の答えに気を良くしたのか、磨弓は扱く速度を早めてきた。
				CASE 1
					CALL HPH_PRINT,@"「はぁ…はぁ…HPHんっHPHふぅ…っ…HPHくぅ…HPHはぁ…ぁぁ…HPH」","L"
					CALL HPH_PRINT,@"（%CALLNAME:MASTER%のおちんぽ…HPHいつ見ても…大きくて、固い…HPH）","L"
					CALL HPH_PRINT,@"（早く…HPH早くこいつを、私の膣内に挿入れてほしいっ…HPH）","L"
					PRINTFORMDW 磨弓は空いた手で、自分の股座を弄りながら手淫をしている…！
				CASE 2
					CALL HPH_PRINT,@"「こうして…♪先端を引っ掻かれるの、気持ち良いだろう？HPH」","L"
					PRINTFORMDW 磨弓の人差し指が亀頭を刺激してくる…！
				CASE 3
					PRINTFORML 「竿だけでなく…こっちも、と…♪」
					PRINTFORMDW 磨弓はペニスだけでなく、睾丸も揉みしだいて刺激してきた…！
			ENDSELECT
			RETURN 1
		ENDIF
	;それ以外
	ELSE
		;今射精した
		IF NOWEX:PLAYER:11
			SELECTCASE RAND:3
				CASE 0
					CALL HPH_PRINT,@"「はぁ…HPHはぁっ…HPHはぁっ…HPH HPH」","L"
					PRINTFORMDL "もう射精そうだ"と告げたが、磨弓は扱くのに夢中で聞こえていないようだ。
					PRINTFORMDW %CALLNAME:MASTER%は諦めて、快感に身を任せる事にした…
				CASE 1
					PRINTFORML 「"でそう"…射精か！？」
					PRINTFORML 「わ、私はどうすればいいんだ…！？」
					PRINTFORMDW 磨弓の言葉に耳を貸せるだけの余裕は既に無く…
				CASE 2
					PRINTFORML 「%CALLNAME:MASTER%…さっきよりも、大きくなってきたぞ…？」
					CALL HPH_PRINT,@"「ああ、そうか…射精が近いんだな…？HPH」","L"
					PRINTFORMDW 磨弓は扱く速度を更に早め、射精を促してきた…！
			ENDSELECT
			RETURN 1
		;それ以外
		ELSE
			SELECTCASE RAND:3
				CASE 0
					CALL HPH_PRINT,@"「ふぅ…HPHんっ…♪ふぅ…HPH」","L"
					CALL HPH_PRINT,@"（この大きいのが…！もうすぐ私の中に…？HPH）","L"
					PRINTFORMDW 磨弓は竿を手で扱きながら、太腿をモジモジと擦り合わせている。
				CASE 1
					CALL HPH_PRINT,@"「いつも自分でする時は…こうして、手で擦るのか…？HPH」","L"
					PRINTFORMDW 磨弓は%CALLNAME:MASTER%のオナニーに興味があるようだ…
				CASE 2
					PRINTFORML 「力加減は…この位で、良いのか…？」
					PRINTFORMDW 磨弓は少しぎこちない動きで%CALLNAME:MASTER%の肉棒を扱いている。
			ENDSELECT
			RETURN 1
		ENDIF
	ENDIF
ENDIF
RETURN 1
