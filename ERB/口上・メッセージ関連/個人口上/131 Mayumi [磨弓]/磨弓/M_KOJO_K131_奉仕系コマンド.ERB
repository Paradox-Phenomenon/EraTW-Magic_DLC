				CALL HPH_PRINT,@"「すんすん…HPHはぁ…HPH私のと混ざって…凄い臭いだ…HPH」","L"
				CALL HPH_PRINT,@"「ああ…HPHれろっHPHちゅっHPHは……HPHれろぉ…っHPH」","L"
