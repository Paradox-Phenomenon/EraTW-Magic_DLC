LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF FLAG:70
		PRINTFORMDL 時を止められ、身動きの取れない磨弓にキスをした。
		PRINTFORMDW 人のそれと変わらない、柔らかい唇だ…！
	ELSEIF CFLAG:睡眠
		CALL HPH_PRINT,@"「ん…っ…ちゅ…HPH」","W"
		RETURN 1
	ELSEIF TFLAG:193 == 99
		SELECTCASE RAND:2
			CASE 0
				PRINTFORML 「どうした？力比べがしたいんじゃないのか？」
				PRINTFORMDW 磨弓にアイアンクローをされた…
			CASE 1
				PRINTFORML 「…………。」
				PRINTFORMDW %CALLNAME:MASTER%の邪念を察したのか、飛び出してきた埴輪兵士たちに袋叩きにされた…
		ENDSELECT
	ELSEIF EXP:131:キス経験 == 1
		PRINTFORML 「ふむ…これが"きす"…接吻というものか…」
		PRINTFORML 「…？ああ。初めてだが…？」
		PRINTFORMDW 磨弓はファーストキスにあまり関心が無いようだ…
	ELSEIF CFLAG:うふふ == 2
		SELECTCASE TCVAR:20
			;前から抱きつく
			CASE 32
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「んん…HPHちゅっHPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「ちゅHPH…はぁ…♪」","W"
				ENDSELECT
			;手淫
			CASE 50
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「んっHPHちゅ…HPHこら、大人しくしていろ…♪」","L"
					CASE 1
						CALL HPH_PRINT,@"「ちゅぷっHPHこれは…一人だけでは出来ないだろう…？HPH」","L"
				ENDSELECT
				PRINTFORMDW 磨弓と舌を絡めながら、ペニスを扱いてもらった…！
			;ディープキス
			CASE 60
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「はっHPHちゅぷっHPHふぅっHPHあむっHPHじゅるうぅっHPH HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「ちゅHPHじゅぷぅHPHれるぅHPHちろっHPHじゅっHPHれるぅっHPH ちゅぱっHPH」","W"
				ENDSELECT
			;85=Ｖ挿入する 87=Ａ挿入する 88=腰振りＶ 89=腰振りＡ
			CASE 85,87,88,89
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「はっHPHちゅぷっHPHふぅっHPHあむっHPHじゅるうぅっHPH HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「ちゅHPHじゅぷぅHPHれるぅHPHちろっHPHじゅっHPHれるぅっHPH ちゅぱっHPH」","W"
				ENDSELECT
			;だいしゅきホールド
			CASE 86
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「%CALLNAME:MASTER%…HPHもっと…HPH私と、くっついてぇ…HPH」","L"
						CALL HPH_PRINT,@"「は…HPHれるぅ…HPHちゅぷっHPHは…HPHぢゅうぅHPH」","L"
					CASE 1
						CALL HPH_PRINT,@"「%CALLNAME:MASTER%っHPHんっHPHちゅぷっHPHしゅきっHPHはぷっHPHしゅきいぃっHPH HPH」","L"
				ENDSELECT
				PRINTFORMDW 磨弓とキスをしながら抱き合った…！
			CASEELSE
				CALL MAYUMI_KISS
		ENDSELECT
	ELSE
		IF TALENT:恋人 || TALENT:恋慕
			SELECTCASE RAND:3
				CASE 0
					CALL HPH_PRINT,@"「んっHPH…はぁ…HPH」","L"
					PRINTFORMDW 磨弓と唇を軽く触れ合わせた。
				CASE 1
					CALL HPH_PRINT,@"「ちゅぷっHPHちゅるぅ…HPHちゅぱっHPH」","L"
					PRINTFORMDW 磨弓と舌を絡め合うキスをした。
				CASE 2
					CALL HPH_PRINT,@"「んっ♪…たまにはこういうのも良いな…HPH」","L"
					PRINTFORMDW 磨弓の頬にキスをした。
			ENDSELECT
		ELSEIF TALENT:132:恋人
			SELECTCASE RAND:2
				CASE 0
					SELECTCASE RAND:2
						CASE 0
							CALL HPH_PRINT,@"「んっHPHこ、ら…！こういう事は、袿姫様と…！」","L"
						CASE 1
							CALL HPH_PRINT,@"「だ、駄目だ…！お前には、袿姫様が…んんっHPH」","L"
					ENDSELECT
					PRINTFORMDW 嫌がる磨弓とキスを交わした。
				CASE 1
					PRINTFORML 「%TEXTR("や、やめろ！近づくな/だ…駄目だ！これ以上は、袿姫様を裏切る事に…")%！」
					PRINTFORMDW 磨弓は%CALLNAME:MASTER%とのキスを嫌がっている…
			ENDSELECT
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「ん…これには何の意味が？」
					PRINTFORMDW 磨弓はキスをされても、あまり関心が無いようだ…
