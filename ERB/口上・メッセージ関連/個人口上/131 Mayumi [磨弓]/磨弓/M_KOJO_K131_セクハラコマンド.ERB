@M_KOJO_MESSAGE_COM_K131_311_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF FLAG:70
		PRINTFORMDL 時を止められ、身動きの取れない磨弓に抱きついた。
		PRINTFORMDW 等身大の人形を抱いている気分だ…
	ELSEIF CFLAG:睡眠
		SELECTCASE RAND:2
			CASE 0
				PRINTFORMW 「…うぅ…！…んぅ…？」
			CASE 1
				PRINTFORMW 「ん～…♪」
		ENDSELECT
		RETURN 1
	ELSEIF CFLAG:うふふ == 2
		SELECTCASE TCVAR:20
			;前から抱きつく
			CASE 32
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「ひゃっHPH HPH」","L"
						CALL HPH_PRINT,@"「き、急にどうした…？HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「んっ…HPH%CALLNAME:MASTER%に抱きしめられると、安心する…♪」","W"
				ENDSELECT
			;ディープキス
			CASE 60
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「はっHPHちゅぷっHPHふぅっHPHあむっHPHじゅるうぅっHPH HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「ちゅHPHじゅぷぅHPHれるぅHPHちろっHPHじゅっHPHれるぅっHPH ちゅぱっHPH」","W"
				ENDSELECT
			;ぱふぱふ
			CASE 73
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「お前…本当におっぱいが好きなんだな…HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「ほら…♪ぱふぱふ…HPHぱふぱふ…HPH」","W"
				ENDSELECT
			;乳合わせ
			CASE 74
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「あっHPHあぁっHPH HPH%CALLNAME:MASTER%のちくびっHPHかたくてっHPHきもちいいっHPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「あんっHPHやめっHPHそんなにしたらHPH乳首、こすれるぅっHPH HPH」","W"
				ENDSELECT
			;乳を吸わせる
			CASE 77
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「お前…本当におっぱいが好きなんだな…HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「んんっHPH HPHそんなに…吸うなぁっHPH」","W"
				ENDSELECT
			;85=Ｖ挿入する 87=Ａ挿入する 88=腰振りＶ 89=腰振りＡ
			CASE 85,87,88,89
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「あぁっHPHこれっHPHいいとこっHPH擦れるうっHPH HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「%CALLNAME:MASTER%っHPHもっとHPHもっと強く、抱きしめてほしいっHPH」","W"
				ENDSELECT
			;だいしゅきホールド
			CASE 86
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「%CALLNAME:MASTER%…HPHもっと…HPH私と、くっついてぇ…HPH」","L"
						CALL HPH_PRINT,@"「は…HPHれるぅ…HPHちゅぷっHPHは…HPHぢゅうぅHPH」","L"
					CASE 1
						CALL HPH_PRINT,@"「%CALLNAME:MASTER%っHPHんっHPHちゅぷっHPHしゅきっHPHはぷっHPHしゅきいぃっHPH HPH」","L"
				ENDSELECT
				PRINTFORMDW 磨弓とキスをしながら抱き合った…！
			CASEELSE
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「ひゃっHPH HPH」","L"
						CALL HPH_PRINT,@"「き、急にどうした…？HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「んっ…HPH%CALLNAME:MASTER%に抱きしめられると、安心する…♪」","W"
				ENDSELECT
		ENDSELECT
	ELSE
		IF TALENT:恋人 || TALENT:恋慕
			SELECTCASE RAND:3
				CASE 0
					CALL HPH_PRINT,@"「ひゃっHPH HPH」","L"
					CALL HPH_PRINT,@"「き、急にどうした…？HPH」","W"
				CASE 1
					CALL HPH_PRINT,@"「んっ…HPH%CALLNAME:MASTER%に抱きしめられると、安心する…♪」","W"
				CASE 2
					PRINTFORML 「…%CALLNAME:MASTER%…♪」
					IF TALENT:131:恋人
						CALL HPH_PRINT,@"（好きだぞ…HPH）","L"
						PRINTFORMDW 磨弓が耳元で愛を囁いてきた…！
					ELSE
						PRINTFORML 「ん…♪」
						PRINTFORMDW %CALLNAME:MASTER%が抱きしめると、磨弓も腕を背中に回してきた。
					ENDIF
			ENDSELECT
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「%TEXTR("なっ！？何を…！/っ！？は、離れろ！")%」
					PRINTFORMDW 流石の磨弓も、いきなり抱きつかれるのは予想していなかったようだ。
				CASE 1
					PRINTFORML 「…今、何かしようとしたか？」
					PRINTFORMDW %CALLNAME:MASTER%の行動を察したのか、傍らの埴輪兵士が刃を向けてきた…
				CASE 2
					PRINTFORML 「…………。」
					PRINTFORMDW %CALLNAME:MASTER%の邪念を察したのか、飛び出してきた埴輪兵士たちに袋叩きにされた…
			ENDSELECT
		ENDIF
	ENDIF
ENDIF
RETURN 1

