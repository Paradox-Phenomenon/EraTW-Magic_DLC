;==================================================
;310,尻を撫でる
;TFLAG:193(1=不快(TALENT:臆病なら涙目) 2&&3=恥ずかしがる(TALENT:男嫌い兼MASTERが男なら、身をすくめる) 4=されるがまま)
;CFLAG:うふふ==2&&TCVAR:20(パンツ無し顔面騎乗(70=クンニ強制 71=フェラチオ強制 72=アナル奉仕) 35=スカート内見せつけ 52=素股)
;CFLAG:うふふ==2&&TEQUIP:シックスナイン(パンツありTCVAR:20(70～72)はこちら)
;PREVCOM(305=膝枕
;TFLAG:400(1=デート先or地底のモブが反応する)
;==================================================
@M_KOJO_SUCCESS_COM_K131_310
;成否判定
;TFLAG:192(-2=コマンド終了、-1＝強制失敗、0=COM依存、1=強制成功or大成功
TFLAG:192 =0

;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_MESSAGE_MESSAGECHECK_COM_K131_310
RETURN 0

@M_KOJO_MESSAGE_COM_K131_310
CALL M_KOJO_MESSAGE_COM_K131_310_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K131_310_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	IF FLAG:70
		PRINTFORMDW 芸術作品に勝るとも劣らない、磨弓の形の良い尻を撫でた。
	ELSEIF CFLAG:睡眠
		CALL HPH_PRINT,@"「ん…HPH…ぅ…んん…っ…HPH」","W"
	ELSEIF CFLAG:うふふ == 2
		SELECTCASE TCVAR:20
			;クンニ強制
			CASE 70
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「あっHPHおい…！そっちじゃな…んんっHPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「こら…！尻は後にしろ…HPH」","W"
					ENDSELECT
			;アナル奉仕
			CASE 72
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「んっ…HPHそんなに…撫でるなぁ…っ…HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「%CALLNAME:MASTER%…HPH手つきがいやらしいぞ…？HPH」","W"
				ENDSELECT
			;スカートの中を見せる
			CASE 35
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「あっHPHこら、がっつくな…HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「%CALLNAME:MASTER%…HPH手つきがいやらしいぞ…？HPH」","W"
				ENDSELECT
			;素股
			CASE 52
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「尻を触るな…HPH動けないだろぉっHPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「あんっHPHじっとしていろ…HPH」","W"
				ENDSELECT
			CASEELSE
				SELECTCASE RAND:2
					CASE 0
						CALL HPH_PRINT,@"「んっ…HPHそんなに…撫でるなぁ…っ…HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「%CALLNAME:MASTER%…HPH手つきがいやらしいぞ…？HPH」","W"
				ENDSELECT
		ENDSELECT
	ELSE
		IF TALENT:恋人 || TALENT:恋慕
			SELECTCASE TFLAG:193
				;不快
				CASE 1
					PRINTFORML 「…おい、何をしている…？」
					PRINTFORMDW 磨弓が怒気を孕んだ表情で睨んでいる…
				;恥ずかしがる
				CASE 2,3
					SELECTCASE RAND:3
						CASE 0
							CALL HPH_PRINT,@"「あんっHPH」","L"
						CASE 1
							CALL HPH_PRINT,@"「きゃっHPH」","L"
						CASE 2
							CALL HPH_PRINT,@"「ひあぁっHPH」","L"
					ENDSELECT
					SELECTCASE RAND:3
						CASE 0
							PRINTFORML 「お、お前という奴は…！」
							PRINTFORMDW 磨弓は尻を手で隠しながら赤面している。
						CASE 1
							PRINTFORML 「ば…莫迦っ！」
							PRINTFORMDW 磨弓に頭を叩かれた…
						CASE 2
							PRINTFORML （おい！ここでは不味いだろう…！）
							PRINTFORMDW 磨弓が恥ずかしそうに耳打ちしてきた。
					ENDSELECT
				;されるがまま
				CASE 4
					SELECTCASE RAND:3
						CASE 0
							CALL HPH_PRINT,@"「んっ…HPHも…もっと…触ってほしい…HPH」","L"
							PRINTFORMDW 磨弓が甘えるように見つめてきた…！
						CASE 1
							CALL HPH_PRINT,@"「そ…そんなに…撫でるなぁ…っ…HPH」","L"
							PRINTFORMDW 言葉とは裏腹に、磨弓の抵抗は弱い。
						CASE 2
							CALL HPH_PRINT,@"（直接…触っても、いいんだぞ…？HPH）","L"
							PRINTFORMDW 磨弓が少し恥ずかしそうにしながら耳打ちしてきた…！
					ENDSELECT
			ENDSELECT
		ELSE
			SELECTCASE TFLAG:193
				;不快
				CASE 1
					PRINTFORML 「…お前は何をしているんだ？」
					PRINTFORMDW セクハラをしようと近付いたら、傍らにいた埴輪兵士に腕を掴まれた…
				;恥ずかしがる
				CASE 2,3
					SELECTCASE RAND:3
						CASE 0
							CALL HPH_PRINT,@"「あんっHPH」","L"
						CASE 1
							CALL HPH_PRINT,@"「きゃっHPH」","L"
						CASE 2
							CALL HPH_PRINT,@"「ひあぁっHPH」","L"
					ENDSELECT
					SELECTCASE RAND:2
						CASE 0
							PRINTFORML 「…何をするんだ！」
							PRINTFORMDW 磨弓はよほど恥ずかしかったのか、力を込めて頭を叩いてきた…
						CASE 1
							PRINTFORML 「…あまり調子に乗るなよ…！」
							PRINTFORMDW 磨弓に睨まれた…
					ENDSELECT
				;されるがまま
				CASE 4
					SELECTCASE RAND:2
						CASE 0
							PRINTFORML 「…いつまで触っているつもりだ…！」
							PRINTFORMDW 磨弓の声には怒気が篭っている…
						CASE 1
							PRINTFORML 「…～っ！！」
							IF TALENT:132:恋人 || TALENT:132:恋慕
								PRINTFORML （袿姫様の想い人でなければ、叩き切ってやれるのに…！）
							ELSE
								PRINTFORML （こいつ、調子に乗って…！）
							ENDIF
							PRINTFORMDW 磨弓は唇を噛み締めながら、%CALLNAME:MASTER%のセクハラを受け入れている…
					ENDSELECT
			ENDSELECT
		ENDIF
	ENDIF
ENDIF

RETURN 1
