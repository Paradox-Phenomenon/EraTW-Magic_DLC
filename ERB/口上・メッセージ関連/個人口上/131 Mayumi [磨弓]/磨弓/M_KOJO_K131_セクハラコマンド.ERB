@M_KOJO_MESSAGE_COM_K131_330_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;磨弓の場合は袴ずり下げになる（デフォルトの場合）
	IF FLAG:70
		;穿いてる
		IF TEQUIP:0 > 1
			PRINTFORMDW 磨弓の袴をずり下げ、下着の有無を確認した。
		;穿いてない
		ELSE
			PRINTFORMDW %CALLNAME:MASTER%が磨弓の袴をずり下げると、そこにある筈の下着は無かった…！
		ENDIF
	ELSEIF CFLAG:うふふ == 2
		CALL HPH_PRINT,@"「どうだ…？HPH全部、挿入ったぞ…HPH」","W"
	ELSE
		SELECTCASE TFLAG:193
			;ビンタ
			CASE -5
				PRINTFORML 「―っ！！」
				PRINTFORMDW %TEXTR("磨弓に思い切り頬を張ら/何処からか走ってきた埴輪兵士に殴り飛ばさ")%れた…
			;つねられる
			CASE -3
				PRINTFORML 「…次は無いと思えよ？」
				PRINTFORMDW %TEXTR("磨弓に手を思い切り/埴輪兵士に手の肉がちぎれると錯覚する程の強さで")%つねられた…
			;嫌がる
			CASE -1
				PRINTFORML 「な、何のつもりだ！？」
				PRINTFORMDW %TEXTR("磨弓は服を押さえて抵抗している/埴輪兵士が立ちはだかり、失敗に終わった")%…
			;嫌がる（嬉しげ）
			CASE 0
				PRINTFORML 「お、おい…！流石にここでは…！」
				PRINTFORMDW 磨弓は恥ずかしそうに服を押さえている…
			;成功
			CASE 1
				IF ABL:露出癖 <= 2
					;穿いてる
					IF TEQUIP:0 > 1
						PRINTFORML 「あっ！？な、何をする！！」
						PRINTFORMDW ほんの一瞬だけ、磨弓の下着が見えた…！
					;穿いてない
					ELSE
						PRINTFORML 「…！？…あ…あ…！」
						PRINTFORMDW 下着を履いていない事を%CALLNAME:MASTER%に知られ、磨弓は気が動転している…
					ENDIF
				ELSEIF ABL:露出癖 <= 4
					;穿いてる
					IF TEQUIP:0 > 1
						PRINTFORML 「な…何故私がこんな事をせねばならん…！」
						PRINTFORMDW 文句を言いつつも、磨弓は下着を見せてくれた…！
					;穿いてない
					ELSE
						PRINTFORML 「…悪いか！？私だって、好きでこんな格好をしてる訳じゃないんだぞ！！」
						PRINTFORMDW 泣きそうな顔で訴えかけてくる磨弓の迫力に気圧され、思わず謝罪してしまった…
					ENDIF
				ELSE
					;穿いてる
					IF TEQUIP:0 > 1
						CALL HPH_PRINT,@"「ほら…これで…良いだろう…？HPH」","L"
						PRINTFORMDW 磨弓は少し嬉しそうに、下着を見せてくれた…！
					;穿いてない
					ELSE
						CALL HPH_PRINT,@"「助平め…HPHじろじろ見すぎだ…HPH」","L"
						PRINTFORMDW 下着を付けていない磨弓の股座を、じっくりと視姦した…！
					ENDIF
				ENDIF
		ENDSELECT
	ENDIF
ENDIF
RETURN 1
