;40,ローター
;==================================================
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_MESSAGE_MESSAGECHECK_COM_K131_40
RETURN 0

@M_KOJO_MESSAGE_COM_K131_40
CALL M_KOJO_MESSAGE_COM_K131_40_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K131_40_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		PRINTFORMW 
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		PRINTFORMW 
		RETURN 1
	ELSE
		SELECTCASE RAND:5
			CASE 0
				CALL HPH_PRINT,@"「んんっHPH HPHあぁっHPHあ、ぐうぅっHPH HPH」","L"
				PRINTFORML 「た…頼む…！もう少し…弱めてくれぇ…」
				PRINTFORMDW 磨弓はローターを膣内に入れたまま、弱々しく懇願してきた…！
			CASE 1
				CALL HPH_PRINT,@"「んんっ…HPHうぅ…HPHあっHPHくぅ…！」","L"
				CALL HPH_PRINT,@"「こ…こんな機械なんかにぃ…HPH私が、負ける…かぁ…っ…HPH」","L"
				PRINTFORMDW 磨弓はローターがもたらす快感に抗っている。
			CASE 2
				PRINTFORML 「…おい…！」
				PRINTFORML 「前ならまだいいが、尻だけは止めろ…！」
				PRINTFORMDW アナルにローターを入れようとしたら睨まれた……
			CASE 3
				PRINTFORML 「まっ…！待て！そこは―」
				CALL HPH_PRINT,@"「ひゃああ゛ぁぁぁっHPH HPH HPH」","L"
				PRINTFORMDW クリトリスにローターを押し当てると、磨弓の身体が跳ね上がった。
			CASE 4
				CALL HPH_PRINT,@"「ひいっHPH HPH乳首…ぃ…HPHふるえるぅぅ…っHPH HPH」","L"
				PRINTFORMDW 磨弓の乳首にローターを押し当てた。
		ENDSELECT
	ENDIF
ENDIF
RETURN 1

