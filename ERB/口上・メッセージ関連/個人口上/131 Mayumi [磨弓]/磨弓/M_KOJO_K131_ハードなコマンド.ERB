;ハードな調教コマンド
;※※※※※※※※※※※※※※※※※※※※※※※※※
;==================================================
;140,イラマチオ
;==================================================
;==================================================
;Optional: Determines if the standard description should be skipped.
;Return 0 if description and KOJO should be shown, 1 if description should be hidden and KOJO shown, 2 if description should be shown and KOJO hidden, and 3 if both description and KOJO should be hidden.
;==================================================
@M_KOJO_MESSAGE_MESSAGECHECK_COM_K131_140
RETURN 0

@M_KOJO_MESSAGE_COM_K131_140
CALL M_KOJO_MESSAGE_COM_K131_140_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K131_140_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		IF FLAG:70
			PRINTFORMW 
			RETURN 1
		ELSE
			PRINTFORML 「…"いらまちお"…？何だそれは…？」
			PRINTFORML 「よく分からんが、咥えればいいんだな？」
			PRINTFORMDL 磨弓は%CALLNAME:MASTER%の前に跪くと、言われた通りにペニスを口に含む。
			PRINTFORMDL 上目遣いで次の指示を待つその表情を見て、嗜虐心がふつふつと湧いてきた…！
			PRINTFORML （…？何故、頭に手を回してっ―）
			PRINTFORML 「ごっ！？げ…ごっ！げふ！げふっ！」
			PRINTFORMDW 急に喉奥を刺激され磨弓は咳き込んでいるが、%CALLNAME:MASTER%は構わずに腰を突き動かし始めた…！
		ENDIF
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		PRINTFORMW 
		RETURN 1
	ELSE
		;今射精した
		IF NOWEX:PLAYER:11
			SELECTCASE RAND:3
				CASE 0
					CALL HPH_PRINT,@"「ぐぶっ…！ん゛ん…っ…！ず…お゛ぉーっHPH HPH」","L"
					PRINTFORMDL 喉奥を激しく突かれながらも、磨弓は口を窄めて射精を促してきた。
					PRINTFORMDW 酷い扱いをされても献身的に尽くしてくれる磨弓の為に、%CALLNAME:MASTER%はありったけの精を放った―
				CASE 1
					PRINTFORML 「じゅぶ…っ…ごぉ…っ…う……ぅ……！」
					PRINTFORMDL 激しい責めによる疲労からか、磨弓の目は虚ろになっている。
					PRINTFORMDW %CALLNAME:MASTER%が限界までペニスを押し込んで射精すると、磨弓の目はカッと見開かれた…
				CASE 2
					CALL HPH_PRINT,@"「ぐぅっ！げう゛っHPHごぼっ！ごふっ…げふっ…！」","L"
					PRINTFORMDL %CALLNAME:MASTER%が磨弓の頭を掴んで抽挿していると目が合った。
					PRINTFORMDW 涙と涎で酷く汚れた彼女の顔を見て、%CALLNAME:MASTER%の肉棒は更に大きく膨らんで―
			ENDSELECT
			RETURN 1
		;それ以外
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「…う゛ぅ…っ！ん゛んっ…！ごっ…！ん゛ぅ…！」
					PRINTFORMDW 磨弓はギュッと目を瞑り、行為が早く終わるのを待っている…
				CASE 1
					PRINTFORML 「う゛…ぐ、ぉ…っ！げっ…ぐ…っ！う゛ぇ…っ…！ごぉ…っ…！」
					PRINTFORMDW 磨弓は%CALLNAME:MASTER%の激しい抽挿を必死に耐えている。
				CASE 2
					PRINTFORML 「げふっ！ぐぶ…！ごっ…！ごほっ！…え゛ぇ…っ…！」
					PRINTFORMDW 磨弓は目尻に涙を浮かべながら嘔吐いている…！
			ENDSELECT
			RETURN 1
		ENDIF
	ENDIF
ENDIF
RETURN 1
