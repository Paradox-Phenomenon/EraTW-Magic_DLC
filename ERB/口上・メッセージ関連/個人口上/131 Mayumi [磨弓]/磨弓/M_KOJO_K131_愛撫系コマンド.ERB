						CALL HPH_PRINT,@"「～～っ！？HPH HPH HPH」","L"
						CALL HPH_PRINT,@"（なっ…？なんで、触られただけで、こんなに気持ちいいんだ…！？HPH）","L"
						PRINTFORMDW 挿入されながらの愛撫は、磨弓にとって強烈な刺激だったようだ。
				ENDSELECT
			ENDIF
			RETURN 1
		ENDIF
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		PRINTFORMW 
		RETURN 1
	;Ｃ感覚・Ｂ感覚が５以上
	ELSEIF ABL:Ｃ感覚 >= 5 && ABL:Ｂ感覚 >= 5
		SELECTCASE RAND:5
			CASE 0
				CALL HPH_PRINT,@"「はぁ…っ…HPHはぁ…HPH…ふうっ…HPH んっHPHんっ…♪ふふ…HPH」","L"
				PRINTFORMDW 磨弓の吐息がかかる程に密着しながら、彼女の肢体を愛撫した。
			CASE 1
				CALL HPH_PRINT,@"「ふぅ…♪ふっ…HPHんん…今日は…随分焦らしてくれるな…HPH」","L"
				PRINTFORMDW 磨弓のおねだりを聞くまでは、敢えて性感帯を避けて愛撫する事にした…
			CASE 2
				CALL HPH_PRINT,@"「んっ…あ…HPHはむ…っ…HPHんむ…HPH」","L"
				CALL HPH_PRINT,@"「はぁ…HPHはははっ…♪可愛い反応するじゃないか…HPH」","L"
				PRINTFORMDW 磨弓に耳たぶを甘噛みされ、思わず声を上げてしまった…
			CASE 3
				PRINTFORML 「あ…♪ん…っ…なあ…%CALLNAME:MASTER%…♪」
				CALL HPH_PRINT,@"「…こ…こっちは、触らなくて良いのか…？HPH」","L"
				PRINTFORMDW 磨弓は触ってほしそうに、胸を押し付けてきた…！
			CASE 4
				PRINTFORML 「ふふ…♪不思議なものだな…」
				CALL HPH_PRINT,@"「こうして…お前に触れられているだけで…んっHPH」","L"
				CALL HPH_PRINT,@"「ほら…HPHもう、こんなに…HPH」","L"
				PRINTFORMDW 磨弓が指を広げると、彼女の愛液がねっとりと糸を引いていた…！
		ENDSELECT
		RETURN 1
	;それ以外
	ELSE
		SELECTCASE RAND:5
			CASE 0
				CALL HPH_PRINT,@"「んっ…あ…！ふぅ…っ…♪んん…HPH」","L"
				PRINTFORMDW %CALLNAME:MASTER%が身体に触れる度に、磨弓は熱い吐息を漏らした。
			CASE 1
				CALL HPH_PRINT,@"「ひゃぁっHPHあ…っ…！うぅ…！」","L"
				PRINTFORML 「わ…笑うな！お前が急に触るから…！」
				PRINTFORMDW 可愛らしい声を上げた磨弓に、思わず笑みがこぼれた。
			CASE 2
				CALL HPH_PRINT,@"「んっ…HPHなあ…気が済んだなら、早く挿入れてほしいんだが…」","L"
				PRINTFORML 「…お…お前の…！…その…うぅ…！」
				PRINTFORMDW 磨弓はもどかしそうにモジモジしている。
			CASE 3
				CALL HPH_PRINT,@"「んん…HPHな、何なんだ…その…いやらしい触り方は…！」","W"
			CASE 4
				CALL HPH_PRINT,@"「んぅ…っ…HPHく…くすぐったい…♪」","L"
				PRINTFORMDW 磨弓は%CALLNAME:MASTER%の愛撫で、小さく身体を震わせている。
		ENDSELECT
		RETURN 1
	ENDIF
ENDIF
RETURN 1
