@M_KOJO_MESSAGE_COM_K131_0_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 0
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(SELECTCOM)
		PRINTFORMW 
		RETURN 1
	ENDIF
	;-------------------------------------------------
	;挿入中
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	;挿入中分岐
	IF LOCAL:1 && (TEQUIP:50 == PLAYER || TEQUIP:51 == PLAYER)
		;Ｃ＆Ｂ感覚が一定以上かつＶ挿入中ならＶ感覚５以上Ａ挿入中ならＡ感覚４以上
		IF ABL:Ｃ感覚 >= 5 && ABL:Ｂ感覚 >= 5 && ((TEQUIP:50 == PLAYER && ABL:Ｖ感覚 >= 5) || (TEQUIP:51 == PLAYER && ABL:Ａ感覚 >= 4))
			;射精した
			IF NOWEX:PLAYER:11
				CALL MAYUMI_SEX
			;それ以外
			ELSE
				SELECTCASE RAND:3
					CASE 0
						CALL HPH_PRINT,@"「あんっHPHこ、こらっ…♪お前はおまんこに集中しろ…HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「はっHPHはぁっHPHどう、だっ？HPH%CALLNAME:MASTER%っ？HPH」","L"
						CALL HPH_PRINT,@"「お前のおちんぽっHPHここまで、届いてるんだぞっHPH HPH」","L"
						PRINTFORMDW 磨弓のお腹に手を添えると、%CALLNAME:MASTER%の肉棒が膣内で激しく動いているのが分かった…！
					CASE 2
						CALL HPH_PRINT,@"「あぁっHPHひあっHPHあんっHPH HPH」","L"
						CALL HPH_PRINT,@"「%CALLNAME:MASTER%っHPHもっとHPHいっぱいさわってぇHPH HPH」","L"
						PRINTFORMDW 磨弓の肢体を愛撫しながら、激しい抽挿を続けた…！
				ENDSELECT
				
			ENDIF
			RETURN 1
		;それ以外
		ELSE
			;射精した
			IF NOWEX:PLAYER:11
				CALL MAYUMI_SEX
			;それ以外
			ELSE
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「ま…待て！今は―」
						CALL HPH_PRINT,@"「ひゃああぁっHPH HPH」","L"
						PRINTFORMDW 敏感になった磨弓の身体を愛撫した。
					CASE 1
						PRINTFORML 「ど…同時になんてそんなっ…！」
						CALL HPH_PRINT,@"「あんっHPHひあぁっHPH」","L"
