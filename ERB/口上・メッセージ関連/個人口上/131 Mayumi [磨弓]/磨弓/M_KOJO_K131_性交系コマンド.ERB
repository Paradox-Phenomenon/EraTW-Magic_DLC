			RETURN 1
		;アナル処女
		ELSEIF TCVAR:Ａ破瓜
			CALL MAYUMI_SEX
		ELSE
			CALL MAYUMI_SEX
		RETURN 1
		ENDIF
	ENDIF
	;-------------------------------------------------
	;挿入継続
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && TCVAR:101 == PLAYER
		IF ABL:Ａ感覚 >= 4
			;今射精した
			IF NOWEX:PLAYER:11
				SELECTCASE RAND:3
					CASE 0
						CALL HPH_PRINT,@"「ふっHPHふぅっHPHあぁ…HPHおちんぽ、膨らんできたぞぉ…？HPH」","L"
						CALL HPH_PRINT,@"「ほらっHPH早くだせHPHせいえきっHPHいっぱいだせぇっHPH HPH」","L"
						PRINTFORMDW 磨弓の激しい抽挿と腸壁の締め付けにより、%CALLNAME:MASTER%は呆気なく果ててしまった…！
					CASE 1
						CALL HPH_PRINT,@"「そろそろ射精そうか？HPH…よし…♪」","L"
						CALL HPH_PRINT,@"「ふぅ…んっ！ぐぅっHPHお゛おぉぉっ！？HPH HPH HPH」","L"
						PRINTFORMDL 磨弓はペニスが抜けるギリギリまで腰を浮かせた後、一気に腰を落としてきた。
						PRINTFORMDW 凄まじい快感により、%CALLNAME:MASTER%は頭が真っ白になって―
					CASE 2
						CALL MAYUMI_SEX
				ENDSELECT
				RETURN 1
			;前回射精した
			ELSEIF TCVAR:104
				SELECTCASE RAND:3
					CASE 0
						CALL HPH_PRINT,@"「は…っ…HPHあッ…HPHふぅ…♪」","L"
						PRINTFORMDL 磨弓は深呼吸したかと思うと、最後のひと押しとばかりに腰を激しく動かした…！
						CALL HPH_PRINT,@"「ひぁっHPH HPHも、もう次か！？HPH仕方ないな…HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「はぁーっHPHはぁーっHPH…はぁ…HPH」","L"
						PRINTFORML 「…つい興が乗り過ぎてしまった…さっきのは忘れてくれ…」
						PRINTFORMDW ペニスを挿入したまま振り返った磨弓に、"ああいう趣向も悪くない"と言った。
					CASE 2
						CALL MAYUMI_SEX
				ENDSELECT
				RETURN 1
			ELSE
				SELECTCASE RAND:3
					CASE 0
						CALL HPH_PRINT,@"「ふぅっHPHふぅっHPH%CALLNAME:MASTER%っHPHお前まさか、私の尻で感じてるのかっ？HPH」","L"
						CALL HPH_PRINT,@"「変態めぇっHPHこっちはおまんこと違って、気持ち良くなるための穴じゃないんだぞぉっHPH HPH」","L"
						PRINTFORMDW 磨弓の激しいピストンと言葉責めにより、射精感が近づいてきた…！
					CASE 1
						CALL HPH_PRINT,@"「このHPHこのぉっHPH変態おちんぽめぇっHPH HPH」","L"
						CALL HPH_PRINT,@"「こいつがっHPHこいつが私をおかしくしたんだぁっHPH HPH」","L"
						PRINTFORMDL 磨弓は%CALLNAME:MASTER%のペニスに恨み節をぶつけながら腰を上下させている。
						PRINTFORMDW 声色から察するに、快楽のスパイスにしかなっていないようだ…！
					CASE 2
						CALL MAYUMI_SEX
				ENDSELECT
				RETURN 1
			ENDIF
		ELSE
			;今射精した
			IF NOWEX:PLAYER:11
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「はぁ…！はぁ…！ぐぅ…っ…！も、もう…動けん…！」
						PRINTFORMDL こちらの絶頂が近くなってきたタイミングで、磨弓の抽挿が緩慢になってきた。
						PRINTFORMDL このまま生殺しにされるのも辛い…%CALLNAME:MASTER%は磨弓の腰を掴んだ―
						CALL HPH_PRINT,@"「ひぐうぅっ！？HPH HPHまっ…！%CALLNAME:MASTER%っHPHそんなにっHPHついたらぁっHPH HPH」","W"
					CASE 1
						CALL HPH_PRINT,@"「ぐっ…！お…っ…HPHわ、私の…なか、でっ…！おお、き、くうぅ…っ…HPH」","L"
						PRINTFORMDL 磨弓はラストスパートと言わんばかりに抽挿を早めた。
						PRINTFORMDW %CALLNAME:MASTER%は快楽に身を任せ、磨弓の尻奥へと射精した―
					CASE 2
						CALL MAYUMI_SEX
				ENDSELECT
				RETURN 1
		;前回射精した
			ELSEIF TCVAR:104
				SELECTCASE RAND:3
					CASE 0
						CALL HPH_PRINT,@"「はぁ…HPHはぁ…HPHあぁっ…HPHあ、あぁ…HPH」","L"
						PRINTFORMDL 尻に精液を流し込まれる度、磨弓の肢体は小さく跳ね上がる。
						PRINTFORMDW 腸壁の振動でペニスが刺激され、再び硬さを取り戻した…！
					CASE 1
						CALL HPH_PRINT,@"「ぐ…っHPH精液、が…！いっぱいぃ…HPH」","L"
						PRINTFORMDL 尻奥に射精される感覚に、磨弓は身震いしている。
						PRINTFORMDW %CALLNAME:MASTER%と目が合った磨弓はこちらの心情を察してくれたようで、ゆるゆると抽挿を再開した…！
					CASE 2
						CALL MAYUMI_SEX
				ENDSELECT
				RETURN 1
			ELSE
				SELECTCASE RAND:3
					CASE 0
						PRINTFORML 「ふーっ…！ふーっ…！も、もっと速くだと！？」
						CALL HPH_PRINT,@"「無茶を言うな！これでも…っ…HPH精一杯なんだぞぉ…っ…！」","L"
						PRINTFORMDW ゆっくりとした磨弓の抽挿が、もどかしい刺激を与えてくる…！
					CASE 1
						CALL HPH_PRINT,@"「はぁ…っ…HPHあぁ…っ！う、くぅ…っ…！」","L"
						PRINTFORML （音が漏れて…っ…！恥ずかしいっ…！）
						PRINTFORMDL 磨弓の腰の動きが、少し緩慢になってきた。
						PRINTFORMDW どうやら抽挿の度に尻から漏れる空気音が、彼女の羞恥心を刺激しているようだ…！
					CASE 2
						CALL MAYUMI_SEX
				ENDSELECT
			ENDIF
			RETURN 1
		ENDIF
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		PRINTFORMW 
		RETURN 1
	;Ａ感覚４以上
	ELSEIF ABL:Ａ感覚 >= 4
		SELECTCASE RAND:2
			CASE 0
				CALL HPH_PRINT,@"「んっ…HPH少し…待っていろ…♪」","L"
				CALL HPH_PRINT,@"「こいつには、入念な準備が必要だからな…HPH」","L"
				PRINTFORMDL 磨弓は膣穴から垂れる愛液を、自らの尻穴へと塗りたくっている。
				PRINTFORMDL 扇情的な行為を見せつけられ、%CALLNAME:MASTER%のペニスはみるみる勃起していく…！
				CALL HPH_PRINT,@"「ふ…♪お前も、準備万端のようだな…HPHそれじゃあ…っ…！」","L"
				CALL HPH_PRINT,@"「―ぐぉっ…HPHあ、ふ…HPHふぅぅーっ…HPH HPH」","W"
			CASE 1
				CALL HPH_PRINT,@"「%CALLNAME:MASTER%…HPH挿入れる所、ちゃんと見ていてくれよ…っ…HPH」","L"
				CALL HPH_PRINT,@"「ぐ…っ…HPH…すぅ…っ…ふんっ！！」","L"
				CALL HPH_PRINT,@"「あ゛ああぁぁーーっHPH HPH HPH」","L"
				PRINTFORMDL 磨弓は体重をかけ、ペニスを一息で奥まで挿入した。
				PRINTFORMDW 普段の彼女からは想像もできない雄叫びと共に、強烈な締め付けが襲ってきた…！
		ENDSELECT
	RETURN 1
	;それ以外
	ELSE
		SELECTCASE RAND:2
			CASE 0
				PRINTFORML 「んっ…くぅ…！ぃ…あっ―」
				CALL HPH_PRINT,@"「あぁぁっHPH HPH…はぁっ…！はぁっ…！は、はいった…のか…？」","L"
				PRINTFORMDL 磨弓は腰を落とし、尻穴に挿入する事に成功した。
				PRINTFORMDW 流石に動くのにはまだ慣れないようで、馴染むまで少し待つ事にした…
			CASE 1
				PRINTFORML 「くぅっ…！尻穴に、しかも自分から挿入れれろだとぉっ…！？」
				PRINTFORML 「…お前の頼みでなければ、こんな…んんっ…ことっ…！」
				PRINTFORMDL 磨弓が挿入しようと奮闘しているが、やはり上手くいかないようだ。
				PRINTFORMDL %CALLNAME:MASTER%は磨弓の腰を掴み、補助をする事にした。
				PRINTFORML 「あっ！？待て！まだ準備っ―」
				CALL HPH_PRINT,@"「ひぃぐぅうぅっHPH HPH」","W"
		ENDSELECT
		RETURN 1
	ENDIF
ENDIF
