				CASE 0
					CALL HPH_PRINT,@"「んんっHPHじゅっHPHん…んんぅーーっHPH HPH」","L"
					PRINTFORMDL 磨弓の腰をしっかりと掴み、膣内を舐め回す。
					PRINTFORMDW %CALLNAME:MASTER%の激しい責めに絶頂したようだが、磨弓はペニスから口を離す事はなく―
				CASE 1
					CALL HPH_PRINT,@"「んんっ…HPHは…っ…♪ふ、うぅっ…HPH」","L"
					CALL HPH_PRINT,@"（%CALLNAME:MASTER%が舐めてくれている…HPH私も応えねば…！）","L"
					CALL HPH_PRINT,@"「あ…はむっHPHんっHPHちゅぷHPHぢゅ、ぼぉぉっHPH HPH」","L"
