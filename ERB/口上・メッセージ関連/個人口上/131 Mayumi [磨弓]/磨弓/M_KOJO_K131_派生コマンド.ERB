					CALL HPH_PRINT,@"「ちゅぷっ…HPHぢゅ…HPHんん…っ…HPHじゅるぅ…HPH」","L"
					PRINTFORMDW 膣壁を舐められ、磨弓のフェラチオが一瞬止まった。
				CASE 2
					CALL HPH_PRINT,@"「…ぷはっHPHやめっHPH%CALLNAME:MASTER%っHPH」","L"
					CALL HPH_PRINT,@"「そんなに激しくされたら、舐められないだろぉっHPH HPH」","L"
