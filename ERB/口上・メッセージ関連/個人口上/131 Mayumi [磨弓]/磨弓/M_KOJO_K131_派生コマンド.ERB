	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(TFLAG:50 + 500)
		PRINTFORMW 
		RETURN 1
	ENDIF
	;基本セット
	;時姦中
	IF FLAG:70
		PRINTFORMW 
		RETURN 1
	ELSEIF ABL:胸 >= 2
	;胸技術２以上
		;今射精した
		IF NOWEX:PLAYER:11
			SELECTCASE RAND:3
				CASE 0
					CALL HPH_PRINT,@"「%CALLNAME:MASTER%っHPHもう、少しだからっHPH我慢してくれぇHPH HPH」","L"
					CALL HPH_PRINT,@"「私も…HPH私も、頑張るから…あぁっHPH HPH」","L"
					PRINTFORMDW 磨弓の柔らかい太腿と胸が押し付けられ、包み込まれるような快感の中で射精した―
				CASE 1
					CALL HPH_PRINT,@"「%CALLNAME:MASTER%っHPHおちんぽ、もうイキそうか？HPH」","L"
					CALL HPH_PRINT,@"「んっHPH HPHわ、私も…♪も、もう…HPH HPH」","L"
					PRINTFORMDW 顔に温かい液体が降りかかる感触と同時に、%CALLNAME:MASTER%は射精した…！
				CASE 2
					SELECTCASE RAND:3
						CASE 0
							CALL HPH_PRINT,@"「%CALLNAME:MASTER%、イキそうなのか？よし…HPH」","L"
							PRINTFORMDW %CALLNAME:MASTER%の射精が近い事を察した磨弓は、乳房の動きを更に早めた…！
						CASE 1
							CALL HPH_PRINT,@"「おちんぽがぱくぱくしてきたぞ…♪もう射精そうなんだな？HPH」","L"
							CALL HPH_PRINT,@"「どうする？飲んでやろうか？HPHそれとも顔にかけるかっ？HPH」","L"
							PRINTFORMDW 磨弓の巧みなパイズリにより、呆気なく果ててしまった―
						CASE 2
							CALL HPH_PRINT,@"「お前の好きな時に…っ…♪射精していいからな…HPH」","L"
							PRINTFORMDW 磨弓の柔らかい双房に包まれ、心地よい感覚と共に射精した―
					ENDSELECT
			ENDSELECT
			RETURN 1
		;それ以外
		ELSE
			SELECTCASE RAND:3
				CASE 0
					CALL HPH_PRINT,@"「あうっHPH HPHこ…これくらいでは、私は止まらんぞ…♪」","L"
					PRINTFORMDW 磨弓は%CALLNAME:MASTER%に秘所を舐められながらパイズリをしている…！
				CASE 1
					CALL HPH_PRINT,@"「ふふ…♪どうした%CALLNAME:MASTER%？早く、おまんこ気持ちよくしてくれ…HPH」","L"
					CALL HPH_PRINT,@"「それとも…おっぱいが気持ち良すぎて動けないのか？HPH」","L"
					PRINTFORMDW 磨弓の巧みなパイズリに耐えながら、目の前の秘裂へと舌を伸ばした…！
				CASE 2
					CALL HPH_PRINT,@"「んっ…HPHふぅ…♪う、あっHPHま、負けるか…！」","L"
					PRINTFORMDW 絶頂を堪えながら、互いの性器を愛撫し合った…！
			ENDSELECT
		ENDIF
	ELSE
		;今射精した
		IF NOWEX:PLAYER:11
			SELECTCASE RAND:3
				CASE 0
					CALL HPH_PRINT,@"「んんっHPHふっ…うぅっHPH」","L"
					PRINTFORML （こ、このままでは…私だけが一方的に…！）
					CALL HPH_PRINT,@"「ふっ…！くぅっ…HPHああぁぁっ！HPH」","L"
					PRINTFORMDL 磨弓はペニスを乳房で挟んだり擦ったりと、がむしゃらに責め立ててくる。
					PRINTFORMDW "何とか自分より先に絶頂させてやる"とでもいうようないじらしさが、%CALLNAME:MASTER%の劣情を更に昂らせた…！
				CASE 1
					CALL HPH_PRINT,@"「%CALLNAME:MASTER%…HPHこのまま…胸に射精してくれ…HPH」","L"
					CALL HPH_PRINT,@"「わ…私もっ…HPHうっ…あぁっHPH HPH」","L"
					PRINTFORMDW 磨弓の潮を顔に受けながら、%CALLNAME:MASTER%は射精した―
				CASE 2
					SELECTCASE RAND:3
						CASE 0
							PRINTFORML 「ふ…んんっ…！もっと早く…？こう…か…！？」
							PRINTFORMDW 磨弓は先程よりも強く胸で挟んで擦り上げてきた…！
						CASE 1
							PRINTFORML 「%CALLNAME:MASTER%、出そうなのか…！？」
							PRINTFORML 「しかし…これでは両手が使えん、どうすれば…？」
							PRINTFORMDW 磨弓が迷っている間に、%CALLNAME:MASTER%は射精した…！
						CASE 2
							PRINTFORML （%CALLNAME:MASTER%…気持ち良さそうだな…♪）
							PRINTFORML （胸など、戦いの邪魔でしかないと思っていたが…%CALLNAME:MASTER%が喜んでいるなら―）
							PRINTFORML 「…うわっ！？」
							PRINTFORMDW パイズリに夢中になっていた磨弓は、%CALLNAME:MASTER%の射精が近い事に気が付かなかったようだ…
					ENDSELECT
			ENDSELECT
			RETURN 1
		;それ以外
		ELSE
			SELECTCASE RAND:3
				CASE 0
					PRINTFORML 「…うぅ…！胸で擦りながら股を押し付けるなんて、変態みたいじゃないか…！」
					PRINTFORMDW 磨弓は文句を言いながらも、パイズリをしてくれている。
				CASE 1
					PRINTFORML 「む…胸でするのは…以外と難しいな…！」
					CALL HPH_PRINT,@"「あんっHPHこ、こら！急に舐めるな！」","W"
				CASE 2
					CALL HPH_PRINT,@"「んうぅっHPH HPHそ、そんなに吸われたら…出来ない…だろぉ…！」","L"
					PRINTFORMDW %CALLNAME:MASTER%にクリトリスを吸われた為か、磨弓のパイズリが止まってしまった…
			ENDSELECT
		ENDIF
	ENDIF
ENDIF
