						PRINTFORMDW %CALLNAME:MASTER%も負けじと腰を奥まで捩じ込み、精液を放出した…！
					CASE 2
						CALL HPH_PRINT,@"「あ゛ぁっHPH HPH%CALLNAME:MASTER%っHPHそれだめっHPHイクっHPHイってしまうぅっHPH HPH」","L"
						CALL HPH_PRINT,@"「イクっHPHイクっHPHイっ…あ゛あぁぁあーーっHPH HPH HPH」","L"
						PRINTFORMDW 磨弓が絶頂を迎えた瞬間…子宮口が亀頭に吸い付き、精液を搾り取ろうと収縮した―
				ENDSELECT
			;それ以外
			ELSE
				SELECTCASE RAND:3
					CASE 0
						CALL HPH_PRINT,@"「う゛おぉあ゛あぁぁーーっHPH HPH HPH」","L"
						PRINTFORMDW 子宮内にペニスが侵入し、磨弓は絶叫するように喘いでいる…！
					CASE 1
						CALL HPH_PRINT,@"「かはっHPH HPH…っHPH…ぁ…HPHぉっHPH HPH」","L"
						PRINTFORMDW 子宮を激しく犯され、磨弓は声にならない声で喘いでいる…！
					CASE 2
						CALL HPH_PRINT,@"「あぎいぃっHPH HPHは…あぁ…HPH」","L"
						CALL HPH_PRINT,@"「%CALLNAME:MASTER%分かるか…？HPHおちんぽが、子宮に挿入ってるぞ…HPH」","L"
						PRINTFORMDW 子宮口に亀頭をキュウキュウと締め上げられ、思わず射精しそうになった…！
				ENDSELECT
			ENDIF
		;それ以外
		ELSE
			;今射精した
			IF NOWEX:PLAYER:11
				SELECTCASE RAND:3
					CASE 0
						CALL HPH_PRINT,@"「ぐ…あぁっHPH HPHそんな、押し付けたら…あぁ…HPH HPH」","L"
						PRINTFORMDW 磨弓の子宮に亀頭を密着させながら射精した…！
					CASE 1
						CALL HPH_PRINT,@"「あぐぅっHPH HPH%CALLNAME:MASTER%…！む、無理…だ…！これ以上、はぁっHPH」","L"
						PRINTFORMDL 磨弓と限界まで密着するように腰を突き動かした。
						PRINTFORMDW 亀頭にコツコツと何かが当たるのを感じながら射精した…！
					CASE 2
						CALL HPH_PRINT,@"「んうぅっHPH HPHま、まってぇ…！HPH」","L"
						CALL HPH_PRINT,@"「それ、いじょう…はいら、な…あぁっHPH HPH」","L"
						PRINTFORMDW ペニスを子宮の中に突き入れる様な勢いで腰を押し込んだ―
				ENDSELECT
			;それ以外
			ELSE
				SELECTCASE RAND:3
					CASE 0
						CALL HPH_PRINT,@"「うぐっ…！うぅ…HPHくる、し…！」","L"
						PRINTFORMDW 子宮を押し潰すような勢いで、%CALLNAME:MASTER%は激しく腰を突き動かした。
					CASE 1
						PRINTFORML 「あぐぅ…！い、たい…！そんなに…押し付けるなぁ…っ…！」
						PRINTFORMDW ペニスが子宮に当たっているのか、磨弓は苦しそうな表情をしている…
					CASE 2
						PRINTFORML 「ぐぅ…っ…！う…うぅ…！」
						PRINTFORML 「うぇ…っ…！げほっ！げほっ…！」
						PRINTFORMDL 磨弓の子宮を、ペニスでこじ開けるように犯していく。
						PRINTFORMDW 体内を圧迫された為か、磨弓は激しく咳き込んでいる…
				ENDSELECT
			ENDIF
		ENDIF
