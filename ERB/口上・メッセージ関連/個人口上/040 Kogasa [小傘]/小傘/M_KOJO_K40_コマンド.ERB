;415,招待吃飯
;==================================================
@M_KOJO_MESSAGE_COM_K40_415
CALL M_KOJO_MESSAGE_COM_K40_415_1
RETURN RESULT

@M_KOJO_MESSAGE_COM_K40_415_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL && !FLAG:70 
	;初めて
	IF FIRSTTIME(415)
		PRINTFORMW 「诶？　你想让我也吃吗？」
		PRINTFORMW 「嗯、可以、但是……我不太了解人类的食物哦」
		PRINTFORMW 「所以那个……不要期待哦？」
		PRINTFORMW 「那我就不客气了……啊…、嗯……」
		;失敗
		IF TFLAG:193 == -1
			PRINTFORMW 「嗯…、嗯……」
			PRINTFORMW 「嗯、不行。果然我还是不能吃人类的食物。」
		;讨厌的味道
		ELSEIF TCVAR:MASTER:308 | 60
			PRINTFORMW 「嗯……哇！」
			PRINTFORMW 「……」
			PRINTFORMW 「嘛、嘛、不是很好吃吗……是吗？」
			PRINTFORMW 「你看、%CALLNAME:MASTER%也尝一下……」
			PRINTDL  
			PRINTFORMDW 这样说着、小伞悄悄地把食物还给了我……
			PRINTFORMDW 虽然觉得可疑……%CALLNAME:MASTER%还是把它送到了自己的嘴里……
			PRINTDL  
			PRINTFORMDW …
			PRINTFORMDW ……
			PRINTFORMDW ………
			PRINTDL  
			PRINTFORMDL 无法忍受来自拒绝消化有害物质的消化器官的強酸性有機物涌上、
			PRINTFORMDW 吐在地板上的%CALLNAME:MASTER%。
			PRINTFORMDW 回头一看、小伞的表情就像打破了紧張、忍耐着痛苦也要做的那样。
			PRINTDL  
			PRINTFORMW 「哈啊……哈啊……怎么样、我赢了……」
			PRINTFORMW 「呵呵、给、水……装出若无其事的样子……好痛苦啊」
		;好みの味
		ELSEIF TCVAR:MASTER:308 == 1
			PRINTFORMW 「嗯……啊啦、不是很好吃吗！？」
			PRINTFORMW 「迄今为止、人类的食物、味道都是淡而无味的、不过呢」
			PRINTFORMW 「我知道%CALLNAME:MASTER%给我做的这个很好吃、我知道了哟」
		;普通の味
		ELSE
			PRINTFORMW 「嗯、嗯……好吃……是吗？」
			PRINTFORMW 「那个、我不太清楚。对不起……」
			PRINTFORMW 「果然还是吓我一跳比较好吧」
		ENDIF
	;２回目以降
	ELSE
		;恋慕
		IF TALENT:恋慕
			PRINTFORMW 「嗯、谢谢。虽然光是这份心意、就让我觉得很饱了」
			PRINTFORMW 「但是是好不容易给我做的、我就收下了♪」
		;恋慕で無い
		ELSE
			PRINTFORMW 「你还想让我吃吗？　我觉得应该有更合适的人」
			PRINTFORMW 「但是如果是为了我而做的话、那会很开心吧……我开动了♪」
		ENDIF
		
		PRINTFORMW 「嗯…、啊呣……呜、呜嗯……」
		
		;失敗か讨厌的味道
		IF TFLAG:193 == -1 || (TCVAR:MASTER:308 | 60)
			IF RAND:3 == 0
				PRINTFORMW 「……呜！？」
				PRINTFORMW 「……」
				PRINTFORMW 「吃着这样的东西活下去……」
				PRINTFORMW 「现在我真的觉得、能作为吃人心活下去的妖怪真是太好了」
			ELSEIF RAND:2
				PRINTFORMW 「……」
				PRINTFORMW 「这难道是、让人吓一跳的讲座吗？」
				PRINTFORMW 「但是、不吃的话就没有意义了呢～」
			ELSE
				PRINTFORMW 「哈呣哈呣……嗯～？」
				PRINTFORMW 「那个、你不是打算开玩笑说这就是最近很流行的“吃土”吗？」
			ENDIF
		;好みの味
		ELSEIF TCVAR:MASTER:308 == 1
			PRINTFORMW 「嗯、很好吃啊……非常美味」
			PRINTFORMW 「果然还是喜欢%CALLNAME:MASTER%的味道啊」
			PRINTFORMW 「太好吃了、吓了我一跳。」
			PRINTFORMW 「我吓了一跳、但%CALLNAME:MASTER%却在工作上吓了一跳。总觉得很尊敬啊」
		;普通の味
		ELSE
			PRINTFORMW 「嗯、很好吃……」
			PRINTFORMW 「……我是这么想的、大概」
			PRINTFORMW 「果然我还是不太明白人的食物的味道。」
			PRINTFORMW 「这样说虽然有点什么、但是不是为我、而是为别的女孩做比较好呢」
		ENDIF
	ENDIF
ENDIF
RETURN 1
