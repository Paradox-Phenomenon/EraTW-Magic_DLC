LOCAL:3 = RAND:2
$LOOP_JYANKEN
PRINTFORMDL 『布！｣
LOCAL:1 = RAND:3
;MASTER勝ち
IF LOCAL:3 == 0
	LOCAL:2 = LOCAL:3 + 1
;MASTER負け
ELSE
	LOCAL:2 = LOCAL:3 + 2
ENDIF
LOCAL:2 = LOCAL:2 % 3
PRINTFORM %CALLNAME:MASTER%的手：
;石头
IF LOCAL:1 == 0
	PRINTFORMDL 石头
;剪刀
ELSEIF LOCAL:1 == 1
	PRINTFORMDL 剪刀
;布
ELSE
	PRINTFORMDL 布
ENDIF
PRINTFORM 小伞的手：
;石头
IF LOCAL:2 == 0
	PRINTFORMDL 石头
;剪刀
ELSEIF LOCAL:2 == 1
	PRINTFORMDL 剪刀
;布
ELSE
	PRINTFORMDL 布
ENDIF
PRINTFORMDL 看这边——指！

LOCAL:1 = RAND:4
IF LOCAL:3 == 0
	PRINTFORM %CALLNAME:MASTER%的指向：
ELSE
	PRINTFORM 小伞的指向:
ENDIF

IF LOCAL:1 == 0
	PRINTFORMDL ↑
ELSEIF LOCAL:1 == 1
	PRINTFORMDL ←
ELSEIF LOCAL:1 == 2
	PRINTFORMDL →
ELSE
	PRINTFORMDL ↓
ENDIF
IF LOCAL:3 == 0
	PRINTFORM 小伞的脸转向：
ELSE
	PRINTFORM %CALLNAME:MASTER%的脸转向：
ENDIF
IF LOCAL:1 == 0
	PRINTFORMDL ↑
ELSEIF LOCAL:1 == 1
	PRINTFORMDL ←
ELSEIF LOCAL:1 == 2
	PRINTFORMDL →
ELSE
	PRINTFORMDL ↓
ENDIF
;MASTERの勝ち
IF LOCAL:3 == 0
	RETURN 1
;小伞の勝ち
ELSE
	RETURN 2
ENDIF
;異常終了
RETURN 0

@TS_K40, ARG
#FUNCTION
#DIM TIME_STAMP,1000
;TS:Time Stamp. Trans Sexualではありません。残念。
;その日の初回実行時に時間を記憶し1を返すと、以後一定時間立つまで0を返す。那之后、1を返し繰り返す。
;長文が列挙してる使用頻度の高い口上を、定期的にのみ長文がでるようにするのが目的。
;ARGには指令番号、またはCounter照合番号を要求する

;特殊な番号
;900番台:カウンタ口上　TCVAR:354+900
;800番台:射精、絶頂関連
;

;一定時間の指定
;6時間
TIME_STAMP:500 = 60 * 6

;今日一度もタイムスタンプが切られていないなら、TIME_STAMPを初期化
IF TCVAR:356 == 0
	VARSET TIME_STAMP
	TCVAR:356 = 1
ENDIF
;今日、まだタイムスタンプが切られていない場合
IF TIME_STAMP:ARG == 0
	;0時丁度の場合、00:01分扱いに
	IF TIME == 0
		TIME_STAMP:ARG = 1
	;現在時刻でタイムスタンプを切る
	ELSE
		TIME_STAMP:ARG = TIME
	ENDIF
	RETURNF 1
;タイムスタンプが切られてから一定時間後
ELSEIF TIME > TIME_STAMP:ARG + TIME_STAMP:500
	IF TIME == 0
		TIME_STAMP:ARG = 1
	ELSE
		TIME_STAMP:ARG = TIME
	ENDIF
	RETURNF 1
;日を跨いだ場合
ELSEIF (TIME < TIME_STAMP:0) && TIME > TIME_STAMP:ARG + TIME_STAMP:500 - 60 * 24
	IF TIME == 0
		TIME_STAMP:ARG = 1
	ELSE
		TIME_STAMP:ARG = TIME
	ENDIF
	RETURNF 1
ELSE
	RETURNF 0
ENDIF