;==================================================
;60,掏耳朵
;==================================================
@M_KOJO_MESSAGE_SCOM_K40_60
CALL M_KOJO_MESSAGE_SCOM_K40_60_1
RETURN RESULT
@M_KOJO_MESSAGE_SCOM_K40_60_1
;-------------------------------------------------
;記入チェック（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL && !FLAG:70 
	;-------------------------------------------------
	;小分岐
	;-------------------------------------------------
	;初めて
	;記入チェック
	LOCAL:1 = 1
	;-------------------------------------------------
	IF LOCAL:1 && FIRSTTIME(TFLAG:50 + 500)
		PRINTFORMW 「嗯……你想让我掏耳朵吗？」
		PRINTFORMW 「那个……我从来没做过掏耳朵的事……呢」
		PRINTFORMW 「而且、虽然我也隐约察觉到了、但是我不擅长这样细微的动作……」
		PRINTFORMW 「那个……不管发生什么都不要恨我哦？」
		PRINTFORMW 「嗯……」
		;失敗
		IF TFLAG:193 == -1
			PRINTDL  
			PRINTDW …
			PRINTDW ……
			PRINTDW ……
			PRINTDW 啊ー！
			PRINTDW ＼哔啾！／
			PRINTDL  
			PRINTFORMW 「哇……耳朵上的洞第一次捅进去的话会和破瓜一样出血诶」
			PRINTFORMW 「诶？　虽说这是我第一次给%CALLNAME:MASTER%掏耳朵……」
			PRINTFORMW 「%CALLNAME:MASTER%以前也应该有过掏耳朵的经历……嗯这不对啊！？」
			PRINTFORMW 「稍等一下%CALLNAME:MASTER%、莫西莫～西！　听到了吗！？」
			PRINTDL  
			PRINTFORMDW 听到小伞的呼唤是从趴在膝盖上的另一边的耳朵里传来的……
		;成功
		ELSE
			PRINTDL  
			PRINTFORMDW 有点凉丝丝的耳语走进了%CALLNAME:MASTER%的耳洞里。
			PRINTFORMDW 即使不触碰墙壁、也能传达触感……毛骨悚然。
			PRINTFORMDW 轻轻地触摸墙壁、像传递一样慢慢地传上去……浑身颤抖不止、好舒服。
			PRINTFORMDW 虽然有种不习惯的感觉、但是小伞很小心地帮%CALLNAME:MASTER%打扫了耳朵。
		ENDIF
		RETURN 1
	ENDIF
	;基本セット
	;恋慕
	IF TALENT:恋慕
		;失敗
		IF TFLAG:193 == -1
			PRINTFORMW 「呼呼、看起来很大♪」
			PRINTFORMW 「我会努力争取的……如果成功的话、可以取得比现在多出一倍的量、所以请不要动。」
			PRINTDL  
			PRINTFORMDW 从小伞的耳语中感觉就像相当习惯一样……即使如此、也无法消除%CALLNAME:MASTER%的不安。
			PRINTFORMDW 细小的震动也会使耳孔更加敏感……这样的话耳朵会变得很舒服、虽然到那为止还不错……
			PRINTDL  
			PRINTDW …
			PRINTDW ……
			PRINTDW ………
			PRINTDW 哦吼噢噢！
			PRINTDW ＼哔啾！／
			PRINTDL  
			PRINTFORMW 「嗯？　搞错了吗？」
		;成功
		ELSE
			PRINTFORMW 「看～啊、插入%CALLNAME:MASTER%的耳朵里吧……」
			PRINTFORMW 「（为了让耳垢看起来更清楚）黑色的(为了能很好地去除耳垢)粗粗的棒子会把%CALLNAME:MASTER%的耳朵扩張哟」
			PRINTFORMW 「看、唔呼呼呼♪　呼呼、我会帮你弄出来很多（指耳垢）的♥」
			PRINTDL  
			PRINTFORMDW 与粗暴的说法相反、小伞把插在耳洞里的棉棒咕噜咕噜地转来绕去试图缠绕耳垢。
			PRINTFORMDW 敏感的耳朵黏膜上纤维摩擦的触感中也能感受到小伞的温柔……很舒服。
			PRINTFORMDL 事故比挖耳勺少、小伞也快乐地凌辱着%CALLNAME:MASTER%的耳洞、
			PRINTFORMDW 我觉得偶尔用棉棒帮%CALLNAME:MASTER%打扫一下耳朵也不错呢。
		ENDIF
		RETURN 1
	;それ以外
	ELSE
		PRINTFORMW 「掏耳朵？　嗯、好啊」
		PRINTFORMW 「拜托我什么的、%CALLNAME:MASTER%也真是好事之徒呢」
		RETURN 1
	ENDIF
ENDIF
