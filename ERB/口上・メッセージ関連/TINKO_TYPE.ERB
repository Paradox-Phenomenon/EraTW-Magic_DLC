;-------------------------------------------------
;函数名:TINKO
;概　要:二番煎じ上等
;参　数:ARG…角色登录番号；ARG:1…有定语
;返回值:
;备　考:文中函数
;使用例:%TINKO(PLAYER)%
;-------------------------------------------------
@TINKO(ARG, ARG:1=1, ARG:2=0, ARG:3=0)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
VARSET LOCALS
SIF !ARG
	ARG = MASTER
;可能需要污物描写开关
[SKIPSTART]
;1 (第 0 位) + 4 (第 2 位) + 8 (第 3 位) + 64 (第 6 位) = 77
SIF STAIN:ARG:2 & 77
	LOCALS += "粘上"
IF GETBIT(STAIN:ARG:2,6)
	LOCALS = 破瓜血
	LOCAL ++
ENDIF
IF GETBIT(STAIN:ARG:2,3)
	SIF LOCAL
		LOCALS += "、"
	LOCALS += "肠液"
	LOCAL ++
ENDIF
IF GETBIT(STAIN:ARG:2,2)
	SIF LOCAL
		LOCALS += "、"
	LOCALS += "精液"
	LOCAL ++
ENDIF
IF GETBIT(STAIN:ARG:2,0)
	SIF LOCAL
		LOCALS += "、"
	LOCALS += "爱液"
	LOCAL ++
ENDIF
SIF LOCAL
	LOCALS += "，"
[SKIPEND]
;概率で形容词がつく
IF ARG:1
	IF !RAND:4 && ARG == MASTER && TCVAR:ARG:100 != TARGET && TCVAR:ARG:101 != TARGET
		IF BASE:ARG:勃起 > 1000 
			SELECTCASE RAND:4
				CASE 0
					LOCALS += "凶猛翘起的"
				CASE 1
					LOCALS += "不断滴落着前列腺液的"
				CASE 2
					LOCALS += "浮现血管的"
				CASE 3
					LOCALS += "散发浓烈精臭的"
			ENDSELECT
		ELSEIF BASE:ARG:勃起 > 500
			SELECTCASE RAND:3
				CASE 0
					LOCALS += "抬起头的"
				CASE 1
					LOCALS += "硬度渐增的"
				CASE 2
					LOCALS += "半勃起的"
			ENDSELECT
		ELSE
			LOCALS += "还很柔软的"	
		ENDIF
	ELSEIF !RAND:3
		SELECTCASE TALENT:ARG:形状
			CASE 1
				;未熟
				SELECTCASE RAND:3
					CASE 0
						LOCALS += "可爱的"
					CASE 1
						LOCALS += "小孩子的"
					CASE 2
						LOCALS += "尚未成熟的"
				ENDSELECT
			CASE 2
				;粗末
				LOCALS += "寒酸的"
			CASE 3
				;普通
				LOCALS += "健壮的"
			CASE 4
				;光る
				SELECTCASE RAND:3
					CASE 0
						LOCALS += "散发着模糊的光的"
					CASE 1
						LOCALS += "忽明忽暗闪烁着的"
					CASE 2
						LOCALS += "亮得刺眼的"
				ENDSELECT
			CASE 5
				SELECTCASE RAND:3
					CASE 0
						LOCALS += "奇形怪状的"
					CASE 1
						LOCALS += "凶恶的"
					CASE 2
						LOCALS += "布满突起的"
				ENDSELECT
			CASE 6
				;巨根
				LOCALS += "粗大的"
			CASE 10
				;马并
				LOCALS += "驴一样的"
		ENDSELECT
	ELSEIF ARG == MASTER && TARGET
		IF !RAND:3
			IF TALENT:TARGET:妊娠
				LOCALS += "让她怀孕的"
			ELSEIF STRFIND(CSTR:TARGET:処女喪失履歴, "阴茎") > 0
				LOCALS += "让她变成女人的"
				
			ENDIF
		ELSEIF !RAND:2 && 妊娠可否(TARGET) && CFLAG:TARGET:生理周期 == 7 && TEQUIP:TARGET:50 == MASTER
			LOCALS += "能确实让人怀孕的"
		ENDIF
	ENDIF
ENDIF
SELECTCASE RAND:12
	CASE 0 TO 11
		LOCALS += "肉棒"
	;CASE 0
	;	LOCALS += "雄性象征"
	;CASE 1
	;	LOCALS += "男根"
	;CASE 2
	;	LOCALS += "怒張"
	;CASE 3
	;	LOCALS += "陰茎"
	;CASE 4
	;	LOCALS += "肉棒"
	;CASE 5
	;	LOCALS += "剛直"
	;CASEELSE
	;	LOCALS += "陰莖"
ENDSELECT
SIF !TALENT:ARG:2 & 2
	LOCALS = "穿戴式假阴茎"
RETURNF LOCALS


@TINKO_DECIDE(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC CHOOSING_FOR_MASTER
#DIM nLineCount
SIF GROUPMATCH(ARG, MASTER, FLAG:なりきり)
	CHOOSING_FOR_MASTER = 1
SIF !HAS_PENIS(ARG)
	RETURN
nLineCount = LINECOUNT
$LOOP
CLEARLINE LINECOUNT - nLineCount
PRINTFORML 设置%CALLNAME:ARG%的男性器形状。
PRINTFORML [1] 未成熟
PRINTFORML [2] 短小
PRINTFORML [3] 普通
PRINTFORML [4] 发光
PRINTFORML [5] 带疣
PRINTFORML [6] 粗大
;PRINTFORML [7] 小ぶり
;PRINTFORML [8] ドリル
;PRINTFORML [9] パイプカット済み
INPUT
IF RESULT == 1
	IF !CHOOSING_FOR_MASTER
		PRINTFORML 也好，只有那里很成熟也很奇怪吧。
		PRINTFORML [0] 不，不平衡或许也不错
		PRINTFORML [1] 对的，还是可爱的大小更配%CALLNAME:ARG%
		INPUT
		SIF RESULT == 0
			GOTO LOOP
	ENDIF
	PRINTFORMW %CALLNAME:ARG%的男性器变成了可爱的尺寸
	TALENT:ARG:形状 = 1
ELSEIF RESULT == 2
	IF !CHOOSING_FOR_MASTER
		PRINTFORML 也请体谅一下长着这种东西的人吧。
		PRINTFORML [0] 确实有点可怜
		PRINTFORML [1] 就要这个
		INPUT
		SIF RESULT == 0
			GOTO LOOP
	ENDIF
	PRINTFORMW %CALLNAME:ARG%的男性器变成了可怜的样子
	TALENT:ARG:形状 = 2
ELSEIF RESULT == 3
	IF !CHOOSING_FOR_MASTER
		PRINTFORML 果然普通是最好的吧？
		PRINTFORML [0] 感觉少了点什么
		PRINTFORML [1] 这样就好
		INPUT
		SIF RESULT == 0
			GOTO LOOP
	ENDIF
	PRINTFORMW %CALLNAME:ARG%的男性器是非常普通的形状
	TALENT:ARG:形状 = 3
ELSEIF RESULT == 4
	PRINTFORML 发光…到底是什么原理
	PRINTFORML [0] 抱歉，点错了
	PRINTFORML [1] 和萤光鱿是相同的发光原理
	INPUT
	IF RESULT == 1
		IF CHOOSING_FOR_MASTER
			PRINTW 这样啊。
		ELSE
			PRINTW 喜好真独特呢。
		ENDIF
		PRINTFORMW %CALLNAME:ARG%的男性器开始发光了
		TALENT:ARG:形状 = 4
	ELSE
		GOTO LOOP
	ENDIF
ELSEIF RESULT == 5
	PRINTW 就算被那东西插入，也只会痛而不舒服吧？
	SIF CHOOSING_FOR_MASTER
		PRINTW 这不单纯是自我满足吗？难道忘了体谅对方的心情了吗？
	PRINTFORML [0] 那还是就算了
	PRINTFORML [1] 多管闲事
	INPUT
	IF RESULT == 1
		IF CHOOSING_FOR_MASTER
			PRINTW 你这鬼畜！
		ELSE
			PRINTW 你这抖M！
		ENDIF
		PRINTFORMW %CALLNAME:ARG%的男性器长出了疣
		TALENT:ARG:形状 = 5
	ELSE
		GOTO LOOP
	ENDIF
ELSEIF RESULT == 6
	PRINTFORML 你是否在简单地认为越大越好呢？越大就越难充分供血，也会难以坚挺。
	PRINTFORML 而且重要的不是尺寸大小，而是和\@ CHOOSING_FOR_MASTER ? 对方 # 自己 \@小穴的相容性。尺寸不合只会让双方都痛苦不堪。
	SELECTCASE CHOOSING_FOR_MASTER
		CASE 1
			PRINTFORML [0] 因为想插入萝莉XXX所以算了
			PRINTFORML [1] 即使自己痛苦也想看到少女因痛苦而扭曲的脸
			INPUT
			SIF RESULT == 1
				PRINTW 简直了。
		CASE 0
			PRINTFORML [0] 有点没自信，所以算了
			PRINTFORML [1] 即使自己痛苦也想看到少女因冲动而扭曲的脸
			INPUT
			SIF RESULT == 1
				PRINTW 你真是无可救药了。
	ENDSELECT
	IF RESULT == 1
		PRINTFORMW %CALLNAME:ARG%的男性器变大了
		TALENT:ARG:形状 = 6
	ELSE
		GOTO LOOP
	ENDIF
ENDIF

@TINKO_VSOURCE(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
SELECTCASE TALENT:(TEQUIP:ARG:50):形状
	CASE 5
	;长疣的
		CUP:ARG:快Ｖ /= 4
	CASE 2
	;粗末
		CUP:ARG:快Ｖ /= 2
	CASE 10
	;马并
		CUP:ARG:快Ｖ *= 2
ENDSELECT
SIF 挿入不可(ARG) == -1 && ABL:ARG:膣 < 2
	CUP:ARG:快Ｖ = CUP:ARG:快Ｖ * 4 / 5
SIF 挿入不可(ARG) == -2 && ABL:ARG:膣 < 3
	CUP:ARG:快Ｖ /= 2
@TINKO_ASOURCE(ARG)

SELECTCASE TALENT:(TEQUIP:ARG:51):形状
	CASE 5
	;长疣的
		CUP:ARG:快Ａ /= 4
	CASE 2
	;粗末
		CUP:ARG:快Ａ /= 2
	CASE 10
	;马并
		CUP:ARG:快Ａ *= 2
SIF 挿入不可(ARG) == -1 && ABL:ARG:肛門 < 2
	CUP:ARG:快Ａ = CUP:ARG:快Ｖ * 4 / 5
SIF 挿入不可(ARG) == -2 && ABL:ARG:肛門 < 3
	CUP:ARG:快Ａ /= 2
ENDSELECT

@TINKO_SIMPLE(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
VARSET LOCALS
SELECTCASE TALENT:ARG:形状
	CASE 1
		LOCALS = 幼小的
	CASE 2
		LOCALS = 寒酸的
	CASE 3
		LOCALS = 健壮的
	CASE 4
		LOCALS = 发光的
	CASE 5
		LOCALS = 凶猛的
	CASE 6
		LOCALS = 粗壮的
	CASE 10
		LOCALS = 驴一样的
ENDSELECT
LOCALS += "肉棒"
RETURNF LOCALS