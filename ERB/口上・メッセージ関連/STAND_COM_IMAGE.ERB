; 立絵追加リソースセット関連
@DISPLAY_COM_IMAGE(COMNO)
#DIMS リソース名
#DIM COMNO
リソース名 '= ""
IF !FLAG:立絵種類 && CHECK_NUDE(NO:TARGET)
IF CFLAG:差し替え適用
	;替换用画像
	リソース名 = 別立ち{CFLAG:差し替え適用}_裸_COM_{NO:TARGET}_{COMNO}
ELSE
	;通常画像
	リソース名 = 立絵_裸_COM_{NO:TARGET}_{COMNO}
ENDIF
ELSEIF SHOW_BOTE(NO:TARGET)
	リソース名 = ボテ_{NO:TARGET}
ENDIF
SIF SPRITECREATED(リソース名)
	CALL PRINT_IMAGE(リソース名)

@SHOW_BOTE(CHARA)
#FUNCTION
#DIM CHARA
SIF CFLAG:CHARA:衣装一時変更
	RETURNF 0
SIF CFLAG:CHARA:诶嘿嘿
	RETURNF 0
SIF TEQUIP:CHARA:上半身着衣状況 == 0 || TEQUIP:CHARA:下半身着衣状況 == 0
	RETURNF 0
SIF CFLAG:CHARA:妊娠経過日数 < 40 || SELECTCOM != 306
	RETURNF 0
RETURNF 1

@IS_BUNNY(CHARA)
#FUNCTION
#DIM CHARA
SIF CURRENT_CLOTHES_SET(CHARA) == 55
	RETURNF 1
;SIF CHECK_NUDE(CHARA)
;	RETURNF 0
;SIF CFLAG:CHARA:衣装一時変更 == 55
;	RETURNF 1
;SIF CFLAG:CHARA:基本服装セット == 55 && CFLAG:CHARA:衣装一時変更==0
;	RETURNF 1
RETURNF 0
