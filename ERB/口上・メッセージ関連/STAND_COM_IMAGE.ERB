; 立絵追加リソースセット関連
@DISPLAY_COM_IMAGE(COMNO)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC リソース名
#DIM DYNAMIC COMNO
#DIMS DYNAMIC 服装
#DIMS DYNAMIC Version
#DIMS DYNAMIC 表示形式
;只有膝上绘
表示形式 = %GET_BASESTYLE(TARGET, "立絵")%
VARSET RESULTS
TRYCALLFORM SPECIAL_BASE_IMAGE_{TARGET}
IF STRCOUNT(RESULTS, "EagloV")
	RESULT = 0
	TRYCALLFORM EagloV_Version{TARGET}
	SIF RESULT
		Version = %RESULTS%
	服装 = %EagloV_服装初步判定(TARGET)%
	IF 服装 == "服"
		TRYCALLFORM EagloV_特殊服装%Version%_{TARGET}
		IF RESULT
			服装 += RESULTS
		ENDIF
	ELSEIF 服装 == "内衣" || 服装 == "胸罩" || 服装 == "胖次"
		TRYCALLFORM EagloV_特殊内衣%Version%_{TARGET}
		IF RESULT
			服装 += RESULTS
		ENDIF
	ENDIF
ELSE
	IF CHECK_NUDE(TARGET)
		服装 = 裸
	ELSE
		服装 = 服
	ENDIF
	CALL IMAGE_CHARA_OVERRIDE("特殊服装", TARGET)
	IF RESULT:1
		服装 += RESULTS
	ENDIF
ENDIF
RESULTS =
RESULT = 0
TRYCALLFORM SPIRIT_Version{NO:TARGET}
IF RESULT && RESULTS != ""
	Version '= RESULTS
	TRYCALLFORM IMAGE_I{TARGET}_特殊表情COM(TARGET, COMNO)
	;DEBUGPRINTFORML 特殊表情COM运用：{TARGET}%Version%_%服装%_表情_%RESULTS% = {RM_RESOURCECHECK(@"{TARGET}%Version%_%服装%_表情_%RESULTS%")}
	IF RM_RESOURCECHECK(@"{TARGET}%Version%_%服装%_表情_%RESULTS%")
		CALL PRINT_IMAGE(@"{TARGET}%Version%_%服装%_表情_%RESULTS%",1000*默认角色画像横幅/180)
		RETURN
	ENDIF
ENDIF
;DEBUGPRINTFORML TFLAG:50:{TFLAG:50}

IF TFLAG:50
	RESULTS =
	RESULT = 0
	TRYCALLFORM SPECIAL_SCOM_IMAGE
	IF RESULT && RM_RESOURCECHECK(RESULTS)
		CALL PRINT_IMAGE(RESULTS,1000*默认角色画像横幅/180)
		RETURN
	ELSEIF RM_RESOURCECHECK(@"%表示形式%_%服装%_SCOM{TFLAG:50}_{NO:TARGET}")
		CALL PRINT_IMAGE(@"%表示形式%_%服装%_SCOM{TFLAG:50}_{NO:TARGET}",1000*默认角色画像横幅/180)
		RETURN
	ENDIF
ENDIF
IF RM_RESOURCECHECK(@"%表示形式%_%服装%_COM{COMNO}_{NO:TARGET}")
	CALL PRINT_IMAGE(@"%表示形式%_%服装%_COM{COMNO}_{NO:TARGET}",1000*默认角色画像横幅/180)
ELSEIF GROUPMATCH(TEQUIP:TARGET:体位,POSE_正常位,POSE_后背位,POSE_骑乘位,POSE_对面坐位,POSE_背面坐位) && RM_RESOURCECHECK(@"%表示形式%_%服装%_COM{POSE_TO_COMNO:(TEQUIP:TARGET:体位)}_{NO:TARGET}")
	CALL PRINT_IMAGE(@"%表示形式%_%服装%_COM{POSE_TO_COMNO:(TEQUIP:TARGET:体位)}_{NO:TARGET}",1000*默认角色画像横幅/180)
ENDIF

@SHOW_BOTE(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CHARA
SIF CFLAG:CHARA:衣装一時変更
	RETURNF 0
SIF CFLAG:CHARA:诶嘿嘿
	RETURNF 0
SIF TEQUIP:CHARA:上半身着衣状況 == 0 || TEQUIP:CHARA:下半身着衣状況 == 0
	RETURNF 0
SIF CFLAG:CHARA:妊娠経過日数 < 40 || SELECTCOM != 306
	RETURNF 0
RETURNF 1

@IS_BUNNY(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CHARA
SIF CURRENT_CLOTHES_SET(CHARA) == 55 || CURRENT_CLOTHES_SET(CHARA) == 66
	RETURNF 1
;SIF CHECK_NUDE(CHARA)
;	RETURNF 0
;SIF CFLAG:CHARA:衣装一時変更 == 55
;	RETURNF 1
;SIF CFLAG:CHARA:基本服装セット == 55 && CFLAG:CHARA:衣装一時変更==0
;	RETURNF 1
RETURNF 0

@IS_SCHOOLUNIFORM(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CHARA
SIF CURRENT_CLOTHES_SET(CHARA) == 74 || CURRENT_CLOTHES_SET(CHARA) == 80
	RETURNF 1
RETURNF 0

@IS_TOPLESS(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CHARA
RETURNF (!EQUIP:CHARA:上半身上着１ && !EQUIP:CHARA:上半身上着２ && !EQUIP:CHARA:外搭 && !EQUIP:CHARA:和服 && !EQUIP:CHARA:連衣裙 && !EQUIP:CHARA:レオタード && !EQUIP:CHARA:ボディースーツ) && EQUIP:CHARA:下半身内衣２ != 0
