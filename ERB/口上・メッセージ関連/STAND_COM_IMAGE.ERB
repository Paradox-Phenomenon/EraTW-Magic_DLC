; 立絵追加リソースセット関連
@DISPLAY_COM_IMAGE(COMNO)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC リソース名
#DIM DYNAMIC COMNO
#DIMS DYNAMIC 服装
#DIMS DYNAMIC Version
#DIMS DYNAMIC 表示形式
;只有膝上绘
表示形式 = %GET_BASESTYLE(TARGET, "立絵")%
VARSET RESULTS
TRYCALLFORM SPECIAL_BASE_IMAGE_{TARGET}
IF STRCOUNT(RESULTS, "EagloV")
	RESULT = 0
	TRYCALLFORM EagloV_Version{TARGET}
	SIF RESULT
		Version = %RESULTS%
	服装 = %EagloV_服装初步判定(TARGET)%
	IF 服装 == "服"
		TRYCALLFORM EagloV_特殊服装%Version%_{TARGET}
		IF RESULT
			服装 += RESULTS
		ENDIF
	ELSEIF 服装 == "内衣" || 服装 == "胸罩" || 服装 == "胖次"
		TRYCALLFORM EagloV_特殊内衣%Version%_{TARGET}
		IF RESULT
			服装 += RESULTS
		ENDIF
	ENDIF
ELSE
	IF CHECK_NUDE(TARGET)
		服装 = 裸
	ELSE
		服装 = 服
	ENDIF
	CALL IMAGE_CHARA_OVERRIDE("特殊服装", TARGET)
	IF RESULT:1
		服装 += RESULTS
	ENDIF
ENDIF
リソース名 = %表示形式%_%服装%_COM{COMNO}_{NO:TARGET}
IF TFLAG:50 && RM_リソースチェック(@"%表示形式%_%服装%_SCOM{TFLAG:50}_{NO:TARGET}")
	リソース名 = %表示形式%_%服装%_SCOM{TFLAG:50}_{NO:TARGET}
ENDIF
IF RM_リソースチェック(リソース名)
	CALL PRINT_IMAGE(リソース名,1000*默认角色画像横幅/180)
;ELSEIF SHOW_BOTE(NO:TARGET)
;	CALL PRINT_IMAGE(@"ボテ_{NO:TARGET}")
ENDIF

@SHOW_BOTE(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CHARA
SIF CFLAG:CHARA:衣装一時変更
	RETURNF 0
SIF CFLAG:CHARA:诶嘿嘿
	RETURNF 0
SIF TEQUIP:CHARA:上半身着衣状況 == 0 || TEQUIP:CHARA:下半身着衣状況 == 0
	RETURNF 0
SIF CFLAG:CHARA:妊娠経過日数 < 40 || SELECTCOM != 306
	RETURNF 0
RETURNF 1

@IS_BUNNY(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CHARA
SIF CURRENT_CLOTHES_SET(CHARA) == 55 || CURRENT_CLOTHES_SET(CHARA) == 66
	RETURNF 1
;SIF CHECK_NUDE(CHARA)
;	RETURNF 0
;SIF CFLAG:CHARA:衣装一時変更 == 55
;	RETURNF 1
;SIF CFLAG:CHARA:基本服装セット == 55 && CFLAG:CHARA:衣装一時変更==0
;	RETURNF 1
RETURNF 0

@IS_SCHOOLUNIFORM(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CHARA
SIF CURRENT_CLOTHES_SET(CHARA) == 74 || CURRENT_CLOTHES_SET(CHARA) == 80
	RETURNF 1
RETURNF 0
