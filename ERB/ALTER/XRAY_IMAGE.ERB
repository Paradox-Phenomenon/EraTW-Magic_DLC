@XRAY_IMAGE_STRING(CHARA,縦位置,最大レイヤー数)
#DIM CHARA
#DIM 最大レイヤー数
#DIM 縦位置
#DIM デフォルトキャラ画像横幅退避

#DIMS DYNAMIC strXRAY_V = ""
#DIMS DYNAMIC strXRAY_V_SEMON = ""

#DIMS DYNAMIC strXRAY_A = ""
#DIMS DYNAMIC strXRAY_A_SEMON = ""

#DIMS DYNAMIC strXRAY_W = ""
#DIMS DYNAMIC strXRAY_W_SEMON = ""

#DIMS DYNAMIC strXRAY_P = ""
#DIMS DYNAMIC strXray_P_CONDOM = ""
#DIMS DYNAMIC strXray_P_CUM = ""

#DIMS DYNAMIC strXRAY_DW = ""

#DIMS DYNAMIC HTMLText = ""



; determine P
SELECTCASE TALENT:MASTER:形状
    CASE 1
        ;未成熟
        strXRAY_P = _child
    CASE 2
        ;粗チン
        strXRAY_P = _poor
    CASE 3
        ;普通
        strXRAY_P = _normal
    CASE 4
        ;発光する
        strXRAY_P = _light
    CASE 5
        ;イボ付き
        strXRAY_P = _bead
    CASE 6,10
        ;ごんぶと
        strXRAY_P = _large
    CASEELSE
        strXRAY_P = _normal
ENDSELECT
IF TEQUIP:MASTER:コンドーム
    strXray_P_CONDOM = _condom
ELSEIF 充填率(CHARA,1) >= 50
    strXray_P_CUM = _cum
ENDIF

; 計算子宮填充率
IF 充填率(CHARA,1) >= 200 
    strXRAY_W_SEMON = _cum_200
ELSEIF 充填率(CHARA,1) >= 100
    strXRAY_W_SEMON = _cum_100
ELSEIF 充填率(CHARA,1) >= 50
    strXRAY_W_SEMON = _cum_50
ELSEIF 充填率(CHARA,1) >= 25
    strXRAY_W_SEMON = _cum_25
ELSEIF 充填率(CHARA,1) >= 1
    strXRAY_W_SEMON = _cum_1
ELSE
    strXRAY_W_SEMON = 
ENDIF

; 挿入子宮口責め & PENIS IS HUGE ENOUGH
IF TEQUIP:CHARA:Ｖセックス != -1 && TALENT:MASTER:形状 >= 3 &&SELECTCOM == 73 && EXP:CHARA:子宮口開発経験 >= 50
    SIF strXRAY_W_SEMON == "_cum_1"
        strXRAY_W_SEMON = "_cum_25"
    strXRAY_DW = DW%strXRAY_P%%strXray_P_CONDOM%%strXray_P_CUM%%strXRAY_W_SEMON%
ELSE
    ;W (+1)
    strXRAY_W = W
    ; 優先顯示妊娠
    IF CFLAG:CHARA:妊娠経過日数 > 0
        IF CFLAG:CHARA:妊娠経過日数 > 60
            strXRAY_W = W_pregnant_60
        ELSEIF CFLAG:CHARA:妊娠経過日数 > 20
            strXRAY_W = W_pregnant_20
        ELSE
            strXRAY_W = W_pregnant_0
        ENDIF
    ELSE
        ; 沒有妊娠才處理精液量
        strXRAY_W = W%strXRAY_W_SEMON%
    ENDIF

    ;V (+2)
    strXRAY_V = %\@TALENT:CHARA:処女 > 0 ? V_virgin # V\@%
    IF PALAM:CHARA:潤滑 > 500
        strXRAY_V = %strXRAY_V%_wet
    ENDIF

    IF 充填率(CHARA,1) >= 100
        strXRAY_V_SEMON = V_cumfull
    ELSEIF 充填率(CHARA,1) > 0
        strXRAY_V_SEMON = V_cum
    ELSE
        strXRAY_V_SEMON = 
    ENDIF

    IF 充填率(CHARA,2) >= 100
        strXRAY_A_SEMON = A_cumfull
    ELSEIF 充填率(CHARA,2) > 0
        strXRAY_A_SEMON = A_cum
    ELSE
        strXRAY_A_SEMON = 
    ENDIF

    IF strXRAY_V_SEMON != ""
        strXRAY_V = %strXRAY_V%/%strXRAY_V_SEMON%
    ENDIF
    ; add penis image
    IF TEQUIP:CHARA:Ｖセックス != -1
        strXRAY_V = %strXRAY_V%/D%strXRAY_P%
        IF strXray_P_CONDOM != ""
            strXRAY_V = %strXRAY_V%%strXray_P_CONDOM%
        ELSE
            strXRAY_V = %strXRAY_V%%strXray_P_CUM%
        ENDIF
    ENDIF
    IF CFLAG:CHARA:処女喪失記念日 == DAY
        strXRAY_V = %strXRAY_V%/V_blood
    ENDIF
ENDIF


;A (+3)
strXRAY_A = A
; add penis type
IF TEQUIP:CHARA:アナルバイブ
    strXRAY_A = A_dildo
ELSEIF TEQUIP:CHARA:アナルビーズ
    strXRAY_A = A_analbead
ELSEIF TEQUIP:CHARA:Ａ接触部位 == 3
    strXRAY_A = A_finger
ELSEIF TEQUIP:CHARA:Ａセックス != -1
    strXRAY_A = A%strXRAY_P%
ELSE
    strXRAY_A = A_null
ENDIF

IF 充填率(CHARA,2) >= 100
    strXRAY_A = %strXRAY_A%_100
ELSEIF 充填率(CHARA,2) > 0
    strXRAY_A = %strXRAY_A%_50
ELSE
    strXRAY_A = %strXRAY_A%_0
ENDIF

; 設置圖片
; デフォルトキャラ画像横幅避難
デフォルトキャラ画像横幅退避 = デフォルトキャラ画像横幅
; 縦位置 = (デフォルトキャラ画像横幅)* キャラ画像表示サイズ比 /100
デフォルトキャラ画像横幅 = デフォルトキャラ画像横幅 *50/180


; ; CALL 画像セット("XRAY_BLANK_GREEN", 縦位置, 0 , キャラ画像表示サイズ比*3/10 , 最大レイヤー数)
HTMLText += @"%getHtmlXray("XRAY_BLANK_GREEN",デフォルトキャラ画像横幅*3/10)%"

IF strXRAY_DW != ""
;     ; CALL 画像セット(@"%strXRAY_DW%_w", 縦位置, 0 , キャラ画像表示サイズ比 , 最大レイヤー数)
    HTMLText += @"%getHtmlXray(@"%strXRAY_DW%_w",デフォルトキャラ画像横幅,縦位置)%"
;     ; CALL 画像セット(@"%strXRAY_DW%_d", 縦位置, 0 , キャラ画像表示サイズ比 , 最大レイヤー数)
    HTMLText += @"%getHtmlXray(@"%strXRAY_DW%_d",デフォルトキャラ画像横幅,縦位置)%"
;     DEBUGPRINTFORML DW画 %callname:CHARA% %strXRAY_DW%
ELSE
    CALL AAZ_IMAGE_STATE_CHECK(strXRAY_W)
;     ; CALL 画像セット(strXRAY_W, 縦位置, 0 , キャラ画像表示サイズ比 , 最大レイヤー数)
    HTMLText += @"%getHtmlXray(@"%strXRAY_W%",デフォルトキャラ画像横幅,縦位置)%"
;     DEBUGPRINTFORML W画 %callname:CHARA% %strXRAY_W%
    CALL AAZ_IMAGE_STATE_CHECK(strXRAY_V)
;     ; CALL 画像セット(strXRAY_V, 縦位置, 0 , キャラ画像表示サイズ比 , 最大レイヤー数)
    HTMLText += @"%getHtmlXray(@"%strXRAY_V%",デフォルトキャラ画像横幅,縦位置)%"
;     DEBUGPRINTFORML V画 %callname:CHARA% %strXRAY_V%
ENDIF

; CALL AAZ_IMAGE_STATE_CHECK(strXRAY_A)
; ; CALL 画像セット(strXRAY_A, 縦位置, 0 , キャラ画像表示サイズ比 , 最大レイヤー数)
HTMLText += @"%getHtmlXray(@"%strXRAY_A%",デフォルトキャラ画像横幅,縦位置)%"
; DEBUGPRINTFORML A画 %callname:CHARA% %strXRAY_A%

; CALL 画像セット("XRAY_BLANK_GREEN", 縦位置, 0 , キャラ画像表示サイズ比*3/10, 最大レイヤー数)
HTMLText += @"%getHtmlXray("XRAY_BLANK_YELLOW",デフォルトキャラ画像横幅*3/10)%"
; PRINTFORML %HTMLText%

SIF MAX_LAYER_NUM < 最大レイヤー数
    MAX_LAYER_NUM = 最大レイヤー数

; デフォルトキャラ画像横幅歸還
デフォルトキャラ画像横幅 = デフォルトキャラ画像横幅退避
RESULTS = %HTMLText%
RETURN 0



@getHtmlXray(spriteName, imageWidth,縦位置=0)
#FUNCTIONS
#DIMS spriteName
#DIM imageWidth
#DIM 縦位置
#DIMS DYNAMIC HTMLText = ""

SIF imageWidth == 0
    imageWidth = デフォルトキャラ画像横幅/3

IF STRLENS(spriteName) > 0
    HTMLText += @"<img src='%spriteName%' height = '{imageWidth}px' width = '{imageWidth}px' ypos='{縦位置}px'>"
ENDIF
RETURNF HTMLText