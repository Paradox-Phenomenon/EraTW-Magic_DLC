@CREATE_BBAS_DATABASE()
#LOCALSIZE 1
#LOCALSSIZE 1
    #DIMS schema
    #DIMS data_xml

    ; chara info
    DT_CREATE "bbas_dataset"
    schema '= LOADTEXT("plugins/schema.xml")
    data_xml '= LOADTEXT("plugins/bbas_dataset.xml")
    DT_FROMXML "bbas_dataset", schema, data_xml

    ; map info
    DT_CREATE "bbas_map"
    schema '= LOADTEXT("plugins/bbas_map_schema.xml")
    data_xml '= LOADTEXT("plugins/bbas_map.xml")
    DT_FROMXML "bbas_map", schema, data_xml

@GET_BBAS_DATASET(chara, request)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM chara
#DIMS request
DT_CELL_GETS "bbas_dataset", chara, request, 1
RETURN RESULT
