			"睡眠", "発情", "オナニー",
			"愛撫", "愛撫1", "性交", "性交1", "性交2",
			"恥ずい", "悩ん", "欣快", "悩ん1"
}
;NUDE_EXPRESSION_EXISTS was for 通常 and stuff, but it would look like character was reacting to getting stripped in timestop
;eventually chose to add expressions like 通常1
;another way to do this is to compose 通常1's expression on the 通常 tag instead when conditions are met
;frankly that might be more consistent, next patch TODO?
#DIMS NUDE_EXPRESSION_EXISTS = "別顔_裸_発情"
#DIM NUDE_EXPRESSION_CHECK_PASSED
#DIM HAS_MANPU
#DIMS MANPU_TEMPS
#DIM HAS_COMPOSED_BREATH
#DIM HAS_COMPOSED_BLUSH
{
#DIMS PAT =
			"Start_0",          "FaceShadow", "00",                                     "End",
			"Start_1",          "01",                                                   "End",
			"Start_2",          "FaceShadow", "10",                                     "End",
			"Start_3",          "11",                                                   "End",
			"Start_4",          "FaceShadow", "20", "Manpu_Anger",                      "End",
			"Start_5",          "21", "Manpu_Anger",                                    "End",

			"Start_6",          "30",                                                   "End",
			"Start_7",          "ExtraBlush", "40",                                     "End",
			"Start_7_Nude",     "ExtraBlush", "41",                                     "End",
			"Start_8",          "Blush", "50", "Breath",                                "End",

			"Start_9",          "ExtraBlush", "60",                                     "End",
			"Start_10",         "ExtraBlush", "70",                                     "End",
			"Start_11",         "ExtraBlush", "80",                                     "End",
			"Start_12",         "ExtraBlush", "90",                                     "End",
			"Start_13",         "ExtraBlush", "100",                                    "End",

			"Start_14",         "ExtraBlush", "110",                                    "End",
			"Start_15",         "FaceShadow", "120", "Manpu_Anger",                     "End",
			"Start_16",         "130", "Manpu_EighthNote",                              "End",
			"Start_17",         "FaceShadow_L", "ExtraBlush", "140", "Manpu_Bothered",  "End"
}
SIF !CHECK_IMAGE_NEEDS_UPDATE([[日狭美]])
	RETURN

FOR 素体COUNT, 0, VARSIZE("素体")
	FOR 表情COUNT, 0, VARSIZE("表情")
		HAS_COMPOSED_BREATH = 0
		HAS_COMPOSED_BLUSH = 0
		NUDE_EXPRESSION_CHECK_PASSED = 0

		;if this expression has a nude specific variant, set flag
		IF STRFIND(素体:素体COUNT, "裸") > -1
			FOR TEMP, 0, VARSIZE("NUDE_EXPRESSION_EXISTS")
				SIF @"%素体:素体COUNT%_%表情:表情COUNT%" == @"%NUDE_EXPRESSION_EXISTS:TEMP%"
					NUDE_EXPRESSION_CHECK_PASSED = 1
			NEXT
		ENDIF
		;check if current 素体 is portrait or standing art
		VARIANT = %\@ STRFIND(素体:素体COUNT, "顔") > -1 ? faceparts # bodyparts \@%

		;remove the compsoed sprite from memory to update it, effects rely on this
		;not worth as this set grows bigger!!! compose blushing variants as well instead of constant rebuilding
		SIF SPRITECREATED(@"%素体:素体COUNT%_%表情:表情COUNT%_156")
			SPRITEDISPOSE @"%素体:素体COUNT%_%表情:表情COUNT%_156"

		;compose 素体
		G_ID = 0
		CALL 画像合成(G_ID, @"156_%素体:素体COUNT%")

		;顔合成
		L_COUNT = 0
		WHILE L_COUNT < VARSIZE("PAT")
			IF PAT:L_COUNT == @"Start_{表情COUNT}%COND_STR("_Nude", NUDE_EXPRESSION_CHECK_PASSED)%"
				;照れ, on top of 素体, underneath everything else due to unique layering
				IF CHECK_BLUSH(156)
					CALL 画像合成(G_ID, @"156_%VARIANT%_Blush")
					HAS_COMPOSED_BLUSH = 1
				ENDIF

				;compose the expression, MANPU is handled separately so it exists on top of headdress
				VARSET HAS_MANPU
				VARSET MANPU_TEMPS
				L_COUNT ++
				WHILE PAT:L_COUNT != @"End"
					IF STRFIND(PAT:L_COUNT, "Manpu") > -1
						HAS_MANPU = 1
						MANPU_TEMPS = %PAT:L_COUNT%
					ELSE
						;オナニー requires VFXes on at all times so I'm doing this
						SIF STRFIND(PAT:L_COUNT, "Blush") > -1 && !HAS_COMPOSED_BLUSH
							HAS_COMPOSED_BLUSH = 1
						SIF STRFIND(PAT:L_COUNT, "Breath") > -1
							HAS_COMPOSED_BREATH = 1
						CALL 画像合成(G_ID, @"156_%VARIANT%_%PAT:L_COUNT%")
						;skip to nextloop if currently composing for a variant that shouldn't exist(missing resource)
						SIF RESULT == 0
							GOTO NEXTLOOP
					ENDIF
					L_COUNT ++
				WEND

				;髪飾
				SIF CHECK_HEADDRESS_156() || STRFIND(素体:素体COUNT, "ボロ") == -1
					CALL 画像合成(G_ID, @"156_%VARIANT%_Headdress")

				;漫符
				SIF HAS_MANPU
					CALL 画像合成(G_ID, @"156_%VARIANT%_%MANPU_TEMPS%")

				;吐息
				SIF CHECK_EXHALATION(156) && !HAS_COMPOSED_BREATH
					CALL 画像合成(G_ID, @"156_%VARIANT%_Breath")

			ELSE
				L_COUNT ++
			ENDIF
		WEND
		SPRITECREATE @"%素体:素体COUNT%_%表情:表情COUNT%_156", G_ID
		$NEXTLOOP
	NEXT
NEXT


