@GET_SUCCESS_RATE(CHARA)
#FUNCTION
#DIM CHARA
VARSET LOCAL
SIF !CHARA
	CHARA = TARGET
;親密
IF MAGIC_DLC_大成功相关 && MAGIC_DLC_好感亲密重做
	LOCAL += MIN(ABL:CHARA:親密, 20)+MIN(ABL:CHARA:親密, 40)+MIN(ABL:CHARA:親密, 60)+MIN(ABL:CHARA:親密, 80)+ABL:CHARA:親密
ELSE
	LOCAL += MIN(ABL:CHARA:親密, 10) * 5
ENDIF
LOCAL += GETPALAMLV(PALAM:CHARA:恭順,5) * 3

;叛逆.坦率
LOCAL -= TALENT:CHARA:態度 * 5
;堅強
SIF TALENT:CHARA:胆量 > 0
	LOCAL -= 5

;自尊心高
SIF TALENT:CHARA:自尊心 > 0
	LOCAL -= 15
;自尊心低
SIF TALENT:CHARA:自尊心 < 0
	LOCAL += 5
;目立ちたがり
SIF TALENT:CHARA:目立ちたがり
	LOCAL += 2
;圧抑
SIF TALENT:CHARA:自己愛 < 0
	LOCAL -= 10
;抵抗
SIF TALENT:CHARA:抵抗
	LOCAL -= 10
;容易高潮
SIF TALENT:CHARA:容易高潮
	LOCAL += 10
;性別嗜好
SIF OTOKOGIRAI(CHARA)
	LOCAL -= 7

LOCAL += TALENT:CHARA:心情 * 15

;調教者の素質
;魅惑
SIF TALENT:PLAYER:魅惑
	LOCAL += 6
;謎之魅力
SIF TALENT:PLAYER:謎之魅力
	LOCAL += 6
SIF TALENT:PLAYER:魅力
	LOCAL += 6

;相性チェック
R = NO:PLAYER
IF RELATION:CHARA:R > 0 && RELATION:CHARA:R < 30
	LOCAL -= 10
ELSEIF RELATION:CHARA:R > 0 && RELATION:CHARA:R < 70
	LOCAL -= 6
ELSEIF RELATION:CHARA:R > 0 && RELATION:CHARA:R < 100
	LOCAL -= 3
ELSEIF RELATION:CHARA:R >= 100 && RELATION:CHARA:R < 130
	LOCAL += 3
ELSEIF RELATION:CHARA:R >= 100 && RELATION:CHARA:R < 170
	LOCAL += 6
ELSEIF RELATION:CHARA:R >= 100 && RELATION:CHARA:R >= 170
	LOCAL += 10
ENDIF

;好感度
LOCAL += MIN(CFLAG:CHARA:好感度 / 200, 50)
;信赖度
LOCAL += MIN(CFLAG:CHARA:信赖度 / 20, 50)

;思慕
SIF TALENT:CHARA:思慕 || TALENT:CHARA:愛欲
	LOCAL += 20
;恋慕
SIF TALENT:CHARA:恋慕
	LOCAL += 40
LOCAL += (CFLAG:MASTER:310 - CFLAG:CHARA:310) / 500
LOCAL += TFLAG:幸運補正 * 20
SIF LOCAL < 0
	LOCAL = 0

DEBUGPRINTFORML SUCCESS_RATE{LOCAL}

RETURNF LOCAL
