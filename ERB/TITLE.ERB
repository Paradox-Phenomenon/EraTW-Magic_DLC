;revからパクリ

@SYSTEM_TITLE
LOADGLOBAL
RESULT = GLOBAL
SAVEGLOBAL
LOADGLOBAL

RESETBGCOLOR

;stop for error
[IF_DEBUG]
SIF LINECOUNT > 1
	WAIT
[ENDIF]

;warning if screen isn't wide enough
IF MAXWIDTH() < CHAR_PER_LINE
	CALL COLORMESSAGE("ウィンドウの幅が推奨される行幅よりも小さいため、表示内容が正しく配置されない可能性があります。", C_YELLOW, 1)
	CALL COLORMESSAGE("修正するには、ウィンドウの幅を広げるか、より小さいフォントを使用してください。", C_YELLOW, 1)
	PRINTL
ENDIF

IF GAMEBASE_VERSION == 0
	WINDOW_TITLE = %GAMEBASE_TITLE% %eraTW_Version%
ELSEIF GAMEBASE_VERSION < 0
	WINDOW_TITLE = %GAMEBASE_TITLE% 0.00
ENDIF
SIF LINECOUNT == 1
	CLEARLINE 1
RESULT  = 1
LOCAL:2 = LINECOUNT


DO
	REDRAW 0
	CLEARLINE LINECOUNT - LOCAL:2
	FOR LOCAL:0, 0, 35
		HTML_PRINT "<p align='center'><img src='TW_title" + TOSTR(LOCAL:0, "000") + "'></p>"
	NEXT
	$START
	ALIGNMENT CENTER
	CUSTOMDRAWLINE ━
	PRINTFORML %GAMEBASE_TITLE%
	PRINTFORML \@ GAMEBASE_VERSION <= 0 ? %eraTW_Version% # %TOSTR(GAMEBASE_VERSION,"0,.###")% \@
	PRINTFORML %GAMEBASE_YEAR%
;	CALL HTMLPRINTL(@"%HTMLFONT(@"<b>%HTMLSTYLE(@"%GAMEBASE_TITLE%", 2)%</b>", "Courier New", )%")
;	CALL HTMLPRINTL(@"%HTMLFONT(@"<b>%eraTW_Version%</b>", "Courier New")%")
;	CALL HTMLPRINTL(@"%HTMLFONT(@"<b>(%GAMEBASE_YEAR%)</b>", "Courier New")%")
	PRINTL
	PRINTFORML %GAMEBASE_INFO%
	CUSTOMDRAWLINE ━
	PRINTFORML [0] はじめから
	PRINTFORML [1] つづきから
	ALIGNMENT LEFT
	REDRAW 1
	INPUT
	CUSTOMDRAWLINE ━
	SELECTCASE RESULT
		CASE 0
			RESETDATA
			ADDCHARA 0
			BEGIN FIRST
		CASE 1
			CALL LOAD_SAVE(0,1)
	ENDSELECT
	GOTO START
LOOP RESULT
