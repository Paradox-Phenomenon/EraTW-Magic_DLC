@DEFAULT_MAP_COLOR
#LOCALSIZE 1
#LOCALSSIZE 1
PRINTFORML 请选择地图的种类(可以在选项中更改)
PRINTFORML [1] 颜色地图 + 动画 (FPS：{GETCONFIG("FPS")} ※在上方工具栏-帮助-设置-显示)
PRINTFORML [2] 颜色地图
PRINTFORML [3] 经典

$INPUTLOOP
INPUT
IF RESULT == 1
	RECOLOREDMAPS = 1
	ANIMATERECOLOREDMAPS = 1000 / GETCONFIG("FPS")
ELSEIF RESULT == 2
	RECOLOREDMAPS = 1
	ANIMATERECOLOREDMAPS = 0
ELSEIF RESULT == 3
	RECOLOREDMAPS = 0
	ANIMATERECOLOREDMAPS = 0
ELSE
	RESTART
ENDIF
