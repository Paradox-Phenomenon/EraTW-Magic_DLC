@ALTER_RESET_CHARA_MAIN()
#DIM CHARA
PRINTFORML 请选择要切换或重置的角色
PRINTFORML 如果需要切换剧本，则一定会重置某些记录进度的标志和变量，以确保不会出现BUG
CALL SHOW_CHARA_LIST("现有的角色列表")
CHARA = RESULT
IF CHARA != 999

	PRINTFORML 确定要重置%CALLNAME:CHARA%吗?（如好感度和信赖度会清零）
	CALL ASK_YN("Y","N")
	IF RESULT == 0
		
		CFLAG:CHARA:口上実装状況 = 0
		CALL KOJO_MULTIPLE(CHARA,,1)
	
		CALL RESET_KOJO_CHARA_PORTION(CHARA)
		PRINTFORML 重置经验EXP?
		CALL ASK_YN("Y","N")
		IF RESULT == 0
			FOR LOCAL,0,100
				EXP:CHARA:LOCAL = CSVEXP(CHARA,LOCAL)
			NEXT
			PRINTFORMW %CALLNAME:CHARA%的经验重置了。
		ENDIF

		PRINTFORML 重置能力ABL?
		CALL ASK_YN("Y","N")
		IF RESULT == 0
			FOR LOCAL,0,100
				ABL:CHARA:LOCAL = CSVABL(CHARA,LOCAL)
			NEXT
			PRINTFORMW %CALLNAME:CHARA%的能力重置了。
		ENDIF
		
	ENDIF
	
ENDIF

