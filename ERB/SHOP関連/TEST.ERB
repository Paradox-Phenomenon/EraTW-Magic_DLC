@TEST_XML_ADDNODE_BUGFIX

    #DIMS xml
    
    PRINTL --- 测试 XML_ADDNODE 批量插入 Bugfix ---
    
    ; 准备一个包含 3 个相同标签的 XML
    xml '= "<root><item id='1'/><item id='2'/><item id='3'/></root>"
    PRINTFORML [测试前] %xml%
    
    ; 目标：给所有 <item> 标签内部添加一个 <new>子节点</new>
    ; 参数说明：methodType=0(追加为子节点), doSetAll=1(应用于所有匹配项)
    LOCAL = XML_ADDNODE(xml, "/root/item", "<new>子节点</new>", 0, 1)
    
    PRINTFORML [匹配数] {LOCAL}
    PRINTFORML [测试后] %xml%
    
    ; 验证结果
    IF STRFIND(xml, "<item id=\"1\"><new>") >= 0 && STRFIND(xml, "<item id=\"2\"><new>") >= 0 && STRFIND(xml, "<item id=\"3\"><new>") >= 0
        SETCOLOR 0x00FF00
        PRINTL 测试通过：所有节点均成功插入了子节点！
    ELSE
        SETCOLOR 0xFF0000
        PRINTL 测试失败：未能向所有节点插入子节点（旧版 Bug 依然存在）。
    ENDIF
    RESETCOLOR
    
    WAIT

;============================================================
; 测试函数：对比新旧CURRENT_CLOTHES_SET函数的输出
;============================================================
@测试_CURRENT_CLOTHES_SET对比
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM C_ID = 1
#DIM CONST MAX_SET = 150
#DIM DYNAMIC OLD_RESULT
#DIM DYNAMIC NEW_RESULT
#DIM DYNAMIC MATCH_COUNT
#DIM DYNAMIC MISMATCH_COUNT
#DIM DYNAMIC TOTAL_COUNT
#DIM DYNAMIC SKIP_COUNT
#DIM DYNAMIC SET_ID
#DIM DYNAMIC PART_ID
#DIM DYNAMIC OLD_EQUIP, 23
#DIM DYNAMIC OLD_CFLAG_BASE
#DIM DYNAMIC OLD_CFLAG_TEMP

PRINTFORML 开始测试 CURRENT_CLOTHES_SET 函数对比
PRINTFORML 测试角色ID：{C_ID} %CALLNAME:C_ID%
PRINTFORML 最大测试套装数：{MAX_SET}
CALL D_LINE

; 保存当前装备状态和CFLAG
FOR PART_ID, 1, 23
	OLD_EQUIP:PART_ID = EQUIP:C_ID:PART_ID
NEXT
OLD_CFLAG_BASE = CFLAG:C_ID:基本服装セット
OLD_CFLAG_TEMP = CFLAG:C_ID:衣装一時変更

; 设置正确的换装环境条件，使CURRENT_CLOTHES_SET进入详细检测
CFLAG:C_ID:衣装一時変更 = 100

TOTAL_COUNT = 0
MATCH_COUNT = 0
MISMATCH_COUNT = 0
SKIP_COUNT = 0

PRINTFORML
PRINTFORML 开始遍历所有套装...
PRINTFORML

CALL D_LINE
PRINTFORML 套装ID   | 套装名称              | 旧函数 | 新函数 | 结果
CALL D_LINE

; 遍历所有套装
FOR SET_ID, 1, MAX_SET
	TOTAL_COUNT++
	
	; 检查套装是否存在
	IF !STRLENS(GETMETH_STR(C_ID, "衣装セット", SET_ID, "名前"))
		SKIP_COUNT++
		CONTINUE
	ENDIF
	
	; 应用套装装备
	FOR PART_ID, 1, 23
		EQUIP:C_ID:PART_ID = GETMETH_INT(C_ID, "衣装セット", SET_ID, EQUIPNAME:PART_ID)
	NEXT
	
	; 调用旧函数和新函数
	OLD_RESULT = CURRENT_CLOTHES_SET(C_ID)
	NEW_RESULT = CURRENT_CLOTHES_SET_RECONSTRUCTED(C_ID)
	
	; 输出结果
	IF OLD_RESULT == NEW_RESULT
		MATCH_COUNT++
		PRINTFORML {SET_ID,8} | %GETMETH_STR(C_ID, "衣装セット", SET_ID, "名前"),20% | {OLD_RESULT,6} | {NEW_RESULT,6} | 匹配
	ELSE
		MISMATCH_COUNT++
		SETCOLOR 0xFF6600
		PRINTFORML {SET_ID,8} | %GETMETH_STR(C_ID, "衣装セット", SET_ID, "名前"),20% | {OLD_RESULT,6} | {NEW_RESULT,6} | 不匹配
		RESETCOLOR
	ENDIF
	
	; 每20个套装输出进度
	IF TOTAL_COUNT % 20 == 0
		PRINTFORML ...进度: {TOTAL_COUNT}/{MAX_SET} 已测试, {MISMATCH_COUNT} 个不匹配
	ENDIF
NEXT

; 恢复原始装备状态
FOR PART_ID, 1, 23
	EQUIP:C_ID:PART_ID = OLD_EQUIP:PART_ID
NEXT
CFLAG:C_ID:基本服装セット = OLD_CFLAG_BASE
CFLAG:C_ID:衣装一時変更 = OLD_CFLAG_TEMP

PRINTFORML
CALL D_LINE
PRINTFORML 测试完成！
PRINTFORML ----------------------------------------
PRINTFORML 总测试套装数: {TOTAL_COUNT}
PRINTFORML 有效套装数: {TOTAL_COUNT - SKIP_COUNT}
PRINTFORML 跳过套装数: {SKIP_COUNT}
PRINTFORML 匹配数: {MATCH_COUNT}
PRINTFORML 不匹配数: {MISMATCH_COUNT}
IF TOTAL_COUNT - SKIP_COUNT > 0
	PRINTFORML 匹配率: {(MATCH_COUNT * 100) / (TOTAL_COUNT - SKIP_COUNT)}\%
ENDIF
CALL D_LINE
PRINTFORML

; 输出不匹配的套装列表
IF MISMATCH_COUNT > 0
	PRINTFORML 不匹配的套装详情：
	CALL D_LINE
	PRINTFORML 套装ID   | 套装名称              | 旧函数 | 新函数
	CALL D_LINE
	FOR SET_ID, 1, MAX_SET
		IF !STRLENS(GETMETH_STR(C_ID, "衣装セット", SET_ID, "名前"))
			CONTINUE
		ENDIF
		
		; 重新应用套装
		FOR PART_ID, 1, 23
			EQUIP:C_ID:PART_ID = GETMETH_INT(C_ID, "衣装セット", SET_ID, EQUIPNAME:PART_ID)
		NEXT
		
		OLD_RESULT = CURRENT_CLOTHES_SET(C_ID)
		NEW_RESULT = CURRENT_CLOTHES_SET_RECONSTRUCTED(C_ID)
		
		IF OLD_RESULT != NEW_RESULT
			SETCOLOR 0xFF6600
			PRINTFORML {SET_ID,8} | %GETMETH_STR(C_ID, "衣装セット", SET_ID, "名前"),20% | {OLD_RESULT,6} | {NEW_RESULT,6}
			RESETCOLOR
			
			; 输出该套装的装备详情
			PRINTFORML  装备详情:
			FOR PART_ID, 1, 23
				IF GETMETH_INT(C_ID, "衣装セット", SET_ID, EQUIPNAME:PART_ID) != 0
					PRINTFORML   %EQUIPNAME:PART_ID%: {EQUIP:C_ID:PART_ID}
				ENDIF
			NEXT
			PRINTFORML
		ENDIF
	NEXT
ENDIF

; 恢复原始装备状态
FOR PART_ID, 1, 23
	EQUIP:C_ID:PART_ID = OLD_EQUIP:PART_ID
NEXT

WAIT

[SKIPEND]


