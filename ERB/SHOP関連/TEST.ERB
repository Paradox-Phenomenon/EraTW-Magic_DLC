;-------------------------------------------------
; 逻辑处理模块：解析按钮点击与文本指令
;-------------------------------------------------
@DEBUG_MAP_PROCESS(EVENT_TYPE, EVENT_DATA, MAP_MODE)
#DIM EVENT_TYPE
#DIMS EVENT_DATA
#DIMS REF MAP_MODE
#DIM NUM_VAL

; 处理动画更新
IF EVENT_TYPE == 0 && EVENT_DATA == "UPDATE"
	RETURN 3
ENDIF

; 处理 ESC 或 右键退出
IF EVENT_DATA == "ESC" || EVENT_DATA == "MOUSE_R" || EVENT_DATA == "EXIT" || EVENT_DATA == "999"
	RETURN -1
ENDIF

; 忽略空输入
IF EVENT_DATA == ""
	RETURN 1
ENDIF

; --- 按钮点击逻辑优先 ---
SELECTCASE EVENT_DATA
	; 模式切换
	CASE "MODE_HOME"
		MAP_MODE = 
		RETURN 2
	CASE "MODE_ODE"
		MAP_MODE = ODEKAKE
		RETURN 2
	CASE "MODE_GLO"
		MAP_MODE = GLOBAL
		RETURN 2

	; 调整 MAIN_MAP
	CASE "MAP_PREV"
		MAIN_MAP = (MAIN_MAP < 0) ? 11 # MAIN_MAP - 1
		CFLAG:MASTER:约会中 = MAIN_MAP
		TFLAG:地圖切換 = 1
		RETURN 2
	CASE "MAP_NEXT"
		MAIN_MAP = (MAIN_MAP > 11) ? 0 # MAIN_MAP + 1
		CFLAG:MASTER:约会中 = MAIN_MAP
		TFLAG:地圖切換 = 1
		RETURN 2

	; 调整 分页
	CASE "PAGE_PREV"
		TFLAG:地圖切換 = (TFLAG:地圖切換 <= 1) ? MAP_PAGES # TFLAG:地圖切換 - 1
		RETURN 2
	CASE "PAGE_NEXT"
		TFLAG:地圖切換 = (TFLAG:地圖切換 >= MAP_PAGES) ? 1 # TFLAG:地圖切換 + 1
		RETURN 2

	; 调整季节与日期
	CASE "SEASON_PREV"
		DAY:2 = (DAY:2 <= 1) ? 4 # DAY:2 - 1
		RETURN 2
	CASE "SEASON_NEXT"
		DAY:2 = (DAY:2 >= 4) ? 1 # DAY:2 + 1
		RETURN 2
	CASE "DAY_PREV"
		DAY:3 = (DAY:3 <= 1) ? 31 # DAY:3 - 1
		RETURN 2
	CASE "DAY_NEXT"
		DAY:3 = (DAY:3 >= 31) ? 1 # DAY:3 + 1
		RETURN 2

	; 调整动画速度与时停
	CASE "DELAY_SUB"
		ANIMATERECOLOREDMAPS -= 10
		SIF ANIMATERECOLOREDMAPS < 0
			ANIMATERECOLOREDMAPS = 0
		RETURN 2
	CASE "DELAY_ADD"
		ANIMATERECOLOREDMAPS += 10
		RETURN 2
	CASE "TOGGLE_TIME"
		FLAG:70 = !FLAG:70
		RETURN 2
ENDSELECT

; --- 快捷指令解析 (如 "MAP9", "DAY15", "MS100") ---
; 利用 SUBSTRING 截取数字部分进行纯数字判断，避免 "MAP_PREV" 触发
IF STRFIND(EVENT_DATA, "MAP") == 0 && ISNUMERIC(SUBSTRING(EVENT_DATA, 3))
	NUM_VAL = TOINT(SUBSTRING(EVENT_DATA, 3))
	MAIN_MAP = LIMIT(NUM_VAL, 0, 14)
	TFLAG:地圖切換 = 1
	RETURN 2
ELSEIF STRFIND(EVENT_DATA, "DAY") == 0 && ISNUMERIC(SUBSTRING(EVENT_DATA, 3))
	NUM_VAL = TOINT(SUBSTRING(EVENT_DATA, 3))
	DAY:3 = LIMIT(NUM_VAL, 1, 31)
	RETURN 2
ELSEIF STRFIND(EVENT_DATA, "MS") == 0 && ISNUMERIC(SUBSTRING(EVENT_DATA, 2))
	NUM_VAL = TOINT(SUBSTRING(EVENT_DATA, 2))
	ANIMATERECOLOREDMAPS = LIMIT(NUM_VAL, 0, 2000)
	RETURN 2
ELSEIF STRFIND(EVENT_DATA, "FPS") == 0 && ISNUMERIC(SUBSTRING(EVENT_DATA, 3))
	NUM_VAL = TOINT(SUBSTRING(EVENT_DATA, 3))
	ANIMATERECOLOREDMAPS = LIMIT(NUM_VAL, 0, 2000)
	RETURN 2
ENDIF

; 无有效操作，继续等待
RETURN 1

