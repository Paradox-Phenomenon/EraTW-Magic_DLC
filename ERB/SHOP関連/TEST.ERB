@RAINBOW_FUNCTIONS_TEACHING
#DIMS DEMO_TEXT = "哇！彩虹文字来袭～虹色超展开！"

PRINTFORML RAINBOW系是固定12色彩虹的复古游戏风格文字特效，包含静态和动画两大类函数，参数丰富，可以实现多种炫彩效果。以下是各个参数的含义和使用示例：
PRINTFORML 【 全部使用同一段文字示范不同用法 】
PRINTFORML RAINBOW全系参数含义("主体文字", "前缀", "后缀", 偏移量, 是否反向)
; ────────────────────────────────────────────────
; 1. 最基本静态彩虹（无前后缀、无偏移、无反向）
; ────────────────────────────────────────────────
PRINTL ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PRINTL 1. PRINT_RAINBOW 基本款
CALL PRINT_RAINBOW(DEMO_TEXT)
PRINTL 

; ────────────────────────────────────────────────
; 2. 加上前后缀（前后缀保持原本颜色）
; ────────────────────────────────────────────────
PRINTL ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PRINTL 2. 前后加括号（括号不变色）
CALL PRINT_RAINBOW(DEMO_TEXT, "【", "】")
PRINTW 

; ────────────────────────────────────────────────
; 3. 改变起始颜色（偏移量 0～11）
; ────────────────────────────────────────────────
PRINTL ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PRINTL 3. 从不同颜色开始（偏移 4 = 从绿色开始）
CALL PRINT_RAINBOW(DEMO_TEXT, , , 4)
PRINTL 
CALL PRINT_RAINBOW("同样偏移4，但加前后缀", "『", "』", 4)
PRINTW 

; ────────────────────────────────────────────────
; 4. 反向彩虹（颜色逆时针走）
; ────────────────────────────────────────────────
PRINTL ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PRINTL 4. 反向彩虹（最后参数设 1）
CALL PRINT_RAINBOW(DEMO_TEXT, , , , 1)
PRINTW 

; ────────────────────────────────────────────────
; 5. 自动换行版（L 结尾）
; ────────────────────────────────────────────────
PRINTL ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PRINTL 5. PRINT_RAINBOWL（自动换行）
CALL PRINT_RAINBOWL("这句会自动换行哦～", "《", "》")
PRINTW 
; ────────────────────────────────────────────────
; 7. 动画版基本（RAINBOW2）
;    参数：(文字, 循环次数, 前缀, 后缀, 每帧等待毫秒, 模式)
; ────────────────────────────────────────────────
PRINTL ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PRINTL 7. PRINT_RAINBOW2L 动画版（循环8次，每帧80ms）
CALL PRINT_RAINBOW2L(DEMO_TEXT, 8, , , 80, 0)
PRINTW 
; ────────────────────────────────────────────────
; 8. 动画 + 反向
; ────────────────────────────────────────────────
PRINTL ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PRINTL 8. 动画 + 反向（模式1）
CALL PRINT_RAINBOW2L("逆向流动彩虹～", 10, "⇒", "⇐", 70, 1)
PRINTW 

; ────────────────────────────────────────────────
; 9. 动画 + 前后缀也变彩虹（模式 2～5）
;    模式2：前缀正向 + 后缀正向
; ────────────────────────────────────────────────
PRINTL ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PRINTL 9. 模式2：前后缀也彩虹（正向）
CALL PRINT_RAINBOW2L(DEMO_TEXT, 12, "【", "】", 60, 2)
PRINTW 

; ────────────────────────────────────────────────
; 10. 模式5：前缀逆向 + 后缀逆向（最混乱的一种）
; ────────────────────────────────────────────────
PRINTL ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PRINTL 10. 模式5：前后都逆向彩虹
CALL PRINT_RAINBOW2L("全部逆向大混战！", 150, "全部逆向大混战！", "全部逆向大混战！", 50, 5)
PRINTW 

; ────────────────────────────────────────────────
; 12. 等待玩家按键版（W 结尾）
; ────────────────────────────────────────────────
PRINTL ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PRINTL 12. 动画结束后等待按键
CALL PRINT_RAINBOW2W("这段会动完才出现 WAIT", 12, , , 65, 0)

PRINTFORML 
PRINTFORML ── 教学范例结束 ──
PRINTFORML （可自行修改 DEMO_TEXT 内容、循环次数、等待毫秒等参数来玩）

RETURN 1