;这是一个示例，用来说明，ARG不具备动态分配和多实例，所有同名函数共用一组ARG数组。一旦递归，ARG就将覆写。
@FACT(ARG)
IF ARG <= 0
	PRINTFORMW FACT({ARG})==1
	RETURN 1
ENDIF

CALL FACT(ARG - 1)
PRINTFORMW FACT({ARG})== {ARG * RESULT}
RETURN ARG * RESULT

@FACT2(num)
#DIM DYNAMIC num
IF num <= 0
	PRINTFORMW FACT({num}) == 1
	RETURN 1
ENDIF

CALL FACT2(num - 1)
PRINTFORMW FACT({num}) == {num * RESULT}
RETURN num * RESULT

@TEST_XML_ATTRIBUTES
    #DIMS xml_content
    #DIMS result_arr, 20
    #DIMS temp_name, 10
    #DIM loop_i
    #DIMS target_val

    xml_content = 
    xml_content += "<root>"
    xml_content += "  <char id='0'>灵梦</char>"
    xml_content += "  <char id='1'>琪露诺</char>"
    xml_content += "  <char id='2'>魔理沙</char>"
    xml_content += "  <char id='3'>蕾米莉亚</char>"
    xml_content += "  <char id='4'>妹红</char>"
    xml_content += "  <color charid='0'>红色</color>"
    xml_content += "  <color charid='1'>蓝色</color>"
    xml_content += "  <color charid='2'>黑色</color>"
    xml_content += "  <color charid='3'>红色</color>"
    xml_content += "  <color charid='4'>红色</color>"

    ; --- 杂项: 用于测试嵌套属性 ---
    xml_content += "<config version='1.0'><mode>Hard</mode></config>"
    xml_content += "</root>"

    ; 注册 XML 文档，ID 为 100
    XML_DOCUMENT 100, xml_content
 
    PRINTL <root>
    PRINTL   <char id='0'>灵梦</char>
    PRINTL   <char id='1'>琪露诺</char>
    PRINTL   <char id='2'>魔理沙</char>
    PRINTL   <char id='3'>蕾米莉亚</char>
    PRINTL   <char id='4'>妹红</char>
    PRINTL   <color charid='0'>红色</color>
    PRINTL   <color charid='1'>蓝色</color>
    PRINTL   <color charid='2'>黑色</color>
    PRINTL   <color charid='3'>红色</color>
    PRINTL   <color charid='4'>红色</color>
    PRINTL </root>
   
    PRINTFORML ——————————————————————————————————————
    PRINTFORML XML 综合测试：属性获取与反向查找 (文档ID: 100)
    PRINTFORML ——————————————————————————————————————
    

    ;——————————————————————————————————————
    ; 第一部分：基础属性获取与正向查找
    ;——————————————————————————————————————==
    PRINTL [第一部分：基础属性操作]

    ; --- 测试 1: 获取属性值 ---
    ; 场景：我想知道 id=0 的角色的 id 属性是多少（验证读取）
    ; XPath: /root/char[@id='0']/@id
    ;-----------------------------------------------------------
    count = XML_GET(100, "/root/char[@id='0']/@id", result_arr)
    PRINTFORML 1. 读取属性值 (ID=0):
    PRINTFORML 　　结果: %result_arr:0% (期望: 0)

    ; --- 测试 2: 通过属性查找内容 ---
    ; 场景：我想知道 id='1' 的角色名字叫什么
    ; XPath: /root/char[@id='1']
    ; Type: 1 (InnerText)
    ;-----------------------------------------------------------
    count = XML_GET(100, "/root/char[@id='1']", result_arr, 1)
    PRINTFORML 2. 通过属性 ID 查找名字 (ID=1):
    PRINTFORML 　　结果: %result_arr:0% (期望: 琪露诺)

    ; --- 测试 3: 关联查找 (正向) ---
    ; 场景：我想知道 charid='2' (魔理沙) 的颜色是什么
    ; XPath: /root/color[@charid='2']
    ; Type: 1 (InnerText)
    ;-----------------------------------------------------------
    count = XML_GET(100, "/root/color[@charid='2']", result_arr, 1)
    PRINTFORML 3. 关联查找 (查找 ID=2 的颜色):
    PRINTFORML 　　结果: %result_arr:0% (期望: 黑色)

    ; --- 测试 4: 批量获取属性 ---
    ; 场景：获取所有角色的 ID 列表
    ; XPath: /root/char/@id
    ;-----------------------------------------------------------
    count = XML_GET(100, "/root/char/@id", result_arr)
    PRINTFORML 4. 批量获取所有 ID:
    PRINTFORM 　　结果: 
    FOR loop_i, 0, count
        PRINTFORM [%result_arr:loop_i%] 
    NEXT
    PRINTL (期望: 0 1 2 3 4)
    PRINTL 

    ;——————————————————————————————————————==
    ; 第二部分：反向查找与筛选 (模拟 SQL 查询)
    ;——————————————————————————————————————==
    PRINTL [第二部分：反向查找与筛选]

    ; --- 测试 5: 反向查找 (一对多) ---
    ; 场景：查找所有颜色是“红色”的角色 ID，并顺便查出他们的名字
    ; 逻辑：
    ;   1. 找到 <color> 内容是 '红色' 的节点 -> color[.='红色']
    ;   2. 获取该节点的 charid 属性 -> /@charid
    ;-----------------------------------------------------------
    target_val = 红色
    count = XML_GET(100, "/root/color[.='" + target_val + "']/@charid", result_arr)
    
    PRINTFORML 5. 查找颜色为 '%target_val%' 的角色 (一对多测试):
    PRINTFORML 　　匹配数量: {count} (期望: 3)
    PRINTFORML 　　详细列表:
    
    FOR loop_i, 0, count
        ; result_arr:loop_i 现在存的是 ID (例如 "0", "3", "4")
        
        ; 利用查到的 ID，再去查询角色名字，证明关联成功
        ; XPath: /root/char[@id='FoundID']
        LOCAL = XML_GET(100, "/root/char[@id='" + result_arr:loop_i + "']", temp_name, 1)
        
        PRINTFORML 　　  - ID [%result_arr:loop_i%] -> 名字: %temp_name:0%
    NEXT

    ; --- 测试 6: 反向查找 (一对一) ---
    ; 场景：查找颜色是“蓝色”的角色 ID
    ;-----------------------------------------------------------
    target_val = 蓝色
    count = XML_GET(100, "/root/color[.='" + target_val + "']/@charid", result_arr)
    PRINTL 
    PRINTFORML 6. 查找颜色为 '%target_val%' 的角色 (单项测试):
    PRINTFORML 　　结果 ID: %result_arr:0% (期望: 1)

    ; --- 测试 7: 查找不存在的值 ---
    ; 场景：查找颜色是“金色”的角色 ID
    ;-----------------------------------------------------------
    target_val = 金色
    count = XML_GET(100, "/root/color[.='" + target_val + "']/@charid", result_arr)
    PRINTL 
    PRINTFORML 7. 查找不存在的颜色 '%target_val%':
    PRINTFORML 　　结果数量: {count} (期望: 0)

    WAIT
