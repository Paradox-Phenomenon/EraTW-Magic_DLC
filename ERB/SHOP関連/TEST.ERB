;-------------------------------------------------
;函数名:@DEBUG_MAP_TOOL
;概　要:动态地图渲染调试工具
;参　数:无
;返回值:无
;备　注:用于实时调试 DRAW_COLOREDMAP 的渲染效果、FPS以及季节变色
;-------------------------------------------------
@DEBUG_MAP_TOOL
#DIM DYNAMIC INPUT_LOOP_LINE
#DIM DYNAMIC ANIMATION_SEED
#DIM DYNAMIC PREV_REDRAW
#DIM DYNAMIC UPDATE_INTERVAL
#DIMS DYNAMIC LISTEN_CONF
#DIM  DYNAMIC AWAIT_HANG

; --- 1. 状态备份 (防止搞坏玩家存档) ---
#DIM BACKUP_MAIN_MAP
#DIM BACKUP_PAGE
#DIM BACKUP_FLAG70
#DIM BACKUP_DAY2
#DIM BACKUP_DAY3
#DIM BACKUP_ANIM
#DIMS MAP_MODE ; "" = 家, "ODEKAKE" = 外出, "GLOBAL" = 幻想乡

BACKUP_MAIN_MAP = MAIN_MAP
BACKUP_PAGE     = TFLAG:地圖切換
BACKUP_FLAG70   = FLAG:70
BACKUP_DAY2     = DAY:2
BACKUP_DAY3     = DAY:3
BACKUP_ANIM     = ANIMATERECOLOREDMAPS

; 初始化测试环境
MAP_MODE = 
ANIMATION_SEED = 0
PREV_REDRAW = CURRENTREDRAW()

; 构建输入监听配置：监听左键、右键、回车、ESC
LISTEN_CONF = %UI_AWAIT_CONFIG("DEFAULT", "", 1, 0, 1)%

LINESTART = LINECOUNT
$MAP_LOOP
CLEARLINE LINECOUNT - LINESTART

REDRAW 0
CALL DEBUG_MAP_DRAW(ANIMATION_SEED, MAP_MODE)
REDRAW PREV_REDRAW

INPUT_LOOP_LINE = LINECOUNT
$INPUT_LOOP
CLEARLINE LINECOUNT - INPUT_LOOP_LINE

; 决定动画刷新间隔
AWAIT_HANG = (ANIMATERECOLOREDMAPS > 0 && !FLAG:70)
UPDATE_INTERVAL = AWAIT_HANG ? ANIMATERECOLOREDMAPS # 0

IF AWAIT_HANG
	SETTEXTBOX MOUSEB()
	CALL AWAIT_UI_INPUT(LISTEN_CONF, UPDATE_INTERVAL)
ELSE
	INPUTS
	RESULT = 1
ENDIF

; 逻辑分发
CALL DEBUG_MAP_PROCESS(RESULT, RESULTS, MAP_MODE)
SELECTCASE RESULT
	CASE -1 ; 退出
		GOTO EXIT_TOOL
	CASE 1  ; 无效输入，继续等待
		GOTO INPUT_LOOP
	CASE 2  ; 状态改变，需要重绘
		GOTO MAP_LOOP
	CASE 3  ; 动画Tick
		ANIMATION_SEED = (ANIMATION_SEED + 1) % 20
		GOTO MAP_LOOP
ENDSELECT

$EXIT_TOOL
; --- 退出时还原状态 ---
MAIN_MAP             = BACKUP_MAIN_MAP
CFLAG:MASTER:约会中  = BACKUP_MAIN_MAP
TFLAG:地圖切換       = BACKUP_PAGE
FLAG:70              = BACKUP_FLAG70
DAY:2                = BACKUP_DAY2
DAY:3                = BACKUP_DAY3
ANIMATERECOLOREDMAPS = BACKUP_ANIM
PRINTW [测试结束] 已还原所有时间和地图设置。
RETURN

