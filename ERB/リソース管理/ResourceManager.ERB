;*******************************************************************************************************
; 资源管理器 (已完全由 C# 引擎层接管)
;*******************************************************************************************************
@RM_タイトル画像用意
	#LOCALSIZE 1
	#LOCALSSIZE 1
	SIF !GCREATED(RM_TITLE)
		GCREATEFROMFILE RM_TITLE, "title.webp"
	FOR I, 0, 35
		SPRITECREATE "TW_title"+TOSTR(I, "D3"), RM_TITLE, 0, I*16, 1041, 16
	NEXT

@SYSTEM_LOADEND
	#LOCALSIZE 1
	#LOCALSSIZE 1
	CLEARMEMORY
	; 释放标题图像
	IF GCREATED(RM_TITLE)
		GDISPOSE RM_TITLE
		FOR I, 0, 35
			SPRITEDISPOSE "TW_title"+TOSTR(I, "D3")
		NEXT
	ENDIF

;*******************************************************************************************************
; 返回精灵的宽度 / 高度
;*******************************************************************************************************
@RM_SPRITEWIDTH(リソース名)
	#LOCALSIZE 1
	#LOCALSSIZE 1
    #DIMS DYNAMIC リソース名
    #FUNCTION
    SIF RM_RESOURCECHECK_LOAD(リソース名)
        RETURNF SPRITEWIDTH(リソース名)
    RETURNF 0

@RM_SPRITEHEIGHT(リソース名)
	#LOCALSIZE 1
	#LOCALSSIZE 1
	#DIMS DYNAMIC リソース名
	#FUNCTION
	SIF RM_RESOURCECHECK_LOAD(リソース名)
		RETURNF SPRITEHEIGHT(リソース名)
	RETURNF 0

;*******************************************************************************************************
; 检查精灵是否存在 (由 C# 引擎直接接管加载和 LRU 缓存)
;*******************************************************************************************************
@RM_RESOURCECHECK(リソース名)
	#LOCALSIZE 1
	#LOCALSSIZE 1
	#DIMS DYNAMIC リソース名
	#FUNCTION
	RETURNF RM_RESOURCE_EXIST(リソース名)

;*******************************************************************************************************
; 手动释放所有资源 (一般不需要调用，因为 C# 有 LRU 自动淘汰，但提供接口以防万一)
;*******************************************************************************************************
@RM_全部リリース
	#LOCALSIZE 1
	#LOCALSSIZE 1
	RM_RELEASE_ALL