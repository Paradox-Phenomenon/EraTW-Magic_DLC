[SKIPSTART]
;LSU管理
;本来就没有释放的必要，LSU作为可行的扩展
SIF !MAP_EXIST(RM_LRU_MAP)
	MAP_CREATE RM_LRU_MAP  ; 键=资源名, 值=最后使用时间

; 在 @RM_RESOURCECHECK_LOAD 末尾添加
SIF SPRITECREATED(リソース名)
	CALL RM_UPDATE_LRU(リソース名)  ; 更新 LRU
	CALL RM_CHECK_CACHE_LIMIT  ; 检查并淘汰超限

; 更新 LRU 时间
@RM_UPDATE_LRU(リソース名)
#DIMS リソース名
MAP_SET RM_LRU_MAP, リソース名, GETMILLISECOND()  ; 用当前毫秒时间戳标记最近使用

; 检查缓存上限并淘汰 LRU
@RM_CHECK_CACHE_LIMIT
#DIMS KEYS, RM_CACHE_MAX + 10
IF MAP_SIZE(RM_GMAP) > RM_CACHE_MAX
	MAP_GETKEYS RM_GMAP, KEYS, 1
	LOCAL = RESULT  ; 键数
	VARI TIMES, LOCAL
	FOR I, 0, LOCAL
		TIMES:I = TOINT(MAP_GET(RM_LRU_MAP, KEYS:I))  ; 获取时间戳
	NEXT
	; 找到最小时间戳的索引（最久未用）
	LOCAL:1 = MAXARRAY(TIMES)
	LOCAL:2 = KEYS:(LOCAL:1)  ; 最旧资源名
	; 释放它
	CALL RM_RELEASE_RESOURCE(LOCAL:2)
	PRINTFORML [RM] 淘汰 LRU 资源: %LOCAL:2%
ENDIF

; 释放单个资源（G_ID + Sprite）
@RM_RELEASE_RESOURCE(リソース名)
#DIMS リソース名
#DIM G_ID
IF MAP_HAS(RM_GMAP, リソース名)
	G_ID = TOINT(MAP_GET(RM_GMAP, リソース名))
	GDISPOSE G_ID
	CALLF BitSet(RM_GID_BITS, G_ID - RM_GID_BASE, 0)
	MAP_DEL RM_GMAP, リソース名
ENDIF
IF MAP_HAS(RM_SMAP, リソース名)
	SPRITEDISPOSE リソース名
	MAP_DEL RM_SMAP, リソース名
ENDIF
MAP_DEL RM_LRU_MAP, リソース名

; 恢复 EVENT 触发（但可选，只清部分）
@EVENTTURNEND
;#LATER
CALL RM_RELEASE_UNUSED

; 类似 RM_CHECK_CACHE_LIMIT，但清到 RM_CACHE_MAX / 2
@RM_RELEASE_UNUSED
WHILE MAP_COUNT(RM_GMAP) > RM_CACHE_MAX / 2
	; 重复淘汰 LRU
	CALL RM_CHECK_CACHE_LIMIT
WEND
[SKIPEND]