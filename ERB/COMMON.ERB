;-------------------------------------------------
;時刻変換(HOUR, MINUTE)
;与えられたHOUR時MINUTE分をTIME用に変換
;念のためにHOURが25だったりMINUTEが61だったりした場合にも対応した
;例）CLOCK_TO_TIME(10, 0)をすると返る数値は600
;eraTWの一日は00:01～24:00の範囲、詳しくは@INFO_GO_NEXTDAYを見よ
;-------------------------------------------------
@CLOCK_TO_TIME(HOUR, MINUTE)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM HOUR
#DIM MINUTE
SIF HOUR == 24 && MINUTE == 0
	RETURNF 24 * 60
HOUR   = (HOUR + MINUTE / 60) % 24
MINUTE = MINUTE % 60
RETURNF HOUR * 60 + MINUTE



