;-------------------------------------------------
@COLOR_STAMP(STAMP_NUM, MAX_NUM, STAMP_STR, STAMP_COLOR, ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM  STAMP_NUM   ;並べるスタンプの数
