;関数置き場
;-------------------------------------------------
;道具販売状況@ITEMSTOCK
;戻り値1 道具が存在しない
;戻り値2 卖完
;戻り値3 お金が足りない
;戻り値4 条件を満たしていない
;戻り値5 すでに99个所持している
;-------------------------------------------------
@ITEMSTOCK(ARG, 値段)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM 値段
SIF !STRLENS(ITEMNAME:ARG)
	RETURNF 1
SIF ITEMSALES:ARG == -2
	RETURNF 4
SIF ITEMSALES:ARG == -1
	RETURNF 2
SIF MONEY < 値段
	RETURNF 3
SIF ITEM:ARG >= 999
	RETURNF 5
RETURNF 0

