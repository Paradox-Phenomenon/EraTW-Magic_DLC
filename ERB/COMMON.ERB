;-------------------------------------------------
;関数名:RECOVER
;概　要:BASE回復処理
;		表示文字列が空の場合かつ回復量が100未満非表示
;		表示文字列がある場合は表示
;引　数:ARG:0	参照する角色番号
;		回復量	ARGSに対応するBASEに加算する値（負数の場合は減らす）
;       ARGS	ベース名
;		ARGS:1	表示文字列
;-------------------------------------------------
@RECOVER(ARG,回復量,ARGS,ARGS:1)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM BASE_ID
#DIM 回復量
SIF 回復量 == 0 || !CHECK_BASE(ARG, ARGS)
	RETURN
;回復処理
IF MAGIC_DLC 
	IF (ARGS == "TSP" || ARGS == "法力") && 回復量 < 0 
		SIF ARGS == "TSP"
			MONEY:1 -= 回復量
		SIF TALENT:ARG:大魔法师
			回復量 = 回復量 * 7 / 10
		SIF TALENT:ARG:昨日重现
			回復量 = 回復量 * (20 - TALENT:ARG:昨日重现) / 20
	ENDIF
ENDIF
BASE:ARG:(ARGS) = LIMIT(BASE:ARG:(ARGS) + 回復量, 0, MAXBASE:ARG:(ARGS))
;表示処理
SIF 回復量 > 0 && 回復量 < 100 && ARGS:1 == ""
	RETURN
IF CFLAG:ARG:現在位置 == CFLAG:MASTER:現在位置
	BASE_ID = GETNUM(BASE, ARGS)
	LOCALS = \@ ARGS:1 != "" ? （%ARGS:1%） # \@
	IF 回復量 > 0
		CALL COLORMESSAGE(@"%BASE_TR(BASENAME:BASE_ID)%＋{回復量} （%CALLNAME:ARG%）%LOCALS%",C_GREEN,1)
	ELSEIF 回復量 < 0
		CALL COLORMESSAGE(@"%BASE_TR(BASENAME:BASE_ID)%－{ABS(回復量)} （%CALLNAME:ARG%）%LOCALS%",C_RED,1)
	ENDIF
ENDIF

;-------------------------------------------------
;関数名:RECOVER_PERMIL
;概　要:BASE割合回復処理
;引　数:ARG:0		参照する角色番号
;		回復割合	MAXBASE対して算出する値（負数の場合は減らす）
;       ARGS		ベース名
;       回復速度の影響
;		ARGS:1		表示文字列
;回復割合は0.1%単位
;-------------------------------------------------
@RECOVER_PERMIL(ARG,回復割合,ARGS,回復速度の影響,ARGS:1="")
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM 回復割合
#DIM 回復速度の影響
#DIM 回復量
SIF !CHECK_BASE(ARG, ARGS)
	RETURN
回復量 = MAXBASE:ARG:(ARGS) * 回復割合 / 1000
SIF 回復速度の影響
	回復量 = 回復量 * (TALENT:ARG:回復速度 + 4) / 4
CALL RECOVER(ARG, 回復量, ARGS, ARGS:1)

;-------------------------------------------------
;関数名:RECOVER_PERMIL_BOTH
;概　要:RECOVER_PERMILを你と対象角色両方やる
;-------------------------------------------------
@RECOVER_PERMIL_BOTH(ARG,回復割合,ARGS,回復速度の影響,ARGS:1="")
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM 回復割合
#DIM 回復速度の影響
CALL RECOVER_PERMIL(ARG,回復割合,ARGS,回復速度の影響,ARGS:1)
SIF ARG != MASTER
	CALL RECOVER_PERMIL(MASTER,回復割合,ARGS,回復速度の影響,ARGS:1)

;-------------------------------------------------
;関数名:CHECK_BASE
;概　要:ARGが使えるBASEか判定
;戻り値:0：使用不可
;		1：使用可能
;-------------------------------------------------
@CHECK_BASE(ARG, ARGS)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_ID
L_ID = GETNUM(BASE, ARGS)
IF L_ID < 0
	PRINTFORML 没有找到%ARGS%，请保存日志报错
	RETURNF 0
ENDIF
SELECTCASE L_ID
	CASE BASE_体力, BASE_气力
	;竿無ならスキップ
	CASE BASE_精力, BASE_勃起, BASE_射精
		SIF !HAS_PENIS(ARG)
			RETURNF 0
	;你以外TSPスキップ
	CASE BASE_TSP
		SIF ARG != MASTER
			RETURNF 0
	CASE BASE_母乳
		SIF !TALENT:ARG:母乳体質
			RETURNF 0
ENDSELECT
RETURNF 1
;-------------------------------------------------
;関数名:CHANGE_MAXBASE(魔法DLC)
;概要:特定BASE的永久变化
;-------------------------------------------------
@CHANGE_MAXBASE(ARG,强化能力,变动值,info = 0)
#DIM 变动值
#DIM 强化能力
#DIM info
SIF !CHECK_BASE(ARG, BASENAME:强化能力)
	RETURN
IF MAGIC_DLC
	SIF 变动值 < 0 && ABS(变动值) > MAXBASE:ARG:强化能力
		变动值 = (MAXBASE:ARG:强化能力 -1) * -1
	SIF (MAXBASE:ARG:强化能力 + 变动值) > 9999999
		变动值 = 9999999 - MAXBASE:ARG:强化能力
	MAXBASE:ARG:强化能力 += 变动值
	SIF (info == 1 || (info == 2 && ARG == MASTER))&& 变动值 != 0
		CALL COLORMESSAGE(@"%CALLNAME:ARG%的%BASENAME:强化能力%永久\@ 变动值 > 0? 上升了# 下降了\@{ABS(变动值)}",C_YELLOW,1)
ELSE
	MAXBASE:ARG:强化能力 += 变动值
ENDIF

;-------------------------------------------------
;関数名:BUFF_BASE
;概　要:特定BASEを一時的に強化
;-------------------------------------------------
@BUFF_BASE(ARG,強化能力,変動値,メッセージ)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM 変動値
#DIM 強化能力
#DIM メッセージ
SIF MAXBASE:ARG:強化能力 <= 0
	RETURN
IF !MAGIC_DLC
	SIF 変動値 < 0 && ABS(変動値) > MAXBASE:ARG:強化能力
		変動値 = (MAXBASE:ARG:強化能力 -1) * -1

	MAXBASE:ARG:強化能力 += 変動値
	BASE:ARG:強化能力 += 変動値
	BUFF:ARG:強化能力 += 変動値
	;failsafe
	MAXBASE:ARG:強化能力 = MAX(0, MAXBASE:ARG:強化能力)
	BASE:ARG:強化能力 = MAX(0, BASE:ARG:強化能力)
	SIF メッセージ
		CALL COLORMESSAGE(@"%CALLNAME:ARG%的%BASE_TR(BASENAME:強化能力)%暂时\@ 変動値 > 0? 上升了# 下降了\@{ABS(変動値)}",C_YELLOW,1)
ELSE
	SIF 変動値 < 0 && ABS(変動値) > MAXBASE:ARG:強化能力
		変動値 = (MAXBASE:ARG:強化能力 -1) * -1
	SIF (MAXBASE:ARG:強化能力 + 変動値) > 9999999
		変動値 = 9999999 - MAXBASE:ARG:強化能力
	MAXBASE:ARG:強化能力 += 変動値
	BASE:ARG:強化能力 += 変動値
	BUFF:ARG:強化能力 += 変動値
	SIF (メッセージ == 1 || (メッセージ == 2 && ARG == MASTER))&& 変動値 != 0
		CALL COLORMESSAGE(@"%CALLNAME:ARG%的%BASENAME:強化能力%暂时的\@ 変動値 > 0? 上升了# 下降了\@{ABS(変動値)}",C_YELLOW,1)
ENDIF
;-------------------------------------------------
;関数名:BUFF_RESET
;概　要:Buffを完全にリセット
;-------------------------------------------------
@BUFF_RESET
#LOCALSIZE 2
#LOCALSSIZE 1
FOR LOCAL,0,CHARANUM
	FOR LOCAL:1, 0, 16
		SIF BUFF:LOCAL:(LOCAL:1) == 0
			CONTINUE
		MAXBASE:LOCAL:(LOCAL:1) = MAX(0, MAXBASE:LOCAL:(LOCAL:1) - BUFF:LOCAL:(LOCAL:1))
		BASE:LOCAL:(LOCAL:1) = MAX(0, MAXBASE:LOCAL:(LOCAL:1) - BUFF:LOCAL:(LOCAL:1))
		BUFF:LOCAL:(LOCAL:1) = 0
	NEXT
NEXT

;-------------------------------------------------
;関数名:CHANGE_CFLAG
;概　要:メッセージ付きCFLAG変動
;减少にはならないようになってるので注意
;-------------------------------------------------
@CHANGE_CFLAG(変動フラグ,対象,変動数,DISPLAY_TYPE = 2, DESCRIPTION = "") ;custom code, added DISPLAY_TYPE, DESCRIPTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM 変動フラグ
#DIM 対象
#DIM 変動数
#DIM DISPLAY_TYPE ;custom code
#DIMS DESCRIPTION ;custom code
IF 変動フラグ < 0
	PRINTFORMW 没有找到CFLAG:{変動フラグ}，请保存日志报错
	RETURN
ENDIF

CFLAG:対象:変動フラグ = MAX(CFLAG:対象:変動フラグ + 変動数, 0)
IF 変動数 > 0
	;Custom code, translate Favor/trust
	CALL COLORMESSAGE(@"%CFLAGNAME_TR(CFLAGNAME:変動フラグ)%＋{変動数}（%CALLNAME:対象%）%COND_STR(@"（%DESCRIPTION%）", DESCRIPTION != "")%",C_YELLOW,DISPLAY_TYPE,1)
ELSEIF 変動数 < 0 ;don't show if zero
	;Custom code, translate Favor/trust
	CALL COLORMESSAGE(@"%CFLAGNAME_TR(CFLAGNAME:変動フラグ)%−{-変動数}（%CALLNAME:対象%）%COND_STR(@"（%DESCRIPTION%）", DESCRIPTION != "")%",C_RED,DISPLAY_TYPE,1)
ENDIF

;-------------------------------------------------
;函数名:AddEXP
;概　要:附带消息文本的经验值增加
;-------------------------------------------------
@AddEXP(ENUM,C_ID,MOD_NUM)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC LABEL
#DIMS ENUM
#DIMS VARNAME
#DIM C_ID
#DIM MOD_NUM
VARNAME = EXP

SIF MOD_NUM == 0 || !INRANGE(C_ID,0,CHARANUM)
	RETURN

LABEL '= QOL_GETENUMNAME(VARNAME,ENUM)
IF LABEL == "NULL"
	PRINTFORMW [错误]参数1 "%ENUM%" 不是合法的[%VARNAME%]类型名称或ID，请保存日志报错
	RETURN
ENDIF
LOCAL = QOL_GETVAR(VARNAME,ENUM,C_ID)
IF LOCAL == 安全失败值
	DEBUGPRINTFORML [警告]尝试读取 %VARNAME%:%ENUM% 失败。
	RETURN 0
ENDIF
IF MOD_NUM > 0
	CALL COLORMESSAGE(@"%LABEL%＋{MOD_NUM}（%CALLNAME:C_ID%）",C_YELLOW,2,1)
ELSE
	CALL COLORMESSAGE(@"%LABEL%－{-MOD_NUM}（%CALLNAME:C_ID%）",C_RED,2,1)
ENDIF

IF QOL_SETVAR(VARNAME,ENUM,MAX(LOCAL + MOD_NUM, 0),C_ID)
	RETURN 1
ELSE 
	DEBUGPRINTFORML %VARNAME%:%ENUM%赋值失败
ENDIF


;-------------------------------------------------
;関数名:SHIRAHU
;概　要:普通に意識がある状態か　2だとウフフ中
;-------------------------------------------------
@SHIRAHU(ARG)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
IF FLAG:時間停止 && CFLAG:ARG:時間停止行動 == 0
	RETURNF 0
ELSEIF !CFLAG:ARG:睡眠 && !CFLAG:ARG:陪睡中 && !TCVAR:ARG:烂醉 && !CFLAG:ARG:衰弱
	IF TFLAG:102 > 1
		RETURNF 2
	ELSE
		RETURNF 1
	ENDIF
ELSE
	RETURNF 0
ENDIF

;-------------------------------------------------
;関数名:BETWEENTIME
;概　要:TIMEがARGからARG:1までの間なのか返す関数
;-------------------------------------------------
@BETWEENTIME(ARG,ARG:1)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
IF ARG < ARG:1
	IF TIME >= ARG && TIME < ARG:1
		RETURNF 1
	ELSE
		RETURNF 0
	ENDIF
ELSE
	IF TIME >= ARG || TIME < ARG:1
		RETURNF 1
	ELSE
		RETURNF 0
	ENDIF
ENDIF
;-------------------------------------------------
;関数名:VISIT
;概　要:その角色の活動時間帯かどうかを返す関数    判断该角色是否处于活动时间段的函数
;-------------------------------------------------
@VISIT(ARG)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
;幻想乡大地图 如果是据点地图模式，且玩家所在地图位于其初期地图，则起床-来访和归宅-就寝时间区间也视为活动时间
SIF GMF_GETBIT("幻想乡大地图") && !GMF_IS_ODEKAKE(-1) && GET_MAPID(CFLAG:MASTER:現在位置) == GET_MAPID(CFLAG:ARG:初期位置) && (BETWEENTIME(CFLAG:ARG:起床時間,CFLAG:ARG:来訪時間) || BETWEENTIME(CFLAG:ARG:帰宅時間,CFLAG:ARG:就寝時間))
	RETURNF 1

;if they're on the main map before visit time (e.g. slept over), they don't go home    如果他们在访问时间之前已经在主地图上（例如留宿），那么他们就不会回家
SIF (BETWEENTIME(CFLAG:ARG:起床時間,CFLAG:ARG:来訪時間) || CFLAG:ARG:睡眠) && CFLAG:MASTER:初期位置 == CFLAG:ARG:現在位置 && CFLAG:ARG:拠点来訪
	RETURNF 1

RETURNF BETWEENTIME(CFLAG:ARG:来訪時間,CFLAG:ARG:帰宅時間)
;-------------------------------------------------
;関数名:睡眠時間
;概　要:住宿人物が寝てるかどうかを返す関数だったのを全員使えるように    将原本只对住宿人员是否在睡觉进行反馈的函数改为全员可用
;寝てると1を返す    睡觉时返回1
;-------------------------------------------------
@睡眠時間(ARG)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
SIF ARG == MASTER
	RETURNF CFLAG:MASTER:睡眠
IF CFLAG:ARG:衰弱
	RETURNF 1
ELSE
	;睡眠時間をチェックする    检查睡眠时间
	CALLF 睡眠時間２(ARG)
	IF !BETWEENTIME(CFLAG:ARG:起床時間, CFLAG:ARG:就寝時間 + CFLAG:ARG:清醒劑)
		RETURNF 1
	ELSE
		RETURNF 0
	ENDIF
ENDIF
;-------------------------------------------------
;関数名:睡眠時間２
;概　要:角色ARGが寝てから起きるまでの時間の計測    测量角色ARG从睡下到醒来的时间
;逸脱していた場合は自動で修正する    如有偏离则自动修正
;-------------------------------------------------
@睡眠時間２(ARG)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM SLEEPTIME
#DIM WAKEUPTIME
;清醒劑の強度分延長する    清醒剂延长持续时间
WAKEUPTIME = CFLAG:ARG:起床時間
SLEEPTIME = CFLAG:ARG:就寝時間 + CFLAG:ARG:清醒劑
;就寝時間が24時を超えている場合    若就寝时间超过24点的情况
WHILE SLEEPTIME >= 1440
	SLEEPTIME -= 1440
WEND
;前日の夜に寝て翌日の朝に起きる場合    前一天晚上睡下第二天早上起的情况
SIF SLEEPTIME > WAKEUPTIME
	WAKEUPTIME += 1440
;睡眠時間が2～14時間を逸している場合はチェック    若睡眠时间偏离2～14小时进行检查
IF !INRANGE(WAKEUPTIME - SLEEPTIME, 120, 840)
	;清醒劑が原因
	IF CFLAG:ARG:清醒劑
		;30分ずつ是正していく
		CFLAG:ARG:清醒劑 -= 30
		RESTART
	;設定がおかしい
	ELSE
		[IF_DEBUG]
			;チェックのためTHROWしておく,路人子は許可,一時的に守矢神簽対策,あとで修正,THROWはアレなのでデバッグ用に
			;SIF ARG != [[モブ子]] && CFLAG:ARG:起床時間 % 1440 != CFLAG:ARG:就寝時間 % 1440 && !CFLAG:ARG:出禁
				;THROW
		[ENDIF]
	ENDIF
ENDIF
RETURNF WAKEUPTIME - SLEEPTIME

;-------------------------------------------------
;角色の生活時間を設定する関数
;一日の始まりに設定する
;-------------------------------------------------
@生活時間設定(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
;新增剧本侧接口，调用剧本侧设定的角色移动数值
CALL KOJO_CHECK(CHARA, "CHARADATA", "MOVE", 3)
IF RESULT == -1
	;剧本侧禁用该机制
	;对于生活时间设定，禁用等于什么都不会发生
ELSEIF RESULT
	;采用剧本设定的值
ELSE 
;剧本没有采用CHECK函数或者剧本需要是结果为0，从而采用原版移动数值
TRYCALLFORM CHARAMOVE_DATA_{NO:CHARA}(3)
ENDIF 
CFLAG:CHARA:起床時間 = 時刻計算(CSVCFLAG(CHARA, GETNUM(CFLAG, "起床時間")) + CFLAG:CHARA:生活時間補正)
CFLAG:CHARA:来訪時間 = 時刻計算(CSVCFLAG(CHARA, GETNUM(CFLAG, "来訪時間")) + CFLAG:CHARA:生活時間補正)
CFLAG:CHARA:帰宅時間 = 時刻計算(CSVCFLAG(CHARA, GETNUM(CFLAG, "帰宅時間")) + CFLAG:CHARA:生活時間補正)
CFLAG:CHARA:就寝時間 = 時刻計算(CSVCFLAG(CHARA, GETNUM(CFLAG, "就寝時間")) + CFLAG:CHARA:生活時間補正)
;大晦日はみんな夜ふかし    跨年夜大家都熬夜
IF FESTIVAL() == "大晦日"
	IF INRANGE(CFLAG:CHARA:帰宅時間, 900 , 1440) || INRANGE(CFLAG:CHARA:帰宅時間, 0 , 59) || INRANGE(CFLAG:CHARA:就寝時間, 900 , 1440) || INRANGE(CFLAG:CHARA:就寝時間, 0 , 119)
		CFLAG:CHARA:帰宅時間 = 60
		CFLAG:CHARA:就寝時間 = 120
	ENDIF
ENDIF
;-------------------------------------------------
;時刻の計算
;時刻X+Yを時刻で返す
;-------------------------------------------------
@時刻計算(ARG)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = ARG
WHILE LOCAL > 1440
	LOCAL -= 1440
WEND
WHILE LOCAL < 0
	LOCAL += 1440
WEND
RETURNF LOCAL

;-------------------------------------------------
;関数名:兒童の睡眠時間
;概　要:角色ARGの兒童が寝てるかどうかを返す関数
;寝てると1を返す
;-------------------------------------------------
@兒童の睡眠時間(ARG)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM 兒童の起床時間
#DIM 兒童の就寝時間
SIF !TALENT:ARG:育児中
	RETURNF 0
兒童の起床時間 = CFLAG:ARG:起床時間
兒童の就寝時間 = CFLAG:ARG:就寝時間 - 120 + (CFLAG:ARG:就寝時間 - 120 < 0 ? 1440 # 0 )
IF !BETWEENTIME(兒童の起床時間, 兒童の就寝時間)
	RETURNF 1
ELSE
	RETURNF 0
ENDIF
