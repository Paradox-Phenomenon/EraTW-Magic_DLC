	RETURNF TALENT:C_ID:人类 && (TALENT:C_ID:妖怪 || TALENT:C_ID:妖精 || TALENT:C_ID:神霊 || TALENT:C_ID:幽霊 || TALENT:C_ID:付喪神 || TALENT:C_ID:人形)
