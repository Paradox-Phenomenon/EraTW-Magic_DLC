;-------------------------------------------------
;関数名:Counter不発指令
;戻り値:0でないとCounter不発
;-------------------------------------------------
@Counter不発指令(ARG)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
SELECTCASE ARG
	;(天候パッチ)「眺望天空」はCounter不发
	CASE 495
		RETURNF 1
	;立即行为：告白&炮友契约 
	CASE 352,357
		RETURNF 1
	;养鸡补丁
	CASE 499
		RETURNF 1
	;换装补丁
	CASE 429
		RETURNF 1
	;可能的立即行为：特殊地点移动
	CASE 464
		SIF SPECIAL_AREAMOVE_TIME() <= 1
			RETURNF 1
	;读日记
	CASE 406
		RETURNF 1
	;自定义指令补丁
	CASE ADD_CUSTOM_COM
		RETURNF Counter不发_ADD_CUSTOM(ADD_SELECTCUSTOMCOM)
	CASE 697 TO 699
		RETURNF 1
	;外出、推倒、挣扎
	CASE 405, 350, 850
		RETURNF 1
	CASEELSE
		RETURNF 0
ENDSELECT
;-------------------------------------------------
;関数名:ENDUFUFU
;概　要:诶嘿嘿終了時リセット処理
;-------------------------------------------------
@ENDUFUFU(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
[IF DEBUG]
	PRINTFORML 诶嘿嘿終了処理
[ENDIF]
IF CFLAG:ARG:诶嘿嘿
	CALLF SET_UPDATECHECK(TOSTR(ARG), "WITHDRAWN_LIST", , 1)
ENDIF
;時間停止中は服装セットしない
;睡眠中分岐などは全部リセット処理側にあります
SIF !FLAG:時間停止
	CALL CHANGE_CLOTHES(ARG, "复原衣服")
;服装をTEQUIPへ
CALL CLOTHES_SETTING_TRAIN(ARG)

;MASTERとの接触位置をリセット
CALL TOUCH_SET(0, 0, 0, 1)

;ウフフ時系装備リセット
;TEQUIP:ARG:10-TEQUIP:ARG:149を初期化する
VARSET TEQUIP:ARG:0, 0, 10, 150

;魔法DLC的魅惑发情解除
IF TCVAR:ARG:魅惑发情 && MAGIC_DLC
	TCVAR:ARG:発情 = 0
	TCVAR:ARG:魅惑发情 = 0
ENDIF
;射精関係リセット
IF TFLAG:102 < 2
	BASE:ARG:射精 = 0
	TCVAR:ARG:要去了 = 0
ENDIF
CFLAG:ARG:诶嘿嘿 = 0
TEQUIP:ARG:50 = -1
TEQUIP:ARG:51 = -1
TEQUIP:ARG:上半身裸露状態 = 0
;TEQUIP:ARG:下半身挪開状態 = 0
TEQUIP:ARG:上衣脱衣完毕 = 0
TEQUIP:ARG:縄 = 0
TEQUIP:ARG:拘束 = 0
TCVAR:ARG:强行 = 0
TCVAR:ARG:随便 = 0
TCVAR:ARG:次回Counter = 0
;一応MASTERも初期化（しとかないと、終了後も○○装着中が表示される可能性があるので
IF CFLAG:MASTER:诶嘿嘿
	CFLAG:MASTER:诶嘿嘿 = 0
	CALL CHANGE_CLOTHES(MASTER, "复原衣服")
	CALL CLOTHES_SETTING_TRAIN(MASTER)
	VARSET TEQUIP:MASTER:0, 0, 10, 150
	TEQUIP:MASTER:50 = -1
	TEQUIP:MASTER:51 = -1
	TEQUIP:MASTER:上半身裸露状態 = 0
	;TEQUIP:MASTER:下半身挪開状態 = 0
	CALL ADD_TOUCH_CLEAR() ;addition custom code
ENDIF

IF CFLAG:睡眠
	IF CFLAG:ARG:口内精液
		IF TALENT:ARG:精愛味覚 == 1
			SETCOLOR C_PINK
			PRINTFORML ❤～
			PRINTFORML 梦中的%CALLNAME:ARG%自然的饮下了%CALLNAME:MASTER%赠与的白浊，随后就像触发了什么开关一样缓缓将手移到身下，满面红潮
			TCVAR:ARG:発情 = 1
			IF MAGIC_DLC
				CFLAG:ARG:积攒度 += LIMIT((10 + RAND:20 + RAND:20 + RAND:20) * ABL:ARG:欲望,200,积攒度上限(ARG))
			ELSE
				CFLAG:ARG:积攒度 += LIMIT((10 + RAND:20 + RAND:20 + RAND:20) * ABL:ARG:欲望,200,MAX_积攒度)
			ENDIF
		ELSEIF ABL:ARG:精液中毒 > 4
			SETCOLOR C_YELLOW
			PRINTFORML 嗯～
			PRINTFORML %CALLNAME:ARG%在美梦中熟练的吞下了%CALLNAME:MASTER%留在口中的罪恶，但似乎没能满足似的舔舐着口中残存的味道
			IF MAGIC_DLC
