;----------------------------------------------------------------------------------------------------
;角色の登場判定
;とりあえず你は弾くようにした
;----------------------------------------------------------------------------------------------------
@CAN_MEET(CHARA)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
;if it's passerby but passerby hasn't been generated, it'll break. Just ignore the case completely
SIF !CHARA || CHARA == RANDOM_CHARANUM || CHARA >= CHARANUM
	RETURNF 0
SIF !EXISTCSV(CHARA)
	RETURNF 0
SIF CFLAG:CHARA:出禁
	RETURNF 0
SIF CHARA == FLAG:扮演
	RETURNF 0
RETURNF 1

;----------------------------------------------------------------------------------------------------
;現在地点から移動可能な場所へ移動    从当前位置移动到可到达的位置
;部屋から追い出されるときなど    比如被赶出房间的时候
;----------------------------------------------------------------------------------------------------
@GETOUT(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;幻想乡大地图，GMF调用函数修改MAIN_MAP后获得对应地图返回值
IF GMF_GETBIT("幻想乡大地图") && GMF_METHOD_STACK != "GETOUT"
	JUMP GMF_MAP_METHOD(CFLAG:ARG:現在位置, 1, "GETOUT", ARG)
ENDIF
TCVAR:ARG:追い出され時刻 = TIME
TCVAR:ARG:追い出され地点 = CFLAG:ARG:現在位置
FOR LOCAL, MINROOM(), MAXROOM
	;全くもってスマートでないが、番号の関係上幽香私室からは露台に追い出されてしまうため个別処理する    虽然一点也不聪明，但因为编号关系，我被幽香私室赶到了露台，所以要单独处理
	IF CFLAG:ARG:現在位置 == P463幽香私室
		CFLAG:ARG:現在位置 = P465大堂
		BREAK
	;bugfix: when the Tsukumo Sisters and Raiko kick you out of their room, move the player to Residential Area    当雷鼓弁弁八桥将你从她们的房间赶出去时，将玩家移动到居住区
	ELSEIF GROUPMATCH(CFLAG:ARG:現在位置, P208雷鼓の部屋, P209八橋の部屋, P210弁々の部屋)
		CFLAG:ARG:現在位置 = P214長屋前
		BREAK
	ELSEIF CAN_MOVE(CFLAG:ARG:現在位置, LOCAL) & 1
		CFLAG:ARG:現在位置 = LOCAL
		BREAK
	ENDIF
NEXT


;----------------------------------------------------------------------------------------------------
;角色の随机選抜関数
;手抜き処理でできるだけ簡素な抽選関数をと思った（RAND_CHARASELECTはちと凝り過ぎ）
;渡した角色は選ばれない
;出禁角色が多すぎると無限ループのおそれがあるのが難点
;難点と是うが全角色対象の抽選では
;極端なプレイングをしなければ問題にはならない、はず
;----------------------------------------------------------------------------------------------------
@RAND_PERSON(CHARA)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIM HIT_CHARA
DO
	HIT_CHARA = RAND(1, 人物数量上限)
	SIF !CAN_MEET(HIT_CHARA) || HIT_CHARA == CHARA || TALENT:CHARA:路人
		CONTINUE
	BREAK
LOOP 1
RETURNF HIT_CHARA



