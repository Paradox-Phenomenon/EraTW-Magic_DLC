CASE "妖兽"
	RETURNF GROUPMATCH(GET_TRIBENAME(C_ID, GETNUM(TALENT, "妖怪")), "妖兽", "妖鸟", "妖虫")
CASE "妖精"
	RETURNF TALENT:C_ID:妖精
CASE "神霊"
