;-------------------------------------------------
;函数名:GET_REVISION
;概要:通用修正值获取函数
;参数:ARG:0…要参照的数值
;返回值:修正后的值
;备注:式内函数
;当需要将某个数值转换为一个渐近上限值的数值时
;如果上升率小，则很快达到上限；反之，如果上升率大，则难以接近上限
;-------------------------------------------------
@GET_REVISION(ARG:0, 上限, 上昇率)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM 上限
#DIM 上昇率
RETURNF 上限 - 上昇率 * 上限 / (上昇率 + ARG:0)

;eg 10000,2000,20000だと2000-2000*20000/30000

@GET_REVISION2(ARG:0, 上限, 上昇率)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM 上限
#DIM 上昇率
RETURNF 上限 * (ARG:0 + 1) / (上昇率 + ARG:0 + 1)

;-------------------------------------------------
;関数名:GET_REVISION3
;概　要:汎用補正値取得関数
;引　数:num…参照する数値　TH:0~2…しきい値1~3　
;-------------------------------------------------
@GET_REVISION3(num, TH:0, TH:1, TH:2)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM TH, 3
#DIM num

FOR LOCAL,0,3
	SIF num <= TH:LOCAL || !TH:LOCAL
		RETURNF num
	;引数がTHを超えてたら超過分をSQRT*2
	num = TH:LOCAL + SQRT(num - TH:LOCAL) * 2
NEXT

RETURNF num

