;-------------------------------------------------
;選択肢を表示し入力結果を返す関数 条件を満たさない選択肢をグレー表示にして無効にすることが可能
;引数にセリフと条件(0で無効、非0で有効)を指定。最大7個まで
;戻り値は選択した選択肢の番号
;set any ARG to -1 to hide option entirely
;-------------------------------------------------
@ASK_M(ARGS:0, ARG:0, ARGS:1, ARG:1, ARGS:2, ARG:2, ARGS:3, ARG:3, ARGS:4, ARG:4, ARGS:5, ARG:5, ARGS:6, ARG:6, ARGS:7, ARG:7, ARGS:8, ARG:8)
#LOCALSIZE 3
#LOCALSSIZE 1
#DIM CONST 選択肢上限 = 8
#DIM PREV_REDRAW
PREV_REDRAW = CURRENTREDRAW()
LOCAL:2 = GETCOLOR()
REDRAW 0
RESETCOLOR
FOR LOCAL:0, 0, (選択肢上限 + 1)
	IF ARGS:(LOCAL:0) != "" && ARG:(LOCAL:0) >= 0
		IF ARG:(LOCAL:0)
			;PRINTBUTTON @"[{LOCAL:0, 2, RIGHT}] %ARGS:(LOCAL:0)%", LOCAL:0
			PRINTBUTTON @"[{LOCAL:0}] %ARGS:(LOCAL:0)%", LOCAL:0
		ELSE
			SETCOLOR 0x606060
			PRINTPLAINFORM [{LOCAL:0}] %ARGS:(LOCAL:0)%
			RESETCOLOR
		ENDIF
		PRINTL
	ENDIF
NEXT
$INPUT_LOOP
INPUT
IF RESULT < 0 || RESULT > 選択肢上限 || ARGS:RESULT == "" || ARG:RESULT <= 0
	CLEARLINE 1
	GOTO INPUT_LOOP
ENDIF
REDRAW PREV_REDRAW
SETCOLOR LOCAL:2
RETURN RESULT
;-------------------------------------------------
;現金と筹码どちらでも払える選択肢のための関数
;-------------------------------------------------
@PAY_YEN_OR_CM(ARG,ARG:1)
#LOCALSIZE 3
#LOCALSSIZE 1
LOCAL:2 = GETCOLOR()
RESETCOLOR
PRINTFORML [0] 放弃
PRINTFORML [1] 支付%金額表示(ARG)%　　（现在的所持金：%金額表示(MONEY)%）
