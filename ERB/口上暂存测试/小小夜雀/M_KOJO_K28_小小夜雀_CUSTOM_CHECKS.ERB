;-------------------------------------------------
;自定义陷落条件
;YEARNING-思慕 LOVE-恋慕 FUCK BUDDY-炮友 LUST-爱欲
;-------------------------------------------------
;覆写判定
;RETURN=1，以自定义条件覆盖原版条件 =0，自定义条件与原版条件需要同时满足 =-1 禁止转变为该陷落状态
;-------------------------------------------------
@M_KOJO_小小夜雀_CHECK_K28_FALL_STATE_OVERRIDE(ARGS,ARG,ARG:1)
SELECTCASE ARGS
	CASE "YEARNING"

	CASE "LOVE"
		RETURN 1
	CASE "FUCK BUDDY"
		RETURN 1
	CASE "LUST"
		RETURN 1
ENDSELECT
RETURN 0

;-------------------------------------------------
;为角色设置自定义陷落条件
;RETURN 自定义条件的数量
;RESULT(S) 存储每个条件的结果及其描述文本
;-------------------------------------------------
@M_KOJO_小小夜雀_CHECK_K28_FALL_STATE(ARGS,ARG,ARG:1)
SELECTCASE ARGS
	CASE "YEARNING"
		RESULTS:1 = 和他聊天很开心
		RESULT:1 = ABL:MASTER:話術技能 > 2
		RESULTS:2 = 很尊重我的工作
		RESULT:2 = 1
		RETURN 2

	CASE "LOVE"
		RESULTS:1 = 令人倾心的厨艺
		RESULT:1 = ABL:MASTER:料理技能 > 4
		RESULTS:2 = 度过了反狱王危机
		RESULT:2 = 0
		RESULTS:3 = 两人携手战胜了幽幽子（？）
		RESULT:3 = 0
		RESULTS:4 = 我俩亲密无间！（亲密达到20）
		RESULT:4 = ABL:MASTER:親密 > 20

		RETURN 4

	CASE "FUCK BUDDY"
		RESULTS:1 = 牡蛎牡蛎，绝对牡蛎
		RESULT:1 = 0
		RETURN 1
	CASE "LUST"
		RESULTS:1 = 达咩达咩！H什么的禁止
		RESULT:1 = 0
		RETURN 1

ENDSELECT
RETURN 0