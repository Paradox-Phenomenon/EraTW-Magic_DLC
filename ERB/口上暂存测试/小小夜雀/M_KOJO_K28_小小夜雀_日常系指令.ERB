@M_KOJO_小小夜雀_MESSAGE_COM_K28_301
CALL M_KOJO_小小夜雀_MESSAGE_COM_K28_301_1
RETURN RESULT

@M_KOJO_小小夜雀_MESSAGE_COM_K28_301_1
;-------------------------------------------------
;启用（=0, 非表示、1, 表示）
LOCAL = 1
;-------------------------------------------------
IF LOCAL
    IF TALENT:恋人
	    SELECTCASE RAND:1
		    CASE 0 
				IF FIRSTTIME("恋人泡茶")
					PRINTFORML 「呼，呼……」
					PRINTFORMDL 米斯蒂娅双手捧着茶杯，鼓起小嘴，用力的吹着。
					PRINTFORMDL 接着，将杯子移到嘴边，小心的用嘴唇试了一下茶水的温度。
					PRINTFORML 「刚刚好！」
					PRINTFORML 「给，%CALLNAME:MASTER%。」
					PRINTFORMDW 看这些少女的笑容，%CALLNAME:MASTER%也笑着接过了茶杯。
					PRINTFORMDL 不久之前，小夜雀正在喝茶的时候突然和自己提到。
					PRINTFORMDL 「好像一直是你先生在给我泡茶吧？我好像都没怎么给你先生泡过茶。」
					PRINTFORMDL 这么一提的话，好像确实是这样的。
					PRINTFORMDL 点了点头，小碎骨顿时露出了几分不甘的表情。
					PRINTFORML 「唔，怎么能这样？」
