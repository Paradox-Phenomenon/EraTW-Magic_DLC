;-------------------------------------------------
;函数名:QOL_Gathering_Drawing(SPOT_ID, GATHER_POW, MOD_VALUE)
;概　要:根据地点、采集力和补正值，随机抽取一件满足条件的采集物并计算数量
;参　数:SPOT_ID     = 采集位置ID (採集位置)
;		GATHER_POW  = 玩家的采集力 (採集パワー)
;		MOD_VALUE   = 采集力补正值 (Modification)
;返回值:RESULT:0 = 抽中的物品ID (0为未抽中)
;		RESULT:1 = 获得数量
;备　注:采用分级抽选池，并利用优势掷骰减少挫败感
;-------------------------------------------------
@QOL_Gathering_Drawing(SPOT_ID, GATHER_POW, MOD_VALUE)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC SPOT_ID
#DIM DYNAMIC GATHER_POW
#DIM DYNAMIC MOD_VALUE

#DIM DYNAMIC CHOSEN_ID
#DIM DYNAMIC QTY
#DIM DYNAMIC TOTAL_POWER
#DIM DYNAMIC MAX_LEVEL        ; 玩家当前采集力能触及的最高等级
#DIM DYNAMIC TARGET_LEVEL     ; 经过优势投掷后，本次决定抽取的期望等级
#DIM DYNAMIC BONUS_ROLLS      ; 投掷次数(优势层数)
#DIM DYNAMIC ITEM_ID
#DIM DYNAMIC QTY_PENALTY
#DIM DYNAMIC MAT_TOTAL
#DIM DYNAMIC VALID_POOL, 500  ; 存放基础条件合格的素材池
#DIM DYNAMIC VALID_COUNT      ; 基础池的数量
#DIM DYNAMIC FINAL_POOL, 500  ; 存放满足价格(稀有度)要求的分级抽选池
#DIM DYNAMIC FINAL_COUNT      ; 分级抽选池的数量

#DIM CONST BONUS_THRESHOLD = 8000
; 计算期望的稀有度等级
TOTAL_POWER = POWER(GATHER_POW + MOD_VALUE, 2) + 1000
MAX_LEVEL = GET_GATHERING_LEVEL(TOTAL_POWER)
; 优势掷骰规则：每溢出 8000 点采集力，多投掷1次，取最高值
BONUS_ROLLS = 1 + (TOTAL_POWER / BONUS_THRESHOLD)
TARGET_LEVEL = RAND_ADVANTAGE(MAX_LEVEL + 1, BONUS_ROLLS)
;DEBUGPRINTFORML 采集力：{TOTAL_POWER} 优势骰：{BONUS_ROLLS} 优势池：{TARGET_LEVEL} 随机/期望池：{RAND(MAX_LEVEL + 1) }/{MAX_LEVEL}

MAT_TOTAL = GET_MATERIAL_LIST(-1)  ; 获取系统中素材的总数量
FOR LOCAL, 0, MAT_TOTAL
	ITEM_ID = GET_MATERIAL_LIST(LOCAL)
	; 如果当前地点、当前季节可采集，且玩家采集力达标，则加入当前地点的实际备选池
	IF IS_GATHERABLE(ITEM_ID, SPOT_ID) && (GATHER_POW + MOD_VALUE) >= GET_GATHER_DIFFICULTY(ITEM_ID)
		VALID_POOL:VALID_COUNT = ITEM_ID
		VALID_COUNT ++
	;ELSEIF IS_GATHERABLE(ITEM_ID, SPOT_ID) && (GATHER_POW + MOD_VALUE) < GET_GATHER_DIFFICULTY(ITEM_ID)
	;	DEBUGPRINTFORML 采集力({GATHER_POW + MOD_VALUE})不足，略过%ITEMNAME:(ITEM_ID)%
	ENDIF

NEXT
; 如果没有任何物品符合条件，直接返回
SIF VALID_COUNT == 0
	RETURN 0, 0

; 分级抽选池自动降级循环
WHILE TARGET_LEVEL >= 0
	FINAL_COUNT = 0
	FOR LOCAL, 0, VALID_COUNT
		ITEM_ID = VALID_POOL:LOCAL
		SIF GET_GATHERING_LEVEL(ITEMPRICE:ITEM_ID) == TARGET_LEVEL
			FINAL_POOL:(FINAL_COUNT++) = ITEM_ID
	NEXT
	SIF FINAL_COUNT > 0
		BREAK
	TARGET_LEVEL --
WEND

CHOSEN_ID = FINAL_POOL:(RAND:FINAL_COUNT)
QTY_PENALTY = MAX(SQRT(GATHER_POW) - TARGET_LEVEL, 1)
QTY = MAX(RANDSF(1, QTY_PENALTY), 1)
RETURN CHOSEN_ID, QTY

;-------------------------------------------------
;函数名:GET_GATHERING_LEVEL(VAL)
;概　要:根据物品价格或采集力，返回硬编码的素材价值层级(0~5)
;参　数:VAL = 物品价格或总采集力
;-------------------------------------------------
@GET_GATHERING_LEVEL(VAL)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM DYNAMIC VAL
#DIM CONST GATHER_VALUE_LEVEL, 6 = 0, 500, 2000, 4000, 7000, 10000
#DIM DYNAMIC LEVEL
FOR LOCAL, 0, 6
	SIF VAL >= GATHER_VALUE_LEVEL:LOCAL
		LEVEL = LOCAL
NEXT
RETURNF LEVEL

;-------------------------------------------------
;函数名:IS_GATHERABLE(ITEM_ID, SPOT_ID)
;概　要:判断指定物品在当前季节和地点是否可以被采集
;参　数:ITEM_ID = 物品的道具ID
;		SPOT_ID = 采集位置ID
;返回值:1 = 可采集, 0 = 不可采集
;-------------------------------------------------
@IS_GATHERABLE(ITEM_ID, SPOT_ID)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM DYNAMIC ITEM_ID
#DIM DYNAMIC SPOT_ID

SIF ITEMNAME:ITEM_ID == ""
	RETURNF 0
IF ITEM:ITEM_ID >= 999
	;DEBUGPRINTFORML 所持上限のため%ITEMNAME:ITEM_ID%をスキップ
	RETURNF 0
ENDIF
IF !GATHERING_SEASON(ITEM_ID)
	;DEBUGPRINTFORML 过季のため%ITEMNAME:ITEM_ID%をスキップ
	RETURNF 0
ENDIF
IF GATHERING_PRODUCT(ITEM_ID, SPOT_ID) < 1
	;DEBUGPRINTFORML 位置が不適切なため%ITEMNAME:ITEM_ID%をスキップ
	RETURNF 0
ENDIF
RETURNF 1

;-------------------------------------------------
;函数名:GET_GATHER_DIFFICULTY(ITEM_ID)
;概　要:计算获取某素材所需的最低难度(即需要的采集力)，受当前天气影响
;参　数:ITEM_ID = 物品的道具ID
;返回值:整数形式的最低难度值
;-------------------------------------------------
@GET_GATHER_DIFFICULTY(ITEM_ID)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM  DYNAMIC ITEM_ID
#DIM  DYNAMIC BASE_DIFF
#DIMS DYNAMIC LOC_LOW
#DIMS DYNAMIC LOC_CUMULUS
#DIM  DYNAMIC RESULT_DIFF

LOC_LOW = %GET_LOCATION_LOW()%
LOC_CUMULUS = %GET_LOCATION_CUMULUS()%
BASE_DIFF = ITEMPRICE:ITEM_ID + 1000

; 特殊天气的难度减半补正
IF GROUPMATCH(ITEM_ID, 606, 625, 634, 647) && ((LOC_LOW == "台風一過" && IS_TYPHOON:1 >= 5) || LOC_LOW == "二つ玉低気圧通過" || (LOC_CUMULUS == "積乱雲通過" && CAN_CUMULUS:0 == 5))
	RESULT_DIFF = SQRT(BASE_DIFF) / 2
ELSEIF ITEM_ID == 609 && (LOC_LOW == "寒冷渦通過" || LOC_LOW == "二つ玉低気圧通過")
	RESULT_DIFF = SQRT(BASE_DIFF) / 2
ELSE
	RESULT_DIFF = SQRT(BASE_DIFF)
ENDIF

RETURNF RESULT_DIFF

;-------------------------------------------------
;函数名:GET_MATERIAL_LIST(ARG)
;概　要:与@GATHERING_PRODUCT判定同步，入组所有可采集素材的ID
;参　数:ARG = -1 返回素材总数，ARG >= 0 返回对应索引的道具ID，ARG = -2 强制重新扫描
;备　注:利用ERABASIC函数私有变量的静态特性，只在存档中第一次调用时执行耗时扫描
;-------------------------------------------------
@GET_MATERIAL_LIST(ARG = -1)
#LOCALSIZE 3
#LOCALSSIZE 1
#FUNCTION
#DIM ITEM_POOL, 500   ; 静态数组缓存池（支持最多500种素材）
#DIM ITEM_COUNT       ; 静态变量，记录有效素材总数
#DIM HAS_INIT         ; 静态标记，是否已经完成初始化扫描

IF !HAS_INIT || ARG == -2
	ITEM_COUNT = 0
	VARSET ITEM_POOL, 0

	FOR LOCAL:0, 0, 1000
		SIF ITEMNAME:(LOCAL:0) == ""
			CONTINUE
		LOCAL:2 = 0
		FOR LOCAL:1, 1, 100
			IF GATHERING_PRODUCT(LOCAL:0, LOCAL:1)
				LOCAL:2 = 1
				BREAK
			ENDIF
		NEXT
		IF LOCAL:2
			;DEBUGPRINTFORML {ITEM_COUNT},%ITEMNAME:(LOCAL:0)%,{LOCAL:0}
			ITEM_POOL:ITEM_COUNT = LOCAL:0
			ITEM_COUNT ++
		ENDIF
	NEXT
	
	HAS_INIT = 1
	;DEBUGPRINTFORML 【素材池初始化完成】共扫描到 {ITEM_COUNT} 种素材。
ENDIF

SIF ARG == -1
	RETURNF ITEM_COUNT
SIF ARG < 0 || ARG >= ITEM_COUNT
	RETURNF 0
RETURNF ITEM_POOL:ARG
