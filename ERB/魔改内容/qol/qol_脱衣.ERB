@套装立绘映射(O_ID,C_ID)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM TEMP_SET
#DIMS DYNAMIC TEMP_GRAPH
#DIM TEMP_RESULT
#DIM O_ID
#DIM C_ID
TEMP_RESULT = RESULT
TEMP_SET = TCVAR:C_ID:EVENT_CLOTHING_SET
VARSET RESULTS
TRYCALLFORM SPECIAL_BASE_IMAGE_{C_ID}
IF STRCOUNT(RESULTS, "EagloV")
	TRYCALLFORM EagloV_特殊服装_{C_ID}
	IF RESULT
		TEMP_GRAPH '= RESULTS
	ELSE
		TRYCALLFORM EagloV_特殊内衣_{C_ID}
		IF RESULT
			TEMP_GRAPH '= RESULTS
		ENDIF
	ENDIF
ELSE
	TRYCALLFORM IMAGE_I{C_ID}_特殊服装(C_ID)
	SIF RESULTS != ""
		TEMP_GRAPH '= RESULTS
ENDIF

TCVAR:C_ID:EVENT_CLOTHING_SET = O_ID
