	ENDIF
ELSE
	TRYCALLFORM IMAGE_I{C_ID}_特殊服装(C_ID)
	IF RESULTS != TEMP_GRAPH && RESULTS != ""
		SETCOLOR C_ORANGE
	ENDIF
ENDIF
TCVAR:C_ID:EVENT_CLOTHING_SET = TEMP_SET
RETURN TEMP_RESULT

