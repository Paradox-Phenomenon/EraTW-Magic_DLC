;-----------------------------------------------------------
;@初始化邻接表(ARG = 0)
;概  要:用字符串充当邻接表
;参  数：为真时强制初始化，只在需要时更新
;-----------------------------------------------------------
@初始化邻接表(ARG = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
SIF P_AdjListDone == now_version && !ARG
	RETURN 0
VARSET P_AdjList
FOR I, 0, MAXHOME
	SIF !GET_EXISTMAP(I)
		CONTINUE
	;出发地
	FOR J, 1, 100
		;目的地
		FOR K, 1, 100
			IF GETMETH(@"CAN_MOVE_{I}", 0, I*100 + J, I*100 + K) & 1
				P_AdjList:(I*100 + J) += @"{I*100 + K}/"
			ENDIF
		NEXT
	NEXT
NEXT
P_AdjListDone = now_version

;-----------------------------------------------------------
; @QOL_SKIP_MOVE_INFO(目的地, 出发地, 地图ID)
; 概  要:使用预先生成的邻接表和BFS算法寻找最短路径
; 参  数:参照@SKIP_MOVE_{地图ID}(目的地, 出发地)的规格
; 返回值:从“出发地”到“目的地”需要移动到的下一个地点ID
;-----------------------------------------------------------
@QOL_SKIP_MOVE_INFO(ARG, ARG:1, map_id)
#LOCALSIZE 1
#DIM DYNAMIC queue, MAX_LOCATIONS
#DIM DYNAMIC parent, MAX_LOCATIONS
#DIM DYNAMIC visited, MAX_LOCATIONS
#DIM DYNAMIC queue_head
#DIM DYNAMIC queue_tail
#DIM DYNAMIC current_location
#DIM DYNAMIC path_tracer
#DIM DYNAMIC neighbor
#DIM DYNAMIC map_id
#FUNCTION 
DEBUGPRINTFORM map_id{map_id} {ARG:1} 到 {ARG} 的首个路径算出：
SIF !ARG:1
	ARG:1 = CFLAG:MASTER:現在位置

SIF GETMETH(@"CAN_MOVE_{map_id}", 0, ARG:1, ARG) & 1
	RETURNF ARG
SIF ARG == ARG:1
	RETURNF ARG
IF P_AdjList:(ARG:1) == "" && !(GETMETH(@"CAN_MOVE_{map_id}", 0, ARG:1, ARG) & 1)
	PRINTFORML [警告] 未找到从{ARG:1}到{ARG}的寻路，请汇报错误
	RETURNF ARG
ENDIF
IF ARG:1 / 100 != map_id || ARG / 100 != map_id
	THROW [警告] 错误的寻路，请汇报错误（map_id：{map_id} 路径：从{ARG:1}到{ARG}）
ENDIF

;BFS
queue:queue_tail = ARG:1 % 100
queue_tail += 1
visited:(ARG:1 % 100) = 1
parent:(ARG:1 % 100) = -1

WHILE queue_head < queue_tail
	current_location = queue:queue_head
	queue_head += 1
	IF current_location == ARG % 100
		BREAK
	ENDIF
	FOR i, 0, SPLIT_F(P_AdjList:(current_location + 100 * map_id),"/",LOCALS)
		neighbor = TOINT(LOCALS:I) % 100
		IF !visited:neighbor
			visited:neighbor = 1
			parent:neighbor = current_location
			queue:queue_tail = neighbor
			queue_tail += 1
		ENDIF
	NEXT
WEND
path_tracer = ARG % 100
IF visited:path_tracer == 0
	RETURNF ARG
ENDIF
WHILE parent:path_tracer != -1 && parent:path_tracer != ARG:1 % 100
	path_tracer = parent:path_tracer
WEND
IF parent:path_tracer == -1
	RETURNF ARG
ELSE
	DEBUGPRINTFORML {path_tracer + 100 * map_id}
	RETURNF path_tracer + 100 * map_id
ENDIF

;-----------------------------------------------------------
; @QOL_GET_DISTANCE(目的地, 出发地, 地图ID)
; 概  要:使用预先生成的邻接表和BFS算法计算最短距离
; 参  数:参照@SKIP_MOVE_{地图ID}(目的地, 出发地)的规格
; 返回值:从“出发地”到“目的地”的最短步数(如果无法到达则返回-1)
;-----------------------------------------------------------
@QOL_GET_DISTANCE(ARG, ARG:1, map_id)
#LOCALSIZE 1
#DIM DYNAMIC queue, MAX_LOCATIONS
#DIM DYNAMIC dist_map, MAX_LOCATIONS
#DIM DYNAMIC visited, MAX_LOCATIONS
#DIM DYNAMIC queue_head
#DIM DYNAMIC queue_tail
#DIM DYNAMIC current_location
#DIM DYNAMIC neighbor
#DIM DYNAMIC map_id
#FUNCTION 
DEBUGPRINTFORM map_id{map_id} {ARG:1} 到 {ARG} 的BFS深度算出：

SIF !ARG:1
	ARG:1 = CFLAG:MASTER:現在位置

;直连或原地的情况优化
SIF ARG == ARG:1
	RETURNF 0
SIF GETMETH(@"CAN_MOVE_{map_id}", 0, ARG:1, ARG) & 1
	RETURNF 1

;异常处理保持一致
IF P_AdjList:(ARG:1) == "" && !(GETMETH(@"CAN_MOVE_{map_id}", 0, ARG:1, ARG) & 1)
	PRINTFORML [警告] 未找到从{ARG:1}到{ARG}的寻路，请汇报错误
	RETURNF -1
ENDIF
IF ARG:1 / 100 != map_id || ARG / 100 != map_id
	THROW [警告] 错误的寻路，请汇报错误（map_id：{map_id} 路径：从{ARG:1}到{ARG}）
ENDIF

;BFS 初始化
queue:queue_tail = ARG:1 % 100
queue_tail += 1
visited:(ARG:1 % 100) = 1
dist_map:(ARG:1 % 100) = 0

WHILE queue_head < queue_tail
	current_location = queue:queue_head
	queue_head += 1
	
	;返回
	IF current_location == ARG % 100
		DEBUGPRINTFORML {dist_map:current_location}
		RETURNF dist_map:current_location
	ENDIF

	FOR i, 0, SPLIT_F(P_AdjList:(current_location + 100 * map_id),"/",LOCALS)
		neighbor = TOINT(LOCALS:I) % 100
		IF !visited:neighbor
			visited:neighbor = 1
			;生长 - 父节点的距离 + 1
			dist_map:neighbor = dist_map:current_location + 1
			queue:queue_tail = neighbor
			queue_tail += 1
		ENDIF
	NEXT
WEND

;队列空了也没找到
PRINTFORML [警告] 未找到从{ARG:1}到{ARG}的寻路，请汇报错误
;THROW [警告] 错误的寻路，请汇报错误（map_id：{map_id} 路径：从{ARG:1}到{ARG}）
RETURNF -1

@连通性遍历
#LOCALSIZE 3
#LOCALSSIZE 1
FOR LOCAL:0, MAIN_MAP*100, MAXROOM
	SIF NAME_FROM_PLACE(LOCAL:0) == ""
		CONTINUE
	FOR LOCAL:1, LOCAL:0 + 1, MAXROOM
		SIF NAME_FROM_PLACE(LOCAL:1) == ""
			CONTINUE
		LOCAL:2 = QOL_GET_DISTANCE(LOCAL:0,LOCAL:1,MAIN_MAP)
		PRINTFORML %NAME_FROM_PLACE(LOCAL:1)%{LOCAL:1}到%NAME_FROM_PLACE(LOCAL:0)%{LOCAL:0}的距离是{LOCAL:2}
		SIF LOCAL:2 < 1
			WAIT
		AWAIT
	NEXT
NEXT
