; 获取添加物ID (返回 -1 表示"无")
@GET_TENKABUTSU_ID(ING)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM DYNAMIC ING
SIF INRANGE(ING,1,VARSIZE("TENKABUTSU"))
	RETURNF GETNUM(ITEM, TENKABUTSU:ING)

@GET_SHIKOMI_ID(ING)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM DYNAMIC ING
SIF INRANGE(ING,1,VARSIZE("SHIKOMI"))
	RETURNF GETNUM(ITEM, SHIKOMI:ING)

; 判定某添加物是否只允许在甜点(DISH_TYPE_NUM == 3)中使用
@IS_DESSERT_ONLY_ADDITIVE(ITEM_ID)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM ITEM_ID
SELECTCASE ITEM_ID
	CASE [[莓子酒]], [[草莓白兰地]], [[黑朗姆酒]], [[白兰地VS]], [[白兰地VSOP]], [[白兰地XO]]
		RETURNF 1
	CASEELSE
		RETURNF 0
ENDSELECT

; 获取添加物的得分/减分修正
@GET_ADDITIVE_BONUS(ITEM_ID)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM ITEM_ID
SELECTCASE ITEM_ID
	CASE [[栄養強化剤]]
		RETURNF -1
	CASE [[莓子酒]], [[草莓白兰地]], [[黑朗姆酒]], [[白兰地VS]]
		RETURNF 2
	CASE [[白兰地VSOP]]
		RETURNF 3
	CASE [[白兰地XO]]
		RETURNF 4
	CASEELSE
		RETURNF 0
ENDSELECT

