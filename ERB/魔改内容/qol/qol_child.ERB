@SELECT_CHILD_INTERACTABLE_HERE
#DIM DYNAMIC _LINECOUNT
#DIM CHILDNUM
#DIM DYNAMIC _COUNT = 1
#DIM TEMP,200
_LINECOUNT = LINECOUNT
PRINTFORML 想找哪个孩子呢？
FOR LOCAL, 0, CHARANUM
	SIF CFLAG:LOCAL:兒童人数 <= 0
		CONTINUE
	FOR LOCAL:1, 1, MAXCHILD + 1
		IF CHILD_INTERACTABLE_HERE:LOCAL:(LOCAL:1) > 0
			IF CHILD_INTERACTABLE_HERE:LOCAL:(LOCAL:1) < 1000 
				IF STRLENS(CHILD_ACT:(CHILD_INTERACTABLE_HERE:LOCAL:(LOCAL:1)):(LOCAL:1)) > 0
					SETCOLOR C_GREEN
					PRINTBUTTON @"[{_COUNT, 2}]-%CHILDNAME:LOCAL:(LOCAL:1), 8%　\@ CHILD_SEX:LOCAL:(LOCAL:1) == 1 ? ♀ # ♂\@　　未成年　　母亲：%NAME:LOCAL%",_COUNT
					TEMP:_COUNT = CHILD_INTERACTABLE_HERE:LOCAL:(LOCAL:1)
				ELSE
					SETCOLOR 0x669966
					PRINTPLAINFORM [{_COUNT, 2}]-%CHILDNAME:LOCAL:(LOCAL:1), 8%　\@ CHILD_SEX:LOCAL:(LOCAL:1) == 1 ? ♀ # ♂\@　　未成年　　母亲：%NAME:LOCAL%
				ENDIF
			ELSE
				PRINTBUTTON @"[{_COUNT, 2}]-%CHILDNAME:LOCAL:(LOCAL:1), 8%　\@ CHILD_SEX:LOCAL:(LOCAL:1) == 1 ? ♀ # ♂\@　　成年　　母亲：%NAME:LOCAL%",_COUNT
				TEMP:_COUNT = CHILD_INTERACTABLE_HERE:LOCAL:(LOCAL:1)
			ENDIF
			RESETCOLOR
			PRINTL
			_COUNT ++
		ELSE
			CONTINUE
		ENDIF
	NEXT
NEXT
PRINTBUTTON @"[0] 还是算了", -1
INPUT
CLEARLINE LINECOUNT - _LINECOUNT
IF RESULT == -1
	PRINTFORML 还是先不打扰孩子们了
ELSEIF TEMP:RESULT
	RETURN TEMP:RESULT
ELSE
	PRINTFORML 无效输入
ENDIF
RETURN -1
