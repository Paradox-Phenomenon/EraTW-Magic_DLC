;-------------------------------------------------
;1 春・秋の天気(基本)
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_1(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY

SELECTCASE TIME:5
	;晴天の時
	CASE 天气_少云
		;20%で晴天に移行
		IF RAND:5 == 0
			TIME:5 = 天气_晴
		;20%で多雲に移行
		ELSEIF RAND:5 == 0
			TIME:5 = 天气_多云
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		;上記確率に引っかからなかったら晴天
		ELSE
			TIME:5 = 天气_少云
		ENDIF
	CASE 天气_晴
		;20%で晴天に移行
		IF RAND:5 == 0
			TIME:5 = 天气_少云
		;20%で多雲に移行
		ELSEIF RAND:5 == 0
			TIME:5 = 天气_多云
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	;陰天の時
	CASE 天气_多云, 天气_阴
		;50%で弱体化
		IF RAND:2 == 0
			TIME:5 = 天气_多云
		ELSE
			;晴天に移行
			TIME:5 = 天气_少云
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	;雨の時
	CASE 天气_雨, 天气_大雨, 天气_冰霰, 天气_暴雨, 天气_冰雹
		;50%で弱体化
		IF RAND:2 == 0 && TIME:5 != 天气_雨
			TIME:5 = 天气_雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSE
			;25%で陰天に移行
			IF RAND:4 == 0
				TIME:5 = 天气_阴
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			;雨なら10%で霧雨か雨雪交加に移行
			ELSEIF TIME:5 == 天气_雨 && RAND:10 == 0
				TIME:5 = 天气_雾雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			;晴天に移行
			ELSE
				TIME:5 = 天气_少云
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				;更に低確率で晴朗
				SIF RAND:100 < 5
					TIME:5 = 天气_晴
				;雨→晴天を処理したら虹が出る
				TIME:7 = 天气_彩虹
				;市場が開かれる
				FLAG:市場の神 = 1
			ENDIF
		ENDIF
	;霧・霧雨の時
	CASE 天气_雾雨, 天气_雾
		TIME:5 = 天气_少云
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	CASE IS >= 天气_雪
		;雪は冬以外降らない
		IF RAND:2
			;雨になる
			TIME:5 = 天气_雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSE
			;25%で陰天に移行
			IF RAND:4 == 0
				TIME:5 = 天气_阴
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			;晴天に移行
			ELSE
				TIME:5 = 天气_少云
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				;更に低確率で晴朗
				SIF RAND:100 < 5
					TIME:5 = 天气_晴
				;雪→晴天を処理したらダイヤモンドダストが出る
				TIME:7 = 天气_钻石尘
			ENDIF
		ENDIF
	CASEELSE
		TIME:5 = RAND:4
ENDSELECT

;連続降水Counter
CALL qol_CONTINUOUS_RAINFALL_COUNTER(TIME:5)

;強風である場合風がおさまる
WIND_VELOCITY = 天气_无风
CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)

;春第2タームまでは降雪・雪崩判定
IF DAY:2 == 1 && NOW_TERM <= 2
	;連続降雪Counter
	CALL qol_CONTINUOUS_SNOWFALL_COUNTER_SPRING(TIME:5)
	;雪崩発生フラグ判定
	CALL qol_POSSIBLITY_AVALANCHE_SPRING(TIME:5)
ELSE
	CALL qol_NO_AVALANCHE
ENDIF

;-------------------------------------------------
;2 春・秋の天気(温暖前線接近時)
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_2(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY

SELECTCASE TIME:5
	;晴朗の時
	CASE 天气_晴
		TIME:5 = 0
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	;晴天の時
	CASE 0
		;60%で多雲に移行
		IF RAND:2 == 0
			TIME:5 = 天气_多云
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		;10%で陰天に移行
		ELSEIF RAND:10 == 0
			TIME:5 = 天气_阴
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	;多雲の時
	CASE 天气_多云
		;60%で陰天に移行
		IF RAND:2 == 0
			TIME:5 = 天气_阴
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		;10%で雨に移行
		ELSEIF RAND:10 == 0
			TIME:5 = 天气_雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	;曇の時
	CASE 天气_阴
		;50%で雨に移行
		IF RAND:2 == 0
			TIME:5 = 天气_雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	;降雨時
	CASE 天气_雨, 天气_大雨, 天气_冰霰, 天气_暴雨, 天气_冰雹
		;熱雷発生フラグが立っているとき大雨に移行
		IF GET_HEAT_THUNDERSTORM() && TIME:5 == 天气_雨
			TIME:5 = 天气_大雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	CASEELSE
		TIME:5 = 天气_多云
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
ENDSELECT

;連続降水Counter
CALL qol_CONTINUOUS_RAINFALL_COUNTER(TIME:5)

;春第2タームまでは降雪・雪崩判定
IF DAY:2 == 1 && NOW_TERM <= 2
	;連続降雪Counter
	CALL qol_CONTINUOUS_SNOWFALL_COUNTER_SPRING(TIME:5)
	;雪崩発生フラグ判定
	CALL qol_POSSIBLITY_AVALANCHE_SPRING(TIME:5)
ELSE
	CALL qol_NO_AVALANCHE
ENDIF

;-------------------------------------------------
;3 春・秋の天気(暖域時)
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_3(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY

IF (TIME:5 != 天气_少云 || TIME:5 != 天气_多云)
	IF RAND:2 == 1
		TIME:5 = 天气_少云
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		IF TIME:5 >= 天气_雨
			;雨→晴天を処理したら虹が出る
			TIME:7 = 1
			;市場が開かれる
			FLAG:市場の神 = 1
		ENDIF
	ELSE
		TIME:5 = 天气_多云
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	ENDIF
ENDIF

;連続降水Counter
CALL qol_CONTINUOUS_RAINFALL_COUNTER(TIME:5)

;風速変化の確立
LOCAL:1 = RAND:10

;50%の確率で風速弱体化。暖気が強い場合20%の確率で風速強化
;但し春第1タームは確実に強風
IF DAY:2 == 1 && NOW_TERM == 1 && WIND_VELOCITY != 天气_强风
	WIND_VELOCITY = 天气_强风
	CALL qol_WEATHER_CHANGE_DIARY_PRINT("春风")
ELSEIF POWER_WARM_AIR >= 4 && LOCAL:1 >= 8 && WIND_VELOCITY == 天气_无风
	WIND_VELOCITY = 天气_强风
	CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
ELSEIF LOCAL:1 >= 5 && WIND_VELOCITY > 天气_无风
	WIND_VELOCITY = 天气_无风
	CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
ENDIF

;春第2タームまでは降雪・雪崩判定
IF DAY:2 == 1 && NOW_TERM <= 2
	;連続降雪Counter
	CALL qol_CONTINUOUS_SNOWFALL_COUNTER_SPRING(TIME:5)
	;雪崩発生フラグ判定
	CALL qol_POSSIBLITY_AVALANCHE_SPRING(TIME:5)
ELSE
	CALL qol_NO_AVALANCHE
ENDIF

;-------------------------------------------------
;4 春・秋の天気(寒冷前線通過時)
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_4(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY

IF TIME:5 == 天气_冰雹 && GET_FRONTAL_THUNDERSTORM() == 1 && GET_HEAT_THUNDERSTORM() == 1
	TIME:5 = 天气_暴雨
	CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
ELSEIF (TIME:5 == 天气_冰霰 || TIME:5 == 天气_冰雹)
	TIME:5 = 天气_大雨
	CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
ELSEIF TIME:5 != 天气_雨 && TIME:5 != 天气_大雨 && TIME:5 != 天气_暴雨
	IF RAND:3 == 0
		TIME:5 = 天气_雨
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	ELSEIF RAND:3 == 1 && GET_FRONTAL_THUNDERSTORM() == 1
		SELECTCASE POWER_WARM_AIR
			CASE 5
				IF RAND:3 == 0
					TIME:5 = 天气_冰雹
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ELSE
					TIME:5 = 天气_冰霰
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ENDIF
			CASEELSE
				TIME:5 = 天气_冰霰
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDSELECT
	ELSE
		TIME:5 = 天气_大雨
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	ENDIF
ELSE
	IF GET_FRONTAL_THUNDERSTORM() == 1 && GET_HEAT_THUNDERSTORM() == 1
		IF TIME:5 != 天气_暴雨
			TIME:5 = 天气_暴雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	ELSE
		SELECTCASE TIME:5
			CASE 天气_雨
				IF RAND:3 == 0
					TIME:5 = 天气_大雨
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ENDIF
			CASE 天气_大雨
				IF RAND:3 == 0
					TIME:5 = 天气_雨
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ENDIF
			CASE 天气_暴雨
				TIME:5 = 天气_大雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			CASEELSE
				TIME:5 = 天气_大雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDSELECT
	ENDIF
ENDIF

;連続降水Counter
CALL qol_CONTINUOUS_RAINFALL_COUNTER(TIME:5)

;風速変化の確立
LOCAL:1 = RAND:4

;(天候パッチ)熱界雷時の処理　ダウンバースト発生
IF GET_FRONTAL_THUNDERSTORM() == 1 && GET_HEAT_THUNDERSTORM() == 1 && ATMOSPHERIC_INSTABILITY <= -1
	IF ATMOSPHERIC_INSTABILITY <= -2
		SELECTCASE WIND_VELOCITY
			CASE 天气_无风
				WIND_VELOCITY = 天气_暴风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
				;ダウンバーストによる作物への影響
				CALL qol_WEATHER_CHANGE_TO_CROP("STORM")
			CASE 天气_强风
				WIND_VELOCITY = 天气_暴风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
				;ダウンバーストによる作物への影響
				CALL qol_WEATHER_CHANGE_TO_CROP("STORM")
			CASEELSE
				WIND_VELOCITY = 天气_暴风
		ENDSELECT
	ELSE
		SELECTCASE WIND_VELOCITY
			CASE 天气_无风
				WIND_VELOCITY = 天气_强风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
			CASE 天气_强风
				WIND_VELOCITY = 天气_强风
			CASEELSE
				WIND_VELOCITY = 天气_强风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
		ENDSELECT
	ENDIF
;強風である場合25%で風がおさまる
ELSEIF LOCAL:1 == 0 && WIND_VELOCITY != 天气_无风
	WIND_VELOCITY = 天气_无风
	CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
ENDIF

;春第2タームまでは降雪・雪崩判定
IF DAY:2 == 1 && NOW_TERM <= 2
	;連続降雪Counter
	CALL qol_CONTINUOUS_SNOWFALL_COUNTER_SPRING(TIME:5)
	;雪崩発生フラグ判定
	CALL qol_POSSIBLITY_AVALANCHE_SPRING(TIME:5)
ELSE
	CALL qol_NO_AVALANCHE
ENDIF


;-------------------------------------------------
;5 春・秋の天気(寒冷渦接近時)
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_5(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY

;暖気が1の場合降雪の可能性
IF POWER_WARM_AIR == 1
	SELECTCASE TIME:5
		;陰天
		CASE 天气_阴
			SELECTCASE RAND:5
				CASE 0
					TIME:5 = 天气_冰霰
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				CASE 1, 2
					TIME:5 = 天气_雪
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				CASEELSE
					TIME:5 = 天气_大雪
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDSELECT
		;雪
		CASE 天气_雪
			SELECTCASE RAND:5
				CASE 0
					TIME:5 = 天气_冰雹
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				CASE 1
					TIME:5 = 天气_阴
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				CASEELSE
					TIME:5 = 天气_大雪
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDSELECT
		;大雪
		CASE 天气_大雪
			SELECTCASE RAND:5
				CASE 0
					TIME:5 = 天气_冰霰
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				CASE 1
					TIME:5 = 天气_阴
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				CASEELSE
					TIME:5 = 天气_雪
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDSELECT
		;冰雹
		CASE 天气_冰霰
			SELECTCASE RAND:4
				CASE 0
					TIME:5 = 天气_雪
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				CASEELSE
					TIME:5 = 天气_大雪
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDSELECT
		CASEELSE
			TIME:5 = 天气_大雪
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	ENDSELECT
ELSE
	SELECTCASE TIME:5
		;陰天
		CASE 天气_阴
			IF GET_FRONTAL_THUNDERSTORM() == 1 && GET_HEAT_THUNDERSTORM() == 1 && RAND:6 == 0
				SELECTCASE RAND:6
					CASE 0
						TIME:5 = 天气_冰雹
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					CASE IS >= 2
						TIME:5 = 天气_大雨
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					CASEELSE
						TIME:5 = 天气_暴雨
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ENDSELECT
			ELSE
				SELECTCASE RAND:6
					CASE 0
						TIME:5 = 天气_冰霰
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					CASE 1
						TIME:5 = 天气_雨夹雪
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					CASE 2
						TIME:5 = 天气_雨
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					CASEELSE
						TIME:5 = 天气_大雨
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ENDSELECT
			ENDIF
		;雨
		CASE 天气_雨
			IF GET_FRONTAL_THUNDERSTORM() == 1 && GET_HEAT_THUNDERSTORM() == 1 && RAND:4 == 0
				SELECTCASE RAND:6
					CASE 0
						TIME:5 = 天气_冰雹
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					CASE IS >= 2
						TIME:5 = 天气_大雨
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					CASEELSE
						TIME:5 = 天气_暴雨
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ENDSELECT
			ELSE
				SELECTCASE RAND:6
					CASE 0
						TIME:5 = 天气_冰霰
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					CASE 1
						TIME:5 = 天气_雨夹雪
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					CASE 2
						TIME:5 = 天气_阴
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					CASEELSE
						TIME:5 = 天气_大雨
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ENDSELECT
			ENDIF
		;大雨
		CASE 天气_大雨, 天气_暴雨
			SELECTCASE RAND:5
				CASE 0
					TIME:5 = 天气_冰霰
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				CASE 1
					TIME:5 = 天气_阴
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				CASEELSE
					IF TIME:5 == 天气_暴雨
						TIME:5 = 天气_大雨
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					ELSEIF GET_FRONTAL_THUNDERSTORM() == 1 && GET_HEAT_THUNDERSTORM() == 1 && RAND:2 == 0
						TIME:5 = 天气_暴雨
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					ELSE
						TIME:5 = 天气_雨
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					ENDIF
			ENDSELECT
		;雨雪交加
		CASE 天气_雨夹雪
			SELECTCASE RAND:5
				CASE 0
					TIME:5 = 天气_冰霰
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				CASE 1, 2
					TIME:5 = 天气_阴
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				CASEELSE
					TIME:5 = 天气_雨
			ENDSELECT
		;冰雹
		CASE 天气_冰霰
			SELECTCASE RAND:4
				CASE 0
					TIME:5 = 天气_雨
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				CASEELSE
					TIME:5 = 天气_大雨
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDSELECT
		;ひょう
		CASE 天气_冰雹
			SELECTCASE RAND:4
				CASE 0
					TIME:5 = 天气_暴雨
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				CASEELSE
					TIME:5 = 天气_大雨
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDSELECT
		CASEELSE
			TIME:5 = 天气_大雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	ENDSELECT
ENDIF

;連続降水Counter
CALL qol_CONTINUOUS_RAINFALL_COUNTER(TIME:5)

;風速変化の確立
LOCAL:1 = RAND:20

;(天候パッチ)熱界雷時の処理　ダウンバースト発生
IF GET_FRONTAL_THUNDERSTORM() == 1 && GET_HEAT_THUNDERSTORM() == 1 && ATMOSPHERIC_INSTABILITY <= -1
	IF ATMOSPHERIC_INSTABILITY <= -2
		SELECTCASE WIND_VELOCITY
			CASE 天气_无风
				WIND_VELOCITY = 天气_暴风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
				;ダウンバーストによる作物への影響
				CALL qol_WEATHER_CHANGE_TO_CROP("STORM")
			CASE 天气_强风
				WIND_VELOCITY = 天气_暴风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
				;ダウンバーストによる作物への影響
				CALL qol_WEATHER_CHANGE_TO_CROP("STORM")
			CASEELSE
				WIND_VELOCITY = 天气_暴风
		ENDSELECT
	ELSE
		SELECTCASE WIND_VELOCITY
			CASE 天气_无风
				WIND_VELOCITY = 天气_强风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
			CASE 天气_强风
				WIND_VELOCITY = 天气_强风
			CASEELSE
				WIND_VELOCITY = 天气_强风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
		ENDSELECT
	ENDIF
;10%の確率で暴風
ELSEIF LOCAL:1 == 0 && WIND_VELOCITY == 天气_强风
	WIND_VELOCITY = 天气_暴风
	CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
;50%の確率で暴風から強風に弱体化
ELSEIF LOCAL:1 >= 10 && WIND_VELOCITY == 天气_暴风
	WIND_VELOCITY = 天气_强风
	CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
ELSEIF WIND_VELOCITY == 天气_无风
	WIND_VELOCITY = 天气_强风
	CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
ENDIF

;春第2タームまでは降雪・雪崩判定
IF DAY:2 == 1 && NOW_TERM <= 2
	;連続降雪Counter
	CALL qol_CONTINUOUS_SNOWFALL_COUNTER_SPRING(TIME:5)
	;雪崩発生フラグ判定
	CALL qol_POSSIBLITY_AVALANCHE_SPRING(TIME:5)
ELSE
	CALL qol_NO_AVALANCHE
ENDIF

;-------------------------------------------------
;6 夏の天気(基本)
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_6(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY

;暖気が1のとき
IF POWER_WARM_AIR == 1
	SELECTCASE TIME:5
		;晴天の時
		CASE 天气_少云
			;20%で晴天に移行
			IF RAND:5 == 0
				TIME:5 = 天气_晴
			;20%で多雲に移行
			ELSEIF RAND:5 == 0
				TIME:5 = 天气_多云
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			;上記確率に引っかからなかったら晴天
			ELSE
				TIME:5 = 天气_少云
			ENDIF
		CASE 天气_晴
			;20%で晴天に移行
			IF RAND:5 == 0
				TIME:5 = 天气_晴
			;20%で多雲に移行
			ELSEIF RAND:5 == 0
				TIME:5 = 天气_多云
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDIF
		;陰天の時
		CASE 天气_多云, 天气_阴
			;25%で弱体化
			IF RAND:4 == 0
				TIME:5 = 天气_多云
			ELSE
				;20%で晴天に移行
				IF RAND:5 == 0
					TIME:5 = 天气_少云
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ENDIF
			ENDIF
		;雨の時
		CASE 天气_雨, 天气_大雨, 天气_暴雨, 天气_冰雹
			;25%で弱体化
			IF RAND:4 == 0 && TIME:5 != 天气_雨
				TIME:5 = 天气_雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSE
				;25%で陰天に移行
				IF RAND:4 == 0
					TIME:5 = 天气_阴
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				;雨なら10%で霧雨に移行
				ELSEIF TIME:5 == 天气_雨 && RAND:10 == 0
					TIME:5 = 天气_雾雨
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				;10%で晴天に移行
				ELSEIF RAND:10 == 0
					TIME:5 = 天气_少云
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					;更に低確率で晴朗
					SIF RAND:100 < 5
						TIME:5 = 天气_晴
					;雨→晴天を処理したら虹が出る
					TIME:7 = 天气_彩虹
					;市場が開かれる
					FLAG:市場の神 = 1
				ENDIF
			ENDIF
		;霧・霧雨の時
		CASE 天气_雾雨, 天气_雾
			TIME:5 = 天气_少云
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		;雪の時
		CASE IS >= 天气_雪
			;雪は冬以外降らない
			IF TIME:5 == 天气_雪
				;雨になる
				CLEARBIT TIME:5,3
				SETBIT TIME:5,2
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			;50%の確率で弱体化
			ELSEIF GETBIT(TIME:5,0) && RAND:2
				CLEARBIT TIME:5,0
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSE
				;25%で陰天に移行
				IF RAND:4 == 0
					TIME:5 = 天气_阴
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				;雪なら10%で細雪か雨雪交加に移行
				ELSEIF TIME:5 == 天气_雪 && RAND:10 == 0
					IF RAND:2
						TIME:5 = 天气_细雪
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					ELSE
						TIME:5 = 天气_雨夹雪
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					ENDIF
					;更に10%の確率で霧雪,冰雹に移行
					SIF RAND:10 == 0
						SETBIT TIME:5,0
				;10%で晴天に移行
				ELSEIF RAND:10 == 0
					TIME:5 = 天气_少云
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					;更に低確率で晴朗
					SIF RAND:100 < 5
						TIME:5 = 天气_晴
					;雪→晴天を処理したらダイヤモンドダストが出る
					TIME:7 = 天气_钻石尘
				ENDIF
			ENDIF
		CASEELSE
			TIME:5 = RAND:4
	ENDSELECT
;暖気が2以上
ELSE
	SELECTCASE TIME:5
		;晴天の時
		CASE 天气_少云
			TIME:5 = 天气_晴
		;陰天の時
		CASE 2,3
			TIME:5 = 天气_晴
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		;雨の時
		CASE 天气_雨, 天气_大雨, 天气_雾雨, 天气_雾, 天气_冰霰
			;25%で陰天に移行
			IF RAND:4 == 0
				TIME:5 = 天气_阴
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			;75%で晴天に移行
			ELSE
				TIME:5 = 天气_少云
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				;更に確率で晴朗
				SIF RAND:10 < 5
					TIME:5 = 天气_晴
				;雨→晴天を処理したら虹が出る
				TIME:7 = 天气_彩虹
				;市場が開かれる
				FLAG:市場の神 = 1
			ENDIF
		CASE 天气_暴雨, 天气_冰雹
			TIME:5 = 天气_大雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		;雪の時
		CASE IS >= 天气_雪
			;雪は冬以外降らない
			IF TIME:5 == 天气_雪
				;雨になる
				CLEARBIT TIME:5,3
				SETBIT TIME:5,2
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			;50%の確率で弱体化
			ELSEIF GETBIT(TIME:5,0) && RAND:2
				CLEARBIT TIME:5,0
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSE
				;25%で陰天に移行
				IF RAND:4 == 0
					TIME:5 = 天气_阴
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				;雪なら10%で細雪か雨雪交加に移行
				ELSEIF TIME:5 == 8 && RAND:10 == 0
					IF RAND:2
						TIME:5 = 天气_细雪
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					ELSE
						TIME:5 = 天气_雨夹雪
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					ENDIF
					;更に10%の確率で霧雪,冰雹に移行
					SIF RAND:10 == 0
						SETBIT TIME:5,0
				;10%で晴天に移行
				ELSEIF RAND:10 == 0
					TIME:5 = 天气_少云
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					;更に低確率で晴朗
					SIF RAND:100 < 5
						TIME:5 = 天气_晴
					;雪→晴天を処理したらダイヤモンドダストが出る
					TIME:7 = 天气_钻石尘
				ENDIF
			ENDIF
		CASEELSE
			TIME:5 = 天气_晴
	ENDSELECT
ENDIF

;連続降水Counter
CALL qol_CONTINUOUS_RAINFALL_COUNTER(TIME:5)

;強風である場合風がおさまる
IF WIND_VELOCITY != 天气_无风
	WIND_VELOCITY = 天气_无风
	CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
ENDIF

;降雪・雪崩判定を解除
CALL qol_NO_AVALANCHE

;-------------------------------------------------
;7 夏の天気(夕立接近時)
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_7(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY

SELECTCASE CAN_CUMULUS:0
	CASE 1
		TIME:5 = 天气_少云
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
			PRINTW 绵云出来了
	CASE 2, 3
		IF RAND:2 == 0
			TIME:5 = 天气_少云
			SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
				PRINTW 绵云出来了
		ELSE
			;TIME:5 = 天气_阴
			TIME:5 = 天气_多云
			SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
				PRINTW 变成多云天气了
		ENDIF
	CASE 4
		IF RAND:2 == 0
			TIME:5 = 天气_多云
			SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
				PRINTW 卷云正在蔓延
		ELSE
			TIME:5 = 天气_阴
			SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
				PRINTW 昙多起来了
		ENDIF
		SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
			PRINTW 冷风吹起来了！
	CASE 5
		TIME:5 = 天气_阴
		IF !CFLAG:MASTER:诶嘿嘿 && !无天气
			PRINTW 天暗下来了……
			PRINTW 冷风吹起来了！
		ENDIF
ENDSELECT

;連続降水Counter
CALL qol_CONTINUOUS_RAINFALL_COUNTER(TIME:5)

;降雪・雪崩判定を解除
CALL qol_NO_AVALANCHE

;-------------------------------------------------
;8 夏の天気(夕立通過後)
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_8(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY

SELECTCASE CAN_CUMULUS:0
	CASE 1
		IF RAND:2 == 0 && TIME:5 <= 天气_晴
			TIME:5 = 天气_少云
		ELSEIF TIME:5 < 天气_阴
			TIME:5 = 天气_阴
			SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
				PRINTW 昙多起来了
		ENDIF
	CASE 2
		IF RAND:3 == 0 && TIME:5 < 天气_雨
			TIME:5 = 天气_雨
			SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
				PRINTW 下雨了！
		ELSEIF TIME:5 < 天气_阴
			TIME:5 = 天气_阴
			SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
				PRINTW 昙多起来了
		ENDIF
	CASE 3
		IF RAND:3 == 0 && TIME:5 < 天气_雨
			TIME:5 = 天气_大雨
			SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
				PRINTW 变成了瓢泼大雨！
		ELSEIF TIME:5 < 天气_雨
			TIME:5 = 天气_雨
			SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
				PRINTW 下雨了！
		ENDIF
	CASE 4
		IF RAND:3 == 0 && TIME:5 == 天气_大雨
			TIME:5 = 天气_冰霰
			SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
				PRINTW 落冰雹了！
		ELSEIF TIME:5 != 天气_大雨
			TIME:5 = 天气_大雨
			SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
				PRINTW 变成了瓢泼大雨！
		ENDIF
	CASE 5
		IF RAND:3 == 0 && TIME:5 != 天气_冰雹
			TIME:5 = 天气_冰雹
			SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
				PRINTW 下起了大块的冰雹！
		ELSEIF TIME:5 != 天气_暴雨
			TIME:5 = 天气_暴雨
			SIF !CFLAG:MASTER:诶嘿嘿 && !无天气
				PRINTW 雨下得很大！
		ENDIF
ENDSELECT

;連続降水Counter
CALL qol_CONTINUOUS_RAINFALL_COUNTER(TIME:5)

;ダウンバースト発生
IF CAN_CUMULUS:2 == 2 && WIND_VELOCITY != 天气_暴风
	WIND_VELOCITY = 天气_暴风
	CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
	;ダウンバーストによる作物への影響
	CALL qol_WEATHER_CHANGE_TO_CROP("STORM")
ELSEIF CAN_CUMULUS:2 == 1 && WIND_VELOCITY != 天气_强风
	WIND_VELOCITY = 天气_强风
	CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
ENDIF

;降雪・雪崩判定を解除
CALL qol_NO_AVALANCHE

;-------------------------------------------------
;9 冬の天気(基本)
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_9(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY

SELECTCASE TIME:5
	;晴天の時
	CASE 天气_少云
		;20%で多雲に移行
		IF RAND:5 == 0
			TIME:5 = 天气_多云
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		;5%で陰天に移行
		ELSEIF RAND:20 == 0
			TIME:5 = 天气_阴
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		;上記確率に引っかからなかったら晴天
		ELSE
			TIME:5 = 天气_少云
		ENDIF
	CASE 天气_晴
		;20%で多雲に移行
		IF RAND:5 == 0
			TIME:5 = 天气_多云
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSE
			TIME:5 = 天气_少云
		ENDIF
	;陰天の時
	CASE 天气_多云, 天气_阴
		;25%で強化or弱体化
		IF RAND:4 == 0
			INVERTBIT TIME:5,0
		ELSE
			;20%で晴天に移行
			IF RAND:5 == 0
				TIME:5 = 天气_少云
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			;多雲なら10%で雨か雪に移行
			ELSEIF TIME:5 == 天气_多云 && RAND:10 == 0
				TIME:5 = 天气_雪
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				;更に10%の確率で霧雨,細雪に移行
				SIF RAND:10 == 0
					SETBIT TIME:5,1
			;陰天なら30%で雪に移行
			ELSEIF TIME:5 == 天气_阴 && RAND:10 < 3
				TIME:5 = 天气_雪
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDIF
		ENDIF
	;雨の時
	CASE 天气_雨, 天气_大雨, 天气_暴雨, 天气_冰雹
		TIME:5 = 天气_雪
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	;霧・霧雨の時
	CASE 天气_雾雨, 天气_雾
		TIME:5 = 天气_少云
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	;雪の時
	CASE IS >= 天气_雪
		;大雪は弱体化
		IF TIME:5 == 天气_大雪
			TIME:5 = 天气_雪
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)

		ELSE
			;50%で陰天に移行
			IF RAND:2 == 0
				TIME:5 = 天气_阴
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			;雪なら10%で細雪か雨雪交加に移行
			ELSEIF TIME:5 == 天气_雪 && RAND:10 == 0
				TIME:5 = 天气_细雪
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				;更に10%の確率で霧雪,冰雹に移行
				SIF RAND:10 == 0
					SETBIT TIME:5,0
			;25%で晴天に移行
			ELSEIF RAND:4 == 0
				TIME:5 = 天气_少云
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				;更に低確率で晴朗
				SIF RAND:100 < 5
					TIME:5 = 天气_晴
				;雪→晴天を処理したらダイヤモンドダストが出る
				TIME:7 = 天气_钻石尘
			ENDIF
		ENDIF
	CASEELSE
		TIME:5 = RAND:4
ENDSELECT

;連続降水Counter
CALL qol_CONTINUOUS_RAINFALL_COUNTER(TIME:5)

;連続降雪Counter
CALL qol_CONTINUOUS_SNOWFALL_COUNTER_WINTER(TIME:5)

;強風である場合風がおさまる
SELECTCASE WIND_VELOCITY
	CASE 天气_强风
		WIND_VELOCITY = 天气_无风
		CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
	CASE 天气_暴风
		WIND_VELOCITY = 天气_强风
		CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
