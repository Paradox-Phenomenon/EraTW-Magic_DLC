@qol_CHANGE_WEATHER_SYSTEM_12(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY

SELECTCASE TIME:5
	;晴天の時
	CASE 天气_少云, 天气_晴
		TIME:5 = 天气_阴
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	;陰天の時
	CASE 天气_多云, 天气_阴
		;25%で強化or弱体化
		IF RAND:4 == 0
			INVERTBIT TIME:5,0
		ELSE
			;多雲なら25%で雨か雪に移行
			IF TIME:5 == 天气_多云 && RAND:4 == 0
				TIME:5 = 天气_雪
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			;陰天なら50%で雨に移行
			ELSEIF TIME:5 == 天气_阴 && RAND:2 == 0
				TIME:5 = 天气_雪
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDIF
		ENDIF
	;雨の時
	CASE 天气_雨, 天气_大雨, 天气_雾雨, 天气_雾, 天气_暴雨, 天气_冰雹
		TIME:5 = 天气_雪
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	;雪の時
	CASE IS >= 天气_雪
		;10%で強化
		IF !GETBIT(TIME:5,0) && RAND:10 == 0
			SETBIT TIME:5,0
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		;50%の確率で弱体化
		ELSEIF GETBIT(TIME:5,0) && RAND:2
			CLEARBIT TIME:5,0
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)

		ELSE
			;25%で陰天に移行
			IF RAND:4 == 0
				TIME:5 = 天气_阴
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			;雪なら10%で細雪か雨雪交加に移行
			ELSEIF TIME:5 == 天气_雪 && RAND:10 == 0
				TIME:5 = 天气_细雪
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				;更に10%の確率で霧雪,冰雹に移行
				SIF RAND:10 == 0
					SETBIT TIME:5,0
			ENDIF
		ENDIF
	CASEELSE
		TIME:5 = 天气_雪
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
ENDSELECT

