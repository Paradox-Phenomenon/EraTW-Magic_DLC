#DIM 上回风力
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY

SELECTCASE TIME:5
	CASE 天气_晴
		TIME:5 = 天气_多云
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	CASE 天气_多云
		IF RAND:4 == 0
			TIME:5 = 天气_少云
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSE
			TIME:5 = 天气_阴
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	CASE 天气_阴
		IF RAND:3 == 0
			TIME:5 = 天气_多云
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSE
			TIME:5 = 天气_雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	CASE 天气_雨, 天气_大雨, 天气_雾雨, 天气_雾, 天气_暴雨, 天气_冰雹
		IF GET_HEAT_THUNDERSTORM() == 1 && GET_FRONTAL_THUNDERSTORM() == 1 && (TIME:5 == 天气_雨 || TIME:5 == 天气_大雨) && RAND:2 == 0 && TIME:5 != 天气_暴雨
			TIME:5 = 天气_暴雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSEIF (GET_HEAT_THUNDERSTORM() == 1 || GET_FRONTAL_THUNDERSTORM() == 1) && TIME:5 == 天气_雨
			IF RAND:4 == 0
				TIME:5 = 天气_冰霰
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSE
				TIME:5 = 天气_大雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDIF
		ELSEIF RAND:3 == 0
			TIME:5 = 天气_少云
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			;雨→晴天を処理したら虹が出る
			TIME:7 = 天气_晴
			;市場が開かれる
			FLAG:市場の神 = 1
		ELSE
			TIME:5 = 天气_阴
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	CASEELSE
		TIME:5 = 天气_阴
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
ENDSELECT

;連続降水Counter
CALL qol_CONTINUOUS_RAINFALL_COUNTER(TIME:5)

;強風である場合風がおさまる
IF WIND_VELOCITY != 天气_无风
	WIND_VELOCITY = 天气_无风
	CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
ENDIF

;降雪・雪崩判定を解除
CALL qol_NO_AVALANCHE

;-------------------------------------------------
;15 梅雨・秋雨(梅雨末期・秋雨+台風接近)・先駆降雨帯発生時の天気
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_15(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
#DIM 活発化フラグ
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY
活発化フラグ = 0

SIF POWER_WARM_AIR == 5 || GET_LOCATION_LOW() == "台風勢力圏" || GET_HEAT_THUNDERSTORM() == 1 || GET_FRONTAL_THUNDERSTORM() == 1
	活発化フラグ = 1

SELECTCASE TIME:5
	CASE 天气_阴
		IF 活発化フラグ == 1
			IF RAND:3 == 0
				TIME:5 = 天气_大雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSEIF RAND:2 == 0 && (GET_HEAT_THUNDERSTORM() == 1 || GET_FRONTAL_THUNDERSTORM() == 1)
				IF GET_HEAT_THUNDERSTORM() == 1 && GET_FRONTAL_THUNDERSTORM() == 1
					IF RAND:4 == 0
						TIME:5 = 天气_冰雹
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					ELSE
						TIME:5 = 天气_暴雨
						CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
					ENDIF
				ELSE
					TIME:5 = 天气_冰霰
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ENDIF
			ELSE
				TIME:5 = 天气_雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDIF
		ELSE
			IF RAND:4 == 0
				TIME:5 = 天气_大雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSE
				TIME:5 = 天气_雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDIF
		ENDIF
	CASE 天气_雨, 天气_雾雨, 天气_雾
		IF GET_HEAT_THUNDERSTORM() == 1 && GET_FRONTAL_THUNDERSTORM() == 1 && RAND:2
			IF RAND:4 == 0
				TIME:5 = 天气_冰雹
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSE
				TIME:5 = 天气_暴雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDIF
		ELSEIF 活発化フラグ == 1
			IF RAND:3 != 0
				TIME:5 = 天气_大雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSEIF RAND:2 == 0
				TIME:5 = 天气_冰霰
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSE
				TIME:5 = 天气_阴
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDIF
		ELSE
			IF RAND:2 != 0
				TIME:5 = 天气_大雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSE
				TIME:5 = 天气_阴
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDIF
		ENDIF
	CASE 天气_大雨, 天气_暴雨, 天气_冰雹
		IF GET_HEAT_THUNDERSTORM() == 1 && GET_FRONTAL_THUNDERSTORM() == 1
			IF RAND:4 == 0 && TIME:5 != 天气_冰雹
				TIME:5 = 天气_冰雹
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSEIF RAND:2 == 0 && TIME:5 != 天气_暴雨
				TIME:5 = 天气_暴雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSEIF TIME:5 == 天气_暴雨
				IF RAND:3
					TIME:5 = 天气_雨
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ELSE
					TIME:5 = 天气_大雨
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ENDIF
			ELSE
				TIME:5 = 天气_阴
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDIF
		ELSEIF 活発化フラグ == 1
			IF RAND:2 != 0
				TIME:5 = 天气_冰霰
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSE
				TIME:5 = 天气_雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDIF
		ELSE
			IF RAND:2 != 0
				TIME:5 = 天气_雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSE
				TIME:5 = 天气_阴
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDIF
		ENDIF
	CASE 天气_冰霰
		IF GET_HEAT_THUNDERSTORM() == 1 && GET_FRONTAL_THUNDERSTORM() == 1
			TIME:5 = 天气_暴雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSE
			TIME:5 = 天气_大雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	CASEELSE
		TIME:5 = 天气_雨
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
ENDSELECT

;連続降水Counter
CALL qol_CONTINUOUS_RAINFALL_COUNTER(TIME:5)

;(天候パッチ)熱界雷時の処理　ダウンバースト発生
IF GET_FRONTAL_THUNDERSTORM() == 1 && GET_HEAT_THUNDERSTORM() == 1 && ATMOSPHERIC_INSTABILITY <= -1
	IF ATMOSPHERIC_INSTABILITY <= -2 && RAND:2 == 0
		SELECTCASE WIND_VELOCITY
			CASE 天气_无风
				WIND_VELOCITY = 天气_暴风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
				;ダウンバーストによる作物への影響
				CALL qol_WEATHER_CHANGE_TO_CROP("STORM")
			CASE 天气_强风
				WIND_VELOCITY = 天气_暴风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
				;ダウンバーストによる作物への影響
				CALL qol_WEATHER_CHANGE_TO_CROP("STORM")
			CASEELSE
				WIND_VELOCITY = 天气_暴风
		ENDSELECT
	ELSE
		SELECTCASE WIND_VELOCITY
			CASE 天气_无风
				WIND_VELOCITY = 天气_强风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
			CASE 天气_强风
				WIND_VELOCITY = 天气_强风
			CASEELSE
				WIND_VELOCITY = 天气_强风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
		ENDSELECT
	ENDIF
;強風である場合風がおさまる
ELSEIF WIND_VELOCITY != 天气_无风
	WIND_VELOCITY = 天气_无风
	CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
ENDIF

;降雪・雪崩判定を解除
CALL qol_NO_AVALANCHE

;-------------------------------------------------
;16 台風接近時の天気(強風域)
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_16(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
#DIMS 低気圧位置
#DIM 豪雨フラグ
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY
低気圧位置 = %GET_LOCATION_LOW()%
豪雨フラグ = 0

;台風勢力5以上、台風の位置が西かつ暖気5のとき豪雨フラグオン
SIF IS_TYPHOON:1 >= 5 && IS_TYPHOON:2 == 3 && POWER_WARM_AIR >= 5
	豪雨フラグ = 1

SELECTCASE TIME:5
	CASE 天气_阴
		IF RAND:2 == 0
			TIME:5 = 天气_大雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSE
			TIME:5 = 天气_雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	CASE 天气_雨, 天气_雾雨, 天气_雾
		IF RAND:2 != 0
			TIME:5 = 天气_大雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSEIF RAND:2 == 0 && 低気圧位置 == "台風通過強風域"
			TIME:5 = 天气_阴
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	CASE 天气_大雨, 天气_暴雨
		IF RAND:2 != 0 && 豪雨フラグ == 1 && TIME:5 != 天气_暴雨 && 低気圧位置 != "台風通過強風域"
			TIME:5 = 天气_暴雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSEIF RAND:2 != 0
			TIME:5 = 天气_雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	CASE 天气_冰霰, 天气_冰雹
		TIME:5 = 天气_大雨
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	CASEELSE
		TIME:5 = 天气_雨
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
ENDSELECT

;連続降水Counter
CALL qol_CONTINUOUS_RAINFALL_COUNTER(TIME:5)

SELECTCASE WIND_VELOCITY
	CASE 天气_无风
		WIND_VELOCITY = 天气_强风
		CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
		低気圧位置 = %GET_LOCATION_LOW()%
		IF 低気圧位置 == "台風接近強風域"
			CALL qol_WEATHER_CHANGE_DIARY_PRINT("台风")
		ENDIF
	CASE IS >= 天气_暴风
		WIND_VELOCITY = 天气_强风
		CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
ENDSELECT

;降雪・雪崩判定を解除
CALL qol_NO_AVALANCHE

;-------------------------------------------------
;21 台風接近時の天気(暴風域・最接近)
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_21(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
#DIM 現在台風位置
#DIMS 低気圧位置
#DIM 颶風フラグ
#DIM 豪雨フラグ
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY
低気圧位置 = %GET_LOCATION_LOW()%
颶風フラグ = 0
豪雨フラグ = 0

;台風勢力5以上、台風の位置が西かつ暖気5のとき豪雨フラグオン
SIF IS_TYPHOON:1 >= 5 && IS_TYPHOON:2 == 3 && POWER_WARM_AIR >= 5
	豪雨フラグ = 1

SELECTCASE 低気圧位置
	CASE "台風接近暴風域", "台風最接近"
		現在台風位置 = 1
	CASE "台風通過暴風域"
		現在台風位置 = 2
ENDSELECT

SELECTCASE TIME:5
	CASE 天气_阴
		IF RAND:2 == 0
			TIME:5 = 天气_大雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSE
			TIME:5 = 天气_雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	CASE 天气_雨, 天气_雾雨, 天气_雾
		IF RAND:2 != 0
			TIME:5 = 天气_大雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSEIF RAND:2 == 0
			IF 豪雨フラグ == 1
				TIME:5 = 天气_暴雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSEIF 現在台風位置 == 2
				TIME:5 = 天气_阴
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDIF
		ELSE
			TIME:5 = 天气_阴
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	CASE 天气_大雨, 天气_暴雨
		IF TIME:5 != 天气_暴雨 && 豪雨フラグ == 1
			TIME:5 = 天气_暴雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSEIF RAND:2 != 0 && 現在台風位置 == 2
			TIME:5 = 天气_阴
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSEIF RAND:2 != 0
			IF TIME:5 == 天气_暴雨
				TIME:5 = 天气_大雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ELSE
				TIME:5 = 天气_雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			ENDIF
		ENDIF
	CASE 天气_冰霰, 天气_冰雹
		TIME:5 = 天气_大雨
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	CASEELSE
		TIME:5 = 天气_雨
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
ENDSELECT

;連続降水Counter
CALL qol_CONTINUOUS_RAINFALL_COUNTER(TIME:5)

;台風勢力5以上、寒気1かつ暖気5のとき颶風フラグオン
SIF IS_TYPHOON:1 >= 5 && POWER_COLD_AIR == 1 && POWER_WARM_AIR >= 5
	颶風フラグ = 1

SELECTCASE WIND_VELOCITY
	CASE 天气_无风
		IF 颶風フラグ == 1
			WIND_VELOCITY = 天气_飓风
			CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
		ELSE
			WIND_VELOCITY = 天气_暴风
			CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
		ENDIF
	CASE 天气_强风
		WIND_VELOCITY = 天气_暴风
		CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
		;台風直撃による作物への影響
		SIF IS_TYPHOON:2 == 2
			CALL qol_WEATHER_CHANGE_TO_CROP("STORM")
	CASE 天气_暴风
		IF 颶風フラグ == 1 && 現在台風位置 == 1
			WIND_VELOCITY = 天气_飓风
			CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
			;猛烈な風による作物への影響
			CALL qol_WEATHER_CHANGE_TO_CROP("STORM")
		ENDIF
	CASE IS >= 天气_飓风
		IF 現在台風位置 == 2
			WIND_VELOCITY = 天气_暴风
			CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
		ENDIF
ENDSELECT

;降雪・雪崩判定を解除
CALL qol_NO_AVALANCHE

;-------------------------------------------------
;17 台風接近時の天気(台風の目)
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_17(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY

IF IS_TYPHOON:1 < 3 && (TIME:5 != 天气_多云 || WIND_VELOCITY != 天气_无风)
	TIME:5 = 天气_多云
	WIND_VELOCITY = 天气_无风
	CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
	;念のため相合伞を解除
	FOR LOCAL,0,CHARANUM
		SIF TEQUIP:LOCAL:201
			TEQUIP:LOCAL:201 = 0
	NEXT
ELSEIF TIME:5 != 天气_少云 || WIND_VELOCITY != 天气_无风
	TIME:5 = 天气_少云
	WIND_VELOCITY = 天气_无风
	CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
	;念のため相合伞を解除
	FOR LOCAL,0,CHARANUM
		SIF TEQUIP:LOCAL:201
			TEQUIP:LOCAL:201 = 0
	NEXT
ENDIF

;降雪・雪崩判定を解除
CALL qol_NO_AVALANCHE

;-------------------------------------------------
;18 霧の天気
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_18(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY

SELECTCASE TIME:5
	CASE 天气_雾雨
		TIME:5 = 天气_雾
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	CASE 天气_细雪
		TIME:5 = 天气_雾
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	CASE 天气_雾
		IF DAY:2 == 4
			TIME:5 = 天气_细雪
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSE
			TIME:5 = 天气_雾雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
	CASEELSE
		IF RAND:2 == 0
			TIME:5 = 天气_雾
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSEIF DAY:2 == 4
			TIME:5 = 天气_细雪
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ELSE
			TIME:5 = 天气_雾雨
			CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
		ENDIF
ENDSELECT

;連続降水Counter
CALL qol_CONTINUOUS_RAINFALL_COUNTER(TIME:5)

;-------------------------------------------------
;19 疑似好天
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_19(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY

IF TIME:5 != 天气_晴 || WIND_VELOCITY != 天气_无风
	TIME:5 = 天气_晴
	WIND_VELOCITY = 天气_无风
	CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
ENDIF

;雪崩発生フラグ判定
CALL qol_POSSIBLITY_AVALANCHE_WINTER(TIME:5)

;-------------------------------------------------
;20 集中豪雨時の天気
;-------------------------------------------------
@qol_CHANGE_WEATHER_SYSTEM_20(无天气)
#DIM 无天气
#DIM 上回天气
#DIM 上回风力
TIME:7 = 0
上回天气 = TIME:5
上回风力 = WIND_VELOCITY

SELECTCASE TIME:5
	CASE 天气_大雨
		SELECTCASE RAND:3
			CASE 0,1
				TIME:5 = 天气_暴雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			CASE 2
				IF ATMOSPHERIC_INSTABILITY <= 0
					TIME:5 = 天气_冰雹
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ELSE
					TIME:5 = 天气_冰霰
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ENDIF
		ENDSELECT
	CASE 天气_暴雨
		SELECTCASE RAND:4
			CASE 0
				TIME:5 = 天气_大雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
			CASE 1
				IF ATMOSPHERIC_INSTABILITY <= 0
					TIME:5 = 天气_冰雹
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ELSE
					TIME:5 = 天气_冰霰
					CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
				ENDIF
		ENDSELECT
	CASE 天气_冰霰, 天气_冰雹
				TIME:5 = 天气_暴雨
				CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
	CASEELSE
		TIME:5 = 天气_暴雨
		CALL qol_CHANGE_WEATHER_SYSTEM_INFO_PRINT(无天气, MASTER, 上回天气, TIME:5, TIME:2)
ENDSELECT

;連続降水Counter
CALL qol_CONTINUOUS_RAINFALL_COUNTER(TIME:5)

;(天候パッチ)熱界雷時の処理　ダウンバースト発生
IF ATMOSPHERIC_INSTABILITY <= 0 && RAND:4 == 0
	IF ATMOSPHERIC_INSTABILITY <= -2 && RAND:2 == 0
		SELECTCASE WIND_VELOCITY
			CASE 天气_无风
				WIND_VELOCITY = 天气_暴风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
				;ダウンバーストによる作物への影響
				CALL qol_WEATHER_CHANGE_TO_CROP("STORM")
			CASE 天气_强风
				WIND_VELOCITY = 天气_暴风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
				;ダウンバーストによる作物への影響
				CALL qol_WEATHER_CHANGE_TO_CROP("STORM")
			CASEELSE
				WIND_VELOCITY = 天气_暴风
		ENDSELECT
	ELSE
		SELECTCASE WIND_VELOCITY
			CASE 天气_无风
				WIND_VELOCITY = 天气_强风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
			CASE 天气_强风
				WIND_VELOCITY = 天气_强风
			CASEELSE
				WIND_VELOCITY = 天气_强风
				CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
		ENDSELECT
	ENDIF
;強風である場合風がおさまる
ELSEIF WIND_VELOCITY != 天气_无风
	WIND_VELOCITY = 天气_无风
	CALL qol_CHANGE_WEATHER_SYSTEM_WIND_PRINT(无天气, MASTER, 上回风力, WIND_VELOCITY)
ENDIF

;降雪・雪崩判定を解除
CALL qol_NO_AVALANCHE
