@删除立绘履历
#DIM POPSTRLINES
#LOCALSIZE 2
#LOCALSSIZE 300
#DIM CONST 制动阈值 = 60
VARSET LOCALS
SIF FIGURE_ENDLINE == 0
	RETURN
LOCAL:1 = CURRENTREDRAW()
REDRAW 0
POPSTRLINES = MIN(LINECOUNT - FIGURE_ENDLINE, 299)
[IF_NDEBUG]
	IF POPSTRLINES > 制动阈值 && MESSKIP()
		FORCEWAIT
	ENDIF
[ENDIF]
FOR LOCAL, POPSTRLINES, -1, -1
	LOCALS:LOCAL = %HTML_GETPRINTEDSTR(LOCAL)%
NEXT
CLEARLINE LINECOUNT - FIGURE_STARTLINE
FOR LOCAL, POPSTRLINES, -1, -1
	PRINTPLAINFORM %HTML_TOPLAINTEXT(LOCALS:LOCAL)%
	PRINTL
NEXT
REDRAW LOCAL:1

@INIT_KOJO_COLOR
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_C
LOCAL = GETCOLOR()
FOR COUNT, 1, RANDOM_CHARANUM
	RESETCOLOR
	CALL KOJO_ACTIVE_INFO(COUNT)
	TRYCALLFORM M_KOJO%RESULTS%_COLOR_K{COUNT}
	QOL_KOJO_COLOR:COUNT:0 = GETCOLOR()
NEXT
SETCOLOR LOCAL
