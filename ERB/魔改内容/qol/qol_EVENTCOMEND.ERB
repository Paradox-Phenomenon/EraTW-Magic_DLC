@删除立绘履历
#LOCALSIZE 2
#LOCALSSIZE 1
#DIM  DYNAMIC POPSTRLINES
#DIMS DYNAMIC L_STR,1000
#DIM CONST 制动阈值 = 60
VARSET LOCALS
SIF FIGURE_ENDLINE == 0
	RETURN

LOCAL:1 = CURRENTREDRAW()
REDRAW 0
BITMAP_CACHE_ENABLE 1

POPSTRLINES = MIN(LINECOUNT - FIGURE_ENDLINE, 999)
[IF NDEBUG]
	IF POPSTRLINES > 制动阈值 && MESSKIP()
		FORCEWAIT
	ENDIF
[ENDIF]
FOR LOCAL, POPSTRLINES, -1, -1
	L_STR:LOCAL = <clearbutton>%HTML_GETPRINTEDSTR(LOCAL)%</clearbutton>
NEXT
CLEARLINE LINECOUNT - FIGURE_STARTLINE
FOR LOCAL, POPSTRLINES, -1, -1
	HTML_PRINT L_STR:LOCAL
NEXT
REDRAW LOCAL:1
BITMAP_CACHE_ENABLE 0

@INIT_KOJO_COLOR
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_C
LOCAL = GETCOLOR()
FOR COUNT, 1, RANDOM_CHARANUM
	RESETCOLOR
	CALL KOJO_ACTIVE_INFO(COUNT)
	TRYCALLFORM M_KOJO%RESULTS%_COLOR_K{COUNT}
	QOL_KOJO_COLOR:COUNT:0 = GETCOLOR()
NEXT
SETCOLOR LOCAL
