@MAKE_OOP_MAP(CLASS_NAME, O_FIRST = OBJ_ID_FIRST, O_LAST = OBJ_ID_LAST)
#DIMS DYNAMIC CLASS_NAME
#DIM DYNAMIC O_FIRST
#DIM DYNAMIC O_LAST
#DIMS DYNAMIC O_MAP
#LOCALSIZE 1
#LOCALSSIZE 1
O_MAP '= CLASS_NAME + "_NAME2ID"
IF !MAP_EXIST(O_MAP)
	MAP_CREATE O_MAP
	;DEBUGPRINTFORML ------------------------------
	FOR LOCAL, O_FIRST, OBJ_ID_LAST + 1
		LOCALS '= GETMETH_STR(0, CLASS_NAME, LOCAL, "名前")
		IF LOCALS != ""
			MAP_SET O_MAP, LOCALS, TOSTR(LOCAL)
			;DEBUGPRINTFORML {LOCAL, 3, LEFT}: %LOCALS%
		ENDIF
	NEXT
	;DEBUGPRINTFORML ------------------------------
	;DEBUGPRINTFORML %O_MAP% map made
ENDIF
