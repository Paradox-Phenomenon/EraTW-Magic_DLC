@GETMETH_INT(ARG, CLASS_NAME, O_ID, O_DATA)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS CLASS_NAME  ;OBJの名前（例：WEAPON）
#DIM  O_ID        ;参照するOBJのID（例：1）
#DIMS O_DATA      ;参照したい情報の名前（例：価格）
;DEBUGPRINTFORML GET_INT ARG：{ARG}, CLASS_NAME：%CLASS_NAME%, O_ID：{O_ID}, O_DATA：%O_DATA%
;IF !EXISTMETH(@"F%CLASS_NAME%{O_ID}")
;	DEBUGPRINTFORML F%CLASS_NAME%{O_ID}不存在
;	RETURNF 0
;ENDIF
LOCALS = %GETMETHS(@"F%CLASS_NAME%{O_ID}", "0", ARG, O_DATA)%
;DEBUGPRINTFORML GET_INT LOCALS：%LOCALS%
SIF !STRLENS(LOCALS)
	RETURNF 0
SIF !ISNUMERIC(LOCALS)
	RETURNF 0
RETURNF TOINT(LOCALS)

@GETMETH_STR(ARG, CLASS_NAME, O_ID, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS CLASS_NAME  ;OBJの名前（例：WEAPON）
#DIM  O_ID        ;参照するOBJのID（例：1）
#DIMS O_DATA      ;参照したい情報の名前（例：名前）
;DEBUGPRINTFORML GET_STR ARG：{ARG}, CLASS_NAME：%CLASS_NAME%, O_ID：{O_ID}, O_DATA：%O_DATA%
;IF !EXISTMETH(@"F%CLASS_NAME%{O_ID}")
;	DEBUGPRINTFORML F%CLASS_NAME%{O_ID}不存在
;	RETURNF 
;ENDIF
RETURNF GETMETHS(@"F%CLASS_NAME%{O_ID}", "", ARG, O_DATA)

@GETMETH_OBJNAME_TO_ID(ARG, CLASS_NAME, KEY)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC CLASS_NAME
#DIMS DYNAMIC KEY
#DIMS DYNAMIC O_MAP
O_MAP '= CLASS_NAME + "_NAME2ID"
IF MAP_EXIST(O_MAP)
	LOCALS '= MAP_GET(O_MAP, KEY)
	IF LOCALS != ""
		RETURNF TOINT(LOCALS)
	ENDIF
ENDIF
;只有动态名需要
FOR LOCAL, 0, OBJ_ID_LAST + 1
	IF GETMETH_STR(ARG, CLASS_NAME, LOCAL, "名前") == KEY
		RETURNF LOCAL
	ENDIF
NEXT
RETURNF -1

