@SET_MAINHOME_PROCESS_INPUT(EVENT_TYPE, EVENT_DATA, 設定前MAIN_MAP, 設定前酒虫, 設定前初期位置, 設定前大家, ANIMATION_SEED, UI_MESSAGE)
#LOCALSIZE 1
#LOCALSSIZE 1
