@QOL_COM400
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC INPUT_LOOP_LINE
#DIM DYNAMIC ANIMATION_SEED
#DIM DYNAMIC PREV_REDRAW
#DIM DYNAMIC UPDATE_INTERVAL
#DIM DYNAMIC HOVER_TIMEOUT
#DIMS DYNAMIC LISTEN_CONF
#DIMS DYNAMIC UI_MESSAGE
#DIM  DYNAMIC AWAIT_HANG     ; 闸口状态：1 = AWAIT滚动模式, 0 = TINPUTS悬停模式
#DIM  DYNAMIC AWAIT_CHECK
#DIM DYNAMIC PREV_AWAIT_HANG

; 幻想乡大地图，GMF调用函数修改MAIN_MAP后获得对应地图返回值
IF GMF_GETBIT("幻想乡大地图") && GMF_METHOD_STACK != "COM400"
	SIF GMF_IS_ODEKAKE()
		CALL GMF_604_TO_400
	JUMP GMF_MAP_METHOD(-1, 0, "COM400")
ENDIF

TOOLTIP_SETDELAY 100
AWAIT_CHECK = (ANIMATERECOLOREDMAPS > 0 && !FLAG:70)
ANIMATION_SEED = 0
;PREV_REDRAW = CURRENTREDRAW()
AWAIT_HANG = AWAIT_CHECK
AWAIT_HOVER_VALUE = 

LISTEN_CONF = %UI_AWAIT_CONFIG("MAP_MODE", "", 1, 0, 1)%

LINESTART = LINECOUNT
$MAP_LOOP
CLEARLINE LINECOUNT - LINESTART
CALL COM400_DRAW_UI(ANIMATION_SEED, UI_MESSAGE)

UI_MESSAGE = 
INPUT_LOOP_LINE = LINECOUNT

$INPUT_LOOP
CLEARLINE LINECOUNT - INPUT_LOOP_LINE

PREV_AWAIT_HANG = AWAIT_HANG

IF AWAIT_CHECK
	; 检查鼠标是否悬停在有效按钮上 (MOUSEB()返回当前悬停按钮的value)
	AWAIT_HOVER_VALUE '= MOUSEB()
	IF AWAIT_HOVER_VALUE != ""
		; 如果鼠标在按钮上，暂停动画
		AWAIT_HANG = 0
		UPDATE_INTERVAL = 0
	ELSE
		; 否则恢复动画
		AWAIT_HANG = 1
		UPDATE_INTERVAL = ANIMATERECOLOREDMAPS
	ENDIF
ELSE
	AWAIT_HANG = 0
	UPDATE_INTERVAL = 0
ENDIF

IF AWAIT_HANG
	CALL AWAIT_UI_INPUT(LISTEN_CONF, UPDATE_INTERVAL)

	LOCAL:0 = RESULT
	LOCALS:0 = %RESULTS%
ELSE
	IF PREV_AWAIT_HANG
		;REDRAW 2
		GOTO MAP_LOOP
	ENDIF
	IF ANIMATERECOLOREDMAPS > 0 && !FLAG:70
		TINPUTS 1500, "UPDATE", 0, ""
	ELSE
		INPUTS
	ENDIF
	LOCAL:0 = (RESULTS == "UPDATE") ? 0 # 1
	LOCALS:0 = %RESULTS%
ENDIF

CALL COM400_PROCESS_INPUT(LOCAL:0, LOCALS:0, UI_MESSAGE)

SELECTCASE RESULT
	CASE -1
		;DEBUGPRINTFORML [QOL_COM400] 收到 -1，退出地图
		TOOLTIP_SETDELAY 500
		RETURN -1
	CASE 0
		;DEBUGPRINTFORML [QOL_COM400] 收到 0，移动成功
		TOOLTIP_SETDELAY 500
		RETURN 1
	CASE 1
		;DEBUGPRINTFORML [QOL_COM400] 收到 1，无效输入，GOTO INPUT_LOOP
		GOTO INPUT_LOOP
	CASE 2
		;DEBUGPRINTFORML [QOL_COM400] 收到 2，UI状态改变，GOTO MAP_LOOP
		GOTO MAP_LOOP
	CASE 3
		ANIMATION_SEED ++
		SIF ANIMATION_SEED >= 20
			ANIMATION_SEED = 0
		GOTO MAP_LOOP
ENDSELECT

;================================================
; COM400 UI 渲染模块
;================================================
@COM400_DRAW_UI(ANIMATION_SEED, UI_MESSAGE)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM ANIMATION_SEED
#DIMS REF UI_MESSAGE
#DIM BUTTON返回
#DIM BUTTON切替左
#DIM BUTTON切替中
#DIM BUTTON切替右

BUTTON返回 = MAXROOM + 1
BUTTON切替左 = MAXROOM + 2
BUTTON切替中 = MAXROOM + 4
BUTTON切替右 = MAXROOM + 4

; 人数カウントをリセット
VARSET COUNTCHARA
FOR LOCAL, 1, CHARANUM
	COUNTCHARA:(CFLAG:LOCAL:現在位置) ++
NEXT
CALL TURN_RESET

DRAWLINE
IF RECOLOREDMAPS
	CALL DRAW_COLOREDMAP(ANIMATION_SEED)
ELSE
	CALL DRAW_MAP
ENDIF

IF FLAG:移動先表示 < 3
	PRINTL
	TRYCALLFORM MAP_{MAIN_MAP}_{TFLAG:マップ切り替え}
ENDIF
PRINTL
PRINTFORML 当前位置→[{(CFLAG:MASTER:現在位置)}]%NAME_FROM_PLACE(CFLAG:MASTER:現在位置)%

IF FLAG:察知模式 == 1
	PRINT 颜色的说明：
	CALL COLORMESSAGE("逗留中　", C_H_PINK, 0)
	CALL COLORMESSAGE("工作中　", C_D_ORANGE, 0)
	CALL COLORMESSAGE("睡眠中　", C_N_BLUE, 0)
	CALL COLORMESSAGE("路人　", C_D_PINK, 0)
	CALL COLORMESSAGE("自由行动", C_YELLOW, 0)
	PRINTL
ELSEIF FLAG:察知模式 == 2
	IF OUTROOF(CFLAG:MASTER:現在位置) && DAY:2 == 4
		PRINT 积雪量：
		CALL COLORMESSAGE("干净　", C_GREEN, 0)
		CALL COLORMESSAGE("小　", C_M_GREEN , 0)
		CALL COLORMESSAGE("较小　", C_P_GREEN, 0)
		CALL COLORMESSAGE("中　", 0xFFFFFF, 0)
		CALL COLORMESSAGE("较大　", 0xFFFFFF, 0)
		CALL COLORMESSAGE("大　", 0xFFFFFF , 0)
		CALL COLORMESSAGE("雪山", 0xFFFFFF, 0)
		PRINTL
	ELSE
		PRINT 清洁度：
		CALL COLORMESSAGE("最高　", C_GREEN, 0)
		CALL COLORMESSAGE("高　", C_M_GREEN , 0)
		CALL COLORMESSAGE("较高　", C_P_GREEN, 0)
		CALL COLORMESSAGE("中　", C_YELLOW, 0)
		CALL COLORMESSAGE("较低　", C_V_PINK, 0)
		CALL COLORMESSAGE("低　", C_RED , 0)
		CALL COLORMESSAGE("垃圾山", C_RED, 0)
		PRINTL
	ENDIF
ENDIF

SIF CFLAG:MASTER:現在位置 != CFLAG:MASTER:初期位置 && (!GMF_GETBIT("幻想乡大地图") || GET_MAPID(CFLAG:MASTER:現在位置) == GMF_HOME_MAP)
	PRINTL [  0] - 返回私室

FOR LOCAL, MINROOM(), MAXROOM
	SIF !(CAN_MOVE(CFLAG:MASTER:現在位置, LOCAL) & 1) || NAME_FROM_PLACE(LOCAL) == ""
		CONTINUE
	SELECTCASE FLAG:移動先表示
		CASE 1, 3
			PRINTFORML [{LOCAL, 3}] - %NAME_FROM_PLACE(LOCAL)%
		CASE 2, 4
			PRINTFORM [{LOCAL, 3}] - %NAME_FROM_PLACE(LOCAL),5,LEFT%
	ENDSELECT
NEXT

SIF FLAG:移動先表示 == 2 || FLAG:移動先表示 == 4
	PRINTL

IF !CAN_MOVE(CFLAG:MASTER:現在位置, ENTRANCE) & 1 && CFLAG:MASTER:現在位置 != ENTRANCE
	SIF FLAG:移動先表示 == 1
		PRINTL
	PRINTFORML [{ENTRANCE, 3}] - %NAME_FROM_PLACE(ENTRANCE)%
ELSEIF FLAG:移動先表示 == 1
	PRINTL
ENDIF

PRINTFORM [{BUTTON返回, 3}] - 返回　　　
PRINTBUTTON "＜]", TOSTR(BUTTON切替左)
PRINTBUTTON "地图切换", TOSTR(BUTTON切替中)
PRINTFORM ({TFLAG:地圖切換})
PRINTBUTTON "[＞", TOSTR(BUTTON切替右)

SIF TALENT:MASTER:居場所察知 || TALENT:MASTER:汚部屋察知
	PRINTBUTTON "　　[Y] - 察觉模式", "Y"
IF FLAG:察知模式 == 1
	PRINT (居)　
ELSEIF FLAG:察知模式 == 2
	PRINT (污)　
ELSE
	PRINT 　　
ENDIF

SIF TALENT:MASTER:居場所察知 && FLAG:察知模式 == 1
	PRINTBUTTON "[Z] - 所在地察觉　 ", "Z"
SIF TALENT:MASTER:汚部屋察知 && FLAG:察知模式 == 2
	PRINTBUTTON "[X] - 脏房间察觉　 ", "X"
PRINTBUTTON "[C] - 切换目的地显示", "C"

IF TALENT:MASTER:体型 < -4
	PRINTL
	IF CFLAG:MASTER:同行
		PRINT （搭顺风车真开心）
	ELSE
		PRINT （走过去都很辛苦…）
	ENDIF
ENDIF

IF UI_MESSAGE != ""
	PRINTL
	CALL COLORMESSAGE(@" ※ %UI_MESSAGE% ※", C_RED, 1)
ELSE
	PRINTL
ENDIF

;================================================
; COM400 逻辑处理模块 (返回代码告知主控进行何种跳转)
; -1=退出当前指令, 0=完成移动, 1=忽略等待, 2=需重绘(清除屏幕), 3=Tick更新
;================================================
@COM400_PROCESS_INPUT(EVENT_TYPE, EVENT_DATA, UI_MESSAGE)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM EVENT_TYPE
#DIMS EVENT_DATA
#DIMS REF UI_MESSAGE
#DIM BUTTON返回
#DIM BUTTON切替左
#DIM BUTTON切替中
#DIM BUTTON切替右
#DIM DYNAMIC NUM_RES

BUTTON返回 = MAXROOM + 1
BUTTON切替左 = MAXROOM + 2
BUTTON切替中 = MAXROOM + 4
BUTTON切替右 = MAXROOM + 4
;DEBUGPRINTFORML PROCESS_INPUT:{EVENT_TYPE}-%EVENT_DATA%

; --- 1. 动画 Tick 拦截 ---
IF EVENT_TYPE == 0 && EVENT_DATA == "UPDATE"
	RETURN 3
ENDIF

; --- 2. 退出指令拦截 (ESC / 鼠标右键) ---
IF EVENT_TYPE == 3 || EVENT_DATA == "MOUSE_R"
	RETURN -1
ENDIF

; --- 3. 忽略无效空字符串 (如点击非按钮区域) ---
IF EVENT_DATA == ""
	RETURN 1
ENDIF

; --- 4. 热键处理 ---
SELECTCASE EVENT_DATA
	CASE "Z", "z", "X", "x"
		IF TALENT:MASTER:居場所察知 && (EVENT_DATA == "Z" || EVENT_DATA == "z")
			CALL QOL_HITOSAGASI(, 1)
		ELSEIF TALENT:MASTER:汚部屋察知 && (EVENT_DATA == "X" || EVENT_DATA == "x")
			CALL OHEYA_CHECK()
		ELSE
			RETURN 2
		ENDIF
		IF RESULT > 0
			NUM_RES = RESULT
			GOTO PROCESS_MOVE_LOGIC
		ENDIF
		RETURN 2
	CASE "Y", "y"
		IF TALENT:MASTER:居場所察知 && TALENT:MASTER:汚部屋察知
			FLAG:察知模式 = (FLAG:察知模式 >= 2) ? 0 # FLAG:察知模式 + 1
		ELSEIF TALENT:MASTER:居場所察知
			FLAG:察知模式 = !FLAG:察知模式
		ELSEIF TALENT:MASTER:汚部屋察知
			FLAG:察知模式 = (!FLAG:察知模式) * 2
		ENDIF
		RETURN 2
	CASE "C", "c"
		FLAG:移動先表示 = (FLAG:移動先表示 >= 5) ? 0 # FLAG:移動先表示 + 1
		RETURN 2
ENDSELECT

; --- 5. 数字按键(地点跳转)处理 ---
IF ISNUMERIC(EVENT_DATA)
	NUM_RES = TOINT(EVENT_DATA)
ELSE
	RETURN 1
ENDIF

SELECTCASE NUM_RES
	CASE BUTTON返回, CFLAG:MASTER:現在位置
		RETURN -1
	CASE BUTTON切替左
		TFLAG:地圖切換 -= 1
		SIF TFLAG:地圖切換 <= 0
			TFLAG:地圖切換 = MAP_PAGES
		RETURN 2
	CASE BUTTON切替右
		TFLAG:地圖切換 += 1
		SIF TFLAG:地圖切換 > MAP_PAGES
			TFLAG:地圖切換 = 1
		RETURN 2
	CASE 0
		IF GMF_GETBIT("幻想乡大地图") && GET_MAPID(CFLAG:MASTER:現在位置) != GMF_HOME_MAP
			RETURN 2
		ENDIF
		IF IN_HOME(CFLAG:MASTER:初期位置) != 1
			UI_MESSAGE = 初始位置不正确，重设为私室位置
			CFLAG:MASTER:初期位置 = 默认初期位置
			RETURN 2 ; 要求重绘把红字印出来
		ENDIF
		SIF CFLAG:MASTER:現在位置 != CFLAG:MASTER:初期位置
			CALL SKIP_MOVE(CFLAG:MASTER:現在位置, CFLAG:MASTER:初期位置)
		RETURN 0
ENDSELECT

; 常规地点处理
SIF INRANGE(NUM_RES, 1, 99)
	NUM_RES += MAIN_MAP * 100

$PROCESS_MOVE_LOGIC
; 移动判定
IF NUM_RES == CFLAG:MASTER:現在位置
	RETURN -1
ELSEIF IN_HOME(NUM_RES) != 1
	TFLAG:マップ切り替え = 0
	UI_MESSAGE = 移动范围外
	RETURN 2 ; 越界，重绘报错
ELSEIF MAP_CAN_MOVE(NUM_RES) == 0
	IF TFLAG:移動不能メッセージ == 999 && LOCKPICK_SYSTEM > 0
		; 开锁系统接管
		CALL LOCKPICK_INFO(NUM_RES)
		RETURN 0
	ELSE
		UI_MESSAGE '= QOL_CANNOT_MOVE_MESSAGE(NUM_RES)
		RETURN 2 ; 走不通，要求重绘出红字
	ENDIF
ELSE
	CALL SKIP_MOVE(CFLAG:MASTER:現在位置, NUM_RES)
	RETURN 0
ENDIF

@QOL_COM604
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC INPUT_LOOP_LINE
#DIM DYNAMIC ANIMATION_SEED
#DIM DYNAMIC UPDATE_INTERVAL
#DIMS DYNAMIC LISTEN_CONF
#DIMS DYNAMIC UI_MESSAGE
#DIM  DYNAMIC AWAIT_HANG
#DIM DYNAMIC PREV_AWAIT_HANG

; 幻想乡大地图拦截
IF GMF_GETBIT("幻想乡大地图") && GMF_METHOD_STACK != "COM604"
	SIF !GMF_IS_ODEKAKE(-1)
		CALL GMF_400_TO_604
	JUMP GMF_MAP_METHOD(-1, 0, "COM604")
ENDIF

FLAG:自室施錠 = 0 ;custom code, unlocks door
ANIMATION_SEED = 0
AWAIT_HANG = (ANIMATERECOLOREDMAPS > 0 && !FLAG:70)
LISTEN_CONF = %UI_AWAIT_CONFIG("DEFAULT", "", 1, 0, 1)% ; 启用右键和ESC退出

LINESTART = LINECOUNT
$MAP_LOOP
CLEARLINE LINECOUNT - LINESTART
CALL COM604_DRAW_UI(ANIMATION_SEED, UI_MESSAGE)

UI_MESSAGE = 
INPUT_LOOP_LINE = LINECOUNT

$INPUT_LOOP
CLEARLINE LINECOUNT - INPUT_LOOP_LINE

PREV_AWAIT_HANG = AWAIT_HANG

IF AWAIT_HANG || (ANIMATERECOLOREDMAPS > 0 && !FLAG:70)
	; 检查鼠标是否悬停在有效按钮上 (MOUSEB()返回当前悬停按钮的value)
	AWAIT_HOVER_VALUE '= MOUSEB()
	IF AWAIT_HOVER_VALUE != ""
		; 如果鼠标在按钮上，暂停动画
		AWAIT_HANG = 0
		UPDATE_INTERVAL = 0
	ELSE
		; 否则恢复动画
		AWAIT_HANG = 1
		UPDATE_INTERVAL = ANIMATERECOLOREDMAPS
	ENDIF
ELSE
	AWAIT_HANG = 0
	UPDATE_INTERVAL = 0
ENDIF

IF AWAIT_HANG
	CALL AWAIT_UI_INPUT(LISTEN_CONF, UPDATE_INTERVAL)
ELSE
	IF PREV_AWAIT_HANG
		;REDRAW 2
		GOTO MAP_LOOP
	ENDIF
	IF ANIMATERECOLOREDMAPS > 0 && !FLAG:70
		TINPUTS 1500, "UPDATE", 0, ""
	ELSE
		INPUTS
	ENDIF
	SIF RESULTS == "UPDATE"
		RESULT = 0
ENDIF

CALL COM604_PROCESS_INPUT(RESULT, RESULTS, UI_MESSAGE)
SELECTCASE RESULT
	CASE -1
		RETURN -1 ; 返回
	CASE 0
		RETURN 1  ; 移动成功，结束指令
	CASE 1
		GOTO INPUT_LOOP ; 无效输入
	CASE 2
		GOTO MAP_LOOP   ; 需要重绘 (UI_MESSAGE 等)
	CASE 3
		ANIMATION_SEED = (ANIMATION_SEED + 1) % 20
		GOTO MAP_LOOP   ; 动画Tick
ENDSELECT

@COM604_DRAW_UI(ANIMATION_SEED, UI_MESSAGE)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM ANIMATION_SEED
#DIMS REF UI_MESSAGE
#DIM LPCOUNT
#DIM 現在地点
#DIM P_ID
#DIM 所要時間
#DIM 時間補正
#DIM 時間停止ジャンプ
#DIM 特殊ワープ

時間停止ジャンプ = FLAG:時間停止 || (GETBIT(FLAG:瞬間移動, AT_HOME(MASTER)) && !FLAG:デート相手)

DRAWLINEFORM ～
IF RECOLOREDMAPS
	CALL DRAW_COLOREDMAP(ANIMATION_SEED, "ODEKAKE")
ELSE
	CALL DRAW_MAP("ODEKAKE")
ENDIF
DRAWLINEFORM ～

PRINTL 要去哪里呢？
現在地点 = CFLAG:MASTER:現在位置 % 100 / 10
LOCAL = 0
FOR LPCOUNT, 1, 10
	P_ID = CFLAG:MASTER:约会中 * 100 + LPCOUNT * 10
	SIF NAME_FROM_PLACE(P_ID) == ""
		CONTINUE
	IF LPCOUNT == 現在地点
		PRINTPLAINFORM [  0] - %NAME_FROM_PLACE(P_ID), 18, LEFT%
		CALL COLORMESSAGE(@"现在地　", C_GREEN, 3)
	ELSE
		時間補正 = 0
		IF 時間停止ジャンプ
			LOCALS = TSP%" "%
		ELSE
			SIF IS_TSUKIAU([[小町]])
				時間補正 += -50
			SIF IS_TSUKIAU([[若鷺姫]]) && !GETBIT (FLAG:泳池, 0)
				時間補正 += 100
			SIF SHORTCUT(CFLAG:MASTER:约会中, -1)
				時間補正 += -50
			LOCALS = 分　
		ENDIF
		所要時間 = 散步所要時間(CFLAG:MASTER:現在位置, P_ID, 時間補正)
		PRINTFORM [{LPCOUNT, 3}] - %NAME_FROM_PLACE(P_ID), 18, LEFT%
		IF 時間補正 < 0
			SETCOLOR C_L_GREEN
		ELSEIF 時間補正 > 0
			SETCOLOR C_ROYAL_BLUE
		ENDIF
		PRINTFORM {所要時間, 3} %LOCALS%
		RESETCOLOR
	ENDIF
	LOCAL ++
	SIF LOCAL % 2 == 0
		PRINTL
NEXT
SIF LOCAL % 2 == 1
	PRINTL

特殊ワープ = ODEKAKEMAP_SETTING(CFLAG:MASTER:現在位置, "特殊ワープ")
IF 特殊ワープ
	所要時間 = 時間停止ジャンプ ? 30 # 10
	PRINTFORML [{特殊ワープ, 3}] - %NAME_FROM_PLACE(特殊ワープ), 18, LEFT%{所要時間, 3} %LOCALS%
ENDIF

PRINTL [100] - 返回　　　　　　　　　　　[ 99] - 移动至其他地域
IF UI_MESSAGE != ""
	PRINTL
	CALL COLORMESSAGE(@" ※ %UI_MESSAGE% ※", C_RED, 1)
ENDIF

@COM604_PROCESS_INPUT(EVENT_TYPE, EVENT_DATA, UI_MESSAGE)
#DIM EVENT_TYPE
#DIMS EVENT_DATA
#DIMS REF UI_MESSAGE
#DIM NUM_RES
#DIM P_ID
#DIM 所要時間
#DIM 時間補正
#DIM 時間停止ジャンプ
#DIM 特殊ワープ

IF EVENT_TYPE == 0 && EVENT_DATA == "UPDATE"
	RETURN 3
ENDIF
IF EVENT_TYPE == 3 || EVENT_DATA == "MOUSE_R"
	RETURN -1
ENDIF
IF EVENT_DATA == "" || !ISNUMERIC(EVENT_DATA)
	RETURN 1
ENDIF

NUM_RES = TOINT(EVENT_DATA)
時間停止ジャンプ = FLAG:時間停止 || (GETBIT(FLAG:瞬間移動, AT_HOME(MASTER)) && !FLAG:デート相手)
特殊ワープ = ODEKAKEMAP_SETTING(CFLAG:MASTER:現在位置, "特殊ワープ")

IF NUM_RES == 100 || NUM_RES == 0
	RETURN -1
ELSEIF NUM_RES == 99
	DRAWLINE
	CALL OTHERREGIONS("散步")
	IF RESULT == 100
		RETURN 2 ; 重绘
	ELSE
		RETURN 0 ; 移动成功
	ENDIF
ELSEIF 特殊ワープ && NUM_RES == 特殊ワープ
	IF FLAG:時間停止 && BASE:MASTER:TSP < 30
		UI_MESSAGE = TSP不足
		RETURN 2
	ENDIF
	IF 時間停止ジャンプ
		BASE:MASTER:TSP -= 30
	ELSE
		TIME += 10
	ENDIF
	PRINTFORML %CALLNAME:MASTER%踏入了空间的扭曲后
	PRINTFORMW 不知不觉间便到达了%NAME_FROM_PLACE(特殊ワープ)%…
	P_ID = 特殊ワープ
	CFLAG:MASTER:現在位置 = P_ID
	CFLAG:MASTER:约会中 = GET_MAPID(P_ID)
	IF FLAG:约会的对象
		CFLAG:(FLAG:约会的对象):現在位置 = P_ID
		CFLAG:(FLAG:约会的对象):约会中 = GET_MAPID(P_ID)
		IF MOREDATE
			FOR LOCAL, 0, NumberOfDates
				CFLAG:(Datees:LOCAL):現在位置 = P_ID
				CFLAG:(Datees:LOCAL):デート中 = GET_MAPID(P_ID)
			NEXT
		ENDIF
	ENDIF
	RETURN 0
ELSEIF INRANGE(NUM_RES, 1, 9)
	P_ID = CFLAG:MASTER:约会中 * 100 + NUM_RES * 10
	SIF NAME_FROM_PLACE(P_ID) == ""
		RETURN 1
	CALL SANSAKU_UNIQUEPLACE(P_ID)
	IF RESULT
		P_ID = RESULT
		; 重新计算时间
		時間補正 = 0
		SIF IS_TSUKIAU([[小町]])
			時間補正 += -50
		SIF IS_TSUKIAU([[若鷺姫]]) && !GETBIT (FLAG:泳池, 0)
			時間補正 += 100
		SIF SHORTCUT(CFLAG:MASTER:约会中, -1)
			時間補正 += -50
		所要時間 = 散步所要時間(CFLAG:MASTER:現在位置, P_ID, 時間補正)

		IF FLAG:约会的对象
			CFLAG:(FLAG:约会的对象):現在位置 = P_ID
			TIME += 所要時間
		ELSEIF FLAG:時間停止 && BASE:MASTER:TSP < 所要時間
			UI_MESSAGE = TSP不足
			RETURN 2
		ELSEIF 時間停止ジャンプ
			BASE:MASTER:TSP -= 所要時間
		ELSE
			TIME += 所要時間
		ENDIF
		CFLAG:MASTER:現在位置 = P_ID
		RETURN 0
	ENDIF
ENDIF
RETURN 1

@QOL_SET_MAINHOME
#LOCALSIZE 4
#LOCALSSIZE 1
#DIM DYNAMIC INPUT_LOOP_LINE
#DIM DYNAMIC ANIMATION_SEED
#DIM DYNAMIC UPDATE_INTERVAL
#DIMS DYNAMIC LISTEN_CONF
#DIMS DYNAMIC UI_MESSAGE
#DIM  DYNAMIC AWAIT_HANG
#DIM DYNAMIC PREV_AWAIT_HANG

#DIM 設定前MAIN_MAP
#DIM 設定前酒虫
#DIM 設定前初期位置
#DIM 設定前大家

ANIMATION_SEED = 0

[IF DEBUG]
	IF ANIMATERECOLOREDMAPS
		ANIMATION_SEED = (GETMILLISECOND() / ANIMATERECOLOREDMAPS) % 20
	ENDIF
[ENDIF]

IF !引っ越し
	IF ゲーム開始処理中 || ゲーム继承処理中
		MAIN_MAP = 0
		TFLAG:地圖切換 = 0
		TRYCALLFORM ROOMSETTING_{MAIN_MAP}
	ENDIF
	設定前MAIN_MAP = MAIN_MAP
	設定前酒虫 = 拠点_酒虫
	設定前初期位置 = 默认初期位置
	設定前大家 = 拠点_家主
	引っ越し = 1
	SIF GMF_GETBIT("幻想乡大地图")
		GMF_MAP_MODE = 0
ENDIF

IF !GMF_临时更新地图
	IF FLAG:一時滞在
		PRINTFORMW 因为有来这里过夜的角色、所以无法搬家
		RETURN
	ENDIF
ENDIF

AWAIT_HANG = (ANIMATERECOLOREDMAPS > 0 && !FLAG:70)
LISTEN_CONF = %UI_AWAIT_CONFIG("DEFAULT", "", 0, 0, 0)%

LINESTART = LINECOUNT
$MAP_LOOP
CLEARLINE LINECOUNT - LINESTART
CALL SET_MAINHOME_DRAW_UI(ANIMATION_SEED, UI_MESSAGE)

UI_MESSAGE = 
INPUT_LOOP_LINE = LINECOUNT

$INPUT_LOOP
CLEARLINE LINECOUNT - INPUT_LOOP_LINE
PREV_AWAIT_HANG = AWAIT_HANG

IF AWAIT_HANG || (ANIMATERECOLOREDMAPS > 0 && !FLAG:70)
; 检查鼠标是否悬停在有效按钮上 (MOUSEB()返回当前悬停按钮的value)
	AWAIT_HOVER_VALUE '= MOUSEB()
	IF AWAIT_HOVER_VALUE != "" || MAP_ANIMATION_PAUSE
; 如果鼠标在按钮上，暂停动画
		AWAIT_HANG = 0
		UPDATE_INTERVAL = 0
	ELSE
; 否则恢复动画
		AWAIT_HANG = 1
		UPDATE_INTERVAL = ANIMATERECOLOREDMAPS
	ENDIF
ELSE
	AWAIT_HANG = 0
	UPDATE_INTERVAL = 0
ENDIF

IF AWAIT_HANG
	CALL AWAIT_UI_INPUT(LISTEN_CONF, UPDATE_INTERVAL)
ELSE
	IF PREV_AWAIT_HANG
		;REDRAW 2
		GOTO MAP_LOOP
	ENDIF
	IF ANIMATERECOLOREDMAPS > 0 && !FLAG:70
		TINPUTS 1500, "UPDATE", 0, "", 1
	ELSE
		INPUTS "UPDATE", 1
	ENDIF
	SIF RESULTS == "UPDATE"
		RESULT = 0
ENDIF

CALL SET_MAINHOME_PROCESS_INPUT(RESULT, RESULTS, 設定前MAIN_MAP, 設定前酒虫, 設定前初期位置, 設定前大家, ANIMATION_SEED, UI_MESSAGE)
SELECTCASE RESULT
	CASE -1
		RETURN ; 中止
	CASE 0
		GOTO POST_MOVE ; 决定
	CASE 1
		GOTO INPUT_LOOP
	CASE 2
		GOTO MAP_LOOP
	CASE 3
		ANIMATION_SEED = RESULT:1 ; 更新后的SEED
		GOTO MAP_LOOP
ENDSELECT

$POST_MOVE
SIF !GMF_临时更新地图
	FLAG:神簽契約 = 0
TFLAG:地圖切換 = 0
CALL SET_ENKAI_LOCATIONDISPLAY
CALL MAP_DEFAULTRESIDENT(MAIN_MAP)
VARSET LOCK

FOR LOCAL,1,CHARANUM
	CALL CHARA_SLEEP, LOCAL, 0
NEXT

LOCAL:2 = 0 ; CHK_TRAINING
LOCAL:3 = 0 ; CHK_GARDENING
FOR LOCAL,1,100
	SIF ROOMDATA:LOCAL & 場所_訓練
		LOCAL:2 = 1
	SIF ROOMDATA:LOCAL & 場所_菜園
		LOCAL:3 = 1
NEXT
SIF !LOCAL:2
	CALL COLORMESSAGE(@"这个地图无法进行[战斗训练]",C_YELLOW,2)
SIF !LOCAL:3
	CALL COLORMESSAGE(@"这个地图无法进行[家庭菜园]",C_YELLOW,2)
SIF !SUMIKOMI_ROOM
	CALL COLORMESSAGE(@"这个地图不会发生角色搬入事件。",C_YELLOW,2)
SIF FLAG:扮演 && CFLAG:(FLAG:扮演):出禁 && MAIN_MAP == GET_MAPID(CSVCFLAG(FLAG:扮演,311)) && CSVCFLAG(FLAG:扮演,311) != SUKIMA()
	CFLAG:MASTER:初期位置 = CSVCFLAG(FLAG:扮演,311)

CALL TRAP_MOVING
RETURN

