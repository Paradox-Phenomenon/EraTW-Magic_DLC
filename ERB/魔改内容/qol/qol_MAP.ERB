;-------------------------------------------------
; 函数名: QOL_HITOSAGASI
; 概要:   显示寻人界面，让玩家选择一个房间/地点，返回选择的房间编号
; 参数:
;   DEF_ROOM   - 默认选中的房间编号（可选，0表示无默认）
;   SHOW_OTHER_AREA - 是否显示「查看其他区域」按钮（0=否，1=是）
; 返回值:
;   ≥ MINROOM() 的房间编号   → 玩家选择了该房间
;   -1                        → 玩家按了返回/取消
;-------------------------------------------------
@QOL_HITOSAGASI(DEF_ROOM = 0, SHOW_OTHER_AREA = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC DEF_ROOM
#DIM DYNAMIC SHOW_OTHER_AREA
#DIM DYNAMIC MAP_LOOP_LINE
#DIM DYNAMIC INPUT_LOOP_LINE

; 幻想乡大地图的特殊跳转处理
IF GMF_GETBIT("幻想乡大地图") && GMF_METHOD_STACK != "QOL_HITOSAGASI"
	JUMP GMF_MAP_METHOD(-1, 2, "QOL_HITOSAGASI", DEF_ROOM, SHOW_OTHER_AREA)
ENDIF

MAP_LOOP_LINE = LINECOUNT
DO
	CLEARLINE LINECOUNT - MAP_LOOP_LINE
	CALL HITOSAGASI_2(1)
	CALL HITOSAGASI_2(2)
	PRINTBUTTON "[返回]", 0
	IF SHOW_OTHER_AREA == 1
		PRINTL
		PRINTBUTTON "[查看其他区域]", -1
		PRINTL
	ENDIF

INPUT_LOOP_LINE = LINECOUNT
	DO
		CLEARLINE LINECOUNT - INPUT_LOOP_LINE
		INPUTS
		IF RESULTS == "0" || RESULTS == "ESC" || RESULTS == "MOUSE_R"
			RETURN -1
		ELSEIF RESULTS == "-1" && SHOW_OTHER_AREA == 1
			CALL BROAD_HITOSAGASI
			BREAK
		ENDIF
		IF ISNUMERIC(RESULTS)
			RESULT = TOINT(RESULTS)
			IF RESULT >= MINROOM() && RESULT <= MAXROOM
				RETURN RESULT
			ENDIF
		ENDIF
		CONTINUE
		
	LOOP 1
	
LOOP 1

;-------------------------------------------------
;函数名:@AWAIT_UI_INPUT
;概　要:非阻塞式UI事件监听引擎
;参　数:CONFIG_STR  = 监听配置字符串 (如 "MOUSE_L|KEY_ENTER|HOTKEYS:Z,X,C")
;      :UPDATE_TIME = (可选) 动画Tick的超时时间(毫秒)，0表示无限等待
;返回值:RESULT   = 事件大类分类码
;         0 : Update Tick (超时更新)
;         1 : 常规输入 (左键按钮、文本框Enter、指定快捷键)
;         2 : 特殊鼠标 (右键、中键)
;         3 : 系统按键 (ESC)
;      :RESULTS  = 具体触发的值（如按钮的Value，文本框内容，或者 "MOUSE_R", "ESC"）
;      :RESULT:1 = 修饰键状态位掩码 (0=无, 1=Shift, 2=Ctrl, 4=Alt, 及其组合)
;备　注:全面接管鼠标左右中键、按键、组合键及文本框。使用 AWAIT 挂起释放 CPU。
;-------------------------------------------------
@AWAIT_UI_INPUT(CONFIG_STR = "DEFAULT", UPDATE_TIME = 0, AWAIT_TIME = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS CONFIG_STR
#DIM  UPDATE_TIME
#DIM  AWAIT_TIME
#DIM  START_TIME
#DIMS TEMP_STR
#DIM  MODIFIER_KEY

#DIM  DYNAMIC LISTEN_MOUSE_L
#DIM  DYNAMIC LISTEN_MOUSE_R
#DIM  DYNAMIC LISTEN_MOUSE_M
#DIM  DYNAMIC LISTEN_ENTER
#DIM  DYNAMIC LISTEN_ESC
#DIMS DYNAMIC HOTKEY_STRS, 50
#DIM  DYNAMIC HOTKEY_CODES, 50
#DIM  DYNAMIC HOTKEY_COUNT
#DIMS DYNAMIC CONF_ARR, 20
#DIM  DYNAMIC CONF_NUM
#DIMS DYNAMIC HOT_ARR, 50
#DIM  DYNAMIC HOT_NUM
#DIM  DYNAMIC L_COUNT

SIF AWAIT_TIME == -1
	AWAIT_TIME = 16
IF CONFIG_STR == "DEFAULT"
	CONFIG_STR = "MOUSE_L|KEY_ENTER"
ELSEIF CONFIG_STR == "MAP_MODE"
	CONFIG_STR = "MOUSE_L|KEY_ENTER|KEY_ESC|HOTKEYS:Z,X,C,Y"
ENDIF

SPLIT CONFIG_STR, "|", CONF_ARR, CONF_NUM
FOR L_COUNT, 0, CONF_NUM
	SELECTCASE CONF_ARR:L_COUNT
		CASE "MOUSE_L"
			LISTEN_MOUSE_L = 1
		CASE "MOUSE_R"
			LISTEN_MOUSE_R = 1
		CASE "MOUSE_M"
			LISTEN_MOUSE_M = 1
		CASE "KEY_ENTER"
			LISTEN_ENTER = 1
		CASE "KEY_ESC"
			LISTEN_ESC = 1
		CASEELSE
			IF STRFIND(CONF_ARR:L_COUNT, "HOTKEYS:") == 0
				TEMP_STR = %SUBSTRING(CONF_ARR:L_COUNT, 8)%
				SPLIT TEMP_STR, ",", HOT_ARR
				HOT_NUM = RESULT
				FOR LOCAL, 0, HOT_NUM
					HOTKEY_STRS:HOTKEY_COUNT = %HOT_ARR:LOCAL%
					HOTKEY_CODES:HOTKEY_COUNT = ENCODETOUNI(HOT_ARR:LOCAL)
					HOTKEY_COUNT ++
				NEXT
			ENDIF
	ENDSELECT
NEXT

START_TIME = GETMILLISECOND()
DO
	AWAIT AWAIT_TIME
	
	; [新增] 悬停侦测，如果鼠标悬停状态发生改变，立即触发UPDATE
	IF MOUSEB() != AWAIT_HOVER_VALUE
		AWAIT_HOVER_VALUE '= MOUSEB()
		RESULTS '= "UPDATE"
		RESULT:1 = 0
		RETURN 0
	ENDIF

	MODIFIER_KEY = 0
	SIF GETKEY(16)
		SETBIT MODIFIER_KEY, 0
	SIF GETKEY(17)
		SETBIT MODIFIER_KEY, 1
	SIF GETKEY(18)
		SETBIT MODIFIER_KEY, 2

	; 【鼠标左键】
	IF LISTEN_MOUSE_L && GETKEYTRIGGERED(1)
		TEMP_STR '= MOUSEB()
		IF TEMP_STR != ""
			DEBUGPRINTFORML [AWAIT_UI] 左键点击! 目标:%TEMP_STR%
			RESULTS '= TEMP_STR
			RESULT:1 = MODIFIER_KEY
			RETURN 1
		ENDIF
	ENDIF
	
	; 【鼠标右键】
	IF LISTEN_MOUSE_R && GETKEYTRIGGERED(2)
		DEBUGPRINTFORML [AWAIT_UI] 右键点击!
		RESULTS '= "MOUSE_R"
		RESULT:1 = MODIFIER_KEY
		RETURN 2
	ENDIF
	
	; 【鼠标中键】
	IF LISTEN_MOUSE_M && GETKEYTRIGGERED(4)
		RESULTS '= "MOUSE_M"
		RESULT:1 = MODIFIER_KEY
		RETURN 2
	ENDIF

	; 【回车键】
	IF LISTEN_ENTER && GETKEYTRIGGERED(13)
		TEMP_STR = %GETTEXTBOX()%
		IF TEMP_STR != ""
			DEBUGPRINTFORML [AWAIT_UI] 回车输入! 内容:%TEMP_STR%
			RESULTS '= TEMP_STR
			RESULT:1 = MODIFIER_KEY
			RETURN 1
		ENDIF
	ENDIF

	; 【ESC键】
	IF LISTEN_ESC && GETKEYTRIGGERED(27)
		DEBUGPRINTFORML [AWAIT_UI] ESC 按下!
		RESULTS '= "ESC"
		RESULT:1 = MODIFIER_KEY
		RETURN 3
	ENDIF

	; 【自定义快捷键】
	IF HOTKEY_COUNT > 0
		FOR L_COUNT, 0, HOTKEY_COUNT
			IF GETKEYTRIGGERED(HOTKEY_CODES:L_COUNT)
				DEBUGPRINTFORML [AWAIT_UI] 快捷键按下! 键:%HOTKEY_STRS:L_COUNT%
				RESULTS '= HOTKEY_STRS:L_COUNT
				RESULT:1 = MODIFIER_KEY
				RETURN 1
			ENDIF
		NEXT
	ENDIF

	; 【Tick 更新计时器】
	IF UPDATE_TIME > 0 && (GETMILLISECOND() - START_TIME) >= UPDATE_TIME
		RESULTS '= "UPDATE"
		RESULT:1 = 0
		RETURN 0
	ENDIF
LOOP 1

;-------------------------------------------------
;函数名:@UI_AWAIT_CONFIG
;概　要:构建 AWAIT_UI_INPUT 的配置字符串
;参　数:BASE_MODE = 基础模式 ("DEFAULT", "MAP_MODE", "ALL_MOUSE" 等)
;      :ADD_KEYS  = 追加的快捷键，逗号分隔 (如 "A,B,C")
;      :USE_R_BTN = 是否启用右键 (1=启用)
;      :USE_M_BTN = 是否启用中键 (1=启用)
;      :USE_ESC   = 是否启用ESC键 (1=启用)
;返回值:组装好的配置字符串
;备　注:利用此函数可以屏蔽底层字符串拼写，保持业务端代码整洁
;-------------------------------------------------
@UI_AWAIT_CONFIG(BASE_MODE = "DEFAULT", ADD_KEYS = "", USE_R_BTN = 0, USE_M_BTN = 0, USE_ESC = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS BASE_MODE
#DIMS ADD_KEYS
#DIM  USE_R_BTN
#DIM  USE_M_BTN
#DIM  USE_ESC
#DIMS DYNAMIC FINAL_CONF

SELECTCASE BASE_MODE
	CASE "DEFAULT"
		FINAL_CONF = MOUSE_L|KEY_ENTER
	CASE "MAP_MODE"
		FINAL_CONF = MOUSE_L|KEY_ENTER|KEY_ESC|HOTKEYS:Z,X,C,Y
	CASE "ALL_MOUSE"
		FINAL_CONF = MOUSE_L|MOUSE_R|MOUSE_M|KEY_ENTER
	CASEELSE
		FINAL_CONF = MOUSE_L|KEY_ENTER ; 容错默认值
ENDSELECT

SIF USE_R_BTN && STRFIND(FINAL_CONF, "MOUSE_R") < 0
	FINAL_CONF += "|MOUSE_R"
SIF USE_M_BTN && STRFIND(FINAL_CONF, "MOUSE_M") < 0
	FINAL_CONF += "|MOUSE_M"
SIF USE_ESC && STRFIND(FINAL_CONF, "KEY_ESC") < 0
	FINAL_CONF += "|KEY_ESC"

IF ADD_KEYS != ""
	IF STRFIND(FINAL_CONF, "HOTKEYS:") >= 0
		; 如果已经有 HOTKEYS 标签，直接追加
		FINAL_CONF += "," + ADD_KEYS
	ELSE
		; 否则新建标签
		FINAL_CONF += "|HOTKEYS:" + ADD_KEYS
	ENDIF
ENDIF

RETURNF FINAL_CONF

;-------------------------------------------------
;函数名:@UI_EXECUTE_MOVE
;概　要:处理从菜单、对话框等UI界面发起的瞬时移动请求
;参　数:TARGET_ROOM = 目标房间ID
;返回值:1=移动成功，0=移动失败
;-------------------------------------------------
@UI_EXECUTE_MOVE(TARGET_ROOM)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM TARGET_ROOM

; 已经在目的地
SIF TARGET_ROOM == CFLAG:MASTER:現在位置
	RETURN 0
; 间隙内直接移动
IF IS_GAP_GUEST(MASTER)
	CALL SKIP_MOVE(CFLAG:MASTER:現在位置, TARGET_ROOM)
	RETURN 1
ENDIF
; 不在主地图
IF !AT_HOME(MASTER) || IN_HOME(TARGET_ROOM) != 1
	TFLAG:マップ切り替え = 0
	PRINTW 没法移动过去
	RETURN 0
ENDIF
; 移动限制检查
IF MAP_CAN_MOVE(TARGET_ROOM) == 0
	IF TFLAG:移動不能メッセージ == 999
		IF LOCKPICK_SYSTEM > 0
			; 调用开锁系统
			CALL LOCKPICK_INFO(TARGET_ROOM)
			RETURN RESULT
		ELSE
			PRINTFORMW 锁上了 可恶
		ENDIF
	ELSE
		; 打印原本的不可移动文本
		TRYCALLFORM MAP_CANNOT_WORD_{MAIN_MAP}(TARGET_ROOM)
	ENDIF
	TFLAG:移動不能メッセージ = 0
	RETURN 0
ENDIF
; 正常移动
CALL SKIP_MOVE(CFLAG:MASTER:現在位置, TARGET_ROOM)
RETURN 1
