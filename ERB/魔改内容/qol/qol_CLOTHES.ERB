@QOL_今天穿的内裤(ARG)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
;预设为三角胖次
#DIM TODAYS_PANTS = 19
#DIM RAND_PANTS, MAXPANTS
#DIM P_TABLE
CALLF FUNC_FISHER_YATES_SHAFFLE(RAND_PANTS, MAXPANTS)
FOR P_TABLE, 0, MAXPANTS
	IF GETMETH_INT(ARG, "下半身内衣_ずらし可能", RAND_PANTS:P_TABLE, "能穿")
		TODAYS_PANTS = RAND_PANTS:P_TABLE
		BREAK
	ELSE
		CONTINUE
	ENDIF
NEXT
RETURNF TODAYS_PANTS

@可用内裤判定(TYPE, ARG,POTENTIAL = 0)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS TYPE
#DIM DYNAMIC POTENTIAL
SELECTCASE TYPE
	CASE "不穿"
		SIF POTENTIAL
			RETURNF 0
		RETURNF (TALENT:ARG:風騷 || TALENT:ARG:小悪魔 || TALENT:ARG:炮友 || ABL:ARG:露出癖 >= 8) && !RAND:5
	CASE "幼稚"
		IF TALENT:ARG:小悪魔 || TALENT:ARG:炮友
			RETURNF 0
		ELSEIF TALENT:ARG:幼稚 || TALENT:ARG:幼児／幼児退行 || TALENT:ARG:体型 < 0 || TALENT:ARG:無知
			RETURNF 1
		ENDIF
	CASE "清纯"
		IF TALENT:ARG:小悪魔 || TALENT:ARG:炮友
			RETURNF 0
		ELSEIF POTENTIAL || !RAND:(1 + (2 * 勝負内衣判定(ARG)))
			RETURNF 1
		ENDIF
	CASE "决胜"
		IF POTENTIAL || !RAND:(2 - (TALENT:ARG:恋慕 > 0))
			RETURNF 1
		ENDIF
	CASE "决胜追加"
		SIF !FLAG:セクシー胖次追加
			RETURNF 0
		IF POTENTIAL || !RAND:(2 - (TALENT:ARG:恋慕 > 0))
			RETURNF 1
		ENDIF
	CASE "通常"
		RETURNF POTENTIAL || !RAND:(1 + (2 * 勝負内衣判定(ARG)))
	CASE "格调"
		IF TALENT:ARG:小悪魔 || TALENT:ARG:恋慕
			;如果是幼稚系，则必须通过额外检定
		ELSEIF TALENT:ARG:幼稚 || TALENT:ARG:幼児／幼児退行 || TALENT:ARG:体型 < 0 || TALENT:ARG:無知
			;如果不是幼稚系，则直接通过
			RETURNF 0
		ENDIF

		IF POTENTIAL || !RAND:(3 - (TALENT:ARG:恋慕 > 0) - 勝負内衣判定(ARG))
			RETURNF 1
		ENDIF
	CASE "性感"
		IF TALENT:ARG:風騷 || TALENT:ARG:小悪魔 || (TALENT:ARG:恋慕 > 0)
		ELSE
			RETURNF 0
		ENDIF
		IF POTENTIAL || !RAND:(3 - (TALENT:ARG:恋慕 > 0) - 勝負内衣判定(ARG))
			RETURNF 1
		ENDIF
	CASE "性感追加"
		SIF !FLAG:セクシー胖次追加
			RETURNF 0
		IF TALENT:ARG:風騷 || TALENT:ARG:小悪魔 || (TALENT:ARG:恋慕 > 0)
		ELSE
			RETURNF 0
		ENDIF
		IF POTENTIAL || !RAND:(3 - (TALENT:ARG:恋慕 > 0) - 勝負内衣判定(ARG))
			RETURNF 1
		ENDIF
	CASE "SM"
		IF (TALENT:ARG:風騷 || TALENT:ARG:小悪魔 || (TALENT:ARG:恋慕 > 0) || TALENT:ARG:炮友) && ABL:ARG:施虐属性 > 4
		ELSEIF (TALENT:ARG:風騷 || TALENT:ARG:小悪魔 || (TALENT:ARG:恋慕 > 0) || TALENT:ARG:炮友)
			RETURNF 0
		ELSE
			RETURNF 0
		ENDIF
		IF POTENTIAL || !RAND:3
			RETURNF 1
		ENDIF
	CASE "暴露"
		SIF !FLAG:セクシー胖次追加
			RETURNF 0
		SIF ABL:ARG:露出癖 < 4
			RETURNF 0
		IF TALENT:ARG:風騷 || TALENT:ARG:小悪魔 || TALENT:ARG:恋慕 > 0
			;如果是幼稚系，则必须通过额外检定
		ELSEIF TALENT:ARG:幼稚 || TALENT:ARG:幼児／幼児退行 || TALENT:ARG:体型 < 0 || TALENT:ARG:無知
			;如果不是幼稚系，则直接通过
			RETURNF 0
		ENDIF

		IF POTENTIAL || !RAND:(3 - (TALENT:ARG:恋慕 > 0) - 勝負内衣判定(ARG))
			RETURNF 1
		ENDIF
	CASE "独有"
		IF POTENTIAL || UNIQUE_UNDERWARE_ABLE(ARG)
			RETURNF 1
		ENDIF
	CASE "兜裆布"
		SIF !FLAG:セクシー胖次追加
			RETURNF 0
		IF POTENTIAL || !RAND:(3 + 勝負内衣判定(ARG))
			RETURNF 1
		ENDIF
	CASE "创口贴"
		SIF !FLAG:セクシー胖次追加
			RETURNF 0
		SIF ABL:ARG:露出癖 < 4
			RETURNF 0
		IF TALENT:ARG:幼稚 || TALENT:ARG:幼児／幼児退行 || TALENT:ARG:体型 < 0 || TALENT:ARG:無知
		ELSE
			RETURNF 0
		ENDIF

		IF POTENTIAL || !RAND:3
			RETURNF 1
		ENDIF
	CASE "可开"
		SIF !FLAG:セクシー胖次追加
			RETURNF 0
		IF TALENT:ARG:炮友 && ABL:ARG:露出癖 >= 5 || TALENT:ARG:無知
		ELSE
			RETURNF 0
		ENDIF

		IF POTENTIAL || !RAND:4
			RETURNF 1
		ENDIF
	CASE "基础"
		RETURNF 1

ENDSELECT
