;理论受孕概率
@INFO_理论受孕概率(C_ID = -1,ARG = -1)
#LOCALSIZE 6
#LOCALSSIZE 1
#DIM C_ID
SIF C_ID == -1
	C_ID = TARGET
SIF ARG == -1
	ARG = MASTER
IF HAS_VAGINA(C_ID) && (EX:C_ID:膣内精液 || CFLAG:C_ID:(ARG + 2000))
	LOCAL = 验算用宫内精液量(C_ID,ARG)
	LOCAL:1 = 充填率(C_ID,6,,LOCAL)
	IF LOCAL:1 >= 100
		SETCOLOR C_PINK
	ELSEIF LOCAL:1 > 20
		SETCOLOR C_YELLOW
	ENDIF
	LOCAL:3 = 理论受孕概率(C_ID,ARG,LOCAL)
	IF (TALENT:C_ID:幼稚 && !TALENT:C_ID:初潮) || QOL_IS_IN_RECOVERY(C_ID) || CFLAG:C_ID:WithChildCount >= MAXCHILD
		SETCOLOR C_GRAY
		PRINTFORM ※受孕:不可
	ELSEIF (GETBIT(BABYDLC,1) && LOCAL:1 && REAL_ESTRUS_CYCLE(C_ID) > 40)
		CALL PRINT_RAINBOW2,"※受孕:一发入魂"
	ELSE
		LOCAL:4 = LOCAL:3 / 100
		LOCAL:5 = LOCAL:3 % 100
		PRINTFORM 理论受孕概率:{LOCAL:4}.\@ LOCAL:5<10 ? 0 # \@{LOCAL:5}％
	ENDIF
	RESETCOLOR
	PRINT  
ENDIF

;返回理论受孕概率的万分数
@理论受孕概率(C_ID = -1, ARG = -1, 验算用宫内精液量 = -1)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM C_ID
#DIM 验算用宫内精液量
SIF C_ID == -1
	C_ID = TARGET
SIF ARG == -1
	ARG = MASTER
SIF 验算用宫内精液量 == -1
	验算用宫内精液量 = 验算用宫内精液量(C_ID,ARG)

SIF (!TALENT:C_ID:初潮 && (TALENT:C_ID:幼稚 || TALENT:C_ID:幼児／幼児退行)) || Qol_IS_IN_RECOVERY(C_ID)
	验算用宫内精液量 = 0
RETURNF 100 * 充填率(C_ID,6,,验算用宫内精液量) * REAL_ESTRUS_CYCLE(C_ID) / 妊娠必要值(C_ID,ARG)

@验算用宫内精液量(C_ID = -1,ARG = -1)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM C_ID
SIF C_ID == -1
	C_ID = TARGET
SIF ARG == -1
	ARG = MASTER
LOCAL = CFLAG:C_ID:(ARG + 2000)
LOCAL += CFLAG:C_ID:(ARG + 3000) / 中毒補正(C_ID)
SIF LOCAL > CFLAG:C_ID:(ARG + 3000)
	LOCAL = CFLAG:C_ID:(ARG + 3000)
RETURNF LOCAL