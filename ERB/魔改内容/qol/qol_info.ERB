@PRINT_TOUCH_INFO
CALL INFO_CHARA_TOUCH(MASTER)
SIF TARGET > 0
	CALL INFO_CHARA_TOUCH(TARGET)
SIF ASSI > 0
	CALL INFO_CHARA_TOUCH(ASSI)
WAIT

@INFO_CHARA_TOUCH(C_ID)
#DIM        C_ID
#DIM        BODY_PARTS
;#DIMS CONST PARTS_NAME = "阴茎", "阴蒂", "指", "口", "胸", "膣", "肛門", "足"
;#DIMS CONST POSITION_NAME = "正常位", "后背位", "骑乘位" , "对面位", "背面位", "小人飞机杯"
PRINTFORML %CALLNAME:C_ID%的接触：
FOR BODY_PARTS, 1, 9
	SIF ADD_SEX_MODULE_PARTNAME(BODY_PARTS) == "阴茎" && !GETBIT(TALENT:C_ID:性別, 1)
		CONTINUE
	PRINTFORM %ADD_SEX_MODULE_PARTNAME(BODY_PARTS), 4, LEFT%　－　
	IF TEQUIP:C_ID:(100 + BODY_PARTS) == 0
		PRINTFORM 无
	ELSE 
		PRINTFORM %ADD_SEX_MODULE_PARTNAME(TEQUIP:C_ID:(100 + BODY_PARTS)), 4, LEFT%
	ENDIF
	PRINTL
NEXT
IF CFLAG:C_ID:诶嘿嘿 > 0
	PRINTFORM %CALLNAME:C_ID%的体位：
	IF TEQUIP:C_ID:体位 > 0
		PRINTFORM %ADD_SEX_MODULE_POSE(TEQUIP:C_ID:体位)%
	ELSE
		PRINTFORM 无
	ENDIF
	PRINTL
ENDIF

