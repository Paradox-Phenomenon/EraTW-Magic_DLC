;参数：可选立绘编号
@SPIRIT_特效索引_43(ARG,特效)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS REF 特效
#DIM DYNAMIC 特效数
SELECTCASE ARG
	CASE 1
		特效:特效数 = 运动服湿
		特效数++
	CASEELSE
ENDSELECT
RETURN 特效数

@SRPITE_运动服湿_43
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
SIF CURRENT_CLOTHES_SET(43) != [[日式学校运动服]]
	RETURNF 0
SIF 湿身度:43 > 30
	RETURNF 1

