@STR_TR(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC TR_RESULT
#DIMS DYNAMIC SAFE_NAME

SIF STR:ARG == ""
RETURNF ""
SELECTCASE ARG
	CASE 0
		RETURNF STR:ARG
	CASEELSE
		SAFE_NAME '= REPLACE(STR:ARG, "'", "''")
TR_RESULT '= SQL_EXECUTE_SCALAR_STRING("TR_DB", @"SELECT v FROM CSV_MAP WHERE k = '%SAFE_NAME%';")
		SIF TR_RESULT != ""
			RETURNF TR_RESULT
		;#;PRINTFORML ※未能找到STR:%STR:ARG%翻译，请保存日志报错
		RETURNF STR:ARG
ENDSELECT

