@GIFT_ADJECTIVE_TR(ARGS)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC TR_RESULT
#DIMS DYNAMIC SAFE_NAME

SIF ARGS == ""
RETURNF
SAFE_NAME '= REPLACE(ARGS, "'", "''")
TR_RESULT '= SQL_EXECUTE_SCALAR_STRING("TR_DB", @"SELECT v FROM TASTE_MAP WHERE k = '%SAFE_NAME%';")
IF TR_RESULT != ""
	LOCALS '= TR_RESULT
ELSE
	LOCALS '= ARGS
	;#;PRINTFORML ※未能找到%ARGS%翻译，请保存日志报错
ENDIF
RETURNF STRLENS(LOCALS) == 4 ? REPLACE(LOCALS, "的", "之") # LOCALS


@GIFT_NOUN_TR(ARGS)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC TR_RESULT
#DIMS DYNAMIC SAFE_NAME

SIF ARGS == ""
RETURNF
SAFE_NAME '= REPLACE(ARGS, "'", "''")
TR_RESULT '= SQL_EXECUTE_SCALAR_STRING("TR_DB", @"SELECT v FROM TASTE_MAP WHERE k = '%SAFE_NAME%';")
SIF TR_RESULT != ""
	RETURNF TR_RESULT
	;#;PRINTFORML ※未能找到%ARGS%翻译，请保存日志报错
RETURNF ARGS


@GIFTSHOP_NAME_TR(ARGS)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
SELECTCASE ARGS
	CASE "香霖堂"
		RETURNF "香霖堂"
	CASE "土産屋"
		RETURNF "土特产店"
	CASEELSE 
		RETURNF ARGS
ENDSELECT

@CREATE_GIFT_NAME_TR(strMain, strAdj)
#FUNCTIONS
#DIMS DYNAMIC strMain
#DIMS DYNAMIC strAdj
#LOCALSIZE 1
#LOCALSSIZE 1
RETURNF GIFT_ADJECTIVE_TR(strAdj) + GIFT_NOUN_TR(strMain)