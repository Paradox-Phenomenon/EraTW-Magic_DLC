@DISHNAME_TR(ARGS)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC TR_RESULT
#DIMS DYNAMIC SAFE_NAME

SIF ARGS == ""
	ARGS '= DISH_NAME
SAFE_NAME '= REPLACE(ARGS, "'", "''")
TR_RESULT '= SQL_EXECUTE_SCALAR_STRING("TR_DB", @"SELECT v FROM TASTE_MAP WHERE k = '%SAFE_NAME%';")
SIF TR_RESULT != ""
	RETURNF TR_RESULT
SIF DISH_COMMENT != "※正在招募中！！※"
	PRINTFORML ※未能找到DISHNAME翻译，请保存日志报错
RETURNF DISH_NAME

@TASTE_TR(ARGS,ARG = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC TR_RESULT
#DIMS DYNAMIC SAFE_NAME

SAFE_NAME '= REPLACE(ARGS, "'", "''")
TR_RESULT '= SQL_EXECUTE_SCALAR_STRING("TR_DB", @"SELECT v FROM TASTE_MAP WHERE k = '%SAFE_NAME%';")
SIF TR_RESULT != ""
	RETURNF TR_RESULT
SAFE_NAME '= REPLACE(ARGS, "'", "''")
TR_RESULT '= SQL_EXECUTE_SCALAR_STRING("TR_DB", @"SELECT v FROM CSV_MAP WHERE k = '%SAFE_NAME%';")
SIF TR_RESULT != ""
	RETURNF TR_RESULT
IF !GROUPMATCH(ARGS, "", " ","　") && !ARG
	;#;PRINTFORML ※未能找到%ARGS%翻译，请保存日志报错
ENDIF
RETURNF ARGS
