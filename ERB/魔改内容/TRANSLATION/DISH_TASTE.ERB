@DISH_NAME_TR(ARGS)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
SIF ARGS == ""
	ARGS '= DISH_NAME
RETURNF DISHNAME_TR(ARGS)

@DISHNAME_TR(ARGS)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
SIF ARGS == ""
	ARGS '= DISH_NAME
SIF MAP_HAS(TASTE_MAP, ARGS)
	RETURNF MAP_GET(TASTE_MAP, ARGS)
SIF DISH_COMMENT != "※正在招募中！！※"
	PRINTL ※未能找到DISHNAME翻译，请保存日志报错
RETURNF DISH_NAME

