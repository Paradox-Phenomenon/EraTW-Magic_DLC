;-------------------------------------------------
;函数名：GET_REF_VARNAME
;概  述：合成变量名字符串
;          处理如 "CSTR:ONCE" 这样的输入，结合下标生成 "CSTR:1:ONCE"
;参 数：ARGS - 变量名定义字符串 (例: "CFLAG:属性" 或 "TALENT")
;       ARG  - CHARADATA的第一下标(角色ID)，为-1时则不插入下标
;返回值：合成后的变量名字符串
;-------------------------------------------------
@GET_REF_VARNAME(ARGS, ARG = -1)
#FUNCTIONS
#DIMS DYNAMIC VAR_COMPONENTS, 2
#DIMS DYNAMIC RESULT_STR

IF STRCOUNT(ARGS,":")
	CALLF SPLIT_F(ARGS, ":", VAR_COMPONENTS)
ELSE
	VAR_COMPONENTS '= ARGS
ENDIF

RESULT_STR = %VAR_COMPONENTS:0%%COND_STR(@":{ARG}",ARG != -1)%%COND_STR(@":%VAR_COMPONENTS:1%",VAR_COMPONENTS:1 != "")%
RETURNF RESULT_STR

