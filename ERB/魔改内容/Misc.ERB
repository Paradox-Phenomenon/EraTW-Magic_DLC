;-------------------------------------------------
;函数名:@RANDSF(ARG,ARG:1)
;概　要:带符号的随机偏移值生成
;参　数:ARG   = 随机幅度参数
;          ＞0 时，每次生成 0～ARG 的随机值并累加
;          ＜0 时，以 1/(1-ARG) 的概率累加 1
;       ARG:1 = 随机次数（权重）
;          绝对值表示随机执行次数
;          符号决定返回值的正负
;返回值:返回根据 ARG 与 ARG:1 生成的随机偏移值,可能为正数或负数
;-------------------------------------------------
@RANDSF(ARG,ARG:1)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM RESULT_SIGN
#FUNCTION
LOCAL = 0
RESULT_SIGN = 1
IF ARG:1 < 0
	ARG:1 = -ARG:1
	RESULT_SIGN *= -1
ENDIF
IF ARG > 0
	WHILE ARG:1 > 0
		ARG:1 --
		LOCAL += RAND:(1+ARG)
	WEND
ELSEIF ARG < 0
	WHILE ARG:1 > 0
		ARG:1 --
		SIF !RAND:(1-ARG)
			LOCAL += 1
	WEND
ENDIF
RETURNF LOCAL * RESULT_SIGN
