;-------------------------------------------------
;函数名:GROUPMATCH_CVAR
;概　要:角色变量的群组判断
;参  数:ARG = 匹配值,ARG:1 = 0匹配模式，1排除模式）,ARG:2 = 完全匹配）
;-------------------------------------------------
@GROUPMATCH_CVAR(LIST,CVAR,ARG = 0,ARG:1 = 0,ARG:2 = 0)
#LOCALSIZE 1
#DIM REF LIST
#DIM DYNAMIC TEMP
#DIM DYNAMIC TEMP_RESULT
#DIMS DYNAMIC VAR_INDEX,2
#DIMS CVAR
#FUNCTION

;在式中函数中调用会重写RESULT(S)的命令时需要暂存RESULT(S)
TEMP_RESULT = RESULT
SPLIT CVAR, ":", VAR_INDEX
RESULT = TEMP_RESULT

FOR LOCAL, 0, VARSIZE("LIST")
	IF ARG:1 == 1
		IF GETVAR(@"%VAR_INDEX:0%:{(LIST:LOCAL)}:%VAR_INDEX:1%") != ARG
			TEMP++
		ELSE
			SIF ARG:2
				RETURNF 0
		ENDIF
	ELSE
		IF GETVAR(@"%VAR_INDEX:0%:{(LIST:LOCAL)}:%VAR_INDEX:1%") == ARG
			TEMP++
		ELSE
			SIF ARG:2
				RETURNF 0
		ENDIF
	ENDIF
NEXT
RETURNF TEMP


;-------------------------------------------------
;函数名：SET_UPDATECHECK
;概  述：CHECK-and-SET这一类型函数的抽象
;参  数：ARGS - 需要检查的元素名
;        ARGS:1 - 需要检查的字符串名
;        ARG - 设定时，表明字符串变量是charadata，该参数作为其第一下标
;        ARG:1 - 设定为真时，表明需要向集合增加新的元素
;返回值：1 = 元素原先已存在, 0 = 元素原先不存在
;-------------------------------------------------
@SET_UPDATECHECK(ARGS, ARGS:1,ARG = -1, ARG:1)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC TEMP_VAR
#DIMS DYNAMIC TEMP_VARVALUE

TEMP_VAR '= GET_REF_VARNAME(ARGS:1, ARG)
TEMP_VARVALUE '= GETVARS(TEMP_VAR)
SIF TEMP_VARVALUE == ""
	TEMP_VARVALUE = /
;DEBUGPRINTFORML TEMP_VARVALUE = %TEMP_VARVALUE%
IF STRCOUNT(TEMP_VARVALUE,@"/%ARGS%/")
	LOCAL = 1
ELSE
	LOCAL = 0
ENDIF
;SET_ADD
IF ARG:1 && LOCAL == 0
	SETVAR TEMP_VAR, @"%TEMP_VARVALUE%%ARGS%/"
ENDIF
RETURNF LOCAL

