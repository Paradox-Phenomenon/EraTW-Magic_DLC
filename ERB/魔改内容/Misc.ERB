@AddEXP(ENUM, C_ID, MOD_NUM)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC ENUM
#DIM DYNAMIC C_ID
#DIM DYNAMIC MOD_NUM
#DIM DYNAMIC EXP_ID

IF ISNUMERIC(ENUM)
	EXP_ID = TOINT(ENUM)
ELSE
	EXP_ID = GETNUM(EXP, ENUM)
ENDIF

IF EXP_ID == -1
	PRINTFORMW [错误]AddEXP: "%ENUM%" 不是合法的EXP名称，请保存日志报错
	RETURN 0
ENDIF

CALL QOL_ADD_EXP_CORE(EXP_ID, C_ID, MOD_NUM, 0)
RETURN RESULT

;----------------------------------------------------------------------
;函数名: AddEXPOrdered
;概　要: AddEXP的变体，消息改为开头显示名字，拥有更灵活的消息输出格式。
;参　数: OutputMode: 1:带制表间距 0:普通模式 -1:静默
;----------------------------------------------------------------------
@AddEXPOrdered(ENUM, C_ID, MOD_NUM, OutputMode)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC ENUM
#DIM DYNAMIC C_ID
#DIM DYNAMIC MOD_NUM
#DIM DYNAMIC OutputMode
#DIM DYNAMIC EXP_ID
#DIM DYNAMIC PRINT_MODE

IF ISNUMERIC(ENUM)
	EXP_ID = TOINT(ENUM)
ELSE
	EXP_ID = GETNUM(EXP, ENUM)
ENDIF

IF EXP_ID == -1
	PRINTFORMW [错误]AddEXPOrdered: "%ENUM%" 不是合法的EXP名称，请保存日志报错
	RETURN 0
ENDIF
IF OutputMode == -1
	PRINT_MODE = -1
ELSEIF OutputMode == 1
	PRINT_MODE = 2
ELSE
	PRINT_MODE = 1
ENDIF

CALL QOL_ADD_EXP_CORE(EXP_ID, C_ID, MOD_NUM, PRINT_MODE)
RETURN RESULT

;-------------------------------------------------
;函数名:@QOL_GETVAR
;概　要:利用反射获取ITEM数组中的值的通用函数
;参　数:VARNAME = 变量名
;      :CID = 角色编号
;      :ENUM = 枚举常量
;返回值:物品持有数量 (int)，如果变量不存在返回 安全失败值
;备　注:使用了EXISTVAR确保安全性
;-------------------------------------------------
@QOL_GETVAR(VARNAME,ENUM,CID = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC VARNAME
#DIMS DYNAMIC ENUM
#DIM DYNAMIC CID
#FUNCTION
SIF CID > CHARANUM-1
	RETURNF 安全失败值
LOCALS = %VARNAME%%COND_STR(@":{CID}",CID > -1)%:%ENUM%
IF EXISTVAR(LOCALS,1)
	RETURNF GETVAR(LOCALS)
ELSE
	RETURNF 安全失败值
ENDIF

;-------------------------------------------------
;函数名:@QOL_SETVAR
;概　要:SETVAR的安全封装
;参　数:VARNAME = 变量名
;      :CID = 角色编号
;      :ENUM = 枚举常量
;		MOD_NUM     = 设定的绝对数值
;返回值:1 = 成功, 0 = 失败 (变量不存在)
;备 注：需配合CALLF使用，或者直接作为错误处理的条件式使用，类似TRYCATCH
;-------------------------------------------------
@QOL_SETVAR(VARNAME,ENUM,MOD_NUM,CID = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC VARNAME
#DIMS DYNAMIC ENUM
#DIM DYNAMIC MOD_NUM
#DIM DYNAMIC CID
#FUNCTION
SIF CID > CHARANUM-1
	RETURNF 0
LOCALS = %VARNAME%%COND_STR(@":{CID}",CID > -1)%:%ENUM%
IF EXISTVAR(LOCALS,1)
	RETURNF SETVAR(LOCALS,MOD_NUM)
ENDIF

;-------------------------------------------------
;函数名:@QOL_GETENUMNAME
;概　要:获取枚举常量的显示名
;参　数:VARNAME = 变量名
;      :ENUM = 枚举常量
;返回值:翻译后的物品显示名称，失败返回 "NULL"
;备　注:本质上是跳过了获取ID的环节直接映射显示名称
;-------------------------------------------------
@QOL_GETENUMNAME(VARNAME,ENUM)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS VARNAME
#DIMS DYNAMIC ENUM
#FUNCTIONS
IF ISNUMERIC(ENUM)
	RETURNF NAME_TR(GETVARS(@"%VARNAME%NAME:{TOINT(ENUM)}"))
ELSEIF EXISTVAR(@"%VARNAME%:%ENUM%",1)
	RETURNF NAME_TR(ENUM,1)
ELSE
	RETURNF "NULL"
ENDIF
