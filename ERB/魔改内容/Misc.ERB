;        ARG - 设定时，表明字符串变量是charadata，该参数作为其第一下标
;返回值：1 = 元素原先已存在, 0 = 元素原先不存在
;-------------------------------------------------
@SET_DELETE(ARGS, ARGS:1,ARG = -1)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS REF CHK_STR

#DIMS DYNAMIC TEMP_VAR
#DIMS DYNAMIC TEMP_VARVALUE

TEMP_VAR '= GET_REF_VARNAME(ARGS:1, ARG)
TEMP_VARVALUE '= GETVARS(TEMP_VAR)
