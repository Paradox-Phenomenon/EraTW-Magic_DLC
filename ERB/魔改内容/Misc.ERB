;-------------------------------------------------
;函数名:@QOL_SHOW_SET_ITEM(ITEM_ID, MOD_NUM, PRINT_TYPE)
;概　要:处理物品增减的核心逻辑，并负责显示消息
;参　数:ITEM_ID    = 物品的数组编号 (INT)
;		MOD_NUM    = 变动数量 (正数为得，负数为失)
;		PRINT_TYPE = 显示模式 (0:Wait 1:Line 2:Wait 3:Silent)
;返回值:1 = 成功, 0 = 失败
;备　注:包含上限判断(999)和消息文本着色逻辑，是物品获得函数系列的抽象，也是封装底层F函数的样例
;-------------------------------------------------
@QOL_SHOW_SET_ITEM(ITEM_ID, MOD_NUM, PRINT_TYPE)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC LABEL
#DIM DYNAMIC ITEM_ID
#DIM DYNAMIC MOD_NUM
#DIM DYNAMIC PRINT_TYPE
#DIM DYNAMIC CURRENT_VAL

SIF MOD_NUM == 0
	RETURN 1
IF ITEM_ID < 0 || ITEM_ID >= VARSIZE("ITEM") || ITEMNAME:ITEM_ID == ""
	DEBUGPRINTFORML [错误]QOL_SHOW_SET_ITEM: 传入了无效的物品ID ({ITEM_ID})
	RETURN 0
ENDIF
CURRENT_VAL = ITEM:ITEM_ID
LABEL = %NAME_TR(ITEMNAME:ITEM_ID)%
ITEM:ITEM_ID = LIMIT(CURRENT_VAL + MOD_NUM, 0, 999)

IF PRINT_TYPE != 3
	IF MOD_NUM > 0 && CURRENT_VAL >= 999
		CALL COLORMESSAGE(@"%LABEL%没法再多拿了", C_YELLOW, PRINT_TYPE)
	ELSEIF MOD_NUM > 0 && CURRENT_VAL + MOD_NUM > 999
		CALL COLORMESSAGE(@"拿不完%LABEL%，只能拿满为止", C_YELLOW, PRINT_TYPE)
	ELSEIF MOD_NUM > 0
		CALL COLORMESSAGE(@"得到了{MOD_NUM}个%LABEL%", C_YELLOW, PRINT_TYPE)
	ELSEIF MOD_NUM < 0
		CALL COLORMESSAGE(@"失去了{-MOD_NUM}个%LABEL%", C_YELLOW, PRINT_TYPE)
	ENDIF
ENDIF
RETURN 1

;-------------------------------------------------
;函数名:@QOL_ADD_EXP_CORE
;概　要:处理经验增减的核心逻辑，同步更新TCVAR防重复结算，并负责显示消息
;参　数:EXP_ID      = 经验的数组编号 (INT)
;		C_ID        = 角色编号 (INT)
;		MOD_NUM     = 变动数量 (正数为得，负数为失)
;		PRINT_MODE  = 显示模式 
;                     -1: 静默 (不显示)
;                      0: 默认模式 [EXP名＋数值（角色名）] (原AddEXP/AddEXP_D)
;                      1: 紧凑模式 [角色名的EXP名 ＋数值] (原AddEXPOrdered Mode 0)
;                      2: 对齐模式 [带制表间距的对齐格式] (原AddEXPOrdered Mode 1)
;返回值:1 = 成功, 0 = 失败
;-------------------------------------------------
@QOL_ADD_EXP_CORE(EXP_ID, C_ID, MOD_NUM, PRINT_MODE)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC EXP_ID
#DIM DYNAMIC C_ID
#DIM DYNAMIC MOD_NUM
#DIM DYNAMIC PRINT_MODE
#DIM DYNAMIC CURRENT_VAL
#DIM DYNAMIC ACTUAL_MOD
#DIMS DYNAMIC LABEL

SIF MOD_NUM == 0 || !INRANGE(C_ID, 0, CHARANUM - 1)
	RETURN 0
SIF EXP_ID < 0 || EXP_ID >= VARSIZE("EXP") || EXPNAME:EXP_ID == ""
	RETURN 0

CURRENT_VAL = EXP:C_ID:EXP_ID
ACTUAL_MOD = MAX(CURRENT_VAL + MOD_NUM, 0) - CURRENT_VAL
EXP:C_ID:EXP_ID += ACTUAL_MOD
TCVAR:C_ID:(400 + EXP_ID) += ACTUAL_MOD

IF PRINT_MODE != -1 && ACTUAL_MOD != 0
	; 获取翻译后的经验名称
	LABEL = %EXP_TR(EXP_ID)%
	IF ACTUAL_MOD > 0
		SELECTCASE PRINT_MODE
			CASE 0
				CALL COLORMESSAGE(@"%LABEL%＋{ACTUAL_MOD}（%CALLNAME:C_ID%）", C_YELLOW, 2, 1)
			CASE 1
				CALL COLORMESSAGE(@"%CALLNAME:C_ID%的%LABEL% ＋{ACTUAL_MOD}", C_YELLOW, 2)
			CASE 2
				CALL COLORMESSAGE(@"%CALLNAME:C_ID+"的",14,LEFT%%LABEL,18,LEFT% ＋{ACTUAL_MOD}", C_YELLOW, 1)
		ENDSELECT
	ELSE
		SELECTCASE PRINT_MODE
			CASE 0
				CALL COLORMESSAGE(@"%LABEL%－{-ACTUAL_MOD}（%CALLNAME:C_ID%）", C_RED, 2, 1)
			CASE 1
				CALL COLORMESSAGE(@"%CALLNAME:C_ID%的%LABEL% －{-ACTUAL_MOD}", C_RED, 2)
			CASE 2
				CALL COLORMESSAGE(@"%CALLNAME:C_ID+"的",14,LEFT%%LABEL,18,LEFT% －{-ACTUAL_MOD}", C_RED, 1)
		ENDSELECT
	ENDIF
ENDIF

RETURN 1

