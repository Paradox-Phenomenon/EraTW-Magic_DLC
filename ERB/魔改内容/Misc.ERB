;=========================================================
;概　要:连乘函数

;POWER的扩展，用于底数为小数的运算，因为没法传递浮点数，所以底数采取有效数字和精度两个部分，精度默认为两位
;intbase是底数*精度的int整数，如计算某数乘以0.80的幂，则intbase为80
;※如果需要增加精度，intbase也要同时增大倍数
;返回值：ARG * intbase^(expo/precision)
;=========================================================
@ExPOWER(ARG,intbase,expo,precision=100)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC intbase
#DIM DYNAMIC expo
#DIM DYNAMIC precision
LOCAL = 0
SIF !ARG
	RETURNF 0
SIF !expo
	RETURNF 1
WHILE ARG && LOCAL != expo
ARG = ARG * intbase / precision
LOCAL++
WEND
RETURNF ARG

@生成图片(ARGS,ARGS:1)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
CALLF 生成GID
GCREATEFROMFILE NEXT_GID, ARGS
SPRITECREATE ARGS:1,NEXT_GID
RETURNF NEXT_GID

@生成GID
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM GID
GID = NEXT_GID
WHILE GCREATED(GID)
	GID ++
WEND
NEXT_GID = GID

;-------------------------------------------------
;函数名:GROUPMATCH_CVAR
;概　要:角色变量的群组判断
;参  数:ARG = 匹配值,ARG:1 = 0匹配模式，1排除模式）,ARG:2 = 完全匹配）
;-------------------------------------------------
@GROUPMATCH_CVAR(LIST,CVAR,ARG = 0,ARG:1 = 0,ARG:2 = 0)
#LOCALSIZE 1
#DIM REF LIST
#DIM DYNAMIC TEMP
#DIM DYNAMIC TEMP_RESULT
#DIMS DYNAMIC VAR_INDEX,2
#DIMS CVAR
#FUNCTION

;在式中函数中调用会重写RESULT(S)的命令时需要暂存RESULT(S)
TEMP_RESULT = RESULT
SPLIT CVAR, ":", VAR_INDEX
RESULT = TEMP_RESULT

FOR LOCAL, 0, VARSIZE("LIST")
	IF ARG:1 == 1
		IF GETVAR(@"%VAR_INDEX:0%:{(LIST:LOCAL)}:%VAR_INDEX:1%") != ARG
			TEMP++
		ELSE
			SIF ARG:2
				RETURNF 0
		ENDIF
	ELSE
		IF GETVAR(@"%VAR_INDEX:0%:{(LIST:LOCAL)}:%VAR_INDEX:1%") == ARG
			TEMP++
		ELSE
			SIF ARG:2
				RETURNF 0
		ENDIF
	ENDIF
NEXT
RETURNF TEMP


;-------------------------------------------------
;CHECK-and-SET这一类型函数的抽象
;参 数：ARGS - 需要检查的元素名
;       ARGS:1 - 需要检查的字符串名
;       ARG - 设定时，表明字符串变量是charadata，该参数作为其第一下标
;       ARG:1 - 设定为真时，表明需要向集合增加新的元素
;-------------------------------------------------
@SET_UPDATECHECK(ARGS, ARGS:1,ARG = -1, ARG:1)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC TEMP
#DIM DYNAMIC TEMP_RESULT
#DIMS DYNAMIC TEMP_VARNAME
#DIMS DYNAMIC TEMP_VARVALUE
#DIMS DYNAMIC VAR_INDEX,2

;在式中函数中调用会重写RESULT(S)的命令时需要暂存RESULT(S)
IF STRCOUNT(ARGS:1,":")
	TEMP_RESULT = RESULT
	SPLIT ARGS:1, ":", VAR_INDEX
	RESULT = TEMP_RESULT
ELSE
	VAR_INDEX '= ARGS:1
ENDIF

TEMP_VARNAME = %VAR_INDEX:0%%COND_STR(@":{ARG}",ARG != -1)%%COND_STR(@":%VAR_INDEX:1%",VAR_INDEX:1 != "")%
;DEBUGPRINTFORM TEMP_VARNAME = %TEMP_VARNAME%  
TEMP_VARVALUE '= GETVARS(TEMP_VARNAME)
SIF TEMP_VARVALUE == ""
	TEMP_VARVALUE = /
;DEBUGPRINTFORML TEMP_VARVALUE = %TEMP_VARVALUE%
IF STRCOUNT(TEMP_VARVALUE,@"/%ARGS%/")
	LOCAL = 1
ELSE
	LOCAL = 0
ENDIF
;SET_ADD
IF ARG:1 && LOCAL == 0
	SETVAR TEMP_VARNAME, @"%TEMP_VARVALUE%%ARGS%/"
ENDIF
RETURNF LOCAL

