;-------------------------------------------------
;函数名:@RANDSF(ARG,ARG:1)
;概　要:带符号的随机偏移值生成
;参　数:ARG   = 随机幅度参数
;          ＞0 时，每次生成 0～ARG 的随机值并累加
;          ＜0 时，以 1/(1-ARG) 的概率累加 1
;       ARG:1 = 随机次数（权重）
;          绝对值表示随机执行次数
;          符号决定返回值的正负
;返回值:返回根据 ARG 与 ARG:1 生成的随机偏移值,可能为正数或负数
;-------------------------------------------------
@RANDSF(ARG,ARG:1)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM RESULT_SIGN
#FUNCTION
LOCAL = 0
RESULT_SIGN = 1
IF ARG:1 < 0
	ARG:1 = -ARG:1
	RESULT_SIGN *= -1
ENDIF
IF ARG > 0
	WHILE ARG:1 > 0
		ARG:1 --
		LOCAL += RAND:(1+ARG)
	WEND
ELSEIF ARG < 0
	WHILE ARG:1 > 0
		ARG:1 --
		SIF !RAND:(1-ARG)
			LOCAL += 1
	WEND
ENDIF
RETURNF LOCAL * RESULT_SIGN

;-------------------------------------------------
;函数名:RAND_ADVANTAGE(MAX_VAL, ROLLS)
;概　要:优势掷骰
;		正数ROLLS = Advantage（投多次取最高值，偏向高结果）
;		负数ROLLS = Disadvantage（投多次取最低值，偏向低结果）
;		0或1 = 普通随机
;参　数:MAX_VAL = 随机范围上限（返回 0 ~ MAX_VAL-1 与RAND行为一致）
;		ROLLS   = 投掷次数（可正可负，绝对值决定次数）
;返回值:带优势/劣势偏移的投掷结果
;备　注:D&D5e的Advantage/Disadvantage Rolls机制，即使是掷双骰，立马产生非常强力的优劣势，切勿将层数设计得太高
;-------------------------------------------------
@RAND_ADVANTAGE(MAX_VAL, ROLLS = 1)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC MAX_VAL
#DIM DYNAMIC ROLLS
#DIM DYNAMIC BEST_VAL
#DIM DYNAMIC CURRENT_ROLL
#DIM DYNAMIC ROLL_COUNT
SIF MAX_VAL <= 0
	RETURNF 0

ROLL_COUNT = ABS(ROLLS)
SIF ROLL_COUNT < 1
	ROLL_COUNT = 1

IF ROLLS >= 0
	BEST_VAL = 0
	FOR LOCAL, 0, ROLL_COUNT
		CURRENT_ROLL = RAND:MAX_VAL
		SIF CURRENT_ROLL > BEST_VAL
			BEST_VAL = CURRENT_ROLL
	NEXT
ELSE
	BEST_VAL = MAX_VAL - 1
	FOR LOCAL, 0, ROLL_COUNT
		CURRENT_ROLL = RAND:MAX_VAL
		SIF CURRENT_ROLL < BEST_VAL
			BEST_VAL = CURRENT_ROLL
	NEXT
ENDIF

RETURNF BEST_VAL

;-------------------------------------------------
;概　要：用于@ORGASM_ADD取代先前的各体位绝顶经验算法
;新性交模块绝顶经验对应表
;101~110 旧的5个体位
;111~150 遗落的小人飞机杯和7个新体位，预留新体位20个
;111~130 V 131~150 A 
;-------------------------------------------------
@新性交模块各体位绝顶经验索引算出(ARG = -1)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
SIF ARG == -1
	ARG = TARGET
