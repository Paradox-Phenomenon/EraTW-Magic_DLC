;-------------------------------------------------
;函数名:@RANDSF(ARG,ARG:1)
;概　要:带符号的随机偏移值生成
;参　数:ARG   = 随机幅度参数
;          ＞0 时，每次生成 0～ARG 的随机值并累加
;          ＜0 时，以 1/(1-ARG) 的概率累加 1
;       ARG:1 = 随机次数（权重）
;          绝对值表示随机执行次数
;          符号决定返回值的正负
;返回值:返回根据 ARG 与 ARG:1 生成的随机偏移值,可能为正数或负数
;-------------------------------------------------
@RANDSF(ARG,ARG:1)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM RESULT_SIGN
#FUNCTION
LOCAL = 0
RESULT_SIGN = 1
IF ARG:1 < 0
	ARG:1 = -ARG:1
	RESULT_SIGN *= -1
ENDIF
IF ARG > 0
	WHILE ARG:1 > 0
		ARG:1 --
		LOCAL += RAND:(1+ARG)
	WEND
ELSEIF ARG < 0
	WHILE ARG:1 > 0
		ARG:1 --
		SIF !RAND:(1-ARG)
			LOCAL += 1
	WEND
ENDIF
RETURNF LOCAL * RESULT_SIGN

;-------------------------------------------------
;概　要：用于@ORGASM_ADD取代先前的各体位绝顶经验算法
;新性交模块绝顶经验对应表
;101~110 旧的5个体位
;111~150 遗落的小人飞机杯和7个新体位，预留新体位20个
;111~130 V 131~150 A 
;-------------------------------------------------
@新性交模块各体位绝顶经验索引算出(ARG = -1)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
SIF ARG == -1
	ARG = TARGET
IF TEQUIP:ARG:50 > -1
	SELECTCASE TEQUIP:ARG:体位
		CASE 1 TO 5
			LOCAL = TEQUIP:ARG:体位 + 100
		CASE 6 TO 25
			LOCAL = TEQUIP:ARG:体位 + 105
	ENDSELECT
ELSEIF TEQUIP:ARG:51 > -1
	SELECTCASE TEQUIP:ARG:体位
		CASE 1 TO 5
			LOCAL = TEQUIP:ARG:体位 + 105
		CASE 6 TO 25
			LOCAL = TEQUIP:ARG:体位 + 125
	ENDSELECT
ELSE
	LOCAL = 0
ENDIF
RETURNF LOCAL

;-------------------------------------------------
;※※请务必在#FUNCTIONS类型中使用此SPLIT函数※※
;函数名:@SPLIT_F
;概　要:防RESULT污染的字符串分割函数
;参　数:ARGS   = 被分割的源字符串
;		ARGS:1 = 分割符 (省略时默认为 "/")
;		_LIST  = [REF] 接收分割结果的字符串数组
;			注：与SPLIT完全一致
;返回值:分割出的子字符串数量 (即实际的切分份数)
;备　注:该函数会在执行SPLIT前后备份/还原全局RESULT
;       可安全用于式中函数或条件判断中，避免逻辑干扰
;-------------------------------------------------
@SPLIT_F(ARGS, ARGS:1 = "/",_LIST)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS REF _LIST
SPLIT ARGS, ARGS:1, _LIST, LOCAL
RETURNF LOCAL

;********************************************
;物品系
;********************************************
;-------------------------------------------------
;函数名:@QOL_SHOW_SET_ITEM(ENUM, MOD_NUM, PRINT_TYPE)
;概　要:处理物品增减的核心逻辑，并负责显示消息
;参　数:ENUM = 物品的键名 (可以是ID字符串 "708" 或 名称 "好吃的鱼")
;		MOD_NUM     = 变动数量 (正数为得，负数为失)
;		PRINT_TYPE   = 显示模式 (0:Wait 1:Line 2:Wait 3:Silent)
;返回值:1 = 成功, 0 = 失败
;备　注:包含上限判断(999)和消息文本着色逻辑，是物品获得函数系列的抽象，也是封装底层F函数的样例
;-------------------------------------------------

;所有支持的样例如下：
;	CALL GET_ITEM("好吃的魚", 1, 1)	;好吃的魚是ITEM.CSV内的键值 ITEMNAME:708 == "好吃的魚"
;	CALL GET_ITEM("うまい魚", 2, 1)	;うまい魚是ITEM.ALS内的键值 标识符うまい魚能提供除了GETNUM键对反射以外同うまい魚一致的等价
;	※已改为别名※ CALL GET_ITEM("好吃的鱼", 3, 1)	;好吃的鱼是.ERH声明的宏 #DEFINE 好吃的鱼 好吃的魚，只有在作为元素编译时才与好吃的魚等价。这说明本系列函数具有运行时编译能力。
;	CALL GET_ITEM(708, 4, 1)	;708是好吃的鱼使用的ITEM数组编号，这里利用了编译自定义函数时允许数值向字符串型参数转换的解释器特性。
;-------------------------------------------------
@QOL_SHOW_SET_ITEM(ENUM, MOD_NUM, PRINT_TYPE)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC LABEL
#DIMS VARNAME
#DIM MOD_NUM
#DIMS DYNAMIC ENUM
#DIM PRINT_TYPE
VARNAME = ITEM

SIF MOD_NUM == 0
	RETURN

LABEL '= QOL_GETENUMNAME(VARNAME,ENUM)
IF LABEL == "NULL"
	PRINTFORMW [错误]参数1 "%ENUM%" 不是合法的[%VARNAME%]类型名称或ID，请保存日志报错
	RETURN
ENDIF
LOCAL = QOL_GETVAR(VARNAME,ENUM)
IF LOCAL == 安全失败值
	DEBUGPRINTFORML [警告]尝试读取 %VARNAME%:%ENUM% 失败。
	RETURN 0
ENDIF

IF QOL_SETVAR(VARNAME,ENUM,LIMIT(LOCAL + MOD_NUM, 0, 999))
	IF PRINT_TYPE != 3
		IF MOD_NUM > 0 && LOCAL > 999
			CALL COLORMESSAGE(@"%LABEL%没法再多拿了", C_YELLOW, PRINT_TYPE)
		ELSEIF MOD_NUM > 0 && LOCAL + MOD_NUM > 999
			CALL COLORMESSAGE(@"拿不完%LABEL%，只能拿满为止", C_YELLOW, PRINT_TYPE)
		ELSEIF MOD_NUM > 0
			CALL COLORMESSAGE(@"得到了{MOD_NUM}个%LABEL%", C_YELLOW, PRINT_TYPE)
		ELSEIF MOD_NUM < 0
			CALL COLORMESSAGE(@"失去了{-MOD_NUM}个%LABEL%", C_YELLOW, PRINT_TYPE)
		ENDIF
	ENDIF
ELSE 
	DEBUGPRINTFORML %VARNAME%:%ENUM%赋值失败
ENDIF


;-------------------------------------------------
;函数名:@QOL_GETVAR
;概　要:利用反射获取ITEM数组中的值的通用函数
;参　数:VARNAME = 变量名
;      :CID = 角色编号
;      :ENUM = 枚举常量
;返回值:物品持有数量 (int)，如果变量不存在返回 安全失败值
;备　注:使用了EXISTVAR确保安全性
;-------------------------------------------------
@QOL_GETVAR(VARNAME,ENUM,CID = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC VARNAME
#DIMS DYNAMIC ENUM
#DIM DYNAMIC CID
#FUNCTION
SIF CID > CHARANUM-1
	RETURNF 安全失败值
LOCALS = %VARNAME%%COND_STR(@":{CID}",CID > -1)%:%ENUM%
IF EXISTVAR(LOCALS,1)
	RETURNF GETVAR(LOCALS)
ELSE
	RETURNF 安全失败值
ENDIF

;-------------------------------------------------
;函数名:@QOL_SETVAR
;概　要:SETVAR的安全封装
;参　数:VARNAME = 变量名
;      :CID = 角色编号
;      :ENUM = 枚举常量
;		MOD_NUM     = 设定的绝对数值
;返回值:1 = 成功, 0 = 失败 (变量不存在)
;备 注：需配合CALLF使用，或者直接作为错误处理的条件式使用，类似TRYCATCH
;-------------------------------------------------
@QOL_SETVAR(VARNAME,ENUM,MOD_NUM,CID = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC VARNAME
#DIMS DYNAMIC ENUM
#DIM DYNAMIC MOD_NUM
#DIM DYNAMIC CID
#FUNCTION
SIF CID > CHARANUM-1
	RETURNF 0
LOCALS = %VARNAME%%COND_STR(@":{CID}",CID > -1)%:%ENUM%
IF EXISTVAR(LOCALS,1)
	RETURNF SETVAR(LOCALS,MOD_NUM)
ENDIF

;-------------------------------------------------
;函数名:@QOL_GETENUMNAME
;概　要:获取枚举常量的显示名
;参　数:VARNAME = 变量名
;      :ENUM = 枚举常量
;返回值:翻译后的物品显示名称，失败返回 "NULL"
;备　注:本质上是跳过了获取ID的环节直接映射显示名称
;-------------------------------------------------
@QOL_GETENUMNAME(VARNAME,ENUM)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS VARNAME
#DIMS DYNAMIC ENUM
#FUNCTIONS
IF ISNUMERIC(ENUM)
	RETURNF NAME_TR(GETVARS(@"%VARNAME%NAME:{TOINT(ENUM)}"))
ELSEIF EXISTVAR(@"%VARNAME%:%ENUM%",1)
	RETURNF NAME_TR(ENUM,1)
ELSE
	RETURNF "NULL"
ENDIF
