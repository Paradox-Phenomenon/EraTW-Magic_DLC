@SPECIAL_SCOM_IMAGE
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_TARGET
#DIM DYNAMIC L_PARTNER
#DIM DYNAMIC CHARA_A
#DIM DYNAMIC CHARA_B
#DIMS DYNAMIC VER_TARGET
#DIMS DYNAMIC VER_PARTNER
#DIMS DYNAMIC CLOTH_STATE
#DIMS DYNAMIC RES_NAME
;_{体位}_{序号}，例如tartget是A时是1，B时是2。
#DIMS DYNAMIC 差分

L_TARGET = TARGET
SELECTCASE TFLAG:50
	CASE 9
		L_PARTNER = MASTER_POSE(SET_M, SET_P, 1)
	CASE 11
		L_PARTNER = MASTER_POSE(SET_B, SET_P, 1)
	CASE 99
		SELECTCASE ADD_SELECTED_SCOM
			CASE 12
				L_PARTNER = ADD_MASTER_POSE_TR(PLAYER, SET_YUBI,SET_P, 1)
			CASE 21
				L_PARTNER = ADD_MASTER_POSE_TR(PLAYER, SET_LEG,SET_P, 1)
			CASEELSE
				
		ENDSELECT
	CASEELSE
		
ENDSELECT
DEBUGPRINTFORML {L_TARGET} {L_PARTNER}
SIF L_PARTNER <= 0
	RETURN 0

; 排序 (方便索引排序，例如 102_103)
IF NO:L_TARGET < NO:L_PARTNER
	CHARA_A = NO:L_TARGET
	CHARA_B = NO:L_PARTNER
ELSE
	CHARA_A = NO:L_PARTNER
	CHARA_B = NO:L_TARGET
ENDIF

RESULTS =
RESULT = 0
TRYCALLFORM SPIRIT_Version{NO:L_TARGET}
SIF RESULT
	VER_TARGET '= RESULTS

RESULTS =
RESULT = 0
TRYCALLFORM SPIRIT_Version{NO:L_PARTNER}
SIF RESULT
	VER_PARTNER '= RESULTS

SIF VER_TARGET == "" || VER_TARGET != VER_PARTNER
	RETURN 0

;获得索引参数
IF CHECK_NUDE(L_TARGET) && CHECK_NUDE(L_PARTNER)
	CLOTH_STATE '= "裸"
ELSE
	CLOTH_STATE '= "服"
ENDIF
;获得差分名
差分 '= GET_SPECIAL_SCOM_IMAGE_DIFF(VER_TARGET,L_TARGET, L_PARTNER)

RES_NAME '= @"%VER_TARGET%_%CLOTH_STATE%_SCOM{TFLAG:50}_{CHARA_A}_{CHARA_B}%差分%"
DEBUGPRINTFORML %RES_NAME% IS {RM_RESOURCECHECK(RES_NAME)}
IF RM_RESOURCECHECK(RES_NAME)
	RESULTS '= RES_NAME
	RETURN 1
ENDIF
; 无服装判定通用图（扩展）
RES_NAME '= @"%VER_TARGET%_SCOM{TFLAG:50}_{CHARA_A}_{CHARA_B}"
IF RM_RESOURCECHECK(RES_NAME)
	RESULTS '= RES_NAME
	RETURN 1
ENDIF

RETURN 0

@GET_SPECIAL_SCOM_IMAGE_DIFF(VERSION, CHARA_1, CHARA_2)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC VERSION
#DIM  DYNAMIC CHARA_1
#DIM  DYNAMIC CHARA_2
#DIM  DYNAMIC CHARA_A
#DIM  DYNAMIC CHARA_B
#DIMS DYNAMIC DIFF_STR

IF NO:CHARA_1 < NO:CHARA_2
	CHARA_A = NO:CHARA_1
	CHARA_B = NO:CHARA_2
ELSE
	CHARA_A = NO:CHARA_2
	CHARA_B = NO:CHARA_1
ENDIF
RETURNF GETMETHS(@"SCOM_DIFF_%VERSION%_{CHARA_A}_{CHARA_B}", "", CHARA_A, CHARA_B)

