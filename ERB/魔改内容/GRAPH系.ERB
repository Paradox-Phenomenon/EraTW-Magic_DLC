@SPIRIT_BUILD_特效差分(Version, CHARA, ARG)
#DIMS DYNAMIC 特效 = "照れ", "吐息", "汗"
#DIM DYNAMIC CHARA
#DIMS DYNAMIC Version
#DIMS DYNAMIC 表示形式
#LOCALSIZE 1
VARSET LOCALS
FOR LOCAL, 0, VARSIZE("特效")
	IF ARG == 0
		表示形式 = 立絵
	ELSEIF ARG == 1
		表示形式 = 別立ち
	ELSE
		表示形式 = 別立ち{ARG}
	ENDIF
	;PRINTFORML 在处理 %表示形式%_%特效:LOCAL%_{CHARA}
	SIF RM_RESOURCECHECK(@"%表示形式%_%特效:LOCAL%_{CHARA}")
		CALL SPIRIT_特效切分(Version, CHARA, @"%表示形式%_%特效:LOCAL%_{CHARA}")
NEXT
TRYCALLFORM SPIRIT_特效索引_{CHARA}(ARG,LOCALS)
SIF !RESULT
	RETURN
FOR LOCAL, 0, RESULT
	;PRINTFORML 在处理 %表示形式%_%LOCALS:LOCAL%_{CHARA}
	SIF RM_RESOURCECHECK(@"%表示形式%_%LOCALS:LOCAL%_{CHARA}")
		CALL SPIRIT_特效切分(Version, CHARA, @"%表示形式%_%LOCALS:LOCAL%_{CHARA}")
NEXT

