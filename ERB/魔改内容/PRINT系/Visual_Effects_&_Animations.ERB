;*************************************************
; 工具函数
;*************************************************
;・如果在别的地方想实现类似彩虹色的效果，也许多少能派上用场？
;・目前只有一个“彩虹色定义函数”
;-------------------------------------------------

;-------------------------------------------------
; 函数名: GET_RAINBOW
; 概  要: 返回彩虹调色板中的一个颜色
; 参  数: ARG:0 … 第几个颜色（0~11）
; 返回值: 颜色值（HEX）
; 特点:
; ・超出范围时自动循环
; ・负数也可安全使用
; 色序:
; Red, Orange, Yellow, Spring,
; Green, Teal, Cyan, Azure,
; Blue, Violet, Magenta, Pink
;-------------------------------------------------
@GET_RAINBOW(ARG:0)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CONST RAINBOW = 0xFF9999, 0xFFCC99, 0xFFFF99, 0xCCFF99, 0x99FF99, 0x99FFCC, 0x99FFFF, 0x99CCFF, 0x9999FF, 0xCC99FF, 0xFF99FF, 0xFF99CC
RETURNF RAINBOW:((ARG:0 >= 0 ? ARG:0 # 11 - ABS(ARG:0 + 1)) % 12)


;*************************************************
; 内部函数
;*************************************************
;・严格来说，真正与“彩虹色”相关的内容实际上只有这里
;・如果从外部直接调用，本作者不保证其行为正确
;・不过说到底，本来就没有哪个函数是保证一定正常的
;・只是说不保证而已，用当然也可以。只是并不推荐就是了
;-------------------------------------------------

;-------------------------------------------------
; 函数名: _PRINT_RAINBOW_SUB1
; 概  要: 彩虹输出核心逻辑
; 工作流程:
; 1. 保存当前颜色
; 2. 遍历字符串
; 3. 每个字符根据索引计算颜色
; 4. 输出字符
; 5. 恢复原颜色
; 技术核心:
;   SETCOLOR GET_RAINBOW(...)
; 实际实现的是:
;   “逐字符颜色循环”
;-------------------------------------------------
@_PRINT_RAINBOW_SUB1(ARGS:0, ARG:0, ARG:1)
#LOCALSIZE 3
#LOCALSSIZE 1
LOCAL:0 = GETCOLOR()		;現在の文字色を取得
LOCAL:1 = STRLENSU(ARGS:0)	;表示文字列の文字数を取得
FOR LOCAL:2, 0, LOCAL:1	;文字数分ループさせる
	;12で割った余り、もしくは11からそれを引いた数で色設定。ここにずらしカウントが入る
	SETCOLOR GET_RAINBOW(ARG:1 ? 11 - (LOCAL:2 + ARG:0) % 12 # (LOCAL:2 + ARG:0) % 12)
	PRINTS CHARATU(ARGS:0, LOCAL:2)	;ARGSから1文字抜き出して出力。こういう用途にCHARATUは実際便利
NEXT
SETCOLOR LOCAL:0	;元の文字色に戻す
RETURN RESULT

;-------------------------------------------------
; 函数名：HSV_PRINT_RAINBOW
; 参  数：L_STR  - 要输出的文本
;         L_TYPE - 颜色预设类型 (默认2:彩虹，6反向彩虹，其他呼吸色参见GET_CHANGING_COLOR)
;         L_OFFSET_STEP - 字符间的时间相位差 (默认15，数值越小变化越平缓)
;         L_WAVE_DIR - 波浪流动方向。0: 向右流动 (默认), 1: 向左流动
;=========================================================
@HSV_PRINT_RAINBOW(L_STR, L_TYPE = 2, L_OFFSET_STEP = 15, L_TIME_SEED = -1, L_WAVE_DIR = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_TYPE
#DIM DYNAMIC L_OFFSET_STEP
#DIM DYNAMIC L_TIME_SEED
#DIM DYNAMIC L_WAVE_DIR
#DIM DYNAMIC L_OLD_COLOR
#DIM DYNAMIC L_LEN
#DIM DYNAMIC L_POS
#DIM DYNAMIC L_CUR_OFFSET
#DIM DYNAMIC L_FROZEN_TIME

L_OLD_COLOR = GETCOLOR()
L_LEN = STRLENSU(L_STR)

IF L_TIME_SEED == -1
	L_FROZEN_TIME = GETMILLISECOND() 
ELSE
	L_FROZEN_TIME = L_TIME_SEED
ENDIF

FOR L_POS, 1, L_LEN + 1
	IF L_WAVE_DIR == 0
		L_CUR_OFFSET = (L_LEN + 1 - L_POS) * L_OFFSET_STEP
	ELSE
		L_CUR_OFFSET = L_POS * L_OFFSET_STEP
	ENDIF
	
	SETCOLOR GET_CHANGING_COLOR(L_TYPE, L_FROZEN_TIME, L_CUR_OFFSET)
	PRINTS CHARATU(L_STR, L_POS)
NEXT

SETCOLOR L_OLD_COLOR

@HSV_PRINT_RAINBOWL(L_STR, L_TYPE = 2, L_OFFSET_STEP = 15, L_TIME_SEED = -1, L_WAVE_DIR = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_TYPE
#DIM DYNAMIC L_OFFSET_STEP
#DIM DYNAMIC L_TIME_SEED
#DIM DYNAMIC L_WAVE_DIR
CALL HSV_PRINT_RAINBOW(L_STR, L_TYPE, L_OFFSET_STEP, L_TIME_SEED, L_WAVE_DIR)
PRINTL

@HSV_PRINT_RAINBOWW(L_STR, L_TYPE = 2, L_OFFSET_STEP = 15, L_TIME_SEED = -1, L_WAVE_DIR = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_TYPE
#DIM DYNAMIC L_OFFSET_STEP
#DIM DYNAMIC L_TIME_SEED
#DIM DYNAMIC L_WAVE_DIR
CALL HSV_PRINT_RAINBOW(L_STR, L_TYPE, L_OFFSET_STEP, L_TIME_SEED, L_WAVE_DIR)
WAIT

;=========================================================
; 函数名：HSV_PRINT_RAINBOW2 (及其 L/W 变体)
; 概  述：带动画效果的波浪呼吸灯输出
; 参  数：L_STR  - 要输出的变色文本
;         L_TYPE - 颜色预设类型 (默认2:正向彩虹)
;         L_FRAMES - 动画持续帧数 (默认20帧)
;         L_PREFIX - 不变色的前缀文本
;         L_SUFFIX - 不变色的后缀文本
;         L_WAIT - 每帧停留的毫秒数 (默认50，数值越小动画越丝滑)
;         L_OFFSET_STEP - 字符波浪相位差 (默认15)
;         L_WAVE_DIR - 波浪流动方向。0: 向右流动 (默认), 1: 向左流动
;=========================================================
@HSV_PRINT_RAINBOW2(L_STR, L_TYPE = 2, L_FRAMES = 20, L_PREFIX = "", L_SUFFIX = "", L_WAIT = 50, L_OFFSET_STEP = 15, L_WAVE_DIR = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_TYPE
#DIM DYNAMIC L_FRAMES
#DIMS DYNAMIC L_PREFIX
#DIMS DYNAMIC L_SUFFIX
#DIM DYNAMIC L_WAIT
#DIM DYNAMIC L_OFFSET_STEP
#DIM DYNAMIC L_WAVE_DIR
#DIM DYNAMIC L_FRAME_IDX
#DIM DYNAMIC L_OLD_REDRAW
#DIMS DYNAMIC L_SAVED_LINE

L_OLD_REDRAW = CURRENTREDRAW()

L_SAVED_LINE = 
IF !LINEISEMPTY()
	REDRAW 0
	PRINTL 
	L_SAVED_LINE = %HTML_TOPLAINTEXT(HTML_GETPRINTEDSTR())%
	CLEARLINE 1
ENDIF

IF ANIME_CONFIG("SCROLLTEXT")
	REDRAW 0
	
	FOR L_FRAME_IDX, 0, L_FRAMES
		SIF L_FRAME_IDX > 0
			CLEARLINE 1
		
		PRINTS L_SAVED_LINE
		PRINTS L_PREFIX
		CALL HSV_PRINT_RAINBOW(L_STR, L_TYPE, L_OFFSET_STEP,,L_WAVE_DIR)
		PRINTS L_SUFFIX
		PRINTL 
		TWAIT L_WAIT, 0
	NEXT
	
	REDRAW L_OLD_REDRAW
	CLEARLINE 1
ENDIF

PRINTS L_SAVED_LINE
PRINTS L_PREFIX
CALL HSV_PRINT_RAINBOW(L_STR, L_TYPE, L_OFFSET_STEP,,L_WAVE_DIR)
PRINTS L_SUFFIX
RETURN RESULT

@HSV_PRINT_RAINBOW2L(L_STR, L_TYPE = 2, L_FRAMES = 20, L_PREFIX = "", L_SUFFIX = "", L_WAIT = 50, L_OFFSET_STEP = 15, L_WAVE_DIR = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_TYPE
#DIM DYNAMIC L_FRAMES
#DIMS DYNAMIC L_PREFIX
#DIMS DYNAMIC L_SUFFIX
#DIM DYNAMIC L_WAIT
#DIM DYNAMIC L_OFFSET_STEP
#DIM DYNAMIC L_WAVE_DIR
CALL HSV_PRINT_RAINBOW2(L_STR, L_TYPE, L_FRAMES, L_PREFIX, L_SUFFIX, L_WAIT, L_OFFSET_STEP, L_WAVE_DIR)
PRINTL
RETURN RESULT

@HSV_PRINT_RAINBOW2W(L_STR, L_TYPE = 2, L_FRAMES = 20, L_PREFIX = "", L_SUFFIX = "", L_WAIT = 50, L_OFFSET_STEP = 15, L_WAVE_DIR = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_TYPE
#DIM DYNAMIC L_FRAMES
#DIMS DYNAMIC L_PREFIX
#DIMS DYNAMIC L_SUFFIX
