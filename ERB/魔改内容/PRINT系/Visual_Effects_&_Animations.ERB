;==============================================================================
; 4：视觉特效与动画 (Visual_Effects_&_Animations)
; 需要考虑屏幕刷新机能的动态效果渲染。
;==============================================================================
;-------------------------------------------------
; 函数名：KEYTYPING
; 概  述：逐字打印特效。支持前后半句切换显示。
;        如：CALL KEYTYPING("あくま/悪魔", "W", 2)  (显示：あ → あく → あくま → 悪魔)
;-------------------------------------------------
@KEYTYPING(L_STR, L_FLAGS, L_DELAY = 1, L_CHUNK_SIZE = 2)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIMS DYNAMIC L_FLAGS
#DIM DYNAMIC L_DELAY
#DIM DYNAMIC L_CHUNK_SIZE
#DIM DYNAMIC L_OLD_C
#DIM DYNAMIC L_OLD_REDRAW
#DIMS DYNAMIC L_TOKENS, 300
#DIM DYNAMIC L_TOKEN_CNT
#DIMS DYNAMIC L_FINAL_STR
#DIMS DYNAMIC L_CURRENT_BUF
#DIM DYNAMIC L_LINE_START

L_OLD_REDRAW = CURRENTREDRAW()
L_DELAY = MAX(L_DELAY, 1)
L_CHUNK_SIZE = LIMIT(L_CHUNK_SIZE, 1, 9)

; 对话框标记
SIF SPLIT_CHECK(TOLOWER(L_FLAGS), "d")
	L_STR = 「%L_STR%」

L_OLD_C = GETCOLOR()
SIF SPLIT_CHECK(TOLOWER(L_FLAGS), "dc")
	RESETCOLOR

REDRAW 0

; 按 "/" 切割转换前/后字符串
SPLIT L_STR, "/", L_TOKENS, L_TOKEN_CNT

; 如果玩家正在按Ctrl快进
IF MESSKIP()
	FOR I, 0, L_TOKEN_CNT, 2
		SIF L_TOKENS:(I + 1) == ""
			L_TOKENS:(I + 1) = %L_TOKENS:I%
		L_FINAL_STR += L_TOKENS:(I + 1)
	NEXT
	GOTO KEYTYPING_SKIP
ENDIF

; 重置鼠标左键状态
GETKEYTRIGGERED 0x01

FOR I, 0, L_TOKEN_CNT, 2
	L_CURRENT_BUF = ""
	FOR J, 0, STRLENS(L_TOKENS:I), L_CHUNK_SIZE
		L_LINE_START = LINECOUNT
		
		SIF I > 0
			PRINTFORM %L_FINAL_STR%
			
		PRINTFORML %SUBSTRING(L_TOKENS:I, 0, J)%
		
		IF MESSKIP() || GETKEYTRIGGERED(0x01)
			CLEARLINE (LINECOUNT - L_LINE_START)
			; 若打断，直接组装最终字符串跳过
			L_FINAL_STR = ""
			FOR I, 0, L_TOKEN_CNT, 2
				SIF L_TOKENS:(I + 1) == ""
					L_TOKENS:(I + 1) = %L_TOKENS:I%
				L_FINAL_STR += L_TOKENS:(I + 1)
			NEXT
			GOTO KEYTYPING_SKIP
		ENDIF
		
		TWAIT L_DELAY, 1
		CLEARLINE (LINECOUNT - L_LINE_START)
	NEXT
	
	SIF L_TOKENS:(I + 1) == ""
		L_TOKENS:(I + 1) = %L_TOKENS:I%
		
	L_FINAL_STR += L_TOKENS:(I + 1)
NEXT

$KEYTYPING_SKIP

; 输出最终结果
PRINTS L_FINAL_STR

SIF SPLIT_CHECK(TOLOWER(L_FLAGS), "l")
	PRINTL
SIF SPLIT_CHECK(TOLOWER(L_FLAGS), "w")
	PRINTW 
	
SETCOLOR L_OLD_C
REDRAW L_OLD_REDRAW

;-------------------------------------------------
; 函数名：ANIMATION_BGCOLOR_TRANSITION
; 概  述：全屏背景色平滑过渡动画 (接入 HSV 渐变引擎)
; 参  数：L_C_START  - 起始背景色 (Hex)
;         L_C_END    - 结束背景色 (Hex)
;         L_STEPS    - 动画总帧数
;         L_DELAY    - 每帧基础延迟 (ms)
;         L_DELAY_ADD- 每帧递增的延迟，可制造减速缓冲效果
;         L_FLAG     - 位标志 (&1: 每帧打印一个换行)
;-------------------------------------------------
@ANIMATION_BGCOLOR_TRANSITION(L_C_START, L_C_END, L_STEPS, L_DELAY, L_DELAY_ADD, L_FLAG)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_C_START
#DIM DYNAMIC L_C_END
#DIM DYNAMIC L_STEPS
#DIM DYNAMIC L_DELAY
#DIM DYNAMIC L_DELAY_ADD
#DIM DYNAMIC L_FLAG
#DIM DYNAMIC L_CUR_C
#DIM DYNAMIC L_WAIT_T

SIF MESSKIP()
	RETURN

SIF L_STEPS <= 0
	L_STEPS = 1

FOR LOCAL, 0, L_STEPS
	L_CUR_C = COLOR_LERP_HSV(L_C_START, L_C_END, LOCAL, L_STEPS - 1)
	SETBGCOLOR L_CUR_C
	
	L_WAIT_T = LIMIT(L_DELAY + (LOCAL * L_DELAY_ADD), 50, 1000)
	; 强制刷新并等待
	AWAIT L_WAIT_T
	
	SIF L_FLAG & 0x0001
		PRINTL
NEXT

;-------------------------------------------------
;函数名：PRINT_PROGRESS_BAR
;概  述：在循环中渲染一个非阻塞的、可自动更新的进度条。
;参  数：L_CUR     - 当前进度值
;        L_MAX     - 最大进度值
;        L_TEXT    - 进度条旁的主提示文本（如 "Loading..."）
;        L_INFO_STR- （可选）在进度条下方额外显示的动态信息文本
;返回值：无
;用法：
; FOR LOCAL, 0, CHARANUM
;     ; 渲染进度条，并在下方显示 "收下了可观的小费后……"
;     CALL PRINT_PROGRESS_BAR, LOCAL, CHARANUM, "Initializing Data", @"收下了可观的小费后……"
;     ;...这里可以执行耗时操作...
;     TWAIT 50, 0
; NEXT
;-------------------------------------------------
@PRINT_PROGRESS_BAR(L_CUR, L_MAX, L_TEXT = "Progress", L_INFO_STR = "")
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_CUR
#DIM DYNAMIC L_MAX
#DIMS DYNAMIC L_TEXT
#DIMS DYNAMIC L_INFO_STR

#DIM DYNAMIC L_OLD_REDRAW
#DIM DYNAMIC L_OLD_COLOR
#DIM DYNAMIC L_DARKNESS
#DIMS DYNAMIC L_HTML
;L_OLD_COLOR = GETCOLOR()
L_OLD_REDRAW = CURRENTREDRAW()

REDRAW 0

;如果L_INFO_STR行数不确定，则需要依赖主调用循环开头的行数记录
CLEARLINE LINECOUNT - gLineCount:1

; 利用 OSCILLATION 产生文字明暗呼吸效果，效果并不好，暂时弃用
;L_DARKNESS = CALC_OSCILLATION_VALUE(0x10 * L_CUR, 0x88 - 0x22)
;SETCOLOR RGB_TO_HEX(0x22 + L_DARKNESS, 0x22 + L_DARKNESS, 0x22 + L_DARKNESS)

; 调用图形进度条组件HTML_RECT_BAR，2400 单位宽，高度 64，底部对齐，蓝色系渐变
L_HTML += HTML_RECT_BAR(L_CUR, L_MAX, 2400, 64, 0x7070C0, 0x202050, 0x9494FF, 30)
; 计算百分比
L_HTML += @"[{L_CUR * 100 / MAX(L_MAX, 1),2}％]"
L_HTML += " " + L_TEXT
HTML_PRINT L_HTML

IF L_INFO_STR != ""
	PRINTSL L_INFO_STR
ENDIF

REDRAW L_OLD_REDRAW
;SETCOLOR L_OLD_COLOR
AWAIT

;-------------------------------------------------
; 函数名：ANIMATION_LOAD
; 概  述：旧进度条的兼容接口，用于计算的L_MIN_VAL在重构后不再需要，而函数名ANIMATION_LOAD也不直观，因此用PRINT_PROGRESS_BAR替代
;-------------------------------------------------
@ANIMATION_LOAD(L_CUR, L_MIN_VAL = 0, L_MAX, L_TEXT = "　Loading")
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_CUR
#DIM DYNAMIC L_MIN_VAL
#DIM DYNAMIC L_MAX
#DIMS DYNAMIC L_TEXT
CALL PRINT_PROGRESS_BAR, L_CUR, L_MAX, L_TEXT

;-------------------------------------------------
; 函数名：TRIPLEDOT
; 概  述：带有延迟等待效果的省略号输出
; 参  数：L_FLAGS - 控制参数 (如 "reverse", "timed", "wait")
;         L_CHAR  - 使用的字符 (默认 ".")
;-------------------------------------------------
@TRIPLEDOT(L_FLAGS, L_CHAR = "...")
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_FLAGS
#DIMS DYNAMIC L_CHAR
#DIMS DYNAMIC L_STR

FOR LOCAL, 0, 3
	IF STRCOUNT(L_FLAGS, "reverse")
		L_STR = 　%L_CHAR * (3 - LOCAL)%
	ELSE
		L_STR = 　%L_CHAR * (LOCAL + 1)%
	ENDIF
	
	PRINTSDL L_STR
	
	SIF STRCOUNT(L_FLAGS, "timed")
		TWAIT 300, 0
	SIF STRCOUNT(L_FLAGS, "wait")
		WAIT
NEXT

;-------------------------------------------------
; 函数名：ROLLTEXT_COMPONENT
; 概  述：统一的文本滚动/滑入/打字动画组件。
;         支持左右滚动、打字机效果、窗口宽度控制、
;         方向反转、下划线绘制、端点弹跳等效果。
;
; 参  数：
;     L_STR     - 要显示的文本
;     L_MODE    - 动画模式
;                 0 = 左→右平移滚动
;                 1 = 右→左平移滚动
;                 2 = 打字机效果（逐字出现）
;     L_SPEED   - 步进间隔（数值越大越快）
;     L_WIDTH   - 可视窗口宽度
;     L_BOUNCE  - 弹跳强度（0为关闭）
;     L_LINE    - 下划线模式
;                 0 = 无
;                 1 = DRAWLINE
;                 2 = CUSTOMDRAWLINE -=
;     L_WAIT    - 每帧等待时间(ms)
;
; 设  计：
;     ・统一管理 REDRAW 开关
;     ・统一清屏策略
;     ・兼容原 SCROLLTEXT / SCROLLTEXTL 接口
;     ・兼容 ANIMATION_ROLL_TEXT 打字效果
;
; 备  注：
;     本函数为滚动动画内核。
;     所有文本滚动效果应通过接口函数调用本组件。
;-------------------------------------------------
@ROLLTEXT_COMPONENT(L_STR, L_MODE, L_SPEED, L_WIDTH, L_BOUNCE, L_LINE, L_WAIT)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_MODE
#DIM DYNAMIC L_SPEED
#DIM DYNAMIC L_WIDTH
#DIM DYNAMIC L_BOUNCE
#DIM DYNAMIC L_LINE
#DIM DYNAMIC L_WAIT

#DIM DYNAMIC L_LEN
#DIM DYNAMIC L_OLD_REDRAW
#DIM DYNAMIC L_START_LINE
#DIMS DYNAMIC L_BUF
#DIM DYNAMIC L_POS    ; 当前截取位置
#DIM DYNAMIC L_AMP    ; 弹跳幅度
#DIM DYNAMIC L_STEP   ; 弹跳步骤

L_LEN = STRLENSU(L_STR)
SIF L_LEN == 0
	RETURN 0

IF MESSKIP()
	PRINTFORML %L_STR%
	FORCEWAIT
	RETURN 0
ENDIF

L_OLD_REDRAW = CURRENTREDRAW()
REDRAW 0

SIF LINEISEMPTY() == 0
	PRINTL

L_START_LINE = LINECOUNT
PRINTL

SELECTCASE L_MODE
	; 平移滚动（双向统一）
	CASE 0, 1
		; 预补空格
		IF L_MODE == 0
			; [空格.......][文本]
			L_STR = %" " * L_WIDTH + L_STR%
		ELSE
			; [文本][空格.......]
			L_STR = %L_STR + (" " * L_WIDTH)%
		ENDIF
		
		; 主滚动
		FOR LOCAL, 0, L_WIDTH - 1, MAX(L_SPEED, 1)
			IF L_MODE == 0
				; 从左往右截取，视觉效果是文本向左移动
				L_POS = LOCAL
				L_BUF = %SUBSTRINGU(L_STR, L_POS)%
			ELSE
				; 从右往左截取，视觉效果是文本向右移动
				L_POS = MAX(STRLENSU(L_STR) - L_WIDTH - LOCAL, 0)
				L_BUF = %SUBSTRINGU(L_STR, L_POS)%
			ENDIF
			
			CLEARLINE LINECOUNT - L_START_LINE
			PRINTSINGLEFORM %L_BUF%
			
			IF L_LINE == 1
				DRAWLINE
			ELSEIF L_LINE == 2
				CUSTOMDRAWLINE -=
			ENDIF
			
			REDRAW 1
			TWAIT L_WAIT, 0
			REDRAW 0
		NEXT
		
		; 弹跳效果，效果不理想，暂时弃用
		;IF L_BOUNCE > 0
			L_AMP = L_BOUNCE * 2
			; 记录最后的定格位置
			L_POS = (L_MODE == 0) ? (L_WIDTH - 2) # 0
			
			FOR L_STEP, 0, L_BOUNCE
				; 往回缩
				L_BUF = %SUBSTRINGU(L_STR, L_POS - L_AMP / (L_STEP + 1))%
				
				CLEARLINE LINECOUNT - L_START_LINE
				PRINTSINGLEFORM %L_BUF%
				REDRAW 1
				TWAIT L_WAIT, 0
				REDRAW 0
				
				; 往外弹
				L_BUF = %SUBSTRINGU(L_STR, L_POS + L_AMP / (L_STEP + 1))%
				
				CLEARLINE LINECOUNT - L_START_LINE
				PRINTSINGLEFORM %L_BUF%
				REDRAW 1
				TWAIT L_WAIT, 0
				REDRAW 0
			NEXT
		;ENDIF
	; 打字机
	CASE 2
		FOR LOCAL, 0, L_LEN
			; 逐字增加长度
			L_BUF = %SUBSTRINGU(L_STR, 0, LOCAL + 1)%
			
			CLEARLINE LINECOUNT - L_START_LINE
			PRINTFORM %L_BUF%
			
			REDRAW 1
			; 最后一个字显示稍微久一点，或者是空格时加快
			TWAIT (LOCAL + 1 < L_LEN ? L_WAIT # 200), 0
			REDRAW 0
		NEXT

ENDSELECT

; 最终定格：清除多余的动画帧，只保留最终纯净文本
CLEARLINE LINECOUNT - L_START_LINE
PRINTFORML %L_STR%

SIF L_LINE == 1
	DRAWLINE
SIF L_LINE == 2
	CUSTOMDRAWLINE -=

REDRAW L_OLD_REDRAW

;-------------------------------------------------
; 函数名：ANIMATION_ROLL_TEXT
; 概  述：跑马灯或打字机特效的文本输出
; 参  数：L_STR  - 文本内容
;         L_TYPE - 动画类型 (0=跑马灯平移, 1=打字机逐字)
;         L_WAIT - 每帧等待时间 (ms)
;-------------------------------------------------
@ANIMATION_ROLL_TEXT(L_STR, L_TYPE, L_WAIT = 50)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_TYPE
#DIM DYNAMIC L_WAIT
CALL ROLLTEXT_COMPONENT(L_STR,(L_TYPE == 1 ? 2 # 1),1,STRLENSU(L_STR)+5,0,0,L_WAIT)
RETURN RESULT

;-------------------------------------------------
;函数名：SCROLLTEXT
;概  述：跑马灯式文本滚动显示
;参  数：L_STR   - 文本内容
;        L_MODE  - 1=底端画线, 2=底端画虚线
;        L_SPEED - 滚动速度
;        L_WIDTH - 视窗宽度
;        L_BOUNCE- 弹跳次数 (0为不弹跳)
;        L_REV   - 反向滚动 (1=从左向右)
;-------------------------------------------------
@SCROLLTEXT(L_STR, L_MODE, L_SPEED = 1, L_WIDTH = -1, L_BOUNCE, L_REV)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_MODE
#DIM DYNAMIC L_SPEED
#DIM DYNAMIC L_WIDTH
#DIM DYNAMIC L_BOUNCE
#DIM DYNAMIC L_REV

IF ANIME_CONFIG("SCROLLTEXT")
	SIF L_WIDTH == -1
		L_WIDTH = MAXWIDTH() - 2
	CALL ROLLTEXT_COMPONENT(L_STR, (L_REV == 1 ? 1 # 0), L_SPEED, L_WIDTH, L_BOUNCE, L_MODE, 50)
ENDIF
RETURN RESULT

@SCROLLTEXTL(L_STR, L_MODE, L_SPEED = 1, L_WIDTH = -1, L_BOUNCE = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_MODE
#DIM DYNAMIC L_SPEED
#DIM DYNAMIC L_WIDTH
#DIM DYNAMIC L_BOUNCE
#DIM DYNAMIC L_REV
CALL SCROLLTEXT(L_STR, L_MODE, L_SPEED, L_WIDTH, L_BOUNCE, 1)
RETURN RESULT

;-------------------------------------------------
;函数名：ANIME_CONFIG
;概  述：全局动画特效配置控制器
;       用于保存/读取/强制覆盖动画设置（如是否允许滚动、闪烁等）
;参  数：ARGS - 指令字符串
;          "SAVE": 返回当前配置值
;          "SET" : 设置配置值 (ARG:0)
;          "FORCE": 强制开启/关闭 (1=强开, 2=强关, 0=恢复)
;          "TIMES": 设定接下来 N 次强制显示
;          "ONCE": 设定接下来 1 次强制显示
;          "SCROLLTEXT"/"FADE"/"QUAKE"/"FLASH"/"FULLCUTIN": 查询/翻转特定功能开关
;        ARG - 配合指令的参数
;返回值：根据指令返回状态值或布尔值
;-------------------------------------------------
@ANIME_CONFIG(ARGS, ARG = -1)
#FUNCTION
#LOCALSIZE 6
; 使用 LOCAL 保存配置状态
; LOCAL:1 表示强制显示 / 强制隐藏状态
; LOCAL:2 存储“指定次数的强制显示”剩余次数
; LOCAL:3 表示正在编辑 / 读取的配置位编号
; LOCAL:4 表示用户自定义编号
; LOCAL:5 表示 ONCE（仅一次）状态

SELECTCASE ARGS
	CASE "SAVE"
		RETURNF LOCAL
	CASE "SET"
		SIF ARG >= 0
			LOCAL = ARG
		RETURNF LOCAL
	CASE "FORCE"
		SIF ARG >= 0
			LOCAL:1 = ARG
		RETURNF LOCAL:1
	CASE "TIMES"
		SIF ARG >= 0
			LOCAL:2 = ARG
		RETURNF LOCAL:2
	CASE "ONCE"
		LOCAL:5 = 1
		RETURNF LOCAL:5
	CASE "SCROLLTEXT", "スクロール"
		;コンフィグビット0番
		LOCAL:3 = 0
	CASE "FADE", "フェード"
		;コンフィグビット1番
		LOCAL:3 = 1
	CASE "QUAKE", "振動"
		;コンフィグビット2番
		LOCAL:3 = 2
	CASE "FLASH", "発光"
		;コンフィグビット3番
		LOCAL:3 = 3
	CASE "FULLCUTIN", "全画面カットイン"
		;コンフィグビット4番
		LOCAL:3 = 4
	CASE "BGM_CUTIN", "ＢＧＭカットイン"
		;コンフィグビット41番
		LOCAL:3 = 41
	CASE "CHARA_CUTIN", "キャラカットイン"
		;コンフィグビット42番
		LOCAL:3 = 42
	CASEELSE
		; 用户自定义位 (USER1 ~ USER13)
		LOCAL:4 = TOINT(REPLACE(ARGS, "USER", ""))
		IF STRCOUNT(ARGS, "USER") && LOCAL:4 > 0 && LOCAL:4 < 14
			LOCAL:3 = 50+LOCAL:4
		ELSE
			RETURNF -1
		ENDIF
ENDSELECT
;设置修改
SELECTCASE ARG
	CASE 0
		SETBIT LOCAL, LOCAL:3
	CASE 1
		CLEARBIT LOCAL, LOCAL:3
	CASE 2
		INVERTBIT LOCAL, LOCAL:3
ENDSELECT
; 状态查询逻辑 (优先级: ONCE > TIMES > FORCE > CONFIG)
IF LOCAL:5
	LOCAL:5 = 0
	RETURNF MESSKIP() ? 0 # 1
ELSEIF LOCAL:2 > 0
	LOCAL:2--
	RETURNF MESSKIP() ? 0 # 1
ELSEIF LOCAL:1
	RETURNF MESSKIP() ? 0 # !(LOCAL:1-1)
ENDIF

RETURNF MESSKIP() ? 0 # !GETBIT(LOCAL, LOCAL:3)


;-------------------------------------------------
;函数名：FADE (及 FADEIN/FADEOUT)
;概  述：多行文本颜色淡入/淡出特效
;        **已升级为 HSV 插值引擎**，色彩过渡更平滑自然
;参  数：L_STEPS   - 动画帧数 (默认8)
;        L_C_START - 起始颜色 (Hex)
;        L_C_END   - 结束颜色 (Hex)
;        L_STR_0~29- 文本行内容
;-------------------------------------------------
@FADE(L_STEPS=8, L_C_START, L_C_END, L_S:0="VOID", L_S:1="VOID", L_S:2="VOID", L_S:3="VOID", L_S:4="VOID", L_S:5="VOID", L_S:6="VOID", L_S:7="VOID", L_S:8="VOID", L_S:9="VOID", L_S:10="VOID", L_S:11="VOID", L_S:12="VOID", L_S:13="VOID", L_S:14="VOID", L_S:15="VOID", L_S:16="VOID", L_S:17="VOID", L_S:18="VOID", L_S:19="VOID", L_S:20="VOID", L_S:21="VOID", L_S:22="VOID", L_S:23="VOID", L_S:24="VOID", L_S:25="VOID", L_S:26="VOID", L_S:27="VOID", L_S:28="VOID", L_S:29="VOID", L_SKIP_LINES=0, L_EXTRA_LINES=0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_STEPS
#DIM DYNAMIC L_C_START
#DIM DYNAMIC L_C_END
#DIMS DYNAMIC L_S, 30
#DIM DYNAMIC L_SKIP_LINES
#DIM DYNAMIC L_EXTRA_LINES

#DIM DYNAMIC L_OLD_C
#DIM DYNAMIC L_OLD_REDRAW
#DIM DYNAMIC L_CUR_C
#DIM DYNAMIC L_LINE_COUNT

L_OLD_C = GETCOLOR()

IF ANIME_CONFIG("FADE")
	L_OLD_REDRAW = CURRENTREDRAW()
	REDRAW 0
	
	; 预计算需要打印的行数
	L_LINE_COUNT = 0
	FOR LOCAL, 0, 30
		SIF L_S:LOCAL != "VOID"
			L_LINE_COUNT++
	NEXT
	L_LINE_COUNT += L_EXTRA_LINES

	; 如果不是 FullCutin 模式 (L_SKIP_LINES=0)，先打印一遍作为初始状态
	IF !L_SKIP_LINES
		SETCOLOR L_C_START
		FOR LOCAL, 0, 30
			SIF L_S:LOCAL != "VOID"
				PRINTSL L_S:LOCAL
		NEXT
		REPEAT L_EXTRA_LINES
			PRINTL
		REND
		TWAIT 100, 0
	ENDIF
	
	; 渐变循环
	; 关键升级：使用 HSV 插值替代原版 RGB 减法
	FOR J, 0, L_STEPS
		SIF !L_SKIP_LINES || J > 0
			CLEARLINE L_LINE_COUNT
		
		L_CUR_C = COLOR_LERP_HSV(L_C_START, L_C_END, J + 1, L_STEPS)
		SETCOLOR L_CUR_C
		
		FOR LOCAL, 0, 30
			SIF L_S:LOCAL != "VOID"
				PRINTSL L_S:LOCAL
		NEXT
		REPEAT L_EXTRA_LINES
			PRINTL
		REND
		TWAIT 100, 0
	NEXT
	
	REDRAW L_OLD_REDRAW
ELSE
	; 动画关闭：直接显示最终色
	SETCOLOR (GETBGCOLOR() == L_C_END ? L_C_START # L_C_END)
	FOR LOCAL, 0, 30
		SIF L_S:LOCAL != "VOID"
			PRINTSL L_S:LOCAL
	NEXT
ENDIF

SETCOLOR L_OLD_C
RETURN 0

