;-------------------------------------------------
;函数名：QUAKE
;概  述：屏幕震动特效
;-------------------------------------------------
@QUAKE(L_COUNT = 2)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_COUNT
#DIM DYNAMIC L_LINES

SIF !ANIME_CONFIG("QUAKE")
	RETURN 0

REDRAW 0
FOR LOCAL, 0, L_COUNT
	L_LINES = RAND:4 + 1
	REPEAT L_LINES
		PRINTL 
	REND
	TWAIT 100, 0
	CLEARLINE L_LINES
	TWAIT 100, 0
NEXT
REDRAW 3
RETURN 0

;-------------------------------------------------
;函数名：FLASH
;概  述：屏幕背景闪烁特效
;-------------------------------------------------
@FLASH(L_COUNT = 2, L_COLOR = 0xFFFFFF)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_COUNT
#DIM DYNAMIC L_COLOR
#DIM DYNAMIC L_OLD_BG

SIF !ANIME_CONFIG("FLASH")
	RETURN 0

L_OLD_BG = GETBGCOLOR()
REDRAW 0

; 填充屏幕 (确保有足够行数被背景色覆盖)
REPEAT 150
	PRINTL
REND

FOR LOCAL, 0, L_COUNT
	SETBGCOLOR L_COLOR
	REDRAW 2
	SETBGCOLOR L_OLD_BG
	REDRAW 2
NEXT

CLEARLINE 150
REDRAW 3
RETURN 0

;-------------------------------------------------
; 函数名：FULLCUTIN
; 概  述：全屏文字 Cut-in（插入画面）演出函数
;
; 参  数：
;     ARG     - 距离左侧边缘的缩进空格数
;     ARG:1   - 从底部上浮的行数
;               （与显示文字总行数相加请不要超过 30 行）
;     ARGS:0～29 - 要显示的文字内容（最多 30 行）
;     ARG:2   - 淡入淡出速度（默认 8）
;     strSetting - 可选附加演出设定
;
; 功  能：
;     ・通过输出空行清理屏幕
;     ・显示占满全屏的 Cut-in 文本演出
;     ・当 FULLCUTIN 动画开启时，强制使用淡入淡出效果
;-------------------------------------------------
@FULLCUTIN(ARG, ARG:1, ARGS = "VOID", ARGS:1 = "VOID", ARGS:2 = "VOID", ARGS:3 = "VOID", ARGS:4 = "VOID", ARGS:5 = "VOID", ARGS:6 = "VOID", ARGS:7 = "VOID", ARGS:8 = "VOID", ARGS:9 = "VOID", ARGS:10 = "VOID", ARGS:11 = "VOID", ARGS:12 = "VOID", ARGS:13 = "VOID", ARGS:14 = "VOID", ARGS:15 = "VOID", ARGS:16 = "VOID", ARGS:17 = "VOID", ARGS:18 = "VOID", ARGS:19 = "VOID", ARGS:20 = "VOID", ARGS:21 = "VOID", ARGS:22 = "VOID", ARGS:23 = "VOID", ARGS:24 = "VOID", ARGS:25 = "VOID", ARGS:26 = "VOID", ARGS:27 = "VOID", ARGS:28 = "VOID", ARGS:29 = "VOID", ARG:2 = 8, strSetting)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC strSetting

IF ARG < 0
	ARG = 0
	ALIGNMENT CENTER   ; 若缩进为负数，则自动改为居中对齐
ENDIF

; 表示开启（动画模式）
IF ANIME_CONFIG("FULLCUTIN")
	FOR LOCAL, 0, 30
		IF ARGS:LOCAL == "VOID"
			IF ARG:1 > 0
				ARGS:LOCAL =  
				ARG:1--
			ENDIF
		ELSE
			ARGS:LOCAL = %" "*ARG+ARGS:LOCAL%
		ENDIF
	NEXT
	CALL SAVELINE
	FOR LOCAL, 0, 150
		PRINTL 
	NEXT
	; 如果 FULLCUTIN 开启，则强制使用淡入效果
	CALLF ANIME_CONFIG("ONCE")
	CALL FADEIN(ARG:2, ARGS, ARGS:1, ARGS:2, ARGS:3, ARGS:4, ARGS:5, ARGS:6, ARGS:7, ARGS:8, ARGS:9, ARGS:10, ARGS:11, ARGS:12, ARGS:13, ARGS:14, ARGS:15, ARGS:16, ARGS:17, ARGS:18, ARGS:19, ARGS:20, ARGS:21, ARGS:22, ARGS:23, ARGS:24, ARGS:25, ARGS:26, ARGS:27, ARGS:28, ARGS:29)
	IF STRLENS(strSetting)
		SELECTCASE strSetting
			CASE "Time"
				;CALL ANIMATION_BGCOLOR_TRANSITION(GETBGCOLOR(), (TIME ? RGBTOHEX("0//0//30") # RGBTOHEX("20//10//0")), 20, 200, -30 )
				CALL ANIMATION_BGCOLOR_TRANSITION(GETBGCOLOR(), (TIME ? RGB_TO_HEX(0,0,30) # RGB_TO_HEX(20,10,0)), 20, 200, -30 )
				TWAIT 1000, 0
		ENDSELECT
	ELSE
		TWAIT 2000, 0
	ENDIF
	CALLF ANIME_CONFIG("ONCE")
	CALL FADEOUT(ARG:2, ARGS, ARGS:1, ARGS:2, ARGS:3, ARGS:4, ARGS:5, ARGS:6, ARGS:7, ARGS:8, ARGS:9, ARGS:10, ARGS:11, ARGS:12, ARGS:13, ARGS:14, ARGS:15, ARGS:16, ARGS:17, ARGS:18, ARGS:19, ARGS:20, ARGS:21, ARGS:22, ARGS:23, ARGS:24, ARGS:25, ARGS:26, ARGS:27, ARGS:28, ARGS:29, 1)
	TWAIT 500, 0
	CALL RETURNLINE
; 表示关闭（简化显示模式）
ELSE
	PRINTL 
	PRINTL 
	FOR LOCAL, 0, 30
		IF ARGS:LOCAL != "VOID"
			IF STRLENSU(ARGS:LOCAL) < 2
				PRINTSL ARGS:LOCAL
			ELSE
				PRINTFORMW %" "*ARG+ARGS:LOCAL%
			ENDIF
		ENDIF
	NEXT
	PRINTL 
	PRINTL 
ENDIF
ALIGNMENT LEFT
RETURN RESULT

