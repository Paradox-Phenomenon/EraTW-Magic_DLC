;-------------------------------------------------
;函数名：COLOR_BAR
;概  述：生成带RGB/HSV渐变的彩色进度条（HTML版）
;       以字符形式（前景▂ + 背景▁）显示比例，支持线性渐变尾部
;       原版基于RGB直接偏移，现已转换为内部HSV渐变（更自然、色相稳定）
;参  数：
;   VAL         - 当前值
;   MAX_VAL     - 最大值（用于计算填充比例）
;   L_LEN       - 进度条总长度（字符数，建议 10~60）
;                 默认 20
;   L_R,L_G,L_B - 基准前景色（RGB 0~255）
;                 默认 160,160,160 → 中性灰
;   L_BG_DIFF   - 背景色相对于前景色的亮度差（通常负值表示更暗）
;                 默认 -80
;   L_GR_R      - 渐变在R通道的每单位长度增量（通常小值或0）
;   L_GR_G      - G通道渐变增量
;   L_GR_B      - B通道渐变增量
;                 三者默认全0 → 无渐变；设为正/负值可制造彩虹尾或冷暖渐变
;   L_GR_FREQ   - 渐变频率（值越大，渐变段越短/变化越快）
;                 默认 1；建议 0.5~4
;   COLOR_FG    - 前景填充字符（默认 "▂"）
;   COLOR_BG    - 背景空字符（默认 "▁"）
;返回值：固定返回 1（表示成功调用HTML_PRINT）
;       直接通过 HTML_PRINT 输出带颜色的字符条
;-------------------------------------------------
; 视觉效果说明：
;   • 前 L_LEN * (VAL/MAX_VAL) 个字符用前景色（从基准色开始）
;   • 剩余部分用背景色（通常比前景暗 L_BG_DIFF）
;   • 最右侧一小段（长度 ≈ L_LEN / L_GR_FREQ）会应用线性渐变
;     渐变基于 HSV 空间计算，更自然（不会出现 RGB 直调时的色偏/过曝）
;   • 典型用法：
;       - 无渐变：L_GR_R=G=B=0 → 纯色条 + 暗背景
;       - 彩虹尾：L_GR_R=15, L_GR_G=-20, L_GR_B=30, L_GR_FREQ=2
;       - 冷→暖：L_GR_R=40, L_GR_G=10, L_GR_B=-30
;-------------------------------------------------
; 使用示例：
;   COLOR_BAR HP, MHP                     ; 默认灰色纯色条
;   COLOR_BAR MP, MMP, 30, 100,180,220    ; 偏蓝色的较长条
;   COLOR_BAR EXP, NEXTEXP, 25, 255,180,60, -100, 30, -20, 10, 1.5
;       → 橙黄基准 → 尾部带彩虹渐变（R↑ G↓ B↑）
;   COLOR_BAR 75, 100, 40, 0,255,0, -120, 0,0,0   ; 纯绿色条，背景很暗
;   COLOR_BAR 999, 500, 20, 255,100,100, -60, 20,40,-10, 0.8
;       → 红色基准 → 尾部偏紫彩虹感
;-------------------------------------------------
@COLOR_BAR(VAL, MAX_VAL, L_LEN=20, L_R=160, L_G=160, L_B=160, L_BG_DIFF=-80, L_GR_R=0, L_GR_G=0, L_GR_B=0, L_GR_FREQ=1, COLOR_FG="▂", COLOR_BG="▁")
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC VAL
#DIM DYNAMIC MAX_VAL
#DIM DYNAMIC L_LEN
#DIM DYNAMIC L_GR_LEN
#DIM DYNAMIC L_R
#DIM DYNAMIC L_G
#DIM DYNAMIC L_B
#DIM DYNAMIC L_BG_DIFF
#DIM DYNAMIC L_GR_R
#DIM DYNAMIC L_GR_G
#DIM DYNAMIC L_GR_B
#DIM DYNAMIC L_GR_FREQ
#DIMS DYNAMIC COLOR_FG
#DIMS DYNAMIC COLOR_BG
#DIM DYNAMIC L_FG_C1
#DIM DYNAMIC L_BG_C
#DIM DYNAMIC L_FG_C2
L_GR_LEN = L_LEN * VAL / MAX_VAL / L_GR_FREQ
L_FG_C1 = RGB_TO_HEX(L_R, L_G, L_B)
L_BG_C = RGB_TO_HEX(L_R + L_BG_DIFF, L_G + L_BG_DIFF, L_B + L_BG_DIFF)
L_FG_C2 = RGB_TO_HEX(L_R + L_GR_R * L_GR_LEN, L_G + L_GR_G * L_GR_LEN, L_B + L_GR_B * L_GR_LEN)

HTML_PRINT QOL_HTML_BARSTR(VAL, MAX_VAL, L_LEN, L_FG_C1, L_BG_C, COLOR_FG, COLOR_BG, L_FG_C2),1
RETURN 1

