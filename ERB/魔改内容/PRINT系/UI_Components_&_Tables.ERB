;-------------------------------------------------
;函数名：QOL_HTML_BARSTR
;概  述：生成基于文本字符的通用进度条（支持HSV渐变）
;参  数：VAL    - 当前数值
;        MAX_VAL    - 最大数值（若<=0，则视为填满）
;        L_LEN    - 进度条的总字符长度（默认20）
;        COLOR_FG   - 前景填充色（Hex颜色，默认当前文字色）
;        COLOR_BG   - 背景空白色（Hex颜色，默认自动变暗）
;        CHAR_FG - 填充用的字符（默认为全角方块 "█"）
;        CHAR_BG - 空白用的字符（默认为半角网纹 "▒"）
;        COLOR_FG2  - 渐变终点色（若指定，则从 COLOR_FG 渐变至此颜色）
;返回值：包含HTML标签的字符串 (可以直接传给 HTML_PRINT)
;-------------------------------------------------
@QOL_HTML_BARSTR(VAL, MAX_VAL, L_LEN = 20, COLOR_FG = -1, COLOR_BG = -1, CHAR_FG = "█", CHAR_BG = "▒", COLOR_FG2 = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIM DYNAMIC VAL
#DIM DYNAMIC MAX_VAL
#DIM DYNAMIC L_LEN
#DIM DYNAMIC COLOR_FG
#DIM DYNAMIC COLOR_BG
#DIMS DYNAMIC CHAR_FG
#DIMS DYNAMIC CHAR_BG
#DIM DYNAMIC COLOR_FG2

#DIM DYNAMIC FILLED_W
#DIM DYNAMIC EMPTY_W
#DIMS DYNAMIC RES_STR
#DIM DYNAMIC CUR_COLOR

SIF COLOR_FG == -1
	COLOR_FG = GETCOLOR()
SIF COLOR_BG == -1
	; 默认背景色：基于当前前景色叠加64的Alpha值（变暗/半透明感）
	COLOR_BG = CALC_ALPHA_COLOR(GETCOLOR(), 64)
SIF COLOR_FG2 == -1
	COLOR_FG2 = COLOR_FG

IF MAX_VAL <= 0
	FILLED_W = L_LEN
ELSE
	; 使用 LIMIT 防止数值溢出导致进度条爆表
	FILLED_W = LIMIT(VAL * L_LEN / MAX_VAL, 0, L_LEN)
ENDIF
EMPTY_W = L_LEN - FILLED_W

IF FILLED_W > 0
	IF COLOR_FG == COLOR_FG2
		; 优化：纯色模式下，直接利用字符串乘法生成，避免循环
		RES_STR += @"<font color='%HEX_TO_HTML_COLOR(COLOR_FG)%' face='MS Gothic'>%CHAR_FG * FILLED_W%</font>"
	ELSE
		; 渐变模式：逐字计算颜色
		FOR I, 0, FILLED_W
			; 计算当前字符的插值颜色 (HSV空间)
			CUR_COLOR = COLOR_LERP_HSV(COLOR_FG, COLOR_FG2, I, MAX(FILLED_W - 1, 1))
			RES_STR += @"<font color='%HEX_TO_HTML_COLOR(CUR_COLOR)%' face='MS Gothic'>%CHAR_FG%</font>"
		NEXT
	ENDIF
ENDIF

IF EMPTY_W > 0
	RES_STR += @"<font color='%HEX_TO_HTML_COLOR(COLOR_BG)%' face='MS Gothic'>%CHAR_BG * EMPTY_W%</font>"
ENDIF

RETURNF RES_STR


;-------------------------------------------------
;函数名：HTML_RECT_BAR
;概  述：生成基于 <shape> 标签的像素级平滑进度条（支持HSV渐变）
;参  数：VAL      - 当前数值
;        MAX_VAL      - 最大数值
;        WIDTH    - 进度条总宽度（单位：Emuera绘图坐标，100 = 1个全角字符宽）
;        HEIGHT   - 进度条高度（单位同上，推荐 25~50）
;        COLOR_FG     - 前景填充色
;        COLOR_BG     - 背景空白色
;        COLOR_FG2    - 渐变终点色
;        Y_OFFSET - Y轴偏移量（用于对齐文本，推荐 37 左右居中）
;返回值：包含多个 <shape> 标签的 HTML 字符串
;-------------------------------------------------
@HTML_RECT_BAR(VAL, MAX_VAL, WIDTH = 1000, HEIGHT = 25, COLOR_FG = -1, COLOR_BG = -1, COLOR_FG2 = -1, Y_OFFSET = 37)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIM DYNAMIC VAL
#DIM DYNAMIC MAX_VAL
#DIM DYNAMIC WIDTH
#DIM DYNAMIC HEIGHT
#DIM DYNAMIC COLOR_FG
#DIM DYNAMIC COLOR_BG
#DIM DYNAMIC COLOR_FG2
#DIM DYNAMIC Y_OFFSET

#DIM DYNAMIC FILLED_W
#DIM DYNAMIC EMPTY_W
#DIMS DYNAMIC RES_STR
#DIM DYNAMIC CHUNK_W
#DIM DYNAMIC DRAWN_W
#DIM DYNAMIC THIS_W
#DIM DYNAMIC CUR_COLOR

SIF COLOR_FG == -1
	COLOR_FG = GETCOLOR()
SIF COLOR_BG == -1
	COLOR_BG = CALC_ALPHA_COLOR(GETCOLOR(), 64)
SIF COLOR_FG2 == -1
	COLOR_FG2 = COLOR_FG

IF MAX_VAL <= 0
	FILLED_W = WIDTH
ELSE
	FILLED_W = LIMIT(VAL * WIDTH / MAX_VAL, 0, WIDTH)
ENDIF
EMPTY_W = WIDTH - FILLED_W

IF FILLED_W > 0
	IF COLOR_FG == COLOR_FG2
		; 纯色模式：直接画一个矩形
		RES_STR += @"<shape type='rect' param='0,{Y_OFFSET},{FILLED_W},{HEIGHT}' color='%HEX_TO_HTML_COLOR(COLOR_FG)%'>"
	ELSE
		; 渐变模式：将进度条切分为多个小矩形
		; 为了防止 HTML 字符串过长导致引擎报错或渲染卡顿，限制最大分块数为 100
		CHUNK_W = MAX(FILLED_W / 100, 1)
		
		WHILE DRAWN_W < FILLED_W
			; 计算本次绘制的宽度（最后一块可能小于 Chunk）
			THIS_W = MIN(CHUNK_W, FILLED_W - DRAWN_W)
			; 计算当前位置的颜色 (使用已绘制宽度作为进度)
			CUR_COLOR = COLOR_LERP_HSV(COLOR_FG, COLOR_FG2, DRAWN_W, MAX(FILLED_W, 1))
			; 拼接 Shape 标签，X坐标相对偏移由引擎自动处理（Shape是流式布局）
			; param='x, y, width, height'
			RES_STR += @"<shape type='rect' param='0,{Y_OFFSET},{THIS_W},{HEIGHT}' color='%HEX_TO_HTML_COLOR(CUR_COLOR)%'>"
			DRAWN_W += THIS_W
		WEND
	ENDIF
ENDIF

IF EMPTY_W > 0
	RES_STR += @"<shape type='rect' param='0,{Y_OFFSET},{EMPTY_W},{HEIGHT}' color='%HEX_TO_HTML_COLOR(COLOR_BG)%'>"
ENDIF

RETURNF RES_STR

;-------------------------------------------------
;函数名：PRINT_RATE_BAR_EX
;概  述：高精度图形条（HTML化重构版），基于 <shape> 标签实现上百个色块的像素级分段进度条
;       支持超限(LimitOver)、粗细调节、上下对齐、分段间隙、双层数值(Vol2)、HSV渐变
;       取代旧版 PRINT_RECT，渲染性能更高、更平滑，如果需要上百个色块，建议同时开启	BITMAP_CACHE_ENABLE 1
;参  数：VAL       - 主当前数值（第一层填充）
;        MAX_VAL   - 最大数值（计算填充比率用）
;        SCALE_NUM - 分段数量（每段绘制一个矩形块）
;        SCALE_W   - 每段宽度（Emuera绘图坐标，100=1个全角字符宽）
;        L_C_L     - 渐变起始色（左/低值颜色）
;        L_C_R     - 渐变结束色（右/高值颜色）
;        L_C_EMPTY - 空值/未填充颜色
;        L_FLAG    - 控制标志（位运算组合，详见下方说明）
;        VAL2      - 第二层当前数值（可选，双层条用，优先级低于VAL）
;        L_C_2     - 第二层颜色（VAL2 > 0 时生效）
;返回值：0（内部直接调用 HTML_PRINT 输出，自动换行）
;-------------------------------------------------
; L_FLAG 标志位说明（可使用 | 组合）：
;   0x0001 : 开启 LimitOver 模式
;   0x0002 : 高度 = 40
;   0x0004 : 高度 = 12
;   0x0008 : 高度 = 90
;   0x0010 : BOTTOM 对齐（偏下）
;   0x0020 : TOP 对齐（偏上）
;   0x1000 : 启用分段间隙（自动计算缝隙宽度）
;   默认值（0）   : 高度 = 62 与TW默认的5/8高度块相似，CENTER 对齐，无间隙，无超限
;   LimitOver（超限延伸）：当 VAL 或 VAL2 超过 MAX_VAL 时，继续向右绘制额外段落
;-------------------------------------------------
; ==================== DEMO ====================
;;  VAL=75, MAX=100）
;; 效果：10段渐变条（绿→红），每段宽60，有间隙，TOP对齐，高度40，第二层30用蓝色
;
;CALL PRINT_RATE_BAR_EX 75, 100, 10, 60, 0x00FF00, 0xFF0000, 0x444444, 0x1000 | 0x0020, 30, 0x0088FF
;
;; 或者用包装函数（更简洁）
;CALL PRINT_RATE_BAR 75, 100, 10, 60, 0x00FF00, 0xFF0000, 0x444444, 0x1000 | 0x0020
;
;; 超限演示（VAL超过MAX_VAL）
;CALL PRINT_RATE_BAR_EX 150, 100, 8, 80, 0xFFFF00, 0xFF8800, 0x333333, 0x0001, 0, 0x000000
; =============================================
@PRINT_RATE_BAR(VAL, MAX_VAL, SCALE_NUM, SCALE_W, L_C_L, L_C_R, L_C_EMPTY, L_FLAG)
	#DIM VAL
	#DIM MAX_VAL
	#DIM SCALE_NUM
	#DIM SCALE_W
	#DIM L_C_L
	#DIM L_C_R
	#DIM L_C_EMPTY
	#DIM L_FLAG

	CALL PRINT_RATE_BAR_EX(VAL, MAX_VAL, SCALE_NUM, SCALE_W, L_C_L, L_C_R, L_C_EMPTY, L_FLAG, 0, 0x000000)
	RETURN

;================================================================
; 核心：高级复合图形条 (HTML化重构版)
; 支持：超限(LimitOver)、粗细调节、上下对齐、分段间隙、双层数值(Vol2)
;================================================================
@PRINT_RATE_BAR_EX(VAL, MAX_VAL, SCALE_NUM, SCALE_W, L_C_L, L_C_R, L_C_EMPTY, L_FLAG, VAL2, L_C_2)
	#DIM VAL
	#DIM MAX_VAL
	#DIM SCALE_NUM
	#DIM SCALE_W
	#DIM L_C_L
	#DIM L_C_R
	#DIM L_C_EMPTY
	#DIM L_FLAG
	#DIM VAL2
	#DIM L_C_2

	#DIM DYNAMIC L_GAP_X
	#DIM DYNAMIC L_POS_Y
	#DIM DYNAMIC L_HEIGHT
	#DIM DYNAMIC L_RATE
	#DIM DYNAMIC L_RATE2
	#DIM DYNAMIC L_LIMIT_OVER
	#DIM DYNAMIC L_SCALE_RATE
	#DIMS DYNAMIC L_RES
	#DIM DYNAMIC L_CUR_C

	; 1. 解析高度与 Y 轴偏移 (基于Emuera 100单位标准)
	IF L_FLAG & 0x0008
		L_HEIGHT = 90
	ELSEIF L_FLAG & 0x0002
		L_HEIGHT = 40
	ELSEIF L_FLAG & 0x0004
		L_HEIGHT = 24
	ELSE
		L_HEIGHT = 62
	ENDIF

	; 2. 解析缝隙 (分段进度条)
	IF L_FLAG & 0x1000
		L_GAP_X = LIMIT(12, SCALE_W / 10, SCALE_W / 3)
	ELSE
		L_GAP_X = 0
	ENDIF

	; 3. 解析对齐
	IF L_FLAG & 0x0010 ; BOTTOM
		L_POS_Y = (100 - L_HEIGHT) * 4 / 5
	ELSEIF L_FLAG & 0x0020 ; TOP
		L_POS_Y = (100 - L_HEIGHT) * 1 / 5
	ELSE ; CENTER
		L_POS_Y = (100 - L_HEIGHT) / 2
	ENDIF

	L_LIMIT_OVER = ((L_FLAG & 0x01) ? 1 # 0)

	; 4. 计算万分比率
	IF MAX_VAL > 0
		L_RATE = MAX(10000 * VAL / MAX_VAL, 0)
		L_RATE2 = MAX(10000 * VAL2 / MAX_VAL, 0)
	ELSE
		L_RATE = 10000
		L_RATE2 = 10000
	ENDIF
	
	IF L_LIMIT_OVER == 0
		L_RATE = LIMIT(L_RATE, 0, 10000)
		L_RATE2 = LIMIT(L_RATE2, 0, 10000)
	ENDIF

	L_SCALE_RATE = MAX(10000 / SCALE_NUM, 1)

	; 5. 循环生成 HTML 标签 (彻底取代老式的 PRINT_RECT)
	FOR LOCAL, 0, SCALE_NUM
		IF L_RATE > 0
			; 利用核心引擎的 HSV 渐变
			L_CUR_C = COLOR_LERP_HSV(L_C_L, L_C_R, LOCAL, MAX(SCALE_NUM - 1, 1))
		ELSE
			IF L_RATE2 > 0
				L_CUR_C = L_C_2
			ELSE
				L_CUR_C = L_C_EMPTY
			ENDIF
		ENDIF
		
		; 拼接图形标签。相对X轴偏移由引擎连续绘制自动处理，我们只需要给出宽度 SCALE_W - L_GAP_X
		; 如果有 GAP_X，利用空白字符填补 (或者插入空 shape)
		SIF L_GAP_X > 0 && LOCAL > 0
			L_RES += @"<shape type='space' param='{L_GAP_X}'>"
			
		L_RES += @"<shape type='rect' param='0,{L_POS_Y},{SCALE_W - L_GAP_X},{L_HEIGHT}' color='%HEX_TO_HTML_COLOR(L_CUR_C)%'>"
		
		L_RATE -= L_SCALE_RATE
		L_RATE2 -= L_SCALE_RATE
	NEXT

	; 处理超限 (Limit Over) 的延伸绘制
	IF L_LIMIT_OVER
		WHILE L_RATE > 0 || L_RATE2 > 0
			SIF L_GAP_X > 0
				L_RES += @"<shape type='space' param='{L_GAP_X}'>"
			
			L_CUR_C = (L_RATE > 0) ? L_C_R # L_C_2
			L_RES += @"<shape type='rect' param='0,{L_POS_Y},{SCALE_W - L_GAP_X},{L_HEIGHT}' color='%HEX_TO_HTML_COLOR(L_CUR_C)%'>"
			
			L_RATE -= L_SCALE_RATE
			L_RATE2 -= L_SCALE_RATE
		WEND
	ENDIF

	HTML_PRINT L_RES,1

	RETURN

