@RGB_TO_HEX(ARG:0, ARG:1, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
;bugfix,避免负数越界问题
;RETURNF COLOR_FROMRGB(ARG:0 & 0xFF, ARG:1 & 0xFF, ARG:2 & 0xFF)
RETURNF COLOR_FROMRGB(LIMIT(ARG:0, 0, 255), LIMIT(ARG:1, 0, 255), LIMIT(ARG:2, 0, 255))

@RGBCOLOR(ARG:0, ARG:1, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
RETURNF RGB_TO_HEX(ARG:0, ARG:1, ARG:2)

@HEX_R(ARG:0 = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
RETURNF ((ARG >= 0 ? ARG:0 # GETCOLOR()) >> 16) & 0xFF

@HEX_G(ARG:0 = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
RETURNF ((ARG >= 0 ? ARG:0 # GETCOLOR()) >> 8) & 0xFF

@HEX_B(ARG:0 = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
RETURNF (ARG >= 0 ? ARG:0 # GETCOLOR()) & 0xFF

@GETRED(ARG:0 = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
RETURNF HEX_R(ARG:0)

@GETGREEN(ARG:0 = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
RETURNF HEX_G(ARG:0)

@GETBLUE(ARG:0 = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
RETURNF HEX_B(ARG:0)

;概  述: 将 HEX 转换为 RGB 存入 RESULT 数组
;返回值: RESULT:0 = R, RESULT:1 = G, RESULT:2 = B
@HEX_TO_RGB, L_HEX_COLOR
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_HEX_COLOR
RETURN HEX_R(L_HEX_COLOR), HEX_G(L_HEX_COLOR), HEX_B(L_HEX_COLOR)

;概  述: 将 HEX 转换为 RGB 存入至少长度为3的 REF 数组
;返回值: L_RESULT:0
;用  法: L_COLOR = HEX_TO_RGB(L_HEX_COLOR, L_COLOR)
@HEX_TO_RGB_F, L_HEX_COLOR, L_RESULT
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM DYNAMIC L_HEX_COLOR
#DIM REF L_RESULT
L_RESULT:0 = HEX_R(L_HEX_COLOR)
L_RESULT:1 = HEX_G(L_HEX_COLOR)
L_RESULT:2 = HEX_B(L_HEX_COLOR)
RETURNF L_RESULT:0

;-------------------------------------------------
; [转换] HSV 转换系统 (标准化范围: H=0-360, S=0-255, V=0-255)
; 为了优化传参，HSV 被打包为一个 32位 整数: (H << 16) | (S << 8) | V
;-------------------------------------------------
@RGB_TO_HSV(L_RGB_COLOR)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM DYNAMIC L_RGB_COLOR
#DIM DYNAMIC L_R
#DIM DYNAMIC L_G
#DIM DYNAMIC L_B
#DIM DYNAMIC MAX_VAL
#DIM DYNAMIC L_MIN
#DIM DYNAMIC L_DELTA
#DIM DYNAMIC L_H
#DIM DYNAMIC L_S
#DIM DYNAMIC L_V

L_R = HEX_R(L_RGB_COLOR)
L_G = HEX_G(L_RGB_COLOR)
L_B = HEX_B(L_RGB_COLOR)

MAX_VAL = MAX(L_R, L_G, L_B)
L_MIN = MIN(L_R, L_G, L_B)
L_DELTA = MAX_VAL - L_MIN

; 明度
L_V = MAX_VAL

; 饱和度
IF MAX_VAL == 0
	L_S = 0
ELSE
	L_S = (L_DELTA * 255) / MAX_VAL
ENDIF

; 色相
IF L_DELTA == 0
	L_H = 0
ELSE
	IF MAX_VAL == L_R
		; H 在 红色 和 黄色/紫色 之间
		L_H = 60 * (L_G - L_B) / L_DELTA
		SIF L_G < L_B
			L_H += 360
	ELSEIF MAX_VAL == L_G
		; H 在 青色 和 黄色 之间
		L_H = 60 * (L_B - L_R) / L_DELTA + 120
	ELSE
		; H 在 紫色 和 青色 之间
		L_H = 60 * (L_R - L_G) / L_DELTA + 240
	ENDIF
ENDIF

RETURNF (LIMIT(L_H, 0, 360) << 16) | (LIMIT(L_S, 0, 255) << 8) | LIMIT(L_V, 0, 255)

@HSV_TO_RGB(L_HSV_COLOR)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM DYNAMIC L_HSV_COLOR
#DIM DYNAMIC L_H
#DIM DYNAMIC L_S
#DIM DYNAMIC L_V
#DIM DYNAMIC L_HI
#DIM DYNAMIC L_F
#DIM DYNAMIC L_P
#DIM DYNAMIC L_Q
#DIM DYNAMIC L_T

L_H = (L_HSV_COLOR >> 16) & 0x1FF
L_S = (L_HSV_COLOR >> 8) & 0xFF
L_V = L_HSV_COLOR & 0xFF

IF L_S == 0
	RETURNF RGB_TO_HEX(L_V, L_V, L_V)
ENDIF

L_HI = (L_H / 60) % 6
L_F = (L_H * 255 / 60) % 255
L_P = L_V * (255 - L_S) / 255
L_Q = L_V * (255 - (L_S * L_F / 255)) / 255
L_T = L_V * (255 - (L_S * (255 - L_F) / 255)) / 255

SELECTCASE L_HI
	CASE 0
		RETURNF RGB_TO_HEX(L_V, L_T, L_P)
	CASE 1
		RETURNF RGB_TO_HEX(L_Q, L_V, L_P)
	CASE 2
		RETURNF RGB_TO_HEX(L_P, L_V, L_T)
	CASE 3
		RETURNF RGB_TO_HEX(L_P, L_Q, L_V)
	CASE 4
		RETURNF RGB_TO_HEX(L_T, L_P, L_V)
	CASE 5
		RETURNF RGB_TO_HEX(L_V, L_P, L_Q)
ENDSELECT
RETURNF 0

; 调整明度
@BRIGHTCOLORF(L_PERCENT, L_COLOR = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM L_PERCENT
#DIM L_COLOR
#DIM L_HSV
#DIM L_V
SIF L_COLOR == -1
	L_COLOR = GETCOLOR()

L_HSV = RGB_TO_HSV(L_COLOR)
L_V = L_HSV & 0xFF
; 调整明度
L_V = LIMIT(L_V * L_PERCENT / 100, 0, 255)
; 重组 HSV (保持 H 和 S 不变)
L_HSV = (L_HSV & ~0xFF) | L_V

RETURNF HSV_TO_RGB(L_HSV)

@BRIGHTCOLOR(L_PERCENT)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM L_PERCENT
SETCOLOR BRIGHTCOLORF(L_PERCENT)
RETURN RESULT

;-------------------------------------------------
; [插值] HSV 空间的颜色线性插值 (色彩过渡更鲜艳)
;-------------------------------------------------
@COLOR_LERP_HSV(L_C1, L_C2, L_STEP, MAX_VAL_STEP)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM DYNAMIC L_C1
#DIM DYNAMIC L_C2
#DIM DYNAMIC L_STEP
#DIM DYNAMIC MAX_VAL_STEP
#DIM DYNAMIC L_HSV1
#DIM DYNAMIC L_HSV2
#DIM DYNAMIC L_H1
#DIM DYNAMIC L_S1
#DIM DYNAMIC L_V1
#DIM DYNAMIC L_H2
#DIM DYNAMIC L_S2
#DIM DYNAMIC L_V2
#DIM DYNAMIC L_H
#DIM DYNAMIC L_S
#DIM DYNAMIC L_V
#DIM IS_C1_ACHROMATIC ; 用于标记C1是否为消色差颜色
#DIM IS_C2_ACHROMATIC ; 用于标记C2是否为消色差颜色

SIF MAX_VAL_STEP <= 0
	RETURNF L_C1
SIF L_STEP >= MAX_VAL_STEP
	RETURNF L_C2
SIF L_STEP <= 0
	RETURNF L_C1

L_HSV1 = RGB_TO_HSV(L_C1)
L_HSV2 = RGB_TO_HSV(L_C2)

L_H1 = (L_HSV1 >> 16) & 0x1FF
L_S1 = (L_HSV1 >> 8) & 0xFF
L_V1 = L_HSV1 & 0xFF

L_H2 = (L_HSV2 >> 16) & 0x1FF
L_S2 = (L_HSV2 >> 8) & 0xFF
L_V2 = L_HSV2 & 0xFF

; 智能色相阈值
IS_C1_ACHROMATIC = L_S1 < 5
IS_C2_ACHROMATIC = L_S2 < 5

IF IS_C1_ACHROMATIC && IS_C2_ACHROMATIC
	L_H1 = 0
	L_H2 = 0
ELSEIF IS_C1_ACHROMATIC
	L_H1 = L_H2
ELSEIF IS_C2_ACHROMATIC
	L_H2 = L_H1
ELSEIF !IS_C1_ACHROMATIC && !IS_C2_ACHROMATIC
	IF ABS(L_H1 - L_H2) > 180
		IF L_H1 < L_H2
			L_H1 += 360
		ELSE
			L_H2 += 360
		ENDIF
	ENDIF
ENDIF

L_H = L_H1 + (L_H2 - L_H1) * L_STEP / MAX_VAL_STEP
L_S = L_S1 + (L_S2 - L_S1) * L_STEP / MAX_VAL_STEP
L_V = L_V1 + (L_V2 - L_V1) * L_STEP / MAX_VAL_STEP

; 归一化色相
L_H = L_H % 360
SIF L_H < 0
	L_H += 360

RETURNF HSV_TO_RGB((L_H << 16) | (L_S << 8) | L_V)

;-------------------------------------------------
; 函数名：CALC_OSCILLATION_VALUE
; 概  述：计算振荡值。使数值在 0 到 L_RANGE 之间来回平滑往复 (三角波)
;-------------------------------------------------
@CALC_OSCILLATION_VALUE(L_VAL, L_RANGE)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM DYNAMIC L_VAL
#DIM DYNAMIC L_RANGE
#DIM DYNAMIC L_CYCLE
#DIM DYNAMIC L_REMAINDER

SIF L_RANGE <= 0
	RETURNF 0

L_CYCLE = (L_VAL / L_RANGE) % 2
L_REMAINDER = L_VAL % L_RANGE

IF L_CYCLE == 0
	RETURNF L_REMAINDER
ELSE
	RETURNF L_RANGE - L_REMAINDER
ENDIF

;-------------------------------------------------
; 函数名：GET_CHANGING_COLOR
; 概  述：根据当前系统时间设置动态变化的呼吸灯/渐变颜色
; 参  数：L_TYPE   - 颜色风格预设
;           1 = 科技蓝白呼吸
;           2 = 全彩虹循环 (色相 0~360 完整正向轮转)
;           3 = 深海幽蓝呼吸
;           4 = 警告红黄呼吸
;           5 = 樱花粉白呼吸
;           6 = 逆彩虹循环 (色相 360~0 完整反向轮转)
;           默认 = 灰白呼吸
;         L_OFFSET - 时间偏移量(用于逐字渲染时的波浪/相位错位效果)
;-------------------------------------------------
@GET_CHANGING_COLOR(L_TYPE = 2, L_TIME_SEED = -1, L_OFFSET = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM DYNAMIC L_TYPE
#DIM DYNAMIC L_TIME_SEED
#DIM DYNAMIC L_OFFSET
#DIM DYNAMIC L_BASE_TIME
#DIM DYNAMIC L_TIME
#DIM DYNAMIC L_STEP
#DIM DYNAMIC L_MAX_STEP
#DIM DYNAMIC L_COLOR_A
#DIM DYNAMIC L_COLOR_B

; 如果外部没有提供时间种子，则自己取当前时间；否则使用外部固定的时间
IF L_TIME_SEED == -1
	L_BASE_TIME = GETMILLISECOND()
ELSE
	L_BASE_TIME = L_TIME_SEED
ENDIF

; 彩虹循环 (2:正向, 6:反向)
IF L_TYPE == 2 || L_TYPE == 6
	L_TIME = L_BASE_TIME / 15 + L_OFFSET
	
	; 色相 H 随时间循环 0~359
	IF L_TYPE == 2
		L_STEP = L_TIME % 360
	ELSE
		; 反向色相
		L_STEP = (360 - (L_TIME % 360)) % 360
	ENDIF
	
	; 饱和度呼吸，使用基准时间保证整句话同步呼吸
	L_MAX_STEP = 0xDD - CALC_OSCILLATION_VALUE(L_BASE_TIME / 30, 0x88)
	RETURNF HSV_TO_RGB((L_STEP << 16) | (L_MAX_STEP << 8) | 0xFF)
ENDIF

; 其余双极点呼吸灯
L_MAX_STEP = 100
SELECTCASE L_TYPE
	CASE 1 ; 科技蓝白呼吸
		L_COLOR_A = 0x22AAFF
		L_COLOR_B = 0xDDFFFF
		L_TIME = L_BASE_TIME / 25 + L_OFFSET
	CASE 3 ; 深海幽蓝呼吸
		L_COLOR_A = 0x0022AA
		L_COLOR_B = 0x0088CC
		L_TIME = L_BASE_TIME / 40 + L_OFFSET
	CASE 4 ; 警告红黄呼吸
		L_COLOR_A = 0xFF0000
		L_COLOR_B = 0xFF8800
		L_TIME = L_BASE_TIME / 15 + L_OFFSET
	CASE 5 ; 樱花粉白呼吸
		L_COLOR_A = 0xFF88AA
		L_COLOR_B = 0xFFEEEE
		L_TIME = L_BASE_TIME / 30 + L_OFFSET
	CASEELSE ; 默认：灰白呼吸
		L_COLOR_A = 0x666666
		L_COLOR_B = 0xCCCCCC
		L_TIME = L_BASE_TIME / 35 + L_OFFSET
ENDSELECT

L_STEP = CALC_OSCILLATION_VALUE(L_TIME, L_MAX_STEP)
RETURNF COLOR_LERP_HSV(L_COLOR_A, L_COLOR_B, L_STEP, L_MAX_STEP)
@SET_CHANGING_COLOR(L_TYPE = 2, L_OFFSET = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_TYPE
#DIM DYNAMIC L_OFFSET
SETCOLOR GET_CHANGING_COLOR(L_TYPE, L_OFFSET)

;-------------------------------------------------
; [混合] 带权重的颜色混合
;-------------------------------------------------
@MIX_COLOR(L_C1, L_W1, L_C2, L_W2)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM DYNAMIC L_C1
#DIM DYNAMIC L_W1
#DIM DYNAMIC L_C2
#DIM DYNAMIC L_W2
#DIM DYNAMIC L_R
#DIM DYNAMIC L_G
#DIM DYNAMIC L_B
#DIM DYNAMIC L_TOTAL_W

L_TOTAL_W = L_W1 + L_W2
SIF L_TOTAL_W == 0
	RETURNF L_C1

L_R = (HEX_R(L_C1) * L_W1 + HEX_R(L_C2) * L_W2) / L_TOTAL_W
L_G = (HEX_G(L_C1) * L_W1 + HEX_G(L_C2) * L_W2) / L_TOTAL_W
L_B = (HEX_B(L_C1) * L_W1 + HEX_B(L_C2) * L_W2) / L_TOTAL_W

RETURNF RGB_TO_HEX(L_R, L_G, L_B)

; [混合] 基于 Alpha 通道的背景融合
@CALC_ALPHA_COLOR(L_COLOR, L_ALPHA)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM DYNAMIC L_COLOR
#DIM DYNAMIC L_ALPHA
L_ALPHA = LIMIT(L_ALPHA, 0, 255)
RETURNF MIX_COLOR(L_COLOR, L_ALPHA, GETBGCOLOR(), 255 - L_ALPHA)

; [格式] 0xRRGGBB -> HTML String "#RRGGBB"
; 移植自ERB\method_from_eratohoЯeverse\HTML系_from_eratohoЯeverse.ERB
@HEX_TO_HTML_COLOR(L_HEX_COLOR = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIM DYNAMIC L_HEX_COLOR
RETURNF "#" + TOSTR((L_HEX_COLOR < 0 ? GETCOLOR() # L_HEX_COLOR) & 0xFFFFFF, "X6")

;魔改版本启用了另一个HTML色值转换，功能是返回没有#前缀的纯色值字符串，功能赘余，已连同用法一同矫正
@HEX_TO_STR(L_NUM = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIM DYNAMIC L_NUM
RETURNF HEX_TO_HTML_COLOR(L_NUM)

;-------------------------------------------------
;函数名:HTMLCCHK
;概　要:检查HTMLCOLOR标签的合法性，追加了智能修复的功能
;引　用：HTMLCOLOR（※已改名为HEX_TO_HTML_COLOR）
;RETURNF "#" + TOSTR((ARG:0 < 0 ? GETCOLOR() # ARG:0) & 0xFFFFFF, "X6")
;-------------------------------------------------
@HTMLCCHK(COLOR_STR, DEFAULT_HEX = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIMS	REF		COLOR_STR
#DIMS	DYNAMIC	TEMP_COL
#DIM	DYNAMIC	DEFAULT_HEX
#DIM	DYNAMIC	L_CHK

SIF STRCOUNT(COLOR_STR, "^#(|0x|0X)[0-9a-fA-F]{6}$") == 1
	RETURNF 1
SIF COLOR_FROMNAME(COLOR_STR) >= 0
	RETURNF 1

;试图恢复可以恢复的标签 (0x, 0X, 0X#)
TEMP_COL '= COLOR_STR
SIF STRFIND(TOLOWER(TEMP_COL), "0x") == 0
	TEMP_COL '= SUBSTRING(TEMP_COL, 2)
SIF STRFIND(TEMP_COL, "#") == 0
	TEMP_COL '= SUBSTRING(TEMP_COL, 1)
IF STRCOUNT(TEMP_COL, "[0-9a-fA-F]{6}$") == 1
	COLOR_STR '= "#" + TEMP_COL
	RETURNF 1
ENDIF
;设了默认值就肯定能传出合法值
IF DEFAULT_HEX > -1
	COLOR_STR '= HEX_TO_HTML_COLOR(DEFAULT_HEX)
	RETURNF 1
ENDIF
RETURNF 0

