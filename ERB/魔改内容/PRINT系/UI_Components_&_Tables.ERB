;-------------------------------------------------
; 模块化的通用 BASE 进度条
;-------------------------------------------------
;-------------------------------------------------
; 体力等属性的数值条
;-------------------------------------------------
@BASE_BAR(C_ID, BASE_NAME, BAR_LENGTH, COLOR_NAME, OP = "")
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM  DYNAMIC C_ID
#DIMS DYNAMIC BASE_NAME
#DIM  DYNAMIC BAR_LENGTH
#DIMS DYNAMIC COLOR_NAME
#DIMS DYNAMIC OP
#DIMS DYNAMIC HTML_STR
#DIMS DYNAMIC L_DISPLAY_NAME
L_DISPLAY_NAME '= HTML_PRINTFORM(BASE_TR(BASE_NAME), 4)
HTML_STR '= GET_BASE_BAR(C_ID, BASE_NAME, BAR_LENGTH, COLOR_NAME, L_DISPLAY_NAME, OP)
IF STRCOUNT(OP, "「改行」")
	HTML_PRINT HTML_STR
ELSE
	HTML_PRINT HTML_STR, 1
ENDIF

;-------------------------------------------------
; INFO用的改良型数值条
;-------------------------------------------------
@BASE_BAR_2(C_ID, BASE_NAME, BASE_NAME_SHORT, BAR_LENGTH, COLOR_NAME)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM  DYNAMIC C_ID
#DIMS DYNAMIC BASE_NAME
#DIMS DYNAMIC BASE_NAME_SHORT
#DIM  DYNAMIC BAR_LENGTH
#DIMS DYNAMIC COLOR_NAME
#DIM  DYNAMIC BASE_ID
#DIMS DYNAMIC L_DISPLAY_NAME
#DIMS DYNAMIC L_OP
#DIMS DYNAMIC HTML_STR

BASE_ID = GETNUM(BASE, BASE_NAME)
SIF BASE_ID < 0
	THROW 不存在BASE_NAME %BASE_NAME%

L_DISPLAY_NAME '= BASE_NAME_SHORT
L_OP '= "「显示当前值」「覆写样式」"
IF BASE_ID == GETNUM(BASE, "精力") && TALENT:C_ID:濃厚精液
	L_DISPLAY_NAME '= @"<font color='%HEX_TO_HTML_COLOR(C_CREAM)%'><b>%BASE_NAME_SHORT%</b></font>"
ELSEIF C_ID == MASTER && BASE_ID == GETNUM(BASE, "酒気") && TFLAG:酔い止め
	L_DISPLAY_NAME '= @"<font color='%HEX_TO_HTML_COLOR(C_D_RED)%'><b>%BASE_NAME_SHORT%</b></font>"
ENDIF
HTML_STR '= GET_BASE_BAR(C_ID, BASE_NAME, BAR_LENGTH, COLOR_NAME, L_DISPLAY_NAME, L_OP)
HTML_PRINT HTML_STR, 1


@GET_BASE_BAR(C_ID, BASE_NAME, BAR_LENGTH, COLOR_NAME, DISPLAY_NAME, OP = "")
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIM  DYNAMIC C_ID
#DIMS DYNAMIC BASE_NAME
#DIM  DYNAMIC BAR_LENGTH
#DIMS DYNAMIC COLOR_NAME
#DIMS DYNAMIC DISPLAY_NAME ; 要显示的文本 (可能已包含 HTML)
#DIMS DYNAMIC OP
#DIM  DYNAMIC BASE_ID
#DIMS DYNAMIC RES_HTML
#DIM  DYNAMIC NUM_COLOR
#DIM  DYNAMIC BAR_COLOR
#DIM  DYNAMIC BG_COLOR
#DIM  DYNAMIC TEXT_COLOR
TEXT_COLOR = GETCOLOR()
BASE_ID = GETNUM(BASE, BASE_NAME)
SIF BASE_ID < 0
	RETURNF @"[错误:不存在的BASE_%BASE_NAME%]"

IF !STRCOUNT(OP, "「種類表記無し」")
	IF STRCOUNT(OP, "「覆写样式」")
		RES_HTML += DISPLAY_NAME
	ELSE
		IF GROUPMATCH(BASE_ID, 0, 1, 6, 8)
			IF GETPERCENT(BASE:C_ID:BASE_ID - (BASE_ID == 0 ? 500 # 0), MAXBASE:C_ID:BASE_ID) < 25
				TEXT_COLOR = C_RED
			ELSEIF GETPERCENT(BASE:C_ID:BASE_ID - (BASE_ID == 0 ? 500 # 0), MAXBASE:C_ID:BASE_ID) < 50
				TEXT_COLOR = C_YELLOW
			ENDIF
		ENDIF
		RES_HTML += @"<font color='%HEX_TO_HTML_COLOR(TEXT_COLOR)%'>%DISPLAY_NAME%</font>"
	ENDIF
ENDIF
RES_HTML += @"<shape type='space' param='2px'>%QOL_HTML_BARSTR(BASE:C_ID:BASE_ID, MAXBASE:C_ID:BASE_ID, BAR_LENGTH, BARCOLORSET(COLOR_NAME), RESULT:1, UNICODE(0x2585), UNICODE(0x2585))%<shape type='space' param='2px'>"

IF !STRCOUNT(OP, "「数字表記無し」")
	NUM_COLOR = GETCOLOR()
	IF BUFF:C_ID:BASE_ID > 0
		NUM_COLOR = C_AQUA
	ELSEIF BUFF:C_ID:BASE_ID < 0
		NUM_COLOR = C_YELLOW
	ENDIF
	
	RES_HTML += @"<font color='%HEX_TO_HTML_COLOR(NUM_COLOR)%'>"
	IF STRCOUNT(OP, "「显示当前值」")
		IF !MAGIC_DLC
			RES_HTML += @"({BASE:C_ID:BASE_ID, 5})"
		ELSE
			RES_HTML += @"({BASE:C_ID:BASE_ID, 7})"
		ENDIF
	ELSE ;默认是显示「当前值/最大值」
		IF !MAGIC_DLC
			RES_HTML += @"({BASE:C_ID:BASE_ID,5}/{MAXBASE:C_ID:BASE_ID,5})"
		ELSE
			RES_HTML += @" ({BASE:C_ID:BASE_ID,7}/{MAXBASE:C_ID:BASE_ID,7})"
		ENDIF
	ENDIF
	RES_HTML += "</font>"
ENDIF
RETURNF RES_HTML

;-------------------------------------------------
;函数名：COLOR_BAR
;概  述：生成带RGB/HSV渐变的彩色进度条（HTML版）
;       以字符形式（前景▂ + 背景▁）显示比例，支持线性渐变尾部
;       原版基于RGB直接偏移，现已转换为内部HSV渐变（更自然、色相稳定）
;参  数：
;   VAL         - 当前值
;   MAX_VAL     - 最大值（用于计算填充比例）
;   L_LEN       - 进度条总长度（字符数，建议 10~60）
;                 默认 20
;   L_R,L_G,L_B - 基准前景色（RGB 0~255）
;                 默认 160,160,160 → 中性灰
;   L_BG_DIFF   - 背景色相对于前景色的亮度差（通常负值表示更暗）
;                 默认 -80
;   L_GR_R      - 渐变在R通道的每单位长度增量（通常小值或0）
;   L_GR_G      - G通道渐变增量
;   L_GR_B      - B通道渐变增量
;                 三者默认全0 → 无渐变；设为正/负值可制造彩虹尾或冷暖渐变
;   L_GR_FREQ   - 渐变频率（值越大，渐变段越短/变化越快）
;                 默认 1；建议 0.5~4
;   COLOR_FG    - 前景填充字符（默认 "▂"）
;   COLOR_BG    - 背景空字符（默认 "▁"）
;返回值：固定返回 1（表示成功调用HTML_PRINT）
;       直接通过 HTML_PRINT 输出带颜色的字符条
;-------------------------------------------------
; 视觉效果说明：
;   • 前 L_LEN * (VAL/MAX_VAL) 个字符用前景色（从基准色开始）
;   • 剩余部分用背景色（通常比前景暗 L_BG_DIFF）
;   • 最右侧一小段（长度 ≈ L_LEN / L_GR_FREQ）会应用线性渐变
;     渐变基于 HSV 空间计算，更自然（不会出现 RGB 直调时的色偏/过曝）
;   • 典型用法：
;       - 无渐变：L_GR_R=G=B=0 → 纯色条 + 暗背景
;       - 彩虹尾：L_GR_R=15, L_GR_G=-20, L_GR_B=30, L_GR_FREQ=2
;       - 冷→暖：L_GR_R=40, L_GR_G=10, L_GR_B=-30
;-------------------------------------------------
; 使用示例：
;   COLOR_BAR HP, MHP                     ; 默认灰色纯色条
;   COLOR_BAR MP, MMP, 30, 100,180,220    ; 偏蓝色的较长条
;   COLOR_BAR EXP, NEXTEXP, 25, 255,180,60, -100, 30, -20, 10, 1.5
;       → 橙黄基准 → 尾部带彩虹渐变（R↑ G↓ B↑）
;   COLOR_BAR 75, 100, 40, 0,255,0, -120, 0,0,0   ; 纯绿色条，背景很暗
;   COLOR_BAR 999, 500, 20, 255,100,100, -60, 20,40,-10, 0.8
;       → 红色基准 → 尾部偏紫彩虹感
;-------------------------------------------------
@COLOR_BAR(VAL, MAX_VAL, L_LEN=20, L_R=160, L_G=160, L_B=160, L_BG_DIFF=-80, L_GR_R=0, L_GR_G=0, L_GR_B=0, L_GR_FREQ=1, COLOR_FG="▂", COLOR_BG="▁")
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC VAL
#DIM DYNAMIC MAX_VAL
#DIM DYNAMIC L_LEN
#DIM DYNAMIC L_GR_LEN
#DIM DYNAMIC L_R
#DIM DYNAMIC L_G
#DIM DYNAMIC L_B
#DIM DYNAMIC L_BG_DIFF
#DIM DYNAMIC L_GR_R
#DIM DYNAMIC L_GR_G
#DIM DYNAMIC L_GR_B
#DIM DYNAMIC L_GR_FREQ
#DIMS DYNAMIC COLOR_FG
#DIMS DYNAMIC COLOR_BG
#DIM DYNAMIC L_FG_C1
#DIM DYNAMIC L_BG_C
#DIM DYNAMIC L_FG_C2

; 防止除以0错误
IF L_GR_FREQ == 0
    L_GR_FREQ = 1
ENDIF

L_GR_LEN = L_LEN * VAL / MAX_VAL / L_GR_FREQ
L_FG_C1 = RGB_TO_HEX(LIMIT(L_R, 0, 255), LIMIT(L_G, 0, 255), LIMIT(L_B, 0, 255))
L_BG_C = RGB_TO_HEX(LIMIT(L_R + L_BG_DIFF, 0, 255), LIMIT(L_G + L_BG_DIFF, 0, 255), LIMIT(L_B + L_BG_DIFF, 0, 255))
L_FG_C2 = RGB_TO_HEX(LIMIT(L_R + L_GR_R * L_GR_LEN, 0, 255), LIMIT(L_G + L_GR_G * L_GR_LEN, 0, 255), LIMIT(L_B + L_GR_B * L_GR_LEN, 0, 255))

HTML_PRINT QOL_HTML_BARSTR(VAL, MAX_VAL, L_LEN, L_FG_C1, L_BG_C, COLOR_FG, COLOR_BG, L_FG_C2), 1
RETURN 1

