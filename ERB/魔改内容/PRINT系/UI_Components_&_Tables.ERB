;==============================================================================
; UI组件 —— 分割线 (核心构建模块)
;==============================================================================

;-------------------------------------------------
; 核心模块1：基于字符的分割线 (Text-based Line)
; 概  述：生成由字符组成的分割线，支持中间嵌入文本
; 参  数：L_CENTER_TEXT - 中间嵌入的文本（可为空）
;         L_PAD_CHAR    - 两侧填充的字符（默认 "-"）
;         L_TOTAL_W_PX  - 总像素宽度（默认 -1 为全屏宽度）
;         L_COLOR       - 颜色（默认 -1 为当前颜色）
; 返回值：HTML 字符串
;-------------------------------------------------
@HTML_STR_LINE(L_CENTER_TEXT = "", L_PAD_CHAR = "-", L_TOTAL_W_PX = -1, L_COLOR = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC L_CENTER_TEXT
#DIMS DYNAMIC L_PAD_CHAR
#DIM DYNAMIC L_TOTAL_W_PX
#DIM DYNAMIC L_COLOR
#DIM DYNAMIC L_TEXT_W
#DIM DYNAMIC L_PAD_W
#DIMS DYNAMIC L_RES

SIF L_TOTAL_W_PX <= 0
	L_TOTAL_W_PX = MAXWIDTH_PX()
SIF L_COLOR == -1
	L_COLOR = GETCOLOR()

L_TEXT_W = HTML_STRINGLEN(L_CENTER_TEXT, 1)
L_TOTAL_W_PX = MAX(L_TOTAL_W_PX, L_TEXT_W)
L_PAD_W = (L_TOTAL_W_PX - L_TEXT_W) / 2

; 利用现有的 HTML_FILL_LINE 进行像素级双侧填充
L_RES '= HTML_FILL_LINE("", L_PAD_CHAR, L_PAD_W) + L_CENTER_TEXT + HTML_FILL_LINE("", L_PAD_CHAR, L_TOTAL_W_PX - L_TEXT_W - L_PAD_W)

RETURNF @"<font color='%HEX_TO_HTML_COLOR(L_COLOR)%'>%L_RES%</font>"

;-------------------------------------------------
; 核心模块2：基于 Shape 的分割线 (Shape-based Line)
; 概  述：生成由 <shape> 标签构成的像素级分割线，支持多种渐变样式
; 参  数：L_TOTAL_W_PX - 总像素宽度（默认 -1 为全屏宽度）
;         L_THICK      - 线条厚度（像素，默认 10）
;         L_BASE_C     - 基准颜色（默认 -1 为当前颜色）
;         L_STYLE      - 样式：0=纯色, 1=向右淡出, 2=向左淡出(反向淡入), 3=向两侧淡出(中间亮)
;         L_Y_OFFSET   - Y轴偏移量（默认 45，适合单行文本居中）
; 返回值：HTML 字符串
;-------------------------------------------------
@HTML_SHAPE_LINE(L_TOTAL_W_PX = -1, L_THICK = 10, L_BASE_C = -1, L_STYLE = 0, L_Y_OFFSET = 45)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIM DYNAMIC L_TOTAL_W_PX
#DIM DYNAMIC L_THICK
#DIM DYNAMIC L_BASE_C
#DIM DYNAMIC L_STYLE
#DIM DYNAMIC L_Y_OFFSET

#DIM DYNAMIC L_HSV
#DIM DYNAMIC L_H
#DIM DYNAMIC L_S
#DIM DYNAMIC L_V
#DIM DYNAMIC L_FADE_STEPS
#DIM DYNAMIC L_SOLID_W
#DIM DYNAMIC L_CUR_V
#DIM DYNAMIC L_CUR_H
#DIMS DYNAMIC L_RES

SIF L_TOTAL_W_PX <= 0
	L_TOTAL_W_PX = MAXWIDTH_PX()
SIF L_BASE_C == -1
	L_BASE_C = GETDEFCOLOR()

L_HSV = RGB_TO_HSV(L_BASE_C)
L_H = (L_HSV >> 16) & 0x1FF
L_S = (L_HSV >> 8) & 0xFF
L_V = L_HSV & 0xFF

L_FADE_STEPS = L_V / 5

SELECTCASE L_STYLE
	CASE 0 ; 纯色
		L_RES '= @"<shape type='rect' param='0,{L_Y_OFFSET},{L_TOTAL_W_PX},{L_THICK}' color='%HEX_TO_HTML_COLOR(L_BASE_C)%'>"
		
	CASE 1 ; 向右淡出 (COLOR_LINE 默认)
		L_SOLID_W = MAX(L_TOTAL_W_PX - (L_FADE_STEPS * 100), 100)
		L_RES += @"<shape type='rect' param='0,{L_Y_OFFSET},{L_SOLID_W},{L_THICK}' color='%HEX_TO_HTML_COLOR(L_BASE_C)%'>"
		L_CUR_V = L_V
		L_CUR_H = L_H
		FOR LOCAL, 0, L_FADE_STEPS
			L_CUR_V = MAX(L_CUR_V - 5, 0)
			SIF LOCAL % 3 == 0
				L_CUR_H = (L_CUR_H + 1) % 360
			L_RES += @"<shape type='rect' param='0,{L_Y_OFFSET},100,{L_THICK}' color='%HEX_TO_HTML_COLOR(HSV_TO_RGB((L_CUR_H << 16) | (L_S << 8) | L_CUR_V))%'>"
		NEXT
		
	CASE 2 ; 向左淡出 / 反向淡入 (COLOR_LINE L_REV=1)
		L_SOLID_W = MAX(L_TOTAL_W_PX - (L_FADE_STEPS * 100), 100)
		L_CUR_V = MAX(L_V - (L_FADE_STEPS * 5), 0)
		L_CUR_H = L_H - (L_FADE_STEPS / 3)
		SIF L_CUR_H < 0
			L_CUR_H += 360
		FOR LOCAL, 0, L_FADE_STEPS
			L_CUR_V = MIN(L_CUR_V + 5, L_V)
			SIF LOCAL % 3 == 0
				L_CUR_H = (L_CUR_H + 1) % 360
			L_RES += @"<shape type='rect' param='0,{L_Y_OFFSET},100,{L_THICK}' color='%HEX_TO_HTML_COLOR(HSV_TO_RGB((L_CUR_H << 16) | (L_S << 8) | L_CUR_V))%'>"
		NEXT
		L_RES += @"<shape type='rect' param='0,{L_Y_OFFSET},{L_SOLID_W},{L_THICK}' color='%HEX_TO_HTML_COLOR(L_BASE_C)%'>"
		
	CASE 3 ; 向两侧淡出 (FADELINE 风格)
		L_SOLID_W = MAX(L_TOTAL_W_PX - (L_FADE_STEPS * 200), 100)
		; 左侧淡入
		L_CUR_V = MAX(L_V - (L_FADE_STEPS * 5), 0)
		L_CUR_H = L_H - (L_FADE_STEPS / 3)
		SIF L_CUR_H < 0
			L_CUR_H += 360
		FOR LOCAL, 0, L_FADE_STEPS
			L_CUR_V = MIN(L_CUR_V + 5, L_V)
			SIF LOCAL % 3 == 0
				L_CUR_H = (L_CUR_H + 1) % 360
			L_RES += @"<shape type='rect' param='0,{L_Y_OFFSET},100,{L_THICK}' color='%HEX_TO_HTML_COLOR(HSV_TO_RGB((L_CUR_H << 16) | (L_S << 8) | L_CUR_V))%'>"
		NEXT
		; 中间实线
		L_RES += @"<shape type='rect' param='0,{L_Y_OFFSET},{L_SOLID_W},{L_THICK}' color='%HEX_TO_HTML_COLOR(L_BASE_C)%'>"
		; 右侧淡出
		L_CUR_V = L_V
		L_CUR_H = L_H
		FOR LOCAL, 0, L_FADE_STEPS
			L_CUR_V = MAX(L_CUR_V - 5, 0)
			SIF LOCAL % 3 == 0
				L_CUR_H = (L_CUR_H + 1) % 360
			L_RES += @"<shape type='rect' param='0,{L_Y_OFFSET},100,{L_THICK}' color='%HEX_TO_HTML_COLOR(HSV_TO_RGB((L_CUR_H << 16) | (L_S << 8) | L_CUR_V))%'>"
		NEXT
ENDSELECT

RETURNF L_RES

;==============================================================================
; UI组件 —— 渲染工具 (封装层)
;==============================================================================

;-------------------------------------------------
; 函数名：D_LINE
; 概  述：打印系统默认颜色的分割线（使用字符 "-"）
; 备  注：保护当前调用颜色，调用默认色打印
;-------------------------------------------------
@D_LINE
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_OLD_C
L_OLD_C = GETCOLOR()
RESETCOLOR
DRAWLINE
SETCOLOR L_OLD_C

;-------------------------------------------------
; 函数名：CENTERLINE
; 概  述：在屏幕中央绘制一条贯穿整个屏幕的水平灰色分割线（使用字符 "─"）
;-------------------------------------------------
@CENTERLINE
#LOCALSIZE 1
#LOCALSSIZE 1
HTML_PRINT HTML_STR_LINE("", "─", -1, C_GRAY)

;-------------------------------------------------
; 函数名：LINECENTER
; 概  述：在屏幕上打印一段居中的文字，并在文字两侧使用指定字符填充作为装饰线
; 参  数：L_STR       - 要居中显示的文字字符串
;         L_PAD_CHAR  - 两侧填充的装饰字符（默认 "-"）
;         L_TOTAL_W   - 总字符宽度（默认 32；≤0 时使用全屏宽度）
; 返回值：无
;-------------------------------------------------
@LINECENTER(L_STR, L_PAD_CHAR = "-", L_TOTAL_W = 32)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIMS DYNAMIC L_PAD_CHAR
#DIM DYNAMIC L_TOTAL_W
#DIM DYNAMIC L_TOTAL_W_PX

IF L_TOTAL_W > 0
	L_TOTAL_W_PX = TO_PXWIDTH(L_TOTAL_W)
ELSE
	L_TOTAL_W_PX = MAXWIDTH_PX()
ENDIF
HTML_PRINT HTMLP(HTML_STR_LINE(L_STR, L_PAD_CHAR, L_TOTAL_W_PX), "center")

;-------------------------------------------------
; 函数名：FADELINE
; 概  述：绘制一条中间明亮、向两侧亮度渐弱的装饰性粗分割线（Style 3）
; 参  数：L_BASE_C - 基准颜色（<=0 时自动使用 0xDDDDDD 浅灰色）
; 返回值：无
;-------------------------------------------------
@FADELINE(L_BASE_C = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_BASE_C
IF L_BASE_C <= 0
	L_BASE_C = 0xDDDDDD
ENDIF
HTML_PRINT HTMLP(HTML_SHAPE_LINE(-1, 20, L_BASE_C, 3, 30), "center")

;-------------------------------------------------
; 函数名：COLOR_LINE
; 概  述：绘制一条支持彩色/渐变效果的分割线（调用 HTML_SHAPE_LINE 实现）
; 参  数：L_THICK   - 线条厚度倍数（默认 1，对应 10 像素）
;         L_BASE_C  - 基准颜色（默认 -1 为当前颜色）
;         L_LINE_W  - 总宽度（字符数，默认 -1 表示全屏宽度）
;         L_REV     - 渐变方向（0=向右淡出，1=向左淡出/反向淡入，默认 0）
; 返回值：0
;-------------------------------------------------
@COLOR_LINE(L_THICK = 1, L_BASE_C = -1, L_LINE_W = -1, L_REV = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_THICK
#DIM DYNAMIC L_BASE_C
#DIM DYNAMIC L_LINE_W
#DIM DYNAMIC L_REV
#DIM DYNAMIC L_LINE_W_PX
#DIM DYNAMIC L_STYLE

IF L_LINE_W == -1
	L_LINE_W_PX = -1
ELSE
	L_LINE_W_PX = TO_PXWIDTH(L_LINE_W)
ENDIF
L_STYLE = L_REV ? 2 # 1

HTML_PRINT HTML_SHAPE_LINE(L_LINE_W_PX, L_THICK * 10, L_BASE_C, L_STYLE)
RETURN 0

;-------------------------------------------------
; 滑块面板 的 HTML实现
;-------------------------------------------------
@HTML_PRINT_RGB_SLIDER(L_BASE_C)
	#LOCALSIZE 1
	#LOCALSSIZE 1
	#DIM L_BASE_C
	#DIM DYNAMIC L_VAL_ARR, 3  ; 存储当前颜色的 R, G, B 值
	#DIMS CONST L_TAG_ARR = "R", "G", "B"
	#DIMS DYNAMIC L_HTML_ARR
	
	#DIM DYNAMIC L_I_DIM       ; 维度索引 (0=R, 1=G, 2=B)
	#DIM DYNAMIC L_I_STEP      ; 步进索引 (0~255)
	
	#DIM DYNAMIC L_TARGET_WIDTH
	#DIM DYNAMIC L_DRAWN_W
	#DIM DYNAMIC L_NEXT_W
	#DIM DYNAMIC L_STEP_W
	#DIM DYNAMIC L_CUR_C
	
	L_VAL_ARR:0 = HEX_R(L_BASE_C)
	L_VAL_ARR:1 = HEX_G(L_BASE_C)
	L_VAL_ARR:2 = HEX_B(L_BASE_C)
	
	L_TARGET_WIDTH = MAX(MAXWIDTH() * 50 * 3 / 4, 1000)

	FOR L_I_DIM, 0, 3
		L_HTML_ARR = <nonbutton> %L_TAG_ARR:L_I_DIM%({L_VAL_ARR:L_I_DIM, 3}/255): </nonbutton>
		
		L_DRAWN_W = 0
		FOR L_I_STEP, 0, 256
			; 计算自适应宽度
			L_NEXT_W = L_TARGET_WIDTH * (L_I_STEP + 1) / 256
			L_STEP_W = L_NEXT_W - L_DRAWN_W
			L_DRAWN_W = L_NEXT_W

			; 根据当前维度生成对应的 Hex 颜色
			SELECTCASE L_I_DIM
				CASE 0 ; R 变化，G B 固定
					L_CUR_C = RGB_TO_HEX(L_I_STEP, L_VAL_ARR:1, L_VAL_ARR:2)
				CASE 1 ; G 变化，R B 固定
					L_CUR_C = RGB_TO_HEX(L_VAL_ARR:0, L_I_STEP, L_VAL_ARR:2)
				CASE 2 ; B 变化，R G 固定
					L_CUR_C = RGB_TO_HEX(L_VAL_ARR:0, L_VAL_ARR:1, L_I_STEP)
			ENDSELECT

			; 生成按钮 (高亮判定)
			IF L_I_STEP == L_VAL_ARR:L_I_DIM
				L_HTML_ARR += @"<button value='{L_CUR_C}' title='%L_TAG_ARR:L_I_DIM%:{L_I_STEP} / %HEX_TO_HTML_COLOR(L_CUR_C)%'><shape type='rect' param='0,15,{L_STEP_W},100' color='#FFD700'></button>"
			ELSE
				L_HTML_ARR += @"<button value='{L_CUR_C}' title='%L_TAG_ARR:L_I_DIM%:{L_I_STEP} / %HEX_TO_HTML_COLOR(L_CUR_C)%'><shape type='rect' param='0,25,{L_STEP_W},80' color='%HEX_TO_HTML_COLOR(L_CUR_C)%'></button>"
			ENDIF
		NEXT
		HTML_PRINT L_HTML_ARR
	NEXT

@HTML_PRINT_HSB_SLIDER(L_BASE_C)
	#LOCALSIZE 1
	#LOCALSSIZE 1
	#DIM L_BASE_C
	#DIM DYNAMIC L_HSV
	#DIM DYNAMIC L_VAL_ARR, 3
	#DIMS CONST L_TAG_ARR = "H", "S", "V"
	#DIM CONST L_MAX_VAL_ARR = 360, 256, 256
	#DIMS DYNAMIC L_HTML_ARR
	#DIM DYNAMIC L_I_DIM
	#DIM DYNAMIC L_I_STEP
	
	#DIM DYNAMIC L_TARGET_WIDTH
	#DIM DYNAMIC L_DRAWN_W
	#DIM DYNAMIC L_NEXT_W
	#DIM DYNAMIC L_STEP_W
	#DIM DYNAMIC L_CUR_C
	
	; 1. 初始化数据
	L_HSV = RGB_TO_HSV(L_BASE_C)
	L_VAL_ARR:0 = (L_HSV >> 16) & 0x1FF ; H
	L_VAL_ARR:1 = (L_HSV >> 8) & 0xFF   ; S
	L_VAL_ARR:2 = L_HSV & 0xFF          ; V
		
	L_TARGET_WIDTH = MAX(MAXWIDTH() * 50 * 3 / 4, 1000)

	; 2. 并行生成
	FOR L_I_DIM, 0, 3
		L_HTML_ARR = <nonbutton> %L_TAG_ARR:L_I_DIM%({L_VAL_ARR:L_I_DIM, 3}/{L_MAX_VAL_ARR:L_I_DIM}): </nonbutton>
		
		L_DRAWN_W = 0
		FOR L_I_STEP, 0, L_MAX_VAL_ARR:L_I_DIM
			L_NEXT_W = L_TARGET_WIDTH * (L_I_STEP + 1) / L_MAX_VAL_ARR:L_I_DIM
			L_STEP_W = L_NEXT_W - L_DRAWN_W
			L_DRAWN_W = L_NEXT_W

			; 根据当前维度生成 HSV 并转为 RGB Hex
			SELECTCASE L_I_DIM
				CASE 0 ; H 变化
					L_CUR_C = HSV_TO_RGB((L_I_STEP << 16) | (L_VAL_ARR:1 << 8) | L_VAL_ARR:2)
				CASE 1 ; S 变化
					L_CUR_C = HSV_TO_RGB((L_VAL_ARR:0 << 16) | (L_I_STEP << 8) | L_VAL_ARR:2)
				CASE 2 ; V 变化
					L_CUR_C = HSV_TO_RGB((L_VAL_ARR:0 << 16) | (L_VAL_ARR:1 << 8) | L_I_STEP)
			ENDSELECT

			IF L_I_STEP == L_VAL_ARR:L_I_DIM
				L_HTML_ARR += @"<button value='{L_CUR_C}' title='%L_TAG_ARR:L_I_DIM%:{L_I_STEP} / %HEX_TO_HTML_COLOR(L_CUR_C)%'><shape type='rect' param='0,15,{L_STEP_W},100' color='#FFD700'></button>"
			ELSE
				L_HTML_ARR += @"<button value='{L_CUR_C}' title='%L_TAG_ARR:L_I_DIM%:{L_I_STEP} / %HEX_TO_HTML_COLOR(L_CUR_C)%'><shape type='rect' param='0,25,{L_STEP_W},80' color='%HEX_TO_HTML_COLOR(L_CUR_C)%'></button>"
			ENDIF
		NEXT

		HTML_PRINT L_HTML_ARR
	NEXT
