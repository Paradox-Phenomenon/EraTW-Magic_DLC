;-------------------------------------------------
;[排版工具] 计算包含 Shape 的 HTML 字符串显示长度
; 长度单位：半角字符 (1个全角 = 2个半角 = Emuera 100 单位)
;-------------------------------------------------
@HTML_STRLENS(L_HTML_STR)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIMS L_HTML_STR
#DIM DYNAMIC L_TOTAL_LEN
#DIM DYNAMIC L_TAG_COUNT
#DIMS DYNAMIC L_TAG
#DIMS DYNAMIC L_PARAM_ARR, 5
#DIM DYNAMIC L_SHAPE_WIDTH

L_TOTAL_LEN = STRLENS(HTML_TOPLAINTEXT(L_HTML_STR))

HTML_TAGSPLIT L_HTML_STR, RESULTS, L_TAG_COUNT

FOR I, 0, L_TAG_COUNT
	L_TAG = %RESULTS:I%
	
	; 如果是图片标签，就最好不要用
	; (如配置了具体宽高的 img，需要根据你游戏的 img 规范调整)
	;IF STRFIND(L_TAG, "<img") > -1
	;	L_TOTAL_LEN += 2
		
	; 如果是shape标签
	IF STRFIND(L_TAG, "<shape") > -1
		; 提取 param='...' 的内容
		SPLIT L_TAG, "param='", L_PARAM_ARR, LOCAL
		IF LOCAL > 1
			SPLIT L_PARAM_ARR:1, "'", L_PARAM_ARR, LOCAL
			; 解析 param 的 x,y,width,height
			SPLIT L_PARAM_ARR:0, ",", L_PARAM_ARR, LOCAL
			IF LOCAL >= 3
				L_SHAPE_WIDTH = TOINT(REPLACE(L_PARAM_ARR:2, " ", ""))
				L_TOTAL_LEN += L_SHAPE_WIDTH / 50
			ENDIF
		ENDIF
	ENDIF
NEXT

RETURNF L_TOTAL_LEN

;-------------------------------------------------
; 滑块面板 的 HTML实现
;-------------------------------------------------
@HTML_PRINT_RGB_SLIDER(L_BASE_C)
	#LOCALSIZE 1
	#LOCALSSIZE 1
	#DIM L_BASE_C
	#DIM DYNAMIC L_VAL_ARR, 3  ; 存储当前颜色的 R, G, B 值
	#DIMS CONST L_TAG_ARR = "R", "G", "B"
	#DIMS DYNAMIC L_HTML_ARR
	
	#DIM DYNAMIC L_I_DIM       ; 维度索引 (0=R, 1=G, 2=B)
	#DIM DYNAMIC L_I_STEP      ; 步进索引 (0~255)
	
	#DIM DYNAMIC L_TARGET_WIDTH
	#DIM DYNAMIC L_DRAWN_W
	#DIM DYNAMIC L_NEXT_W
	#DIM DYNAMIC L_STEP_W
	#DIM DYNAMIC L_CUR_C
	
	L_VAL_ARR:0 = HEX_R(L_BASE_C)
	L_VAL_ARR:1 = HEX_G(L_BASE_C)
	L_VAL_ARR:2 = HEX_B(L_BASE_C)
	
	L_TARGET_WIDTH = MAX(MAXWIDTH() * 50 * 3 / 4, 1000)

	FOR L_I_DIM, 0, 3
		L_HTML_ARR = <nonbutton> %L_TAG_ARR:L_I_DIM%({L_VAL_ARR:L_I_DIM, 3}/255): </nonbutton>
		
		L_DRAWN_W = 0
		FOR L_I_STEP, 0, 256
			; 计算自适应宽度
			L_NEXT_W = L_TARGET_WIDTH * (L_I_STEP + 1) / 256
			L_STEP_W = L_NEXT_W - L_DRAWN_W
			L_DRAWN_W = L_NEXT_W

			; 根据当前维度生成对应的 Hex 颜色
			SELECTCASE L_I_DIM
				CASE 0 ; R 变化，G B 固定
					L_CUR_C = RGB_TO_HEX(L_I_STEP, L_VAL_ARR:1, L_VAL_ARR:2)
				CASE 1 ; G 变化，R B 固定
					L_CUR_C = RGB_TO_HEX(L_VAL_ARR:0, L_I_STEP, L_VAL_ARR:2)
				CASE 2 ; B 变化，R G 固定
					L_CUR_C = RGB_TO_HEX(L_VAL_ARR:0, L_VAL_ARR:1, L_I_STEP)
			ENDSELECT

			; 生成按钮 (高亮判定)
			IF L_I_STEP == L_VAL_ARR:L_I_DIM
				L_HTML_ARR += @"<button value='{L_CUR_C}' title='%L_TAG_ARR:L_I_DIM%:{L_I_STEP} / %HEX_TO_HTML_COLOR(L_CUR_C)%'><shape type='rect' param='0,15,{L_STEP_W},100' color='#FFD700'></button>"
			ELSE
				L_HTML_ARR += @"<button value='{L_CUR_C}' title='%L_TAG_ARR:L_I_DIM%:{L_I_STEP} / %HEX_TO_HTML_COLOR(L_CUR_C)%'><shape type='rect' param='0,25,{L_STEP_W},80' color='%HEX_TO_HTML_COLOR(L_CUR_C)%'></button>"
			ENDIF
		NEXT
		HTML_PRINT L_HTML_ARR
	NEXT

@HTML_PRINT_HSB_SLIDER(L_BASE_C)
	#LOCALSIZE 1
	#LOCALSSIZE 1
	#DIM L_BASE_C
	#DIM DYNAMIC L_HSV
	#DIM DYNAMIC L_VAL_ARR, 3
	#DIMS CONST L_TAG_ARR = "H", "S", "V"
	#DIM CONST L_MAX_VAL_ARR = 360, 256, 256
	#DIMS DYNAMIC L_HTML_ARR
	#DIM DYNAMIC L_I_DIM
	#DIM DYNAMIC L_I_STEP
	
	#DIM DYNAMIC L_TARGET_WIDTH
	#DIM DYNAMIC L_DRAWN_W
	#DIM DYNAMIC L_NEXT_W
	#DIM DYNAMIC L_STEP_W
	#DIM DYNAMIC L_CUR_C
	
	; 1. 初始化数据
	L_HSV = RGB_TO_HSV(L_BASE_C)
	L_VAL_ARR:0 = (L_HSV >> 16) & 0x1FF ; H
	L_VAL_ARR:1 = (L_HSV >> 8) & 0xFF   ; S
	L_VAL_ARR:2 = L_HSV & 0xFF          ; V
		
	L_TARGET_WIDTH = MAX(MAXWIDTH() * 50 * 3 / 4, 1000)

	; 2. 并行生成
	FOR L_I_DIM, 0, 3
		L_HTML_ARR = <nonbutton> %L_TAG_ARR:L_I_DIM%({L_VAL_ARR:L_I_DIM, 3}/{L_MAX_VAL_ARR:L_I_DIM}): </nonbutton>
		
		L_DRAWN_W = 0
		FOR L_I_STEP, 0, L_MAX_VAL_ARR:L_I_DIM
			L_NEXT_W = L_TARGET_WIDTH * (L_I_STEP + 1) / L_MAX_VAL_ARR:L_I_DIM
			L_STEP_W = L_NEXT_W - L_DRAWN_W
			L_DRAWN_W = L_NEXT_W

			; 根据当前维度生成 HSV 并转为 RGB Hex
			SELECTCASE L_I_DIM
				CASE 0 ; H 变化
					L_CUR_C = HSV_TO_RGB((L_I_STEP << 16) | (L_VAL_ARR:1 << 8) | L_VAL_ARR:2)
				CASE 1 ; S 变化
					L_CUR_C = HSV_TO_RGB((L_VAL_ARR:0 << 16) | (L_I_STEP << 8) | L_VAL_ARR:2)
				CASE 2 ; V 变化
					L_CUR_C = HSV_TO_RGB((L_VAL_ARR:0 << 16) | (L_VAL_ARR:1 << 8) | L_I_STEP)
			ENDSELECT

			IF L_I_STEP == L_VAL_ARR:L_I_DIM
				L_HTML_ARR += @"<button value='{L_CUR_C}' title='%L_TAG_ARR:L_I_DIM%:{L_I_STEP} / %HEX_TO_HTML_COLOR(L_CUR_C)%'><shape type='rect' param='0,15,{L_STEP_W},100' color='#FFD700'></button>"
			ELSE
				L_HTML_ARR += @"<button value='{L_CUR_C}' title='%L_TAG_ARR:L_I_DIM%:{L_I_STEP} / %HEX_TO_HTML_COLOR(L_CUR_C)%'><shape type='rect' param='0,25,{L_STEP_W},80' color='%HEX_TO_HTML_COLOR(L_CUR_C)%'></button>"
			ENDIF
		NEXT

		HTML_PRINT L_HTML_ARR
	NEXT
