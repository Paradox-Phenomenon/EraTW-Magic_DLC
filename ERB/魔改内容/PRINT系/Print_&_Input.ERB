@PRINT_RANK(VAR_VALUE, RANK_SCALE)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM  DYNAMIC VAR_VALUE  ;評価対象数値
#DIMS DYNAMIC RANK_SCALE ;評価に使用する尺度の種類
HTML_PRINT GET_RANK_HTML(VAR_VALUE, RANK_SCALE), 1

@GET_RANK_HTML(VAR_VALUE, RANK_SCALE)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIM	DYNAMIC VAR_VALUE
#DIMS	DYNAMIC RANK_SCALE
#DIM	DYNAMIC RANK
#DIM	DYNAMIC RANK_NUM
CALLF CALC_RANK(VAR_VALUE, RANK_SCALE, RANK, RANK_NUM)
RETURNF GET_ALPHABET_HTML(RANK, RANK_NUM)

@PRINT_ALPHABET(RANK, RANK_NUM, ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC RANK
#DIM DYNAMIC RANK_NUM
HTML_PRINT GET_ALPHABET_HTML(RANK, RANK_NUM, ARG), 1

@GET_ALPHABET_HTML(RANK, RANK_NUM, ARG = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIM DYNAMIC RANK
#DIM DYNAMIC RANK_NUM
#DIMS CONST STR_RANK10, 10 = "Ex", "SS", " S", " A", " B", " C", " D", " E", " F", " G"
#DIMS CONST STR_RANK7,   7 = "Ex", " S", " A", " B", " C", " D", " E"
#DIMS CONST STR_RANK10_F, 10 = "ＳＳＳ", "ＳＳ", "Ｓ", "Ａ", "Ｂ", "Ｃ", "Ｄ", "Ｅ", "Ｆ", "Ｇ"
#DIMS CONST STR_RANK7_F,   7 = "ＥＸ", "Ｓ", "Ａ", "Ｂ", "Ｃ", "Ｄ", "Ｅ"
#DIM  CONST C_RANK10, 10 = C_P_PURPLE, C_WHITE, C_WHITE, C_PINK, C_RED, C_ORANGE, C_YELLOW, C_GREEN, C_AQUA, C_GRAY
#DIM  CONST C_RANK7,   7 = C_P_PURPLE, C_WHITE, C_PINK, C_RED, C_ORANGE, C_YELLOW, C_GRAY
#DIMS DYNAMIC RANK_TEXT
#DIM  DYNAMIC RANK_COLOR

IF ARG
	SELECTCASE RANK_NUM
		CASE 10
			RANK_TEXT '= STR_RANK10_F:RANK
			RANK_COLOR = C_RANK10:RANK
		CASE 7
			RANK_TEXT '= STR_RANK7_F:RANK
			RANK_COLOR = C_RANK7:RANK
		CASEELSE
			RETURNF "ERR"
	ENDSELECT
ELSE
	SELECTCASE RANK_NUM
		CASE 10
			RANK_TEXT '= STR_RANK10:RANK
			RANK_COLOR = C_RANK10:RANK
		CASE 7
			RANK_TEXT '= STR_RANK7:RANK
			RANK_COLOR = C_RANK7:RANK
		CASEELSE
			RETURNF "ERR"
	ENDSELECT
ENDIF
RETURNF @"<font color='%HEX_TO_HTML_COLOR(RANK_COLOR)%'>%RANK_TEXT%</font>"

;-------------------------------------------------
; 打印颜色印章
;-------------------------------------------------
@COLOR_STAMP(STAMP_NUM, MAX_NUM, STAMP_STR, STAMP_COLOR, ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM  DYNAMIC STAMP_NUM
#DIM  DYNAMIC MAX_NUM
#DIMS DYNAMIC STAMP_STR
#DIM  DYNAMIC STAMP_COLOR
HTML_PRINT GET_STAMP_HTML(STAMP_NUM, MAX_NUM, STAMP_STR, STAMP_COLOR, ARG), 1

@GET_STAMP_HTML(STAMP_NUM, MAX_NUM, STAMP_STR, STAMP_COLOR, ARG = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIM  DYNAMIC STAMP_NUM
#DIM  DYNAMIC MAX_NUM
#DIMS DYNAMIC STAMP_STR
#DIM  DYNAMIC STAMP_COLOR
#DIMS DYNAMIC RES_STR
; ARG=0 (默认) 是右对齐，先补空格
IF !ARG
	; 使用全角空格 "　" 来对齐全角符号
	RES_STR += "　" * MAX(MAX_NUM - STAMP_NUM, 0)
ENDIF
IF STAMP_NUM > 0
	RES_STR += @"<font color='%HEX_TO_HTML_COLOR(STAMP_COLOR)%'>%STAMP_STR * STAMP_NUM%</font>"
ENDIF
RETURNF RES_STR


