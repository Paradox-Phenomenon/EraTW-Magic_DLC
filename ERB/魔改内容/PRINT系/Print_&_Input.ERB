;==============================================================================
;文本打印
;==============================================================================
;-------------------------------------------------
; 函数名：COLORMESSAGE
; 概  述：带颜色的打印函数。会保存调用前正在使用的颜色和字体，
;         使用结束后自动恢复为原来的颜色和字体设置。
; 参  数：
;     L_STR        - 文本内容
;     L_COLOR      - 颜色值
;     L_TYPE       - 显示形式
;                   (0 = PRINT
;                    1 = PRINTL
;                    2 = PRINTW
;                    3 = PRINTPLAIN)
;     L_STYLE      - 字体样式
;                   (0 = 普通
;                    1 = 粗体
;                    2 = 斜体
;                    4 = 删除线
;                    8 = 下划线)
;         ※ 样式采用位运算管理，例如：
;           3 = 0011 = 1 + 2 = 粗体 + 斜体
; 备  注：
;     此函数默认不换行，需要显性指定换行或等待。
;-------------------------------------------------
@COLORMESSAGE(L_STR, L_COLOR, L_TYPE, L_STYLE)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_COLOR
#DIM DYNAMIC L_TYPE
#DIM DYNAMIC L_STYLE
#DIM DYNAMIC TEMP_STYLE

LOCAL = GETCOLOR()
TEMP_STYLE = GETSTYLE()

SIF L_STYLE
	FONTSTYLE L_STYLE
SETCOLOR L_COLOR

SELECTCASE L_TYPE
	CASE 0
		PRINTFORM %L_STR%
	CASE 1
		PRINTFORML %L_STR%
	CASE 2
		PRINTFORMW %L_STR%
	CASE 3
		PRINTPLAINFORM %L_STR%
ENDSELECT

SETCOLOR LOCAL
FONTSTYLE TEMP_STYLE

;-------------------------------------------------
; 函数名：COND_COLORMESSAGE
; 概  述：满足条件时打印指定颜色的消息
; 参  数：COND     - 判断条件（满足时才着色）
;         MESSAGE  - 消息文本
;         L_COLOR  - 指定颜色（新增第三个参数，默认为明黄色）
;         L_TYPE   - 输出类型（新增第四个参数，默认为1，即PRINTFORML）
; 备  注：
;     此函数因为向后兼容，所以默认换行。
;-------------------------------------------------
@COND_COLORMESSAGE(COND,MESSAGE,L_COLOR = C_YELLOW,L_TYPE = 1)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM COND
#DIMS MESSAGE
#DIM L_COLOR
#DIM L_TYPE
LOCAL = GETCOLOR()
SIF COND
	SETCOLOR L_COLOR
SELECTCASE L_TYPE
	CASE 0
		PRINTFORM %MESSAGE%
	CASE 1
		PRINTFORML %MESSAGE%
	CASE 2
		PRINTFORMW %MESSAGE%
	CASE 3
		PRINTPLAINFORM %MESSAGE%
ENDSELECT
SETCOLOR LOCAL

;只有参数顺序与COLORMESSAGE不同的另一套带颜色的打印函数。重定向到COLORMESSAGE
@PRINTCOLOR(L_COLOR, L_STR, L_TYPE = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_COLOR
#DIM DYNAMIC L_TYPE
CALL COLORMESSAGE(L_STR, L_COLOR, L_TYPE)
RETURN RESULT

@PRINTCOLORL(L_COLOR, L_STR)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_COLOR
#DIM DYNAMIC L_TYPE
CALL COLORMESSAGE(L_STR, L_COLOR, 1)
RETURN RESULT

@PRINTCOLORW(L_COLOR, L_STR)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_COLOR
#DIM DYNAMIC L_TYPE
CALL COLORMESSAGE(L_STR, L_COLOR, 2)
RETURN RESULT

;-------------------------------------------------
; 函数名：HPH_PRINT
; 概  述：解析字符串中的特殊标记（HPH / BPB），
;         将其替换为对应的粉色爱心或斜杠特效，并按模式输出文本。
; 参  数：
;     L_STR   - 待解析并输出的字符串
;     L_MODE  - 输出模式（可选）
;               ""  = 普通 PRINTS（不推送不换行）
;               "l" = PRINTSL   （输出后换行）
;               "w" = PRINTSW   （输出后等待）
;               "dl"= PRINTSDL  （默认色 + 换行）
;               "dw"= PRINTSDW  （默认色 + 等待）
; 功  能：
;     HPH → 调用 HEARTMARK 输出粉色爱心效果
;     BPB → 输出粉色斜杠特效（///）
; 备  注：
;     ·此函数默认不换行。
;     ·穰子剧本作者原创的特殊文本函数，毫无疑问是最常被调用的文本渲染函数。
;     ·半角的三连///符号是FORM语法的关键字，在PRINTFORM中会被解析为CALLNAME:ASSI，而本游戏中ASSI为-1，一旦被调用就会数值越界而跳出，此函数便是为避免这一情况而出现的
;-------------------------------------------------
@HPH_PRINT(L_STR, L_MODE = "")
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIMS DYNAMIC L_MODE
#DIM DYNAMIC L_IDX_HPH
#DIM DYNAMIC L_IDX_BPB
#DIM DYNAMIC L_IDX_NEXT
#DIMS DYNAMIC L_PRINT_PART
SELECTCASE TOLOWER(L_MODE)
	CASE "str"
		REPLACE L_STR, "HPH", "@H@"
		REPLACE L_STR, "BPB", "@B@"
		JUMP PRINT_STR, L_STR
	CASE "strl"
		REPLACE L_STR, "HPH", "@H@"
		REPLACE L_STR, "BPB", "@B@"
		JUMP PRINT_STRL, L_STR
	CASE "strw"
		REPLACE L_STR, "HPH", "@H@"
		REPLACE L_STR, "BPB", "@B@"
		JUMP PRINT_STRW, L_STR
ENDSELECT
DO
	L_IDX_HPH = STRFIND(L_STR, "HPH")
	L_IDX_BPB = STRFIND(L_STR, "BPB")
	
	IF L_IDX_HPH >= 0 && L_IDX_BPB < 0
		L_IDX_NEXT = L_IDX_HPH
	ELSEIF L_IDX_HPH < 0 && L_IDX_BPB >= 0
		L_IDX_NEXT = L_IDX_BPB
	ELSE
		L_IDX_NEXT = MIN(L_IDX_HPH, L_IDX_BPB)
	ENDIF

	; 如果前面有普通文字
	IF L_IDX_NEXT >= 1
		L_PRINT_PART = %SUBSTRING(L_STR, 0, L_IDX_NEXT)%
		IF GROUPMATCH(TOLOWER(L_MODE), "dw", "dl")
			PRINTSD @"%L_PRINT_PART%"
		ELSE
			PRINTS @"%L_PRINT_PART%"
		ENDIF
		L_STR = %SUBSTRING(L_STR, L_IDX_NEXT, -1)%
		
	; 如果开头就是 HPH
	ELSEIF L_IDX_HPH == 0
		CALL HEARTMARK
		L_STR = %SUBSTRING(L_STR, 3, -1)%
		
	; 如果开头就是 BPB
	ELSEIF L_IDX_BPB == 0
		CALL SHYMARK
		L_STR = %SUBSTRING(L_STR, 3, -1)%
		
	; 没有特殊标记了，打印剩余部分并根据 L_MODE 换行/等待
	ELSE
		SELECTCASE TOLOWER(L_MODE)
			CASE "dw"
				PRINTSDW @"%L_STR%"
			CASE "dl"
				PRINTSDL @"%L_STR%"
			CASE "w"
				PRINTSW @"%L_STR%"
			CASE "l"
				PRINTSL @"%L_STR%"
			CASEELSE
				PRINTS @"%L_STR%"
		ENDSELECT
		BREAK
	ENDIF
LOOP 1

;-------------------------------------------------
; 函数名：PRINT_STR
; 概  述：解析特殊标记的字符串并输出
;        支持通过 @ 分割，实现动态变色、按钮化、特殊心形符号等。
; 参  数：允许传入最多10个字符串，内部拼接后解析
;-------------------------------------------------
@PRINT_STR(L_S:0, L_S:1="", L_S:2="", L_S:3="", L_S:4="", L_S:5="", L_S:6="", L_S:7="", L_S:8="", L_S:9="")
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_S,10
#DIM DYNAMIC L_OLD_C
#DIM DYNAMIC L_OLD_F
#DIMS DYNAMIC L_STR
#DIMS DYNAMIC L_TOKENS, 300
#DIM DYNAMIC L_TOKEN_CNT
#DIMS DYNAMIC L_PARAMS, 5

L_STR = %L_S:0%
FOR LOCAL, 1, 10
	IF L_S:LOCAL != ""
		L_STR += "@" + L_S:LOCAL
	ENDIF
NEXT
L_OLD_C = GETCOLOR()
L_OLD_F = GETSTYLE()

SPLIT L_STR, "@", L_TOKENS, L_TOKEN_CNT

FOR LOCAL, 0, L_TOKEN_CNT
	SELECTCASE L_TOKENS:LOCAL
		CASE "CALLNAME:TARGET"
			PRINTFORM %CALLNAME:TARGET%
			CONTINUE
		CASE "CALLNAME:PLAYER"
			PRINTFORM %CALLNAME:PLAYER%
			CONTINUE
		CASE "CALLNAME:ASSI"
			PRINTFORM %CALLNAME:ASSI%
			CONTINUE
		CASE "CALLNAME:MASTER"
			PRINTFORM %CALLNAME:MASTER%
			CONTINUE
			
		; 按钮相关
		CASE "BUTTON"
			LOCAL++
			PRINTBUTTON L_TOKENS:LOCAL, L_TOKENS:LOCAL
			SETCOLOR L_OLD_C
			FONTREGULAR
			CONTINUE
		CASE "BUTTONS"
			LOCAL++
			SPLIT L_TOKENS:LOCAL, "|", L_PARAMS
			PRINTBUTTON L_PARAMS:0, L_PARAMS:1
			SETCOLOR L_OLD_C
			FONTREGULAR
			CONTINUE
		CASE "BUTTONNUM"
			LOCAL++
			SPLIT L_TOKENS:LOCAL, "|", L_PARAMS
			PRINTBUTTON L_PARAMS:0, TOINT(L_PARAMS:1)
			SETCOLOR L_OLD_C
			FONTREGULAR
			CONTINUE
		CASE "NOBUTTON"
			LOCAL++
			PRINTPLAINFORM %L_TOKENS:LOCAL%
			SETCOLOR L_OLD_C
			FONTREGULAR
			CONTINUE
			
		; 控制指令
		CASE "-"
			FONTSTYLE 4
			CONTINUE
		CASE "L"
			PRINTL 
			CONTINUE
		CASE "W"
			PRINTW 
			CONTINUE
		CASE "WAIT"
			WAIT
			CONTINUE
		CASE "FORCEWAIT"
			FORCEWAIT
			CONTINUE
			
		; 特殊符号
		CASE "H", "HEART", "HPH"
			CALL HEARTMARK
			CONTINUE
		CASE "／／／", "BPB"
			CALL SHYMARK
			CONTINUE
			
		; 颜色控制
		CASE "RGB"
			LOCAL++
			SPLIT L_TOKENS:LOCAL, "//", L_PARAMS
			SETCOLOR RGB_TO_HEX(TOINT(L_PARAMS:0), TOINT(L_PARAMS:1), TOINT(L_PARAMS:2))
			CONTINUE
		CASE "HEX"
			LOCAL++
			SETCOLOR TOINT(L_TOKENS:LOCAL)
			CONTINUE
			
		; 字体样式
		CASE "Ｂ", "BOLD"
			FONTBOLD
			CONTINUE
		CASE "UNDER"
			FONTSTYLE 8
			CONTINUE
		CASE "ITALIC"
			FONTITALIC
			CONTINUE
		CASE "STRIKE"
			FONTSTYLE 4
			CONTINUE
	ENDSELECT

	; 默认打印普通文本
	PRINTFORM %L_TOKENS:LOCAL%
	SETCOLOR L_OLD_C
	FONTREGULAR
NEXT

@PRINT_STRL, ARGS, ARGS:1, ARGS:2, ARGS:3, ARGS:4, ARGS:5, ARGS:6, ARGS:7, ARGS:8, ARGS:9
#LOCALSIZE 1
#LOCALSSIZE 1
