;-------------------------------------------------
; 带换行、括号和缩进的角色对话打印
;-------------------------------------------------
@PRINT_DIALOGUE(L_STR, L_FLAGS)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_STR
#DIMS DYNAMIC L_FLAGS
#DIMS DYNAMIC L_BRACKET_L
#DIMS DYNAMIC L_BRACKET_R

IF SPLIT_CHECK(TOLOWER(L_FLAGS), "p")
	L_BRACKET_L = （
	L_BRACKET_R = ）
ELSEIF SPLIT_CHECK(TOLOWER(L_FLAGS), "t")
	L_BRACKET_L = 『
	L_BRACKET_R = 』
ELSE
	L_BRACKET_L = 「
	L_BRACKET_R = 」
ENDIF

IF SPLIT_CHECK(TOLOWER(L_FLAGS), "d")
	CALL KEYTYPING(BREAKENG(L_BRACKET_L + L_STR + L_BRACKET_R, 0, "\n　", MAXWIDTH() - 19), "l", 1, 2)
ELSEIF SPLIT_CHECK(TOLOWER(L_FLAGS), "dc")
	PRINTSDL BREAKENG(L_BRACKET_L + L_STR + L_BRACKET_R, 0, "\n　", MAXWIDTH() - 19)
ELSE
	PRINTSL BREAKENG(L_BRACKET_L + L_STR + L_BRACKET_R, 0, "\n　", MAXWIDTH() - 19)
ENDIF

SIF SPLIT_CHECK(TOLOWER(L_FLAGS), "w")
	WAIT

@CHARA_TEXT(L_TGT_ID, L_STR, L_MODE = "l")
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_TGT_ID
#DIMS DYNAMIC L_STR
#DIMS DYNAMIC L_MODE
#DIM DYNAMIC L_OLD_C

L_OLD_C = GETCOLOR()
RESETCOLOR

SIF FLAG:口上色
    CALL SET_KOJO_COLOR(L_TGT_ID)

SELECTCASE TOLOWER(L_MODE)
    CASE "l"
        PRINTFORML %L_STR%
    CASE "w"
        PRINTFORMW %L_STR%
	CASE "str"
		CALL PRINT_STR, L_STR
	CASE "strl"
		CALL PRINT_STRL, L_STR
	CASE "strw"
		CALL PRINT_STRW, L_STR
    CASEELSE
        PRINTFORM %L_STR%
ENDSELECT
SETCOLOR L_OLD_C

;==============================================================================
;输出交互
;==============================================================================
