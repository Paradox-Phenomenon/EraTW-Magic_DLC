
;==============================================================================
; 2：排版与字符串处理(String Layout & Format)
; 式中函数，不产生任何屏幕输出，仅负责加工字符串。
;==============================================================================

;-------------------------------------------------
; 函数名：CENTER
; 概  述：为字符串两侧填充空格，使其在指定宽度内居中
; 参  数：L_STR   - 需要居中的字符串
;         L_WIDTH - 目标总宽度（半角字符数）
; 返回值：居中对齐后的字符串
;-------------------------------------------------
@CENTER(L_STR, L_WIDTH)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_WIDTH
#DIM DYNAMIC L_PAD_LEFT
#DIM DYNAMIC L_PAD_RIGHT
#DIM DYNAMIC L_STR_LEN

L_STR_LEN = STRLENS(L_STR)
IF L_WIDTH <= L_STR_LEN
	RETURNF L_STR
ENDIF

L_PAD_LEFT = (L_WIDTH - L_STR_LEN) / 2
L_PAD_RIGHT = L_WIDTH - L_STR_LEN - L_PAD_LEFT

RETURNF @"%"", L_PAD_LEFT%%L_STR%%"", L_PAD_RIGHT%"

;-------------------------------------------------
; 函数名：CENTERSCREEN
; 概  述：使字符串在当前控制台屏幕宽度下居中
; 参  数：L_STR - 需要居中的字符串
; 返回值：居中对齐后的字符串
;-------------------------------------------------
@CENTERSCREEN(L_STR)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC L_STR
RETURNF CENTER(L_STR, MAXWIDTH())

;-------------------------------------------------
; 函数名：UNITCELL
; 概  述：单元格字符串对齐函数。
;         根据指定的单元格宽度，将字符串补齐至“单元格宽度”的整数倍长度，
;         以便构造整齐的表格或多列排版。
;
; 参  数：
;     ARGS - 需要放入单元格的字符串
;     ARG  - 单元格宽度（建议为 PRINTCLENGTH）
;
; 功  能：
;     ・若字符串长度未达到单元格宽度的整数倍，
;       自动在末尾补充半角空格，使其对齐到最近的单元格宽度。
;     ・若字符串长度超过单元格宽度，
;       不会截断，而是自动扩展到 2倍 / 3倍 / N倍单元格宽度。
;
; 与 PRINTC 的区别：
;     PRINTC 在超过指定宽度时会破坏排版结构；
;     UNITCELL 则保持“单元格宽度”概念，按倍数扩展，
;     适合构建稳定的表格结构。
;
; 使用场景：
;     ・制作严格对齐的文本表格
;     ・构造类似“横向 2 单元格合并”的视觉效果
;     ・制表框 / 状态栏 / 参数表排版
;
; 备  注：
;     属于排版辅助函数，不做截断处理。
;-------------------------------------------------
@UNITCELL(ARGS, ARG)
#FUNCTIONS
RETURNF @"%ARGS+(" "*(ARG-(STRLENS(ARGS)%ARG)))%"

;-------------------------------------------------
; 函数名：FIXEDCELL
; 概  述：固定宽度单元格函数。
;         将字符串严格限制在指定宽度内，
;         超出时截断，不足时补空格。
;
; 参  数：
;     ARGS - 需要放入单元格的字符串
;     ARG  - 单元格固定宽度
;
; 功  能：
;     ・若字符串长度 <= 指定宽度：
;         在末尾补充半角空格至固定长度。
;     ・若字符串长度 > 指定宽度：
;         截断至 (ARG - 2) 字符，并在末尾追加 ".." 作为省略标记。
;
; 与 UNITCELL 的区别：
;     UNITCELL 维持区切倍数结构，不截断；
;     FIXEDCELL 则强制控制为固定长度，优先保证宽度稳定。
;
; 使用场景：
;     ・列宽严格受限的表格
;     ・日志列表
;     ・名称字段展示（防止溢出）
;
; 备  注：
;     适用于“必须等宽”的场景，但可能丢失部分文本内容。
;-------------------------------------------------
@FIXEDCELL(ARGS, ARG)
#FUNCTIONS
RETURNF \@ STRLENS(ARGS) > ARG ? %SUBSTRING(ARGS, 0, ARG-2)%… # %ARGS+" "*(ARG-(STRLENS(ARGS)))% \@

;-------------------------------------------------
; 函数名：FULLWIDTH_LB
; 概  述：自动全角行换行（适配日文/中文）
;-------------------------------------------------
@FULLWIDTH_LB(L_STR, L_BR_STR = "\n", L_LEN = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC L_STR
#DIMS DYNAMIC L_BR_STR
#DIM DYNAMIC L_LEN
#DIMS DYNAMIC L_RES

; 使用正则按字符数截断并插入换行符
L_RES '= REPLACE(L_STR, @"(.\{1,{(L_LEN/2)-1}\})(.|$)", "$1$2\n")
RETURNF SUBSTRING(L_RES, 0, HTML_STRINGLEN(L_RES) - STRLENS(L_BR_STR))

;-------------------------------------------------
; 函数名：BREAKENG
; 概  述：英文单词级别自动换行（避免单词被切断）
;-------------------------------------------------
@BREAKENG(L_STR, L_INDENT = 0, L_BR_STR = "\n", L_LEN = 0, L_MATCH = "\s")
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_INDENT
#DIMS DYNAMIC L_BR_STR
#DIM DYNAMIC L_LEN
#DIMS DYNAMIC L_MATCH
#DIM DYNAMIC L_LINE_LEN
#DIMS DYNAMIC L_RES

SIF !L_LEN
	L_LEN = MAXWIDTH() - 19
L_LINE_LEN = L_LEN - L_INDENT

IF L_LINE_LEN < 1
	THROW @BREAKENG Usable length cannot be less than 1
ELSE
	L_RES '= REPLACE(L_STR, "(.{1," + TOSTR(L_LINE_LEN) + "})(?:" + L_MATCH + "|$)", " " * L_INDENT + "$1" + L_BR_STR)
	RETURNF SUBSTRING(L_RES, 0, STRLENS(L_RES) - STRLENS(L_BR_STR))
ENDIF

;-------------------------------------------------
; 半角空格生成
;-------------------------------------------------
@BL(L_COUNT)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIM DYNAMIC L_COUNT
SIF L_COUNT <= 0
	RETURNF ""
RETURNF " " * L_COUNT

;-------------------------------------------------
; 文本左右对齐填充
;-------------------------------------------------
@TEXT_RJ(L_STR, L_LEN)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_LEN
IF STRLENS(L_STR) >= L_LEN
	RETURNF L_STR
ELSE
	RETURNF BL(L_LEN - STRLENS(L_STR)) + L_STR
ENDIF

@TEXT_LJ(L_STR, L_LEN)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_LEN
IF STRLENS(L_STR) >= L_LEN
	RETURNF L_STR
ELSE
	RETURNF L_STR + BL(L_LEN - STRLENS(L_STR))
ENDIF

;-------------------------------------------------
; 数字修饰：序数词 (1st, 2nd, 3rd)
;-------------------------------------------------
@ORDINAL(L_NUM)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIM DYNAMIC L_NUM
#DIMS DYNAMIC L_SUFFIX
IF L_NUM >= 11 && L_NUM <= 13
    L_SUFFIX = th
ELSE
    SELECTCASE (L_NUM % 10)
    CASE 1
        L_SUFFIX = st
    CASE 2
        L_SUFFIX = nd
    CASE 3
        L_SUFFIX = rd
    CASEELSE
        L_SUFFIX = th
    ENDSELECT
ENDIF
RETURNF TOSTR(L_NUM) + L_SUFFIX

;-------------------------------------------------
; 数字修饰：千位分隔符 (1,000)
;-------------------------------------------------
@DIGIT_GROUP(L_NUM)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIM DYNAMIC L_NUM
RETURNF @"\@(L_NUM == 0) ? 0 # %TOSTR(L_NUM,"#,###")%\@"

;-------------------------------------------------
; 文本特效：结巴修饰 (I-I-I am...)
;-------------------------------------------------
@STUTTER(L_STR, L_FLAGS = "nospecial")
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC L_STR
#DIMS DYNAMIC L_FLAGS
#DIM DYNAMIC L_IDX
#DIM DYNAMIC L_SHY_CNT
#DIM DYNAMIC L_SUPER_CNT
#DIMS DYNAMIC L_RES

IF STRING_STARTS_IN(L_STR, "I'm")
	IF STRLENS(L_STR) > 3
		RETURNF "I" + SPLIT_G(", :...:-") + "I'm" + SUBSTRING(L_STR, 3, -1)
	ELSE
		RETURNF "I" + SPLIT_G(", :...:-") + "I am"
	ENDIF
ELSEIF STRING_STARTS_IN(L_STR, "I ") && STRLENS(L_STR) > 1
	RETURNF @"I%SPLIT_G(", :...:-")%I%SUBSTRING(L_STR, 1, -1)%"
ELSEIF STRING_STARTS_IN(L_STR, "I") && STRLENS(L_STR) == 1
	RETURNF @"I%SPLIT_G(", :...:-")%I"
ELSE
	L_IDX = RAND:2 + 1
ENDIF
		
L_RES = %SUBSTRING(L_STR, 0, STRLENS(L_STR) >= 5 ? L_IDX # 1)%

IF !SPLIT_CHECK(L_FLAGS, "nospecial") && (SPLIT_CHECK(L_FLAGS, "special") || RAND:3)
	IF SPLIT_CHECK(L_FLAGS, "shy") || (!RAND:3 && STRLENS(L_STR) >= 5 && !SPLIT_CHECK(L_FLAGS, "noshy"))
		L_RES += "..." + SPLIT_G("uh:um:erm:er") + "..."
		L_SHY_CNT++
	ELSE
		L_RES += "-"
	ENDIF
	
	IF SPLIT_CHECK(L_FLAGS, "ss") || (RAND:3 && L_SHY_CNT == 0 && !SPLIT_CHECK(L_FLAGS, "noss"))
		L_SUPER_CNT = RAND:2 + 1
		L_SUPER_CNT = MAX(L_SUPER_CNT, L_IDX)
		L_RES += @"%SUBSTRING(L_STR, 0, STRLENS(L_STR) >= 5 ? L_SUPER_CNT # 1)%-" * (RAND:2 + 1)
	ENDIF
		
	L_RES += L_STR
ELSE
	L_RES += SPLIT_G(", :...:-") + L_STR
ENDIF

RETURNF L_RES

;-------------------------------------------------
; 大小写处理相关
;-------------------------------------------------
@CAP_PROCESS(L_STR, L_MODE)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC L_STR
#DIM DYNAMIC L_MODE
SELECTCASE L_MODE
	CASE 1
		RETURNF TOLOWER(L_STR)
	CASE 2
		RETURNF TOUPPER(L_STR)
	CASE 3
		RETURNF CAPITALIZE(L_STR)
	CASE 4
		RETURNF RAND_CAP(L_STR)
	CASE 5
		RETURNF CAP_WORD(L_STR)
	CASEELSE
		RETURNF L_STR
ENDSELECT

@CAPITALIZE(L_STR)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC L_STR
RETURNF TOUPPER(SUBSTRING(L_STR, 0, 1)) + SUBSTRING(L_STR, 1, -1)

@UNCAPITALIZE(L_STR)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC L_STR
RETURNF TOLOWER(SUBSTRING(L_STR, 0, 1)) + SUBSTRING(L_STR, 1, -1)

@RAND_CAP(L_STR)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC L_STR
#DIMS DYNAMIC L_RES
#DIM DYNAMIC L_BALANCE

L_BALANCE = RAND:2
FOR LOCAL, 0, STRLENS(L_STR)
	IF RAND:3 < L_BALANCE
		L_RES += TOUPPER(SUBSTRING(L_STR, LOCAL, 1))
		L_BALANCE--
	ELSE
		L_RES += TOLOWER(SUBSTRING(L_STR, LOCAL, 1))
		L_BALANCE++
	ENDIF
NEXT
RETURNF L_RES

@CAP_WORD(L_STR)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC L_STR
#DIMS DYNAMIC L_RES

FOR LOCAL, 0, STRCOUNT(L_STR, " ") + 1
	L_RES += CAPITALIZE(SPLIT_SINGLE(L_STR, LOCAL, " "))
	SIF LOCAL < STRCOUNT(L_STR, " ")
		L_RES += " "
NEXT
L_STR '= L_RES
L_RES = ""
FOR LOCAL, 0, STRCOUNT(L_STR, "-") + 1
	L_RES += CAPITALIZE(SPLIT_SINGLE(L_STR, LOCAL, "-"))
	SIF LOCAL < STRCOUNT(L_STR, "-")
		L_RES += "-"
NEXT
RETURNF L_RES

@RETURN_CAP(L_STR_REF, L_STR_TGT)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS DYNAMIC L_STR_REF
#DIMS DYNAMIC L_STR_TGT
RETURNF IS_CAPITALIZED(L_STR_REF) ? CAPITALIZE(L_STR_TGT) # L_STR_TGT

@IS_CAPITALIZED(L_STR)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIMS DYNAMIC L_STR
IF STRCOUNT(L_STR,"^[A-Z]")
	RETURNF 1
ELSE
	RETURNF 0
ENDIF