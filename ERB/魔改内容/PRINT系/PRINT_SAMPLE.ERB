;==============================================================================
; UI 组件全功能展示样例库 (Showcase Demo)
;==============================================================================
@UI_COMPONENT_DEMO_SHOWCASE
#DIM DYNAMIC L_OLD_C
L_OLD_C = GETCOLOR()

PRINTFORML 
PRINTFORML ━━━ [1] 分割线组件 (Line Components) ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PRINTFORML 

; 1. CENTERLINE (屏幕居中分割线)
; 特征：自动根据屏幕宽度生成，并继承当前文本颜色
PRINTFORML ▽ CENTERLINE: 默认颜色
CALL CENTERLINE
SETCOLOR 0xFF5555
PRINTFORML ▽ CENTERLINE: 不继承SETCOLOR变色
CALL CENTERLINE
PRINTFORMW 但也不干扰SETCOLOR变色
RESETCOLOR
; 2. LINECENTER (带文本的居中装饰线)
; 特征：可以自定义填充字符和总宽度
PRINTFORML ▽ LINECENTER: 默认连字符填充
CALL LINECENTER(" 第一章：觉醒 ", "-", 50)
PRINTFORML ▽ LINECENTER: 自定义特殊字符与更宽的跨度
SETCOLOR 0x00FFFF
CALL LINECENTER(" SYSTEM WARNING ", "≈", 80)
RESETCOLOR
WAIT
; 3. FADELINE (粗体矩阵渐变分割线)
; 特征：基于 PRINT_RECT 绘制的像素级明暗衰减线
PRINTFORML ▽ FADELINE: 默认灰色风格
CALL FADELINE(0)
PRINTFORML ▽ FADELINE: 强对比度风格 (参数5)
CALL FADELINE(5)
WAIT
; 4. COLOR_LINE (HSV 色彩渐变分割线)
; 特征：支持厚度调整、基于亮度的长度自适应、正向淡出和反向光晕
PRINTFORML ▽ COLOR_LINE: 默认正向淡出 (蓝色基底, 厚度2)
CALL COLOR_LINE(2, 0x0088FF, MAXWIDTH(), 0)
PRINTFORML ▽ COLOR_LINE: 反向淡入光晕 (金色基底, 厚度4)
CALL COLOR_LINE(4, 0xFFD700, MAXWIDTH(), 1)
WAIT

PRINTFORML 
PRINTFORML ━━━ [2] 字符级进度条 (Text-Based Bars) ━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PRINTFORML 

; 1. BW_BAR (纯字符串黑白/双色条)
; 特征：纯函数返回，通过 HTML_PRINT 输出，适合夹杂在文字中，且不受限颜色
PRINTFORML ▽ BW_BAR: 默认方块
HTML_PRINT "  HP: " + BW_BAR(75, 100, 20)
WAIT

PRINTFORML ▽ BW_BAR: 自定义特殊符号，极速拼接
HTML_PRINT "  MP: " + BW_BAR(30, 100, 20, "★", "☆")
WAIT
; 2. PRINT_COLORBAR (经典纯色字符条封装)
; 特征：直接打印，支持自定义前背景颜色与字符
PRINTFORML ▽ PRINT_COLORBAR: 纯红血条 + 圆点背景
PRINT   AP: 
CALL PRINT_COLORBAR(60, 100, 20, "■", "·", 0xFF2222, 0x442222)
PRINTW
PRINTFORML ▽ PRINT_COLORBAR: 科技感蓝绿条 + 三角形背景
PRINT   SP: 
CALL PRINT_COLORBAR(85, 100, 20, "▶", "▷", 0x00FFCC, 0x114444)
PRINTW

; 3. COLOR_BAR (带彩虹渐变尾巴的字符条)
; 特征：支持参数调整生成漂亮的尾部过渡色
PRINTFORML ▽ COLOR_BAR: 基础单色 (无渐变增量)，不自带换行
PRINT   EXP:
CALL COLOR_BAR(500, 1000, 30, 150, 150, 255)
PRINTW
PRINTFORML ▽ COLOR_BAR: 橙色基底 + 彩虹尾巴渐变 (RGB渐变参数不为0)，不自带换行
PRINT   EXP:
CALL COLOR_BAR(800, 1000, 30, 255, 120, 0, -60, 15, -15, 30, 2)
PRINTW

; 4. PRINTLEVELBAR (等级经验专用包装)
PRINTFORML ▽ PRINTLEVELBAR: 低等级
CALL PRINTLEVELBAR(60, 200, 5, 6, 109, 225, 255)
PRINTW
PRINTFORML ▽ PRINTLEVELBAR: 高等级 (自定义 RGB)
CALL PRINTLEVELBAR(950, 1000, 99, 100, 255, 50, 50)
PRINTW


PRINTFORML 
PRINTFORML ━━━[3] 像素级图形条 (Shape-Based Bars) ━━━━━━━━━━━━━━━━━━━━━━━━
PRINTFORML 

; 1. HTML_RECT_BAR (极度平滑的像素矩形条)
; 特征：利用 <shape> 渲染，不受字体缝隙影响，支持无缝 HSV 渐变
PRINTFORML ▽ HTML_RECT_BAR: 纯色细线条 (高度15)
HTML_PRINT "  " + HTML_RECT_BAR(40, 100, 1500, 15, 0xAA00FF, 0x330033)
PRINTFORML ▽ HTML_RECT_BAR: 红到绿全平滑过渡 (高度30, 起点红, 终点绿)
HTML_PRINT "  " + HTML_RECT_BAR(85, 100, 1500, 30, 0xFF0000, 0x222222, 0x00FF00)

; 2. PRINT_RATE_BAR_EX (重型高精度分段图形条)
; 特征：支持断点(GAP)、双层显示(VAL2)、对齐(TOP/BOTTOM)、超限(LIMIT OVER)
PRINTFORML ▽ PRINT_RATE_BAR_EX: 10段式带间隙 (0x1000)，黄色渐变到红色
PRINT   盾牌（80/100）: 
; L_FLAG = 0x1000(间隙)
CALL PRINT_RATE_BAR_EX(80, 100, 80, 20, 0xFFFF00, 0xFF0000, 0x333333, 0x1000, 0, 0)
PRINTW
PRINTFORML ▽ PRINT_RATE_BAR_EX: 超限模式(0x0001) + 双层显示(水蓝额外层，灰色背景)
PRINTFORM %"护甲（140/100）:",24 %
; VAL=140 超出 MAX_VAL=100。底层VAL2=40。L_FLAG = 0x0001(超限) | 0x1000(间隙)
CALL PRINT_RATE_BAR_EX(140, 100, 80, 20, 0x00FF00, 0xE8E800, 0x222222, 0x001)
PRINTW
PRINTFORML ▽ PRINT_RATE_BAR_EX: 超限模式(0x0001) + 双层显示(水蓝额外层，灰色背景)
PRINTFORM %"护甲（100/100）:",24 %
; VAL=140 超出 MAX_VAL=100。底层VAL2=40。L_FLAG = 0x0001(超限) | 0x1000(间隙)
CALL PRINT_RATE_BAR_EX(100, 100, 80, 20, 0x00FF00, 0xE8E800, 0x222222, 0x001)
PRINTW
PRINTFORML ▽ PRINT_RATE_BAR_EX: 超限模式(0x0001) + 双层显示(水蓝额外层，灰色背景)
PRINTFORM %"护甲（ 60/100）:",24 %
; VAL=140 超出 MAX_VAL=100。底层VAL2=40。L_FLAG = 0x0001(超限) | 0x1000(间隙)
CALL PRINT_RATE_BAR_EX(60, 100, 80, 20, 0x00FF00, 0xE8E800, 0x222222, 0x001)
PRINTW
PRINTFORML ▽ PRINT_RATE_BAR_EX: 超限模式(0x0001) + 双层显示(水蓝额外层，灰色背景)
PRINTFORM %"护甲（60+60/100）:",24 %
; VAL=140 超出 MAX_VAL=100。底层VAL2=40。L_FLAG = 0x0001(超限) | 0x1000(间隙)
CALL PRINT_RATE_BAR_EX(60, 100, 80, 20, 0x00FF00, 0xE8E800, 0x222222, 0x001, 120, C_AQUA)
PRINTW
PRINTFORML 
PRINTFORML ━━━ [4] 高级交互滑块面板 (Interactive Sliders) ━━━━━━━━━━━━━━━━━━━━
PRINTFORML 
; 利用按钮与Shape结合的 1:1 像素级精准映射。选中的滑块会增高变亮金色。
; 在实际使用中它们通常置于 INPUT 循环内，此处仅作视觉渲染展示。

PRINTFORML ▽ HTML_PRINT_RGB_SLIDER: 以紫色 (0x8A2BE2) 为基准
CALL HTML_PRINT_RGB_SLIDER(0x8A2BE2)

PRINTL 
PRINTFORML ▽ HTML_PRINT_HSB_SLIDER: 以青色 (0x00FFFF) 为基准
CALL HTML_PRINT_HSB_SLIDER(0x00FFFF)

INPUT

PRINTFORML 选中了%HEX_TO_STR(RESULT)%!
PRINTFORML ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SETCOLOR L_OLD_C
WAIT
RETURN

LOCALS = 我看到你了我看到你了我看到你了我看到你了我看到你了我看到你了我看到你了
TSTR:1 = 科技蓝白呼吸
TSTR:2 = 全彩虹循环
TSTR:3 = 深海幽蓝呼吸
TSTR:4 = 警告红黄呼吸
TSTR:5 = 樱花粉白呼吸
TSTR:6 = 灰白呼吸
gLineCount = LINECOUNT
FOR LOCAL, 0, 400
	FOR I, 1, 7
		PRINTFORM %TSTR:I,14,LEFT%
		CALL COLORMESSAGE(LOCALS,GET_CHANGING_COLOR(I),1)
	NEXT
	AWAIT 40
	CLEARLINE LINECOUNT - gLineCount
NEXT
FOR I, 1, 7
	PRINTFORM %TSTR:I,14%
	CALL COLORMESSAGE(LOCALS,GET_CHANGING_COLOR(I),1)
NEXT