@PRINT_FACE_PLAYER(CID, 表情="", 服装="", 差分="", エフェクト="", 立绘选择 = -1, EFFECT_OVERRIDE = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM  DYNAMIC CID
#DIMS DYNAMIC 表情
#DIMS DYNAMIC 服装
#DIMS DYNAMIC 差分
