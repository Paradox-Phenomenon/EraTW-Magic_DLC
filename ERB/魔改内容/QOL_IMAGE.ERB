;逻辑层
;=========================================================

;-------------------------------------------------
; UI内部工具：CALC_IMAGE_PAGINATION
; 概  述：UI的分页计算组件，根据当前目标、玩家设定、窗口大小，计算出本次应该渲染的角色数组
; 参  数：TARGET_LIST(输入), PRINT_LIST(输出), PRINT_COUNT(输出人数)
;-------------------------------------------------
@CALC_IMAGE_PAGINATION(TARGET_LIST, PRINT_LIST, PRINT_COUNT)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM REF TARGET_LIST
#DIM REF PRINT_LIST
#DIM REF PRINT_COUNT
#DIM DYNAMIC TOTAL_AVAILABLE
#DIM DYNAMIC CUR_TARGET_IDX
#DIM DYNAMIC START_IDX
#DIM DYNAMIC END_IDX

PRINT_COUNT = 0
TOTAL_AVAILABLE = GET_TARGETNUM() + (自机立绘显示 && 自机立绘开关)

; 寻找主 Target 在数组中的绝对索引
CUR_TARGET_IDX = FINDELEMENT(TARGET_LIST, TARGET_LIST:0, 1)
SIF CUR_TARGET_IDX < 1
	CUR_TARGET_IDX = 1

; 计算滑动窗口 (让当前选中目标尽可能居中)
IF FLAG:画像表示 == 1
	START_IDX = CUR_TARGET_IDX
ELSE
	START_IDX = CUR_TARGET_IDX - (FLAG:画像表示 / 2)
	; 边界约束：确保不会越界，同时尽量填满 FLAG:画像表示 的数量
	START_IDX = LIMIT(START_IDX, 1, MAX(TOTAL_AVAILABLE - FLAG:画像表示 + 1, 1))
ENDIF
END_IDX = START_IDX + FLAG:画像表示

; 1. 如果允许显示玩家，把玩家推入第一个坑位
IF 自机立绘显示 && 自机立绘开关
	PRINT_LIST:PRINT_COUNT = MASTER
	PRINT_COUNT++
ENDIF

; 2. 依次提取区间内的角色
FOR LOCAL, START_IDX, END_IDX
	SIF !TARGET_LIST:LOCAL
		BREAK
	; 如果遇到 MASTER (已经在前面添加过了)，跳过
	SIF NO:(TARGET_LIST:LOCAL) == MASTER && !(自机立绘显示 && 自机立绘开关)
		CONTINUE
		
	PRINT_LIST:PRINT_COUNT = TARGET_LIST:LOCAL
	PRINT_COUNT++
NEXT
RETURN

;-------------------------------------------------
; BLOCK组件：GET_DEFAULT_IMAGE_FLAGS
; 概  述：读取当前系统的全局设置，生成默认的 64位 控制参数
;-------------------------------------------------
; 位图说明 (IMG_FLAGS)：
; Bit 0 : 边框显示 (Frame)
; Bit 1 : 特效显示 (Effect - 汗/吐息等)
; Bit 2 : Xray 显示
; Bit 3 : 夜间滤镜 (Night Filter)
; Bit 4 : 描边滤镜 (Border Filter)
; Bit 5 : 时间停止蒙版 (Time Stop Mask)
; Bit 6 : 按钮化 (Button - 0则渲染为nonbutton纯图)
; Bit 7 : 巨乳差分 (Bust Diff)
;-------------------------------------------------
;样例：
;#DIM DYNAMIC MY_FLAGS
;MY_FLAGS = GET_DEFAULT_IMAGE_FLAGS()
;CLEARBIT MY_FLAGS, 6 ; 关闭按钮交互
;CLEARBIT MY_FLAGS, 2 ; 强制关闭 Xray
;SETBIT   MY_FLAGS, 3 ; 强制开启夜晚滤镜
;SETBIT   MY_FLAGS, 0 ; 强制开启画框
;RESULTS =
;CALL BUILD_CHARA_IMAGE_BLOCK(TARGET, 0, 300, 100, MY_FLAGS)
;-------------------------------------------------
@GET_DEFAULT_IMAGE_FLAGS()
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM DYNAMIC FLAGS

SIF FLAG:画像枠表示
	SETBIT FLAGS, 0
SIF FLAG:追加エフェクト
	SETBIT FLAGS, 1
SIF FLAG:XRay_show
	SETBIT FLAGS, 2
SIF 画像特殊効果_夜間効果 && (INRANGE(TIME, 1140, 1439) || INRANGE(TIME, 0, 299)) && OUTROOF(CFLAG:MASTER:現在位置)
	SETBIT FLAGS, 3
SIF 画像特殊効果_縁取り
	SETBIT FLAGS, 4
SIF FLAG:時間停止
	SETBIT FLAGS, 5
; 默认生成为可交互按钮
SETBIT FLAGS, 6 
SIF FLAG:巨乳差分表示
	SETBIT FLAGS, 7

RETURNF FLAGS

;-------------------------------------------------
; 默认的表情判定逻辑，一种逐步探索方法
; 从@GET_FACETYPE中拆分
;-------------------------------------------------
@CALC_EXPRESSION_CORE(CHARA, 立绘种类, 服装, 差分, SYS_ID, 额外参数)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIMS 立绘种类
#DIMS 服装
#DIMS 差分
#DIM  SYS_ID
#DIMS REF 额外参数

#DIMS DYNAMIC EX_BASE
#DIMS DYNAMIC EX_HOVER
#DIMS DYNAMIC TEMP_B
#DIMS DYNAMIC TEMP_H
#DIM  DYNAMIC EMOTION_LV

IF TALENT:CHARA:心情 == -1 || CFLAG:CHARA:ブチギレ
	EX_BASE '= "憤怒"
	EMOTION_LV = -1
ELSEIF TALENT:CHARA:心情 == 1 || BASE:CHARA:情緒 >= MAXBASE:CHARA:情緒 * 7 / 10 || TCVAR:CHARA:烂醉
	EX_BASE '= "笑顔"
	EMOTION_LV = 1
ELSE
	EX_BASE '= "通常"
	EMOTION_LV = 0
ENDIF
SIF CHECK_CHARA(CHARA, "陥落")
	EMOTION_LV ++
SIF BATHROOM(CFLAG:CHARA:現在位置) && 風呂逐出条件(CHARA)
	EMOTION_LV --
SIF MARK:CHARA:反発刻印
	EMOTION_LV --
SIF BASE:CHARA:憤怒 >= 500
	EMOTION_LV --
SIF BASE:CHARA:情緒 >= 650
	EMOTION_LV ++
IF TALENT:CHARA:嫉妬 && FLAG:デート相手 == CHARA && TARGET != CHARA 
	EX_BASE '= "憤怒" 
	EMOTION_LV = -1 
ENDIF 

SELECTCASE EX_BASE
	CASE "笑顔"
		EX_HOVER '= "通常"
	CASE "憤怒"
		EX_HOVER '= (EMOTION_LV > 0) ? "通常" # "憤怒"
	CASEELSE
		EX_HOVER '= (EMOTION_LV > 0) ? "笑顔" # ((EMOTION_LV < 0) ? "憤怒" # "通常")
ENDSELECT

; 基础降级验证
SIF !CHECK_FACE_EXIST(CHARA, 立绘种类, 服装, 差分, EX_BASE, SYS_ID, 额外参数)
	EX_BASE '= "通常"
SIF !CHECK_FACE_EXIST(CHARA, 立绘种类, 服装, 差分, EX_HOVER, SYS_ID, 额外参数)
	EX_HOVER '= "通常"

IF ENDURE(CHARA) > 550 && BASE:CHARA:理性 <= 350
	IF CHECK_FACE_EXIST(CHARA, 立绘种类, 服装, 差分, "発情", SYS_ID, 额外参数)
		EX_BASE '= "発情"
		EX_HOVER '= "発情"
	ENDIF
ENDIF

IF TCVAR:CHARA:発情 && CHECK_FACE_EXIST(CHARA, 立绘种类, 服装, 差分, "発情", SYS_ID, 额外参数)
	EX_BASE '= "発情"
	EX_HOVER '= "発情"
ENDIF

IF CFLAG:CHARA:睡眠 && CHECK_FACE_EXIST(CHARA, 立绘种类, 服装, 差分, "睡眠", SYS_ID, 额外参数)
	EX_BASE '= "睡眠"
	EX_HOVER '= "睡眠"
ENDIF

IF CFLAG:CHARA:诶嘿嘿 && GETPALAMLV(PALAM:CHARA:欲情, 10) >= 7 && CHECK_FACE_EXIST(CHARA, 立绘种类, 服装, 差分, "トロ顔", SYS_ID, 额外参数)
	EX_BASE '= "トロ顔"
	EX_HOVER '= "トロ顔"
	IF NOWEX:CHARA:TotalEX >= 5 && CHECK_FACE_EXIST(CHARA, 立绘种类, 服装, 差分, "イキ顔", SYS_ID, 额外参数)
		EX_BASE '= "イキ顔"
		EX_HOVER '= "イキ顔"
	ENDIF
ENDIF

VARSET RESULTS
CALL IMAGE_CHARA_OVERRIDE("特殊表情", CHARA)
SIF RESULTS:0 != ""
	EX_BASE '= RESULTS:0
SIF RESULTS:1 != ""
	EX_HOVER '= RESULTS:1

[IF_DEBUG]
DEBUGPRINTFORML 状态表情「%EX_BASE%/%EX_HOVER%」
[ENDIF]
IF !FLAG:時間停止 && CHARA == TARGET && !CFLAG:CHARA:睡眠
	TEMP_B '= EX_BASE
	TEMP_H '= EX_HOVER
	
	IF IS_SEXING(CHARA) && CHECK_FACE_EXIST(CHARA, 立绘种类, 服装, 差分, "性交", SYS_ID, 额外参数)
		EX_BASE '= "性交"
		TEMP_B '= EX_BASE
	ENDIF
	
	SELECTCASE SELECTCOM
		CASE 0 TO 15
			EX_BASE '= (SELECTCOM == 9) ? "自慰" # "愛撫"
		CASE 60 TO 79, 317 TO 323
			EX_BASE '= "性交"
		CASE 313 TO 316
			IF CFLAG:CHARA:诶嘿嘿
				EX_BASE '= "愛撫"
			ELSEIF MARK:CHARA:不埒刻印 == 3
				EX_HOVER '= "愛撫"
			ENDIF
	ENDSELECT
	
	SIF !CHECK_FACE_EXIST(CHARA, 立绘种类, 服装, 差分, EX_BASE, SYS_ID, 额外参数)
		EX_BASE '= TEMP_B
	SIF !CHECK_FACE_EXIST(CHARA, 立绘种类, 服装, 差分, EX_HOVER, SYS_ID, 额外参数)
		EX_HOVER '= TEMP_H
ENDIF

IF RAND:3 && TCVAR:CHARA:発情 && CHECK_FACE_EXIST(CHARA, 立绘种类, 服装, 差分, "発情", SYS_ID, 额外参数)
	SWAP EX_BASE, EX_HOVER
ENDIF

VARSET RESULTS
CALL IMAGE_CHARA_OVERRIDE("特殊表情COM", CHARA, SELECTCOM)
SIF RESULTS:0 != ""
	EX_BASE '= RESULTS:0
SIF RESULTS:1 != ""
	EX_HOVER '= RESULTS:1

RESULTS:0 '= EX_BASE
RESULTS:1 '= EX_HOVER
RETURN

;-------------------------------------------------
; 内部工具：多系统索引的语法检查
; 参  数：SYS_ID = 系统识别符
;         额外参数 = 系统的额外参数
;-------------------------------------------------
@CHECK_FACE_EXIST(CHARA, 立绘种类, 服装, 差分, EXPR, SYS_ID, 额外参数)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM  CHARA
#DIMS 立绘种类
#DIMS 服装
#DIMS 差分
#DIMS EXPR
#DIM  SYS_ID
#DIMS 额外参数
#DIMS DYNAMIC RESOURCE_NAME
SELECTCASE SYS_ID
	CASE GRAPH_SYSTEM_STATIC
		; 格式: [立绘种类]_[服装]_[表情]_[NO]_[差分]
		RESOURCE_NAME '= @"%立绘种类%_%服装%_%EXPR%_{NO:CHARA}%差分%"
		DEBUGPRINTFORML %RESOURCE_NAME% is {RM_RESOURCECHECK(RESOURCE_NAME)}
		RETURNF RM_RESOURCECHECK(RESOURCE_NAME)
	CASE GRAPH_SYSTEM_COMPOSE_SPRITE
		RETURNF FINDELEMENT(额外参数, EXPR, , , 1) != -1
	CASE GRAPH_SYSTEM_SPIRIT
		; 格式: {NO}[Version]_[服装]_表情_[表情]
		DEBUGPRINTFORML {NO:CHARA}%COND_STR(@"%额外参数%_%服装%",额外参数 != "")%_表情_%EXPR% || {NO:CHARA}%COND_STR(额外参数,额外参数 != "")%_表情_%EXPR% is {(RM_RESOURCECHECK(@"{NO:CHARA}%COND_STR(@"%额外参数%_%服装%",额外参数 != "")%_表情_%EXPR%") || RM_RESOURCECHECK(@"{NO:CHARA}%COND_STR(额外参数,额外参数 != "")%_表情_%EXPR%"))}
		RETURNF (RM_RESOURCECHECK(@"{NO:CHARA}%COND_STR(@"%额外参数%_%服装%",额外参数 != "")%_表情_%EXPR%") || RM_RESOURCECHECK(@"{NO:CHARA}%COND_STR(额外参数,额外参数 != "")%_表情_%EXPR%"))
	CASEELSE
		DEBUGPRINTFORML SYS_ID.{SYS_ID}没有注册方法
		RETURNF 0
ENDSELECT

;-------------------------------------------------
; UI组件：CHECK_XRAY_BLOCKED
; 概  述：判断指定角色的 Xray 模块是否应该被隐藏
; 返回值：1 = 隐藏 (Blocked), 0 = 显示
; 备  注：曾经的注入式魔改补丁，抽象为组件
;-------------------------------------------------
@CHECK_XRAY_BLOCKED(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CHARA

SIF CFLAG:CHARA:恶作剧 == 2 || CFLAG:CHARA:诶嘿嘿 != 0
	RETURNF 0 ; 在恶作剧或诶嘿嘿中，无条件解除屏蔽(显示)

IF Xray_display_mode > 4
	IF GETBIT(Xray_display_mode, 2) && GETBIT(Xray_display_mode, 3) && 充填率(CHARA, 3) == 0 && PALAM:CHARA:潤滑 <= 500
		RETURNF 1
	ELSEIF !GETBIT(Xray_display_mode, 2) && GETBIT(Xray_display_mode, 3) && 充填率(CHARA, 3) == 0
		RETURNF 1
	ELSEIF GETBIT(Xray_display_mode, 2) && !GETBIT(Xray_display_mode, 3) && PALAM:CHARA:潤滑 <= 500
		RETURNF 1
	ENDIF
ELSEIF GETBIT(Xray_display_mode, 1)
	RETURNF 1
ENDIF

RETURNF 0

;-------------------------------------------------
; 工具函数：GET_DEFAULT_IMAGE_WIDTH
; 概  述：根据系统当前的“多尺寸”设置，计算指定图片应当占据的真实像素【宽度】
; 参  数：SPRITE_NAME = 图像资源名
;         SCALE = 缩放百分比（默认-1时，自动套用全局设置 100+isModifier）
; 返回值：计算后的像素宽度 (Integer)
;-------------------------------------------------
@GET_DEFAULT_IMAGE_WIDTH(SPRITE_NAME = "", SCALE = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIMS SPRITE_NAME
#DIM  SCALE
#DIM  RAW_W
#DIM  RAW_H
#DIM  W_PX

IF SPRITE_NAME == "" || !RM_RESOURCECHECK(SPRITE_NAME)
	RAW_W = 默认角色画像横幅
	RAW_H = 默认角色画像横幅
ELSE
	RAW_W = RM_SPRITEWIDTH(SPRITE_NAME)
	RAW_H = RM_SPRITEHEIGHT(SPRITE_NAME)
	SIF RAW_W <= 0
		RAW_W = 默认角色画像横幅
	SIF RAW_H <= 0
		RAW_H = 默认角色画像横幅
ENDIF

IF FLAG:多尺寸
	W_PX = RAW_W
ELSE
	W_PX = RAW_W * 默认角色画像横幅 / RAW_H
ENDIF

SIF SCALE == -1
	SCALE = 100 + isModifier

RETURNF W_PX * SCALE / 100

@GET_DEFAULT_IMAGE_HEIGHT(SPRITE_NAME = "", SCALE = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIMS SPRITE_NAME
#DIM  SCALE
#DIM  RAW_H
#DIM  H_PX

IF SPRITE_NAME == "" || !RM_RESOURCECHECK(SPRITE_NAME)
	RAW_H = 默认角色画像横幅
ELSE
	RAW_H = RM_SPRITEHEIGHT(SPRITE_NAME)
	SIF RAW_H <= 0
		RAW_H = 默认角色画像横幅
ENDIF

IF FLAG:多尺寸
	H_PX = RAW_H
ELSE
	H_PX = 默认角色画像横幅
ENDIF

SIF SCALE == -1
	SCALE = 100 + isModifier

RETURNF H_PX * SCALE / 100

