;-------------------------------------------------
; 内部工具：ASSEMBLE_HTML_IMAGE_LAYERS
; 概  述：将一张底图和多个图层（特效/边框/蒙版）按顺序拼合成重叠的 HTML 字符串。
; 参  数：BASE_IMG = 底图, HOVER_IMG = 悬停图
;         EFF_IMGS = 附加图层数组 (使用 REF 传递)
;         EFF_CNT  = 附加图层数量
;         MAX_H_PX = 容器最大高度 (用于计算下沉对齐的 YPOS)
;         SCALE    = 缩放比例
; 返回值：拼合好的 HTML 字符串
;-------------------------------------------------
@ASSEMBLE_HTML_IMAGE_LAYERS(BASE_IMG, HOVER_IMG, EFF_IMGS, EFF_CNT, MAX_H_PX, SCALE = 100)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS          BASE_IMG
#DIMS          HOVER_IMG
#DIMS REF      EFF_IMGS
#DIM           EFF_CNT
#DIM           MAX_H_PX
#DIM           SCALE
#DIMS DYNAMIC  HTML_STR
#DIM  DYNAMIC  IMG_W_PX
#DIM  DYNAMIC  IMG_H_PX
#DIM  DYNAMIC  Y_OFF
IF !RM_RESOURCECHECK_LOAD(BASE_IMG)
	DEBUGPRINTFORML 找不到资源名：%BASE_IMG%
	BASE_IMG = im_av_empty
ENDIF
IF !RM_RESOURCECHECK_LOAD(HOVER_IMG)
	DEBUGPRINTFORML 找不到资源名：%HOVER_IMG%
	HOVER_IMG = 
ENDIF

IMG_W_PX = GET_DEFAULT_IMAGE_WIDTH(BASE_IMG, SCALE)
IMG_H_PX = GET_DEFAULT_IMAGE_HEIGHT(BASE_IMG, SCALE)
Y_OFF = MAX_H_PX - IMG_H_PX

HTML_STR '= @"<img src='%BASE_IMG%' \@ HOVER_IMG != "" ? srcb='%HOVER_IMG%' # \@ width='{IMG_W_PX}px' height='{IMG_H_PX}px' ypos='{Y_OFF}px'>"
FOR LOCAL, 0, EFF_CNT
	SIF EFF_IMGS:LOCAL == "" || !RM_RESOURCECHECK_LOAD(EFF_IMGS:LOCAL)
		CONTINUE
	HTML_STR += @"<shape type='space' param='-{IMG_W_PX}px'>"
	HTML_STR += @"<img src='%EFF_IMGS:LOCAL%' width='{IMG_W_PX}px' height='{IMG_H_PX}px' ypos='{Y_OFF}px'>"
NEXT
RETURNF HTML_STR

;=========================================================
; 构建模块：BUILD_XRAY_IMAGE_BLOCK
;=========================================================
@BUILD_XRAY_IMAGE_BLOCK(CHARA, MAX_H_PX, CHARA_W_PX)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIM MAX_H_PX
#DIM CHARA_W_PX
#DIMS DYNAMIC HTML_STR

; --- [新版 Hook] ---
;TRYCCALLFORM XRAY_IMAGE_STRING(CHARA, 0, 0)
;	RETURNF RESULTS 
;CATCH
;ENDCATCH

;[SKIPSTART]
; --- [当前重构版] ---
#DIMS DYNAMIC XRAY_IMGS, 10
#DIM  DYNAMIC XRAY_Y_PCT, 10
#DIM  DYNAMIC XRAY_CNT
#DIM  DYNAMIC W_PX
#DIM  DYNAMIC H_PX
#DIM  DYNAMIC Y_OFF
RESULT = 0
CALL GET_XRAY_RESOURCES(CHARA, XRAY_IMGS, XRAY_Y_PCT)
XRAY_CNT = RESULT
W_PX = CHARA_W_PX / 5

IF XRAY_CNT == 0
	RESULTS '= @"<img src='im_av_empty' width='{W_PX}px' height='{MAX_H_PX}px'>"
	RETURN
ENDIF

HTML_STR '= @"<img src='im_av_chara' width='{W_PX}px' height='{MAX_H_PX}px' ypos='0'>"
H_PX = MAX_H_PX / 5

FOR LOCAL, 0, XRAY_CNT
	Y_OFF = MAX_H_PX - (MAX_H_PX * XRAY_Y_PCT:LOCAL / 100)
	HTML_STR += @"<shape type='space' param='-{W_PX}px'>"
	HTML_STR += @"<img src='%XRAY_IMGS:LOCAL%' width='{W_PX}px' height='{H_PX}px' ypos='{Y_OFF}px'>"
NEXT
RESULTS '= HTML_STR
;[SKIPEND]

;=========================================================
;路由层
;=========================================================

;=========================================================
; 核心路由：QOL_GET_BASE_RESOURCE
; 概  要：分发资源请求、获取立绘索引
; 参  数：
;   CHARA : 角色ID
;   立绘种类 : 强制指定的显示形式 (如 "顔絵", "立絵")，为空则自动判定
;   服装 : 强制指定的服装状态，为空则自动判定
;   表情 : 强制指定的表情文本，为空则走状态机
;   表情_マウスオーバー : 强制指定的悬停表情
;   差分 : 强制指定的皮肤/状态差分
;   ALLOW_BUST_DIFF : 是否允许开启巨乳降级循环逻辑 (默认1)
; 返回值：
;   RESULTS:0 = 基础图, RESULTS:1 = 鼠标悬停图, RESULT = 1(成功)/0(失败)
;=========================================================
@QOL_GET_BASE_RESOURCE(CHARA, 立绘种类 = "", 服装 = "", 表情 = "", 表情_マウスオーバー = "", 差分 = "", ALLOW_BUST_DIFF = 1)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIMS 立绘种类
#DIMS 服装
#DIMS 表情
#DIMS 表情_マウスオーバー
#DIMS 差分
#DIM  ALLOW_BUST_DIFF

#DIMS DYNAMIC EX_BASE
#DIMS DYNAMIC EX_HOVER
#DIMS DYNAMIC 乳型 = "絶壁", "貧乳", "並乳", "巨乳", "爆乳"
#DIM  DYNAMIC CHARA_CSV_乳型
#DIM  DYNAMIC LOOP_乳型

VARSET RESULTS

TRYCCALLFORM SPECIAL_BASE_IMAGE_{NO:CHARA}
	IF RESULTS != ""
		TRYCCALLFORM %RESULTS%_GET_BASE_RESOURCE(CHARA, 立绘种类, 服装, 表情, 表情_マウスオーバー, 差分)
			RETURN 1
		CATCH
			VARSET RESULTS
		ENDCATCH
	ENDIF
CATCH
ENDCATCH

立绘种类 = %GET_BASESTYLE(CHARA, 立绘种类)%

IF 表情 != ""
	EX_BASE  '= 表情
	EX_HOVER '= (表情_マウスオーバー != "") ? 表情_マウスオーバー # 表情
ENDIF

IF 差分 == ""
	CALL IMAGE_CHARA_OVERRIDE("差分", CHARA)
	SIF RESULT:1
		差分 = %RESULTS%
ENDIF

IF 服装 == ""
	服装 '= CHECK_NUDE(CHARA) ? "裸" # "服"
	CALL IMAGE_CHARA_OVERRIDE("特殊服装", CHARA)
	SIF RESULT:1
		服装 += RESULTS
ENDIF

IF FLAG:巨乳差分表示 && ALLOW_BUST_DIFF
	CHARA_CSV_乳型 = CSVTALENT(NO:CHARA, GETNUM(TALENT, "胸围"))
	LOOP_乳型 = TALENT:CHARA:胸围

	FOR LOCAL, 0, 4
		LOOP_乳型 = LIMIT(LOOP_乳型, -2, 2)

		CALL GET表情体形完整(CHARA, 立绘种类, 服装, EX_BASE, EX_HOVER, 差分, 乳型:(LOOP_乳型 + 2))
		IF RESULT
			RETURN 1
		ENDIF
		CALL GET表情体形拆分组合(CHARA, 立绘种类, 服装, EX_BASE, EX_HOVER, 差分, 乳型:(LOOP_乳型 + 2))
		IF RESULT
			RETURN 1
		ENDIF

		SIF LOOP_乳型 == CHARA_CSV_乳型
			BREAK
		IF CHARA_CSV_乳型 > LOOP_乳型
			LOOP_乳型++
		ELSE
			LOOP_乳型--
		ENDIF
	NEXT
ENDIF

CALL GET表情体形完整(CHARA, 立绘种类, 服装, EX_BASE, EX_HOVER, 差分)
SIF RESULT
	RETURN 1

RESULTS:0 = ""
RESULTS:1 = ""
RETURN 0

