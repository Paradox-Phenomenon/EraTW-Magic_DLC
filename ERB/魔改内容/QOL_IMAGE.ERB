	RETURNF @"フレーム\@CHARA==TARGET?_ターゲット#\@_憤怒"
ELSEIF TALENT:CHARA:心情 == 1
	RETURNF @"フレーム\@CHARA==TARGET?_ターゲット#\@_笑顔"
ELSE
