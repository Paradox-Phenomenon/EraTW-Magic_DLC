@IMAGE_COMPONENT_FILTER(SPRITE_NAME, CHARA, IMG_FLAGS)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIMS SPRITE_NAME
#DIM  CHARA
#DIM  IMG_FLAGS
#DIMS DYNAMIC L_EFFECTNAME

SIF SPRITE_NAME == ""
	RETURNF ""

SIF GETBIT(IMG_FLAGS, 3)
	L_EFFECTNAME '= ADD_EFFECT_WORD(L_EFFECTNAME, EFFNAME_夜)
SIF GETBIT(IMG_FLAGS, 4)
	L_EFFECTNAME '= ADD_EFFECT_WORD(L_EFFECTNAME, EFFNAME_縁取り)

IF L_EFFECTNAME != ""
	RETURNF PICTURE_EFFECT(SPRITE_NAME, L_EFFECTNAME, CHARA)
ENDIF
RETURNF SPRITE_NAME

