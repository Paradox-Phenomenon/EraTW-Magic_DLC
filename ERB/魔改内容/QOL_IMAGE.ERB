;-------------------------------------------------
; 应用：PRINT_STATE_IMAGE
; 概  述：能力信息页面单人立绘显示
; 参  数：iID = 角色ID
;-------------------------------------------------
@QOL_PRINT_STATE_IMAGE(iID)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM iID
#DIMS DYNAMIC HTML_STR
#DIM  DYNAMIC PREV_FACE_TYPE
#DIM  DYNAMIC L_H

SIF !iID && !自机立绘开关
	RETURN RESULT

SIF ((FLAG:立絵種類 == 1 && CFLAG:iID:別顔有) || (FLAG:立絵種類 == 0 && CFLAG:iID:別立ち有)) && FLAG:画像表示
	PRINTFORMLC [98]立绘包:\@CFLAG:iID:差し替え適用?可选立绘{CFLAG:iID:差し替え適用}#初始立绘\@
PRINTL

SIF !FLAG:画像表示
	RETURN RESULT

; 路人生成
IF iID < CHARANUM && TALENT:iID:路人 && !GCREATED(CFLAG:iID:路人子素材CFLAG開始位置)
	CALL 路人子生成(iID, 0)
	CALL 路人子生成(iID, 1)
ENDIF

L_H = GET_DEFAULT_IMAGE_HEIGHT()
IF iID < CHARANUM
	RESULTS =
	CALL BUILD_CHARA_IMAGE_BLOCK(iID, 0, L_H, 100, GET_DEFAULT_IMAGE_FLAGS() & ~(1p6), "顔絵", "", "通常")
	HTML_STR += RESULTS
	HTML_STR += @"<shape type='space' param='20px'>" ; 两张图中间留 20px 间隙
	
	RESULTS =
	CALL BUILD_CHARA_IMAGE_BLOCK(iID, 0, L_H, 100, GET_DEFAULT_IMAGE_FLAGS() & ~(1p6), "立絵", "", "通常")
	HTML_STR += RESULTS
ELSE
	; 占位符兜底
	HTML_STR += @"<img src='im_av_empty' height='L_Hpx'>"
ENDIF

CALL HTML_PRINTL_PX(HTML_STR, L_H)

RETURN RESULT

;-------------------------------------------------
; 应  用：PRINT_SINGLE_CHARA_IMAGE
; 概  述：打印与UI界面显示一致的角色立绘
; 参  数：CHARA = 角色ID, H_PX = 画框像素高度 (默认 UI当前设定)
; 示  例：CALL PRINT_SINGLE_CHARA_IMAGE(TARGET, 400)
;-------------------------------------------------
@PRINT_SINGLE_CHARA_IMAGE(CHARA, H_PX = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIM H_PX
#DIMS DYNAMIC BASE_IMG

SIF !FLAG:画像表示 || CHARA <= 0
	RETURN
CALL QOL_GET_BASE_RESOURCE(CHARA)
BASE_IMG '= RESULTS:0

SIF H_PX <= 0
	H_PX = GET_DEFAULT_IMAGE_HEIGHT(BASE_IMG)
CALL BUILD_CHARA_IMAGE_BLOCK(CHARA, 0, H_PX, 100, GET_DEFAULT_IMAGE_FLAGS() & ~(1p6))
CALL HTML_PRINTL_PX, RESULTS, H_PX

;-------------------------------------------------
; 应  用：PrintOnanismImage
; 概  述：自慰事件配图
;-------------------------------------------------
@QOL_PrintOnanismImage(C_ID)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM C_ID
#DIMS DYNAMIC HTML_STR
#DIM  DYNAMIC PREV_FACE_TYPE
#DIMS DYNAMIC BASE_IMG
#DIMS DYNAMIC EFF_IMGS, 10
#DIM  DYNAMIC EFF_CNT
#DIM  DYNAMIC IMG_H_PX = 300 ; 设定画框高度
#DIM  DYNAMIC IMG_W_PX

SIF !C_ID || !FLAG:画像表示
	RETURN RESULT

PREV_FACE_TYPE = FLAG:立絵種類
FLAG:立絵種類 = 1

CALL IMAGE_CHARA_OVERRIDE("特殊自慰", C_ID)
IF RESULT:1 && RESULTS:0 != ""
	BASE_IMG '= RESULTS:0
	EFF_CNT = 0
	FOR LOCAL, 0, VARSIZE("特殊自慰_エフェクト")
		IF RESULTS:(LOCAL + 1) != "" && RM_RESOURCECHECK(RESULTS:(LOCAL + 1))
			EFF_IMGS:EFF_CNT '= RESULTS:(LOCAL + 1)
			EFF_CNT++
		ENDIF
	NEXT
ELSE
	CALL QOL_GET_BASE_RESOURCE(C_ID, "顔絵", "裸")
	BASE_IMG '= RESULTS:0
	
	CALL GET_EFFECT_RESOURCE(C_ID, "吐息", "顔絵", "", "裸")
	EFF_CNT = RESULT
	FOR LOCAL, 0, EFF_CNT
		EFF_IMGS:LOCAL '= RESULTS:LOCAL
	NEXT

	TRYCCALLFORM SPECIAL_BASE_IMAGE_{C_ID}
		IF RESULTS == "EagloV"
			CALL GET_EFFECT_RESOURCE(C_ID, "照れ", "顔絵", "", "裸")
			IF RESULT > 0
				EFF_IMGS:EFF_CNT '= RESULTS:0
				EFF_CNT++
			ENDIF
		ENDIF
	CATCH
		CALL IMAGE_CHARA_OVERRIDE("自慰エフェクト", C_ID)
		IF RESULT:1
			FOR LOCAL, 0, RESULT
				IF RM_RESOURCECHECK(RESULTS:LOCAL)
					EFF_IMGS:EFF_CNT '= RESULTS:LOCAL
					EFF_CNT++
				ENDIF
			NEXT
		ENDIF
	ENDCATCH
ENDIF

; 组装 HTML
HTML_STR '= ASSEMBLE_HTML_IMAGE_LAYERS(BASE_IMG, "", EFF_IMGS, EFF_CNT, IMG_H_PX, 100)
; 渲染 HTML
CALL HTML_PRINTL_PX, HTML_STR, IMG_H_PX

FLAG:立絵種類 = PREV_FACE_TYPE
RETURN RESULT

;=========================================================
;输出层
;=========================================================
;-------------------------------------------------
; 渲染组件：为跨行渲染的HTML格式字符串自动换行
; 概  述：打印传入的 HTML 串，并自动补齐换行，确保后续文字不与图片重叠。
; 参  数：HTML_STR  = 要打印的 HTML 字符串
;         HEIGHT_PX = 该内容向下渲染的总像素高度
;-------------------------------------------------
@HTML_PRINTL_PX(HTML_STR, HEIGHT_PX)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC HTML_STR
#DIM  DYNAMIC HEIGHT_PX
#DIM  DYNAMIC L_START
#DIM  DYNAMIC LINES_NEEDED
#DIM  DYNAMIC LINES_DRAWN

L_START = LINECOUNT
HTML_PRINT HTML_STR

LINES_NEEDED = (HEIGHT_PX + GETCONFIG("一行の高さ") - 1) / GETCONFIG("一行の高さ")
LINES_DRAWN = LINECOUNT - L_START

FOR LOCAL, 0, MAX(0, LINES_NEEDED - LINES_DRAWN)
	PRINTL 
NEXT

;-------------------------------------------------
; 渲染组件：PRINT_IMAGE_SETTINGS_FOOTER
; 概  述：渲染立绘显示界面底部的控制按钮栏
; 参  数：TARGET_LIST = 当前目标数组，TARGET_NUM = 总人数，CUR_TARGET_IDX = 当前目标在数组中的索引
;-------------------------------------------------
@PRINT_IMAGE_SETTINGS_FOOTER(TARGET_LIST, TARGET_NUM, CUR_TARGET_IDX)
#LOCALSIZE 3
#LOCALSSIZE 1
#DIM REF TARGET_LIST
#DIM  DYNAMIC TARGET_NUM
#DIM  DYNAMIC CUR_TARGET_IDX
#DIMS DYNAMIC sPrint_Text
#DIM  DYNAMIC CHARATRANS

SIF !FLAG:画像表示設定
	RETURN

; 开始构建 HTML
sPrint_Text = <p align='\@FLAG:画像表示位置?left#center\@'>

; --- 第一行：功能开关 ---
sPrint_Text += @"<button value='3105' title='现在：\@FLAG:立絵種類?颜绘#立绘\@'>立绘种类[\@FLAG:立絵種類?颜绘#立绘\@]</button>　"
sPrint_Text += @"<button value='3103' title='现在：\@FLAG:画像表示位置?左对齐#居中对齐\@'>表示位置[\@FLAG:画像表示位置?left#center\@]</button>　"
sPrint_Text += @"<button value='3104' title='现在：\@FLAG:画像枠表示?ON#OFF\@'>边框显示[\@FLAG:画像枠表示?ON#OFF\@]</button>　"
sPrint_Text += @"<button value='3108' title='现在：\@FLAG:巨乳差分表示?ON#OFF\@'>巨乳差分[\@FLAG:巨乳差分表示?ON#OFF\@]</button>　"
sPrint_Text += @"<button value='3109' title='现在：\@FLAG:追加エフェクト?ON#OFF\@'>特效表情[\@FLAG:追加エフェクト?ON#OFF\@]</button>　"

; Xray 开关
sPrint_Text += @"<button value='3999' title='现在：\@FLAG:XRay_show?{FLAG:XRay_show}#OFF\@'>"
LOCALS = \@GETBIT(FLAG:XRay_show,0)?Ａ#nA\@\@GETBIT(FLAG:XRay_show,1)?心#胎\@
sPrint_Text += @"XRAY[\@FLAG:XRay_show?%LOCALS%#OFF\@]</button>"

; 变身/差分角色处理
CHARATRANS = TARGET
SIF CFLAG:TARGET:変化先
	CHARATRANS = CFLAG:TARGET:変化先
IF CFLAG:CHARATRANS:別顔有 || CFLAG:CHARATRANS:別立ち有
	sPrint_Text += @"　<button value='3110' title='现在：\@CFLAG:CHARATRANS:差し替え適用?ON#OFF\@'>差分[\@CFLAG:CHARATRANS:差し替え適用?ON({CFLAG:CHARATRANS:差し替え適用})#OFF\@]</button>"
ENDIF
sPrint_Text += "<br>"

; --- 第二行：翻页与缩放控制 ---
; 防越界处理
LOCAL:1 = MAX(CUR_TARGET_IDX - 1, 1)
LOCAL:2 = MIN(CUR_TARGET_IDX + 1, TARGET_NUM)

sPrint_Text += @"<button value='{1000 + TARGET_LIST:(LOCAL:1)}' title='上一角色'>＜＜</button>"
sPrint_Text += @"<button value='3101' title='显示图像人数－'>[－]</button>"
sPrint_Text += @"显示人数[{FLAG:画像表示}]"
sPrint_Text += @"<button value='3102' title='显示图像人数＋'>[＋]</button>"
sPrint_Text += @"<button value='{1000 + TARGET_LIST:(LOCAL:2)}' title='下一角色'>＞＞</button>　"

sPrint_Text += @"<button value='3106' title='统一减小缩放比例'>[－]</button>"
sPrint_Text += @"<button value='3111' title='设定调整缩放比例前的图像尺寸：现在是\@FLAG:多尺寸?图片原始尺寸（※可能出现大小不一）#统一{默认角色画像横幅}px\@'>"
sPrint_Text += @"画像尺寸[\@FLAG:多尺寸?原始尺寸#{默认角色画像横幅}px\@:{100 + isModifier}％]</button>"
sPrint_Text += @"<button value='3107' title='统一增加缩放比例'>[＋]</button>"

HTML_PRINT sPrint_Text

;=========================================================
;构建层
;=========================================================

;-------------------------------------------------
; 组件：BUILD_CHARA_IMAGE_BLOCK
; 参  数：CHARA = 角色ID, BTN_VAL = 按钮值, MAX_H_PX = 框高(-1则自动获取), SCALE = 缩放, IMG_FLAGS = 64位标记
;         覆写参数，传入则强制使用，不传则走常规状态机
;         O_STYLE = 强制表示形式 (如 "顔絵")
;         O_CLOTH = 强制服装
;         O_EXPR  = 强制表情
;         O_DIFF  = 强制差分
;         O_EFF   = 附加的特效串 (逗号分隔)
; 返回值：RESULTS = HTML 字符串, RESULT = 最终的画像高度(PX)
; 备  注：取消伪装环境的尝试失败，参数传递最多进入到路由层分发的另一个系统路由，本系统之外的合成层依赖 FLAG:立绘种类 参数进行不同的合成行为。由于无法对所有合成系统进行改造，因此在构建栈内伪装环境目前是必须的
;-------------------------------------------------
@BUILD_CHARA_IMAGE_BLOCK(CHARA, BTN_VAL, MAX_H_PX = -1, SCALE = 100, IMG_FLAGS = -1, O_STYLE="", O_CLOTH="", O_EXPR="", O_DIFF="", O_EFF="")
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM  DYNAMIC CHARA
#DIM  DYNAMIC BTN_VAL
#DIM  DYNAMIC MAX_H_PX
#DIM  DYNAMIC SCALE
#DIM  DYNAMIC IMG_FLAGS

#DIMS DYNAMIC O_STYLE
#DIMS DYNAMIC O_CLOTH
#DIMS DYNAMIC O_EXPR
#DIMS DYNAMIC O_DIFF
#DIMS DYNAMIC O_EFF

#DIMS DYNAMIC BASE_IMG
#DIMS DYNAMIC HOVER_IMG
#DIMS DYNAMIC LAYERS, 30
#DIM  DYNAMIC LAYER_CNT
#DIMS DYNAMIC HTML_BLOCK
#DIM  DYNAMIC CHARA_W_PX

#DIMS DYNAMIC CUSTOM_EFFS, 100
#DIM  DYNAMIC CUSTOM_EFF_NUM
#DIMS DYNAMIC TEMP_EFF_NAME
#DIMS DYNAMIC RES_NAME
#DIM  DYNAMIC L_CLOTH_NUDE
#DIM  DYNAMIC PREV_立ち絵種類
#DIMS DYNAMIC IMAGE_TITLE

IF IMG_FLAGS == -1
	IMG_FLAGS = GET_DEFAULT_IMAGE_FLAGS()
ENDIF
PREV_立ち絵種類 = FLAG:立ち絵種類
IF O_STYLE == "顔絵"
	FLAG:立ち絵種類 = 1
ELSEIF O_STYLE == "立絵"
	FLAG:立ち絵種類 = 0
ELSE
	O_STYLE = %GET_BASESTYLE(CHARA, O_STYLE)%
ENDIF

; 提取底图
VARSET RESULT
VARSET RESULTS
CALL QOL_GET_BASE_RESOURCE(CHARA, , O_CLOTH, O_EXPR, O_EXPR, O_DIFF, GETBIT(IMG_FLAGS, 7))
IF MAX_H_PX == -1
	MAX_H_PX = GET_DEFAULT_IMAGE_HEIGHT(RESULTS:0)
ENDIF
IF RESULT == 0 || RESULTS:0 == ""
	; 空图占位保护
	RESULTS '= @"<img src='im_av_empty' width='{MAX_H_PX}px' height='{MAX_H_PX}px'>"
	FLAG:立ち絵種類 = PREV_立ち絵種類
	RETURN MAX_H_PX
ENDIF
BASE_IMG  '= IMAGE_COMPONENT_FILTER(RESULTS:0, CHARA, IMG_FLAGS)
HOVER_IMG '= IMAGE_COMPONENT_FILTER(GETBIT(IMG_FLAGS, 5) ? "" # RESULTS:1, CHARA, IMG_FLAGS)

LAYER_CNT = 0
; 2. 自然特效图层 (受 Bit 1 控制)
IF GETBIT(IMG_FLAGS, 1)
	CALL GET_EFFECT_RESOURCE(CHARA, "", , O_DIFF, O_CLOTH)
	FOR LOCAL, 0, RESULT
		LAYERS:LAYER_CNT '= IMAGE_COMPONENT_FILTER(RESULTS:LOCAL, CHARA, IMG_FLAGS)
		LAYER_CNT++
	NEXT
ENDIF

; 3. 追加的强制定制特效 (附加在自然特效之上)
IF O_EFF != ""
	; 确认是否是裸体以便拼装前缀
	L_CLOTH_NUDE = (O_CLOTH == "裸" || CHECK_NUDE(CHARA))
	SPLIT O_EFF, ",", CUSTOM_EFFS, CUSTOM_EFF_NUM
	O_STYLE '= GET_BASESTYLE(CHARA, O_STYLE)
	FOR LOCAL, 0, CUSTOM_EFF_NUM
		TEMP_EFF_NAME '= CUSTOM_EFFS:LOCAL
		RES_NAME '= @"%O_STYLE%_%TEMP_EFF_NAME%_{NO:CHARA}%O_DIFF%"
		
		IF RM_RESOURCECHECK(RES_NAME)
			LAYERS:LAYER_CNT '= RES_NAME
			LAYER_CNT++
		ELSEIF L_CLOTH_NUDE && RM_RESOURCECHECK(@"%O_STYLE%_裸%TEMP_EFF_NAME%_{NO:CHARA}%O_DIFF%")
			LAYERS:LAYER_CNT '= @"%O_STYLE%_裸%TEMP_EFF_NAME%_{NO:CHARA}%O_DIFF%"
			LAYER_CNT++
		ELSEIF RM_RESOURCECHECK(TEMP_EFF_NAME)
			LAYERS:LAYER_CNT '= TEMP_EFF_NAME
			LAYER_CNT++
		ENDIF
	NEXT
ENDIF

; 4. 边框图层
IF GETBIT(IMG_FLAGS, 0)
	LAYERS:LAYER_CNT '= IMAGE_COMPONENT_FRAME(CHARA)
	LAYER_CNT++
ENDIF

; 5. 时停图层
IF GETBIT(IMG_FLAGS, 5)
	LAYERS:LAYER_CNT '= "時間停止"
	LAYER_CNT++
ENDIF

; === 开始 HTML 包装 ===
IF IS_DEBUG()
	IMAGE_TITLE '= @"%BASE_IMG%<br>%HOVER_IMG%"
ELSE
	IMAGE_TITLE '= @"%CALLNAME:CHARA% ID:{CHARA}"
ENDIF
IF GETBIT(IMG_FLAGS, 6)
	HTML_BLOCK '= @"<button value='{BTN_VAL}' title='%IMAGE_TITLE%'>"
ELSE
	HTML_BLOCK '= @"<nonbutton title='%IMAGE_TITLE%'>"
ENDIF

HTML_BLOCK += ASSEMBLE_HTML_IMAGE_LAYERS(BASE_IMG, HOVER_IMG, LAYERS, LAYER_CNT, MAX_H_PX, SCALE)
HTML_BLOCK += GETBIT(IMG_FLAGS, 6) ? "</button>" # "</nonbutton>"

; 6. 追加 Xray 模块
IF GETBIT(IMG_FLAGS, 2)
	CHARA_W_PX = GET_DEFAULT_IMAGE_WIDTH(BASE_IMG, SCALE)
	;HTML_BLOCK += @"<shape type='space' param='5px'>"
	CALL BUILD_XRAY_IMAGE_BLOCK(CHARA, MAX_H_PX, CHARA_W_PX)
	HTML_BLOCK += RESULTS
ENDIF

RESULTS '= HTML_BLOCK
FLAG:立ち絵種類 = PREV_立ち絵種類
RETURN MAX_H_PX

;-------------------------------------------------
; 函数名：BUILD_CHARA_IMAGE_BLOCK_OVARRIDE
; 概  述：构建角色立绘HTML图像块（核心接口，支持多层特效叠加、悬停效果、自然/自定义特效）
; 参  数：	CID				 - 角色ID（-1 表示当前玩家）
; 			表情			 - 表情名称（默认 ""）
; 			服装			 - 服装名称（默认 ""）
; 			差分			 - 差分名称（默认 ""）
; 			エフェクト		 - 追加特效列表（逗号分隔，默认 ""）
; 			立绘种类		 - 立绘种类名称（默认 ""）
; 			立绘选择		 - 立绘选择索引（=-1）
; 			EFFECT_OVERRIDE	 - 是否覆盖自然特效（=0 使用自然特效）
; 返回值：	RESULTS			 - 构造好的HTML字符串
;			RESULT			 - 图片的行高
; 备  注：很难说明为什么核心模块的覆写器和继承器是两个。主要原因是BUILD_CHARA_IMAGE_BLOCK_OVARRIDE的下游封装PRINT_FIGURE的向后兼容接口PRINT_FACE是一个耦合了路人立绘合成与打印功能的又一个上帝函数。BUILD_CHARA_IMAGE_BLOCK_OVARRIDE继承了这一部分技术债，而BUILD_CHARA_IMAGE_BLOCK是个相对纯净的模块。
;-------------------------------------------------
@BUILD_CHARA_IMAGE_BLOCK_OVARRIDE(CID, 表情="", 服装="", 差分="", エフェクト="", 立绘种类="", 立绘选择=-1, EFFECT_OVERRIDE=0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM  DYNAMIC CID
#DIMS DYNAMIC 表情
#DIMS DYNAMIC 服装
#DIMS DYNAMIC 差分
#DIMS DYNAMIC エフェクト
#DIMS DYNAMIC 立绘种类
#DIM  DYNAMIC 立绘选择
#DIM  DYNAMIC EFFECT_OVERRIDE

#DIMS DYNAMIC BASE_IMG
#DIMS DYNAMIC HOVER_IMG
#DIMS DYNAMIC EFF_IMGS, 200      ; 扩容以容纳更多叠加图层
#DIM  DYNAMIC EFF_CNT
#DIMS DYNAMIC HTML_STR
#DIM  DYNAMIC H_PX
#DIM  DYNAMIC PREV_立ち絵種類
#DIM  DYNAMIC PREV_立绘选择

#DIMS DYNAMIC CUSTOM_EFFS, 100
#DIM  DYNAMIC CUSTOM_EFF_NUM
#DIMS DYNAMIC TEMP_EFF_NAME
#DIMS DYNAMIC RES_NAME

PREV_立ち絵種類 = FLAG:立ち絵種類
PREV_立绘选择 = CFLAG:CID:差し替え適用
IF 立绘种类 == "顔絵"
	FLAG:立ち絵種類 = 1
ELSEIF 立绘种类 == "立絵"
	FLAG:立ち絵種類 = 0
ELSE
	立绘种类 = %GET_BASESTYLE(CID, 立绘种类)%
ENDIF
SIF 立绘选择 != -1
	CFLAG:CID:差し替え適用 = LIMIT(立绘选择, 0, CFLAG:CID:別顔有)

SIF 表情 == ""
	表情 = 通常

IF CID > 0 || CID == -1
	SIF CID == -1
		CID = PLAYER
	TRYCALLFORM IMAGE_EX_I{NO:CID}_PREリソースチェック(CID, 立绘种类, 服装, 表情, "", 差分, "")
	CALL QOL_GET_BASE_RESOURCE(CID, 立绘种类, 服装, 表情, , 差分)
	IF RESULT
		BASE_IMG '= RESULTS:0
		HOVER_IMG '= FLAG:時間停止 ? "" # RESULTS:1
	ELSE
		BASE_IMG '= @"%立绘种类%_服_通常_{CID}"
		HOVER_IMG '= BASE_IMG
	ENDIF
ELSE
	; 路人逻辑
	BASE_IMG '= @"%立绘种类%_%服装%_%表情%_MOB_%差分%"
	IF !RM_RESOURCECHECK(BASE_IMG)
		CALL 路人店員画像作成(TOINT(差分))
		IF !RM_RESOURCECHECK(BASE_IMG)
			BASE_IMG '= @"%立绘种类%_服_通常_MOB_%差分%"
			IF !RM_RESOURCECHECK(BASE_IMG)
				DEBUGPRINTFORML 未找到%BASE_IMG%
				RESULTS =
				RETURN
			ENDIF
		ENDIF
	ENDIF
	HOVER_IMG '= BASE_IMG
ENDIF

EFF_CNT = 0
; 自然特效
IF EFFECT_OVERRIDE == 0
	CALL GET_EFFECT_RESOURCE(CID, "", 立绘种类, 差分, 服装)
	FOR LOCAL, 0, RESULT
		EFF_IMGS:EFF_CNT '= RESULTS:LOCAL
		EFF_CNT++
	NEXT
ENDIF

; 追加传入特效
IF エフェクト != ""
	SPLIT エフェクト, ",", CUSTOM_EFFS, CUSTOM_EFF_NUM
	FOR LOCAL, 0, CUSTOM_EFF_NUM
		TEMP_EFF_NAME '= CUSTOM_EFFS:LOCAL
		; 尝试按照标准格式拼装资源名 (例：顔絵_裸照れ_1)
		RES_NAME '= @"%立绘种类%_%TEMP_EFF_NAME%_{NO:CID}%差分%"
		; 如果存在标准命名的特效，优先使用
		IF RM_RESOURCECHECK(RES_NAME)
			EFF_IMGS:EFF_CNT '= RES_NAME
			EFF_CNT++
		; 如果是裸体状态，自动尝试加上"裸"前缀寻找 (例：顔絵_裸汗_1)
		ELSEIF (服装 == "裸" || CHECK_NUDE(CID)) && RM_RESOURCECHECK(@"%立绘种类%_裸%TEMP_EFF_NAME%_{NO:CID}%差分%")
			EFF_IMGS:EFF_CNT '= @"%立绘种类%_裸%TEMP_EFF_NAME%_{NO:CID}%差分%"
			EFF_CNT++
		; 如果直接传入了完整的绝对资源名，直接采用
		ELSEIF RM_RESOURCECHECK(TEMP_EFF_NAME)
			EFF_IMGS:EFF_CNT '= TEMP_EFF_NAME
			EFF_CNT++
		ENDIF
	NEXT
ENDIF

;组装HTML
H_PX = GET_DEFAULT_IMAGE_HEIGHT(BASE_IMG)
HTML_STR '= @"<nonbutton title='TARGET:{CID}'>"
HTML_STR += ASSEMBLE_HTML_IMAGE_LAYERS(BASE_IMG, HOVER_IMG, EFF_IMGS, EFF_CNT, H_PX, 100)
HTML_STR += "</nonbutton>"

RESULTS '= HTML_STR

FLAG:立ち絵種類 = PREV_立ち絵種類
CFLAG:CID:差し替え適用 = PREV_立绘选择
RETURN H_PX

