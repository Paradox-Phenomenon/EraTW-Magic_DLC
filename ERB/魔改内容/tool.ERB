;-------------------------------------------------
;函数名:AddEXP_D
;概　要:附带信息的经验值增加
;与@AddEXP区别是参数是编号而非字符串
;-------------------------------------------------
@AddEXP_D(ARG,C_ID,变动数)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM C_ID
#DIM 变动数

SIF 变动数 == 0
	RETURN
IF EXPNAME:ARG == ""
	PRINTFORMW 没有找到编号：{ARG}的EXP，请保存日志报错
	RETURN
ENDIF
EXP:C_ID:ARG += 变动数
CALL COLORMESSAGE(@"%EXPNAME:ARG%＋{变动数}（%CALLNAME:C_ID%）",C_YELLOW,2,1)

