;==================================================
; @INIT_UFUFU_LOG
; 初始化战斗履历数据库
;==================================================
@INIT_UFUFU_LOG
#LOCALSIZE 1
#LOCALSSIZE 1
; 如果表不存在，则创建
IF DT_EXIST(DT_UFUFU_LOG) == 0
	DT_CREATE DT_UFUFU_LOG
	; 添加列
	DT_COLUMN_ADD DT_UFUFU_LOG, DT_ULOG_ID,    "int32"
	DT_COLUMN_ADD DT_UFUFU_LOG, DT_ULOG_DATE,    "int64"
	DT_COLUMN_ADD DT_UFUFU_LOG, DT_ULOG_PLACE,   "int16"
	DT_COLUMN_ADD DT_UFUFU_LOG, DT_ULOG_TYPE,    "int8"
	DT_COLUMN_ADD DT_UFUFU_LOG, DT_ULOG_ATTITUDE,"int8"
	DT_COLUMN_ADD DT_UFUFU_LOG, DT_ULOG_DIRT,  "int32"
	DT_COLUMN_ADD DT_UFUFU_LOG, DT_ULOG_TURN,    "int32"
ENDIF
IF DT_EXIST(DT_UFUFU_M_LOG) == 0
	DT_CREATE DT_UFUFU_M_LOG
	; 添加列
	DT_COLUMN_ADD DT_UFUFU_M_LOG, DT_ULOG_ID,    "int32"
	DT_COLUMN_ADD DT_UFUFU_M_LOG, DT_ULOG_MEMBER, "int16"
ENDIF
RETURN 0

;==================================================
; @RECORD_UFUFU_LOG
; 记录战斗履历的主函数 
;==================================================
@RECORD_UFUFU_LOG
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_UID
#DIMS DYNAMIC L_MEMBER_STR
#DIM DYNAMIC L_DATE_VAL
#DIM DYNAMIC L_ATTITUDE
#DIM DYNAMIC L_TURN
L_TURN = TIME_PROGRESS(UFUFU_START_TIME + UFUFU_START_DAY * 1440)
IF L_TURN <= 10
	RETURN
ENDIF

CALL INIT_UFUFU_LOG
L_UID = DT_ROW_LENGTH(DT_UFUFU_LOG) + 1

L_DATE_VAL = UFUFU_START_TIME + UFUFU_START_DAY * 1440

L_ATTITUDE = 2
FOR LOCAL, 1, GET_TARGETNUM() + 1
	IF (TARGET:LOCAL) != MASTER && CFLAG:(TARGET:LOCAL):诶嘿嘿
		DT_ROW_ADD DT_UFUFU_M_LOG,DT_ULOG_ID, L_UID, DT_ULOG_MEMBER, TARGET:LOCAL
		IF L_ATTITUDE == 2 && (TALENT:(TARGET:LOCAL):恋慕 || TALENT:(TARGET:LOCAL):恋人)
		ELSEIF L_ATTITUDE > 0 && TALENT:(TARGET:LOCAL):思慕
			L_ATTITUDE = 1
		ELSE 
			L_ATTITUDE = 0
		ENDIF
	ENDIF
NEXT
{
DT_ROW_ADD DT_UFUFU_LOG,
	DT_ULOG_ID, L_UID,
	DT_ULOG_DATE, L_DATE_VAL,
	DT_ULOG_PLACE, CFLAG:MASTER:现在位置,
	DT_ULOG_TYPE,UFUFU_START_TYPE,
	DT_ULOG_DIRT,YOGORE:(CFLAG:MASTER:现在位置),
	DT_ULOG_ATTITUDE,L_ATTITUDE,
	DT_ULOG_TURN, L_TURN,
}
;#;PRINTFORML 战斗履历No.{L_UID}已更新 
;%DT_ULOG_ID%, {L_UID},%DT_ULOG_DATE%, {L_DATE_VAL},%DT_ULOG_PLACE%, {CFLAG:MASTER:现在位置},%DT_ULOG_TYPE%,{UFUFU_START_TYPE},%DT_ULOG_DIRT%,{YOGORE:(CFLAG:MASTER:现在位置)},%DT_ULOG_ATTITUDE%,L_ATTITUDE,%DT_ULOG_TURN%, {L_TURN}

RETURN 1

;==================================================
; 辅助函数: 获取排序后的ID列表
; 因为原版DT_SELECT排序比较麻烦，这里封装一个简单的按列排序
; ARG:0 = 表名
; ARG:1 = 排序列名
; ARG:2 = 0:升序(ASC), 1:降序(DESC)
; REF:  = 接收结果的数组
;==================================================
@DT_SELECT_SORTED_ID(ARGS_TABLE, ARGS_COL, ARG_DESC, REF_ARR)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS ARGS_TABLE
#DIMS ARGS_COL
#DIM ARG_DESC
#DIM REF REF_ARR
#DIMS L_SORT_ORDER

IF ARG_DESC
	L_SORT_ORDER = %ARGS_COL% DESC
ELSE
	L_SORT_ORDER = %ARGS_COL% ASC
ENDIF

; 调用 DT_SELECT, 条件为空String代表全选
RETURN DT_SELECT(ARGS_TABLE, "", L_SORT_ORDER, REF_ARR)

@GET_UFUFU_NUMBER(UID,L_MEMBER)
#LOCALSIZE 2
#DIM DYNAMIC L_ROW_IDS, 100 ; 存储查询结果的行ID
#DIM DYNAMIC UID
#DIM REF L_MEMBER
#FUNCTION
LOCAL = DT_SELECT(DT_UFUFU_M_LOG, @"UID = {UID}", , L_ROW_IDS)
FOR LOCAL:1, 0, LOCAL
	L_MEMBER:(LOCAL:1) = DT_CELL_GET(DT_UFUFU_M_LOG, L_ROW_IDS:(LOCAL:1), DT_ULOG_MEMBER,1)
NEXT
RETURNF LOCAL

;==================================================
; @SHOW_UFUFU_HISTORY
; 显示履历的UI界面
;==================================================
@SHOW_UFUFU_HISTORY
#DIM DYNAMIC L_ROW_IDS, 100 ; 存储查询结果的行ID
#DIM DYNAMIC L_NUM_ROWS
#DIM DYNAMIC L_NUMBER
#DIM DYNAMIC L_ROW_IDX
#DIM DYNAMIC L_IDX,2
#DIM DYNAMIC L_MEMBER, 30
#DIM DYNAMIC L_UID

CALL INIT_UFUFU_LOG

PRINTL 
CALL PRINTLINE, "战斗履历 (最近50战)"

; 1. 查询所有记录，按日期降序排列 (最新的在最前)
CALL DT_SELECT_SORTED_ID(DT_UFUFU_LOG, DT_ULOG_DATE, 1, L_ROW_IDS)
L_NUM_ROWS = RESULT

IF L_NUM_ROWS == 0
	PRINTL 
	PRINTL     没有战斗记录
	PRINTL 
	WAIT
	RETURN
ENDIF

; 2. 循环显示
FOR L_IDX, 0, MIN(L_NUM_ROWS, 50)
	L_ROW_IDX = L_ROW_IDS:L_IDX
	
	PRINTFORM [{L_IDX, 2}] 
	
	; --- 日期解码 ---
	LOCAL:0 = DT_CELL_GET(DT_UFUFU_LOG, L_ROW_IDX, DT_ULOG_DATE,1)
	PRINTFORM %PRINT_DATE_F(LOCAL:0 / 1440)%（%GET_DAY_CN(LOCAL:0 / 1440)%） %TWENTY_FOUR_TIME(LOCAL:0 % 1440)%  
	
	; --- 地点 ---
	LOCAL:1 = DT_CELL_GET(DT_UFUFU_LOG, L_ROW_IDX, DT_ULOG_PLACE,1)
	PRINTFORM %@"地点：P{LOCAL:1}%GET_HOMEPLACENAME(LOCAL:1)%",32,LEFT%
	; --- 时长 ---
	LOCAL:5 = DT_CELL_GET(DT_UFUFU_LOG, L_ROW_IDX, DT_ULOG_TURN,1)
	PRINTFORM 时长：{LOCAL:5}分钟 
	; --- 结果与类型 ---
	LOCAL:2 = DT_CELL_GET(DT_UFUFU_LOG, L_ROW_IDX, DT_ULOG_TYPE,1)	
	IF LOCAL:2 == 3
		PRINTFORM (逆推) 
	ELSE
		PRINTFORM (推倒) 
	ENDIF

	; --- 伙伴---
	L_UID = DT_CELL_GET(DT_UFUFU_LOG, L_ROW_IDX, DT_ULOG_ID,1)
	L_NUMBER = GET_UFUFU_NUMBER(L_UID,L_MEMBER)
	IF L_NUMBER == 0
		PRINT 独自作战
	ELSE
		PRINT 同伴：
		FOR LOCAL:4, 0, L_NUMBER
			PRINTFORM [%CALLNAME:(L_MEMBER:(LOCAL:4))%] 
		NEXT
	ENDIF
	PRINTL
NEXT

DRAWLINE
WAIT

;永远获得据点名称
@GET_HOMEPLACENAME(PID)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM PID
#FUNCTIONS
LOCAL = MAIN_MAP
MAIN_MAP = PID/100
LOCALS '= GET_PLACENAME(PID)
MAIN_MAP = LOCAL
RETURNF LOCALS
