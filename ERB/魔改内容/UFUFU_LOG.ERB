;==================================================
; @INIT_UFUFU_LOG
; 初始化战斗履历数据库
;==================================================
@INIT_UFUFU_LOG
#LOCALSIZE 1
#LOCALSSIZE 1
; 如果表不存在，则创建
IF DT_EXIST(DT_UFUFU_LOG) == 0
	DT_CREATE DT_UFUFU_LOG
	; 添加列
	DT_COLUMN_ADD DT_UFUFU_LOG, DT_ULOG_ID,    "int32"
	DT_COLUMN_ADD DT_UFUFU_LOG, DT_ULOG_DATE,    "int64"
	DT_COLUMN_ADD DT_UFUFU_LOG, DT_ULOG_PLACE,   "int16"
	DT_COLUMN_ADD DT_UFUFU_LOG, DT_ULOG_TYPE,    "int8"
	DT_COLUMN_ADD DT_UFUFU_LOG, DT_ULOG_ATTITUDE,"int8"
	DT_COLUMN_ADD DT_UFUFU_LOG, DT_ULOG_DIRT,  "int32"
	DT_COLUMN_ADD DT_UFUFU_LOG, DT_ULOG_TURN,    "int32"
ENDIF
IF DT_EXIST(DT_UFUFU_M_LOG) == 0
	DT_CREATE DT_UFUFU_M_LOG
	; 添加列
	DT_COLUMN_ADD DT_UFUFU_M_LOG, DT_ULOG_ID,    "int32"
	DT_COLUMN_ADD DT_UFUFU_M_LOG, DT_ULOG_MEMBER, "int16"
ENDIF
RETURN 0

;==================================================
; @RECORD_UFUFU_LOG
; 记录战斗履历的主函数 
;==================================================
@RECORD_UFUFU_LOG
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_UID
#DIMS DYNAMIC L_MEMBER_STR
#DIM DYNAMIC L_DATE_VAL
#DIM DYNAMIC L_ATTITUDE
#DIM DYNAMIC L_TURN
#DIM DYNAMIC L_PLACE
SIF UFUFU_START_TIME == 0 || !TARGET ||CFLAG:TARGET:诶嘿嘿 == 0
	RETURN
L_TURN = TIME_PROGRESS(UFUFU_START_TIME + UFUFU_START_DAY * 1440) + EXTRA_UFUFU_TIME
IF L_TURN <= 10
	RETURN
ENDIF

CALL INIT_UFUFU_LOG
SIF !DT_UFUFU_LOGID
	DT_UFUFU_LOGID = DT_ROW_LENGTH(DT_UFUFU_LOG)
DT_UFUFU_LOGID += 1

L_DATE_VAL = UFUFU_START_TIME + UFUFU_START_DAY * 1440 - EXTRA_UFUFU_TIME

IF CFLAG:MASTER:现在位置 % 100 == 98
	L_PLACE = 98
ELSEIF CFLAG:MASTER:现在位置 % 100 == 99
	L_PLACE = 99
ELSE
	L_PLACE = CFLAG:MASTER:现在位置
ENDIF

GT_SET =
L_ATTITUDE = 2
FOR LOCAL, 1, GET_TARGETNUM() + 1
	IF (TARGET:LOCAL) != MASTER && CFLAG:(TARGET:LOCAL):诶嘿嘿 && SET_UPDATECHECK(TOSTR(TARGET:LOCAL), "GT_SET", , 1) == 0
		DT_ROW_ADD DT_UFUFU_M_LOG,DT_ULOG_ID, DT_UFUFU_LOGID, DT_ULOG_MEMBER, TARGET:LOCAL
		IF L_ATTITUDE == 2 && (TALENT:(TARGET:LOCAL):恋慕 || TALENT:(TARGET:LOCAL):恋人)
		ELSEIF L_ATTITUDE > 0 && TALENT:(TARGET:LOCAL):思慕
			L_ATTITUDE = 1
		ELSE 
			L_ATTITUDE = 0
		ENDIF
	ENDIF
NEXT
;DEBUGPRINTFORML 伙伴更新：%GT_SET%
;DEBUGPRINTFORML 处理WITHDRAWN_LIST：%WITHDRAWN_LIST%
SPLIT WITHDRAWN_LIST,"/",RESULTS
FOR LOCAL, 0, RESULT
	IF TOINT(RESULTS:LOCAL) != 0 && SET_UPDATECHECK(RESULTS:LOCAL, "GT_SET", , 1) == 0
		DT_ROW_ADD DT_UFUFU_M_LOG,DT_ULOG_ID, DT_UFUFU_LOGID, DT_ULOG_MEMBER, TOINT(RESULTS:LOCAL)
	ENDIF
NEXT
;DEBUGPRINTFORML 伙伴更新：%GT_SET%
{
DT_ROW_ADD DT_UFUFU_LOG,
	DT_ULOG_ID, DT_UFUFU_LOGID,
	DT_ULOG_DATE, L_DATE_VAL,
	DT_ULOG_PLACE, L_PLACE,
	DT_ULOG_TYPE,INRANGE(UFUFU_START_TYPE,2,4) ? UFUFU_START_TYPE # 2 ,
	DT_ULOG_DIRT,YOGORE:(CFLAG:MASTER:现在位置),
	DT_ULOG_ATTITUDE,L_ATTITUDE,
	DT_ULOG_TURN, L_TURN,
}
;#;PRINTFORML 战斗履历No.{DT_UFUFU_LOGID}已更新

;%DT_ULOG_ID%, {L_UID},%DT_ULOG_DATE%, {L_DATE_VAL},%DT_ULOG_PLACE%, {CFLAG:MASTER:现在位置},%DT_ULOG_TYPE%,{UFUFU_START_TYPE},%DT_ULOG_DIRT%,{YOGORE:(CFLAG:MASTER:现在位置)},%DT_ULOG_ATTITUDE%,L_ATTITUDE,%DT_ULOG_TURN%, {L_TURN}

RETURN 1

;==================================================
; 辅助函数: 获取排序后的ID列表
; 因为原版DT_SELECT排序比较麻烦，这里封装一个简单的按列排序
; ARG:0 = 表名
; ARG:1 = 排序列名
; ARG:2 = 0:升序(ASC), 1:降序(DESC)
; REF:  = 接收结果的数组
;==================================================
@DT_SELECT_SORTED_ID(ARGS_TABLE, ARGS_COL, ARG_DESC, REF_ARR)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC ARGS_TABLE
#DIMS DYNAMIC ARGS_COL
#DIM DYNAMIC ARG_DESC
#DIM REF REF_ARR
#DIMS DYNAMIC L_SORT_ORDER

IF ARG_DESC
	L_SORT_ORDER = %ARGS_COL% DESC
ELSE
	L_SORT_ORDER = %ARGS_COL% ASC
ENDIF

; 调用 DT_SELECT, 条件为空String代表全选
RETURN DT_SELECT(ARGS_TABLE, "", L_SORT_ORDER, REF_ARR)

@GET_UFUFU_NUMBER(UID,L_MEMBER)
#LOCALSIZE 2
#DIM DYNAMIC L_ROW_IDS, 100 ; 存储查询结果的行ID
#DIM DYNAMIC UID
#DIM REF L_MEMBER
#FUNCTION
LOCAL = DT_SELECT(DT_UFUFU_M_LOG, @"UID = {UID}", , L_ROW_IDS)
FOR LOCAL:1, 0, LOCAL
	L_MEMBER:(LOCAL:1) = DT_CELL_GET(DT_UFUFU_M_LOG, L_ROW_IDS:(LOCAL:1), DT_ULOG_MEMBER,1)
NEXT
RETURNF LOCAL

;==================================================
; @SHOW_UFUFU_HISTORY
; 显示履历的UI界面
;==================================================
@SHOW_UFUFU_HISTORY
#DIM DYNAMIC L_PAGE_CURRENT
#DIM DYNAMIC L_PAGE_MAX
#DIM DYNAMIC L_PER_PAGE = 40
#DIM DYNAMIC L_LOG_COUNT
#DIM DYNAMIC L_INPUT
#DIMS DYNAMIC L_SORT_STR

; 初始化
L_PAGE_CURRENT = 0
CALL INIT_UFUFU_LOG

LOCAL = LINECOUNT
WHILE 1
	CLEARLINE LINECOUNT - LOCAL

	; 根据当前的筛选条件，获取符合条件的 Log ID 列表
	CALL CREATE_UFUFU_LOG_VIEW_LIST(TEMP_LOG_ROWS, L_LOG_COUNT)

	; 计算最大页数
	L_PAGE_MAX = MAX(0, (L_LOG_COUNT - 1) / L_PER_PAGE)
	; 修正当前页码防止越界
	L_PAGE_CURRENT = LIMIT(L_PAGE_CURRENT, 0, L_PAGE_MAX)

	DRAWLINE
	PRINTFORM 战斗履历一览    
	PRINTFORM 符合条件: {L_LOG_COUNT} 条    
	PRINTFORML 页码: {L_PAGE_CURRENT + 1} / {L_PAGE_MAX + 1}
	DRAWLINE
	
	CALL PRINT_UFUFU_LOG_HEADER

	IF L_LOG_COUNT == 0
		PRINTL 
		PRINTFORML     没有符合条件的记录
		PRINTL 
	ELSE
		CALL PRINT_UFUFU_LOG_LIST(TEMP_LOG_ROWS, L_LOG_COUNT, L_PAGE_CURRENT, L_PER_PAGE)
	ENDIF

	CALL CALC_AND_PRINT_UFUFU_STATS(TEMP_LOG_ROWS, L_LOG_COUNT)
	DRAWLINE

	; 翻页按钮
	PRINTFORM %" " * 30%
	IF L_PAGE_CURRENT > 0
		PRINTBUTTON "[1001] < 上一页", -1001
	ELSE
		SETCOLOR 0x808080
		PRINTPLAIN [1001] < 上一页
		RESETCOLOR
	ENDIF
	PRINTFORM %" " * 5%
	IF L_PAGE_CURRENT < L_PAGE_MAX
		PRINTBUTTON "[1009] 下一页 >", -1009
	ELSE
		SETCOLOR 0x808080
		PRINTPLAIN [1009] 下一页 >
		RESETCOLOR
	ENDIF
	PRINTL 

	; 功能按钮
	PRINTL 
	PRINTFORM [-2000] 筛选:角色 
	IF UFUFU_LOG_FILTER_CHARA >= 0
		SETCOLOR 0x00FF00
		PRINTFORM (%CALLNAME:UFUFU_LOG_FILTER_CHARA%)
		RESETCOLOR
	ELSE
		PRINTFORM (全部)
	ENDIF
	PRINT   

	PRINTFORM [-2001] 筛选:地点 
	IF UFUFU_LOG_FILTER_PLACE >= 0
		SETCOLOR 0x00FF00
		PRINTFORM (%GET_UFUFU_PLACENAME(UFUFU_LOG_FILTER_PLACE)%)
		RESETCOLOR
	ELSE
		PRINTFORM (全部)
	ENDIF
	PRINT   

	PRINTFORM [-2002] 筛选:结果 
	SETCOLOR 0x00FF00
	SELECTCASE UFUFU_LOG_FILTER_TYPE
		CASE 3
			PRINTFORM (逆推)
		CASE 2
			PRINTFORM (推倒)
		CASE 4
			PRINTFORM (时奸)
		CASEELSE
		PRINTFORMD (全部)
	ENDSELECT
	RESETCOLOR
	PRINTL 

	PRINTL [-3000] 重置所有筛选
	PRINTL [0] 返回

	; --- 输入处理 ---
	INPUT
	L_INPUT = RESULT

	SELECTCASE L_INPUT
		CASE 0
			RETURN
		CASE -1001
			L_PAGE_CURRENT--
		CASE -1009
			L_PAGE_CURRENT++
		
		; --- 排序切换 ---
		CASE -1100 ; 日期排序
			IF UFUFU_LOG_SORT_KEY == 0
				UFUFU_LOG_SORT_ORDER = !UFUFU_LOG_SORT_ORDER
			ELSE
				UFUFU_LOG_SORT_KEY = 0
				UFUFU_LOG_SORT_ORDER = 1 ; 默认降序
			ENDIF
		CASE -1101 ; 地点排序
			IF UFUFU_LOG_SORT_KEY == 2
				UFUFU_LOG_SORT_ORDER = !UFUFU_LOG_SORT_ORDER
			ELSE
				UFUFU_LOG_SORT_KEY = 2
				UFUFU_LOG_SORT_ORDER = 0
			ENDIF
		CASE -1102 ; 时长排序
			IF UFUFU_LOG_SORT_KEY == 1
				UFUFU_LOG_SORT_ORDER = !UFUFU_LOG_SORT_ORDER
			ELSE
				UFUFU_LOG_SORT_KEY = 1
				UFUFU_LOG_SORT_ORDER = 1
			ENDIF

		; --- 筛选设置 ---
		CASE -2000 ; 筛选角色
			IF UFUFU_LOG_FILTER_CHARA >= 0
				UFUFU_LOG_FILTER_CHARA = -1
			ELSE
				PRINTL 请选择要筛选的角色：
				CALL SHOW_CHARA_LIST("现有的角色列表")
				IF RESULT == 999
					UFUFU_LOG_FILTER_CHARA = -1
				ELSEIF INRANGE(RESULT,1,CHARANUM-1)
					UFUFU_LOG_FILTER_CHARA = RESULT
				ENDIF
			ENDIF
			L_PAGE_CURRENT = 0

		CASE -2001 ; 筛选地点
			IF UFUFU_LOG_FILTER_PLACE >= 0
				UFUFU_LOG_FILTER_PLACE = -1
			ELSE
				PRINTL 请输入地点ID:
				CALL SHOW_POSITION_LIST
			IF GET_UFUFU_PLACENAME(RESULT) != ""
					UFUFU_LOG_FILTER_PLACE = RESULT
			ELSE
				UFUFU_LOG_FILTER_PLACE = -1
				ENDIF
			ENDIF
			L_PAGE_CURRENT = 0

		CASE -2002 ; 筛选结果
			IF UFUFU_LOG_FILTER_TYPE == -1
				UFUFU_LOG_FILTER_TYPE = 3 ; 逆推
			ELSEIF UFUFU_LOG_FILTER_TYPE == 3
				UFUFU_LOG_FILTER_TYPE = 2
			ELSE
				UFUFU_LOG_FILTER_TYPE = -1
			ENDIF
			L_PAGE_CURRENT = 0

		CASE -3000
			UFUFU_LOG_FILTER_CHARA = -1
			UFUFU_LOG_FILTER_PLACE = -1
			UFUFU_LOG_FILTER_TYPE = -1
			L_PAGE_CURRENT = 0
		CASEELSE
			IF DT_SELECT(DT_UFUFU_LOG, @"%DT_ULOG_ID% = {L_INPUT}") > 0
				CALL DELETE_UFUFU_LOG(L_INPUT)
			ENDIF
	ENDSELECT

WEND

;==================================================
; @CREATE_UFUFU_LOG_VIEW_LIST
;==================================================
@CREATE_UFUFU_LOG_VIEW_LIST(REF_ARR, REF_COUNT)
#DIM REF REF_ARR
#DIM REF REF_COUNT
#DIMS DYNAMIC L_FILTER_STR
#DIMS DYNAMIC L_SORT_STR
#DIM DYNAMIC L_M_COUNT
#DIM DYNAMIC L_IDX

REF_COUNT = 0
VARSET REF_ARR, 0
L_FILTER_STR = 

;角色筛选逻辑 (比较特殊，因为在从表)
IF UFUFU_LOG_FILTER_CHARA >= 0
	L_M_COUNT = DT_SELECT(DT_UFUFU_M_LOG, @"%DT_ULOG_MEMBER% = {UFUFU_LOG_FILTER_CHARA}", , TEMP_MLOG_ROWS)
	IF L_M_COUNT == 0
		RETURN 0
	ENDIF
ENDIF

; 地点
IF UFUFU_LOG_FILTER_PLACE >= 0
	L_FILTER_STR += @"%DT_ULOG_PLACE% = {UFUFU_LOG_FILTER_PLACE}"
ENDIF

; 类型
IF UFUFU_LOG_FILTER_TYPE >= 0
	IF L_FILTER_STR != ""
		L_FILTER_STR += " AND "
	ENDIF
	L_FILTER_STR += @"%DT_ULOG_TYPE% = {UFUFU_LOG_FILTER_TYPE}"
ENDIF

SELECTCASE UFUFU_LOG_SORT_KEY
	CASE 0 ; 日期
		L_SORT_STR = %DT_ULOG_DATE%
	CASE 1 ; 时长
		L_SORT_STR = %DT_ULOG_TURN%
	CASE 2 ; 地点
		L_SORT_STR = %DT_ULOG_PLACE%
ENDSELECT

IF UFUFU_LOG_SORT_ORDER == 1
	L_SORT_STR += " DESC"
ELSE
	L_SORT_STR += " ASC"
ENDIF

;执行
; 先获取主表符合条件的所有 ID
REF_COUNT = DT_SELECT(DT_UFUFU_LOG, L_FILTER_STR, L_SORT_STR, REF_ARR)

IF UFUFU_LOG_FILTER_CHARA >= 0 && REF_COUNT > 0
	VARSET TEMP_MLOG_ROWS
	L_M_COUNT = 0
	
	FOR L_IDX, 0, REF_COUNT
		; 检查这个 Log ID (REF_ARR:L_IDX) 是否在 M_LOG 中包含指定角色
		; UID 是列名，需要取出来
		LOCAL:0 = DT_CELL_GET(DT_UFUFU_LOG, REF_ARR:L_IDX, DT_ULOG_ID, 1) ; 获取实际UID值
		
		; 查从表
		IF DT_SELECT(DT_UFUFU_M_LOG, @"UID = {LOCAL:0} AND %DT_ULOG_MEMBER% = {UFUFU_LOG_FILTER_CHARA}") > 0
			TEMP_MLOG_ROWS:L_M_COUNT = REF_ARR:L_IDX
			L_M_COUNT++
		ENDIF
	NEXT
	
	; 覆盖结果
	VARSET REF_ARR
	FOR L_IDX, 0, L_M_COUNT
		REF_ARR:L_IDX = TEMP_MLOG_ROWS:L_IDX
	NEXT
	REF_COUNT = L_M_COUNT
ENDIF

RETURN 1

;==================================================
; @PRINT_UFUFU_LOG_HEADER
; 显示表头和排序按钮
;==================================================
@PRINT_UFUFU_LOG_HEADER
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC L_MARK
PRINT     
; 日期
IF UFUFU_LOG_SORT_KEY == 0
	L_MARK = \@ UFUFU_LOG_SORT_ORDER ? ▼ # ▲ \@
	SETCOLOR 0xFFFF00
ELSE
	L_MARK = ▽
	RESETCOLOR
ENDIF
PRINTBUTTON @"%@"[日期%L_MARK%]", 36, LEFT%", -1100

; 地点
IF UFUFU_LOG_SORT_KEY == 2
	L_MARK = \@ UFUFU_LOG_SORT_ORDER ? ▼ # ▲ \@
	SETCOLOR 0xFFFF00
ELSE
	L_MARK = ▽
	RESETCOLOR
ENDIF
PRINTBUTTON @"%@"[地点%L_MARK%]", 32, LEFT%", -1101

; 时长
IF UFUFU_LOG_SORT_KEY == 1
	L_MARK = \@ UFUFU_LOG_SORT_ORDER ? ▼ # ▲ \@
	SETCOLOR 0xFFFF00
ELSE
	L_MARK = ▽
	RESETCOLOR
ENDIF
PRINTBUTTON @"[时长%L_MARK%]", -1102

RESETCOLOR
PRINTL   结果 参与者
DRAWLINE
RETURN

;==================================================
; @CALC_AND_PRINT_UFUFU_STATS
; 计算并显示统计行
; 参数:
;   ARR_IDS: 符合当前筛选条件的行ID数组
;   ARR_COUNT: 数组中的数量
;==================================================
@CALC_AND_PRINT_UFUFU_STATS(ARR_IDS, ARR_COUNT)
#DIM REF ARR_IDS
#DIM ARR_COUNT
#DIM DYNAMIC L_IDX
#DIM DYNAMIC L_ROW_INDEX
#DIM DYNAMIC L_TOTAL_TURN
#DIM DYNAMIC L_PLACE_ID
#DIM DYNAMIC L_UNIQUE_PLACE_COUNT
#DIMS DYNAMIC L_PLACE_LIST ; 用于记录去重地点的字符串 "/1/2/10/"
#DIM DYNAMIC L_UNIQUE_CHARA_COUNT
#DIMS DYNAMIC L_CHARA_LIST ; 用于记录去重角色的字符串
#DIM DYNAMIC L_UID
#DIM DYNAMIC L_M_COUNT
#DIM DYNAMIC L_MEMBERS, 20
#DIM DYNAMIC L_CNT

; 初始化
L_TOTAL_TURN = 0
L_UNIQUE_PLACE_COUNT = 0
L_UNIQUE_CHARA_COUNT = 0
L_PLACE_LIST = /
L_CHARA_LIST = /

FOR L_IDX, 0, ARR_COUNT
	L_ROW_INDEX = ARR_IDS:L_IDX
	
	L_TOTAL_TURN += DT_CELL_GET(DT_UFUFU_LOG, L_ROW_INDEX, DT_ULOG_TURN, 1)
	
	L_PLACE_ID = DT_CELL_GET(DT_UFUFU_LOG, L_ROW_INDEX, DT_ULOG_PLACE, 1)
	IF STRCOUNT(L_PLACE_LIST, @"/%TOSTR(L_PLACE_ID)%/") == 0
		L_UNIQUE_PLACE_COUNT++
		L_PLACE_LIST += @"%TOSTR(L_PLACE_ID)%/"
	ENDIF

	L_UID = DT_CELL_GET(DT_UFUFU_LOG, L_ROW_INDEX, DT_ULOG_ID, 1)
	; 获取参与该场战斗的角色
	L_M_COUNT = GET_UFUFU_NUMBER(L_UID, L_MEMBERS)
	FOR L_CNT, 0, L_M_COUNT
		IF STRCOUNT(L_CHARA_LIST, @"/%TOSTR(L_MEMBERS:L_CNT)%/") == 0
			L_UNIQUE_CHARA_COUNT++
			L_CHARA_LIST += @"%TOSTR(L_MEMBERS:L_CNT)%/"
		ENDIF
	NEXT
NEXT

; 统计表头
DRAWLINE
SETCOLOR 0xFF00FF
PRINTFORM %@"统计[计数]", 40, LEFT%
PRINTFORM %@"[地点数]", 32, LEFT%
PRINTFORM %@"[总时长]", 15, LEFT%
PRINTFORM %@"[对战人次]"%
RESETCOLOR
PRINTL 

SETCOLOR 0x00FF00
PRINTFORM %@"      {ARR_COUNT} 条", 40, LEFT%
PRINTFORM %@"{L_UNIQUE_PLACE_COUNT} 处", 32, LEFT%
PRINTFORM %@"{L_TOTAL_TURN}分", 14, LEFT%
PRINTFORM  {L_UNIQUE_CHARA_COUNT} 人次
RESETCOLOR
PRINTL 
RETURN

;==================================================
; @PRINT_UFUFU_LOG_LIST
; 绘制具体的列表内容
;==================================================
@PRINT_UFUFU_LOG_LIST(ARR_IDS, ARR_COUNT, ARG_PAGE, ARG_PER_PAGE)
#DIM REF ARR_IDS
#DIM DYNAMIC ARR_COUNT
#DIM DYNAMIC ARG_PAGE
#DIM DYNAMIC ARG_PER_PAGE
#DIM DYNAMIC L_START
#DIM DYNAMIC L_END
#DIM DYNAMIC L_IDX
#DIM DYNAMIC L_ROW_INDEX
#DIM DYNAMIC L_UID
#DIM DYNAMIC L_DATE
#DIM DYNAMIC L_PLACE
#DIM DYNAMIC L_TURN
#DIM DYNAMIC L_TYPE
#DIM DYNAMIC L_MEMBERS, 20
#DIM DYNAMIC L_M_COUNT
#DIM DYNAMIC L_CNT

L_START = ARG_PAGE * ARG_PER_PAGE
L_END = MIN(L_START + ARG_PER_PAGE, ARR_COUNT)

FOR L_IDX, L_START, L_END
	L_ROW_INDEX = ARR_IDS:L_IDX
	
	; 读取数据
	L_UID = DT_CELL_GET(DT_UFUFU_LOG, L_ROW_INDEX, DT_ULOG_ID, 1)
	L_DATE = DT_CELL_GET(DT_UFUFU_LOG, L_ROW_INDEX, DT_ULOG_DATE, 1)
	L_PLACE = DT_CELL_GET(DT_UFUFU_LOG, L_ROW_INDEX, DT_ULOG_PLACE, 1)
	L_TURN = DT_CELL_GET(DT_UFUFU_LOG, L_ROW_INDEX, DT_ULOG_TURN, 1)
	L_TYPE = DT_CELL_GET(DT_UFUFU_LOG, L_ROW_INDEX, DT_ULOG_TYPE, 1)
	
	; 打印
	LOCALS = [%TOSTR(L_UID,"D3")%]
	
	; 日期
	LOCALS += @" %PRINT_DATE_F(L_DATE / 1440)%（%GET_DAY_CN(L_DATE / 1440)%）%TWENTY_FOUR_TIME(L_DATE % 1440)%"
	PRINTFORM %LOCALS, 40, LEFT%

	; 地点
	LOCALS = P{L_PLACE}%GET_UFUFU_PLACENAME(L_PLACE)%
	PRINTFORM %LOCALS, 32, LEFT%
	
	; 时长
	PRINTFORM {L_TURN, 4}分    

	; 结果
	IF L_TYPE == 3
		SETCOLOR 0xFF8080 ; 红色系
		PRINTFORM 逆推
	ELSEIF L_TYPE == 4
		SETCOLOR C_N_BLUE
		PRINTFORM 时奸
	ELSE
		SETCOLOR C_PINK
		PRINTFORM 推倒
	ENDIF
	RESETCOLOR
	PRINT  

	; 参与者
	L_M_COUNT = GET_UFUFU_NUMBER(L_UID, L_MEMBERS)
	IF L_M_COUNT == 0
		PRINTFORM %" " * 20%
		SETCOLOR 0x808080
		PRINT (独处)
		RESETCOLOR
	ELSE
		FOR L_CNT, 0, L_M_COUNT
			PRINTFORM [%CALLNAME:(L_MEMBERS:L_CNT)%]
		NEXT
	ENDIF

	PRINTL
NEXT
RETURN

;==================================================
; @DELETE_UFUFU_LOG
; 删除指定UID的战斗记录
;==================================================
@DELETE_UFUFU_LOG(L_UID)
#DIM DYNAMIC L_UID
#DIM DYNAMIC L_COUNT
#DIM DYNAMIC L_IDX

SIF !DT_UFUFU_LOGID
	DT_UFUFU_LOGID = DT_ROW_LENGTH(DT_UFUFU_LOG)

PRINTL
PRINTFORML 确定要删除编号 [{L_UID}] 的战斗记录吗？
PRINTL 此操作无法撤销。
PRINTL [0] 否
PRINTL [1] 是
INPUT
IF RESULT != 1
	RETURN 0
ENDIF

VARSET TEMP_MLOG_ROWS
L_COUNT = DT_SELECT(DT_UFUFU_LOG, @"%DT_ULOG_ID% = {L_UID}", , TEMP_MLOG_ROWS)
IF L_COUNT > 0
	DT_ROW_REMOVE DT_UFUFU_LOG, TEMP_MLOG_ROWS:0
ENDIF

VARSET TEMP_MLOG_ROWS
L_COUNT = DT_SELECT(DT_UFUFU_M_LOG, @"%DT_ULOG_ID% = {L_UID}", , TEMP_MLOG_ROWS)
IF L_COUNT > 0
	FOR L_IDX, 0, L_COUNT
		DT_ROW_REMOVE DT_UFUFU_M_LOG, TEMP_MLOG_ROWS:L_IDX
	NEXT
ENDIF

PRINTFORMW 记录No. [{L_UID}] 已删除。
RETURN 1

@SHOW_POSITION_LIST
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC L_MAP
#DIM DYNAMIC L_P
#DIM DYNAMIC LCOUNT

gLineCount = LINECOUNT
WHILE 1
	SIF LINECOUNT - gLineCount > 0
		CLEARLINE LINECOUNT - gLineCount

	FOR L_MAP, 0, MAXHOME
		SIF !GET_EXISTMAP(L_MAP)
			CONTINUE
		PRINTFORML [{L_MAP,2}] %GET_MAPNAME(L_MAP)%
	NEXT
	DRAWLINE
	PRINTL [-1] 返回
	DO
		INPUT
		IF RESULT == -1 
			RETURN -1
		ELSEIF GET_EXISTMAP(RESULT)
			L_MAP = RESULT
			BREAK
		ELSE
			CLEARLINE 1
		ENDIF
	LOOP 1

	FOR LOCAL, 1, 100
		L_P = L_MAP * 100 + LOCAL
		LOCALS '= STR_TR(8000 + L_P)
		SIF LOCALS == ""
			CONTINUE
		LCOUNT += 1
		PRINTFORM %@"[{L_P, 3}] %LOCALS%",40,LEFT%
		IF LCOUNT % 3 == 0
			PRINTL
		ENDIF
	NEXT
	IF LCOUNT % 3
		PRINTL
	ENDIF
	PRINTFORM %@"[{L_MAP * 100 + 97,3}] 去%GET_MAPNAME(L_MAP)%的途中",40,LEFT%
	PRINTFORM %@"[ 98] 招待室",40,LEFT%
	PRINTFORM %@"[ 99] 间隙空间",40,LEFT%
	PRINTL
	DRAWLINE
	PRINTL [-2] 返回上一级
	PRINTL [-1] 返回
	DO
		INPUT
		IF RESULT == -1 || STR_TR(8000 + RESULT) != "" || GROUPMATCH(RESULT,L_MAP * 100 + 97,98,99)
			RETURN RESULT
		ELSEIF RESULT == -2
			BREAK
		ELSE
			CLEARLINE 1
		ENDIF
	LOOP 1
WEND

@GET_UFUFU_PLACENAME(PID)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
#DIM PID
IF PID % 100 == 98
	LOCALS = 招待室
ELSEIF PID % 100 == 97
	LOCALS = 去%GET_MAPNAME(PID / 100)%的途中
ELSEIF  PID % 100 == 99
	LOCALS = 间隙空间
ELSE
	LOCALS = %STR_TR(8000 + PID)%
ENDIF
RETURNF LOCALS
