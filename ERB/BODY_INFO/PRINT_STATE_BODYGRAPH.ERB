@GET_HTML_COLORMESSAGE(MESSAGE, COLOR, NEWLINE)
	#LOCALSIZE 1
	#LOCALSSIZE 1
	#FUNCTIONS
	#DIMS MESSAGE
	#DIMS COLOR
	#DIM NEWLINE
	#DIMS HTMLText
	VARSET HTMLText
	HTMLText '= @"<FONT COLOR='%SUBSTRING(COLOR,2)%'>%MESSAGE%</FONT>"
	SIF NEWLINE
		HTMLText += @"<br>"
	RETURNF HTMLText

@GET_STRING_STATE_GENERAL(選択中キャラID, functionName)
	#LOCALSIZE 1
	#LOCALSSIZE 1
	#DIM 選択中キャラID
	#DIMS HOGES, 20
	#DIMS functionName
	#DIM lineRecord, 2

	VARSET HOGES
	VARSET LOCALS
	lineRecord:0 = LINECOUNT
	
	TRYCCALLFORM %functionName%, 選択中キャラID
	CATCH
		RETURN -1
	ENDCATCH

	lineRecord:1 = LINECOUNT
	FOR LOCAL,0,(lineRecord:1-lineRecord:0)
		HOGES:(lineRecord:1-lineRecord:0 -LOCAL) = %HTML_GETPRINTEDSTR(LOCAL)%
	NEXT
	CLEARLINE LINECOUNT - lineRecord:0
	FOR LOCAL, 0, lineRecord:1-lineRecord:0+1
		; 移除左右空白
		HOGES:LOCAL '= TRIM_STRING(HOGES:LOCAL)
		; 移除 用不到的 tag
		HOGES:LOCAL '= BAN_TAG_STRING(HOGES:LOCAL)
		SIF STRLENS(HOGES:LOCAL) < 1
			CONTINUE
		;不要 □ 開頭的，這是排版行
		SIF CHARATU(HOGES:LOCAL,0) == "□"
			CONTINUE
		LOCALS += HOGES:LOCAL + "<br>"
	NEXT
	RESULTS '= LOCALS


@GET_STRING_STATE_FORMAT(strings)
	#LOCALSIZE 1
	#FUNCTIONS
	#DIMS strings
	#DIMS HTMLText
	#DIM cnt
	VARSET HTMLText
	VARSET LOCALS
	SPLIT strings, "、", LOCALS
	RETURNF STRJOIN(LOCALS, "<br>")

