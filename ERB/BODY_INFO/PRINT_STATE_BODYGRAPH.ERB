@CHECK_BODYGRAPH_RECORD(TYPE="get", idxPart=-1, value=-1)
	#LOCALSIZE 1
	#LOCALSSIZE 1
	#DIMS TYPE
	#DIM idxPart
	#DIM value
	#DIM record, 10
	; 0: photo, 1:A, 2:B, 3:C, 4:V, 5:M
	SIF idxPart == -1
		RETURN 0

	SELECTCASE TYPE
		CASE "get"
			RETURN record:idxPart
		CASE "set"
			IF value != -1
				record:idxPart = value
				RETURN 1
			ENDIF
			IF idxPart == 4
				record:idxPart += 1
				record:idxPart = record:idxPart % 3
			ELSE
				IF record:idxPart == 0
					record:idxPart = 1
				ELSE
					record:idxPart = 0
				ENDIF
			ENDIF
		CASEELSE
			RETURN 0
	ENDSELECT

@TRIM_STRING(string)
	#LOCALSIZE 1
	#LOCALSSIZE 1
	#FUNCTIONS
	#DIMS string
	VARSET LOCALS
	LOCALS '= REPLACE(string, "^\s+", "")
	LOCALS '= REPLACE(LOCALS, "\s+$", "")
	RETURNF LOCALS

@BAN_TAG_STRING(string)
	#LOCALSIZE 1
	#LOCALSSIZE 1
	#FUNCTIONS
	#DIMS string
	VARSET LOCALS
	LOCALS '= REPLACE(string, "^<p[^>]*>", "")
	LOCALS '= REPLACE(LOCALS, "<\/p>$", "")
	LOCALS '= REPLACE(LOCALS, "^<nobr>", "")
	LOCALS '= REPLACE(LOCALS, "<\/nobr>$", "")
	RETURNF LOCALS