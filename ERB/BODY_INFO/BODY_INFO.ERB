			RESETCOLOR
		CASE IS == 3
			SETCOLOR C_YELLOW
			PRINTFORML 【达人】舌头的使用技巧已经变得十分上道了
			RESETCOLOR
		CASE IS == 2
			SETCOLOR C_GREEN
