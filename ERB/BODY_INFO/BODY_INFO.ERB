			RESETCOLOR
		CASE IS == 1
			SETCOLOR C_AQUA
			PRINTFORML 【生疏】接下来的路还长着呢
			RESETCOLOR
		CASE IS == 0
			PRINTFORML 【笨拙】还是笨拙的舌头呢
	ENDSELECT

	IF 選択中キャラID == MASTER
		IF ABL:選択中キャラID:舌 >= 6
			SETCOLOR C_RED
			PRINTFORML 下次就用～尝试过 终身难忘来给自己做宣传吧
			RESETCOLOR
		ELSEIF ABL:選択中キャラID:舌 == 5
			SETCOLOR C_PINK
			PRINTFORML 只要想，就可以用卓越的舌技来俘获少女
			RESETCOLOR
		ELSEIF ABL:選択中キャラID:舌 == 4
			SETCOLOR C_ORANGE
			PRINTFORML 舌技大师击败了一个又一个发起挑战的少女
			RESETCOLOR
		ELSEIF ABL:選択中キャラID:舌 == 3
			SETCOLOR C_YELLOW
			PRINTFORML 能巧妙地使用舌头取悦少女
			RESETCOLOR
		ELSEIF ABL:選択中キャラID:舌 == 2
			SETCOLOR C_GREEN
			PRINTFORML 努力的话用舌头好像也可以满足少女了
