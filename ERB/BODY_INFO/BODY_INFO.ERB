						PRINTFORML 危险日的输卵管里娇嫩的卵子正在等待着受精
					CASE 6
						SETCOLOR C_PINK
						PRINTFORML 排卵日 卵子即将排出 预计明日为危险日
					CASE 5
						SETCOLOR C_ORANGE
						PRINTFORML 新的卵子即将成熟 预计明日排卵日 预计危险日还有二天到来
					CASE 4
						SETCOLOR C_YELLOW
						PRINTFORML 新的卵子成长顺利 危险日预计还有三天到来
					CASE 3
						SETCOLOR C_GREEN
						PRINTFORML 新的卵子正在逐渐成长中 危险日预计还有四天到来
					CASE 2
						SETCOLOR C_AQUA
						PRINTFORML 新的卵子准备中 危险日预计还有五天到来
					CASE 1
						PRINTFORML 月经即将结束 准备产生新的卵子
					CASE 0
						PRINTFORML 新的生理周期开启 月经来潮中
				ENDSELECT
			ENDIF
			RESETCOLOR
		ENDIF
		IF 選択中キャラID == MASTER && EX:選択中キャラID:子宮内精液
			PRINTFORML %CALLNAME:MASTER%子宫内的精液详情
			FOR LOCAL,1,CHARANUM
				SIF !CFLAG:選択中キャラID:(LOCAL + 2000)
					CONTINUE
				SIF CFLAG:選択中キャラID:(LOCAL + 2000) > 100
					SETCOLOR C_YELLOW
				PRINTFORMLC %CALLNAME:LOCAL%{CFLAG:選択中キャラID:(LOCAL + 2000)}
				RESETCOLOR
			NEXT
			PRINTFORML 
		ENDIF
		LOCAL = MAX(1,CFLAG:選択中キャラID:WithChildCount)
		IF TALENT:選択中キャラID:妊娠
			SETCOLOR C_RED
			IF CFLAG:選択中キャラID:妊娠経過日数 < 20
				PRINTFORML 生理期停了
			ELSEIF 選択中キャラID == MASTER
				IF GROUPMATCH(TALENT:選択中キャラID:PREGNANCY_TYPE,2,3)
					PRINTFORML 在子宫内，接受了%CALLNAME:DADDY%精子的受精卵正在茁壮成长
				ELSE
					PRINTFORML 子宫内正孕育着%CALLNAME:DADDY%的孩子
				ENDIF
					;Custom code, date range for hyperpregnancy.
				IF CFLAG:選択中キャラID:妊娠経過日数 == PregnancyProgress:選択中キャラID:(LOCAL-1)
					PRINTFORML 现在妊娠{CFLAG:選択中キャラID:妊娠経過日数}日
				ELSE
					PRINTFORML 现在妊娠{PregnancyProgress:選択中キャラID:(LOCAL-1)}{CFLAG:選択中キャラID:妊娠経過日数}日
				ENDIF
				CALL LOOK_BELLY(選択中キャラID)
				SIF INRANGE(CFLAG:選択中キャラID:妊娠経過日数,20,29)
						PRINT 还没有肉眼可见的变化
				PRINTL
			ELSE
				PRINTFORML 子宫内正孕育着%CALLNAME:MASTER%的孩子
				PRINTFORML 现在妊娠{CFLAG:選択中キャラID:妊娠経過日数}日
				CALL LOOK_BELLY(選択中キャラID)
				SIF INRANGE(CFLAG:選択中キャラID:妊娠経過日数,20,29)
						PRINT 还没有肉眼可见的变化
				PRINTL
			ENDIF
		ELSEIF TALENT:選択中キャラID:NESTING
			PRINTFORML 正在培育受精卵
			IF TALENT:選択中キャラID:NESTING == PregnancyProgress:選択中キャラID:(LOCAL-1)
				PRINTFORML 现在是产卵后的第{TALENT:選択中キャラID:NESTING}天
			ELSE
				PRINTFORML 现在是产卵后的第{PregnancyProgress:選択中キャラID:(LOCAL-1)}天到第{TALENT:選択中キャラID:NESTING}天
			ENDIF
		ENDIF
		IF 充填率(選択中キャラID,3) >= 15 && !TALENT:選択中キャラID:妊娠
			CALL LOOK_BELLY(選択中キャラID)
			PRINTL
		ENDIF
		SETCOLOR C_CREAM
		IF EX:選択中キャラID:子宮内精液 > 0
			PRINTFORML ❤精液量: {(EX:選択中キャラID:子宮内精液),5,LEFT}填充率: ({充填率(選択中キャラID, 4)}％)❤
		ENDIF
		RESETCOLOR
		IF 選択中キャラID == MASTER
			LOCAL = SUMCARRAY(CFLAG:LOCAL:累计射精,1, CHARANUM)
			IF LOCAL
				PRINTFORML ----------%CALLNAME:0%❤累计榨精-----{LOCAL}mL----------
			LOCAL:1 = MAXCARRAY(CFLAG:LOCAL:累计射精,	   1, CHARANUM)
			LOCAL:2 = FINDCHARA(CFLAG:LOCAL:累计射精,LOCAL:1, 1, CHARANUM)
				SETCOLOR C_V_PINK
				PRINTFORML %CALLNAME:(LOCAL:2),11,RIGHT%: 被榨精{LOCAL:1}mL, 被榨干{EXP:(LOCAL:2):被榨経験,3}次.
				RESETCOLOR
			ENDIF
			LOCAL:3 = 0
			FOR LOCAL,1,CHARANUM - 1
				SIF !CFLAG:LOCAL:累计射精
					CONTINUE
				SIF CFLAG:LOCAL:累计射精 > 10000
					SETCOLOR C_YELLOW
				PRINTFORM %CALLNAME:LOCAL,11,RIGHT%❤{CFLAG:LOCAL:累计射精,7,RIGHT}
				RESETCOLOR
				LOCAL:3 ++
				SIF LOCAL:3 % 5 == 0
					PRINTL 
			NEXT
		ENDIF
		PRINTL 
	ENDIF

@肉体情報_C(選択中キャラID)
