			RESETCOLOR
		CASE IS >= 4
			SETCOLOR C_YELLOW
			PRINTL 【十分敏感】经过开发，即便只用嘴也能舒服的高潮
			RESETCOLOR
		CASE IS == 2
			SETCOLOR C_GREEN
			PRINTL 【敏感】口部已经可以产生明显的快感了，继续调教下去这里也能成为合格的性器。
			RESETCOLOR
		CASE IS == 1
			SETCOLOR C_AQUA
			PRINTL 【素质】嘴唇很容易受到刺激，很有调教价值
			RESETCOLOR
		CASE IS == 0
			PRINTL 【未开发】即便被爱抚也没什么特别的感觉
	ENDSELECT
	;履历---------------------------------------------------------------------
	PRINTFORM 初吻履历：
	IF TALENT:選択中キャラID:キス未経験 > 0
		CALL COLORMESSAGE(@"还保有初吻",C_YELLOW,1)
	ELSEIF TALENT:選択中キャラID:キス未経験 < 0
		CALL COLORMESSAGE(@"还保有初吻",C_YELLOW,1)
