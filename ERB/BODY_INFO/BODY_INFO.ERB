			SPLIT CSTR:選択中キャラID:初吻喪失履歴, "￥ＢＲ", LOCALS
			CALL COLORMESSAGE(@"%LOCALS:0%",C_PINK,1)
			PRINTFORM 虽然是这样认为的、但其实……
			CALL COLORMESSAGE(@"%LOCALS:1%",C_PINK,1)
			RESULT = LOCAL
			VARSET LOCALS
		ELSE
			CALL COLORMESSAGE(@"%CSTR:選択中キャラID:初吻喪失履歴%",C_PINK,1)
		ENDIF
	ELSEIF 選択中キャラID != MASTER
		CALL COLORMESSAGE(@"在和%CALLNAME:MASTER%相遇之前就失去了",C_AQUA,1)
	ENDIF
	;中毒---------------------------------------------------------------------
	IF ABL:選択中キャラID:精液中毒 >= 16
		SETCOLOR C_RED
		PRINTFORML 如今只要喝下精液❤、身体就会立刻发情❤
		RESETCOLOR
	ELSEIF ABL:選択中キャラID:精液中毒 >= 12
		SETCOLOR C_PINK
		PRINTFORML 呐…已经很久没有尝到那个味道了…你❤的❤味❤道❤
		RESETCOLOR
	ELSEIF ABL:選択中キャラID:精液中毒 >= 8
		SETCOLOR C_ORANGE
