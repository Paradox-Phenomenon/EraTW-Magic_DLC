	;继承---------------------------------------------------------------------
	SETCOLOR C_CREAM
	SIF GETBIT (CFLAG:選択中キャラID:继承, 6)
		PRINTFORML %CALLNAME:MASTER%非常清楚该如何让其最有感觉
	;高级标签---------------------------------------------------------------------
