IF GETBIT(STAIN:選択中キャラID:Ｂ, 4)
	strImgSet1 += @"%strPrefix%%strBreastsType%_母乳,"
	strImgSet2 += @"%strPrefix%%strBreastsType%_母乳,"
ENDIF

;阿空太陽爐特例
IF 選択中キャラID == 37
	strImgSet1 += @"bodyGraph_B_額外_空,"
	strImgSet2 += @"bodyGraph_B_額外_空,"
ENDIF

;精液
