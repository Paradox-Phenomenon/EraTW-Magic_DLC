@GET_HTML_BODYGRAPH_IMAGE(選択中キャラID, parts, width=180, height=180)
#DIM 選択中キャラID
#DIM height
#DIM width
#DIM bitPart
#DIM layers
#DIM G_ID
#DIMS HTMLText
#DIMS parts
#DIMS DYNAMIC strImgSet1
#DIMS DYNAMIC strImgSet2
#DIMS DYNAMIC strImgSet3
#DIMS DYNAMIC strImgSet4
#DIMS DYNAMIC src
#DIMS DYNAMIC srcb

VARSET strImgSet1
VARSET strImgSet2
VARSET strImgSet3
VARSET strImgSet4

; 男MASTER專用
IF 選択中キャラID == 0 && TALENT:選択中キャラID:性別 == 2
	VARSET RESULTS
	SELECTCASE parts
		CASE "P", "PC" ,"F"
		CASEELSE
			RESULTS '= @"<img src='bodyGraph_X' width='{width}px' height='{height}px'>"
			RETURN
	ENDSELECT
ENDIF

SELECTCASE parts
	CASE "F"
		; fullbody
		bitPart = 0
		CALL SET_BODYGRAPH_SETS_Fullbody(選択中キャラID, strImgSet1, strImgSet2)
		IF strImgSet1 == ""
			VARSET RESULTS
			RETURN 0
		ENDIF
	CASE "A"
		bitPart = 1
		CALL SET_BODYGRAPH_SETS_A(選択中キャラID, strImgSet1, strImgSet2, strImgSet3)
	CASE "B"
		bitPart = 2
		CALL SET_BODYGRAPH_SETS_B(選択中キャラID, strImgSet1, strImgSet2)
	CASE "C"
		bitPart = 3
	CASE "V"
		bitPart = 4
		CALL SET_BODYGRAPH_SETS_V(選択中キャラID, strImgSet1, strImgSet2, strImgSet3, strImgSet4)
	CASE "M"
		; mouth
		bitPart = 5
		CALL SET_BODYGRAPH_SETS_M(選択中キャラID, strImgSet1, strImgSet2)
	CASE "P"
		; mouth
		bitPart = 6
		CALL SET_BODYGRAPH_SETS_P(選択中キャラID, strImgSet1, 0)
		strImgSet2 '= strImgSet1
	CASE "PC"
		; mouth
		bitPart = 6
		CALL SET_BODYGRAPH_SETS_P(選択中キャラID, strImgSet1, 1)
		strImgSet2 '= strImgSet1
	CASEELSE
		strImgSet1 '= "bodyGraph_X"
		strImgSet2 '= "bodyGraph_X"
ENDSELECT

; 未知時把bit調回0
IF STRFIND(strImgSet1, "未知" ) != -1
	CALL CHECK_BODYGRAPH_RECORD("set", bitPart, 0)
ENDIF

; switch image if is n time
CALL CHECK_BODYGRAPH_RECORD("get", bitPart)
IF RESULT == 2 && parts == "V"
	strImgSet1 = %strImgSet4%
	strImgSet2 = %strImgSet4%,bodyGraph_hover
ELSEIF RESULT
	SELECTCASE parts
		CASE "A"
			; use 3
			strImgSet1 = %strImgSet3%
			strImgSet2 = %strImgSet3%,bodyGraph_hover
		CASE "V"
		; use 3
			strImgSet1 = %strImgSet3%
			strImgSet2 = %strImgSet3%
		CASE "F"
			; switch 1 & 2, and use 180 hover arrow
			strImgSet1 = %strImgSet2%
			strImgSet2 = %strImgSet2%,bodyGraph_hover_half
		CASEELSE
		; switch 1 & 2
		strImgSet1 = %strImgSet2%
		strImgSet2 = %strImgSet2%,bodyGraph_hover
	ENDSELECT
ENDIF
; set image
CALL AAZ_OVERLAY_IMAGES_BY_STRING(strImgSet1)
src = %strImgSet1%
CALL AAZ_OVERLAY_IMAGES_BY_STRING(strImgSet2)
srcb = %strImgSet2%

DEBUGPRINTFORML %parts%
DEBUGPRINTFORML src= %src%
DEBUGPRINTFORML srcb= %srcb%
CALLF RM_RESOURCECHECK_LOAD("bodyGraph_X")
SIF !RM_RESOURCECHECK_LOAD( srcb )
	srcb = bodyGraph_X
IF RM_RESOURCECHECK_LOAD( src )
	HTMLText '= @"<button value='{90000+bitPart}'><img src='%src%' srcb='%srcb%' width='{width}px' height='{height}px'></button>"
ELSE
	HTMLText '= @"<img src='bodyGraph_X' width='{width}px' height='{height}px'>"
ENDIF
RESULTS '= HTMLText
RETURN 1

@SET_BODYGRAPH_SETS_Fullbody(選択中キャラID, strImgSet1, strImgSet2)
#DIM 選択中キャラID
#DIMS REF strImgSet1
#DIMS REF strImgSet2
#DIMS strImg1
#DIMS strImg2
#DIM DYNAMIC CHARATRANS

; 自機
IF 選択中キャラID == 0
	strImg1 '= "bodyGraph_F"
	strImg2 '= "bodyGraph_F"
	IF TALENT:選択中キャラID:性別 == 2
		strImg1 += "_male"
		strImg2 += "_male"
	ELSE
		strImg1 += "_female"
		strImg2 += "_female"
	ENDIF
	IF TALENT:選択中キャラID:年齢 == -1
		strImg1 += "_child"
		strImg2 += "_child"
	ELSE
		strImg1 += "_adult"
		strImg2 += "_adult"
	ENDIF

	strImgSet1 '= strImg1 + ","
	strImgSet2 '= strImg2 + ","
	RETURN 
ENDIF

; 有變化(マミゾウ用)
