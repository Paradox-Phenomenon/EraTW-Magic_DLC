; 		CALL GET_BASE_RESOURCE_TRANS(選択中キャラID,CHARATRANS,"立絵","服","通常")
; 		strImg1 '= RESULTS:0
; 		CALL GET_BASE_RESOURCE_TRANS(選択中キャラID,CHARATRANS,"立絵","裸","笑顔")
; 		strImg2 '= RESULTS:0
; 		IF RESULT
; 			; 變化成功
; 			strImgSet1 '= strImg1 + ","
; 			strImgSet2 '= strImg2 + ","
; 			RETURN 
; 		ENDIF
; ENDIF


; 通常
CALL GET_BASE_RESOURCE(選択中キャラID,"立絵","服","通常")
strImg1 '= RESULTS:0

LOCALS '= "笑顔"
; 貓包專用
VARSET RESULTS
TRYCCALLFORM SPECIAL_BASE_IMAGE_{選択中キャラID}
	IF RESULTS == "EagloV"
		LOCALS '= "発情1"
	ENDIF
CATCH
ENDCATCH
CALL GET_BASE_RESOURCE(選択中キャラID,"立絵","裸", LOCALS)
strImg2 '= RESULTS:0


; 確認圖片是否存在
SIF !RM_RESOURCECHECK(strImg1)
	strImg1 '= @"立絵_服_通常_{選択中キャラID}" 
SIF !RM_RESOURCECHECK(strImg2)
	strImg2 '= @"立絵_裸_笑顔_{選択中キャラID}" 

; check if full body image exists
; IF RM_RESOURCECHECK( strImg1 ) && RM_RESOURCECHECK( strImg2 )
strImgSet1 '= strImg1 + ","
strImgSet2 '= strImg2 + ","
; ENDIF

@SET_BODYGRAPH_SETS_A(選択中キャラID, strImgSet1, strImgSet2, strImgSet3)
#DIM 選択中キャラID
#DIMS REF strImgSet1
#DIMS REF strImgSet2
#DIMS REF strImgSet3
#DIMS strPrefix
#DIMS strTail
#DIMS strBodyType

strPrefix '= "bodyGraph_A"

;臀型
IF 選択中キャラID == 93
	strBodyType '= "_わかさぎ"
ELSEIF TALENT:選択中キャラID:体型 == -2
	strBodyType '= "_幼" 
ELSEIF TALENT:選択中キャラID:バストサイズ < 0
	strBodyType '= "_貧" 
ELSEIF TALENT:選択中キャラID:バストサイズ - CFLAG:選択中キャラID:乳ランクアップ > 0 
	strBodyType '= "_巨"
ELSE
	strBodyType '= "_並"
ENDIF

strPrefix += strBodyType

; 未知時提前退出
IF !IS_DEBUG() && 選択中キャラID != MASTER && !IS_FALLEN(選択中キャラID)
	strImgSet1 '= @"%strPrefix%_未知"
	strImgSet2 '= @"%strPrefix%_未知"
	strImgSet3 '= @"%strPrefix%_未知"
	RETURN 0
ENDIF
; 放置底層臀型
strImgSet1 '= @"%strPrefix%,"
strImgSet2 '= @"%strPrefix%,"

; 排除わかさぎ特例
IF 選択中キャラID != 93
; V精液
	IF GETBIT(STAIN:選択中キャラID:Ｖ, 2)
		strImgSet1 += @"bodyGraph_A_精液V,"
		strImgSet2 += @"bodyGraph_A_精液V,"
	ENDIF
; A精液
	IF GETBIT(STAIN:選択中キャラID:Ａ, 2)
		strImgSet1 += @"bodyGraph_A_精液A,"
		strImgSet2 += @"bodyGraph_A_精液A,"
	ENDIF
; 手
	strImgSet1 += @"%strPrefix%_手1,"
	strImgSet2 += @"%strPrefix%_手2,"
ENDIF

; 尾巴
VARSET strTail
strTail '= DT_CELL_GETS("bbas_dataset", 選択中キャラID, "尾巴", 1)

strPrefix '= "bodyGraph_A"
IF 選択中キャラID == 25
	;藍有獨立判定
	strImgSet1 += @"%strPrefix%_尻尾_%strTail%%strBodyType%,"
	strImgSet2 += @"%strPrefix%_尻尾_%strTail%%strBodyType%,"
ELSEIF STRLENS(strTail) > 0
	strImgSet1 += @"%strPrefix%_尻尾_%strTail%,"
	strImgSet2 += @"%strPrefix%_尻尾_%strTail%,"
ENDIF

; 肛門
; 基底
strPrefix '= "bodyGraph_A_hole"
IF 選択中キャラID == 93
	strImgSet3 += @"%strPrefix%_わかさぎ_BASE,"
ELSE
	strImgSet3 += @"%strPrefix%_BASE,"
ENDIF
; 形狀
SELECTCASE ABL:選択中キャラID:アナル
	CASE IS >= 5
		strImgSet3 += @"%strPrefix%_A5,"
	CASE IS >= 3
		strImgSet3 += @"%strPrefix%_A3,"
	CASE 2
		strImgSet3 += @"%strPrefix%_A2,"
	CASE 1
		strImgSet3 += @"%strPrefix%_A1,"
	CASE 0
		strImgSet3 += @"%strPrefix%_A0,"
ENDSELECT

; 精液充填率
SELECTCASE 充填率(選択中キャラID,2)
	CASE IS >= 100
		strImgSet3 += @"%strPrefix%_精液3,"
	CASE IS >= 50
		strImgSet3 += @"%strPrefix%_精液2,"
	CASE IS > 0
		strImgSet3 += @"%strPrefix%_精液1,"
ENDSELECT

;翅膀
IF RM_RESOURCECHECK( @"bodyGraph_A_wing_{選択中キャラID}" )
	strImgSet1 += @"bodyGraph_A_wing_{選択中キャラID},"
	strImgSet2 += @"bodyGraph_A_wing_{選択中キャラID},"
ENDIF


; ; 性交合意後才會放開，否則取消HOVER效果及肛門顯示
IF !IS_DEBUG() && 選択中キャラID != MASTER && !(CFLAG:選択中キャラID:既成事実 & 合意_うふふ)
	strImgSet2 = %strImgSet1%
ENDIF

@SET_BODYGRAPH_SETS_V(選択中キャラID, strImgSet1, strImgSet2, strImgSet3, strImgSet4)
#DIM 選択中キャラID
#DIMS REF strImgSet1
#DIMS REF strImgSet2
#DIMS REF strImgSet3
#DIMS REF strImgSet4
#DIMS strPrefix
#DIMS strPubicHair
#DIMS DYNAMIC penisType
#DIM cumFilledRate
#DIM cumThreshold = 1,25,50,100,200

strPrefix '= "bodyGraph_V"
; 未知時提前退出
IF !IS_DEBUG() && 選択中キャラID != MASTER && !IS_FALLEN(選択中キャラID)
	IF 選択中キャラID == 93
		strImgSet1 '= @"%strPrefix%_わかさぎ_未知"
		strImgSet2 '= @"%strPrefix%_わかさぎ_未知"
		strImgSet3 '= @"%strPrefix%_わかさぎ_未知"
		RETURN 0
	ENDIF
	strImgSet1 '= @"%strPrefix%_未知"
	strImgSet2 '= @"%strPrefix%_未知"
	strImgSet3 '= @"%strPrefix%_未知"
	RETURN 0
ENDIF

; 放置底層秘所
IF 選択中キャラID == 93
	strImgSet1 '= @"%strPrefix%_わかさぎ,"
	strImgSet2 '= @"%strPrefix%_わかさぎ,"
ELSEIF TALENT:選択中キャラID:不思議な根
	strImgSet1 '= @"%strPrefix%_不思議秘所,"
	strImgSet2 '= @"%strPrefix%_不思議秘所,"
ELSE
	strImgSet1 '= @"%strPrefix%_秘所,"
	strImgSet2 '= @"%strPrefix%_秘所,"
ENDIF

; 放置內側精液
SELECTCASE 充填率(選択中キャラID,1)
	CASE IS >= 100
		strImgSet1 += @"%strPrefix%_精液3,"
		strImgSet2 += @"%strPrefix%_精液3,"
	CASE IS >= 50
		strImgSet1 += @"%strPrefix%_精液2,"
		strImgSet2 += @"%strPrefix%_精液2,"
	CASE IS > 0
		strImgSet1 += @"%strPrefix%_精液1,"
		strImgSet2 += @"%strPrefix%_精液1,"
ENDSELECT

;陰毛(暫時無用)
; SELECTCASE CFLAG:選択中キャラID:陰毛
; 	CASE 1
; 		strImgSet1 += @"%strPrefix%_薄い,"
; 		strImgSet2 += @"%strPrefix%_薄い,"
; 	CASE IS > 1
; 		; 上色陰毛
; 		strPubicHair '= "bodyGraph_V_濃い"
; 		CALL CREATE_SPRITE_COLORHEX(strPubicHair, DT_CELL_GET("bbas_dataset", 選択中キャラID, "髮色", 1))
; 		strPubicHair '= RESULTS
; 		strImgSet1 += @"%strPubicHair%,"
; 		strImgSet2 += @"%strPubicHair%,"
; ENDSELECT

; 外部精液
IF GETBIT(STAIN:選択中キャラID:Ｖ, 1)
	strImgSet1 += @"%strPrefix%_精液外,"
	strImgSet2 += @"%strPrefix%_精液外,"
ENDIF

; 放置陰莖
SELECTCASE TALENT:選択中キャラID:形状
	CASE 1
		penisType '= "未熟"
	CASE 2
		penisType '= "粗末"
	CASE 3
		penisType '= "通常"
	CASE 4
		penisType '= "未熟"
	CASE 5
		penisType '= "イボ付き"
	CASE 6
		penisType '= "大"
	CASE 10
		penisType '= "馬"
ENDSELECT
IF TALENT:選択中キャラID:形状
	strImgSet2 += @"%strPrefix%_ちんこ_%penisType%,"
ENDIF

; 手
strImgSet1 += @"%strPrefix%_手1,"
strImgSet2 += @"%strPrefix%_手2,"

; 陰道
strPrefix '= "bodyGraph_V_pussy"
; わかさぎ專用前綴
; 體型
IF 選択中キャラID == 93
	SELECTCASE TALENT:選択中キャラID:体型
		CASE IS <= -2
			strImgSet3 += @"%strPrefix%_わかさぎ_幼,"
		CASE -1
			strImgSet3 += @"%strPrefix%_わかさぎ_小,"
		CASE 0
			strImgSet3 += @"%strPrefix%_わかさぎ_並,"
		CASE IS > 0
			strImgSet3 += @"%strPrefix%_わかさぎ_大,"
	ENDSELECT
ELSE
	; 體型
	SELECTCASE TALENT:選択中キャラID:体型
		CASE IS <= -2
			strImgSet3 += @"%strPrefix%_幼,"
		CASE -1
			strImgSet3 += @"%strPrefix%_小,"
		CASE 0
			strImgSet3 += @"%strPrefix%_並,"
		CASE IS > 0
			strImgSet3 += @"%strPrefix%_大,"
	ENDSELECT
ENDIF

; 形狀
IF TALENT:選択中キャラID:処女 > 0
strImgSet3 += @"%strPrefix%_処,"
ELSE
	SELECTCASE ABL:選択中キャラID:膣
		CASE IS >= 5
			strImgSet3 += @"%strPrefix%_5,"
		CASE IS >= 3
			strImgSet3 += @"%strPrefix%_3,"
		CASE 2
			strImgSet3 += @"%strPrefix%_2,"
		CASE 1
			strImgSet3 += @"%strPrefix%_1,"
		CASE 0
			strImgSet3 += @"%strPrefix%_0,"
	ENDSELECT
ENDIF

; 精液充填率
IF 充填率(選択中キャラID,1) > 0
	strImgSet3 += @"%strPrefix%_精"
	IF ABL:選択中キャラID:膣 >= 3
		strImgSet3 +="b"
	ELSE
		strImgSet3 +="a"
	ENDIF
	strImgSet3 += @"{ LIMIT(充填率(選択中キャラID,1)/20, 1, 5) },"
ENDIF

;愛液
IF PALAM:選択中キャラID:潤滑 > 500
	strImgSet3 += @"%strPrefix%_愛液,"
ENDIF

;不思議な根
IF TALENT:選択中キャラID:不思議な根
	strImgSet3 += @"%strPrefix%_不思議,"
ENDIF

IF TALENT:選択中キャラID:形状
	; 有陰莖就畫金玉
	strImgSet3 += @"%strPrefix%_ちんこ_金玉,"
ELSE
	; 普通畫手
	strImgSet3 += @"%strPrefix%_手,"
ENDIF


; 子宮
strPrefix '= "bodyGraph_V_子宮"
; 判斷妊娠天數
SELECTCASE CFLAG:選択中キャラID:妊娠経過日数
	CASE IS >= 80
		strPrefix += "_80日"
	CASE IS >= 60
		strPrefix += "_60日"
	CASE IS >= 30
		strPrefix += "_30日"
	CASE IS >= 10
		strPrefix += "_10日"
ENDSELECT
;輸出子宮底圖
strImgSet4 '= @"%strPrefix%,"


; 判斷精液量
cumFilledRate = 充填率(選択中キャラID,1)
; cumThreshold = [1,25,50,100,200]
VARSET LOCALS
FOR LOCAL, 0, 5
	IF cumFilledRate >= cumThreshold:LOCAL
		; 確認指定精液量的圖片是否存在
		SIF !RM_RESOURCECHECK( @"%strPrefix%_精液{cumThreshold:LOCAL}" )
			BREAK
		LOCALS '= @"%strPrefix%_精液{cumThreshold:LOCAL}"
	ELSE
		BREAK
	ENDIF
NEXT
IF STRLENS(LOCALS) > 0
	strImgSet4 += @"%LOCALS%,"
ENDIF

; 輸出寶寶
IF CFLAG:選択中キャラID:妊娠経過日数
	strImgSet4 += @"%strPrefix%_妊娠,"
ELSEIF (CFLAG:選択中キャラID:生理周期 == 7 || TCVAR:選択中キャラID:強制排卵) && FLAG:生理周期可視化
	strImgSet4 += @"%strPrefix%_卵子,"
ENDIF

; 性交合意後才會放開，否則取消HOVER效果及顯示
IF !IS_DEBUG() && 選択中キャラID != MASTER && !(CFLAG:選択中キャラID:既成事実 & 合意_うふふ)
	strImgSet2 = %strImgSet1%
ENDIF
RETURN 1


