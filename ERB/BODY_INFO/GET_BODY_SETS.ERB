		strImgSet1 += @"%strPrefix%%strBreastsType%_精液(空),"
		strImgSet2 += @"%strPrefix%%strBreastsType%_精液(空),"
	ELSE
		strImgSet1 += @"%strPrefix%%strBreastsType%_精液,"
		strImgSet2 += @"%strPrefix%%strBreastsType%_精液,"
	ENDIF
ENDIF

;手
strImgSet1 += @"%strPrefix%%strBreastsType%_手%strPregnancyType%,"

;額外
SELECTCASE 選択中キャラID
	CASE 38
		strImgSet1 += @"bodyGraph_B_額外_戀,"
		strImgSet2 += @"bodyGraph_B_額外_戀,"
	CASE 49
		strImgSet1 += @"bodyGraph_B_額外_覺,"
		strImgSet2 += @"bodyGraph_B_額外_覺,"
ENDSELECT

; 性交合意後才會放開胸部，否則取消HOVER效果
IF !IS_DEBUG() && 選択中キャラID != MASTER && !(CFLAG:選択中キャラID:既成事実 & 合意_うふふ)
	strImgSet2 = %strImgSet1%
ENDIF
RETURN 1

@SET_BODYGRAPH_SETS_M(選択中キャラID, strImgSet1, strImgSet2)
#DIM 選択中キャラID
#DIMS REF strImgSet1
#DIMS REF strImgSet2
#DIMS strPrefix
#DIMS strHairGeneral
#DIMS strFaceType
strPrefix '= "bodyGraph_M_口外"

; 指定臉型
VARSET LOCALS
LOCALS '= DT_CELL_GETS("bbas_dataset", 選択中キャラID, "臉型", 1)
IF LOCALS == "幼"
	strImgSet1 += @"%strPrefix%_顔2,"
	strFaceType '= "2"
ELSEIF LOCALS == "普"
	strImgSet1 += @"%strPrefix%_顔1,"
	strFaceType '= "1"
ELSE
	; 矮小、幼童用臉2，其餘臉1
	IF TALENT:選択中キャラID:体型 < 0
		strImgSet1 += @"%strPrefix%_顔2,"
		strFaceType '= "2"
	ELSE
		strImgSet1 += @"%strPrefix%_顔1,"
		strFaceType '= "1"
	ENDIF
ENDIF

; 指定嘴型
VARSET LOCALS
LOCALS '= DT_CELL_GETS("bbas_dataset", 選択中キャラID, "嘴型", 1)
IF STRLENS(LOCALS) != 0
	LOCALS = _%LOCALS%
ELSE
	; 性格判定
	SELECTCASE CFLAG:選択中キャラID:性格傾向
		CASE 1
			; 気弱系
			LOCALS '= "_気弱"
		CASE 2
			; 強気系
			LOCALS '= "_強気"
		CASE 3
			; 素直系
			LOCALS '= "_素直"
		CASE 4
			; 真面目系
			LOCALS '= "_真面目"
		CASEELSE
			; 剩下的丟給素直
			LOCALS '= "_素直"
	ENDSELECT
	; 小惡魔判定(通過則覆蓋前者)
	IF TALENT:選択中キャラID:小悪魔
		LOCALS '= "_小悪魔"
	ENDIF
ENDIF
strImgSet1 += @"%strPrefix%%LOCALS%,"

; 決定精液
IF GETBIT(STAIN:選択中キャラID:口, 2)
	; 無邪氣使用精液2
	IF STRFINDU(strImgSet1, "無邪気") >= 0
		strImgSet1 += @"%strPrefix%_精液2,"
	ELSE
		strImgSet1 += @"%strPrefix%_精液1,"
	ENDIF
ENDIF

;加上頭髮
IF 選択中キャラID == 67 && MOON_WATCH(DAY:3) == 9
	strImgSet1 += @"%strPrefix%_髮_{選択中キャラID}_2,"
ELSEIF RM_RESOURCECHECK(@"%strPrefix%_髮_{選択中キャラID}")
	strImgSet1 += @"%strPrefix%_髮_{選択中キャラID},"
ELSE
	strHairGeneral '= @"bodyGraph_M_口外_髮_泛用%strFaceType%"
	; 路人子
	IF 選択中キャラID == CHARANUM -1
		CALL CREATE_SPRITE_COLORNAME(strHairGeneral, GET_MOB_ELEMENT_COLORNAME("髪色") )
	ELSE
		CALL CREATE_SPRITE_COLORHEX(strHairGeneral, DT_CELL_GET("bbas_dataset", 選択中キャラID, "髮色", 1) )
	ENDIF
	strHairGeneral '= RESULTS
	strImgSet1 += @"%strHairGeneral%,"
ENDIF

; 處理口內圖片
strPrefix '= "bodyGraph_M_口內"
strImgSet2 '= strPrefix
LOCALS '= DT_CELL_GETS("bbas_dataset", 選択中キャラID, "口內", 1)
IF STRLENS(LOCALS) != 0
	LOCALS = _%LOCALS%
ELSE
	LOCALS '= "_通用"
ENDIF
strImgSet2 += LOCALS

; 決定精液
IF GETBIT(STAIN:選択中キャラID:口, 2)
	strImgSet2 += @",%strPrefix%_精液1"
	strImgSet2 += @",%strPrefix%_精液2"
ENDIF
RETURN 1

@SET_BODYGRAPH_SETS_P(選択中キャラID, strImgSet1, CIRCLE=0 )
#DIM 選択中キャラID
#DIM CIRCLE
#DIMS REF strImgSet1

SELECTCASE TALENT:選択中キャラID:形状
	CASE 0
		;無
		strImgSet1 '= "ダミー,"
	CASE 1
		;未成熟
		strImgSet1 '= "bodyGraph_キノコ_マッシュルーム（白）,"
	CASE 2
		;粗チン
		strImgSet1 '= "bodyGraph_キノコ_マッシュルーム,"
	CASE 3
		;普通
		strImgSet1 '= "bodyGraph_キノコ_しいたけ,"
	CASE 4
		;発光する
		strImgSet1 '= "bodyGraph_キノコ_光るキノコ,"
	CASE 5
		;イボ付き
		strImgSet1 '= "bodyGraph_キノコ_毒キノコ,"
	CASE 6
		;大
		strImgSet1 '= "bodyGraph_キノコ_まつたけ,"
	CASE 10
		;馬
		strImgSet1 '= "bodyGraph_キノコ_えりんぎ,"
	CASEELSE
	strImgSet1 '= "bodyGraph_キノコ_しいたけ,"
ENDSELECT
IF CIRCLE == 1
	strImgSet1 '= "bodyGraph_circle," + strImgSet1
ENDIF
RETURN 1