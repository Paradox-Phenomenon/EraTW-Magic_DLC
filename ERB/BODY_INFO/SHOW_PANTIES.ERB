@SHOW_IMAGE_PANTIES(pantiesBase, hexColor = 0XFFFFFF)
#DIM G_ID
#DIMS pantiesBase
#DIMS pantiesNAME
#DIM hexColor
; 特定內褲能指定顏色
IF GROUPMATCH(pantiesBase, "丁字褲", "Ｔ字褲", "條紋胖次", "繩系胖次", "高開叉胖次", "褶边胖次", "低腰緊身胖次", "低腰胖次", "波点胖次", "純色胖次", "三角胖次")
    pantiesNAME = %pantiesBase%x{hexColor}
ELSE
    pantiesNAME = %pantiesBase%
ENDIF

; PRINTFORML %pantiesBase% -> %pantiesNAME%
IF !RM_RESOURCECHECK_LOAD( pantiesNAME )
    ; 不存在指定內褲_顏色，現場搓一個
    G_ID = 0
    CALL 画像合成_COLORMATRIX(G_ID, pantiesBase, 0, 0, 0, 0, hexColor )
    SPRITECREATE pantiesNAME, G_ID
ENDIF
RESULTS = %pantiesNAME%

RETURN 0

