@画像合成_COLORMATRIX(グラフィックID, リソース名, POS_X = 0, POS_Y = 0, 横幅 = 0, 縦幅 = 0, COLORHEX = 0XFFFFFF)
#DIM REF グラフィックID		;合成先のグラフィックID 参照渡し
#DIMS リソース名			;合成元のリソースID
#DIM POS_X					;リソースを配置するX座標
#DIM POS_Y					;リソースを配置するY座標
#DIM 横幅					;合成するリソースの横幅
#DIM 縦幅					;合成するリソースの縦幅
#DIM COLORHEX		        ;カラーブレンドの名称
#DIM カラーマトリクス, 5, 5	;カラーブレンドに使用するマトリクス
SIF !RM_RESOURCECHECK_LOAD(リソース名)
	;リソースが存在しない場合0を返す
	RETURN 0
IF 横幅 == 0 || 縦幅 == 0
	横幅 = SPRITEWIDTH(リソース名)
	縦幅 = SPRITEHEIGHT(リソース名)
ENDIF
IF グラフィックID == 0
	;前回呼び出されていれば続きから始める
	グラフィックID = NEXT_GID
	WHILE GCREATED(グラフィックID)
		;空いているグラフィックIDを走査する
		グラフィックID ++
	WEND
	;次回は続きから走査するように設定
	NEXT_GID = グラフィックID + 1
	
	GCREATE グラフィックID, 横幅, 縦幅 
ENDIF

;カラーブレンドが設定されている場合、適用して合成
CALL SETCOLORMATRIX(カラーマトリクス,COLORHEX)
GDRAWSPRITE グラフィックID, リソース名, POS_X, POS_Y,  横幅, 縦幅, カラーマトリクス:0:0
; SIF IMG_DEBUG ;don't pollute the debug console unless enabled
; DEBUGPRINTFORML 画像合成：%リソース名%:{グラフィックID},{POS_X},{POS_Y},{横幅},{縦幅},%カラーブレンド名%

SIF RESULT == 0
	RETURN 0
RETURN 1


@SETCOLORMATRIX(カラーマトリクス,COLORHEX)
#DIM REF カラーマトリクス, 0, 0	;使用するカラーマトリクスを格納する変数 参照渡し
#DIM COLORHEX
#DIM RED
#DIM GREEN
#DIM BLUE
#DIM LENGTH
; GET RGB VALUES FROM HEX
BLUE = COLORHEX % 256
COLORHEX = COLORHEX / 256
GREEN = COLORHEX % 256
COLORHEX = COLORHEX / 256
RED = COLORHEX % 256
; NORMALIZE RGB VALUES
SETCOLOR RED, GREEN, BLUE
; PRINTFORML r{RED},g{GREEN},b{BLUE}
RESETCOLOR

; LENGTH = SQRT(BLUE*BLUE + GREEN*GREEN + RED*RED)
; RED = RED*256 / LENGTH
; GREEN = GREEN*256 / LENGTH
; BLUE = BLUE*256 / LENGTH
; PRINTFORML Nr{RED},Ng{GREEN},Nb{BLUE}

VARSET カラーマトリクス

カラーマトリクス:0:0 = RED
カラーマトリクス:0:1 = GREEN
カラーマトリクス:0:2 = BLUE

カラーマトリクス:1:0 = 256-2*RED
カラーマトリクス:1:1 = 256-2*GREEN
カラーマトリクス:1:2 = 256-2*BLUE

カラーマトリクス:2:0 = RED
カラーマトリクス:2:1 = GREEN
カラーマトリクス:2:2 = BLUE

カラーマトリクス:3:3 = 256
カラーマトリクス:4:4 = 256