;-------------------------------------------------
;二穴愛撫
;愛撫系コマンド、レベル2
;-------------------------------------------------
@COM25
;-------------------------------------------------
;COM別FLAGの設定
;-------------------------------------------------
;行為者
TCVAR:116 = PLAYER
;奉仕快楽
TCVAR:PLAYER:108 = 1

;破瓜抑制
TFLAG:2 = 1

CSTR:TARGET:10 += @"{PLAYER}/"
;TCVAR:2 射精箇所フラグ（-1=コンドーム 1=膣内 2=アナル 3=手淫 4=口淫 5=パイズリ 6=素股 7=足コキ 8=体表 9=アナル奉仕 10=道具 11=触手 12=Ａ責め 13=Ｖ責め）
TCVAR:TARGET:2 = 12
;強度
TCVAR:TARGET:4 = 800

;-------------------------------------------------
;ソース追加処理
;-------------------------------------------------
;消費体力、気力
IF FLAG:70 == 1
	BASE:MASTER:TSP -= 100
	IF !TALENT:処女 || TALENT:処女 == -1
		SOURCE:快Ｖ = 100
		SOURCE:苦痛 = 60
        SOURCE:快Ａ = 80
	ELSE
		SOURCE:快Ｖ = 50
		SOURCE:苦痛 = 60
        SOURCE:快Ａ = 80
	ENDIF
	IF TALENT:PLAYER:器用な指
		SOURCE:快Ｖ += 15
        SOURCE:快Ａ += 15
    ENDIF
	SOURCE:快Ｖ += ABL:PLAYER:指 * 5
    SOURCE:快Ａ += ABL:PLAYER:指 * 5
	;Vへの苦痛
	CALL PAIN_CHECK_V(TARGET)
	IF HETEROSEX(TARGET,PLAYER)
		EXP:PLAYER:(50 + HETEROSEX(TARGET,PLAYER)) += 1
	ENDIF
	EXP:Ｖ経験 ++
	EXP:PLAYER:手淫経験 ++
ELSE

	DOWNBASE:体力 += 80
	DOWNBASE:気力 += 180

	IF !TALENT:処女 || TALENT:処女 == -1
		SOURCE:快Ｖ = 100
		SOURCE:苦痛 = 100
        SOURCE:快Ａ = 80
        SOURCE:屈従 = 100
		SOURCE:露出 = 20
		SOURCE:逸脱 = 100
		SOURCE:反感 = 100
	;V経験が0の時はV経験を伴わない物に派生
	;Vの珠は入らないが、快Vが高いと慣らしてあるため処女喪失時に影響
	ELSE
		SOURCE:快Ｖ = 60
		SOURCE:苦痛 = 120
        SOURCE:快Ａ = 80
        SOURCE:屈従 = 100
		SOURCE:露出 = 20
		SOURCE:逸脱 = 120
		SOURCE:反感 = 120
	ENDIF

	IF TALENT:PLAYER:器用な指
		SOURCE:快Ｖ += 15
        SOURCE:快Ａ += 15
    ENDIF
	SOURCE:快Ｖ += ABL:PLAYER:指 * 5
    SOURCE:快Ａ += ABL:PLAYER:指 * 5
	;-------------------------------------------------
	;特殊ソース処理
	;-------------------------------------------------
	;抑圧、抵抗持ちには、抑鬱ソース追加
	IF TALENT:自己愛 < 0 || TALENT:抵抗
		SOURCE:鬱屈 += 20
		;処女
		SIF TALENT:処女
			SOURCE:鬱屈 += 10
	ENDIF
	;Vへの苦痛
	CALL PAIN_CHECK_V(TARGET)
	;-------------------------------------------------
	;経験の処理
	;-------------------------------------------------
	;同性愛　レズなら戻り値1ゲイなら戻り値2
	IF HETEROSEX(TARGET,PLAYER)
		EXP:(50 + HETEROSEX(TARGET,PLAYER)) += 1
		EXP:PLAYER:(50 + HETEROSEX(TARGET,PLAYER)) += 1
	ENDIF
	EXP:Ｖ経験 ++
	EXP:PLAYER:手淫経験 ++
ENDIF
;-------------------------------------------------
;汚れの処理
;-------------------------------------------------
;相手の膣内⇔調教者の指の汚れが移動
STAIN:6 |= STAIN:PLAYER:1
STAIN:PLAYER:1 |= STAIN:6
;Ａ⇔調教者の指の汚れが移動
STAIN:PLAYER:1 |= STAIN:4
STAIN:PLAYER:1 |= STAIN:7
STAIN:4 |= STAIN:PLAYER:1
STAIN:7 |= STAIN:PLAYER:1
RETURN 1

;-------------------------------------------------
;実行判定
;-------------------------------------------------
@COM_ABLE25
;二穴愛撫実行判定
SIF !TFLAG:100
	RETURN 0
;一括管理
SIF GLOBAL_COMABLE(25)
	RETURN RESULT
;毒人形だと性器がついてないのでダメ
SIF TALENT:196 == 99
	RETURN 0
;オトコだとダメ
SIF !(TALENT:2 & 1)
	RETURN 0
;あなたの指が低いと駄目
SIF ABL:PLAYER:指 < 3
    RETURN 0
;挿入中は駄目
SIF TEQUIP:50 != -1
	RETURN 0
SIF TEQUIP:51 != -1
	RETURN 0
;アナルビーズ使用中は不可
SIF TEQUIP:15
	RETURN 0
;普通の浣腸使用中は不可
SIF TEQUIP:21
	RETURN 0
;バルーン使用中は不可
SIF TEQUIP:22
	RETURN 0
;電極使用中は不可
SIF TEQUIP:23
	RETURN 0
;時間停止中は許可
IF FLAG:70 != 1
	;潤滑不足で、従順3以下・レズっ気3以下のASSIの場合アナル愛撫はできない（サドならＯＫ）
	IF PALAM:潤滑 < PALAMLV:2 && ASSIPLAY
		SIF (ABL:ASSI:従順 <= 3 || ABL:ASSI:レズっ気 <= 3) && !TALENT:ASSI:サド
			RETURN 0
	ENDIF
ENDIF

;下半身着衣
SIF TEQUIP:0 & 4
	RETURN 0
RETURN 1

@COM25_TAGS
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
LOCAL = 0
SETBIT LOCAL, BIT_V使用コマンド
SETBIT LOCAL, BIT_A使用コマンド
RETURNF LOCAL