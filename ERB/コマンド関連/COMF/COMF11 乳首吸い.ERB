;-------------------------------------------------
;吸乳头
;愛撫系指令、レベル1
;-------------------------------------------------
@COM11
;着脱の処理
TEQUIP:吸乳头 = !TEQUIP:吸乳头

;-------------------------------------------------
;COM別FLAGの設定
;-------------------------------------------------
;行為者
TCVAR:116 = PLAYER
;奉仕快楽
TCVAR:PLAYER:108 = 1

;-------------------------------------------------
;ソース追加処理
;-------------------------------------------------
;消費体力、気力
IF (FLAG:70 == 1 && CFLAG:TARGET:344 == 0)
	BASE:MASTER:TSP -= 20
	SOURCE:快Ｂ += ABL:PLAYER:舌 * 20 + 20

ELSE
	DOWNBASE:体力 += 5
	DOWNBASE:気力 += 50

	SOURCE:快Ｂ = 20
	SOURCE:情愛 = 30
	SOURCE:露出 = 20
	SOURCE:不潔 = 30
	SOURCE:反感 = 100

	SOURCE:快Ｂ += ABL:PLAYER:舌 * 20
	SOURCE:情愛 += ABL:PLAYER:舌 * 5

	SIF ABL:親密 >= 7
		SOURCE:情愛 += (ABL:親密 * 20)

	;調教者のTALENT:舌使いをみる
	SIF TALENT:PLAYER:舌使い
		TIMES SOURCE:快Ｂ , 1.50

	;調教者のTALENT:猫舌をみる
	SIF TALENT:PLAYER:猫舌
		TIMES SOURCE:快Ｂ , 0.75
	;-------------------------------------------------
	;特殊ソース処理
	;-------------------------------------------------
	;圧抑、抵抗持ちには、抑鬱ソース追加
	SIF TALENT:自己愛 < 0 || TALENT:抵抗
		SOURCE:鬱屈 += 100
ENDIF
;-------------------------------------------------
;汚れの処理
;-------------------------------------------------
;奴隷のＢ⇔調教者の口的污垢が移動
STAIN:5 |= STAIN:PLAYER:0
STAIN:PLAYER:0 |= STAIN:5
;-------------------------------------------------
;経験の処理
;-------------------------------------------------
;同性愛　レズなら戻り値1ゲイなら戻り値2
IF (FLAG:70 == 1 && CFLAG:TARGET:344 == 0)
	IF HETEROSEX(TARGET,PLAYER)
		EXP:PLAYER:(50 + HETEROSEX(TARGET,PLAYER)) += 5
	ENDIF
ELSE
	IF HETEROSEX(TARGET,PLAYER)
		EXP:(50 + HETEROSEX(TARGET,PLAYER)) += 5
		EXP:PLAYER:(50 + HETEROSEX(TARGET,PLAYER)) += 5
	ENDIF
ENDIF
;調教者が猫舌持ちの場合は、調教者に嗜虐快楽経験を追加
SIF TALENT:PLAYER:猫舌
	EXP:PLAYER:嗜虐快楽経験 += 1
EXP:PLAYER:口淫経験 ++
RETURN 1
;-------------------------------------------------
;装着継続の処理
;-------------------------------------------------
@EQUIP_COM11(ARG)

IF TFLAG:現在的TARGET == ARG
	IF COM_TAGS_CHECK(SELECTCOM, BIT_乳首吸い解除)
		PRINTL ＜吸乳头解除＞
		SIF TEQUIP:ARG:吸乳头
			TEQUIP:ARG:吸乳头 = 0
		RETURN 1
	ENDIF
ENDIF
;吸乳头中
PRINTL ＜吸乳头中＞
;-------------------------------------------------
;ソース追加処理
;-------------------------------------------------
IF (FLAG:70 == 1 && CFLAG:TARGET:344 == 0)
	BASE:MASTER:TSP -= 20
	SOURCE:ARG:快Ｂ += (ABL:PLAYER:舌 + 1) * 10
ELSE
	DOWNBASE:ARG:体力 += 5
	DOWNBASE:ARG:気力 += 20
	DOWNBASE:PLAYER:体力 += 5
	DOWNBASE:PLAYER:気力 += 10
	SOURCE:ARG:快Ｂ += (ABL:PLAYER:舌 + 1) * 10
	SOURCE:ARG:露出 = 20
	SOURCE:ARG:不潔 = 30
	SOURCE:ARG:反感 = 50
	SOURCE:ARG:情愛 += ABL:PLAYER:舌 * 5

	SIF ABL:ARG:親密 >= 5
		SOURCE:ARG:情愛 += (ABL:ARG:親密 * 3)
ENDIF

;-------------------------------------------------
;汚れの処理
;-------------------------------------------------
;奴隷のＢ⇔調教者の口の汚れが移動
STAIN:ARG:5 |= STAIN:PLAYER:0
STAIN:PLAYER:0 |= STAIN:ARG:5
;調教者が猫舌持ちの場合は、調教者に嗜虐快楽経験を追加
SIF TALENT:PLAYER:猫舌
	EXP:PLAYER:嗜虐快楽経験 += 1
EXP:PLAYER:口淫経験 ++
;EXP:乳頭 ++


@MESSAGE_EQUIP_COM11(ARG = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
SIF ARG == -1
	ARG = TARGET
IF TFLAG:50 == 19
	;授乳PLAYの時は表示しない
ELSE
	PRINT 
	;SIF CFLAG:PLAYER:现在忙得抽不出手 == 1
	;	PRINTFORM %CALLNAME:ARG%
	IF EX:ARG:Ｂ絶頂 * 10000 + PALAM:ARG:快Ｂ + PALAM:ARG:欲情 >= 10000 && ABL:ARG:Ｂ感覚 >= 5
		PRINTFORML %CALLNAME:ARG%%TEXTR("因为对被玩弄乳头的期待而颤抖不已/颤抖的乳蕾无法隐藏内心的迫不及待/")%……
	ENDIF
	PRINTFORM %CALLNAME:MASTER%用口舌%TEXTR("品味/反复舔舐/")%着%CALLNAME:ARG%%NIPPLE_DESCRIPTION(ARG,1)%
	;欲情のPALAMLV4以上
	IF PALAM:ARG:欲情 >= PALAMLV:4 && RAND:3
		PRINT 咯叽咯叽
	ELSEIF EX:ARG:Ｂ絶頂 * 10000 + PALAM:ARG:快Ｂ + PALAM:ARG:欲情 >= 10000 && RAND:2
		PRINT 软糖般
	ELSE
		PRINT 柔软
	ENDIF
	PRINT 触感的同时、
ENDIF

;-------------------------------------------------
;実行判定
;-------------------------------------------------
@COM_ABLE11
#LOCALSIZE 2
#LOCALSSIZE 1
;吸乳头実行判定
SIF !TFLAG:100
	RETURN 0
;一括管理
SIF GLOBAL_COMABLE(11)
	RETURN RESULT
;上半身着衣
SIF (TEQUIP:1 & 2) && TEQUIP:3 == 0
	RETURN 0
;搾乳器使用中は不可
SIF TEQUIP:17
	RETURN 0
;乳頭夾使用中は不可
SIF TEQUIP:16
	RETURN 0
;乳房電極装着中はダメ
SIF TEQUIP:24
	RETURN 0
SIF TEQUIP:体位 == 5 || TEQUIP:体位 == 2 || TEQUIP:体位 == 3
	RETURN 0
;你の口使用中
SIF MASTER_POSE(0,4) && MASTER_POSE(0,4) != TARGET
	RETURN 0
IF IN_ROOM_NUMBER(CFLAG:PLAYER:現在位置) > 2
	LOCAL:1 = 0
	FOR LOCAL,1,CHARANUM
		SIF TEQUIP:LOCAL:吸乳头 && LOCAL != TARGET
			LOCAL:1 ++
		SIF LOCAL:1
			RETURN 0
	NEXT
ENDIF

RETURN 1

@COM11_TOUCH(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1

CALL TOUCH_SET(SET_FROM_B,SET_M,ARG)
