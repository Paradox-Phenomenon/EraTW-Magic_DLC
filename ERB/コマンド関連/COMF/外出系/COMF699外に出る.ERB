;-------------------------------------------------
;外出
;-------------------------------------------------
@COM699
#DIM 出口
;PRINTFORMW %STR:(((CFLAG:TARGET:自宅位置) / 10) + 6000)%に出る
FLAG:自室施錠 = 0
IF IS_GAP_GUEST(MASTER)
	IF !M_TFLAG:瞬移中
		IF !(CHK_DATENOW(CFLAG:MASTER:约会中) && FLAG:约会的对象) && M_FLAG:隙间标记/100 == GMF_HOME_MAP
			DRAWLINE
			PRINTL 出口选择: 
			PRINTLC [1] 返回私室
			PRINTL [2]返回原地
			INPUT 
			SELECTCASE RESULT
				CASE 1
					出口 = M_CFLAG:MASTER:初期记录
				CASE 2
					出口 = M_FLAG:隙间标记
			ENDSELECT
		ELSEIF M_FLAG:隙间标记/100 != GMF_HOME_MAP
			PRINTL 返回到了原地
			出口 = M_FLAG:隙间标记
		ELSE
			PRINTL 回到了原来的约会地点
			出口 = M_FLAG:隙间标记
		ENDIF
	ELSE
		出口 = M_TFLAG:瞬移中
		M_TFLAG:瞬移中 = 0
	ENDIF
ELSE
	IF CFLAG:(CFLAG:MASTER:招待):自宅位置
		出口 = CFLAG:(CFLAG:MASTER:招待):自宅位置
	ELSE
		DO
			LOCAL = RAND:9
			IF LOCAL == MAIN_MAP
				出口 = 0
			ELSE
				出口 = LOCAL * 100 + 10
			ENDIF
		LOOP !出口
	ENDIF
ENDIF


;自宅位置の三桁目を参照
CFLAG:MASTER:约会中 = 出口 / 100
;自宅位置に移動
CFLAG:MASTER:現在位置 = 出口
IF M_FLAG:隙间标记 && MAGIC_DLC
	DEBUGPRINTL 离开隙间中
	FOR LOCAL, 1, CHARANUM
        ; 检查角色是否处于在隙间内
		SIF CFLAG:LOCAL:現在位置 != OMANEKIBEYA()
			CONTINUE
		; 重置角色的初期位置与记录
		CFLAG:LOCAL:初期位置 = M_CFLAG:LOCAL:初期记录
		M_CFLAG:LOCAL:初期记录 = 0
		; 睡眠角色送回, 非睡眠角色一同出隙间
		IF CFLAG:LOCAL:睡眠
			CFLAG:LOCAL:現在位置 = CFLAG:LOCAL:初期位置
			PRINTFORMW 送%CALLNAME:LOCAL%回去了。
		ELSE
			CFLAG:LOCAL:現在位置 = 出口
			PRINTFORMW %CALLNAME:LOCAL%与你一同离开了隙间。
        ENDIF
	NEXT
	CFLAG:MASTER:神社在住 = M_CFLAG:MASTER:初期记录
	CFLAG:MASTER:初期位置 = M_CFLAG:MASTER:初期记录
ELSE
	IF !CFLAG:TARGET:睡眠
		CFLAG:TARGET:現在位置 = 出口
	ELSE
		CFLAG:TARGET:現在位置 = SUKIMA()
	ENDIF
	IF CFLAG:TARGET:神社在住
		CFLAG:TARGET:初期位置 = CFLAG:TARGET:神社在住
	ELSE
		CFLAG:TARGET:初期位置 = SUKIMA()
	ENDIF
ENDIF
;遭遇フラグを自宅位置に設定（連動してると他の角色が駆けつけてくるのは仕様）
CFLAG:(CFLAG:MASTER:招待):遭遇位置 = 出口
;部屋的污垢を保存しておく
IF YOGORE:(OMANEKIBEYA()) > 0
	TCVAR:(CFLAG:MASTER:招待):待客室的污垢 = YOGORE:(OMANEKIBEYA())
ELSE
	;０以下にした場合は識別するために１残す
	TCVAR:(CFLAG:MASTER:招待):待客室的污垢 = 1
ENDIF
;招待フラグに0を代入
CFLAG:TARGET:招待 = 0
CFLAG:MASTER:招待 = 0
M_FLAG:隙间标记 = 0
M_CFLAG:MASTER:初期记录 = 0
;MOREDATES - need to call this always in case player turns off mod while inside a house 
CALL MOREDATES_HOUSE_EXIT(出口)
;TIME += 3
RETURN 1


;-------------------------------------------------
;実行可能判定
;-------------------------------------------------
;外出
@COM_ABLE699
;一括管理
SIF GLOBAL_COMABLE(699)
	RETURN RESULT
;気力0
SIF BASE:MASTER:気力 <= 0
	RETURN 0
;終電…なくなっちゃったね……
SIF NEMUKE() >= 720 && IsRefreshed() && !M_FLAG:隙间标记
	RETURN 0
;待客室専用
SIF CFLAG:MASTER:現在位置 != OMANEKIBEYA()
	RETURN 0
;陪睡中はだめよ
SIF CFLAG:MASTER:陪睡中
	RETURN 0
;恶作剧中もだめ
SIF CFLAG:MASTER:恶作剧
	RETURN 0
;诶嘿嘿中もだめ
SIF CFLAG:MASTER:诶嘿嘿
	RETURN 0
;時間停止中
SIF FLAG:70
	RETURN 0
RETURN 1

