;家具屋
@COM625
#DIM 売値
#DIM ループ数
#DIM リザルト
;#DIM 資材保管
#DIM 削除行数
#DIM MaterialID
#DIM MaterialQTY
;#DIMS DiscountedPrice
#DIM MarketPrice
#DIM MinPrice
#DIM TradePrice
#DIM MakeTime

ループ数 = 0

;開店時間・閉店時間
IF INRANGE(TIME:0, 480, 1020) == 0
	PRINTFORMW 好像是非营业时间
	RETURN -1
ENDIF

;初回イベント
IF FLAG:最後に家具屋に訪れた日 == 0
	PRINTL 
	PRINTFORMW 写着家具屋的看板映入眼帘、进入玄关…
	PRINTFORMW 「……什么啊、你那副憨脸。啊？」
	PRINTFORMW 「啊？　是啊、这里是家具屋。什么？　没有摆出来卖的东西？」
	PRINTFORMW 「蠢货玩意。不管是衣柜还是什么别的东西、我这里都是接到订单了之后再开始干活的。现在就只是单纯地闲着摸鱼而已」
	PRINTFORMW 「……所以呢？　你有什么想要的东西吗」
	PRINTFORMW 「……啊？　看了实物之后再决定？」
	PRINTFORMW 「只是过来口嗨两句的话你还是给我回去吧……虽然想这么说、没办法。我看看啊、上一个工作的账本――」
	PRINTFORMW 　这个男人、砰、这么甩出来的账本上面、用一丝不苟的字体写着订单的事项和费用
	PRINTFORMW 　……呜哇、太贵了吧！？
	PRINTFORMW 「这是专业的实力和严谨的态度保证出来的上品、根本不可能是便宜的妖艳贱货好吧」
	PRINTFORMW 　价格上能不能再有点别的什么让步、这么问了问…
	PRINTFORMW 「你只要坐在金块上面、然后一边数数一边往这扔金条、从一数到十的话我就接受你放的屁」
	PRINTFORMW 「……话是这么说。只要能准备好『制材』的材料的话、我就把相应的原料价格给你扣掉」
	PRINTFORMW 「如果是直接拿来合适尺寸的原木、能按『一木一器』的规格做的话、我还能再扣掉处理劣质纹理的加工费」
	PRINTFORMW 　那样的话、嗯、大概价格会是……呼、这样的话至少还是付得起的水平、总算松了口气
	PRINTFORMW 「哼。嘛、准备好了再过来下订单吧。我会给你做出最好的逸品的」
	PRINTL 
	ループ数 = 1
ENDIF

SIF FLAG:作成中家具
	FLAG:家具作成残り = MAX(FLAG:家具作成残り-((DAY:0 - FLAG:最後に家具屋に訪れた日)*2),0)

$LOOP_SELECT

IF ループ数
	PRINTL 
	IF FLAG:家具作成残り
		PRINTFORMW 「让开让开、爷可是很忙的！」
	ELSE
		PRINTFORMW 「什么啊、还有什么别的事吗」
	ENDIF
ELSE
	;平常来店
	PRINTL 
	;家具発注中
	IF FLAG:家具作成残り >= 14
		PRINTFORMW 「什么嘛、是你啊。猴什么急、图纸都还没开始画呢」
	ELSEIF FLAG:家具作成残り >= 9
		PRINTFORMW 「什么嘛、是你啊。如果是问定的家具的话、还得再摸段时间」
	ELSEIF FLAG:家具作成残り >= 5
		PRINTFORMW 「什么嘛、是你啊。定的家具已经摸了不少了、放心吧」
	ELSEIF FLAG:家具作成残り >= 2
		PRINTFORMW 「喔、定的家具就快做好了！」
	ELSEIF FLAG:作成中家具 && FLAG:家具作成残り == 0
		;完成日
		IF FLAG:作成中家具 == 902
			PRINTFORMW 「哟，你来啦。嗯？你说都看着浴室的改造了，为什么还要特意回店里一趟，是吗？」
			PRINTFORMW 「还有交接送货单之类的各种事情呢。那些地方要是没办妥，留下后患可就麻烦了。」
		ELSE
			PRINTFORMW 「哟。让你久等了。这就是你订的东西。」
		ENDIF
		IF FLAG:作成中家具 == 907
			PRINTFORMW 「咿呀……嘛、毕竟我也不是做扫帚的专家、还是稍微费了点功夫的」
		ELSEIF ITEM:(FLAG:作成中家具) == 2
			PRINTFORMW 「哎呀……真是久违的满意之作啊。这简直就是匠人的无上荣光啊。」
		ELSEIF ITEM:(FLAG:作成中家具) == 1 
			PRINTFORMW 「哼，我在觉得不满意的地方都修整过了……嘛，差不多就是这样了吧。」
			PRINTFORMW 「虽然制作方的满意和使用方的满意，存在微妙的偏差，但能让两者兼顾，才是匠人啊。」
		ELSE
			PRINTFORMW 「要是还有想要的家具，就再跟我说一声啊。啊，要是对现在的家具不满意，也告诉我一声。」
		ENDIF
		PRINTL 
		SETCOLOR 0x00FF00
		PRINTFORM 获得了%ITEMNAME_TR((FLAG:作成中家具))%
		IF ITEM:(FLAG:作成中家具) == 0
			PRINTFORMW ！
		ELSE
			PRINTFORMW 的改进版本、用起来更舒服了！
		ENDIF
		RESETCOLOR
		PRINTL 
		ITEM:(FLAG:作成中家具) ++
		FLAG:作成中家具 = 0
	ELSE
		IF DAY:0 - FLAG:最後に家具屋に訪れた日 > 28
			PRINTFORMW 「什么嘛、是你啊。终于打算来下单了？」
		ELSEIF FLAG:最後に家具屋に訪れた日 == DAY:0
			PRINTFORMW 「什么嘛。没有搭理你的功………啊、我是很闲怎么了、有意见吗」
		ELSE
			PRINTFORMW 「什么嘛、是你啊。有想要的家具吗？」
		ENDIF
	ENDIF
ENDIF

ループ数 ++
FLAG:最後に家具屋に訪れた日 = DAY:0

PRINTFORM 　　所持金: %TOSTR(MONEY,"#,###")%
IF FLAG:作成中家具
	PRINTFORML 　　%ITEMNAME_TR((FLAG:作成中家具))%正在制作中　完工：还有{FLAG:家具作成残り}日
ELSE
	PRINTL 
ENDIF
DRAWLINE

CALL ASK_M("想要制作家具", !FLAG:作成中家具, "确认交易内容", 1, "从店里离开", 2)

SELECTCASE RESULT
	;家具を作ってほしい
	CASE 0
		PRINTFORMW 「如果是说你需要的家具的话……嘛、大概是这样？」

		$INPUT_LOOP01
		;列表の呼び出し
		削除行数 = 0
		FOR LOCAL, 902, 908
			削除行数 ++
			IF ITEM:LOCAL == 3
				PRINTPLAINFORM 　[{LOCAL}]
				LOCALS = %ITEMNAME_TR(LOCAL)%Lv{ITEM:LOCAL}
				PRINTPLAINFORM %LOCALS, 21, LEFT%
			ELSE
				PRINTFORM 　
				PRINTFORM [{LOCAL}]
				IF ITEM:LOCAL == 0
					;未所持
					PRINTFORM %ITEMNAME_TR(LOCAL), 21, LEFT%
				ELSE
					;所持
					LOCALS = %ITEMNAME_TR(LOCAL)%Lv{ITEM:LOCAL}
					PRINTFORM %LOCALS, 21, LEFT%
				ENDIF
			ENDIF
			CALL FURNITURE_EXPLANATION(LOCAL)
		NEXT
		PRINTFORML 　[999]果然还是算了
		削除行数 ++
		
		INPUT
		
		リザルト = RESULT
		SELECTCASE リザルト
			CASE 902 TO 907
				;Lv3の時は選択できない
				IF ITEM:リザルト == 3
					CLEARLINE 削除行数 + 1
					GOTO INPUT_LOOP01
				ENDIF
				MaterialID = FURNITURE(リザルト, "資材番号", ITEM:リザルト)
				;原木信息
				IF ITEM:原木 > 0
					SIF !FLAG:原木種類
						FLAG:原木種類 = 1
				ELSE
					FLAG:原木種類 = 0
				ENDIF
				CALL WoodData(MaterialID)
				MaterialQTY = FURNITURE(リザルト, "軽減上限", ITEM:リザルト)
				MarketPrice = FURNITURE(リザルト, "市场价", ITEM:リザルト)
				MinPrice = FURNITURE(リザルト, "最低額", ITEM:リザルト)
				TradePrice = FURNITURE(リザルト, "", ITEM:リザルト)
				MakeTime = FURNITURE(リザルト, "期間", ITEM:リザルト)

				;注文家具の請求を作成
				DRAWLINE
				PRINTFORML %ITEMNAME_TR(リザルト)%的\@ ITEM:リザルト == 0? 订购# 改造\@
				;所持製材量での値引きの表記
				;Lv1→2の時は半額
				[SKIPSTART]
				IF ITEM:リザルト == 1
					PRINTFORM 　费用　　　　：%金額表示((ITEMPRICE:リザルト / 2))% → 
				ELSE
					PRINTFORM 　费用　　　　：%金額表示(ITEMPRICE:リザルト)%  → 
				ENDIF
				DiscountedPrice = %金額表示(FURNITURE(リザルト, 0, ITEM:リザルト))%
				[SKIPEND]
				
				PRINTFORM 　费用　　　　：%金額表示(MarketPrice)% → 
				IF TradePrice == MinPrice
					SETCOLOR C_RED
				;ELSEIF ITEM:リザルト == 1 && FURNITURE(リザルト, 0, ITEM:リザルト) < ITEMPRICE:リザルト / 2
				;	SETCOLOR C_YELLOW
				ELSEIF TradePrice < MarketPrice
					SETCOLOR C_YELLOW
				ENDIF
				PRINTFORML %金額表示(TradePrice)% \@ TradePrice == MinPrice ? 最低价！# \@
				RESETCOLOR

				;価格軽減に必要な資材量と現在所持量の比較
				PRINTFORML 　价格补贴条件：提供所需的%LOGName:MaterialID%木料
				PRINTFORM  现有/所需木料：
				SIF LOG_SALES:MaterialID >= MaterialQTY
					SETCOLOR C_RED
				PRINTFORML （{LOG_SALES:MaterialID}／{MaterialQTY}）
				RESETCOLOR
				;一木一器
				PRINTFORML 　一木一器条件：\@GROUPMATCH(リザルト, 907) ? 该家具无法一木一器 # 提供所需的整根%LOGName:MaterialID%原木\@
				PRINTFORM  现有/所需木料：
				SIF ITEM:原木 && ((FLAG:原木種類)%100 == MaterialID) && (LOG_LUMBERING(FLAG:原木種類) >= MaterialQTY-1)
					SETCOLOR C_RED
				IF ITEM:原木
					CALL WoodData(FLAG:原木種類%100)
					PRINTFORM （%WOOD_NAME(FLAG:原木種類)%
				ELSE
					PRINTFORM （无原木
				ENDIF
				CALL WoodData(MaterialID)
				PRINTFORML ／%WOOD_NAME((MaterialQTY-1-1)/2*100+MaterialID)%）
				CALL WoodData(FLAG:原木種類%100)
				RESETCOLOR
			CASE 999
				PRINTL 
				GOTO LOOP_SELECT
			CASEELSE
				CLEARLINE 1
				GOTO INPUT_LOOP01
		ENDSELECT
		PRINTL 
		IF ITEM:リザルト == 0
			CALL ASK_M("做这个家具", MONEY >= TradePrice, "算了", 1)
		ELSE
			CALL ASK_M("改造这个家具", MONEY >= TradePrice && ITEM:リザルト <= 2, "算了", 1)
		ENDIF
		
		IF RESULT
			CLEARLINE 12 + 削除行数
			GOTO INPUT_LOOP01
		ELSE
			;費用の支支付
			PRINTFORML 所持金: %金額表示(MONEY)% → %金額表示(MONEY - TradePrice)%
			CALL PAY_MONEY_YEN(TradePrice, 2)

			;製材等の消費  軽減上限量以上に持っていれば上限量分減らし、上限に達していなければ全部消費
			;現在的製材の量を退避してから計算
			;資材保管 = LOG_SALES:FURNITURE(リザルト, "資材番号")
			IF ITEM:原木 && ((FLAG:原木種類)%100 == MaterialID) && (LOG_LUMBERING(FLAG:原木種類) >= MaterialQTY-1)
				ITEM:原木 = 0
				FLAG:原木種類 = 0
				PRINTFORMW 交出了%LOGName:MaterialID%的原木、以一木一器的形式制作了。
			ELSEIF LOG_SALES:MaterialID
				PRINTFORM %LOGName:MaterialID%的木料：{LOG_SALES:MaterialID} → 
				LOG_SALES:MaterialID = MAX(0, LOG_SALES:MaterialID - MaterialQTY)
				PRINTFORMW {LOG_SALES:MaterialID}
			ENDIF
			PRINTL 
			IF ITEM:リザルト
				PRINTFORMW 「什么嘛、对之前的家具不满吗？　那正好。{MakeTime}天后再到店里来、会让你大吃一惊的」
			ELSE
				PRINTFORMW 「好、那么契约成立了。完工是在{MakeTime}天后、那时候再到店里来」
			ENDIF
			FLAG:家具作成残り = MakeTime
			FLAG:作成中家具 = リザルト
		ENDIF
	;取引内容を確認する
	CASE 1
		PRINTFORMW 「啊？　想确认一下？」
		PRINTFORMW 「这里是家具屋、除了做家具还能干什么」
		PRINTFORMW 「准备好材料的制材的话、会给你点优惠」
		PRINTFORMW 「虽然是废话、下完订单之后把家具需要一定的时间」
		PRINTFORMW 「顺便一提、在制作期间因为要专心、所以不接受其他的订单」
		PRINTFORMW 「啊、如果对做好的家具不满的话、直接给我说。虽然会收点钱、但是会把它改进得更好的」
		PRINTL 
	CASE 2
		PRINTFORMW 「没事的话就拜拜了您呐」
		PRINTL 
		TIME += ループ数 * 5
		RETURN -1

ENDSELECT
GOTO LOOP_SELECT

;-------------------------------------------------
;実行可能判定
;-------------------------------------------------
;家具屋
@COM_ABLE625
#LOCALSIZE 1
#LOCALSSIZE 1
RETURN COM_ABLEF625()

@COM_ABLEF625
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
;一括管理
SIF GLOBAL_COMABLE(625)
	RETURNF RESULT
;睡眠中 bugfix 我觉得不是这样的
;SIF CFLAG:睡眠
;	RETURNF 0
;時間停止中
SIF FLAG:70
	RETURNF 0
RETURNF GROUPMATCH(CFLAG:MASTER:現在位置,GET_MAP_REPLACEMENT(214),GET_MAP_REPLACEMENT(1106))


;-------------------------------------------------
;注文できる家具列表に付随する説明文
;ARG 家具の道具番号
;-------------------------------------------------
@FURNITURE_EXPLANATION(ARG)

IF ITEM:ARG
	PRINTFORM 设置场所：
	SELECTCASE ARG
		CASE 902
			LOCALS = %NAME_FROM_PLACE(NEAR_BATH(1))%
		CASE 904, 907
			LOCALS = %CALLNAME:MASTER%带在身上
		CASEELSE
			LOCALS = %CALLNAME:MASTER%的私室
	ENDSELECT
	PRINTFORMD %LOCALS, 26, LEFT%
ELSE
	PRINTFORM 　　　　　　　　　　　　　　　　　　
ENDIF

SIF ITEM:ARG == 0
	SETCOLOR C_GRAY

SELECTCASE ARG
	CASE 902
		PRINTFORM …在设置的场所入浴的话可以增加体力・气力恢复
	CASE 903
		PRINTFORM …增加睡眠时的体力・气力・精力恢复
	CASE 904
		PRINTFORM …能做出更好的料理
	CASE 905
		PRINTFORM …提高在私室里学习或者调合的效率
	CASE 906
		PRINTFORM …增加私室里休憩的体力・气力・精力恢复
	CASE 907
		PRINTFORM …提升扫除的效率
	CASEELSE
		PRINT 
ENDSELECT
IF ITEM:ARG == 3
	SETCOLOR C_ORANGE
	PRINTFORML ▲▲
ELSEIF ITEM:ARG == 2
	SETCOLOR C_YELLOW
	PRINTFORML ▲
ELSE
	PRINTL 
ENDIF
RESETCOLOR

;-------------------------------------------------
;家具注文で使用する各種数値をまとめた関数
;現状は902～907
;F_ID …家具の道具番号
;ARGS 0= 補正価格(省略時)  1= 資材による軽減上限数
;      2= 家具に対応する資材番号  3= 軽減最低額  
;      4= 発注後の作成期間   を返す
;EnhanceTime 0= 初発注(省略時)  1= 強化１  2= 強化２
;        主にITEM:家具番号を入れて利用
;-------------------------------------------------
@FURNITURE(F_ID, ARGS, EnhanceTime = 0)
#FUNCTION
#DIM F_ID
#DIM EnhanceTime
;#DIM DiscountRate
;#DIM MaxDiscount
#DIM 資材番号
#DIM 軽減上限
#DIM 最低額
;#DIM 補正価格
#DIM 期間

;手持製材との調整価格を表記
;在新伐木系统调整了原木制材量后，这边家具也应该做点对应调整，一般原木家具比较讲求一木一器啦，所以其实完全可以和制材量相关
;此外，现在家具购买价格会和木材市场价挂钩，ITEM价格现在只作为参考了。加工费应该是大头，这样才能体现师傅的匠人精神啊
SELECTCASE F_ID
	;桧木浴室
	CASE 902
		資材番号 = 2;ヒノキ
		軽減上限 = 10
		最低額 = 600000
		期間 = 15
	;桐木床
	CASE 903
		資材番号 = 8;キリ
		軽減上限 = 6
		最低額 = 300000
		期間 = 10
	;银杏案板
	CASE 904
		資材番号 = 6;イチョウ
		軽減上限 = 2
		最低額 = 50000
		期間 = 5
	;榉木桌椅
	CASE 905
		資材番号 = 7;ケヤキ
		軽減上限 = 6
		最低額 = 300000
		期間 = 10
	;栎木沙发
	CASE 906
		資材番号 = 9;ナラ
		軽減上限 = 6
		最低額 = 300000
		期間 = 10
	;特制竹箒
	CASE 907
		資材番号 = 12;竹
		軽減上限 = 30
		最低額 = 50000
		期間 = 10
ENDSELECT

;Lv1→Lv2時は半分  Lv2→Lv3時は最初と同じで
;MaxDiscount = ITEMPRICE:F_ID - 最低額
IF EnhanceTime == 1
	軽減上限 /= 2
	最低額 /= 2
	期間 /= 2
	;MaxDiscount /= 2
ENDIF

SIF ARGS == "資材番号"
	RETURNF 資材番号
SIF ARGS == "軽減上限"
	RETURNF 軽減上限
SIF ARGS == "最低額"
	RETURNF 最低額
SIF ARGS == "期間"
	RETURNF 期間
SIF ARGS == "市场价"
	RETURNF 最低額 + 軽減上限 * PLANK_VALUE(資材番号, 0, 1, 0) + (GROUPMATCH(F_ID, 907) ? 0 # 軽減上限 * 10000)
	
[SKIPSTART]
DiscountRate = 100 * MIN(LOG_SALES:資材番号, 軽減上限) / 軽減上限
IF EnhanceTime == 1
	補正価格 = (ITEMPRICE:F_ID / 2) - MaxDiscount * DiscountRate / 100
ELSE
	補正価格 = ITEMPRICE:F_ID - MaxDiscount * DiscountRate / 100
ENDIF
[SKIPEND]
;最终价格 = 加工费 + 木料费 + 制材加工费
SIF ITEM:原木 && (FLAG:原木種類%100 == 資材番号) && (LOG_LUMBERING(FLAG:原木種類) >= 軽減上限-1)
	RETURNF 最低額
RETURNF 最低額 + MAX(軽減上限 - LOG_SALES:資材番号, 0) * PLANK_VALUE(資材番号, 0, 1, 0) + (GROUPMATCH(F_ID, 907) ? 0 # 軽減上限 * 10000)
