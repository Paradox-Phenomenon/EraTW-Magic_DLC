					IF ABL:TARGET:精液中毒 >= 5
						PRINTFORMW %CALLNAME:TARGET%像是舍不得浪费，用手指抹起溢出的精液，一口含住舔干净……
					ELSEIF ABL:TARGET:精液中毒 >= 3 && TALENT:TARGET:恋慕
						PRINTFORMW %CALLNAME:TARGET%一脸珍惜地，用指尖拭起溢出的精液，温柔地舔舐干净……
					ENDIF
				ENDIF
			ELSE
				IF AFTERGLOW_LEVEL(BASE:TARGET:Ｖ絶頂余韻)
					SELECTCASE ABL:TARGET:Ｖ感覚
						CASE 0,1,2,3
							PRINTFORMW %CALLNAME:TARGET%还沉浸在高潮的余韵中……
						CASEELSE
							IF CFLAG:TARGET:溜まってる度 / 10 < 20
								PRINTFORMW 被尽情疼爱的%CALLNAME:TARGET%，正沉醉在雌性的欢愉里……
							ELSEIF CFLAG:TARGET:溜まってる度 / 10 >= 20
								SELECTCASE RAND:3
									CASE 0
										PRINTFORMW %CALLNAME:TARGET%食髓知味的蜜穴，仿佛还在说『还没够呢』，想要紧紧吸住抽出的肉棒……
									CASE 1
										PRINTFORMW %CALLNAME:TARGET%的雌穴像是意犹未尽般，淌着爱液，『噗叽噗叽』地抽搐着……
									CASE 2
										PRINTFORMW 还远远不够满足的%CALLNAME:TARGET%，用眼神拼命恳求着『还要更多』……
								ENDSELECT
							ENDIF
					ENDSELECT
				ELSE
					SELECTCASE ABL:TARGET:Ｖ感覚
						CASE 0,1
							IF TALENT:TARGET:恋慕
								PRINTFORMW 不习惯的%CALLNAME:TARGET%，不安地抬头看过来……
							ELSE
								IF TALENT:MASTER:形状 == 1 || TALENT:MASTER:形状 == 2
									PRINTFORMW %CALLNAME:TARGET%一脸疑惑地望过来……
								ELSE
									PRINTFORMW %CALLNAME:TARGET%露出松了一口气的表情……
								ENDIF
							ENDIF
						CASE 2,3
							IF TALENT:TARGET:恋慕
								PRINTFORMW 交合被中断，%CALLNAME:TARGET%不安地望过来……
							ELSE
								PRINTFORMW 在高潮前被打断的%CALLNAME:TARGET%，一脸不满……
							ENDIF
						CASEELSE
							PRINTFORML 媚肉像是不舍离别般，紧紧缠住火热的雄枪
							PRINTFORMW 在高潮前被吊着胃口的%CALLNAME:TARGET%，用近乎哀求的眼神望过来……
				ENDSELECT
				ENDIF
			ENDIF
		ENDIF
	ENDIF
ENDIF
