		ENDIF
	ELSE
		COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "EJACULATED_INSIDE/"
		IF STRCOUNT(COM26_MESSAGE_FLAG, "ANAL")
			TCVAR:MASTER:射精箇所 = 2
			TCVAR:MASTER:射精快感強度 = 750 + ABL:アナル * 80
			TCVAR:TARGET:射精快感強度 = 500 + (100 * ABL:TARGET:Ａ感覚)
			SOURCE:TARGET:快Ａ += 150
		ELSE
			TCVAR:MASTER:射精箇所 = 1
			TCVAR:MASTER:射精快感強度 = 750 + ABL:膣 * 80
			TCVAR:TARGET:射精快感強度 = 500 + (100 * ABL:TARGET:Ｖ感覚)
			SOURCE:TARGET:快Ｖ += 150
		ENDIF
		DOWNBASE:MASTER:体力 += 50
		DOWNBASE:MASTER:気力 += 50
	ENDIF
;抜く
ELSE
	IF TEQUIP:MASTER:コンドーム
		COM26_MESSAGE_FLAG '= "CONDOM_ON/"
		IF TCVAR:MASTER:ゴム使用済み
			SIF TFLAG:ゴム内
				COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "CONDOM_LOAD/"
			SIF TFLAG:ゴム内 >= 100
				COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "CONDOM_LARGE_LOAD/"
			TEQUIP:MASTER:コンドーム = 0
			TFLAG:ゴム内 = 0
			TCVAR:MASTER:ゴム使用済み = 0
			IF ITEM:コンドーム
				ITEM:コンドーム --
				TEQUIP:MASTER:コンドーム = 1
				PRINTFORML 换上了新的避孕套　剩余{ITEM:コンドーム}枚
			ELSE
				PRINTFORML 取下了用过的避孕套（避孕套已用完）
			ENDIF
			TFLAG:SELECTCOMの分岐 = 99
		ENDIF
	ENDIF
ENDIF

TIME += 1
RETURN 1

@COM26_TOUCH(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
COM26_体位_RECORD = TEQUIP:CHARA:体位
SIF TEQUIP:CHARA:Ｖセックス == PLAYER
	COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "VAGINAL/"
SIF TEQUIP:CHARA:Ａセックス == PLAYER
	COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "ANAL/"
;口上側で指定した場合
;強制失敗
IF TFLAG:192 == -1
	TFLAG:SELECTCOMの分岐 = -1
	RETURN 0
;コマンド終了
ELSEIF TFLAG:192 == -2
	TFLAG:102 = 0
	TFLAG:SELECTCOMの分岐 = -99
	RETURN 0
;気持ちよすぎて膣内で暴発して失敗
ELSEIF !TEQUIP:MASTER:コンドーム && BASE:MASTER:射精 >= EJAC_ENDURANCE_LIMIT && TFLAG:192 == 0
	;暴発して失敗　ABL:TARGET:膣・ABL:TARGET:アナルが4以下だと67％で失敗、4以上だと100％で失敗
	IF STRCOUNT(COM26_MESSAGE_FLAG, "VAGINAL")
		IF ABL:膣 >= 4
			TFLAG:SELECTCOMの分岐 = -2
			RETURN 0
		ELSE
			IF RAND:3 <= 1
				TFLAG:SELECTCOMの分岐 = -2
				RETURN 0
			ENDIF
		ENDIF
	ELSEIF STRCOUNT(COM26_MESSAGE_FLAG, "ANAL")
		IF ABL:アナル >= 4
			TFLAG:SELECTCOMの分岐 = -2
			RETURN 0
		ELSE
			IF RAND:3 <= 1
				TFLAG:SELECTCOMの分岐 = -2
				RETURN 0
			ENDIF
		ENDIF
	ENDIF
;TARGETが外出しを阻止（だいしゅきホールド）して失敗
ELSEIF TALENT:妊娠願望 || ABL:TARGET:膣射中毒 > 3 && TFLAG:192 == 0
	;充填率（子宮内の精液量）が50以下だと外出し阻止。それ以上であれば満足して阻止しない
	IF TALENT:妊娠願望 && 充填率(TARGET,1, 1) <= 50
		IF RAND:2
			TFLAG:SELECTCOMの分岐 = -1
			RETURN 0
		ENDIF
	;阻止率は50％中出しさせた後に後悔する描写が追加
	ELSE
		IF RAND:2
			TFLAG:SELECTCOMの分岐 = -1
			RETURN 0
		ENDIF
	ENDIF
ENDIF

IF TEQUIP:CHARA:Ｖセックス == PLAYER
	IF EX:CHARA:精液残量
		COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "VAGINAL_LOAD_LEAK/"
		SIF EX:CHARA:精液残量 >= 100
			COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "VAGINAL_LARGE_LOAD_LEAK/"
	ENDIF
	CALL TOUCH_SET(SET_FROM_V,0,CHARA)
ENDIF
IF TEQUIP:CHARA:Ａセックス == PLAYER
	IF EX:CHARA:アナル精液残量
		COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "ANAL_LOAD_LEAK/"
		SIF EX:CHARA:アナル精液残量 >= 100
			COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "ANAL_LARGE_LOAD_LEAK/"
	ENDIF
	CALL TOUCH_SET(SET_FROM_A,0,CHARA)
ENDIF

