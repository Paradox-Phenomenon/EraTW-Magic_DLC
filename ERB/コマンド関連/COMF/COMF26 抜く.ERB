@COM26
#LOCALSIZE 1
#LOCALSSIZE 1
;行為者
TCVAR:116 = PLAYER

IF TCVAR:PLAYER:イきそう
	;奉仕快楽フラグ
	TCVAR:MASTER:奉仕フラグ = 1

	CSTR:MASTER:射精判定用 += @"{TARGET}/"
	IF INRANGE(COM_ALTER_26, 1, 10)
		RESULT = COM_ALTER_26 - 1
	ELSEIF COM_ALTER_26 == 11
		; 随机部位
		RESULT = RAND:10
	ELSE
		PRINTFORML 要射在%CALLNAME:TARGET%身上哪里呢？
		CALL ASK_M("正面", 1, "背上", 1, "脸蛋", 1, "舌头", 1, "胸部", 1, "大腿", 1, "脚丫", 1, "手掌", 1, "腋下", 1, "蜜唇", 1)
	ENDIF
	SELECTCASE RESULT
		CASE 1
			STAIN:Ａ |= 4
		CASE 0,4
			STAIN:Ｂ |= 4
		CASE 2,3
			STAIN:口 |= 4
			SIF RESULT == 3
				EXP:精飲経験 ++
		CASE 5,9
			STAIN:Ｖ |= 4
	ENDSELECT
	SETBIT TCVAR:MASTER:射精体表箇所, RESULT
	TCVAR:MASTER:射精箇所 = 8
	TCVAR:MASTER:童貞喪失 = 1
	TCVAR:MASTER:射精快感強度 = 300

	CSTR:TARGET:射精判定用 += @"{PLAYER}/"
	;強度
	TCVAR:TARGET:射精快感強度 = 300
	DOWNBASE:MASTER:体力 += 30
	DOWNBASE:MASTER:気力 += 30
ENDIF

;have to record some states here for the MESSAGE_COM since TOUCH_SUCCESSION is called way before messages
;temporary solution until we add universal trackers, TODO
;also can I just say that multi-penis is a psychotic concept to entertain
IF TEQUIP:MASTER:コンドーム
	COM26_MESSAGE_FLAG '= "CONDOM_ON/"
	IF TFLAG:ゴム内 >= 100
		COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "CONDOM_BIGLOAD/"
	ELSEIF TFLAG:ゴム内
		COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "CONDOM_SOMELOAD/"
	ENDIF
	;removes condom to ejaculate outside
	IF TCVAR:MASTER:イきそう
		TEQUIP:MASTER:コンドーム = 0
		TFLAG:ゴム内 = 0
		COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "CONDOM_REMOVED/"
	ENDIF
ENDIF

TIME += 1
RETURN 1

@COM26_TOUCH(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
IF TEQUIP:CHARA:Ｖセックス == PLAYER
	COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "VAGINAL/"
	IF EX:CHARA:精液残量 > 0
		COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "EJACULATED/"
		IF EX:CHARA:精液残量 >= 100
			COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "LARGE_LOAD/"
		ENDIF
	ENDIF
	CALL CAVITY_FLUID_SPILL(CHARA, "PULLOUT")
	CALL TOUCH_SET(SET_FROM_V,0,CHARA)
ENDIF
IF TEQUIP:CHARA:Ａセックス == PLAYER
	COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "ANAL/"
	IF EX:CHARA:アナル精液残量 > 0
		COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "EJACULATED/"
		IF EX:CHARA:アナル精液残量 >= 100
			COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "LARGE_LOAD/"
		ENDIF
	ENDIF
	CALL CAVITY_FLUID_SPILL(CHARA, "PULLOUT")
	CALL TOUCH_SET(SET_FROM_A,0,CHARA)
ENDIF

