	;	CASE 5,9
	;		STAIN:Ｖ |= 4
	;ENDSELECT
	;SETBIT TCVAR:MASTER:射精体表箇所, RESULT

	;外出し成功
	;TCVAR:2 射精箇所フラグ（-1=コンドーム 1=膣内 2=アナル 3=手淫 4=口淫 5=パイズリ 6=素股 7=足コキ 8=体表 9=アナル奉仕 10=道具 11=触手 12=Ａ責め 13=Ｖ責め）
	IF TFLAG:SELECTCOMの分岐 >= 0
		TCVAR:MASTER:射精箇所 = 8
		IF STRCOUNT(COM26_MESSAGE_FLAG, "ANAL")
			TCVAR:MASTER:射精快感強度 = 350 + ABL:アナル * 50
			SOURCE:TARGET:快Ａ += 60
		ELSE
			TCVAR:MASTER:射精快感強度 = 350 + ABL:膣 * 50
			SOURCE:TARGET:快Ｖ += 60
		ENDIF
		DOWNBASE:MASTER:体力 += 10
		DOWNBASE:MASTER:気力 += 10
		IF TEQUIP:MASTER:コンドーム
			TEQUIP:MASTER:コンドーム = 0
			TFLAG:ゴム内 = 0
			COM26_MESSAGE_FLAG '= COM26_MESSAGE_FLAG + "CONDOM_ON/"
