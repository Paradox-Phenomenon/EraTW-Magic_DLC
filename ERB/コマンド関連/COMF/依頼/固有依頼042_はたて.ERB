@F固有依頼42(ARG, O_DATA, V_NAME)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE ARG % 1000
;ID101：美食报告
CASE 101
	SELECTCASE O_DATA
	CASE "依頼名"
		RETURNF "美食报告"
	CASE "依頼内容表示"
		RETURNF "总结人里料理的感想"
	CASE "依頼報酬表示"
		RETURNF @"%金額表示(3000)%"
	CASE "依頼実行指令名"
		RETURNF "进行美食报道"
		
	CASE "依頼内容"
		;小料理屋(218)が対象
		RETURNF @"{MAKE_IRAI_DATA(218, "伝令（場所）")}"
	CASE "依頼サブ"
	CASE "依頼期限"
	;発生時ではなく受託時に確定します
		RETURNF @"{7}"
	CASE "依頼発生率"
	;これは他の固有依頼との相対確率なんで10％ではありません
		RETURNF @"{10}"
	CASE "依頼発生条件"
	SIF CFLAG:[[はたて]]:1005 >= 1 && ABL:MASTER:教養 >= 1
		RETURNF @"{1}"
	CASE "依頼受託可能条件"
	;受託可能は@COM_ABLE366も確認のこと
	;ここを参照するのは依頼人をTARGETにしてる時なので素通しでよし
		RETURNF @"{1}"
	CASE "依頼実行可能条件"
	;実行可能は@COM_ABLE367も確認のこと
		IF FLAG:70
		ELSE
			RETURNF @"{1}"
		ENDIF
	;成功/失敗処理はCARRYOUTで直接書く
	;SOURCEやITEM入手など、内容が複雑なので
	CASE "依頼消滅条件"
	;30％で消失
		SIF RAND:100 < 30
			RETURNF @"{1}"
	ENDSELECT
ENDSELECT



;固有依頼の設定用
;この関数は実行/成功/失敗時の
;報酬とペナルティと地の文のみを扱います
;各角色のメッセージは別所にて
@IRAI_固有42(CHARA, IRAI_ID, SCENE)
#DIM  CHARA
#DIM  IRAI_ID
#DIMS SCENE
#DIM  CLIENT_ID
CLIENT_ID = IRAI_ID_TO_CLIENT(IRAI_ID)
SELECTCASE STR_DATA_IRAI(IRAI_ID, "依頼名", CLIENT_ID)
	
CASE "美食报告"
	SELECTCASE SCENE
	CASE "依頼条件表示"
	;何か専用の表示情報を設けたい時用
	;受託済みの依頼表示で使用されます
	;
	;PRINT系だけでSOURCEとかは入れちゃダメ、WAITも無しで
	;ここ以外の表示項目は
	;PRINTFORML 　　　　　：
	;となっているのでスペースを揃えたほうが見栄えが良いです
	
	CASE "依頼実行時"
	;このCASEに限り、RESULTが意味を持ちます
	;依頼実行時のRESULTにはIRAI_CONST_RESULT()を使用してください
	;可能な引数は"中止", "実行して成功", "実行して失敗", "実行して未解決"です
	;独自処理を仕込みたい時は"実行して未解決"で先延ばしするなりしてください
		DOWNBASE:MASTER:気力 += 50
		PRINTFORMW %CALLNAME:MASTER%走进小餐馆，向店主打过招呼后拍下了料理的照片，一边吃一边整理着感想……
		TIME += 120
		TCVAR:MASTER:空腹時刻 = 1440 * DAY + TIME + 120
		IF (ABL:MASTER:話術技能 + ABL:MASTER:教養 + ABL:MASTER:料理技能 + RAND:5) >= RAND:12
			PRINTFORML 照片拍得不错。文章也写得令人食欲大增。这样果应该会满意吧
			PRINTW 
			RETURN IRAI_CONST_RESULT("実行して成功")
		ELSEIF INRANGE((ABL:MASTER:話術技能 + ABL:MASTER:教養 + ABL:MASTER:料理技能 + RAND:5), 6, 10)
			SELECTCASE RAND:2
			CASE 0
				PRINTFORML 文章还行，但是照片拍得不太诱人……不想妥协
				PRINTW 
			CASE 1
				PRINTFORML 觉得照片拍得不错，但文章感觉没能充分传达出料理的魅力……
				PRINTW 
			ENDSELECT
			RETURN IRAI_CONST_RESULT("実行して未解決")
		ELSE
			PRINTFORML 照片模糊不清，文章也写得不知所云……这不行啊
			PRINTFORML 没办法，只能用这个去报告了
			PRINTW 
			RETURN IRAI_CONST_RESULT("実行して失敗")
		ENDIF
	CASE "依頼成功時"
	;成功報告時の報酬など
		CALL KIGEN_CHANGE(TARGET, 100, 1)
		SOURCE:TARGET:歓楽 = 1000
		SOURCE:TARGET:征服 = 500
		SOURCE:TARGET:達成 = 500
		;システムメッセージつき好感度変化
		;最後の引数だけ好感度が変化
		CALL CHANGE_CFLAG(2, TARGET, 40)
		;システムメッセージつき信赖度変化
		;最後の引数だけ信赖度が変化
		CALL CHANGE_CFLAG(4, TARGET, 25)
		CALL GET_MONEY_YEN(3000, 2)
	CASE "依頼失敗時"
	;失敗報告時の処理
		;システムメッセージつき好感度変化
		;最後の引数だけ好感度が変化
		CALL CHANGE_CFLAG(2, TARGET, -20)
		;システムメッセージつき信赖度変化
		;最後の引数だけ信赖度が変化
		CALL CHANGE_CFLAG(4, TARGET, -10)
	ENDSELECT
ENDSELECT
