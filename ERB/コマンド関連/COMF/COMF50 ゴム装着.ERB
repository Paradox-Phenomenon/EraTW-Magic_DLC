;-------------------------------------------------
;避孕套装备
;道具使用指令、レベル2
;-------------------------------------------------
@COM50_DISPLAY
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
SIF TCVAR:PLAYER:ゴム使用済み
	TEMP_COM_DISPLAY_COLOR = C_ORGASM
SIF TEQUIP:PLAYER:コンドーム
	RETURNF "コンドームを外す"

@COM50
;着脱の処理
TFLAG:102 = 0
IF !TEQUIP:PLAYER:避孕套
	ITEM:45 -= 1
	TEQUIP:PLAYER:避孕套 = 1
	PRINTL 戴上了避孕套
	PRINTFORMW 剩余{ITEM:45}枚
ELSE
	TEQUIP:PLAYER:避孕套 = 0
	TFLAG:ゴム内 = 0
	TCVAR:PLAYER:ゴム使用済み = 0
	PRINTW 取下了避孕套
ENDIF
;-------------------------------------------------
;COM別FLAGの設定
;-------------------------------------------------
;行為者
TCVAR:116 = PLAYER

RETURN 0

;-------------------------------------------------
;実行判定
;-------------------------------------------------
@COM_ABLE50
#LOCALSIZE 1
#LOCALSSIZE 1
;避孕套装备
SIF !TFLAG:100
	RETURN 0
;一括管理
SIF GLOBAL_COMABLE(50)
	RETURN RESULT
;解除是つでも可能
SIF TEQUIP:PLAYER:避孕套
	RETURN 1
SIF !ITEM:45
	RETURN 0
SIF !HAS_PENIS(PLAYER)
	RETURN 0
;TODO TOUCH rework, doesn't work in sex involving multiple people, breaks when targeting someone else
SIF TEQUIP:Ｖセックス == PLAYER && TEQUIP:Ａセックス == PLAYER
	RETURN 0
RETURN 1

@COM50_TAGS
#FUNCTION
LOCAL = 0
SETBIT LOCAL, BIT_USED_CONDOM_ALLOWED
RETURNF LOCAL