;-------------------------------------------------
;オナニー
;日常系コマンド、レベル1
;-------------------------------------------------
@COM451
#DIM C_ID
#DIM AMT
IF TARGET
	PRINTFORMW オナニーの時はね、誰にも邪魔されず 自由でなんというか救われてなきゃあダメなんだ 独りで静かで豊かで……
	RETURN -1
ENDIF
PRINTFORML 誰のことを思い浮かべますか？
DRAWLINE
FOR LOCAL,1,CHARANUM
	IF !IS_NAMED(LOCAL) || !CFLAG:LOCAL:面識
		CONTINUE
	ENDIF
	PRINTFORMLC [{LOCAL, 3}] %CALLNAME:LOCAL%
NEXT
PRINTL
DRAWLINE
PRINTL [999] 誰も思い浮かべない [1000] やめる
INPUT
C_ID = RESULT
SELECTCASE C_ID
	CASE 1 TO CHARANUM
		CALL PRINT_FACE, C_ID, "発情", "裸", "_1"
		PRINTFORML %CALLNAME:MASTER%は%CALLNAME:C_ID%のことを考えながら性欲を処理した
	CASE 999
		PRINTFORML %CALLNAME:MASTER%は%TEXTR("天体の運行/山川草木/生老病死")%に思いを馳せながら性欲を処理した
		IF FLAG:1058 >= 4
			PRINTW ………
			PRINTW 段々ムラムラしてきたので、とりあえず頭に浮かんだにとりをオカズにする事に決めた…
			C_ID = 51
		ENDIF
	CASEELSE
		RETURN -1
ENDSELECT

AMT = 50 + RAND:51

;オナホ構造改革
IF FLAG:1058 == 1
	PRINTW 改造したオナホールで自家発電に勤しむ…
	AMT *= 2
ENDIF

;魔法のオナホ
IF FLAG:1058 == 4
	PRINTL 魔改造したオナホールで自家発電に勤しむ…
	PRINTFORMW 魔法のオナホは%CALLNAME:MASTER%が思い描く%CALLNAME:C_ID%の膣内を模るかのように変化した！
	AMT *= 4
ENDIF

;奇跡のオナホ
IF FLAG:1058 == 5
	PRINTL 奇跡を呼ぶオナホールで自家発電に勤しむ…
	PRINTFORMW 奇跡のオナホは%CALLNAME:MASTER%が思い描く%CALLNAME:C_ID%の膣内とリンクした！
	CALL PRINT_FACE, C_ID, "発情", "裸", ""
	PRINTFORML %CALLNAME:MASTER%はオナホを通して%CALLNAME:C_ID%の感触を心行くまで堪能する…
	PRINTFORMW 離れた場所にいる%CALLNAME:C_ID%は訳も分からぬまま膣内を蹂躙されてしまった！
	SIF TALENT:C_ID:0 ==1
		PRINTFORML あくまでオナホ越しの行為なので、実際には%CALLNAME:C_ID%の処女こそ奪っていないものの、
	PRINTFORMW %CALLNAME:MASTER%は散々%CALLNAME:C_ID%の膣オナホを弄んだ後に最奥への膣内射精をキメた！
	EXP:C_ID:1 += RAND:10 + 1
	EXP:C_ID:6 += RAND:10 + 1
	AMT *= 8
ENDIF

IF TALENT:MASTER:濃厚精液
	AMT *= 2
	PRINTFORMW ……濃いのが{AMT}出た
ELSE
	PRINTFORMW ……{AMT}出た
ENDIF

;オナホ増設タンク
IF FLAG:1058 >= 2 && FLAG:1058 != 5 
	TFLAG:700 += AMT
	PRINTFORMW オナホに接続したタンクには精液が{TFLAG:700}溜まっている…
	IF TFLAG:700 >= 1000 && FLAG:1058 == 4
		PRINTL
		PRINTW その時、不思議な事が起こった…
		PRINTFORML 魔法のオナホと溜め込んだ精液と%CALLNAME:MASTER%の時間停止能力etc…が奇跡を起こす！
		PRINTW 魔法のオナホは『奇跡のオナホ』へと進化を遂げた！！
		BASE:MASTER:8 = 0
		TFLAG:700 = 0
		FLAG:1058 = 5
	ELSEIF TFLAG:700 >= 1000 && FLAG:1058 != 4
		PRINTL
		PRINTW その時、不思議な事が起こった…
		PRINTFORML 気温、風向、湿度、大気圧、曜日、月齢、惑星の並び…そして何よりも%CALLNAME:MASTER%の溜まりに溜まったリビドー…
		PRINTFORMW それらが複雑に絡み合い、%CALLNAME:MASTER%の放った精液が生命の輝きと共に結晶化する！
		CALL COLORMESSAGE("愛欲を独占するミラダの石ミレニアム", C_D_PINK, 0, 1)
		PRINTFORMW を手に入れた！！
		TFLAG:700 = 0
		ITEM:530 += 1
	ENDIF
ELSEIF FLAG:1058 == 5
	TFLAG:700 += AMT
ENDIF

;奇跡のオナホ
IF FLAG:1058 == 5 && TFLAG:700 > 0
	PRINTFORML %CALLNAME:MASTER%の射精した精液はオナホ内から%CALLNAME:C_ID%の膣内へと転送されていった！
	EX:C_ID:14 += AMT
	PRINTFORMW %CALLNAME:C_ID%の膣内には精液が{EX:C_ID:14}溜まっている…
ENDIF

BASE:MASTER:精力 -= AMT
SIF BASE:MASTER:精力 < 0
	BASE:MASTER:精力 = 0
DOWNBASE:MASTER:気力 = 100

TIME += 20
RETURN 1

;待つ
@COM_ABLE451
;ショップ画面では不可
SIF !TFLAG:100
	RETURN 0
;一括管理
SIF GLOBAL_COMABLE(451)
	RETURN RESULT
;気力0では不可
SIF BASE:MASTER:気力 <= 0
	RETURN 0
;精力0では不可
SIF BASE:MASTER:精力 <= 0
	RETURN 0
;ウフフ中は不可
SIF CFLAG:うふふ
	RETURN 0
;停止中は不可
SIF FLAG:70 == 1
	RETURN 0
;私室以外では不可
SIF CFLAG:MASTER:現在位置 != CFLAG:MASTER:初期位置
	RETURN 0
RETURN 1