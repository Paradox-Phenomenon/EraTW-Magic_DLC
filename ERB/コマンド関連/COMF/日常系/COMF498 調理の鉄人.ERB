@COM498
#DIMS 対戦相手
#DIMS 相手の料理
#DIM DISH_TYPE_NUM
#DIM SCORE, 3
#DIM JUDGE, 3
#DIM TOTAL_PLAYER
#DIM TOTAL_ENEMY
#DIM ENEMY_LV
#DIM C_ID
#DIM PREV_REDRAW
#DIMS THEME
#DIMS TASTE_TREND_GOOD
#DIMS TASTE_TREND_BAD
#DIMS DISH_NAME_ENEMY
#DIMS DISH_TASTE_ENEMY
#DIM BASEPOINT_TEMP
#DIMS WINNER
#DIM DishEXP
#DIM FirstWinBonus

PRINTFORML 対戦相手を選んでください
IF !TARGET == CFLAG:MASTER
	CALL ASK_M("素人",1,"駆け出し",1,"腕利き",1,"熟練",1,CALLNAME:TARGET,1,"やめる",1)
ELSE
	CALL ASK_M("素人",1,"駆け出し",1,"腕利き",1,"熟練",1,"やめる",1)
ENDIF
SELECTCASE RESULT
	CASE 0
		対戦相手 = 素人料理人
		ENEMY_LV = 1
	CASE 1
		対戦相手 = 駆け出し料理人
		ENEMY_LV = 3
	CASE 2
		対戦相手 = 腕利き料理人
		ENEMY_LV = 4
	CASE 3
		対戦相手 = 熟練料理人
		ENEMY_LV = 5
	CASE 4
		SIF TARGET == CFLAG:MASTER
			RETURN -1
		対戦相手 = %CALLNAME:TARGET%
		ENEMY_LV = ABL:TARGET:料理技能
	CASEELSE
		RETURN -1
ENDSELECT
SETBIT TFLAG:一日一回, 14
DISH_TYPE_NUM = RAND:2 + 1
;レベル不足の時は軽食のみ
SIF ABL:MASTER:料理技能 < 2
	DISH_TYPE_NUM = 1

SELECTCASE DISH_TYPE_NUM
	CASE 1
		DISH_TYPE = 軽食
	CASE 2
		DISH_TYPE = 主食
ENDSELECT
IF DISH_TYPE == "軽食"
	THEME = %TEXTR("和食/洋食/中華/肉料理/魚料理/汁物/揚げ物/煮物/おつまみ/家庭料理")%
ELSEIF DISH_TYPE == "主食"
	THEME = %TEXTR("和食/洋食/中華/肉料理/魚料理/麺類/鍋物/汁物/揚げ物/謎料理/家庭料理")%
ENDIF

PRINTFORML 「さあ、皆さま！これより幕を開けますは、お待ちかねの――調理の鉄人！本日の竈に灯る炎は、勝利の意志を燃やすのか、それとも敗北の涙と化すのか！」
IF 対戦相手 == CALLNAME:TARGET
	PRINTFORML 「今回のテーマは【%THEME%】。私の記憶が確かならば、%THEME%といえばこの女！」
ELSE
	PRINTFORML 「今回のテーマは【%THEME%】。私の記憶が確かならば、%THEME%といえばこの男！」
ENDIF
PRINTFORML 「皆さん大きな拍手でお迎えください！%THEME%の鉄人、%対戦相手%！」
SIF THEME == "家庭料理"
	THEME = 家庭的
PRINTFORML 「対する挑戦者は%CALLNAME:MASTER%！」
PRINTFORML 「そして審査員は以下の面々です」

$JUDGE_SELECT
CALL FISHER_YATES_SHAFFLE(CHARANUM - 1)
ARRAYCOPY "SHAFFLE_ARRAY" , "JUDGE"

;テーマの味が嫌いな審査員だった場合再抽選
;対戦相手,なりきり時は自分だった場合も再抽選
FOR LOCAL, 0 , 3
	C_ID = JUDGE:LOCAL + 1
	SIF STRCOUNT(GET_STR(, "キャラデータ", C_ID, "料理：嫌いな味"), THEME)
		GOTO JUDGE_SELECT
	SIF C_ID == TARGET
		GOTO JUDGE_SELECT
	SIF C_ID == FLAG:なりきり
		GOTO JUDGE_SELECT
NEXT

FOR LOCAL, 0 , 3
	JUDGE:LOCAL += 1
	C_ID = JUDGE:LOCAL
	CALL PRINT_FACE, C_ID, "通常", "服", "", ""
	PRINTFORML 
	PRINTFORML 【審査員 no.{LOCAL + 1} %CALLNAME:C_ID%】
	PRINTL 好きな味：
	CALL SHOW_TASTE(GET_STR(, "キャラデータ", C_ID, "料理：好きな味"), "POSITIVE", ABL:C_ID:親密 < 3)
	PRINTL 嫌いな味：
	CALL SHOW_TASTE(GET_STR(, "キャラデータ", C_ID, "料理：嫌いな味"), "NEGATIVE", ABL:C_ID:親密 < 3)
	PRINTFORMW 
	CALL JUDGE_RESEARCH(C_ID,"GET")
NEXT

TASTE_TREND_GOOD =
TASTE_TREND_BAD =

;好きな味、嫌いな味の内気を付けるべきものを提示
CALL JUDGE_RESEARCH(C_ID,"OUT")
PRINTFORM 「今回の調理の鉄人は…
FOR LOCAL, 0, 6
	IF LOCAL < 3
		PRINTFORM [%RESULTS:LOCAL%]
		TASTE_TREND_GOOD += RESULTS:LOCAL + "/"
		SIF LOCAL == 2
			PRINTFORM 味の使い方がカギになりそうです！反対に、
	ELSEIF LOCAL > 2
		PRINTFORM [%RESULTS:LOCAL%]
		TASTE_TREND_BAD += RESULTS:LOCAL + "/"
		SIF LOCAL == 5
			PRINTFORM 味には要注意！」
	ENDIF
NEXT
PRINTFORMW 

{
	PRINTFORML 「%TEXTR("勝利の行方を握るのは、食材に込められし魂と、それを操る天賦の才！迎え撃つ挑戦者はいかなる奇跡の皿を繰り出すのか、注目でございます！
		/このキッチンが、此度の戦場。二人の料理人が、秘めたる匠の技をぶつけ合う壮絶な一戦を、どうぞ心ゆくまでご堪能あれ！
		/果たして、華麗なる技の応酬の先にある栄冠はどちらの手に！？　さあ、限られた時間の中で生み出される至高の一皿――いざ皆さま、ご覧いただきましょう！")%」
}
PRINTFORMW 「それでは……Allez cuisine(アレ・キュイジーヌ)！」

;相手の料理を生成する
CALL ENEMY_DISH_MENU(対戦相手, DISH_TYPE_NUM, THEME, ENEMY_LV, TASTE_TREND_GOOD, TASTE_TREND_BAD)
DISH_NAME_ENEMY = %RESULTS:0%
DISH_TASTE_ENEMY = %RESULTS:1%

CALL COLORMESSAGE(@"【%DISH_TYPE%】【%THEME%】(テーマから外れている場合失格)",C_YELLOW,1)
DRAWLINE
PREV_REDRAW = CURRENTREDRAW()
REDRAW 0
CALL COOKING_MATCH_SELECT(DISH_TYPE_NUM, THEME)
REDRAW PREV_REDRAW
IF RESULTS == "棄権"
	PRINTFORML おおっと挑戦者、棄権を宣言しました！
	WINNER = 棄権
	GOTO PLAYER_LOSE
ENDIF

BASEPOINT_TEMP = DISH_BASEPOINT
CALL ENEMY_COOKING(DISH_NAME_ENEMY, DISH_TASTE_ENEMY, ENEMY_LV, 対戦相手)
DISH_NAME_ENEMY = %RESULTS%

PRINTFORML 両者ともに完成しました！
PRINTFORMW それでは%対戦相手%の%DISH_NAME_ENEMY%からご賞味いただきましょう！

TOTAL_ENEMY = 0
FOR LOCAL, 0 , 3
	C_ID = JUDGE:LOCAL
	CALL PRINT_FACE, C_ID, "通常", "服", "", ""
	CALL REVIEW_DISH(C_ID, DISH_TASTE_ENEMY)
	SCORE:LOCAL = TCVAR:C_ID:料理評価値/10
	PRINTFORMW 【審査員 no.{LOCAL + 1} %CALLNAME:C_ID%】 {SCORE:LOCAL}点
	TOTAL_ENEMY += SCORE:LOCAL
NEXT
CALL COLORMESSAGE(@"合計点：{TOTAL_ENEMY}点",C_YELLOW,1)
DISH_BASEPOINT = BASEPOINT_TEMP

PRINTFORMW 対する挑戦者の%DISH_NAME%の評価やいかに！？

IF STRFIND(DISH_TASTE, THEME) == -1
	PRINTFORML おっと！？
	PRINTFORML 【%THEME%】が含まれていません！失格です！
	GOTO PLAYER_LOSE
ENDIF

TOTAL_PLAYER = 0
FOR LOCAL, 0 , 3
	C_ID = JUDGE:LOCAL
	CALL PRINT_FACE, C_ID, "通常", "服", "", ""
	CALL REVIEW_DISH(C_ID, DISH_TASTE)
	SCORE:LOCAL = TCVAR:C_ID:料理評価値 / 10
	IF SCORE:LOCAL >= 80
		SETCOLOR C_GREEN
		FONTBOLD
		{
			PRINTFORML %CALLNAME:C_ID%の背景で%TEXTR("紅魔館が爆発した
				/妖怪の山が噴火した/鈴奈庵が炎上した
				/逆さ城が墜落して博麗神社が倒壊した/動物霊とハニワがサンバを踊った
				/月がバウンドしてヘカーティアの頭に嵌った
				/守矢神社が二つに割れてヒソウテンソクが発進した
				/血の池地獄がコバルトブルーに変わり周囲にヤシの木が生えた
				/巨大な鍵山雛の顔が浮かび上がった
				/七色のキャノンボールが発射された")%
		}
		RESETCOLOR
		FONTREGULAR
	ENDIF
	PRINTFORMW 【審査員 no.{LOCAL + 1} %CALLNAME:C_ID%】 {SCORE:LOCAL}点
	TOTAL_PLAYER += SCORE:LOCAL
NEXT
CALL COLORMESSAGE(@"合計点：{TOTAL_PLAYER}点",C_YELLOW,2)
IF TOTAL_PLAYER > TOTAL_ENEMY
	WINNER = 勝利
	PRINTFORMW 挑戦者の勝利です！
ELSE
	WINNER = 敗北
	$PLAYER_LOSE
	PRINTFORMW %対戦相手%の勝利です！
ENDIF
CALL RESET_DISH

IF WINNER == "勝利"
	IF !CFLAG:TARGET:料理勝負勝利 && 対戦相手 == CALLNAME:TARGET
		CALL COLORMESSAGE(@"【%CALLNAME:TARGET%に初勝利】",C_YELLOW,1)
		CFLAG:TARGET:料理勝負勝利 = 1
		SELECTCASE ABL:TARGET:料理技能
			CASE 0
				FirstWinBonus = 1
			CASE 1
				FirstWinBonus = 3
			CASE 2
				FirstWinBonus = 5
			CASE 3
				FirstWinBonus = 10
			CASE 4
				FirstWinBonus = 20
			CASE 5
				FirstWinBonus = 30
			CASEELSE
				FirstWinBonus = 50
		ENDSELECT
		EXP:MASTER:料理経験 += FirstWinBonus
	ENDIF
	DishEXP = MAX(ENEMY_LV , 1)
	SIF ABL:MASTER:料理技能 < ENEMY_LV
		DishEXP *= 2
	EXP:MASTER:料理経験 += DishEXP
ELSEIF WINNER == "敗北"
	EXP:MASTER:料理経験 += 1
ENDIF
DOWNBASE:MASTER:体力 = 100
DOWNBASE:MASTER:気力 = 100
TIME += 90
RETURN 1

;-------------------------------------------------
;料理の選択
;-------------------------------------------------
@COOKING_MATCH_SELECT(DISH_TYPE_NUM, THEME)
#DIM DISH_TYPE_NUM
#DIM MAXMENU
#DIM MENUCOUNT
#DIM SELECT_MENU
#DIM SELECT_ING
#DIM 料理結果
#DIM REQUIRED_LV
#DIMS THEME

CALL COOKING_UI(DISH_TYPE_NUM, SELECT_MENU, SELECT_ING, 0, 0, 0, THEME)
PRINTFORML [ 0] 棄権する
INPUT
;やめる
RESULTS =
IF RESULT == 0
	RESULTS = 棄権
ELSEIF RESULT == 9 && SELECT_MENU
	CALL DISHDATA(SELECT_MENU, DISH_TYPE, 0)
	IF RESULT != 10
		CLEARLINE 13 + COOKING_LCOUNT
		RESTART
	ENDIF
	CALL DISH_TASTE_ADD(SELECT_ING)
	DISH_RANK = 食材レベル(SELECT_ING)
	;DISHNAMEは口上でのみ使用してください
	DISHNAME = %DISH_NAME%
	FLAG:料理 = SELECT_MENU
	SELECT_MENU = 0
	PRINTFORML 使用食材：%ITEMNAME:SELECT_ING%
	ITEM:SELECT_ING --
	CALL DISH_COOKING(0)
ELSE
	;料理選択
	IF INRANGE(RESULT, 101, 400 + CHARANUM)
		SELECT_MENU = RESULT
		CALL DISHDATA(RESULT, DISH_TYPE)
		;表示外なら選択リセット
		IF !RESULT
			SELECT_MENU = 0
			SELECT_ING = -1
		;作れないなら材料だけリセットして表示する
		ELSEIF RESULT < 10
			SELECT_ING = -1
		;作れるなら材料を設定
		ELSEIF RESULT == 10
			RESULT = 0
			;選択中の材料があったら選択を保持する
			FOR LOCAL, 1, 11
				IF DISH_ING:LOCAL == SELECT_ING && SELECT_ING >= 0
					RESULT = 1
					BREAK
				ENDIF
			NEXT
			;選択中の材料がなければ材料を再設定
			IF !RESULT
				FOR LOCAL, 1, 11
					IF ITEM:(DISH_ING:LOCAL)
						SELECT_ING = DISH_ING:LOCAL
						BREAK
					ENDIF
				NEXT
			ENDIF
		ENDIF
	ELSEIF INRANGE(RESULT, 11, 20) && DISH_ING:(RESULT - 10) >= 0 && ITEM:(DISH_ING:(RESULT - 10))
		SELECT_ING = DISH_ING:(RESULT - 10)
	ENDIF
	CLEARLINE 14 + COOKING_LCOUNT
	RESTART
ENDIF
