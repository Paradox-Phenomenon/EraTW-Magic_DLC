;採集
@COM445
#DIM 採集物
#DIM 採集パワー
#DIM 採集パワーM
#DIM 採集パワーT
#DIM 土地の恵み
#DIM CHARA
#DIM 採集位置
;lockpick and treasure system
#DIM DYNAMIC TREASURE_CHEST_FIND
;あからさまな人の敷地での無断採集は放弃、弾幕勝負で勝ってれば腕づくで
IF FLAG:催眠強度 <= 50
	SELECTCASE CFLAG:MASTER:現在位置
		CASE 太陽花田, 438
			IF ABL:[[幽香]]:親密 < 5 && CFLAG:[[幽香]]:弾幕勝負勝利 == 0
				DRAWLINE
				PRINTFORML 感觉在这里擅自采集的话非常危险…
				RETURN -1
			ENDIF
		;天界、桃園
		CASE 天界, 833
			IF ABL:[[天子]]:親密 < 5 && CFLAG:[[天子]]:弾幕勝負勝利 == 0
				DRAWLINE
				PRINTFORML 感觉在这里擅自采集的话会陷入麻烦…
				RETURN -1
			ENDIF
		;虹龍洞
		CASE 虹龍洞, 855
			IF ABL:[[百百世]]:親密 < 5 && CFLAG:[[百百世]]:弾幕勝負勝利 == 0
				DRAWLINE
				PRINTFORML 感觉在这里擅自采集的话会陷入麻烦…
				RETURN -1
			ENDIF
	ENDSELECT
ENDIF

採集物 = 0
採集パワーM = 0
採集パワーT = 0
LOCAL:4 = 0

;参加者判定
IF FLAG:约会的对象 && (!FLAG:70 || CFLAG:TARGET:344 == 1)
	;Group date stuff, prioritize target date instead of lastest date invite
	IF IS_DATING_WITH_PLAYER(TARGET)
		CHARA = TARGET
	ELSE
		CHARA = FLAG:デート相手
	ENDIF
ELSEIF TARGET && ABL:TARGET:親密 >= 5 && SHIRAHU(TARGET) && CFLAG:TARGET:行動 != 5
	CHARA = TARGET
ELSE
	CHARA = 0
ENDIF

;土地の恵み。日替わりで-25～+25の間を随机で浮動。釣魚を参考に。
土地の恵み = CFLAG:MASTER:今日の運勢 / 20 - 25

SIF ITEM:三粒の天滴
	土地の恵み += 5

;採集パワー設定
IF !MAGIC_DLC
	採集パワーM = 10 + TALENT:MASTER:採集Lv * 10 + ABL:MASTER:教養 * 5 + TFLAG:幸運補正 * 10
ELSE
	採集パワーM = 10 + TALENT:MASTER:採集Lv * 10 + ABL:MASTER:教養 * 5 + MAGIC_SuccessRate()/2 + TALENT:MASTER:神性 * 10
ENDIF
SIF ITEM:108
	採集パワーM += 10

SIF CHARA && !FLAG:70
	採集パワーT = 10 + TALENT:CHARA:採集Lv * 10 + ABL:CHARA:教養 * 5
;参加者で最もパワーが高いものを基準に、1/2したもう１人のパワーを足す
IF 採集パワーM >= 採集パワーT
	採集パワー = 採集パワーM + (採集パワーT / 2)
ELSE
	採集パワー = 採集パワーT + (採集パワーM / 2)
ENDIF
採集位置 = GATHERING_SPOT(CFLAG:MASTER:現在位置)
REPEAT 5
	REUSELASTLINE  \@ CHARA ? 和%CALLNAME:CHARA%一起 #  \@采集中.%"." * COUNT%
	TWAIT 40, 1
REND
;デバッグ用
;PRINTFORML 採集位置{採集位置}
;PRINTFORML 採集パワー{採集パワー}
LOCAL = RANDSF(-3,TALENT:MASTER:採集Lv + ABL:MASTER:TSLv + TALENT:MASTER:神性 + GET_LUCK(1))
IF LOCKPICK_SYSTEM > 0 && !RAND:10
	TREASURE_CHEST_FIND = 1
	CALL TREASURE_CHEST
	SIF RESULT == 1
		TFLAG:SELECTCOM的分岐 = CHEST_LOOT:0
ELSEIF MAGIC_DLC_宝藏袋 && !RAND:9 && LOCAL
	PRINTFORML 你发现了{LOCAL}个宝藏袋
	ITEM:宝藏袋 += LOCAL
ELSE
	$TREASURSARCH
	CALL Gathering_Drawing(採集位置, 採集パワー, 土地の恵み)

	採集物 = RESULT:0
	TFLAG:194 = RESULT:1
	VARSET RESULT
	;試行回数を１回増やす
	LOCAL:4 ++
	;採集物が気に入らない場合は引き直し
	IF 採集物 != 0
		IF !FLAG:採集再抽選
			CLEARLINE 3
		ELSE
			SETCOLOR 0x00FF00
			PRINTFORM 发现了%ITEMNAME_TR((採集物))%
			RESETCOLOR
			PRINTFORML (所持数：{ITEM:(採集物)})。要采集吗？
			CALL ASK_YN("采集","再次探索")
			IF !RESULT
				CLEARLINE 4
			ELSE
				CLEARLINE 4
				採集物 = 0
				TFLAG:194 = 0
				REPEAT 5
					REUSELASTLINE  \@ CHARA ? 和%CALLNAME:CHARA%一起 #  \@採集中.%"." * COUNT%
					TWAIT 40, 1
				REND
			ENDIF
		ENDIF
	ENDIF

	;試行回数３回以下で採集物が確保されていない場合はループ
	SIF LOCAL:4 <= 3 && 採集物 == 0
		GOTO TREASURSARCH

	;道具入手処理 99个以上にならないようにする
	IF 採集物 != 0
		LOCALS = %ITEMNAME:採集物%
		CALL GET_ITEM(LOCALS, TFLAG:194 , 2)
	ENDIF
ENDIF

;基本の経験
EXP:MASTER:採集経験 ++
SIF !採集物
	EXP:MASTER:採集経験 += 2
SIF CHARA
	EXP:CHARA:採集経験 ++

SIF ITEM:108 && !RAND:2
	EXP:MASTER:採集経験 ++

SIF ABL:MASTER:教養 <= 2
	EXP:MASTER:学習経験 ++

;能力差で教えてもらう・進行解答
IF 採集パワーM >= 採集パワーT && CHARA
	EXP:CHARA:採集経験 ++
ELSEIF CHARA
	EXP:MASTER:採集経験 ++
ENDIF
IF CHARA && MAGIC_DLC_等级重置
	IF TALENT:MASTER:採集Lv > TALENT:CHARA:採集Lv 
		EXP:CHARA:採集経験 += (TALENT:MASTER:採集Lv - TALENT:CHARA:採集Lv)
	ELSEIF TALENT:MASTER:採集Lv < TALENT:CHARA:採集Lv
		EXP:MASTER:採集経験 += (TALENT:CHARA:採集Lv - TALENT:MASTER:採集Lv)
	ELSEIF TALENT:MASTER:採集Lv == TALENT:CHARA:採集Lv
		EXP:CHARA:採集経験 ++
		EXP:MASTER:採集経験 ++
	ENDIF
ENDIF
;約會経験
IF IS_DATING_WITH_PLAYER(CHARA) && CHARA > 0
	EXP:MASTER:約會経験 ++
	EXP:CHARA:約會経験 ++
ENDIF

;時間停止時はTSP減
IF FLAG:70
	;虹龍洞は採掘困難
	IF 採集位置 == 68
		BASE:MASTER:TSP -= 290
	ELSE
		BASE:MASTER:TSP -= 120
	ENDIF
	BASE:MASTER:TSP = MAX(BASE:MASTER:TSP, 0)
ELSE
	;時間経過
	IF !TREASURE_CHEST_FIND
		TIME += 60
		M_TFLAG:时间因子类型 = TimeFactor_采集
	ELSE
		TIME += 20
		M_TFLAG:时间因子类型 = TimeFactor_采集
	ENDIF
	;虹龍洞は空気が单薄的（無い）ので体力を余計に消耗する　ITEM:空色の勾玉の実装が待たれる
	IF 採集位置 == 68
		DOWNBASE:MASTER:体力 = 320 - (ABL:MASTER:戦闘能力 * 10)
		DOWNBASE:MASTER:気力 = 280
		PRINTFORML 矿坑内空气稀薄，令人感到非常疲惫…
	ELSE
		;体力減少は戦闘能力によって減少抑制
		DOWNBASE:MASTER:体力 = 180 - (ABL:MASTER:戦闘能力 * 15)
		DOWNBASE:MASTER:気力 = 150
	ENDIF
ENDIF

;参加者のソース,同一指令制限を受けないので控えめに,見つからないと半減
IF CHARA > 0
	;固定で獲得するソース
	SOURCE:CHARA:歓楽 = 300
	SOURCE:CHARA:情愛 = 50
	
	;ABL:従順をみる
	IF ABL:従順 <= 1
		SOURCE:CHARA:歓楽 += (ABL:従順 * 40)
		SOURCE:CHARA:情愛 += (ABL:親密 * 20)
	ELSEIF ABL:従順 <= 3
		SOURCE:CHARA:歓楽 += 200 + (ABL:従順 * 40)
		SOURCE:CHARA:情愛 += 50 + (ABL:親密 * 30)
	ELSEIF ABL:従順 <= 5
		SOURCE:CHARA:歓楽 += 500 + (ABL:従順 * 40)
		SOURCE:CHARA:情愛 += 200 + (ABL:親密 * 30)
	ELSEIF ABL:従順 <= 8
		SOURCE:CHARA:歓楽 += 750 + (ABL:従順 * 60)
		SOURCE:CHARA:情愛 += 300 + (ABL:親密 * 40)
	ELSEIF ABL:従順 <= 11
		SOURCE:CHARA:歓楽 += 1000 + (ABL:従順 * 60)
		SOURCE:CHARA:情愛 += 600 + (ABL:親密 * 40)
	ELSE
		SOURCE:CHARA:歓楽 += 1600 + (ABL:従順 * 30)
		SOURCE:CHARA:情愛 += 1000 + (ABL:親密 * 20)
	ENDIF
	SIF IS_DATING_WITH_PLAYER(CHARA)
		SOURCE:CHARA:情愛 = 0
	
	;好感度はみない
	
	SOURCE:CHARA:受動 = 200 + 100 * ABL:CHARA:従順
	SOURCE:CHARA:征服 = 200 + 100 * ABL:CHARA:施虐属性
	
	;採集成果をみる、道具価格に応じてとりあえず設定
	IF 採集物
		SELECTCASE ITEMPRICE:(採集物)
			CASE 1 TO 499
				TIMES SOURCE:CHARA:歓楽 , 1.00
				TIMES SOURCE:CHARA:受動 , 1.00
				TIMES SOURCE:CHARA:征服 , 1.00
				SOURCE:CHARA:達成 = 80
			CASE 500 TO 999
				TIMES SOURCE:CHARA:歓楽 , 1.10
				TIMES SOURCE:CHARA:受動 , 1.10
				TIMES SOURCE:CHARA:征服 , 1.10
				SOURCE:CHARA:達成 = 115
			CASE 1000 TO 2999
				TIMES SOURCE:CHARA:歓楽 , 1.25
				TIMES SOURCE:CHARA:受動 , 1.25
				TIMES SOURCE:CHARA:征服 , 1.15
				SOURCE:CHARA:達成 = 125
			CASE 3000 TO 5999
				TIMES SOURCE:CHARA:歓楽 , 1.50
				TIMES SOURCE:CHARA:受動 , 1.50
				TIMES SOURCE:CHARA:征服 , 1.25
				SOURCE:CHARA:達成 = 150
			CASE 6000 TO 9999
				TIMES SOURCE:CHARA:歓楽 , 1.75
				TIMES SOURCE:CHARA:受動 , 1.75
				TIMES SOURCE:CHARA:征服 , 1.50
				SOURCE:CHARA:達成 = 200
			CASE 10000 TO 14999
				TIMES SOURCE:CHARA:歓楽 , 2.00
				TIMES SOURCE:CHARA:受動 , 2.00
				TIMES SOURCE:CHARA:征服 , 1.75
				SOURCE:CHARA:達成 = 300
			CASEELSE
				TIMES SOURCE:CHARA:歓楽 , 2.25
				TIMES SOURCE:CHARA:受動 , 2.25
				TIMES SOURCE:CHARA:征服 , 2.00
				SOURCE:CHARA:達成 = 350
		ENDSELECT
	;見つからない
	ELSE
		TIMES SOURCE:CHARA:歓楽 , 0.50
		TIMES SOURCE:CHARA:受動 , 0.50
		TIMES SOURCE:CHARA:征服 , 0.50
	ENDIF
	;採集物の角色に応じた固有反応（上書き）
	SELECTCASE 採集物
		;青蛙
		CASE 706
		;琪露諾
			IF CHARA == [[琪露諾]]
				TIMES SOURCE:CHARA:歓楽 , 2.00
				TIMES SOURCE:CHARA:受動 , 2.00
				TIMES SOURCE:CHARA:征服 , 2.00
			;諏訪子
			ELSEIF CHARA == [[諏訪子]]
				TIMES SOURCE:CHARA:歓楽 , 0.50
				TIMES SOURCE:CHARA:受動 , 0.50
				TIMES SOURCE:CHARA:征服 , 0.50
			ELSE
				TIMES SOURCE:CHARA:歓楽 , 1.25
				TIMES SOURCE:CHARA:受動 , 1.00
				TIMES SOURCE:CHARA:征服 , 1.00
			ENDIF
			SOURCE:CHARA:達成 = 110
	ENDSELECT
ENDIF

;フラグ引き渡し
TFLAG:SELECTCOM的分岐 = 採集物
	
RETURN 1

;-------------------------------------------------
;実行可能判定
;-------------------------------------------------
;採集
@COM_ABLE445
#LOCALSIZE 1
#LOCALSSIZE 1
SIF !TFLAG:100
	RETURN 0
;一括管理
SIF GLOBAL_COMABLE(445)
	RETURN RESULT
;採集できる場所である
SIF !GATHERING_SPOT(CFLAG:MASTER:現在位置)
	RETURN 0
;约会中は约会的对象とだけ
SIF FLAG:デート相手 && !IS_DATING_WITH_PLAYER(TARGET)
	RETURN 0
;睡眠中
SIF CFLAG:MASTER:睡眠
	RETURN 0
SIF CFLAG:诶嘿嘿
	RETURN 0
;体力・気力不足
SIF BASE:MASTER:気力 < 650 || BASE:MASTER:体力 < 680
	RETURN 0
;時間停止中も可能（仮）
;SIF FLAG:70
;	RETURN 0
SIF FLAG:70 && BASE:MASTER:TSP < 120
	RETURN 0
RETURN 1

;-----------------------------------------------------------
;現在位置から採集スポットを割り出す関数
;ARG		現在位置
;ARG:1		@ShowGatheringSpotsからの参照用
;RETURN		0 該当無	1～30 森、草原	31～60 水系		61～ 特殊
;COMMENT	場所を追加した場合、CASEを変更の事
;-----------------------------------------------------------
@GATHERING_SPOT(ARG, ARG:1)
#FUNCTION
IF !IN_HOME(ARG) && !ARG:1
;サブMapなどでの判定
	SELECTCASE ARG
		CASE 妖精的大樹
			RETURNF 1
		CASE 斜角的竹林
			RETURNF 2
		CASE 無名之丘
			RETURNF 3
		CASE 太陽花田
			RETURNF 4
		CASE 再思之道
			RETURNF 5
		CASE 古木的大樹
			RETURNF 6
		CASE 迷途之家
			RETURNF 7
		CASE 彼岸
			RETURNF 8
		CASE 山麓樹海
			RETURNF 11
		CASE 絶景之丘
			RETURNF 12
		CASE 天界
			RETURNF 13
		CASE 桃林～砂浜
			RETURNF 14
		;大别墅
		CASE 大别墅
			RETURNF 16
		CASE 霧之湖
			RETURNF 31
		CASE 三途之川
			RETURNF 32
		CASE 玄武之澤
			RETURNF 33
		CASE 大蛤蟆之池
			RETURNF 34
		CASE 九天瀑布
			RETURNF 35
		CASE 山之湖
			RETURNF 36
		CASE 地獄的深道
			RETURNF 37
		CASE 墓地
			RETURNF 61
		CASE 無縁塚
			RETURNF 62
		CASE 間欠泉地下中樞
			RETURNF 64
		CASE 灼熱地獄跡
			RETURNF 65
		CASE 幻想風穴
			RETURNF 66
		CASE 寧靜海
			RETURNF 67
		CASE 虹龍洞
			RETURNF 68
		CASE 冰雪世界
			RETURNF 69
	ENDSELECT
ELSE
	;メインMapでの判定
	SELECTCASE ARG
		;大别墅 - 广场
		CASE P68大广场
			RETURNF 16
		;博霊神社
		CASE P25鎮守之森
			RETURNF 1
		;命蓮寺
		CASE P121墓地
			RETURNF 61
		;紅魔館
		CASE P343湖畔
			RETURNF 31
		;永遠亭
		CASE P433斜角的竹林
			RETURNF 2
		CASE P436無名之丘
			RETURNF 3
		CASE P438太陽花田
			RETURNF 4
		;魔法之森
		CASE P506無縁塚
			RETURNF 62
		CASE P507菌菇群生地
			RETURNF 63
		CASE P509再思之道
			RETURNF 5
		CASE P540古木的大樹
			RETURNF 6
		;冥界
		CASE P604彼岸
			RETURNF 8
		CASE P630八雲邸玄関
			RETURNF 7
		;妖怪之山山麓
		CASE P702山道・通往沼澤之道
			RETURNF 9
		CASE P703玄武之澤
			RETURNF 33
		CASE P705山道・中腹
			RETURNF 10
		CASE P708大蛤蟆之池
			RETURNF 34
		CASE P712間欠泉地下中樞
			RETURNF 64
		;妖怪之山山頂
		CASE P805頂上
			RETURNF 12
		CASE P806瀑布背面
			RETURNF 35
		CASE P814湖畔
			RETURNF 36
		CASE P833桃園
			RETURNF 13
		CASE P855虹龍洞
			RETURNF 68
		;地底
		CASE P928灼熱地獄跡
			RETURNF 65
		CASE P945川岸
			RETURNF 37
		CASE P948縦穴底部
			RETURNF 66
		;月
		CASE P1014桃林, P1015砂浜
			RETURNF 14
		CASE P1016入海口
			RETURNF 67
		;魔
		CASE P1182冰雪世界・冰原
			RETURNF 69
	ENDSELECT
ENDIF
RETURNF 0

;-------------------------------------------------
;その採集スポットでの採集物の出現判定をする関数
;道具番号ARG:0
;GATHERING_SPOT(ARG)の返り値ARG:1（採集スポット）  の
;出現可否を数字で返す 出現==1 非出現==0
;道具を追加した場合は、GROUPMATCH内にそれぞれ追記
;-------------------------------------------------
@GATHERING_PRODUCT(ARG:0, ARG:1)
#FUNCTION

;(酒造パッチ)山葡萄665・发霉葡萄666を追加
SELECTCASE ARG:1
	;鎮守之森、妖精的大樹
	CASE 1
		SIF GROUPMATCH(ARG:0, ITEM_普通的菌菇, ITEM_毒菌菇, ITEM_黏性菌菇, ITEM_薬草, ITEM_高級薬草, ITEM_山菜, ITEM_毒草, ITEM_山芋, ITEM_苦根, ITEM_白色树脂, ITEM_黄色树脂, ITEM_树莓, ITEM_蜂蜜, ITEM_木通果, ITEM_粪, ITEM_山葡萄, ITEM_发霉葡萄)
			RETURNF 1
	;斜角的竹林
	CASE 2
		SIF GROUPMATCH(ARG:0, ITEM_薬草, ITEM_高級薬草, ITEM_山菜, ITEM_毒草, ITEM_特薬草, ITEM_高麗人参, ITEM_苦根, ITEM_竹笋, ITEM_辰砂, ITEM_鳳凰の尾)
			RETURNF 1
	;無名之丘
	CASE 3
		SIF GROUPMATCH(ARG:0, ITEM_普通的菌菇, ITEM_毒菌菇, ITEM_黏性菌菇, ITEM_冬虫夏草, ITEM_毒草, ITEM_山芋, ITEM_曼陀罗草, ITEM_树莓, ITEM_蜂蜜, ITEM_碎骨, ITEM_粪, ITEM_彷徨灵魂, ITEM_山葡萄, ITEM_发霉葡萄)
			RETURNF 1
	;太陽花田
	CASE 4
		SIF GROUPMATCH(ARG:0, ITEM_毒草, ITEM_特薬草, ITEM_彼岸花, ITEM_雪霊草, ITEM_姜黄, ITEM_高麗人参, ITEM_苦根, ITEM_曼陀罗草, ITEM_香甜树脂, ITEM_悪華乳液, ITEM_树莓, ITEM_蜂蜜, ITEM_山葡萄, ITEM_发霉葡萄)
			RETURNF 1
	;再思之道
	CASE 5
		SIF GROUPMATCH(ARG:0, ITEM_毒草, ITEM_彼岸花, ITEM_苦根, ITEM_悪華乳液, ITEM_碎骨, ITEM_石膏, ITEM_彷徨灵魂)
			RETURNF 1
	;古木的大樹
	CASE 6
		SIF GROUPMATCH(ARG:0, ITEM_普通的菌菇, ITEM_毒菌菇, ITEM_黏性菌菇, ITEM_冬虫夏草, ITEM_可疑菌菇, ITEM_魔法菌菇, ITEM_薬草, ITEM_高級薬草, ITEM_山菜, ITEM_毒草, ITEM_山芋, ITEM_高麗人参, ITEM_白色树脂, ITEM_黄色树脂, ITEM_香甜树脂, ITEM_竜血, ITEM_树莓, ITEM_蜂蜜, ITEM_木通果, ITEM_山葡萄, ITEM_发霉葡萄)
			RETURNF 1
	;迷途之家
	CASE 7
		SIF GROUPMATCH(ARG:0, ITEM_普通的菌菇, ITEM_毒菌菇, ITEM_黏性菌菇, ITEM_冬虫夏草, ITEM_薬草, ITEM_高級薬草, ITEM_山菜, ITEM_毒草, ITEM_山芋, ITEM_姜黄, ITEM_苦根, ITEM_白色树脂, ITEM_黄色树脂, ITEM_树莓, ITEM_蜂蜜, ITEM_木通果, ITEM_山葡萄, ITEM_发霉葡萄)
			RETURNF 1
