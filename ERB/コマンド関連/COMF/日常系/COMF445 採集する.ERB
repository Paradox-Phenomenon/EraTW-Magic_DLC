;-------------------------------------------------
;採集物の季節ごとの出現判定
;道具番号ARG:0の季節ごとの
;出現可否を数字で返す関数 出現==1 非出現==0
;道具を追加した場合は、CASEに追記
;ARG:1 に採集地点を入れると、以下の列表用の式に変換 省略可
;-------------------------------------------------
@GATHERING_SEASON(ARG:0, ARG:1 = 0)
#FUNCTION
RETURNF GATHERING_SEASON2(ARG:0, ARG:1)
[SKIPSTART]
LOCAL = DAY:2
SIF GatheringSeason
	LOCAL = GatheringSeason

;(酒造パッチ)山葡萄665・发霉葡萄666を追加

SELECTCASE LOCAL
	;春:
	CASE 1
		SELECTCASE ARG:0
			CASE 600 TO 602, 604 TO 608, 610 TO 613, 616, 618 TO 627, 629, 631 TO 640, 647, 651 TO 654, 706
				RETURNF 1
			CASE 609
				SIF CFLAG:MASTER:現在位置 == 1182 || (!MAIN_MAP && CFLAG:MASTER:現在位置 == 1140)
					RETURNF 1
				RETURNF 0
		ENDSELECT
	;夏
	CASE 2
		SELECTCASE ARG:0
			CASE 600 TO 601, 603, 606 TO 608, 612 TO 613, 618 TO 627, 630 TO 640, 647, 651 TO 654, 665, 706
				RETURNF 1
			CASE 609
				SIF CFLAG:MASTER:現在位置 == 1182 || (!MAIN_MAP && CFLAG:MASTER:現在位置 == 1140)
					RETURNF 1
				RETURNF 0
		ENDSELECT
	;秋
	CASE 3
		SELECTCASE ARG:0
			CASE 600 TO 608, 611 TO 614, 616 TO 623, 625 TO 628, 631 TO 640, 647, 651 TO 654, 665, 706
				RETURNF 1
			CASE 609
				SIF CFLAG:MASTER:現在位置 == 1182 || (!MAIN_MAP && CFLAG:MASTER:現在位置 == 1140)
					RETURNF 1
				RETURNF 0
		ENDSELECT
		;(酒造パッチ)(天候パッチ)发霉葡萄666は寒気の強さが5の時のみ
		SIF ARG:0 == 666 && POWER_COLD_AIR == 5
			RETURNF 1
	;冬
	CASE 4
		;天界、地底、月と菌菇群生地、虹龍洞は夏とみ無て採集可能
		IF ARG:1
			LOCAL:1 =ARG:1
		ELSE
			LOCAL:1 = GATHERING_SPOT(CFLAG:MASTER:現在位置)
		ENDIF

		IF GROUPMATCH(LOCAL:1, 13, 14, 37, 63, 64, 65, 66, 67, 68)
			SELECTCASE ARG:0
				CASE 600 TO 601, 603, 606 TO 609, 612 TO 613, 618 TO 627, 630 TO 640, 647, 651 TO 654, 706
					RETURNF 1
			ENDSELECT
		ELSE
			SELECTCASE ARG:0
				CASE 606, 609, 615, 620, 631 TO 635, 637 TO 640
					RETURNF 1
			ENDSELECT
		ENDIF
ENDSELECT
RETURNF 0
[SKIPEND]
@GATHERING_SEASON2(ARG:0, ARG:1 = 0)
#FUNCTION
LOCAL = DAY:2
SIF GatheringSeason
	LOCAL = GatheringSeason


;全年可用: 600,601,606,607,608,612,613,618-627,631-640,647,651-654,706
SIF GROUPMATCH(ARG:0, ITEM_普通的菌菇, ITEM_毒菌菇, ITEM_龍之爪, ITEM_薬草, ITEM_高級薬草, ITEM_毒草, ITEM_特薬草, ITEM_高麗人参, ITEM_苦根, ITEM_曼陀罗草, ITEM_白色树脂, ITEM_黄色树脂, ITEM_香甜树脂, ITEM_竜血, ITEM_树莓, ITEM_蜂蜜, ITEM_碎骨, ITEM_石膏, ITEM_滑石, ITEM_竜骨, ITEM_辰砂, ITEM_粪, ITEM_湯の花, ITEM_彷徨灵魂, ITEM_暗黑物质, ITEM_鳳凰の尾, ITEM_龍珠, ITEM_仙贝, ITEM_魔界物质, ITEM_魔界菌菇, ITEM_魔界石, ITEM_青蛙)
	RETURNF 1
;609(氷之鱗) - 魔界特定位置
SIF ARG:0 == ITEM_氷之鱗 && (CFLAG:MASTER:現在位置 == GET_MAP_REPLACEMENT(P1182冰雪世界・冰原))
	RETURNF 1
;仅春: 610(木材), 629(竹笋)
IF LOCAL == 1
	SIF GROUPMATCH(ARG:0,ITEM_黏性菌菇, ITEM_可疑菌菇, ITEM_魔法菌菇, ITEM_山菜, ITEM_山芋, ITEM_木材, ITEM_悪華乳液, ITEM_竹笋)
		RETURNF 1
;仅夏: 665(山葡萄) - 实际上是夏秋
ELSEIF LOCAL == 2
	SIF GROUPMATCH(ARG:0, ITEM_冬虫夏草, ITEM_悪華乳液, ITEM_仙桃, ITEM_山葡萄)
		RETURNF 1
;仅秋: 614(彼岸花), 617(姜黄), 628(木通果), 665(山葡萄), 666(发霉葡萄-寒气5)
ELSEIF LOCAL == 3
	SIF GROUPMATCH(ARG:0,ITEM_黏性菌菇, ITEM_冬虫夏草, ITEM_可疑菌菇, ITEM_魔法菌菇, ITEM_山菜, ITEM_山芋, ITEM_彼岸花, ITEM_姜黄, ITEM_木通果, ITEM_山葡萄)
		RETURNF 1
	SIF ARG:0 == ITEM_发霉葡萄 && POWER_COLD_AIR == 5
		RETURNF 1
;仅冬: 615(雪霊草), 609(氷之鱗-普通地点)
ELSEIF LOCAL == 4
	;先判断是否是特殊地点(天界13/地底14/灼热37/菌菇63/间歇泉64/风穴65/宁静海66/虹龙洞67)
	IF ARG:1
		LOCAL:1 = ARG:1
	ELSE
		LOCAL:1 = GATHERING_SPOT(CFLAG:MASTER:現在位置)
	ENDIF
	
	IF GROUPMATCH(LOCAL:1, 13, 14, 37, 63, 64, 65, 66, 67, 68)
		;冬特殊地点额外可用: 603(冬虫夏草), 630(仙桃)
		SIF GROUPMATCH(ARG:0, ITEM_冬虫夏草, ITEM_氷之鱗, ITEM_仙桃, ITEM_悪華乳液)
			RETURNF 1
	ELSE
		;冬普通地点: 606, 609, 615, 620, 631-635, 637-640
		SIF GROUPMATCH(ARG:0, ITEM_氷之鱗, ITEM_雪霊草)
			RETURNF 1
	ENDIF
ENDIF
RETURNF 0

