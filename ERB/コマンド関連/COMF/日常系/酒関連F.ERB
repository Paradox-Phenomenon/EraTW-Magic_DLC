	RETURNF ""
CASE "醸造日数"
	RETURNF ""
CASE "醸造数"
	LOCAL = 2 + RAND:(ABL:MASTER:教養 + 1)
	RETURNF @"{LOCAL}"
CASE "酒気増加量"
	LOCAL = 400 + RAND:200
	RETURNF @"{LOCAL}"
CASE "TASTE"
		IF TALENT:ARG:酒耐性 < 0
			LOCAL = 12
		ELSEIF TALENT:ARG:酒耐性 < 1
			LOCAL = 20
		ELSEIF TALENT:ARG:酒耐性 < 4
			LOCAL = 25
		ELSE
			LOCAL = 17
		ENDIF
		SIF ABL:ARG:教養 >= 3
			LOCAL += 10
	RETURNF @"{LOCAL}"
ENDSELECT

