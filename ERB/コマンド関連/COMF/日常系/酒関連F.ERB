@F酒データ_WATER_GENERAL(ARG, O_DATA, V_NAME)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
	;shared with other water
	CASE "ITEM：马铃薯"
		RETURNF "薯类酒曲"
	CASE "QUANTITY：马铃薯"
		RETURNF "10"

	CASE "ITEM：蜂蜜"
		RETURNF "蜂蜜水"
	CASE "QUANTITY：蜂蜜"
		RETURNF "10"

	CASE "ITEM：树莓"
		RETURNF "树莓汁"
	CASE "QUANTITY：树莓"
		RETURNF "20"
	CASE "EXTRA：树莓"
		SIF MAGIC_DLC
			RETURNF "果渣"
	CASE "EXTRAQUANTITY：树莓"
		SIF MAGIC_DLC
			RETURNF "1"

	CASE "ITEM：山葡萄"
		RETURNF "葡萄汁"
	CASE "QUANTITY：山葡萄"
		RETURNF "20"
	CASE "EXTRA：山葡萄"
		RETURNF "果渣"
	CASE "EXTRAQUANTITY：山葡萄"
		RETURNF "1"

	CASE "ITEM：发霉葡萄"
		RETURNF "贵腐葡萄汁"
	CASE "QUANTITY：发霉葡萄"
		RETURNF "20"
	CASE "EXTRA：发霉葡萄"
		RETURNF "果渣"
	CASE "EXTRAQUANTITY：发霉葡萄"
		RETURNF "1"

	CASE "ITEM：甜味料"
		RETURNF "糖水"
	CASE "QUANTITY：甜味料"
		RETURNF "10"

	CASE "ITEM：陈酿前的朗姆酒"
		RETURNF "陈酿前的朗姆酒"
	CASE "QUANTITY：陈酿前的朗姆酒"
		RETURNF "1"

	CASE "ITEM：陈酿前的莓子酒"
		RETURNF "陈酿前的莓子酒"
	CASE "QUANTITY：陈酿前的莓子酒"
		RETURNF "1"

	CASE "ITEM：陈酿前的白兰地"
		RETURNF "陈酿前的白兰地"
	CASE "QUANTITY：陈酿前的白兰地"
		RETURNF "1"

	CASE "ITEM：优质食材"
		RETURNF "大米酒曲"
	CASE "QUANTITY：优质食材"
		RETURNF "1"
ENDSELECT

