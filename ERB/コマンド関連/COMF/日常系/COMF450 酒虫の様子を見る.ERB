;-------------------------------------------------
;酒虫の様子を見る
;日常系コマンド、レベル1
;-------------------------------------------------

@COM450
#DIM 醸造量
#DIM 酒ID
#DIM CAN_ADD_ITEMS
VARSET LOCAL

酒ID = ALC_ID()
醸造量 = GET_INT(0, "酒データ", 酒ID, "醸造数")
LOCALS '= @"%VAR_WATER%と入れ替える"
LOCAL = 1
IF VAR_WATER == ""
	LOCALS '= "替えの水も無しにくみ出すわけにはいかない"
	LOCAL = 0
ENDIF

CALL BREWING_GUIDE

PRINTFORML %CALLNAME:MASTER%は酒虫の入っている瓶を覗き込んだ
PRINTFORML 瓶は%VAR_FERMENT%で満たされている…
DRAWLINE

CAN_ADD_ITEMS = GET_STR(0, "酒データ", ALC_ID(VAR_FERMENT), "ADDITIONS") != ""
{
CALL ASK_M("何もしない",1,@"%LOCALS%", LOCAL,"アイテムを足す", CAN_ADD_ITEMS,
"時間操作酒造（TSP2400消費）",BASE:MASTER:8 >= 2400,"『キング・クリムゾン』！（TSP4000&キング・クリムゾン消費）", BASE:MASTER:8 >= 4000 && ITEM:キング・クリムゾン && GET_STR(0, "酒データ", ALC_ID(VAR_FERMENT), "変化先") != "0")
}
SELECTCASE RESULT
	CASE 0
		RETURN -1
	CASE 1
		PRINTFORML %CALLNAME:MASTER%は%VAR_FERMENT%を汲み出して%VAR_WATER%と入れ替えた
		IF 醸造量 > 0
			;bonus from brewer
			SIF TALENT:MASTER:酒造家
				醸造量++
			CALL GET_ITEM(@"%VAR_FERMENT%", 醸造量, 2)
			CALL BREWING_GUIDE_CONSUME(VAR_FERMENT)
		ENDIF
		;(酒造パッチ)酒粕入手
		SIF VAR_FERMENT == "吟醸酒" || VAR_FERMENT == "熟成酒" || VAR_FERMENT == "古酒" || VAR_FERMENT == "貴醸酒" || VAR_FERMENT == "貴醸熟成酒" || VAR_FERMENT == "貴醸古酒"
			CALL GET_ITEM("酒粕", 1, 1)
		VAR_FERMENT = %VAR_WATER%
		VAR_WATER =
		DAY:10 = 0
		;入れ替え時にエサをやれる
		IF ITEM:魚粕 || ITEM:肉骨粉
			PRINTFORML 酒虫にエサを与えようか…
			{
			CALL ASK_M("魚粕を与える", ITEM:魚粕,
			"肉骨粉を与える", ITEM:肉骨粉,
			"エサはやらない",1)
			}
			SELECTCASE RESULT
				CASE 0
					CALL LOST_ITEM("魚粕", 1, 1)
					PRINTFORML 酒虫は魚粕をついばんで少し活動的になったようだ…
					DAY:10 += 1
				CASE 1
					CALL LOST_ITEM("肉骨粉", 1, 1)
					PRINTFORML 酒虫は肉骨粉をついばんで活動的になったようだ…
					DAY:10 += 2
				CASE 2
					PRINTFORML エサはやらないことにした
			ENDSELECT
		ENDIF
		CALL BREWING_GUIDE_MAKE_KNOWN(VAR_FERMENT)
	CASE 2
		CALL COM450_1
	CASE 3
		IF GET_STR(0, "酒データ", 酒ID, "変化先") == "0"
			PRINTFORMW %VAR_FERMENT%にはやる意味がない
			RETURN -1
		ENDIF
		PRINTFORML %CALLNAME:MASTER%は時間停止能力を応用して強引に瓶の中の時を進めた
		BASE:MASTER:8 -= 2400
		CALL 酒造
	CASE 4
		IF GET_STR(0, "酒データ", 酒ID, "変化先") == "0"
			PRINTFORMW %VAR_FERMENT%にはやる意味がない
			RETURN -1
		ENDIF
		PRINTFORML %CALLNAME:MASTER%は時間を消し飛ばして『結果』だけを得た
		BASE:MASTER:8 -= 4000
		ITEM:キング・クリムゾン --
		DAY:10 += 9
		CALL 酒造
ENDSELECT
TIME += 5
RETURN 1



@COM450_1
CALL BREWING_GUIDE_MIX_MENU
RETURN RESULT

;酒虫の様子を見る
@COM_ABLE450
;停止中は不可
SIF FLAG:70 == 1
	RETURN 0
;移動実行判定
SIF !TFLAG:100
	RETURN 0
;一括管理
SIF GLOBAL_COMABLE(450)
	RETURN RESULT
;台所
SIF CFLAG:MASTER:現在位置 != 拠点_酒虫
	RETURN 0
SIF CFLAG:うふふ
	RETURN 0
RETURN 1

@CAN_FERMENT(ARG)
#FUNCTION
SIF DAY:10 >= 3
	RETURNF 0
SIF GROUPMATCH(VAR_FERMENT, "ただの水", "霧の湖の水", "地獄温泉の水", "奇跡の水")
	RETURNF 1
RETURNF 0

