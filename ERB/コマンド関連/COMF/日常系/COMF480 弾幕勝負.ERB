;-------------------------------------------------
;弾幕勝負
;日常系指令、レベル1
;-------------------------------------------------
@COM480

#DIM OPPONENT_REMAIN
#DIM FirstWinBonus
#DIM BattleEXP
#DIM MASTER_REMAIN

HANDICAP_FIXED = 0
HANDICAP_RAND = 0
TFLAG:GipsLV = 0

IF !BATTLEDLC
	IF TCVAR:TARGET:弾幕勝負不能
		PRINTFORML %CALLNAME:TARGET%已经很累了。明天再说吧
		RETURN -1
	ENDIF
ENDIF

$INPUT_LOOP
CALL DANMAKU_OPPONENT_STATUS(TARGET)
SIF PANGCI
	CALL PANNOQIKALA_REVEAL_OUTPUT(TARGET)

PRINTFORM 要和%CALLNAME:TARGET%进行弹幕胜负吗？ \@ TFLAG:GipsLV ? 装甲强度:{TFLAG:GipsLV}# \@
SIF CFLAG:TARGET:弾幕勝負勝利 == 1
	PRINTFORM 　★胜利
PRINTL 
CALL ASK_M("还是算了", 1, "挑战", 1, "规则说明", 1, "装备大角虫特训装置", (ITEM:角虫养成外骨骼 || ITEM:大角虫养成外骨骼))
SELECTCASE RESULT
	CASE 0
		TFLAG:GipsLV = 0
		RETURN -1
	CASE 1
		
	CASE 2
		CALL SHOW_DANMAKU_RULE
		GOTO INPUT_LOOP
	CASE 3
		CALL DANMAKU_GipsEquip
		GOTO INPUT_LOOP
ENDSELECT

;台詞・選択肢は幽香口上内に記述、口上がない場合は賭けや勝利報酬は無し
;ここでHANDICAP_FIXED, HANDICAP_RANDに数値を入れると、你の骰子判定に减少補正がかかるよ
;判定値 -= (HANDICAP_FIXED + RAND:(HANDICAP_RAND))
VARSET RESULT
CALL KOJO_MESSAGE_SEND("DANMAKU", 0, TARGET, -1, -1, "戦闘前")
IF RESULT == -1
	RETURN -1
ENDIF


PRINTFORMW 胜负开始！！
CALL DANMAKU_BATTLE(TARGET)
OPPONENT_REMAIN = RESULT
MASTER_REMAIN = RESULT:1

CALL KOJO_MESSAGE_SEND("DANMAKU", OPPONENT_REMAIN, TARGET, -1, MASTER_REMAIN, "戦闘後")
PRINTL 

;source操作他
TCVAR:TARGET:弾幕勝負不能 = 1


DOWNBASE:気力 += 500
DOWNBASE:MASTER:気力 += 500
DOWNBASE:体力 += 500
DOWNBASE:MASTER:体力 += 500

SOURCE:歓楽 += (3000 + ABL:親密 * 100) / (OPPONENT_REMAIN + 1)

IF !CFLAG:TARGET:弾幕勝負勝利 && OPPONENT_REMAIN == 0
	CALL COLORMESSAGE(@"【第一次战胜%CALLNAME:TARGET%】",C_YELLOW,1)
	TFLAG:好感度BONUS = 400 / (OPPONENT_REMAIN + 1)
	TFLAG:信赖度管理 = 3 - OPPONENT_REMAIN
	CFLAG:TARGET:弾幕勝負勝利 = 1
	SELECTCASE ABL:TARGET:戦闘能力
		CASE 0
			FirstWinBonus = 1
		CASE 1
			FirstWinBonus = 3
		CASE 2
			FirstWinBonus = 5
		CASE 3
			FirstWinBonus = 10
		CASE 4
			FirstWinBonus = 20
		CASE 5
			FirstWinBonus = 30
		CASEELSE
			FirstWinBonus = 50
	ENDSELECT
	EXP:MASTER:戦闘経験 += FirstWinBonus
ENDIF
; 特殊角色胜利奖励(魔法DLC)
IF !GETBIT(M_CFLAG:TARGET:魔法奖励获得, 0) && MAGIC_DLC ; 检查弹幕胜利位是否未设置
	IF (TARGET == 26 || TARGET == 124) ; 八云紫(ID:26) 
		ITEM:982 += 1 ; 获得隙间魔法使用权
		SETBIT M_CFLAG:TARGET:魔法奖励获得, 0 ; 设置弹幕胜利位
		IF TARGET == 26
			CALL COLORMESSAGE(@"与八云紫的战斗中，你初步理解了空间与境界的奥秘",C_GREEN,1)
			CALL COLORMESSAGE(@"隙间的原理似乎已被你掌握，但要熟练运用或许还需要时间",C_GREEN,1)
		ELSEIF TARGET == 124
			CALL COLORMESSAGE(@"与摩多罗隐岐奈的战斗中，你接触到了万物背上的秘门原理",C_GREEN,1)
			CALL COLORMESSAGE(@"秘神的力量虽难以完全掌握，但你已对门扉的奥秘有所领悟",C_GREEN,1)
		ENDIF
		IF ITEM:982 == 2
			CALL COLORMESSAGE(@"你学会了博识魔法",C_BLUE,1)
			SIF ABL:MASTER:TSLv < 5
				CALL COLORMESSAGE(@"升级TSLv至5级,或者使用触媒Lv5后可以使用",C_BLUE,1)
		ENDIF
	ELSEIF TARGET == 34 ; 天子(ID:34)
		ITEM:973 += 1 ; 获得天气控制魔法使用权
		SETBIT M_CFLAG:TARGET:魔法奖励获得, 0 ; 设置弹幕胜利位
		CALL COLORMESSAGE(@"与天子的战斗让你对天气和气质的运行原理有了新的认识",C_GREEN,1)
		CALL COLORMESSAGE(@"你学会了天气控制魔法",C_BLUE,1)
		SIF ABL:MASTER:TSLv < 4
			CALL COLORMESSAGE(@"升级TSLv至4级,或者使用触媒Lv4后可以使用",C_BLUE,1)
	ELSEIF (TARGET == 1 || TARGET == 31)
		ITEM:979 += 1 ; 增加转运魔法数量
		SETBIT M_CFLAG:TARGET:魔法奖励获得, 0 ; 设置弹幕胜利位
		IF TARGET == 1
			CALL COLORMESSAGE(@"与博丽灵梦的战斗让你领悟了因缘生起的奥秘，运与势的流转如同四季更替般自然",C_GREEN,1)
			CALL COLORMESSAGE(@"也许这就是命运的安排，博丽巫女的力量让你对运势有了全新的感知",C_GREEN,1)
		ELSEIF TARGET == 31
			CALL COLORMESSAGE(@"与东风谷早苗的战斗让你见证了奇迹的力量，那是来自守矢神社的神秘祝福",C_GREEN,1)
			CALL COLORMESSAGE(@"风祝的祈祷声仿佛仍在耳边回响，你感受到了自然与奇迹交织的力量",C_GREEN,1)
		ENDIF
		IF ITEM:979 == 2
			CALL COLORMESSAGE(@"你学会了转运魔法",C_BLUE,1)
			SIF ABL:MASTER:TSLv < 2
				CALL COLORMESSAGE(@"升级TSLv至2级,或者使用触媒Lv2后可以使用",C_BLUE,1)
		ENDIF
	ELSEIF TARGET == 65 ; 犬走椛(ID:65)
		ITEM:980 += 1 ; 获得察知之眼使用权
		SETBIT M_CFLAG:TARGET:魔法奖励获得, 0 ; 设置弹幕胜利位
		CALL COLORMESSAGE(@"与犬走椛的战斗中，你领悟了千里眼的奥秘",C_GREEN,1)
		CALL COLORMESSAGE(@"你对感知周围环境有了全新的认识",C_GREEN,1)
		CALL COLORMESSAGE(@"你学会了察知之眼",C_BLUE,1)
		SIF ABL:MASTER:TSLv < 3
			CALL COLORMESSAGE(@"升级TSLv至3级,或者使用触媒Lv3后可以使用",C_BLUE,1)
	ELSEIF TARGET == 39 ; 娜兹玲(ID:39)
		SETBIT M_CFLAG:TARGET:魔法奖励获得, 0 ; 设置弹幕胜利位
		SIF ITEM:980 
			CALL COLORMESSAGE(@"千里眼的能力似乎升级了",C_BLUE,1)
	ELSEIF (TARGET == 69 || TARGET == 113 || TARGET == 41); 二岩猯藏(ID:69)
		ITEM:981 += 1 ; 获得魔法换装使用权
		SETBIT M_CFLAG:TARGET:魔法奖励获得, 0 ; 设置弹幕胜利位
		IF TARGET == 69
			CALL COLORMESSAGE(@"与二岩猯藏的战斗中，你领悟了变化的真谛",C_GREEN,1)
			CALL COLORMESSAGE(@"狸猫的变化之术原理已被你掌握",C_GREEN,1)
		ELSEIF TARGET == 113
			CALL COLORMESSAGE(@"与赫卡提亚的战斗中，你接触到了多体存在的奥秘",C_GREEN,1)
			CALL COLORMESSAGE(@"三副身体的运行原理让你对变化有了新的理解",C_GREEN,1)
		ELSEIF TARGET == 41
			CALL COLORMESSAGE(@"与封兽鵺的战斗中，你感受到了真实与虚幻的边界",C_GREEN,1)
			CALL COLORMESSAGE(@"样貌变化的奥秘已被你领悟",C_GREEN,1)
		ENDIF
		IF ITEM:981 == 1
			CALL COLORMESSAGE(@"你学会了魔法换装",C_BLUE,1)
			SIF ABL:MASTER:TSLv < 1
				CALL COLORMESSAGE(@"升级TSLv至1级,或者使用触媒Lv1后可以使用",C_BLUE,1)
		ELSEIF ITEM:981 == 2
			CALL COLORMESSAGE(@"形态变化的原理已被你进一步掌握",C_BLUE,1)
			CALL COLORMESSAGE(@"你学会了变形魔法",C_BLUE,1)
			SIF ABL:MASTER:TSLv < 4
				CALL COLORMESSAGE(@"升级TSLv至4级,或者使用触媒Lv4后可以使用",C_BLUE,1)
			;获得变形魔法使用权
			ITEM:978 += 1
		ELSEIF ITEM:981 == 3
			CALL COLORMESSAGE(@"魅力变化的原理已被你深度掌握",C_BLUE,1)
			CALL COLORMESSAGE(@"你学会了魅力魔法",C_BLUE,1)
			SIF ABL:MASTER:TSLv < 5
				CALL COLORMESSAGE(@"升级TSLv至5级,或者使用触媒Lv5后可以使用",C_BLUE,1)
			ITEM:974 += 1
			ITEM:972 += 1 
		ENDIF
	ELSEIF TARGET == 159 ; 先代(ID:159)
		ITEM:976 += 1 ; 获得锻炼魔法使用权
		SETBIT M_CFLAG:TARGET:魔法奖励获得, 0 ; 设置弹幕胜利位
		CALL COLORMESSAGE(@"与先代的战斗中，你领悟了锻炼的奥秘",C_GREEN,1)
		CALL COLORMESSAGE(@"先代的格斗技巧和灵力运用让你对身体强化有了全新的理解",C_GREEN,1)
		CALL COLORMESSAGE(@"你学会了锻炼魔法",C_BLUE,1)
		SIF ABL:MASTER:TSLv < 3
			CALL COLORMESSAGE(@"升级TSLv至3级,或者使用触媒Lv3后可以使用",C_BLUE,1)
	ELSEIF (TARGET == 15 || TARGET == 62) ; 十六夜咲夜(ID:15)、辉夜(ID:62)
		ITEM:959 += 1 ; 增加时间转化魔法数量
		SETBIT M_CFLAG:TARGET:魔法奖励获得, 0 ; 设置弹幕胜利位
		IF TARGET == 15
			CALL COLORMESSAGE(@"与十六夜咲夜的战斗中，你感受到了时间操控的奥秘",C_GREEN,1)
			CALL COLORMESSAGE(@"咲夜的时间停止能力让你对时间的本质有了新的认识",C_GREEN,1)
		ELSEIF TARGET == 62
			CALL COLORMESSAGE(@"与辉夜的战斗中，你接触到了永远与须臾的境界",C_GREEN,1)
			CALL COLORMESSAGE(@"月之公主的永恒之力让你对时间流转有了更深的理解",C_GREEN,1)
		ENDIF
		IF ITEM:959 == 1
			CALL COLORMESSAGE(@"你学会了时间转化Lv1",C_BLUE,1)
			SIF ABL:MASTER:TSLv < 2
				CALL COLORMESSAGE(@"升级TSLv至2级,或者使用触媒Lv2后可以使用",C_BLUE,1)
		ELSEIF ITEM:959 == 2
			;获得时间转化Lv2使用权
			ITEM:960 += 1
			CALL COLORMESSAGE(@"你学会了时间转化Lv2",C_BLUE,1)
			SIF ABL:MASTER:TSLv < 3
				CALL COLORMESSAGE(@"升级TSLv至3级,或者使用触媒Lv3后可以使用",C_BLUE,1)
		ELSEIF ITEM:959 == 3
			;获得时间转化Lv3使用权
			ITEM:961 += 1
			CALL COLORMESSAGE(@"你学会了时间转化Lv3",C_BLUE,1)
			SIF ABL:MASTER:TSLv < 5
				CALL COLORMESSAGE(@"升级TSLv至5级,或者使用触媒Lv5后可以使用",C_BLUE,1)
		ENDIF
	ELSE
	ENDIF
ENDIF
BattleEXP = 5 - OPPONENT_REMAIN
IF ABL:MASTER:戦闘能力 <= ABL:TARGET:戦闘能力
	BattleEXP *= 2
	CALL COLORMESSAGE(@"【强敌BONUS！所获经验提高】",C_YELLOW,1)
ENDIF
EXP:MASTER:戦闘経験 += BattleEXP
IF !BATTLEDLC
	TIME += 60
	M_TFLAG:时间因子类型 = TimeFactor_战斗
ELSE
	TIME += 15
	M_TFLAG:时间因子类型 = TimeFactor_战斗
ENDIF

SIF AT_HOME(MASTER)
	YOGORE:(CFLAG:MASTER:現在位置) = LIMIT(YOGORE:(CFLAG:MASTER:現在位置) + 3000, 0, 6000)

RETURN 1


;-------------------------------------------------
;実行判定
;-------------------------------------------------
@COM_ABLE480
;停止中は不可
SIF FLAG:70 == 1
	RETURN 0
;実行判定
SIF !TFLAG:100
	RETURN 0
;一括管理
SIF GLOBAL_COMABLE(480)
	RETURN RESULT
SIF TARGET <= 0
	RETURN 0
SIF !SHIRAHU(TARGET)
	RETURN 0
SIF CFLAG:诶嘿嘿
	RETURN 0
;仕事中
SIF CFLAG:行動 == 5
	RETURN 0
;戦闘能力0以外
SIF ABL:TARGET:戦闘能力 == 0
	RETURN 0
SIF !戦闘訓練可(CFLAG:MASTER:現在位置)
	RETURN 0
;体力・気力不足
SIF BASE:MASTER:気力 < 500 || BASE:MASTER:体力 < 500
	RETURN 0
;体力・気力不足
SIF BASE:TARGET:気力 < 500 || BASE:TARGET:体力 < 500
	RETURN 0
RETURN 1
