;-------------------------------------------------
;接吻（継続）
;愛撫系指令、レベル1
;-------------------------------------------------
@COM19_DISPLAY
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
SIF TEQUIP:継続キス
	RETURNF "キス終了"

@COM19

IF TEQUIP:継続接吻
	PRINTFORMW 嘴唇分离的时候、唾液在两人之间形成了一道透明之桥……
	TEQUIP:継続接吻 = 0
	RETURN -1
ENDIF

CALL KISS_CANCEL
SIF RESULT == -1
	RETURN -1


;着脱の処理
TEQUIP:継続接吻 = 1

;-------------------------------------------------
;COM別FLAGの設定
;-------------------------------------------------
;行為者
TCVAR:116 = PLAYER
;奉仕快楽フラグ
TCVAR:PLAYER:108 = 1
TCVAR:108 = 1

;-------------------------------------------------
;ソース追加処理
;-------------------------------------------------
;消費体力、気力
IF (FLAG:70 == 1 && CFLAG:TARGET:344 == 0)
	BASE:MASTER:TSP -= 20
	SOURCE:快Ｍ = ABL:PLAYER:舌 * 3 + 10
ELSE
	DOWNBASE:気力 += 30
	SOURCE:快Ｍ = ABL:PLAYER:舌 * 3 + 10
	SOURCE:PLAYER:快Ｍ = ABL:舌 * 3 + 10
	SOURCE:情愛 = 100 + GET_REVISION(EXP:愛情経験,200,100)
	SOURCE:性行動 = 50 + GET_REVISION(EXP:愛情経験,50,100)

	SOURCE:屈従 = 10
	SOURCE:逸脱 = 10
	SOURCE:反感 = 10
	SOURCE:不潔 = 30

	;好感度をみる
	IF CFLAG:2 <= 500
		SOURCE:情愛 += CFLAG:2
	ELSEIF CFLAG:2 <= 5000
		SOURCE:情愛 += 300 + (CFLAG:2 - 500) / 6
	ELSE
		SOURCE:情愛 += 1000 + (CFLAG:2 - 5000) / 8
	ENDIF
	SIF SOURCE:情愛 < 0
		SOURCE:情愛 = 0
	;-------------------------------------------------
	;特殊ソース処理
	;-------------------------------------------------
	CALL KISS_TALENTEFFECT
ENDIF

;-------------------------------------------------
;汚れの処理
;-------------------------------------------------
;奴隷の口⇔調教者の口的污垢が移動
STAIN:0 |= STAIN:PLAYER:0
STAIN:PLAYER:0 |= STAIN:0
;-------------------------------------------------
;経験の処理
;-------------------------------------------------
CALL KISS_EXP
SIF TALENT:恋慕 && (!FLAG:70 || CFLAG:TARGET:344 == 1) && !CFLAG:恶作剧
	EXP:愛情経験 += 1
TCVAR:ＦＫ喪失 = 1
RETURN 1

;-------------------------------------------------
;装着継続の処理
;-------------------------------------------------
@EQUIP_COM19(ARG)

PRINTL ＜接吻中＞
;-------------------------------------------------
;ソース追加処理
;-------------------------------------------------
;KISS_TALENTEFFECTを使おうかと思ったが、そうすると継続中に実行した指令にも影響が出ることに気づいた

IF (FLAG:70 == 1 && CFLAG:ARG:344 == 0)
	BASE:MASTER:TSP -= 20
	SOURCE:ARG:快Ｍ = ABL:PLAYER:舌 * 3 + 5
ELSE

	DOWNBASE:ARG:気力 += 30
	DOWNBASE:PLAYER:気力 += 30
	SOURCE:ARG:快Ｍ = (ABL:PLAYER:舌 - TALENT:PLAYER:猫舌 + TALENT:PLAYER:舌使い + TALENT:接吻魔) * 3 + 5
	SOURCE:PLAYER:快Ｍ = (ABL:ARG:舌 * 3 - TALENT:ARG:猫舌 + TALENT:ARG:舌使い + TALENT:ARG:接吻魔) * 3 + 5
	SOURCE:ARG:情愛 = 100 - TALENT:PLAYER:猫舌 * 10 + TALENT:PLAYER:舌使い * 20 + TALENT:ARG:接吻魔 * 20
	SOURCE:ARG:性行動 = 50 - TALENT:ARG:猫舌* 10 + TALENT:ARG:舌使い * 20 + TALENT:ARG:接吻魔 * 20
	SOURCE:ARG:屈従 = 10
	SOURCE:ARG:逸脱 = 10
	SOURCE:ARG:反感 = 10

	SOURCE:ARG:不潔 = 30
	SIF TALENT:ARG:猫舌
		SOURCE:ARG:加虐 += 20
	SIF TALENT:ARG:自己愛 < 0 || TALENT:ARG:抵抗
		SOURCE:ARG:鬱屈 += 50
ENDIF
CALL KISS_EXP(ARG)


RETURN 1

;@MESSAGE_EQUIP_COM19

;-------------------------------------------------
;実行判定
;-------------------------------------------------
@COM_ABLE19
VARSET LOCAL
;接吻実行判定
SIF !TFLAG:100
	RETURN 0
;一括管理
SIF GLOBAL_COMABLE(19)
	RETURN RESULT

;口球使用中は不可
SIF TEQUIP:口球
	RETURN 0

;TARGETと接吻中なら可、すでに他の誰かと接吻してるなら駄目
FOR LOCAL,1,CHARANUM
	IF TEQUIP:LOCAL:継続接吻
		IF LOCAL != TARGET
			RETURN 0
			BREAK
		ELSE
			RETURN 1
			BREAK
		ENDIF
	ENDIF
NEXT


;直前にTARGETと接吻してるなら可
SIF PREVCOM == 20 && TARGET == TFLAG:切换到前一回的TARGET
	RETURN 1
;それ以外は駄目
RETURN 0

;-------------------------------------------------
;経験の処理
;-------------------------------------------------
@KISS_EXP(ARG = -1)
SIF ARG == -1
	ARG = TARGET

;同性愛　レズなら戻り値1ゲイなら戻り値2
IF FLAG:70 == 1 || CFLAG:ARG:恶作剧
	SIF HETEROSEX(ARG,PLAYER)
		EXP:PLAYER:(50 + HETEROSEX(ARG,PLAYER)) += 3
	EXP:PLAYER:口淫経験 ++
	EXP:PLAYER:接吻経験 ++
ELSE
	CALL ADD_EXP_LESNIAN(3)
	EXP:ARG:接吻経験 ++
	EXP:ARG:口淫経験 ++
	EXP:ARG:Ｍ経験 ++
	EXP:PLAYER:口淫経験 ++
	EXP:PLAYER:接吻経験 ++
	SIF TALENT:ARG:猫舌
		EXP:ARG:嗜虐快楽経験 += 1
	SIF MAGIC_DLC_好感亲密重做
		CFLAG:ARG:积攒度 = LIMIT(CFLAG:ARG:积攒度 + (ABL:ARG:親密 + 2 * ABL:ARG:欲望), 0, 积攒度上限(ARG))
ENDIF

;-------------------------------------------------
;汚れや猫舌による中止
;-------------------------------------------------
@KISS_CANCEL

IF TALENT:PLAYER:猫舌 && ABL:PLAYER:舌 < 2
	PRINTFORML 和猫舌的%CALLNAME:PLAYER%进行不熟练的接吻的话说不定会导致口腔炎
	PRINTFORML 等技术更好的时候再做吧
	RETURN -1
ENDIF
IF TALENT:猫舌 && ABL:舌 < 2
	PRINTFORML 把舌头伸进猫舌的%CALLNAME:TARGET%的口中的话说不定会导致口腔炎
	PRINTFORML 等到技术更好的时候再做吧
	RETURN -1
ENDIF
IF TALENT:PLAYER:汚臭耐性 < 2
	IF STAIN:0 & 污渍_精液 && ABL:PLAYER:精液中毒 < 3
		PRINTFORML 有精液的话稍微有点……
		RETURN -1
	ENDIF
	IF STAIN:0 & 汚渍_肛門
		PRINTFORML 舔过屁股的话稍微有点……
		RETURN -1
	ENDIF
	IF STAIN:0 & 污渍_阴茎 && TALENT:PLAYER:汚臭耐性 < 0
		PRINTFORML 纤细的%CALLNAME:PLAYER%无法和含过肉棒的嘴亲吻
		RETURN -1
	ENDIF
	IF TALENT:PLAYER:汚臭耐性 == -2
		IF STAIN:0 & 汚渍_破瓜血 || STAIN:0 & 污渍_愛液
			PRINTFORML 有洁癖症%CALLNAME:PLAYER%、完全无法忍受那种污垢
			RETURN -1
		ENDIF
	ENDIF
ENDIF

;-------------------------------------------------
;特殊ソース処理
;-------------------------------------------------
@KISS_TALENTEFFECT
;圧抑、抵抗持ちには、抑鬱ソース追加
SIF TALENT:自己愛 < 0 || TALENT:抵抗
	SOURCE:鬱屈 += 50

;正常位か対面座位だと情愛と性行動追加
IF TEQUIP:体位 == 1 || TEQUIP:体位 == 4
	TIMES SOURCE:情愛 , 1.30
	TIMES SOURCE:性行動 , 1.20
ENDIF
;舌を使用調教では、調教者の舌使いによって、快感のソース増加
IF TALENT:PLAYER:舌使い
	TIMES SOURCE:情愛 , 1.50
	TIMES SOURCE:快Ｍ , 1.50
ENDIF
IF TALENT:舌使い
	TIMES SOURCE:PLAYER:快Ｍ , 1.50
ENDIF
;猫舌では減少
IF TALENT:PLAYER:猫舌
	TIMES SOURCE:情愛 , 0.75
	TIMES SOURCE:快Ｍ , 0.75
ENDIF
IF TALENT:猫舌
	SOURCE:加虐 += 50
	TIMES SOURCE:PLAYER:快Ｍ , 0.75
ENDIF
IF TALENT:接吻魔
	TIMES SOURCE:性行動 , 1.40
	TIMES SOURCE:情愛 , 1.40
	TIMES SOURCE:PLAYER:快Ｍ , 1.40
ENDIF

@COM19_TAGS
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
LOCAL = 0
SETBIT LOCAL, BIT_オート喘ぎ禁止
RETURNF LOCAL