@SHOW_USERCOM
#LOCALSIZE 1
#LOCALSSIZE 1

TFLAG:100 = !TFLAG:101
VARSET LOCAL

CALL LOOK_AT
PRINTL
FIGURE_ENDLINE = LINECOUNT
CALL 过滤器表示

;指令表示
CALL QOL_SHOW_USERCOM

;addition custom code
SIF ADD_CUSTOM_COM_SWITCH
	CALL Add_Custom_List_COMS
CALL ADD_TOUCH_SET_OLD_FIELDS(1)
RESULT = 0
SIF SWEEPGOD
	PRINTC 一键扫除[778]
;自动实行中なら下记表示をスキップ
SIF !TFLAG:100
	GOTO SKIP

PRINTL
CALL PRINTBUTTON_EX(TFLAG:USERCOM非表示 ? "▽[＋] Ex_COM" # "▼[－] Ex_COM", 3002, TFLAG:USERCOM非表示)
PRINTPLAIN  == 
CALL PRINTBUTTON_EX("[CONFIG]",809)
IF MAGIC_DLC
;条件暂时设置为打开魔法DLC, 后面可能新加一个补丁
	PRINTPLAIN  =
	CALL PRINTBUTTON_EX("[SETTING]",-809)
ENDIF
IF 音乐补丁开关
	PRINTPLAIN  =
	CALL PRINTBUTTON_EX("[背景音乐设置]",-810)
ENDIF
PRINTPLAIN =
SELECTCASE FLAG:推倒
	CASE 0
		LOCALS = 逆推：不会拒绝
	CASE 1
		LOCALS = 逆推：会进行力量比较
	CASE 2
		LOCALS = 逆推：不会发生
	CASEELSE
		LOCALS = 逆推助手：参数错误
ENDSELECT
CALL PRINTBUTTON_EX(@"[%LOCALS%]", -9200, !FLAG:推倒)
IF GMF_GETBIT("幻想乡大地图")
	PRINTPLAIN =
	SELECTCASE GMF_MAP_FORCE_MODE
		CASE -1
			LOCALS = 地图模式:原版
		CASE 0
			LOCALS = 地图模式:未设置
		CASE 1
			LOCALS = 地图模式:小地图
		CASE 2
			LOCALS = 地图模式:大地图
	ENDSELECT
CALL PRINTBUTTON_EX(@"[%LOCALS%]", -3000, !GMF_MAP_FORCE_MODE)
ENDIF
PRINTPLAIN =
