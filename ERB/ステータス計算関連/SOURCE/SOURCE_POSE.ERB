;MASTERとTARGETの接触部位を設定する
@TOUCH_SET(ARG,ARG:1,ARG:2,ARG:3)
;ARG TARGETの接触部位(101=阴茎 102=阴蒂 103=指 104=口 105=胸 106=膣 107=肛門 108=足)
;ARG:1 MASTERの接触部位(1=阴茎 2=阴蒂 3=指 4=口 5=胸 6=膣 7=肛門 8=足)
;ARG:2 対象の角色番号
;ARG:3 真ならリセットする
;addition custom code
CALL ADD_TOUCH_SET_TR(PLAYER, ARG-100,ARG:1,ARG:2,,ARG:3)
RETURN

VARSET LOCAL

IF ARG:3
	FOR LOCAL,1,CHARANUM
		FOR LOCAL:1,1,10 ;custom code, cancel armpitjobs too
		;COM60~70の場合、口はリセットしない
			SIF LOCAL == ARG:2 && LOCAL:1 == 4 && TFLAG:3 >= 60 && TFLAG:3 <= 70
				CONTINUE
			TEQUIP:LOCAL:(100 + LOCAL:1) = 0
		NEXT
		;ついでに体位もリセット
		TEQUIP:LOCAL:体位 = 0
	NEXT
ENDIF
SIF ARG <= 100
	RETURN 0
FOR LOCAL,1,CHARANUM
	FOR LOCAL:1,1,9
		SIF TEQUIP:LOCAL:(100 + LOCAL:1) == ARG:1
			TEQUIP:LOCAL:(100 + LOCAL:1) = 0
	NEXT
NEXT
TEQUIP:(ARG:2):ARG = ARG:1
;継続系指令を解除

IF MASTER_POSE(SET_M,SET_M) != ARG:2 && TEQUIP:(ARG:2):継続接吻 && SELECTCOM != 0
	FOR LOCAL,1,CHARANUM
		TEQUIP:LOCAL:継続接吻 = 0
	NEXT
	PRINTL ＜接吻解除＞
ENDIF

IF MASTER_POSE(SET_B,SET_YUBI) != ARG:2 && TEQUIP:(ARG:2):揉胸
	FOR LOCAL,1,CHARANUM
		TEQUIP:LOCAL:揉胸 = 0
	NEXT
	PRINTL ＜揉胸解除＞
ENDIF

IF MASTER_POSE(SET_B,SET_M) != ARG:2 && TEQUIP:(ARG:2):吸乳头 && SELECTCOM != 6 && SELECTCOM != 12
	FOR LOCAL,1,CHARANUM
		TEQUIP:LOCAL:吸乳头 = 0
	NEXT
	PRINTL ＜吸乳头解除＞
ENDIF


;MASTERの接触部位をリセットする
@TOUCH_RESET_M(ARG)
;addition custom code
CALL ADD_TOUCH_RESET_M_TR(ARG, PLAYER)
RETURN
;ARG MASTERの接触部位(1=阴茎 2=阴蒂 3=指 4=口 5=胸 6=膣 7=肛門 8=足)
FOR LOCAL, 1, GET_TARGETNUM() + 1
	SIF TARGET:LOCAL <= 0
		CONTINUE
	FOR LOCAL:1,1,10 ;custom code, cancel armpitjobs too
		SIF TEQUIP:(TARGET:LOCAL):(100 + LOCAL:1) == ARG
				TEQUIP:(TARGET:LOCAL):(100 + LOCAL:1) = 0
	NEXT
NEXT

;TARGETの接触部位をリセットする
@TOUCH_RESET_T(ARG)
;addition custom code
CALL ADD_TOUCH_RESET_T_TR(ARG)
RETURN
FOR LOCAL,1,10 ;custom code, cancel armpitjobs too
	TEQUIP:ARG:(100 + LOCAL) = 0
NEXT
SIF TEQUIP:ARG:体位 > 0
	TEQUIP:ARG:体位 = 0
SIF TEQUIP:MASTER:体位 > 0
	TEQUIP:MASTER:体位 = 0
@MASTER_POSE(ARG,ARG:1,ARG:2)
;ARG MASTER的部位被TARGET:X的哪个部位占据(1=阴茎 2=阴蒂 3=手指 4=口 5=胸 6=阴道 7=肛门 8=足)
;ARG 0的话返回是谁占据着
;ARG:1 MASTER的部位(1=阴茎 2=阴蒂 3=手指 4=口 5=胸 6=阴道 7=肛门 8=足)
;ARG:2 真则查看前一回合的履历
;返回值 如果有TARGET:X占据着MASTER的部位，则返回该角色编号
;MASTER_POSE(SET_M,SET_P,1) 如果前一回合(第3个参数)有人用嘴(第1个参数)占据着MASTER的阴茎(第2个参数)，则返回该角色编号
;ARG返回接触MASTER的ARG:1的角色

#FUNCTION
;addition custom code
RETURNF ADD_MASTER_POSE_TR(PLAYER, ARG, ARG:1, ARG:2)
VARSET LOCAL
IF !ARG
	FOR LOCAL,1,CHARANUM
		SIF CFLAG:LOCAL:現在位置 != CFLAG:MASTER:現在位置
			CONTINUE
		FOR LOCAL:1,1,9
			SIF TEQUIP:LOCAL:(100 + LOCAL:1) == ARG:1
				RETURNF LOCAL
		NEXT
	NEXT
ENDIF
ARG:2 = ARG:2 ? 1 # 0
FOR LOCAL, 1, GET_TARGETNUM() + 1
	SIF TARGET:LOCAL <= 0
		CONTINUE
	SIF TEQUIP:(TARGET:LOCAL):(100 + ARG + 10 * ARG:2) == ARG:1
		RETURNF TARGET:LOCAL
NEXT

;TODO unfinished? or maybe this is fine
;wanted to make it so that dialogues can have a buffer because decay happens before dialogue messages
;doesn't even fucking account for which hole we are pulling out from, too lazy right now to do it though
@CAVITY_FLUID_SPILL(CHARA, ITERATION = "PASSIVE")
#DIM CHARA
#DIMS ITERATION

CALL CAVITY_FLUID_SPILL_GET_AMOUNT(CHARA, ITERATION)
CALL CAVITY_FLUID_SPILL_APPLY(CHARA)

;calculates leakage amounts based on elapsed time and stores in TCVAR:Ｖ精液漏出量 / Ａ精液漏出量
;passive scales by TIME_PROGRESS, pullout is a one-time burst
@CAVITY_FLUID_SPILL_GET_AMOUNT(CHARA, ITERATION = "PASSIVE")
#DIM CHARA
#DIMS ITERATION
#DIM ELAPSED

SIF CHARA <= 0 || CHARA >= CHARANUM
	RETURN

TCVAR:CHARA:Ｖ精液漏出量 = 0
TCVAR:CHARA:Ａ精液漏出量 = 0

SIF INRANGE(CFLAG:CHARA:Ｖ漏出阻止, 0, 1)
	CFLAG:CHARA:Ｖ漏出阻止 = IS_GAPPAGE_BLOCKED(CHARA, 0)
SIF INRANGE(CFLAG:CHARA:Ａ漏出阻止, 0, 1)
	CFLAG:CHARA:Ａ漏出阻止 = IS_GAPPAGE_BLOCKED(CHARA, 1)

ELAPSED = TIME_PROGRESS(TIME:1)

SELECTCASE ITERATION
	CASE "PASSIVE"
		;~2-3% per minute, full drain ~60min, leakage stops at 30
		SIF EX:CHARA:精液残量 > 30 && !CFLAG:CHARA:Ｖ漏出阻止 && ELAPSED
			TCVAR:CHARA:Ｖ精液漏出量 = MAX(EX:CHARA:精液残量 * ELAPSED * (2 + RAND:2) / 100, ELAPSED * 2 + RAND:(ELAPSED + 1))
		SIF EX:CHARA:アナル精液残量 > 30 && !CFLAG:CHARA:Ａ漏出阻止 && ELAPSED
			TCVAR:CHARA:Ａ精液漏出量 = MAX(EX:CHARA:アナル精液残量 * ELAPSED * (2 + RAND:2) / 100, ELAPSED * 2 + RAND:(ELAPSED + 1))
	CASE "PULLOUT"
		;pullout leak 30-50%
		SIF TEQUIP:CHARA:Ｖ接触部位 == SET_P && EX:CHARA:精液残量 > 0 && !CFLAG:CHARA:Ｖ漏出阻止
			TCVAR:CHARA:Ｖ精液漏出量 = EX:CHARA:精液残量 * (30 + RAND:21) / 100
		SIF TEQUIP:CHARA:Ａ接触部位 == SET_P && EX:CHARA:アナル精液残量 > 0 && !CFLAG:CHARA:Ａ漏出阻止
			TCVAR:CHARA:Ａ精液漏出量 = EX:CHARA:アナル精液残量 * (30 + RAND:21) / 100
	CASEELSE
		THROW Invalid iteration for @CAVITY_FLUID_SPILL_GET_AMOUNT.  ITERATION = %ITERATION%
ENDSELECT

;applies TCVAR:CHARA:Ｖ精液漏出量 / Ａ精液漏出量 to EX
;sets STAIN too (pointless?)
@CAVITY_FLUID_SPILL_APPLY(CHARA)
#DIM CHARA

SIF CHARA <= 0 || CHARA >= CHARANUM
	RETURN

IF TCVAR:CHARA:Ｖ精液漏出量 > 0
	EX:CHARA:精液残量 = MAX(EX:CHARA:精液残量 - TCVAR:CHARA:Ｖ精液漏出量, 0)
	SIF EX:CHARA:精液残量 < 20 && !RAND:5
		EX:CHARA:精液残量 = 0
	STAIN:CHARA:Ｖ |= 汚れ_精液
ENDIF
IF TCVAR:CHARA:Ａ精液漏出量 > 0
	EX:CHARA:アナル精液残量 = MAX(EX:CHARA:アナル精液残量 - TCVAR:CHARA:Ａ精液漏出量, 0)
	SIF EX:CHARA:アナル精液残量 < 5 && !RAND:5
		EX:CHARA:アナル精液残量 = 0
	STAIN:CHARA:Ａ |= 汚れ_精液
ENDIF

@IS_GAPPAGE_BLOCKED(ARG, ARG:1)
#FUNCTION
IF !ARG:1
	SIF TEQUIP:ARG:Ｖ接触部位 == SET_P
		RETURNF 1
	SIF TEQUIP:ARG:バイブ
		RETURNF 1
ELSE
	SIF TEQUIP:ARG:Ａ接触部位 == SET_P
		RETURNF 1
	SIF TEQUIP:ARG:アナルバイブ
		RETURNF 1
	SIF TEQUIP:ARG:アナルビーズ
		RETURNF 1
ENDIF
RETURNF 0

@插入解除(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
CALL CAVITY_FLUID_SPILL(ARG, "PULLOUT")
;addition custom code
CALL ADD_挿入解除_TR(ARG)
RETURN
SIF TEQUIP:ARG:Ｖ接触部位 == 1
	TEQUIP:ARG:Ｖ接触部位 = 0
SIF TEQUIP:ARG:Ａ接触部位 == 1
	TEQUIP:ARG:Ａ接触部位 = 0
TEQUIP:ARG:Ｃ接触部位 = 0
TEQUIP:ARG:Ｐ接触部位 = 0
TEQUIP:ARG:口接触部位 = 0
TEQUIP:ARG:Ｖ性交 = -1
TEQUIP:ARG:Ａ性交 = -1
TEQUIP:ARG:体位 = 0
TCVAR:ARG:誤爆挿入フラグ = 0
@挿入解除(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;addition custom code
CALL 插入解除(ARG)
RETURN
