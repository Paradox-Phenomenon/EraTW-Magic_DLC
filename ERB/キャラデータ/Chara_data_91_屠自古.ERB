@CHARAMOVE_DATA_91(ARG, ARG:2)
LOCAL = 91
SELECTCASE ARG
	;連動設定（RETURN=依存するキャラ, RESULT:1～3=対等に連動するキャラ）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;神霊廟メンバーの私室はあんまり入らない
			CASE P127布都私室, P128神子私室, P139邪仙楼
				RETURN -5
			;命蓮寺内部
			CASE P103本堂 TO P120物置
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE お地蔵通り, 枝垂れ柳の下, 墓地, 神霊廟広場, 神霊廟道場
				RETURN 1
			CASE 中有の道, 三途の川, 白玉楼庭, 白玉楼, 地獄
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ91
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ91(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "呼び名"
	CALLF MAKE_STR(V_NAME, "屠自古")
;こっから衣装設定
CASE "今日のパジャマ"
	CALLF MAKE_STR(V_NAME, "パジャマ（襦袢）セット")

CASE "普段着：帽子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("帽子", "烏帽子"))
CASE "普段着：ワンピース"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("ワンピース", "ワンピース"))
CASE "普段着：その他１"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("その他１", "護符"))

CASE "固有下着形容詞"
	CALLF MAKE_STR(V_NAME, "重さのない")
CASE "固有下半身下着名"
	CALLF MAKE_STR(V_NAME, "霊体ショーツ")
CASE "固有上半身下着"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身下着名"
	CALLF MAKE_STR(V_NAME, "霊体ブラ")
CASE "固有下着着用条件"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有下着透ける(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有下着透ける(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有下着生地厚さ"
	CALLF MAKE_INT(V_NAME, 2)


;料理関連
CASE "料理：好きな味"
	CALLF MAKE_STR(V_NAME, "野菜/揚げ物/あっさり/淡白/上品/鮮やか/豪快/ふわふわ/仙術/和食/和食/しょっぱい/しょっぱい/すっぱい/すっぱい/")
CASE "料理：嫌いな味"
	CALLF MAKE_STR(V_NAME, "洋食/ガッツリ/濃厚/質素/甘い/甘い/カエル/カエル/カエル/虫肉/虫肉/虫肉/")
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "刺激的/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "緑/美しい/レトロ/威厳/" + "雷/幽霊/" * 3 + "亡霊の/稲妻の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "ポップ/繊細/" + "護符/生体品/" * 3)

;農民関連
;豪族組で相談したら土地も用意できそうだけどそこまでしてくれるか？
CASE "農民：説明"
	CALLF MAKE_STR(V_NAME, "大根農家")
CASE "農民：作物"
	CALLF MAKE_STR(V_NAME, "大根")
CASE "農民：畑の種類"
	CALLF MAKE_STR(V_NAME, "大根畑")
CASE "農民：畑のマップ"
	CALLF MAKE_STR(V_NAME, "人里")

CASE "農民：マップID"
	CALLF MAKE_INT(V_NAME, 2)
CASE "農民：場所ID"
	CALLF MAKE_INT(V_NAME, 205)
CASE "農民：報酬"
	CALLF MAKE_INT(V_NAME, 400)
CASE "農民：金利"
	CALLF MAKE_INT(V_NAME, 12)
ENDSELECT

;-------------------------------------------------
;固有料理設定
;DISH_NAME          料理名
;RESULTS            料理の種類（軽食/主食/デザート）
;CALL 材料設定("")  材料の指定。"汎用"を入れると自動で汎用食材になる
;DISH_TASTE         味の設定
;DISH_COMMENT       （任意）一行コメント
;DISH_TIME          （任意）調理にかかる時間
;DISH_MAXLIMIT      （任意）料理の持続時間
;-------------------------------------------------
@SPECIAL_MENU_91
DISH_NAME = 雷おこし
RESULTS = デザート
CALL 材料設定("甘味材")
DISH_TASTE = 和食/米/甘い/質素/サクサク/
SIF GROUPMATCH(天候, 5, 10) || GROUPMATCH(FLAG:異常気象, 9, 10)
	DISH_TASTE += "縁起物/"
DISH_COMMENT = 加工したお米を飴で固めた和菓子。嵐の日に食べると縁起が良いとされる。
RETURN 1

;IMAGE_I91_特殊服装(CHARA)-------------------------------------------------------------------
;キャラクター特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I91_特殊服装(CHARA)
#DIM CHARA
VARSET RESULTS

IF CFLAG:[[屠自古]]:差し替え適用
	;差し替え画像
	IF CHECK_NUDE(CHARA)
		;裸
		IF FLAG:立ち絵種類
			;顔絵
		ELSE
			;立ち絵
		ENDIF
	ELSE
		;服
		IF FLAG:立ち絵種類
			;顔絵
			IF GROUPMATCH(CFLAG:[[屠自古]]:差し替え適用, 1)
				IF CURRENT_CLOTHES_SET(CHARA) == 51
					RESULTS = _メイド
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 55
					RESULTS = _バニー
				ENDIF
			ENDIF
		ELSE
			;立ち絵
			IF GROUPMATCH(CFLAG:[[屠自古]]:差し替え適用, 1)
				IF CURRENT_CLOTHES_SET(CHARA) == 51
					RESULTS = _メイド
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 55
					RESULTS = _バニー
				ENDIF
			ENDIF
		ENDIF
	ENDIF
ELSE
	;通常画像
	IF CHECK_NUDE(CHARA)
		;裸
		IF FLAG:立ち絵種類
			;顔絵
		ELSE
			;立ち絵
		ENDIF
	ELSE
		;服
	ENDIF
ENDIF

