@CHARAMOVE_DATA_161(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 161
SELECTCASE ARG
	;連動設定（RETURN=依存するキャラ, RESULT:1～3=対等に連動するキャラ）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;山
			;私室には入らない
			CASE P704河童のアジト, P706厄神の家, P709リリーたちの家, P716秋姉妹の家・土間 TO P730仙人の屋敷・庭
				RETURN -100
			CASE P733正邪の隠れ家, P736山姥の家, P737招き猫の家, P740山童のアジト,P742美天居所
				RETURN -100
			;竹林
			CASE P432影狼の家, P437メディスンの家, P439ラルバの家, P443ミスティアの家, P445妹紅の家
				RETURN -100
			;永遠亭の奥には行かない
			CASE P405調剤室, P407廊下 TO P430地下室
				RETURN -100
			;夢幻館には行かない
			CASE P450玄関 TO P466庭
				RETURN -100
			CASE P433斜角の竹林, P434迷いの小道, P444夜雀の屋台, P447竹林入口
				RETURN 1
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 山麓樹海, 玄武之澤, 大蛤蟆之池, 森の深奥, 圣域, 浅间净秽山
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ161
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ161(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	CALLF MAKE_STR(V_NAME, "姥芽")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（吊带睡裙）套")

CASE "便装：裙子"
	CALLF MAKE_INT(V_NAME, [[裙子_缠绳短裙]])
CASE "便装：上身衣服２"
	CALLF MAKE_INT(V_NAME, [[上身衣服_はだけ可能_挂颈式露脐上衣]])
CASE "便装：帽子"
	CALLF MAKE_INT(V_NAME, [[頭装備_皇冠]])

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "圣域风格的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "拼布条胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "拼布条胸罩")
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[姥芽]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 0)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 0)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 3)

;料理関連
;ほぼネムノ
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "辣/咸/" * 5 + "肉料理/" * 2 + "とろとろ/野趣/油炸食品/魚料理/鍋物/下酒菜/丰盛/濃厚/質素/家庭的/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "謎料理/" * 3 + "淡白/简易/甜/" * 2 + "面包/乳酪/外界風/洋食/")
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "母亲的味道/刺激的/得意料理＊肉料理＊/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "茶/美的/シンプル/パワフル/聖なる/自然/" + "秩序/力の/肉体の/" * 3 + "山の/聖域の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "混沌/忘却の/宝石/派手/かわいい/" + "外界の/" * 5)
ENDSELECT

;-------------------------------------------------
;固有料理設定
;DISH_NAME          料理名
;RESULTS            料理の種類（軽食/主食/甜点）
;CALL 材料設定("")  材料の指定。"汎用"を入れると自動で汎用食材になる
;DISH_TASTE         味の設定
;DISH_COMMENT       （任意）一行コメント
;DISH_TIME          （任意）調理にかかる時間
;DISH_MAXLIMIT      （任意）料理の持続時間
;-------------------------------------------------
[SKIPSTART]
@SPECIAL_MENU_161
#LOCALSIZE 1
#LOCALSSIZE 1
DISH_NAME = 圣餐饼
RESULTS = 甜点
CALL 材料設定("汎用")
DISH_TASTE = 洋食/简易/家庭的/芸術的/マニアック/
DISH_COMMENT = 一种轻薄的米饼，常被象征为‘基督的身体’。 
RETURN 1
[SKIPEND]
;IMAGE_I161_特殊服装(CHARA)-------------------------------------------------------------------
;角色特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I161_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS
SELECTCASE CFLAG:161:差し替え適用
	CASE 1
	CASE 0
		IF CHECK_NUDE(CHARA)
		ELSE
			IF IS_BUNNY(CHARA)
				RESULTS = _兔女郎
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
				RESULTS = _水手服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 33
				RESULTS = _睡衣
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || CURRENT_CLOTHES_SET(CHARA) == 53 || TEQUIP:CHARA:SWIMMING
				RESULTS = _比基尼
			ELSEIF CHECK_CLO("bra_visible", CHARA)
				RESULTS = _睡衣
			ENDIF
		ENDIF
ENDSELECT
