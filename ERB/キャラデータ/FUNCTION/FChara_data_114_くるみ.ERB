@Fキャラデータ114(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "胡桃"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"

CASE "固有内衣形容詞"
	RETURNF "可爱少女风的"
CASE "固有下半身内衣名"
	RETURNF "心形丝带内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "丝带文胸"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/香料/洋食/汁物/ジャンキー/豪華/新鲜/怪诞/滑溜溜/夢幻風/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "野菜/質素/辣/辣/"
CASE "料理：助手効果"
	RETURNF "夢幻風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黒/混沌/可怕的/ポップ/パワフル/ロリータ/" + "闇/血/妖術/" * 3 + "蝠の/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/シンプル/懷舊/和風/繊細/知的/" + "水/光/日/护符/書物/" * 3
ENDSELECT

