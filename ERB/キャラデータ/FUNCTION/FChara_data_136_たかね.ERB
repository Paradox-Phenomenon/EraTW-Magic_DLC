@Fキャラデータ136(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "高岭"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_鸭舌帽]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_上衣]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_袋子]]}"


CASE "固有内衣形容詞"
	RETURNF "特殊加工的"
CASE "固有下半身内衣名"
	RETURNF "迷彩胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "迷彩胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/蘑菇/蘑菇/蘑菇/葉物/甜/甜/酸/酸/简易/健康/質素/芸術的/野趣/黏稠/"
CASE "料理：讨厌的味道"
	RETURNF "青蛙/青蛙/青蛙/魚料理/魚料理/魚料理/咸/咸/丰盛/ジャンキー/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "得意料理＊葉物＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "高級/技術/緑/秩序/かわいい/別緻/知的/マニアック/" + "植物/深緑の/" * 3 + "葉っぱの/森の/钱包/" * 5
CASE "感性：嫌い"
	RETURNF "青/パワフル/威厳/" + "安物/水/" * 3 + "河童の/天狗の/鬼の/护臂/" * 10
ENDSELECT


