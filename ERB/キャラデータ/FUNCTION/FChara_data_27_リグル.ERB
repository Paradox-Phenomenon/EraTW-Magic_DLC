@Fキャラデータ27(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "莉格露"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：外搭"
	RETURNF @"{[[外搭_斗篷]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裤子"
	RETURNF @"{[[裤子_短裤]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
;custom code
CASE "固有指令"
	RETURNF "虫虫的采集服务"
CASE "固有指令実行可能"
	SIF !WORKING(27)
		RETURNF "1"
CASE "固有内衣形容詞"
	RETURNF "妖力笼罩的"
CASE "固有下半身内衣名"
	RETURNF "野蚕丝制胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "野蚕丝制胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[莉格露]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;農民関連
;虫つながりで蚕
;本人は金もって無さそうだけど儲けがかなり大きいということで500
;本来ならもっと手間かかるだろうがこまけーこたーいいんだよっ！
;小屋は誰が建てたんだろうね
CASE "農民：説明"
	RETURNF "養蚕農家"
CASE "農民：作物"
	RETURNF "蚕丝"
CASE "農民：田的种类"
	RETURNF "養蚕小屋"
CASE "農民：畑の所在地"
	RETURNF "魔法之森"

CASE "農民：MapID"
	RETURNF "5"
CASE "農民：場所ID"
	RETURNF "540"
CASE "農民：報酬"
	RETURNF "500"
CASE "農民：金利"
	RETURNF "4"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/果物/葉物/饮用/简易/健康/濃厚/質素/野趣/新鲜/滑溜溜/甜/甜/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "ジャンキー/淡白/咸/咸/謎料理/謎料理/謎料理/謎料理/謎料理/" + "虫肉/" * 10
CASE "料理：助手効果"
	RETURNF "得意料理＊野趣＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "かわいい/" + "緑/光/虫/照明/生体品/" * 3 + "蛍石の/蛍火の/" * 5
CASE "感性：嫌い"
	RETURNF "可怕的/威厳/" + "护臂/機械/" * 3 + "蜘蛛糸の/蜘蛛の/" * 10
ENDSELECT


