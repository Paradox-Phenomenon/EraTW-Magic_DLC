@Fキャラデータ30(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "映姫"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"
CASE "特殊衣装着用"
	;毎週金曜日はカジュアルデー
	SIF YOUBI_MATCH(DAY, "金")
		RETURNF "62"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_背心]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_悔悟棒]]}"

CASE "固有内衣形容詞"
	RETURNF "穿旧了的"
CASE "固有下半身内衣名"
	RETURNF "棉布胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "棉布胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[映姫]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/麺類/中華/和食/软糯的/温暖/質素/冥界風/甜/酸/" + "香料/" * 3 + "辣/" * 5
CASE "料理：讨厌的味道"
	RETURNF "魔力/霊障/咸/咸/" + "青蛙/虫肉/ジャンキー/外界風/化学的/" * 3 + "謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "冥界風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "白/黒/秩序/かわいい/シンプル/別緻/" + "死生/法具/" * 3 + "四季の/彼岸の/救世の/手板/" * 5
CASE "感性：嫌い"
	RETURNF "灰/混沌/派手/ロリータ/マニアック/" + "生体品/护臂/" * 3

;農民関連
;白黒で思い浮かんだのがこれ
;報酬は多めにくれる
;立地が人里なのは三途之川をうろつくのはやめなさいという心遣い
CASE "農民：説明"
	RETURNF "胡麻農家"
CASE "農民：作物"
	RETURNF "芝麻"
CASE "農民：田的种类"
	RETURNF "胡麻畑"
CASE "農民：畑の所在地"
	RETURNF "人里"

CASE "農民：MapID"
	RETURNF "2"
CASE "農民：場所ID"
	RETURNF "204"
CASE "農民：報酬"
	RETURNF "450"
CASE "農民：金利"
	RETURNF "2"

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	RETURNF "2"
CASE "一般依頼発生率"
	RETURNF "3"
CASE "固有依頼発生率"
	RETURNF "5"
CASE "固有依頼最終要素"
	RETURNF "101"
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		CALLF 固有依頼30(ARG, O_DATA, V_NAME)
ENDSELECT


