@Fキャラデータ105(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "​舞​"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"

CASE "固有内衣形容詞"
	RETURNF "在魔界也新奇的"
CASE "固有下半身内衣名"
	RETURNF "魔法阵图案胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "裹胸"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[​舞​]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "牛奶/果物/洋食/汁物/简易/淡白/機能的/上品/家庭的/软绵绵/魔界風/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "濃厚/野趣/酸/酸/" + "青蛙/虫肉/謎料理/" * 3
CASE "料理：助手効果"
	RETURNF "魔界風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "白/かわいい/ポップ/洋風/別緻/繊細/" + "魔法/" * 3 + "魔界の/背叛の/禁断の/" * 5
CASE "感性：嫌い"
	RETURNF "懷舊/和風/派手/パワフル/マニアック/"
ENDSELECT


