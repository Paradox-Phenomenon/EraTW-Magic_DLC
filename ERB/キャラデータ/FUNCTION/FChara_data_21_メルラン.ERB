@Fキャラデータ21(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "梅露蘭"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_背心]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_小号]]}"

CASE "固有内衣形容詞"
	RETURNF "太阳图案的"
CASE "固有下半身内衣名"
	RETURNF "荷叶边胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "全罩杯胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[梅露蘭]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "牛奶/乳酪/洋食/鍋物/派/丰盛/ジャンキー/芸術的/新鲜/豪快/软绵绵/甜/甜/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "简易/咸/咸/虫肉/虫肉/虫肉/香料/香料/香料/"
CASE "料理：助手効果"
	RETURNF "未知の味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "粉色/幽霊/かわいい/派手/パワフル/" + "音楽/日/楽器/" * 3 + "虹の/幽霊の/欢愉の/幸福の/三位一体の/" * 5
CASE "感性：嫌い"
	RETURNF "別緻/繊細/" + "星/月/刃物/弾/护臂/烟袋/" * 3 + "鼓槌/拨片/指揮棒/" * 5 + "精霊銀の/憂鬱の/" * 10
ENDSELECT

