@Fキャラデータ143(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "尤魔"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裙子+兜帽"
	
CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_勺子]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_角饰带]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_叉勺]]}"

CASE "固有内衣形容詞"
	RETURNF "毛茸茸的"
CASE "固有下半身内衣名"
	RETURNF "小羊胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "小羊胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "中華/ジャンキー/濃厚/畜生流/" + "辣/丰盛/豪快/" * 3
CASE "料理：讨厌的味道"
	;例外的に讨厌的味道が極端に少ない
	RETURNF "質素/简易/淡白/"
CASE "料理：助手効果"
	RETURNF "畜生流/"
;贈り物関連
CASE "感性：好き"
	RETURNF "白/混沌/可怕的/知的/" + "強欲な/血/鹫の/" * 3  + "羊の/剛欲な/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/派手/芸術的/" + "神霊/" * 3 + "埴轮の/水獭の/狼の/龟の/龍の/埴轮/" * 10
ENDSELECT


