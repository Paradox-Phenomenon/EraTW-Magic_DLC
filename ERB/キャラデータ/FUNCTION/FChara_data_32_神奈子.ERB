@Fキャラデータ32(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "神奈子"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_发饰]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_上衣]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_注连绳]]}"

CASE "固有内衣形容詞"
	RETURNF "献给神明的"
CASE "固有下半身内衣名"
	RETURNF "细纱内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "裹胸"
CASE "固有内衣着用条件"
	SIF !RAND:3
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "青蛙/好吃的魚/鳥肉/和食/麺類/辣/丰盛/豪華/野趣/豪快/サクサク/" + "咸/" * 3
CASE "料理：讨厌的味道"
	RETURNF "简易/質素/甜/甜/妖力/妖力/虫肉/虫肉/虫肉/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "加護/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/秩序/美的/懷舊/パワフル/威厳/" + "風/巫術/" * 3 + "神圣庄严の/注連縄の/蛇の/風神の/山の/" * 5
CASE "感性：嫌い"
	RETURNF "ポップ/洋風/繊細/ロリータ/" + "土/" * 3 + "蛙の/博霊の/" * 10

;農民関連
;神奈子さま高付加価値農業とか好きそう
CASE "農民：説明"
	RETURNF "香瓜農家"
CASE "農民：作物"
	RETURNF "甜瓜"
CASE "農民：田的种类"
	RETURNF "温室"
CASE "農民：畑の所在地"
	RETURNF "守谷神社"

CASE "農民：MapID"
	RETURNF "8"
CASE "農民：場所ID"
	RETURNF "814"
CASE "農民：報酬"
	RETURNF "700"
CASE "農民：金利"
	RETURNF "18"
ENDSELECT


