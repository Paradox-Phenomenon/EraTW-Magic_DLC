@Fキャラデータ55(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "白蓮"
;こっから衣装設定
CASE "特殊衣装着用"
	;1/8概率换上机车夹克
	SIF FLAG:9 % 8 == 0
		RETURNF "64"
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：外搭"
	RETURNF @"{[[外搭_斗篷]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_长靴]]}"
CASE "便装：襪子"
	IF FLAG:2 > 0
		RETURNF @"{[[襪子_吊带袜]]}"
	ELSE
		RETURNF @"{[[襪子_袜子]]}"
	ENDIF
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_哥特洛丽塔裙]]}"

CASE "固有内衣形容詞"
	RETURNF "缝缝补补的"
CASE "固有下半身内衣名"
	RETURNF "缠布内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "缠布裹胸"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[白蓮]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/蘑菇/和食/中華/葉物/甜/健康/淡白/質素/野趣/家庭的/黏稠/魔界風/酸/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "洋食/濃厚/上品/新鲜/咸/咸/" + "肉料理/魚料理/卵/青蛙/虫肉/ジャンキー/冥界風/地獄風/化学的/" * 3
CASE "料理：助手効果"
	RETURNF "魔界風/得意料理＊質素＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "白/秩序/美的/シンプル/大陸風/派手/巫術/" + "光/魔法/法具/" * 3 + "魔界蝶の/魔神の/法界の/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/ロリータ/" + "死生/刃物/护臂/" * 3 + "死神の/死の/" * 10

;農民関連
;素齋用
CASE "農民：説明"
	RETURNF "大豆農家"
CASE "農民：作物"
	RETURNF "大豆"
CASE "農民：田的种类"
	RETURNF "大豆畑"
CASE "農民：畑の所在地"
	RETURNF "命蓮寺"

CASE "農民：MapID"
	RETURNF "1"
CASE "農民：場所ID"
	RETURNF "106"
CASE "農民：報酬"
	RETURNF "400"
CASE "農民：金利"
	RETURNF "2"
ENDSELECT


