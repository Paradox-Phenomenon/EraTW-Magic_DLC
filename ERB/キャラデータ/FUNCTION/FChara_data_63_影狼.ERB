@Fキャラデータ63(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "影狼"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：外搭"
	RETURNF @"{[[外搭_披肩]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_胸针]]}"
CASE "便装：帽子"
	; IF GET_MAPID(CFLAG:ARG:現在位置) == 2 && CFLAG:ARG:基本服装セット == (100 + [[影狼]])
	; 	RETURNF @"{[[頭装備_头巾]]}"
	; ELSEIF CFLAG:ARG:口上セレクタ == 0 && CFLAG:ARG:基本服装セット == (100 + [[影狼]]) && TCVAR:ARG:363 == 101
	; 	RETURNF @"{[[頭装備_草帽]]}"
	; ENDIF
CASE "便装：其他２"
	; IF CFLAG:ARG:口上セレクタ == 0 && CFLAG:ARG:基本服装セット == (100 + [[影狼]]) && TCVAR:ARG:363 == 2
	; 	RETURNF @"{[[其他衣装_围巾]]}"
	; ENDIF
CASE "特殊衣装着用"
	;イベント発生済みで春か夏にセーラー服着用
	SIF TCVAR:63:371 == 1
		RETURNF "74"
CASE "固有内衣形容詞"
	RETURNF "菊花杯式样的"
CASE "固有下半身内衣名"
	RETURNF "麻布胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "麻布胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "油炸食品/甜/丰盛/濃厚/野趣/赏月/芸術的/芸術的/魚料理/肉料理/肉料理/肉料理/"
CASE "料理：讨厌的味道"
	RETURNF "简易/淡白/辣/辣/虫肉/野菜/酸/天狗流/" + "謎料理/蘑菇/" * 3 + "香料/" * 5
CASE "料理：助手効果"
	RETURNF "浓郁/得意料理＊肉料理＊/"
;贈り物関連
CASE "感性：好き"
	{
	RETURNF ("和風/犬の/渴血の/動物/繊細/" + "シンプル/赤/自然/" * 2 + 
	"装飾/月/牙/爪/芸術的/美的/別緻/" * 3
	 + "時尚/狼の/満月の/" * 5)
	}
CASE "感性：嫌い"
	{
	RETURNF ("奇妙/金属/" + "派手/ロリータ/マニアック/" * 2 
	+ "壮大/威厳/刃物/天狗の/河童の/鬼の/" * 3 + "機械/" * 5+ "项圈/" * 10)
	}
ENDSELECT

