@Fキャラデータ122(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "舞"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_乌帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_长筒袜]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_竹枪]]}"

CASE "固有内衣形容詞"
	RETURNF "方便跳舞的"
CASE "固有下半身内衣名"
	RETURNF "平角裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "运动文胸"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[舞]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/鍋物/丰盛/ジャンキー/濃厚/豪華/芸術的/豪快/软绵绵/甜/甜/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "野菜/質素/酸/酸/天狗流/天狗流/天狗流/"
CASE "料理：助手効果"
	RETURNF "附魔/浓郁/"
;贈り物関連
CASE "感性：好き"
	RETURNF "緑/混沌/かっこいい/ポップ/派手/不思議/" + "音楽/楽器/" * 3 + "竹の/疯狂な/後戸の/肉体の/" * 5
CASE "感性：嫌い"
	RETURNF "別緻/繊細/知的/" + "書物/" * 3 + "天狗の/" * 10
ENDSELECT


