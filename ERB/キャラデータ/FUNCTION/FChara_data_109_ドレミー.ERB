@Fキャラデータ109(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "哆来咪"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_圣诞帽]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_梦日记]]}"

CASE "固有内衣形容詞"
	RETURNF "柔软可塑的"
CASE "固有下半身内衣名"
	RETURNF "梦魂胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "梦魂胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "牛奶/卵/麺類/淡白/芸術的/新鲜/软绵绵/甜/甜/酸/酸/" + "謎料理/" * 3
CASE "料理：讨厌的味道"
	RETURNF "濃厚/質素/夢幻風/咸/咸/"
CASE "料理：助手効果"
	RETURNF "未知の味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/美的/奇妙/ポップ/不思議/マニアック/" + "精神/置物/" * 3 + "羊の/貘の/夢の/睡眠の/悪夢の/软乎乎の/夢境的/" * 5
CASE "感性：嫌い"
	RETURNF "パワフル/ロリータ/威厳/" + "刃物/弾/" * 3
ENDSELECT


