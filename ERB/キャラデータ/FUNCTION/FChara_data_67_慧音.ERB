@Fキャラデータ67(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "慧音"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：上身衣服２"
;	IF DAY:2 == 2
;		RETURNF @"{[[上身衣服_はだけ可能_短袖女式衬衫]]}"
;	ELSE
		RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
;	ENDIF
;CASE "便装：裤子"
;	SIF DAY:2 == 2
;		RETURNF @"{[[裤子_裤子]]}"
;CASE "便装：其他１"
;	SIF DAY:2 == 2
;		RETURNF @"{[[其他衣装_领带]]}"
;CASE "便装：其他２"
;	SIF DAY:2 == 2
;		RETURNF @"{[[其他衣装_吊帯]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"

CASE "固有内衣形容詞"
	RETURNF "尾部开洞的"
CASE "固有下半身内衣名"
	RETURNF "蓝染内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "蓝染胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[慧音]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	IF DAY:3 == 15 && INRANGE(TIME:2, 5, 7)
		RETURNF "野菜/和食/葉物/简易/淡白/質素/上品/家庭的/サクサク/妖力/妖力/妖力/赏月/甜/甜/酸/酸/"
	ELSE
		RETURNF "野菜/和食/葉物/简易/淡白/質素/上品/家庭的/サクサク/神力/赏月/甜/甜/酸/酸/"
	ENDIF
CASE "料理：讨厌的味道"
	IF DAY:3 == 15 && INRANGE(TIME:2, 5, 7)
		RETURNF "神力/辣/辣/" + "青蛙/虫肉/怪诞/" * 3 + "謎料理/" * 5
	ELSE
		RETURNF "妖力/辣/辣/" + "青蛙/虫肉/怪诞/" * 3 + "謎料理/" * 5
	ENDIF
CASE "料理：助手効果"
	RETURNF "得意料理＊家庭的＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/秩序/かわいい/シンプル/懷舊/繊細/知的/" + "文具/書物/" * 3 + "懐かしき/過去の/牛の/知識の/知恵の/記録/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/派手/ロリータ/" + "刃物/弾/生体品/护臂/鼠の/" * 3
ENDSELECT


