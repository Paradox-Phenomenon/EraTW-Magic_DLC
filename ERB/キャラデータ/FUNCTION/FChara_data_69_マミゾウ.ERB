@Fキャラデータ69(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "猯藏"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_发饰]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_木屐]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_眼鏡]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_酒壶]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_账簿]]}"

CASE "固有内衣形容詞"
	RETURNF "雅致叶子图案的"
CASE "固有下半身内衣名"
	RETURNF "亚麻内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "亚麻胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;特殊衣装
CASE "おうちデート衣装"
	SIF MAIN_MAP == 2
		RETURNF @"{[[猯藏和装]]}"
CASE "人里デート衣装", "人間衣装"
	RETURNF @"{[[猯藏和装]]}"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/香料/和食/麺類/濃厚/芸術的/野趣/豪快/软糯的/外界風/赏月/辣/辣/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "酸/酸/面包/面包/面包/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "ドッキリ味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "茶/混沌/美的/奇妙/和風/知的/" + "付喪神/妖術/眼鏡/酒/" * 3 + "狸の/葉っぱの/烟袋/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/シンプル/洋風/ロリータ/" + "神霊/护臂/" * 3 + "狐の/" * 10

;農民関連
;地主に違和感がない
CASE "農民：説明"
	RETURNF "米農家"
CASE "農民：作物"
	RETURNF "大米"
CASE "農民：田的种类"
	RETURNF "水田"
CASE "農民：畑の所在地"
	RETURNF "命蓮寺"

CASE "農民：MapID"
	RETURNF "1"
CASE "農民：場所ID"
	RETURNF "101"
CASE "農民：報酬"
	RETURNF "500"
CASE "農民：金利"
	RETURNF "20"
ENDSELECT


