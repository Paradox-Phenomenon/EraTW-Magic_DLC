@Fキャラデータ89(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "芳香"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_御札]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_上衣]]}"

CASE "固有内衣形容詞"
	RETURNF "类似青娥穿的"
CASE "固有下半身内衣名"
	RETURNF "三层褶边短裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "褶边胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"


;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/中華/和食/油炸食品/ジャンキー/濃厚/冷/質素/野趣/黏稠/妖力/霊障/甜/甜/酸/酸/丰盛/丰盛/" + "怪诞/" * 3
CASE "料理：讨厌的味道"
	RETURNF "温暖/神力/" + "咸/简易/淡白/" * 2 + "健康/" * 3
CASE "料理：助手効果"
	RETURNF "未知の味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黒/混沌/可怕的/奇妙/" + "死生/妖術/生体品/" * 3 + "死霊の/不滅の/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/知的/" + "光/神霊/書物/护符/機械/" * 3
ENDSELECT


