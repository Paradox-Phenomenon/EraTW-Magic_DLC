@Fキャラデータ138(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "魅須丸"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_羽织]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_无袖上衣]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_勾玉]]}"
	
CASE "固有内衣形容詞"
	RETURNF "自制的"
CASE "固有下半身内衣名"
	RETURNF "勾玉图案胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "勾玉图案胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[魅須丸]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/和食/汁物/甜/甜/酸/酸/简易/淡白/質素/芸術的/家庭的/サクサク/"
CASE "料理：讨厌的味道"
	RETURNF "咸/咸/丰盛/濃厚/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "得意料理＊和食＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "鉱物/朱/秩序/美的/芸術的/和風/繊細/壮大/" + "土/巫術/装飾/" * 3 + "龍珠の/勾玉/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/洋風/パワフル/" + "生体品/" * 3 + "機械/" * 10
ENDSELECT


