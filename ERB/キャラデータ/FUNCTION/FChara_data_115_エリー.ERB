@Fキャラデータ115(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "艾麗"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_大镰]]}"

CASE "固有内衣形容詞"
	RETURNF "优雅花边图案的"
CASE "固有下半身内衣名"
	RETURNF "雅致内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "雅致胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[艾麗]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;特殊衣装設定
CASE "おうちデート衣装","人里デート衣装"
	RETURNF @"{[[纯色连衣裙套装]]}"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/洋食/麺類/派/濃厚/豪華/新鲜/怪诞/サクサク/夢幻風/甜/甜/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "辣/辣/" + "青蛙/虫肉/香料/謎料理/" * 3
CASE "料理：助手効果"
	RETURNF "夢幻風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/混沌/可怕的/洋風/別緻/" + "死生/妖術/刃物/" * 3 + "死神の/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/派手/マニアック/"
ENDSELECT

