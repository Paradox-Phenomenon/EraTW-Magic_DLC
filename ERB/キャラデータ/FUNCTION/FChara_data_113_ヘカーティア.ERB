@Fキャラデータ113(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "赫卡提亚"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：飾品"
	RETURNF @"{[[飾品_鎖]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_三色裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_地獄Ｔ恤衬衫]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_项圈]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_惑星]]}"

CASE "固有内衣形容詞"
	RETURNF "光看就可能掉进地狱的"
CASE "固有下半身内衣名"
	RETURNF "『GoToHell』胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "抹胸胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:3
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "面包/香料/麺類/派/丰盛/ジャンキー/濃厚/豪華/新鲜/サクサク/地獄風/外界風/" + "洋食/辣/咸/" * 2 + "怪诞/" * 3
CASE "料理：讨厌的味道"
	RETURNF "中華/简易/健康/淡白/野趣/酸/酸/質素/質素/月都風/月都風/月都風/月都風/月都風/"
CASE "料理：助手効果"
	RETURNF "地獄風/魔力/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/青/黄/高級/混沌/可怕的/奇妙/派手/パワフル/威厳/壮大/マニアック/" + "闇/宝石/妖術/冥王の/月の/地上の/異界の/" * 3 + "万魔殿な/紺珠の/女神の/地獄の/" * 5
CASE "感性：嫌い"
	RETURNF "シンプル/懷舊/別緻/繊細/" + "安物/" * 3
ENDSELECT


