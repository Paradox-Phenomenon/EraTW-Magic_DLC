@Fキャラデータ84(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "山女"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_上衣]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_无袖連衣裙]]}"

CASE "固有内衣形容詞"
	RETURNF "黑色蛛网刺绣的"
CASE "固有下半身内衣名"
	RETURNF "蜘蛛图案内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "蜘蛛图案胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[山女]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/和食/汁物/饮用/濃厚/質素/野趣/怪诞/黏稠/地底風/咸/咸/酸/酸/" + "虫肉/" * 5
CASE "料理：讨厌的味道"
	RETURNF "辣/辣/面包/面包/面包/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "地底風/得意料理＊虫肉＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黒/茶/かわいい/別緻/" + "虫/毒/生体品/" * 3 + "蜘蛛糸の/蜘蛛の/" * 5
CASE "感性：嫌い"
	RETURNF "派手/パワフル/ロリータ/" + "動物/鳥/機械/" * 3
ENDSELECT


