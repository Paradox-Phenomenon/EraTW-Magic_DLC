@Fキャラデータ121(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "成美"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_笠]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_雪駄]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_足袋]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_法衣]]}"

CASE "固有内衣形容詞"
	RETURNF "写着经文的"
CASE "固有下半身内衣名"
	RETURNF "朱红色兜裆布"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "经文胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[成美]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/卵/和食/麺類/简易/淡白/冬物/質素/上品/謎料理/サクサク/神力/冥界風/甜/甜/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "酸/酸/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/"
CASE "料理：助手効果"
	RETURNF "薄味/得意料理＊冬物＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "灰/かわいい/別緻/" + "土/魔法/护符/法具/" * 3 + "石の/救世の/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/可怕的/" + "刃物/弾/护臂/" * 3 + "孤独の/" * 10
ENDSELECT


