@Fキャラデータ99(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "豊姫"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
;CASE "便装：襪子"
	;RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_背带裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_褶边女式衬衫]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_束腰]]}"

CASE "固有内衣形容詞"
	RETURNF "永远不坏的"
CASE "固有下半身内衣名"
	RETURNF "F纤维内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "F纤维胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:3
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/鍋物/健康/淡白/上品/野趣/家庭的/滑溜溜/月都風/赏月/美味的水/中華/中華/甜/甜/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "洋食/ジャンキー/酸/酸/" + "青蛙/虫肉/怪诞/" * 3 + "謎料理/生命力/" * 5
CASE "料理：助手効果"
	RETURNF "月都風/幸運/"
;贈り物関連
CASE "感性：好き"
	RETURNF "紫/秩序/美的/芸術的/大陸風/繊細/知的/" + "水/月/巫術/护符/扇/" * 3 + "フェムトファイバーの/桃の/海神の/海の/穢れなき/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/奇妙/パワフル/ロリータ/マニアック/" + "土/闇/死生/生体品/护臂/" * 3 + "地上の/万魔殿な/" * 10
ENDSELECT


