@Fキャラデータ101(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "朱鷺子"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"

CASE "固有内衣形容詞"
	RETURNF "红色渐染纯白的"
CASE "固有下半身内衣名"
	RETURNF "朱鹭色胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "朱鹭色胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/虫肉/和食/葉物/简易/淡白/質素/野趣/家庭的/黏稠/甜/甜/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "辣/辣/卵/卵/卵/" + "鳥肉/謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "薄味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/秩序/かわいい/シンプル/和風/別緻/繊細/知的/" + "鳥/書物/" * 3 + "知恵の/知識の/" * 5
CASE "感性：嫌い"
	RETURNF "ポップ/パワフル/威厳/" + "刃物/弾/护臂/" * 3
ENDSELECT



