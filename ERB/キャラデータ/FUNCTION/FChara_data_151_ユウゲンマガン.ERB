@Fキャラデータ151(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "幽幻魔眼"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（连衣裙）套"

CASE "便装：和服"
	RETURNF @"{[[和服_和服]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"	
CASE "便装：飾品"
	RETURNF @"{[[飾品_袖]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_蝴蝶结]]}"

CASE "固有内衣形容詞"
	RETURNF "带电的"
CASE "固有下半身内衣名"
	RETURNF "导体内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "导体胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[幽幻魔眼]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "謎料理/魔界風/新鲜/外界風/魔力/附魔/逆転/" + "ドッキリ味/" * 3
CASE "料理：讨厌的味道"
	RETURNF "薄味/霊障/秘術/" + "科学的/化学的/" * 3
CASE "料理：助手効果"
	RETURNF "魔界風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "恐怖的/妖艶な/怪奇な/エニグマティクな/マニアックな/幻獣の/闇の/法界の/诅咒の/電子工学の/" + "哥特的/懷舊的/神秘的/前衛的な/オカルティックな/外界の/" * 3 + "幽玄な/神秘的な/奇妙な/令人害怕の/疯狂な/禁忌の/幻影の/" * 5 + "邪悪の/狂気の/" * 10
CASE "感性：嫌い"
	RETURNF "紅魔の/巫女の/天空の/平和の/肉体の/俗气の/時空の/退魔の/" + "モダンな/東方風格的/天輪の/" * 3 + "かわいい/封魔の/封呪の/" * 5
ENDSELECT


