@Fキャラデータ152(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "菊理"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（连衣裙）套"

CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "固有内衣形容詞"
	RETURNF "固态金属的"
CASE "固有下半身内衣名"
	RETURNF "黄铜内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "黄铜胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[菊理]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "煎餅/派/淡白/魔界風/隠し味/附魔/秘術/蛋糕/漢堡/外界風/大火力/" + "春物/加護/道具の共鳴/" * 3 + "和食/" * 5
CASE "料理：讨厌的味道"
	RETURNF "怪诞/謎料理/霊障/ジャンキー/浓郁/玉兎流/逆転/純化的味道/貧乏飯/洋食/" + "科学的/滑溜溜/平价食材/" * 3 + "软糯的/" * 5
CASE "料理：助手効果"
	RETURNF "闪耀/神力/魔界風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "古の/懐かしき/神代の/天空の/霊力の/金属风格的/退魔の/" + "懷舊的/和風の/太古の/聖域の/法界の/山吹の/" * 3 + "中世風の/始原の/黄金の/故郷の/" * 5 + "青銅の/菊の/反射の/" * 10
CASE "感性：嫌い"
	RETURNF "复古未来な/多彩な/塑料の/软乎乎の/蓬蓬鼓鼓の/诅咒の/量子の/" + "近未来風の/氷結の/" * 3 + "モダンな/锈迹の/" * 5
ENDSELECT


