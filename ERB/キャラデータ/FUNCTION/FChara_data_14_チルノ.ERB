@Fキャラデータ14(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "琪露諾"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：其他１"
	IF CURRENT_CLOTHES_SET(ARG) == 114 && DAY:2 == 2
		RETURNF @"{[[其他衣装_向日葵胸针]]}"
	ELSE
		RETURNF @"{[[其他衣装_蝴蝶结]]}"
	ENDIF
CASE "便装：其他２"
	SIF CURRENT_CLOTHES_SET(ARG) == 114 && DAY:2 == 2
		RETURNF @"{[[其他衣装_牵牛花]]}"

CASE "固有内衣形容詞"
	RETURNF "凉凉的"
CASE "固有下半身内衣名"
	RETURNF "冰精胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "冰精吊带衫"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[琪露諾]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

CASE "固有指令"
	RETURNF "买冰淇淋"
CASE "固有指令実行可能"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "青蛙/魚料理/汁物/冰淇淋/濃厚/野趣/豪快/滑溜溜/闪耀/" + "甜/冷/夏物/謎料理/" * 3
CASE "料理：讨厌的味道"
	RETURNF "鍋物/辣/辣/" + "野菜/香料/温暖/" * 3
CASE "料理：助手効果"
	RETURNF "氷結/得意料理＊夏物＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/かっこいい/ポップ/パワフル/ロリータ/壮大/" + "氷/夏の/" * 3 + "向日葵の/氷精の/氷の/氷結の/" * 5
CASE "感性：嫌い"
	RETURNF "赤/繊細/知的/" + "書物/烟袋/" * 3 + "火/" * 5

;農民関連
;最強とか天才とかそういう言葉が好きそう
;寒冷地の作物って感じがするしこの子に任せるっきゃない
;収穫した甜菜は紅魔館に出荷され砂糖に加工されるのであった
CASE "農民：説明"
	RETURNF "甜菜農家"
CASE "農民：作物"
	RETURNF "甜菜"
CASE "農民：田的种类"
	RETURNF "甜菜畑"
CASE "農民：畑の所在地"
	RETURNF "霧之湖"

CASE "農民：MapID"
	RETURNF "3"
CASE "農民：場所ID"
	RETURNF "343"
CASE "農民：報酬"
	RETURNF "250"
CASE "農民：金利"
	RETURNF "9"

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	RETURNF "2"
CASE "一般依頼発生率"
	RETURNF "3"
CASE "固有依頼発生率"
	RETURNF "5"
CASE "固有依頼最終要素"
	RETURNF "101"
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		CALLF 固有依頼14(ARG, O_DATA, V_NAME)
ENDSELECT


