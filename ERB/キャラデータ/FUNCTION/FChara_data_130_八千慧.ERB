@Fキャラデータ130(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "八千慧"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_龟壳]]}"

CASE "固有内衣形容詞"
	RETURNF "不能给人看的"
CASE "固有下半身内衣名"
	RETURNF "龟龟图案内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "龟甲胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[八千慧]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/香料/麺類/下酒菜/丰盛/健康/濃厚/冷/豪華/上品/怪诞/黏稠/畜生流/中華/中華/辣/辣/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "淡白/新鲜/甜/甜/虫肉/虫肉/虫肉/天界風/天界風/天界風/"
CASE "料理：助手効果"
	RETURNF "畜生流/幸運/得意料理＊中華＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "緑/高級/混沌/かわいい/奇妙/大陸風/別緻/知的/威厳/" + "水/宝石/美術品/" * 3 + "水獭の/龟の/龍の/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/ポップ/派手/ロリータ/" + "安物/神霊/" * 3 + "埴轮の/狼の/马の/鹫の/天馬の/埴轮/" * 10
ENDSELECT


