@Fキャラデータ8(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "千百合"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子+兜帽）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裤子"
	RETURNF @"{[[裤子_短裤]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_水手服]]}"

CASE "固有内衣形容詞"
	RETURNF "蓝白条"
CASE "固有下半身内衣名"
	RETURNF "水手风胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "水手风胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/香料/洋食/咖喱/油炸食品/丰盛/濃厚/謎料理/サクサク/魔力/化学的/" + "辣/機能的/" * 3
CASE "料理：讨厌的味道"
	RETURNF "野菜/淡白/" + "甜/" * 2 + "青蛙/" * 3
CASE "料理：助手効果"
	RETURNF "化学的/"
;贈り物関連
CASE "感性：好き"
	RETURNF "白/技術/かっこいい/未来/パワフル/知的/" + "書物/" * 3 + "錨の/人工制品/機械/" * 5
CASE "感性：嫌い"
	RETURNF "懷舊/繊細/ロリータ/威厳/" + "护臂/烟袋/" * 3

ENDSELECT


