@Fキャラデータ54(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "帕秋莉"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_魔导书]]}"

CASE "固有内衣形容詞"
	RETURNF "亲肤的"
CASE "固有下半身内衣名"
	RETURNF "雪纺内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "雪纺胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

CASE "固有泳装名"
	RETURNF "紫色比基尼套"
CASE "固有泳衣类型"
	;2连体泳衣、1分体泳衣
	RETURNF "2"
CASE "固有连身泳衣名"
	RETURNF "紫色死库水"
CASE "固有泳衣形容詞"
	RETURNF "诱人的"
CASE "固有下半身泳衣名"
	RETURNF "紫色比基尼内裤"
CASE "固有上半身泳衣"
	RETURNF "1"
CASE "固有上半身泳衣名"
	RETURNF "紫色比基尼胸罩"
CASE "固有泳衣着用条件"
	RETURNF "1"
CASE "固有泳衣半透明(前)"
	RETURNF "1"
CASE "固有泳衣半透明(後)"
	RETURNF "1"
CASE "固有泳衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	IF CFLAG:54:口上セレクタ == 2
		RETURNF "野菜/果物/蘑菇/葉物/酸/简易/健康/淡白/上品/機能的/新鲜/謎料理/黏稠/女僕流/洋食/洋食/" + "甜/" * 3
	ELSE
		RETURNF "野菜/果物/蘑菇/葉物/甜/简易/健康/淡白/上品/機能的/新鲜/謎料理/黏稠/女僕流/洋食/洋食/" + "酸/" * 3
	ENDIF
CASE "料理：讨厌的味道"
	RETURNF "肉料理/ジャンキー/咸/咸/丰盛/丰盛/丰盛/濃厚/濃厚/濃厚/"
CASE "料理：助手効果"
	RETURNF "彩り/隠し味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "虹/美的/シンプル/洋風/知的/" + "魔法/書物/" * 3 + "魔女の/賢者の/七曜の/知識の/魔法書/" * 5
CASE "感性：嫌い"
	RETURNF "和風/ロリータ/" + "刃物/护臂/" * 3
ENDSELECT


