@Fキャラデータ164(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "维缦"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（吊带睡裙）套"
	
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_无袖高领袍]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_布条]]}"

CASE "固有内衣形容詞"
	RETURNF "永恒轮回的"
CASE "固有下半身内衣名"
	RETURNF "莫比乌斯环胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "莫比乌斯环胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[维缦]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
;鹿だいしゅき、月都関連大嫌い
CASE "料理：喜欢的味道"
	RETURNF "野趣/" * 3 + "肉料理/和食/獣肉/旬/濃厚/質素/質素/"
CASE "料理：讨厌的味道"
	RETURNF "化学的/营养饮料/" + "機能的/" * 3 + "赏月/月都風/" * 5
CASE "料理：助手効果"
	RETURNF "神力/得意料理＊獣肉＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "自然/美的/獣の/山の/大地の/" + "神代の/過去の/自由の/" * 3 + "白蛇の/懐かしき/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/未来/知的/技術/機械/" + "量子の/電子工学の/近未来風の/フェムトファイバーの/" * 3 + "月/穢れなき/人工知能/" * 10 
ENDSELECT


