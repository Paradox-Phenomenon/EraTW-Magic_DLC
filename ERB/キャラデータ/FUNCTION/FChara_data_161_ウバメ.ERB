@Fキャラデータ161(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "姥芽"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（吊带睡裙）套"

CASE "便装：裙子"
	RETURNF @"{[[裙子_缠绳短裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_挂颈式露脐上衣]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_皇冠]]}"

CASE "固有内衣形容詞"
	RETURNF "圣域风格的"
CASE "固有下半身内衣名"
	RETURNF "拼布条胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "拼布条胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[姥芽]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
;ほぼネムノ
CASE "料理：喜欢的味道"
	RETURNF "辣/咸/" * 5 + "肉料理/" * 2 + "黏稠/野趣/油炸食品/魚料理/鍋物/下酒菜/丰盛/濃厚/質素/家庭的/"
CASE "料理：讨厌的味道"
	RETURNF "謎料理/" * 3 + "淡白/简易/甜/" * 2 + "面包/乳酪/外界風/洋食/"
CASE "料理：助手効果"
	RETURNF "母亲的味道/刺激的/得意料理＊肉料理＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "茶/美的/シンプル/パワフル/聖なる/自然/" + "秩序/力の/肉体の/" * 3 + "山の/聖域の/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/忘却の/宝石/派手/かわいい/" + "外界の/" * 5
ENDSELECT


