@Fキャラデータ147(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "萨丽艾尔"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_袖]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"	
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_魔法之杖]]}"

CASE "固有内衣形容詞"
	RETURNF "彰显堕落的"
CASE "固有下半身内衣名"
	RETURNF "渎圣内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "蕾丝全罩杯胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "天界風/魔界風/神力/牛奶/煮物/質素/简易/健康/淡白/豪華/芸術的/上品/软绵绵/地獄風/怪诞/謎料理/外界風/外界風/甜/甜/辣/辣/酸/"
CASE "料理：讨厌的味道"
	RETURNF "洋食/ジャンキー/濃厚/咸/咸/" + "青蛙/虫肉/" * 3 + "生命力/" * 5
CASE "料理：助手効果"
	RETURNF "神力/天界風/魔界風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/白/黒/秩序/美的/壮大/威厳/シンプル/大陸風/繊細/知的/天使の/天人の/天界の/書物/土/精神/" + "青/巫術/护符/翼の/羽飾/羽/聖なる/死神の/" * 3 + "穢れなき/運命の/死生/死の/生と死の/带来死亡の/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/奇妙/派手/パワフル/ロリータ/マニアック/" + "生体品/烟袋/" * 3 + "悪魔の/" * 10
ENDSELECT


