@Fキャラデータ42(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "果"

;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（吊带睡裙）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_兜巾]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_木屐]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_领带]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_翻盖手机]]}"

CASE "固有内衣形容詞"
	RETURNF "外界女生间流行的"
CASE "固有下半身内衣名"
	RETURNF "褶边胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "褶边胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/獣肉/虫肉/葉物/丰盛/濃厚/豪華/機能的/新鲜/软绵绵/天狗流/外界風/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "简易/辣/辣/卵/卵/卵/地底風/地底風/地底風/鳥肉/鳥肉/鳥肉/鳥肉/鳥肉/"
CASE "料理：助手効果"
	RETURNF "浓郁/"
;贈り物関連
CASE "感性：好き"
	RETURNF "紫/かわいい/時尚/ポップ/不思議/" + "風/鳥/文具/風の/硬幣/" * 3 + "鸦の/天狗の/疾風の/吊饰/钥匙扣/领带/" * 5
CASE "感性：嫌い"
	RETURNF "シンプル/懷舊/別緻/" + "刃物/弾/护臂/" * 3 + "龟の/河童の/鬼の/" * 10
;ENDSELECT
;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	RETURNF "0"
CASE "一般依頼発生率"
	RETURNF "2"
CASE "固有依頼発生率"
	RETURNF "8"
CASE "固有依頼最終要素"
	RETURNF "101"
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		RETURNF F固有依頼42(ARG, O_DATA, V_NAME)
ENDSELECT


