@Fキャラデータ80(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "阿求"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_发饰]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_行灯袴]]}"
CASE "便装：和服"
	RETURNF @"{[[和服_和服]]}"

CASE "固有内衣形容詞"
	RETURNF "100％亲肤的"
CASE "固有下半身内衣名"
	RETURNF "无边内裤"
CASE "固有上半身内衣"
	RETURNF "0"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/和食/葉物/简易/健康/淡白/芸術的/上品/家庭的/黏稠/外界風/甜/甜/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "辣/丰盛/ジャンキー/濃厚/" * 2 + "青蛙/香料/冥界風/地獄風/" * 3 + "謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "薄味/稗田家秘伝の味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "茶/美的/芸術的/懷舊/知的/" + "文具/書物/" * 3 + "記憶の/知識の/記録/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/パワフル/ロリータ/" + "火/刃物/生体品/护臂/烟袋/鼠の/" * 3 + "死神の/死の/忘却の/" * 10

;農民関連
;人里のとっぷに君臨する
CASE "農民：説明"
	RETURNF "米農家"
CASE "農民：作物"
	RETURNF "大米"
CASE "農民：田的种类"
	RETURNF "水田"
CASE "農民：畑の所在地"
	RETURNF "人里"

CASE "農民：MapID"
	RETURNF "2"
CASE "農民：場所ID"
	RETURNF "206"
CASE "農民：報酬"
	RETURNF "550"
CASE "農民：金利"
	RETURNF "9"
ENDSELECT


