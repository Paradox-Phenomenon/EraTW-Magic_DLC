@Fキャラデータ129(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "久侘歌"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_长靴]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_丝帯项链]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_雛雞]]}"

CASE "固有内衣形容詞"
	RETURNF "会发出啾啾声的"
CASE "固有下半身内衣名"
	RETURNF "雏鸡胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "雏鸡胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/米/葉物/简易/淡白/質素/上品/新鲜/软绵绵/冥界風/甜/甜/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "油炸食品/丰盛/濃厚/咸/咸/青蛙/青蛙/青蛙/" + "謎料理/" * 5 + "鳥肉/卵/" * 10
CASE "料理：助手効果"
	RETURNF "冥界風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黄/秩序/美的/ポップ/繊細/" + "鳥/" * 3 + "鸡の/勇気の/蛋の/卵/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/奇妙/マニアック/" + "弾/护臂/生体品/機械/" * 3 + "鸦の/" * 10
ENDSELECT


