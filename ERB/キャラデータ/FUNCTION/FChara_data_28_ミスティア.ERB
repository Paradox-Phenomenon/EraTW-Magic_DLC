@Fキャラデータ28(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "米斯蒂亜"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_长筒袜]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "固有指令"
	RETURNF "路边摊吃饭"
CASE "固有指令実行可能"
	RETURNF @"{CFLAG:28:行動 == 5 && BASE:28:工作量 < 3000 && CFLAG:28:職種 == 44}" ;bugfix custom code, only while actually working at stall

;ソング＝Ｔ字褲
CASE "固有内衣形容詞"
	RETURNF "双翼装饰的"
CASE "固有下半身内衣名"
	RETURNF "丁字裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "半罩杯胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[米斯蒂亜]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/煮物/下酒菜/濃厚/野趣/家庭的/新鲜/サクサク/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "油炸食品/辣/辣/卵/卵/卵/" + "鳥肉/" * 10
CASE "料理：助手効果"
	RETURNF "得意料理＊魚料理＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黒/かわいい/ポップ/" + "闇/音楽/食器/" * 3 + "雀の/毒蛾の/" * 5
CASE "感性：嫌い"
	RETURNF "光/弾/护臂/機械/" * 3 + "精霊銀の/" * 10
ENDSELECT


