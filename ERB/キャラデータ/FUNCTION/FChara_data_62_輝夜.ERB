@Fキャラデータ62(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "輝夜"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_上衣]]}"

;神様が織った布の胖次とか月じゃ普通だと思う
CASE "固有内衣形容詞"
	RETURNF "星芒纹饰的"
CASE "固有下半身内衣名"
	RETURNF "纺织胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "纺织胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[輝夜]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/豆沙/果物/和食/鍋物/简易/淡白/芸術的/上品/新鲜/软糯的/月都風/赏月/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "野趣/酸/酸/" + "質素/外界風/" * 3 + "青蛙/虫肉/謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "月都風/彩り/上品/"
;贈り物関連
CASE "感性：好き"
	RETURNF "虹/高級/秩序/美的/芸術的/不思議/威厳/" + "月/宝石/遺物/" * 3 + "蓬莱の/永遠の/須臾の/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/シンプル/ポップ/" + "火/安物/死生/生体品/护臂/" * 3 + "鳳凰の/" * 10
ENDSELECT


