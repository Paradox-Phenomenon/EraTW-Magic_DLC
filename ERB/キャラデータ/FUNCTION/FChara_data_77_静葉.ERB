@Fキャラデータ77(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "静葉"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_发饰]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"

CASE "固有内衣形容詞"
	RETURNF "体现秋末的"
CASE "固有下半身内衣名"
	RETURNF "红叶胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "红叶胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/米/香料/葉物/简易/健康/淡白/芸術的/野趣/新鲜/サクサク/甜/甜/辣/辣/秋物/秋物/秋物/秋物/秋物/"
CASE "料理：讨厌的味道"
	RETURNF "ジャンキー/濃厚/咸/咸/" + "青蛙/虫肉/冬物/" * 3 + "謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "絢爛/得意料理＊秋物＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "美的/芸術的/和風/派手/繊細/" + "朱/風/植物/美術品/" * 3 + "紅葉の/秋の/秋風の/" * 5
CASE "感性：嫌い"
	RETURNF "威厳/" + "氷/刃物/弾/护臂/機械/" * 3 + "夏の/樱花の/向日葵の/西瓜の/" * 5  + "春の/冬の/春風の/" * 10

;農民関連
;葡萄がついてるのは妹のほうだが
;葡萄ならオサレ感あるし紅葉もするし果実も色づくし
;変えるなら穣子を葡萄にして静葉は漆（非食用の有用植物、かつ紅葉する）とか？？？
CASE "農民：説明"
	RETURNF "山葡萄農家"
CASE "農民：作物"
	RETURNF "山葡萄"
CASE "農民：田的种类"
	RETURNF "山葡萄畑"
CASE "農民：畑の所在地"
	RETURNF "妖怪之山・山麓"

CASE "農民：MapID"
	RETURNF "7"
CASE "農民：場所ID"
	RETURNF "715"
CASE "農民：報酬"
	RETURNF "400"
CASE "農民：金利"
	RETURNF "4"
ENDSELECT


