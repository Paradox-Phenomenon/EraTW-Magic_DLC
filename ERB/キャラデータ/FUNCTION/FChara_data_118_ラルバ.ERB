@Fキャラデータ118(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "拉尔瓦"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"

CASE "固有内衣形容詞"
	RETURNF "闪耀翠绿的"
CASE "固有下半身内衣名"
	RETURNF "鳞粉内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "吊带小背心"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "葉物/饮用/简易/夏物/芸術的/野趣/新鲜/滑溜溜/野菜/野菜/甜/甜/甜/"
CASE "料理：讨厌的味道"
	RETURNF "丰盛/咸/咸/肉料理/肉料理/肉料理/魚料理/魚料理/魚料理/" + "虫肉/" * 10
CASE "料理：助手効果"
	RETURNF "得意料理＊夏物＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黄/かわいい/ポップ/派手/ロリータ/" + "虫/" * 3  + "揚羽蝶の/向日葵の/夏の/" * 5
CASE "感性：嫌い"
	RETURNF "別緻/知的/" + "氷/鳥/烟袋/" * 3 + "蜘蛛糸の/蜘蛛の/冬の/" * 10
ENDSELECT


