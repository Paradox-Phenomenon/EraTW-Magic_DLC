@Fキャラデータ58(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "美鈴"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"
CASE "特殊衣装着用"
	SIF (TALENT:58:恋慕 || TALENT:58:炮友) && CFLAG:58:积攒度 >= 700 ;&& CURRENT_CLOTHES_SET(58) == 158
		RETURNF "73"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裤子"
	RETURNF @"{[[裤子_裤子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_旗袍]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_蝴蝶结]]}"

CASE "固有内衣形容詞"
	RETURNF "无痕的"
CASE "固有下半身内衣名"
	RETURNF "高叉胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "运动文胸"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[美鈴]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "2"
;特殊衣装
CASE "デート衣装", "人里デート衣装", "おうちデート衣装"
	RETURNF @"{[[生足美鈴套]]}"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/香料/油炸食品/丰盛/濃厚/芸術的/野趣/新鲜/软糯的/女僕流/中華/中華/" + "辣/" * 3
CASE "料理：讨厌的味道"
	RETURNF "酸/酸/淡白/淡白/淡白/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "得意料理＊中華＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/虹/秩序/美的/大陸風/パワフル/" + "七色の/極彩の/龍の/" * 5
CASE "感性：嫌い"
	RETURNF "知的/洋風/" + "刃物/弾/" * 3 + "小刀/" * 10
ENDSELECT


