@Fキャラデータ128(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "潤美"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_无袖服]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_羽织]]}"
CASE "便装：裤子"
	RETURNF @"{[[裤子_短裤]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_石像]]}"

CASE "固有内衣形容詞"
	RETURNF "田园风的"
CASE "固有下半身内衣名"
	RETURNF "牛图案胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "牛图案胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

CASE "固有指令"
	IF 成人再教育插件开关 == 1
		RETURNF "与润美对话"
	ELSE
		RETURNF "鱼的交换"
	ENDIF
CASE "固有指令実行可能"
	RETURNF "1"
CASE "固有指令：鱼的交换比率"
	RETURNF @"{MAX(5, 10 - ABL:[[潤美]]:親密)}"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/虫肉/煮物/下酒菜/丰盛/豪華/野趣/家庭的/サクサク/辣/辣/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "酸/酸/青蛙/青蛙/青蛙/小人族秘伝の味/小人族秘伝の味/小人族秘伝の味/"
CASE "料理：助手効果"
	RETURNF "冥界風/得意料理＊魚＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "茶/かわいい/シンプル/別緻/" + "魚/人形/鬼の/" * 3 + "石の/深海魚の/古代魚の/" * 5
CASE "感性：嫌い"
	RETURNF "ポップ/派手/ロリータ/マニアック/"
ENDSELECT


