@Fキャラデータ71(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "針妙丸"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_小碗]]}"
CASE "便装：和服"
	RETURNF @"{[[和服_和服]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_肌襦袢]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_帯]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_针]]}"
CASE "便装：其他３"
	RETURNF @"{[[其他衣装_小槌]]}"

CASE "固有内衣形容詞"
	RETURNF "变大变小都合身的"
CASE "固有下半身内衣名"
	RETURNF "小人胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "小人吊带衫"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[針妙丸]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/卵/和食/葉物/ジャンキー/豪華/上品/新鲜/软绵绵/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "質素/辣/辣/謎料理/謎料理/謎料理/" + "青蛙/虫肉/鬼の魔力/" * 5
CASE "料理：助手効果"
	RETURNF "得意料理＊上品＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "白/秩序/かっこいい/時尚/ポップ/繊細/巫術/" + "装飾/" * 3 + "小人の/小小の/針/茶碗/" * 5
CASE "感性：嫌い"
	RETURNF "パワフル/知的/" + "烟袋/" * 3 + "鬼の/鬼力の/" * 10

;農民関連
;ころぽっくる
CASE "農民：説明"
	RETURNF "蕗農家"
CASE "農民：作物"
	RETURNF "蜂鬥葉"
CASE "農民：田的种类"
	RETURNF "蕗畑"
CASE "農民：畑の所在地"
	RETURNF "博麗神社"

CASE "農民：MapID"
	RETURNF "0"
CASE "農民：場所ID"
	RETURNF "22"
CASE "農民：報酬"
	RETURNF "350"
CASE "農民：金利"
	RETURNF "3"
ENDSELECT


