@Fキャラデータ165(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "阿梨夜"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（吊带睡裙）套"
	
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_斗篷]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_石假面]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_化石]]}"

CASE "固有内衣形容詞"
	RETURNF "掌管不变的"
CASE "固有下半身内衣名"
	RETURNF "始祖鸟胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "始祖鸟胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[阿梨夜]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
;変化に関連することが嫌い
CASE "料理：喜欢的味道"
	RETURNF "質素/" * 5 + "野雞肉/竜骨/上品/地底風/サクサク/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "旬/旬/春物/夏物/秋物/冬物/生命力/月都風/"
CASE "料理：助手効果"
	RETURNF "神力/不変/"
;贈り物関連
CASE "感性：好き"
	RETURNF "かっこいい/化石/骨/土/鉱物/" + "石の/面/假面/孤独の/神霊/" * 3 + "永遠の/不滅の/不変の/" * 5
CASE "感性：嫌い"
	RETURNF "美的/木の/花の/華の/四季の/" + "破滅の/" * 3 + "刹那の/須臾の/" * 10
ENDSELECT


