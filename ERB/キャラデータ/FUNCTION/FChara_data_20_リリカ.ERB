@Fキャラデータ20(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "莉莉卡"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_背心]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_键盘]]}"

CASE "固有内衣形容詞"
	RETURNF "星空图样的"
CASE "固有下半身内衣名"
	RETURNF "纯棉胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "运动文胸"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[莉莉卡]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "面包/香料/洋食/麺類/派/濃厚/豪華/芸術的/新鲜/サクサク/咸/咸/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "野菜/質素/辣/辣/"
CASE "料理：助手効果"
	RETURNF "隠し味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/幽霊/かわいい/" + "音楽/星/楽器/" * 3 + "虹の/幽霊の/幻想の/三位一体の/" * 5
CASE "感性：嫌い"
	RETURNF "日/月/刃物/弾/护臂/烟袋/" * 3 + "精霊銀の/" * 10
ENDSELECT

