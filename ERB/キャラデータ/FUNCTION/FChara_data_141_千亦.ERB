@Fキャラデータ141(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "千亦"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（连衣裙）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_发箍]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_斗篷]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_长靴]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_斜挎包]]}"

CASE "固有内衣形容詞"
	RETURNF "特制的"
CASE "固有下半身内衣名"
	RETURNF "彩虹内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "彩虹胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[千亦]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "香料/香料/香料/果物/果物/果物/煮物/蛋糕/甜/甜/酸/酸/豪華/芸術的/新鲜/滑溜溜/闪耀/"
CASE "料理：讨厌的味道"
	RETURNF "辣/辣/質素/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "彩り/"
;贈り物関連
CASE "感性：好き"
	RETURNF "虹/秩序/美的/芸術的/派手/不思議/壮大/マニアック/" + "巫術/七色の/" * 3 + "虹の/月虹の/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/別緻/" + "闇/" * 3
ENDSELECT


