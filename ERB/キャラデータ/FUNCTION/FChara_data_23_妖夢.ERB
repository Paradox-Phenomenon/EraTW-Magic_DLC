@Fキャラデータ23(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "妖夢"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_发箍]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_背心]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_刀]]}"

CASE "固有内衣形容詞"
	RETURNF "重视运动的"
CASE "固有下半身内衣名"
	RETURNF "紧身裤"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[妖夢]])))
		RETURNF "1"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "运动文胸"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "卵/米/煮物/酸/淡白/春物/質素/上品/家庭的/软糯的/妖力/冥界風/和食/和食/甜/甜/甜/"
CASE "料理：讨厌的味道"
	RETURNF "面包/洋食/霊障/辣/辣/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/" + "怪诞/謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "切れ味/冥界風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "緑/秩序/かわいい/和風/別緻/" + "幽霊/死生/刃物/" * 3 + "冥界の/幽明の/幽霊の/魂の/生と死の/懐剣/護刀/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/可怕的/奇妙/洋風/知的/威厳/" + "弾/生体品/烟袋/機械/" * 3

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	RETURNF "2"
CASE "一般依頼発生率"
	RETURNF "3"
CASE "固有依頼発生率"
	RETURNF "5"
CASE "固有依頼最終要素"
	RETURNF "101"
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		RETURNF F固有依頼23(ARG, O_DATA, V_NAME)
ENDSELECT


