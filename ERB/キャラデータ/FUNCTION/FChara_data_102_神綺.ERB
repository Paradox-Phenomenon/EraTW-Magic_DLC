@Fキャラデータ102(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "神綺"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（吊带睡裙）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_披肩领长裙]]}"

CASE "固有内衣形容詞"
	RETURNF "无法创造出来的"
CASE "固有下半身内衣名"
	RETURNF "魔神胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "魔神胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"
;特殊衣装
CASE "デート衣装", "人里デート衣装", "おうちデート衣装"
	RETURNF @"{[[浴衣穿搭]]}"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "面包/香料/洋食/鍋物/派/简易/健康/豪華/上品/家庭的/软糯的/魔力/女僕流/魔界風/甜/甜/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "中華/丰盛/質素/酸/酸/" + "青蛙/虫肉/謎料理/" * 3
CASE "料理：助手効果"
	RETURNF "魔界風/母亲的味道/"
;贈り物関連
CASE "感性：好き"
	RETURNF "白/高級/混沌/美的/威厳/壮大/" + "魔法/妖術/" * 3 + "魔界蝶の/魔神の/魔界の/神話の/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/ロリータ/マニアック/" + "安物/巫術/" * 3
ENDSELECT

