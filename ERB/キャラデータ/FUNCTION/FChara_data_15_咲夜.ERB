@Fキャラデータ15(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "咲夜"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（吊带睡裙）套"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_女仆发箍]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	IF FLAG:2 > 0
		RETURNF @"{[[襪子_吊带袜]]}"
	ELSE
		RETURNF @"{[[襪子_长筒袜]]}"
	ENDIF
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_围裙洋装]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_蝴蝶结]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_小刀]]}"

CASE "固有内衣形容詞"
	RETURNF "带吊带的"
CASE "固有下半身内衣名"
	RETURNF "高级丝绸胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "高级丝绸胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[咲夜]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"
;特殊衣装
CASE "デート衣装", "人里デート衣装", "おうちデート衣装"
	RETURNF @"{[[外出女仆套装]]}"

CASE "固有指令"
	RETURNF "红魔馆出差服务"
CASE "固有指令実行可能"
	IF TFLAG:上门清扫 && (FLAG:澆水代行 || !ITEM:150)
	ELSEIF MAIN_MAP == MAP湖
	ELSE
		RETURNF "1"
	ENDIF

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/香料/中華/煮物/甜/淡白/豪華/上品/家庭的/サクサク/絢爛/" + "酸/" * 3
CASE "料理：讨厌的味道"
	RETURNF "質素/野趣/咸/咸/虫肉/虫肉/虫肉/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "隠し味/秘術/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/美的/シンプル/洋風/別緻/" + "钟表/食器/" * 3 + "瀟洒な/女僕的/時の/時空の/怀表/小刀/" * 5
CASE "感性：嫌い"
	RETURNF "パワフル/ロリータ/" + "烟袋/" * 3

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	RETURNF "2"
CASE "一般依頼発生率"
	RETURNF "3"
CASE "固有依頼発生率"
	RETURNF "5"
CASE "固有依頼最終要素"
	RETURNF "101"
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		CALLF 固有依頼15(ARG, O_DATA, V_NAME)
ENDSELECT


