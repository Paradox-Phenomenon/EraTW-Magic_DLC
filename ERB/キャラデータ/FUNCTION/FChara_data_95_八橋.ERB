@Fキャラデータ95(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "八橋"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_发箍]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_琴弦]]}"

CASE "固有内衣形容詞"
	RETURNF "古着改造的"
CASE "固有下半身内衣名"
	RETURNF "宽松的系带短裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "素朴的系带胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[八橋]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/肉料理/和食/煮物/濃厚/豪華/芸術的/家庭的/滑溜溜/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "淡白/辣/辣/" + "青蛙/虫肉/蘑菇/怪诞/謎料理/" * 3
CASE "料理：助手効果"
	RETURNF "浓郁/"
;贈り物関連
CASE "感性：好き"
	RETURNF "茶/かわいい/芸術的/和風/別緻/" + "音楽/楽器/" * 3 + "嵐の/旋律の/爪/拨片/" * 5
CASE "感性：嫌い"
	RETURNF "洋風/繊細/" + "刃物/生体品/护臂/" * 3 + "鼓槌/指揮棒/" * 5 + "精霊銀の/" * 10
ENDSELECT


