@Fキャラデータ73(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "蛮奇"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：外搭"
	RETURNF @"{[[外搭_披肩斗篷]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：其他１"
;とりあえず冬限定にしてみる
	SIF DAY:2 == 4
		RETURNF @"{[[其他衣装_围巾]]}"

CASE "固有内衣形容詞"
	RETURNF "色彩柔和的"
CASE "固有下半身内衣名"
	RETURNF "淡红色胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "淡红色胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[蛮奇]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "卵/香料/中華/汁物/简易/ジャンキー/淡白/機能的/上品/新鲜/软糯的/辣/辣/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "米/丰盛/野趣/酸/酸/"
CASE "料理：助手効果"
	RETURNF "薄味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "かわいい/時尚/大陸風/別緻/マニアック/" + "赤/" * 3 + "騎士の/斗篷/面罩/" * 5
CASE "感性：嫌い"
	RETURNF "派手/知的/ロリータ/" + "書物/" * 3

;農民関連
;首が落ちる＋赤色
;あんま人付き合いなさそうだけど一応
CASE "農民：説明"
	RETURNF "椿農家"
CASE "農民：作物"
	RETURNF "椿油"
CASE "農民：田的种类"
	RETURNF "椿農園"
CASE "農民：畑の所在地"
	RETURNF "人里"

CASE "農民：MapID"
	RETURNF "2"
CASE "農民：場所ID"
	RETURNF "206"
CASE "農民：報酬"
	RETURNF "350"
CASE "農民：金利"
	RETURNF "6"
ENDSELECT


