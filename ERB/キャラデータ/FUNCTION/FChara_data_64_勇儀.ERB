@Fキャラデータ64(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "勇儀"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：靴"
	RETURNF @"{[[靴_木屐]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_拘束具]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_酒杯]]}"

CASE "固有内衣形容詞"
	RETURNF "超强的"
CASE "固有下半身内衣名"
	RETURNF "虎皮鬼胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "裹胸"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[勇儀]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "3"

;特殊衣装
CASE "デート衣装", "人里デート衣装", "おうちデート衣装"
	RETURNF @"{[[勇仪和服套装]]}"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/香料/和食/鍋物/下酒菜/辣/丰盛/濃厚/芸術的/野趣/豪快/サクサク/地底風/天狗流/" + "咸/" * 3
CASE "料理：讨厌的味道"
	RETURNF "简易/淡白/甜/甜/謎料理/謎料理/謎料理/化学的/化学的/化学的/" + "小人族秘伝の味/" * 5
CASE "料理：助手効果"
	RETURNF "地底風/得意料理＊豪快＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/金/混沌/かっこいい/パワフル/壮大/" + "食器/鎖の/酒/" * 3 + "鬼の/華の/鬼力の/力の/" * 5
CASE "感性：嫌い"
	RETURNF "精神/ポップ/繊細/知的/ロリータ/" + "刃物/弾/書物/機械/" * 3 + "河童の/天狗の/" * 10
ENDSELECT


