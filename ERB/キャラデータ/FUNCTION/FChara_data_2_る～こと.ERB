@Fキャラデータ2(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "留琴"

;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_女仆发箍]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_长筒袜]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_围裙洋装]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_扫把]]}"

CASE "固有内衣形容詞"
	RETURNF "崭新的"
CASE "固有下半身内衣名"
	RETURNF "纯白胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "纯白胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "牛奶/和食/煮物/派/健康/質素/機能的/家庭的/サクサク/科学的/甜/甜/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "油炸食品/辣/咸/妖力/霊障/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "化学的/得意料理＊家庭的＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "銀/秩序/かわいい/シンプル/未来/別緻/" + "金属/食器/" * 3 + "女僕的/机械装置の/箒/機械/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/奇妙/派手/不思議/威厳/" + "生体品/护臂/" * 3

ENDSELECT


