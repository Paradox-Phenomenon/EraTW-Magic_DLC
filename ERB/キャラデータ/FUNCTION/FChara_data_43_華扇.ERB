@Fキャラデータ43(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "華扇"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_束发簪]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_道士服]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_绷带]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_拘束具]]}"

CASE "固有内衣形容詞"
	RETURNF "淡粉色的"
CASE "固有下半身内衣名"
	RETURNF "褶边短裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "褶边胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;;addition custom code
;CASE "固有下着SHIFTABLE"
;	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/米/中華/油炸食品/下酒菜/丰盛/濃厚/上品/新鲜/豪快/软糯的/仙術/地底風/地獄風/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "淡白/酸/酸/冥界風/冥界風/冥界風/" + "謎料理/小人族秘伝の味/" * 5
CASE "料理：助手効果"
	RETURNF "浓郁/得意料理＊中華＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/秩序/美的/大陸風/知的/" + "動物/食器/生体品/鎖の/幻獣の/ドラゴンの/酒/" * 3 + "鬼の/龍の/仙人の/鬼力の/茨の/華の/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/ポップ/ロリータ/" + "機械/" * 3 + "河童の/天狗の/" * 10

;特殊衣装設定、おうちデートで稀にみこかせん
CASE "おうちデート衣装"
	SIF MAIN_MAP == 0 && !RAND:15
		RETURNF "101"
ENDSELECT


