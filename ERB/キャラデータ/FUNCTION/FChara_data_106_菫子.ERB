@Fキャラデータ106(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "菫子"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：飾品"
	RETURNF @"{[[飾品_眼鏡]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_长筒袜]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_水手服]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_斗篷]]}"

CASE "固有内衣形容詞"
	RETURNF "对女高中生来说非常土的"
CASE "固有下半身内衣名"
	RETURNF "普通内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "素色文胸"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[菫子]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "面包/乳酪/洋食/汁物/派/ジャンキー/豪華/上品/家庭的/软绵绵/霊障/夢幻風/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "酸/酸/" + "青蛙/虫肉/怪诞/謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "秘術/"
;贈り物関連
CASE "感性：好き"
	RETURNF "高級/混沌/かっこいい/奇妙/ポップ/不思議/マニアック/" + "紫/眼鏡/遺物/" * 3 + "オカルティックな/堇の/夢の/斗篷/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/懷舊/" + "刃物/弾/生体品/护臂/烟袋/" * 3 + "外界の/悪夢の/" * 10
ENDSELECT


