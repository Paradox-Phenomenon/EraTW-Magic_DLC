@Fキャラデータ116(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "夢月"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_长筒袜]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_女仆发箍]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_围裙洋装]]}"

CASE "固有内衣形容詞"
	RETURNF "像女仆的"
CASE "固有下半身内衣名"
	RETURNF "花纹白蕾丝内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "花纹白蕾丝胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "面包/卵/洋食/汁物/蛋糕/简易/淡白/豪華/上品/新鲜/软绵绵/夢幻風/甜/甜/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "野趣/咸/咸/" + "青蛙/虫肉/香料/" * 3 + "謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "夢幻風/女僕流/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/混沌/かわいい/洋風/別緻/威厳/" + "妖術/禁断の/" * 3 + "女僕的/夢幻の/悪魔の/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/和風/派手/" + "神霊/" * 3
ENDSELECT

