@Fキャラデータ16(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "蕾米莉亜"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍）套"

CASE "便装：飾品"
	RETURNF @"{[[飾品_傘]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_发圈]]}"

CASE "固有内衣形容詞"
	RETURNF "非常高级的"
CASE "固有下半身内衣名"
	RETURNF "蕾丝胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "蕾丝吊带衫"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[蕾米莉亜]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "高级食材/汁物/蛋糕/濃厚/豪華/上品/新鲜/软绵绵/女僕流/外界風/赏月/洋食/洋食/甜/甜/甜/"
CASE "料理：讨厌的味道"
	RETURNF "和食/简易/ジャンキー/淡白/野趣/" + "平价食材/青蛙/虫肉/質素/" * 3 + "辣/" * 4  + "謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "得意料理＊洋食＊/絢爛/"

;贈り物関連
CASE "感性：好き"
	RETURNF "高級/宝石/混沌/かわいい/奇妙/洋風/派手/ロリータ/威厳/" + "赤/血/美術品/人形/" * 3 + "永远鲜红の/蝠の/悪魔の/紅魔の/満月の/血の/運命の/傘/" * 5
CASE "感性：嫌い"
	RETURNF "青/秩序/シンプル/和風/繊細/" + "安物/水/光/护符/护臂/烟袋/女僕的/" * 3 + "日/太陽石の/" * 5
;農民関連
;西洋っぽいので小麦の供給元に
;霧之湖近辺は冷害が可怕的
CASE "農民：説明"
	RETURNF "小麦農家"
CASE "農民：作物"
	RETURNF "小麦"
CASE "農民：田的种类"
	RETURNF "小麦畑"
CASE "農民：畑の所在地"
	RETURNF "紅魔館"

CASE "農民：MapID"
	RETURNF "3"
CASE "農民：場所ID"
	RETURNF "301"
CASE "農民：報酬"
	RETURNF "600"
CASE "農民：金利"
	RETURNF "16"
ENDSELECT


