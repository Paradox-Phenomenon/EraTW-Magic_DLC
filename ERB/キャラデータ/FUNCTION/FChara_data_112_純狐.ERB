@Fキャラデータ112(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "純狐"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_冕冠]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_道士服]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_帯]]}"

CASE "固有内衣形容詞"
	RETURNF "突出臀部线条的"
CASE "固有下半身内衣名"
	RETURNF "修身内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "蕾丝胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[純狐]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "青蛙/肉料理/卵/中華/汁物/简易/芸術的/上品/新鲜/黏稠/地獄風/咸/咸/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "野趣/甜/甜/虫肉/虫肉/虫肉/謎料理/謎料理/謎料理/謎料理/謎料理/" + "月都風/赏月/" * 10
CASE "料理：助手効果"
	RETURNF "純化的味道/得意料理＊中華＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "白/美的/シンプル/大陸風/別緻/威厳/" + "光/宝石/" * 3 + "百合の/神霊の/純粋の/殺意の/" * 5
CASE "感性：嫌い"
	RETURNF "ポップ/ロリータ/マニアック/" + "黄/安物/生体品/" * 3 + "月/海神の/" * 10
ENDSELECT


