@Fキャラデータ3(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "卡娜"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_围裙洋装]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_晚宴手套]]}"

CASE "固有内衣形容詞"
	RETURNF "猫咪图案的"
CASE "固有下半身内衣名"
	RETURNF "印花胖次(猫)"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "吊带小背心"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "面包/牛奶/汁物/派/咸/简易/淡白/上品/新鲜/サクサク/外界風/洋食/洋食/甜/甜/甜/謎料理/謎料理/謎料理/"
CASE "料理：讨厌的味道"
	RETURNF "和食/丰盛/野趣/辣/辣/虫肉/虫肉/虫肉/"
CASE "料理：助手効果"
	RETURNF "薄味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "白/混沌/かわいい/洋風/ポップ/不思議/" + "鳥/幽霊/" * 3 + "夢の/逝去的/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/別緻/知的/" + "日/护符/書物/护臂/" * 3
ENDSELECT

