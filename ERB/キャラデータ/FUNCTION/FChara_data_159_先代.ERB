@Fキャラデータ159(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "先代"

;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：飾品"
	RETURNF @"{[[飾品_袖]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	IF FLAG:2 > 0
		RETURNF @"{[[襪子_长筒袜]]}"
	ELSE
		RETURNF @"{[[襪子_袜子]]}"
	ENDIF
CASE "便装：裙子"
	RETURNF @"{[[裙子_行灯袴]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_博麗的巫女服]]}"
	
CASE "固有指令"
	RETURNF "特殊训练"
CASE "固有指令実行可能"
	RETURNF "1"
	

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/辣/洋食/葉物/简易/淡白/質素/上品/家庭的/软绵绵/" + "甜/酸/" * 2 + "春物/煎餅/" * 3
CASE "料理：讨厌的味道"
	RETURNF "/妖力/" * 2 + "怪诞/謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "薄味/得意料理＊和食＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/秩序/かわいい/和風/" + "神霊/巫術/护符/狐の/春の/永遠の/" * 3 + "蓮華蝶の/樱花の/巫女の/楽園の/封魔の/パワフル/かっこいい/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/洋風/ロリータ/マニアック/" + "妖術/" * 3 + "烟袋/" * 5 + "守矢の/妖怪の/" * 10

CASE "固有内衣形容詞"
	RETURNF "放出奇怪的光泽"
CASE "固有下半身内衣名"
	RETURNF "丝绸内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "丝绸内衣"
CASE "固有内衣着用条件"
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;農民関連
;神社は土地持ってそう、神田
CASE "農民：説明"
	RETURNF "米農家"
CASE "農民：作物"
	RETURNF "大米"
CASE "農民：田的种类"
	RETURNF "水田"
CASE "農民：畑の所在地"
	RETURNF "博麗神社"

CASE "農民：MapID"
	RETURNF "0"
CASE "農民：場所ID"
	RETURNF "22"
CASE "農民：報酬"
	RETURNF "800"
CASE "農民：金利"
	RETURNF "5"

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	RETURNF "2"
CASE "一般依頼発生率"
	RETURNF "3"
CASE "固有依頼発生率"
	RETURNF "5"
CASE "固有依頼最終要素"
	RETURNF "102"
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		RETURNF F固有依頼159(ARG, O_DATA, V_NAME)

;固有Counterテスト


ENDSELECT


