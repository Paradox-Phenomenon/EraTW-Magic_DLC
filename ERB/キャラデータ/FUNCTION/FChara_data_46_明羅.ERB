@Fキャラデータ46(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "明羅"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：靴"
	RETURNF @"{[[靴_雪駄]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_足袋]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_肩衣]]}"
CASE "便装：和服"
	RETURNF @"{[[和服_小袖]]}"
CASE "便装：裤子"
	RETURNF @"{[[裤子_袴]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_刀]]}"

CASE "固有内衣形容詞"
	RETURNF "古代宽松的"
CASE "固有下半身内衣名"
	RETURNF "畚兜裆布"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "裹胸"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[明羅]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/米/油炸食品/简易/淡白/豪華/野趣/豪快/软糯的/和食/和食/辣/辣/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "洋食/濃厚/甜/甜/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "切れ味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/美的/和風/別緻/" + "闇/刃物/" * 3 + "博霊の/懐剣/護刀/护臂/闇の/" * 5
CASE "感性：嫌い"
	RETURNF "奇妙/洋風/ポップ/派手/ロリータ/"
ENDSELECT

