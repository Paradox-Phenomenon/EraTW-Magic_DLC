@Fキャラデータ158(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "瑞霊"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_发饰]]}"
CASE "便装：裙子"
	;神社节庆日
	IF GROUPMATCH(FESTIVAL(),"例大祭", "元旦", "女兒節", "七夕", "盂蘭盆節", "風神「二百十日」", "十五夜", "収穫祭", "節分", "大晦日") || FLAG:9 % 8 == 0
		RETURNF @"{[[裙子_裙子]]}"
	ELSE
		RETURNF @"{[[裙子_囚犯裙子]]}"
	ENDIF
CASE "便装：上身衣服１"
	;神社节庆日
	IF GROUPMATCH(FESTIVAL(),"例大祭", "元旦", "女兒節", "七夕", "盂蘭盆節", "風神「二百十日」", "十五夜", "収穫祭", "節分", "大晦日") || FLAG:9 % 8 == 0
		RETURNF @"{[[上身衣服_はだけ不可_博麗的巫女服]]}"
	ELSE
	ENDIF
CASE "便装：上身衣服２"
	;神社节庆日
	IF GROUPMATCH(FESTIVAL(),"例大祭", "元旦", "女兒節", "七夕", "盂蘭盆節", "風神「二百十日」", "十五夜", "収穫祭", "節分", "大晦日") || FLAG:9 % 8 == 0
	ELSE
		RETURNF @"{[[上身衣服_はだけ可能_囚犯衬衫]]}"
	ENDIF
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_拘束具]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_手铐]]}"
CASE "固有内衣形容詞"
	RETURNF "黑白条纹的"
CASE "固有下半身内衣名"
	RETURNF "囚犯胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "纯黑吊带背心"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "香料/肉料理/和風/汁物/咸/豪華/上品/豪快/辣/辣/辣/玉兎流/謎料理/"
CASE "料理：讨厌的味道"
	RETURNF "中華/甜/丰盛/濃厚/質素/魔界風/魔界風/魔界風/天狗流/简易/淡白/"
CASE "料理：助手効果"
	RETURNF "謎料理/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黒/妖怪/可怕的/知的/" + "幽霊/魔法/闇/懷舊/混沌/法具/伝来の/" * 3 + "闇の/機力の/" * 5 + "渴血の/殺意の/" * 10
CASE "感性：嫌い"
	RETURNF "未来/異国風の/神霊/" + "护符/靴/封呪の/" * 3 + "妖怪の/地霊の/廃獄の/地底の/" * 5 + "巫女の/博霊の/怒りの/退魔の/" * 10
ENDSELECT

