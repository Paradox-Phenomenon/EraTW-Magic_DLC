@Fキャラデータ131(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "磨弓"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_鎧]]}"
CASE "便装：裤子"
	RETURNF @"{[[裤子_袴]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_金屬護手]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_胸针]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_杖刀]]}"

CASE "固有内衣形容詞"
	RETURNF "古坟时代的"
CASE "固有下半身内衣名"
	RETURNF "埴轮胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "埴轮胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[磨弓]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "面包/乳酪/油炸食品/派/淡白/質素/機能的/家庭的/サクサク/甜/甜/辣/辣/神力/神力/神力/"
CASE "料理：讨厌的味道"
	RETURNF "咸/咸/妖力/妖力/妖力/霊障/霊障/霊障/畜生流/畜生流/畜生流/畜生流/畜生流/"
CASE "料理：助手効果"
	RETURNF "切れ味/薄味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黄/茶/秩序/かわいい/懷舊/" + "土/刃物/弾/" * 3 + "埴轮の/造形術の/护臂/埴轮/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/ポップ/未来/マニアック/" + "金属/生体品/" * 3 + "狼の/水獭の/鹫の/" * 10
ENDSELECT


