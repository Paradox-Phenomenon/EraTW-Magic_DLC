@Fキャラデータ47(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME

IF DAY:0 % 2
	;EX里香
	SELECTCASE O_DATA
		CASE "稱呼"
			RETURNF "里香"
		;こっから衣装設定
		CASE "今天的睡衣"
			RETURNF "睡衣（裤子）套"

		CASE "帽子"
			RETURNF @"{[[頭装備_帽子]]}"
		CASE "便装：靴"
			RETURNF @"{[[靴_皮鞋]]}"
		CASE "便装：襪子"
			RETURNF @"{[[襪子_袜子]]}"
		CASE "便装：裙子"
				RETURNF @"{[[裙子_裙子]]}"
		CASE "便装：上身衣服２"
			RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
		CASE "便装：上身衣服１"
			RETURNF @"{[[上身衣服_はだけ不可_无袖上衣]]}"
		CASE "固有内衣形容詞"
			RETURNF "平时随便穿的"
		CASE "固有下半身内衣名"
			RETURNF "老土内裤"
		CASE "固有上半身内衣"
			RETURNF "1"
		CASE "固有上半身内衣名"
			RETURNF "运动文胸"
		CASE "固有内衣着用条件"
			SIF !RAND:(1 + (2 * 勝負内衣判定([[里香]])))
				RETURNF "1"
		CASE "固有内衣半透明(前)"
			RETURNF "1"
		CASE "固有内衣半透明(後)"
			RETURNF "1"
		CASE "固有内衣布料厚度"
			RETURNF "2"

		;料理関連
		CASE "料理：喜欢的味道"
			RETURNF "牛奶/卵/煮物/派/丰盛/ジャンキー/濃厚/機能的/新鲜/软糯的/科学的/甜/甜/酸/酸/" + "謎料理/" * 3
		CASE "料理：讨厌的味道"
			RETURNF "简易/淡白/野趣/咸/咸/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/"
		CASE "料理：助手効果"
			RETURNF "化学的/"
		;贈り物関連
		CASE "感性：好き"
			RETURNF "銀/技術/混沌/かわいい/奇妙/パワフル/知的/マニアック/" + "金属/付喪神/妖術/" * 3 + "変形型/人工制品/機械/" * 5
		CASE "感性：嫌い"
			RETURNF "シンプル/別緻/繊細/" + "护臂/烟袋/" * 3
	ENDSELECT
ELSE
	;普通の里香
	SELECTCASE O_DATA
		CASE "稱呼"
			RETURNF "里香"
		;こっから衣装設定
		CASE "今天的睡衣"
			RETURNF "睡衣（裤子）套"
		CASE "便装：靴"
			RETURNF @"{[[靴_鞋子]]}"
		CASE "便装：襪子"
			RETURNF @"{[[襪子_袜子]]}"
		CASE "便装：裤子"
			RETURNF @"{[[裤子_短裤]]}"
		CASE "便装：上身衣服２"
			RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"

		CASE "固有内衣形容詞"
			RETURNF "平时随便穿的"
		CASE "固有下半身内衣名"
			RETURNF "老土内裤"
		CASE "固有上半身内衣"
			RETURNF "1"
		CASE "固有上半身内衣名"
			RETURNF "运动文胸"
		CASE "固有内衣着用条件"
			SIF !RAND:(1 + (2 * 勝負内衣判定([[里香]])))
				RETURNF "1"
		CASE "固有内衣半透明(前)"
			RETURNF "1"
		CASE "固有内衣半透明(後)"
			RETURNF "1"
		CASE "固有内衣布料厚度"
			RETURNF "2"

		;料理関連
		CASE "料理：喜欢的味道"
			RETURNF "牛奶/卵/煮物/派/丰盛/ジャンキー/濃厚/機能的/新鲜/软糯的/科学的/甜/甜/酸/酸/" + "謎料理/" * 3
		CASE "料理：讨厌的味道"
			RETURNF "简易/淡白/野趣/咸/咸/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/"
		CASE "料理：助手効果"
			RETURNF "化学的/"
		;贈り物関連
		CASE "感性：好き"
			RETURNF "銀/技術/混沌/かわいい/奇妙/パワフル/知的/マニアック/" + "金属/付喪神/妖術/" * 3 + "変形型/人工制品/機械/" * 5
		CASE "感性：嫌い"
			RETURNF "シンプル/別緻/繊細/" + "护臂/烟袋/" * 3
	ENDSELECT
ENDIF

