@Fキャラデータ17(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "愛麗絲"
;CASE "今日の衣装"
;	SIF (DAY:2 == 1 && DAY:3 == 1) || (DAY:2 == 4 && DAY:3 == 31)
;		RETURNF "年越し"
;CASE "明日の衣装"
;	SIF DAY:2 == 4 && (DAY:3 == 30 || DAY:3 == 31)
;		RETURNF "年越し"
CASE "特殊衣装着用"
	SIF (DAY:2 == 1 && DAY:3 == 1) || (DAY:2 == 4 && DAY:3 == 31)
		RETURNF "92"
		
CASE "今天的睡衣"
	IF (DAY:2 == 1 && DAY:3 == 1) || (DAY:2 == 4 && DAY:3 == 31)
		RETURNF "睡衣（襦袢）套"
	ELSEIF CFLAG:ARG:初期位置 == CFLAG:MASTER:初期位置
		RETURNF "睡衣（吊带睡裙）套"
	ELSE
		RETURNF "睡衣（裤子）套"
	ENDIF

CASE "便装：外搭"
	RETURNF @"{[[外搭_披肩]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_发箍]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_长靴]]}"
CASE "便装：襪子"
	IF FLAG:2 > 0
		RETURNF @"{[[襪子_连裤袜]]}"
	ELSE
		RETURNF @"{[[襪子_长筒袜]]}"
	ENDIF
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_魔导书]]}"

;CASE "年越し：和服"
;	RETURNF @"{[[和服_和服]]}"
;CASE "年越し：帽子"
;	RETURNF @"{[[頭装備_发箍]]}"
;CASE "年越し：靴"
;	RETURNF @"{[[靴_长靴]]}"
;CASE "年越し：襪子"
;	IF FLAG:2 > 0
;		RETURNF @"{[[襪子_连裤袜]]}"
;	ELSE
;		RETURNF @"{[[襪子_长筒袜]]}"
;	ENDIF

CASE "固有内衣形容詞"
	RETURNF "爱丽丝手制的"
CASE "固有下半身内衣名"
	RETURNF "手织蕾丝胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "衬裙"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[愛麗絲]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "面包/牛奶/葉物/派/咸/简易/淡白/豪華/芸術的/新鲜/サクサク/魔界風/洋食/洋食/" + "甜/" * 3
CASE "料理：讨厌的味道"
	RETURNF "肉料理/和食/丰盛/辣/辣/" + "青蛙/虫肉/濃厚/" * 3 + "謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "彩り/魔界風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "虹/繊細/秩序/かわいい/時尚/洋風/別緻/知的/" + "魔法/装飾/蓬莱の/魔界の/鏡之国の/" * 3 + "七色の/魔女の/魔彩光の/魔法書/人形/布娃娃/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/和風/パワフル/" + "护臂/" * 3
ENDSELECT


