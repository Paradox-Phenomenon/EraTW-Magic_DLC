@Fキャラデータ148(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "萨拉"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_结丝巾]]}"

CASE "固有内衣形容詞"
	RETURNF "孩子气到让人脸红的"
CASE "固有下半身内衣名"
	RETURNF "泰迪熊内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "柔性胸衣"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "葉物/野菜/野趣/酸/健康/简易/淡白/家庭的/新鲜/怪诞/魔界風/外界風/甜/甜/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "ジャンキー/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/"
CASE "料理：助手効果"
	RETURNF "魔界風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "粉色/赤/紫/シンプル/パワフル/魔界蝶の/霊知の/" + "魔法/自然/魔界の/" * 3 + "地上の/楽園の/春風の/守護の/" * 5
CASE "感性：嫌い"
	RETURNF "奇妙/懷舊/パワフル/ロリータ/マニアック/" + "知的/" * 3 + "刃物/弾/幼心地の/" * 3
ENDSELECT


