@Fキャラデータ61(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "妹紅"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裤子"
	RETURNF @"{[[裤子_指貫袴]]}"
CASE "便装：上身衣服２"
	IF DAY:2 == 2
		RETURNF @"{[[上身衣服_はだけ可能_短袖女式衬衫]]}"
	ELSE
		RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
	ENDIF
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_背帯]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_护符]]}"

CASE "固有内衣形容詞"
	RETURNF "不经意流行起来的"
CASE "固有下半身内衣名"
	RETURNF "护符胖次"
CASE "固有上半身内衣"
	RETURNF "0"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/香料/和食/鍋物/简易/温暖/質素/新鲜/家庭的/软绵绵/辣/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "冰淇淋/丰盛/濃厚/冷/甜/甜/酸/酸/謎料理/謎料理/謎料理/赏月/赏月/赏月/月都風/月都風/月都風/月都風/月都風/"
CASE "料理：助手効果"
	RETURNF "大火力/得意料理＊鳥肉＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "かわいい/和風/パワフル/壮大/" + "赤/火/巫術/护符/" * 3 + "鳳凰の/不滅の/" * 5
CASE "感性：嫌い"
	RETURNF "ポップ/繊細/ロリータ/マニアック/" + "死生/機械/" * 3 + "水/氷/月/王女の/蓬莱の/" * 5
ENDSELECT


