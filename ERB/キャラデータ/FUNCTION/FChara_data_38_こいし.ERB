@Fキャラデータ38(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "恋"
;こっから衣装設定
CASE "今天的睡衣"
	IF !RAND:2
		IF RAND:1000 == 514
			RETURNF "全裸"
		ELSE
			RETURNF "パンイチ"
		ENDIF
	ELSE
		RETURNF "睡衣（裤子+兜帽）套"
	ENDIF

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"

CASE "固有内衣形容詞"
	RETURNF "大概不是恋恋的"
CASE "固有下半身内衣名"
	RETURNF "性感内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "性感胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[恋]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "香料/乳酪/洋食/油炸食品/蛋糕/ジャンキー/濃厚/家庭的/芸術的/滑溜溜/地底風/甜/甜/辣/辣/" + "謎料理/" * 3
CASE "料理：讨厌的味道"
	RETURNF "質素/咸/咸/野菜/野菜/野菜/"
CASE "料理：助手効果"
	RETURNF "地底風/ドッキリ味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "灰/かわいい/奇妙/ポップ/ロリータ/不思議/" + "精神/" * 3 + "心形の/蔷薇の/地底の/心の/本我の/自我の/小刀/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/シンプル/知的/" + "护臂/" * 3 + "瞳の/" * 10
ENDSELECT


