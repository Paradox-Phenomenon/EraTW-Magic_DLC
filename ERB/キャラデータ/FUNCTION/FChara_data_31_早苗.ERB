@Fキャラデータ31(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "早苗"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"
CASE "特殊衣装着用"
	IF !TCVAR:31:399
        IF (DAY:2 == 1 || DAY:2 == 2) && !RAND:7
            TCVAR:31:399 = 1
        ELSE
            TCVAR:31:399 = -1
        ENDIF
    ENDIF

	SIF TCVAR:31:399 == 1
		RETURNF "74"

CASE "便装：飾品"
	RETURNF @"{[[飾品_袖]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_发饰]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	IF FLAG:2 > 0
		RETURNF @"{[[襪子_长筒袜]]}"
	ELSE
		RETURNF @"{[[襪子_袜子]]}"
	ENDIF
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_守矢的巫女服]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_大币]]}"

CASE "固有内衣形容詞"
	RETURNF "早苗珍藏的"
CASE "固有下半身内衣名"
	RETURNF "侧缎带胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "前扣胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[早苗]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/魚料理/和食/油炸食品/辣/ジャンキー/濃厚/滑溜溜/外界風/甜/甜/甜/"
CASE "料理：讨厌的味道"
	RETURNF "酸/酸/妖力/妖力/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/" + "怪诞/謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "奇跡/外界風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "緑/果実/秩序/かわいい/時尚/ポップ/未来/派手/不思議/壮大/マニアック/" + "光/神霊/巫術/护符/蛙の/蛇の/客星の/" * 3 + "巫女の/奇跡の/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/シンプル/懷舊/別緻/" + "妖怪/护臂/烟袋/" * 3 + "博霊の/妖怪の/" * 10

;農民関連
;神社は土地持ってそう、神田
CASE "農民：説明"
	RETURNF "米農家"
CASE "農民：作物"
	RETURNF "大米"
CASE "農民：田的种类"
	RETURNF "水田"
CASE "農民：畑の所在地"
	RETURNF "守谷神社"

CASE "農民：MapID"
	RETURNF "8"
CASE "農民：場所ID"
	RETURNF "814"
CASE "農民：報酬"
	RETURNF "500"
CASE "農民：金利"
	RETURNF "5"
ENDSELECT


