@Fキャラデータ52(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "鈴仙"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_白衬衫]]}"
CASE "便装：上身衣服１"
;夏は西装上衣を脱掉
	SIF DAY:2 != 2
		RETURNF @"{[[上身衣服_はだけ不可_西装上衣]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_领带]]}"

CASE "固有内衣形容詞"
	RETURNF "用丝带系在兔尾上的"
CASE "固有下半身内衣名"
	RETURNF "条纹内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "条纹胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/果物/葉物/健康/上品/機能的/家庭的/软糯的/玉兎流/月都風/赏月/甜/甜/酸/酸/胡萝卜/胡萝卜/胡萝卜/胡萝卜/胡萝卜/"
CASE "料理：讨厌的味道"
	RETURNF "野趣/辣/辣/" + "青蛙/獣肉/香料/虫肉/怪诞/" * 3 + "謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "玉兎流/得意料理＊健康＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/秩序/かわいい/繊細/知的/" + "兔の/地上の/狂気の/药瓶/领带/可爱黑暗的/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/可怕的/奇妙/派手/ロリータ/" + "刃物/生体品/护臂/" * 3

;特殊衣装
CASE "おうちデート衣装"
	SIF MAIN_MAP == 2
		RETURNF @"{[[卖药套]]}"
CASE "人里デート衣装", "人間衣装"
	RETURNF @"{[[卖药套]]}"

CASE "固有指令"
	RETURNF "买药"
CASE "固有指令実行可能"
	RETURNF "1"
ENDSELECT


