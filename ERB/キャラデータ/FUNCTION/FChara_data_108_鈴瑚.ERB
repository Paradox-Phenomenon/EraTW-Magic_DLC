@Fキャラデータ108(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "鈴瑚"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_鸭舌帽]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_Ｔ恤衬衫]]}"
CASE "便装：裤子"
	RETURNF @"{[[裤子_南瓜裤]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_团子串]]}"

CASE "固有内衣形容詞"
	RETURNF "【铃瑚屋】图案的"
CASE "固有下半身内衣名"
	RETURNF "宣传用胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "无钢圈文胸"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[鈴瑚]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野趣/中華/鍋物/丰盛/濃厚/秋物/野趣/新鲜/豪快/软糯的/玉兎流/月都風/赏月/甜/甜/辣/辣/胡萝卜/胡萝卜/胡萝卜/胡萝卜/胡萝卜/"
CASE "料理：讨厌的味道"
	RETURNF "简易/淡白/質素/咸/咸/" + "青蛙/獣肉/虫肉/" * 3 + "謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "玉兎流/浓郁/"
;贈り物関連
CASE "感性：好き"
	RETURNF "朱/秩序/かわいい/シンプル/" + "食器/" * 3 + "橘色の/兔の/苹果の/" * 5
CASE "感性：嫌い"
	RETURNF "ロリータ/威厳/" + "刃物/生体品/护臂/" * 3 + "浅葱色の/" * 10
ENDSELECT


