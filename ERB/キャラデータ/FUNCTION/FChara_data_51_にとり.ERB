@Fキャラデータ51(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "荷取"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"
CASE "特殊衣装着用"
	;1/8概率换上作业服
	SIF FLAG:9 % 8 == 0
		RETURNF "88"
CASE "便装：飾品"
	RETURNF @"{[[飾品_風鏡]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_鸭舌帽]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_帆布背包]]}"
CASE "便装：上身衣服２"
	;IF DAY:2 == 2
	;	RETURNF @"{[[上身衣服_はだけ可能_吊帯背心]]}"
	;ELSE
		RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
	;ENDIF
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_上衣]]}"
;CASE "便装：裤子"
;	SIF DAY:2 == 2
;		RETURNF @"{[[裤子_工装裤]]}"
CASE "便装：裙子"
	;SIF DAY:2 != 2
		RETURNF @"{[[裙子_裙子]]}"

CASE "固有内衣形容詞"
	RETURNF "防水的"
CASE "固有下半身内衣名"
	RETURNF "比基尼胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "抹胸胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "2"

CASE "固有指令"
	RETURNF "购买道具"
CASE "固有指令実行可能"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/鍋物/简易/ジャンキー/冷/野趣/滑溜溜/外界風/化学的/美味的水/甜/甜/酸/酸/" + "夏物/機能的/謎料理/" * 3 + "黄瓜/" * 5
CASE "料理：讨厌的味道"
	RETURNF "丰盛/質素/辣/辣/" + "青蛙/香料/虫肉/" * 3 + "怪诞/" * 5
CASE "料理：助手効果"
	RETURNF "化学的/美味的水/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/技術/秩序/かっこいい/シンプル/未来/知的/マニアック/" + "水/金属/道具/龟の/" * 3 + "黄瓜の/河童の/机械装置の/光学技術の/機械/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/可怕的/威厳/" + "火/氷/生体品/" * 3 + "天狗の/鬼の/" * 10

;農民関連
;薄給
CASE "農民：説明"
	RETURNF "黄瓜農家"
CASE "農民：作物"
	RETURNF "黄瓜"
CASE "農民：田的种类"
	RETURNF "黄瓜畑"
CASE "農民：畑の所在地"
	RETURNF "妖怪之山·山麓"

CASE "農民：MapID"
	RETURNF "7"
CASE "農民：場所ID"
	RETURNF "703"
CASE "農民：報酬"
	RETURNF "300"
CASE "農民：金利"
	RETURNF "4"

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	RETURNF "2"
CASE "一般依頼発生率"
	RETURNF "3"
CASE "固有依頼発生率"
	RETURNF "5"
CASE "固有依頼最終要素"
	RETURNF "102"
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		RETURNF F固有依頼51(ARG, O_DATA, V_NAME)
ENDSELECT


