@Fキャラデータ127(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "瓔花"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_涼鞋]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_叠石]]}"

CASE "固有指令"
	RETURNF "今日的叠石主题"
CASE "固有指令実行可能"
	RETURNF "1"


CASE "固有内衣形容詞"
	RETURNF "轻飘飘软绵绵"
CASE "固有下半身内衣名"
	RETURNF "水子胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "水子胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "牛奶/卵/汁物/饮用/简易/淡白/冷/質素/野趣/家庭的/冥界風/美味的水/甜/甜/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "油炸食品/丰盛/濃厚/温暖/咸/咸/" + "青蛙/肉料理/魚料理/香料/地獄風/" * 3
CASE "料理：助手効果"
	RETURNF "冥界風/幸運/美味的水/"
;贈り物関連
CASE "感性：好き"
	RETURNF "灰/鉱物/かわいい/シンプル/ポップ/ロリータ/別緻/繊細/" + "水/" * 3 + "石の/水母の/纸风车/" * 5
CASE "感性：嫌い"
	RETURNF "派手/パワフル/知的/威厳/" + "火/死生/刃物/弾/烟袋/機械/" * 3
ENDSELECT


