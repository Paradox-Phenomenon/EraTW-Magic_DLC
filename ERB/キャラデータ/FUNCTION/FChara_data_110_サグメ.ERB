@Fキャラデータ110(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "探女"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_夹克衫]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"

CASE "固有内衣形容詞"
	RETURNF "和服装裙子配套的"
CASE "固有下半身内衣名"
	RETURNF "矢印纹胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "矢印纹胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/牛奶/煮物/简易/健康/淡白/豪華/芸術的/上品/软绵绵/地獄風/中華/中華/甜/甜/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "洋食/ジャンキー/濃厚/質素/野趣/咸/咸/" + "青蛙/虫肉/" * 3 + "怪诞/謎料理/生命力/" * 5
CASE "料理：助手効果"
	RETURNF "月都風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "白/秩序/かわいい/シンプル/大陸風/別緻/繊細/知的/" + "月/鳥/巫術/护符/" * 3 + "穢れなき/運命の/逆転の/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/奇妙/洋風/派手/パワフル/ロリータ/マニアック/" + "黒/土/闇/死生/生体品/烟袋/" * 3 + "地上の/万魔殿な/" * 10
ENDSELECT


