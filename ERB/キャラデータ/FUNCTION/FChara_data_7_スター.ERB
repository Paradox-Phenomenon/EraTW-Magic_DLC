@Fキャラデータ7(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "斯塔"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"

CASE "固有内衣形容詞"
	RETURNF "星星刺绣的"
CASE "固有下半身内衣名"
	RETURNF "斑点胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "吊带小背心"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[斯塔]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

CASE "固有指令"
	RETURNF "探访迹象"
CASE "固有指令実行可能"
	SIF CFLAG:7:好感度 >= 200 && AT_HOME(7)
		RETURNF "1"

;農民関連
;むりやりなスターフルーツから秋葵（星形断面）に変更
;秋葵って英語だったのか・・・
CASE "農民：説明"
	RETURNF "秋葵農家"
CASE "農民：作物"
	RETURNF "秋葵"
CASE "農民：田的种类"
	RETURNF "秋葵畑"
CASE "農民：畑の所在地"
	RETURNF "博麗神社"

CASE "農民：MapID"
	RETURNF "0"
CASE "農民：場所ID"
	RETURNF "25"
CASE "農民：報酬"
	RETURNF "200"
CASE "農民：金利"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/和食/鍋物/健康/芸術的/上品/家庭的/滑溜溜/闪耀/甜/甜/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "辣/野趣/怪诞/怪诞/怪诞/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "隠し味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/果実/かわいい/洋風/別緻/ロリータ/" + "星/書物/" * 3 + "星の/星光の/三位一体の/" * 5
CASE "感性：嫌い"
	RETURNF "闇/日/月/生体品/护臂/烟袋/" * 3
ENDSELECT


