@Fキャラデータ6(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "露娜"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"

CASE "固有内衣形容詞"
	RETURNF "月亮刺绣的"
CASE "固有下半身内衣名"
	RETURNF "斑点胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "吊带小背心"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[露娜]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;農民関連
CASE "農民：説明"
	RETURNF "栗子農家"
CASE "農民：作物"
	RETURNF "栗"
CASE "農民：田的种类"
	RETURNF "栗林"
CASE "農民：畑の所在地"
	RETURNF "博麗神社"

CASE "農民：MapID"
	RETURNF "0"
CASE "農民：場所ID"
	RETURNF "25"
CASE "農民：報酬"
	RETURNF "200"
CASE "農民：金利"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "果物/洋食/汁物/派/简易/淡白/冷/質素/機能的/上品/软糯的/闪耀/赏月/甜/甜/甜/甜/"
CASE "料理：讨厌的味道"
	RETURNF "野趣/香料/香料/香料/丰盛/丰盛/丰盛/辣/辣/辣/辣/怪诞/怪诞/怪诞/怪诞/怪诞/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "薄味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黄/果実/かわいい/ポップ/繊細/ロリータ/" + "月/护符/" * 3 + "月の/月光の/三位一体の/" * 5
CASE "感性：嫌い"
	RETURNF "可怕的/奇妙/パワフル/威厳/" + "闇/日/星/幽霊/刃物/弾/护臂/烟袋/" * 3

ENDSELECT


