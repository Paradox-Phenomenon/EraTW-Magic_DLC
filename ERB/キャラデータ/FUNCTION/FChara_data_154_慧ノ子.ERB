@Fキャラデータ154(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "慧ノ子"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍+睡帽）套"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_露肩衬衫]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_首飾]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_捕兽夹]]}"

CASE "固有内衣形容詞"
	RETURNF "陷阱图案的"
CASE "固有下半身内衣名"
	RETURNF "狗狗胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "狗狗胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/肉料理/肉料理/和食/煮物/下酒菜/咸/咸/酸/酸/简易/濃厚/質素/野趣/家庭的/黏稠/畜生流/"
CASE "料理：讨厌的味道"
	RETURNF "甜/甜/丰盛/ジャンキー/"
CASE "料理：助手効果"
	RETURNF "畜生流/"
;贈り物関連
CASE "感性：好き"
	RETURNF "灰/秩序/かわいい/時尚/別緻/知的/" + "火/狼の/" * 3 + "犬の/森の/" * 5
	;森閑の不存在，暂且定为森の
CASE "感性：嫌い"
	RETURNF "混沌/派手/威厳/" + "死生/" * 3 + "水獭の/鹫の/" * 10
ENDSELECT


