@Fキャラデータ66(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "幽幽子"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
		RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：和服"
	RETURNF @"{[[和服_和服]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_肌襦袢]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_帯]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_扇]]}"

CASE "固有内衣形容詞"
	RETURNF "鲜艳樱色的"
CASE "固有下半身内衣名"
	RETURNF "和服衬裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "和装衬衣"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[幽幽子]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/肉料理/油炸食品/下酒菜/丰盛/濃厚/芸術的/上品/家庭的/软糯的/冥界風/赏月/和食/和食/甜/甜/酸/酸/" + "春物/" * 3 + "YYK严选/" * 3
CASE "料理：讨厌的味道"
	RETURNF "咸/简易/淡白/天界風/天界風/天界風/"
CASE "料理：助手効果"
	RETURNF "冥界風/得意料理＊春物＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "粉色/美的/芸術的/和風/派手/繊細/" + "死生/幽霊/扇/食器/樱桃の/睡眠の/" * 3 + "黒死蝶の/樱花の/亡霊の/春の/冥界の/带来死亡の/死の/" * 5
CASE "感性：嫌い"
	RETURNF "洋風/パワフル/ロリータ/" + "神霊/刃物/生体品/护臂/" * 3 + "不滅の/" * 10

;農民関連
;石榴に設定したのは独断
;冥界（死）＆女性に縁のある果物としてチョイス
;最初は米農家にしたけど彼岸で米栽培してるのはとても違和感が
CASE "農民：説明"
	RETURNF "柘榴農家"
CASE "農民：作物"
	RETURNF "石榴"
CASE "農民：田的种类"
	RETURNF "柘榴畑"
CASE "農民：畑の所在地"
	RETURNF "冥界"

CASE "農民：MapID"
	RETURNF "6"
CASE "農民：場所ID"
	RETURNF "630"
CASE "農民：報酬"
	RETURNF "500"
CASE "農民：金利"
	RETURNF "13"
ENDSELECT


