@Fキャラデータ149(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "奥莲姬"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裤子"
	RETURNF @"{[[裤子_热裤]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_无袖上衣]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_蝴蝶结]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_杖]]}"

CASE "固有内衣形容詞"
	RETURNF "紧身的"
CASE "固有下半身内衣名"
	RETURNF "运动短裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "运动文胸"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "夏物/野菜/濃厚/辣/辣/丰盛/肉料理/豪華/甜/質素/新鲜/家庭的/黏稠/妖力/酸/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "酸/酸/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "果物/"
;贈り物関連
CASE "感性：好き"
	RETURNF "夏の/緑/黄/指揮棒/蝴蝶结/发带/芸術的/" + "手板/杖/妖術/" * 3 + "橙子の/パワフル/"* 5
CASE "感性：嫌い"
	RETURNF "知的/欲望の/" + "厄の/不吉の/巫女の/驅魔棒/博霊の/" * 10 
ENDSELECT


