@Fキャラデータ34(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "天子"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_桃]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_要石]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_剑]]}"

CASE "固有内衣形容詞"
	RETURNF "无针脚的"
CASE "固有下半身内衣名"
	RETURNF "桃色内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "胸衣"
CASE "固有内衣着用条件"
	SIF !RAND:3
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

CASE "固有指令"
	RETURNF "天候操作"
CASE "固有指令実行可能"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "果物/香料/中華/麺類/派/丰盛/ジャンキー/濃厚/豪華/上品/新鲜/软绵绵/天界風/甜/甜/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "野菜/简易/健康/淡白/質素/野趣/酸/酸/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/"
CASE "料理：助手効果"
	RETURNF "天界風/絢爛/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/虹/混沌/美的/奇妙/ポップ/派手/壮大/威厳/" + "土/刃物/" * 3 + "要石の/桃の/天使の/天人の/極光の/天界の/緋想の/非想非非想の/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/シンプル/別緻/繊細/知的/" + "雷/死生/書物/生体品/领带/" * 3 + "悪魔の/" * 5

;農民関連
;もも
CASE "農民：説明"
	RETURNF "桃農家"
CASE "農民：作物"
	RETURNF "桃"
CASE "農民：田的种类"
	RETURNF "桃農園"
CASE "農民：畑の所在地"
	RETURNF "天界"

CASE "農民：MapID"
	RETURNF "8"
CASE "農民：場所ID"
	RETURNF "833"
CASE "農民：報酬"
	RETURNF "600"
CASE "農民：金利"
	RETURNF "7"
ENDSELECT


