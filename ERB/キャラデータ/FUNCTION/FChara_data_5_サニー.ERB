@Fキャラデータ5(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "桑尼"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_女仆发箍]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"

CASE "固有内衣形容詞"
	RETURNF "太阳刺绣的"
CASE "固有下半身内衣名"
	RETURNF "斑点胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "抹胸"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[桑尼]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;農民関連
CASE "農民：説明"
	RETURNF "生菜農家"
CASE "農民：作物"
	RETURNF "生菜"
CASE "農民：田的种类"
	RETURNF "生菜田地"
CASE "農民：畑の所在地"
	RETURNF "博麗神社"

CASE "農民：MapID"
	RETURNF "0"
CASE "農民：場所ID"
	RETURNF "25"
CASE "農民：報酬"
	RETURNF "200"
CASE "農民：金利"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "牛奶/蘑菇/洋食/油炸食品/辣/丰盛/ジャンキー/濃厚/温暖/豪華/野趣/豪快/黏稠/闪耀/甜/甜/甜/"
CASE "料理：讨厌的味道"
	RETURNF "質素/酸/酸/野菜/野菜/野菜/怪诞/怪诞/怪诞/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "浓郁/"
;贈り物関連
CASE "感性：好き"
	RETURNF "朱/果実/かわいい/ポップ/派手/パワフル/ロリータ/" + "日/生体品/" * 3 + "太陽の/陽光の/三位一体の/反射の/" * 5
CASE "感性：嫌い"
	RETURNF "別緻/知的/" + "闇/星/月/書物/烟袋/" * 3

ENDSELECT


