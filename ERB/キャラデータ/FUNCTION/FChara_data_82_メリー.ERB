@Fキャラデータ82(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "梅莉"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"

CASE "固有内衣形容詞"
	RETURNF "给人沉稳印象的"
CASE "固有下半身内衣名"
	RETURNF "条纹内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "条纹胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/乳酪/和食/煮物/蛋糕/简易/淡白/芸術的/上品/家庭的/软绵绵/夢幻風/甜/甜/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "ジャンキー/野趣/辣/辣/霊障/霊障/虫肉/虫肉/虫肉/地獄風/地獄風/地獄風/" + "怪诞/謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "化学的/得意料理＊洋食＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "紫/美的/奇妙/和風/繊細/知的/不思議/" + "自然/精神/美術品/エニグマティクな/" * 3 + "魅知の/未知の/境界の/夢の/夢と現の/手賬/" * 5
CASE "感性：嫌い"
	RETURNF "パワフル/威厳/" + "闇/妖怪/生体品/护臂/领带/" * 3 + "外界の/悪夢の/" * 10
ENDSELECT


