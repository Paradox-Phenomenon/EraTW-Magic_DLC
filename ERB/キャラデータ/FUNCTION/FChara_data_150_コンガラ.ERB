@Fキャラデータ150(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "矜羯罗"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_雪駄]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_足袋]]}"
CASE "便装：和服"
	RETURNF @"{[[和服_白袖红袴]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_帯]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_刀]]}"

CASE "固有内衣形容詞"
	RETURNF "缝缝补补的"
CASE "固有下半身内衣名"
	RETURNF "兜裆布"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "裹胸"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[矜羯罗]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/米/野菜/和食/和食/油炸食品/辣/辣/简易/淡白/芸術的/野趣/豪快/地獄風/酸/" + "咸/" * 3
CASE "料理：讨厌的味道"
	RETURNF "中華/洋食/小人族秘伝の味/" + "甜/" * 2 + "謎料理/"*5 + "化学的/青蛙/虫肉/"*3
CASE "料理：助手効果"
	RETURNF "地獄風/切れ味/得意料理＊質素＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/美的/和風/別緻/かっこいい/パワフル/壮大/鬼の/鬼力の/酒/懐剣/高級/威厳/" + "土/刃物/闇/护臂/秩序/法具/" * 3 + "護刀/力の/宝剣/闇の/法界の/" * 5
CASE "感性：嫌い"
	RETURNF "精神/ポップ/繊細/洋風/ロリータ/奇妙/" + "弾/機械/派手/巫術/" * 3 + "混沌/" * 10
ENDSELECT


