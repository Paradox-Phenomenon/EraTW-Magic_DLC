@Fキャラデータ9(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "夢美"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：外搭"
	SELECTCASE DAY:2
	CASE 1
		RETURNF @"{[[外搭_披肩]]}"
	CASE 3
		RETURNF @"{[[外搭_斗篷]]}"
	CASE 4
		RETURNF @"{[[外搭_披肩斗篷]]}"
	ENDSELECT
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"

CASE "固有内衣形容詞"
	RETURNF "自修复的"
CASE "固有下半身内衣名"
	RETURNF "纳米技术胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "纳米技术胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[夢美]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "3"

;農民関連
CASE "農民：説明"
	RETURNF "草莓農家"
CASE "農民：作物"
	RETURNF "草莓"
CASE "農民：田的种类"
	RETURNF "草莓畑"
CASE "農民：畑の所在地"
	RETURNF "夢幻遺跡"

CASE "農民：MapID"
	RETURNF "0"
CASE "農民：場所ID"
	RETURNF "36"
CASE "農民：報酬"
	RETURNF "400"
CASE "農民：金利"
	RETURNF "5"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "面包/洋食/汁物/饮用/ジャンキー/濃厚/新鲜/サクサク/魔力/化学的/面包/面包/甜/甜/甜/機能的/機能的/機能的/草莓/草莓/草莓/草莓/草莓/"
CASE "料理：讨厌的味道"
	RETURNF "油炸食品/淡白/野趣/辣/辣/青蛙/青蛙/青蛙/"
CASE "料理：助手効果"
	RETURNF "化学的/"
;贈り物関連
CASE "感性：好き"
	RETURNF "技術/美的/未来/知的/マニアック/" + "赤/魔法/遺物/" * 3 + "十字型の/草莓の/人工制品/機械/" * 5
CASE "感性：嫌い"
	RETURNF "シンプル/懷舊/別緻/ロリータ/" + "护臂/" * 3
ENDSELECT

;-------------------------------------------------
;固有料理設定
;DISH_NAME		  料理名
;RESULTS			料理の種類（軽食/主食/甜点）
;CALL 材料設定("")  材料の指定。"汎用"を入れると自動で汎用食材になる
;DISH_TASTE		 味の設定
;DISH_COMMENT	   （任意）一行コメント
;DISH_TIME		  （任意）調理にかかる時間
;DISH_MAXLIMIT	  （任意）料理の持続時間
;-------------------------------------------------
