@Fキャラデータ137(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "駒草"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_羽织]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_長着]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_木屐]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_烟袋]]}"
	
CASE "固有内衣形容詞"
	RETURNF "会在给足小费后消失的"
CASE "固有下半身内衣名"
	RETURNF "烟雾胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "烟雾胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "香料/香料/香料/肉料理/肉料理/肉料理/和食/鍋物/下酒菜/咸/咸/酸/酸/丰盛/ジャンキー/濃厚/豪華/上品/新鲜/软绵绵/"
CASE "料理：讨厌的味道"
	RETURNF "牛奶/牛奶/牛奶/洋食/甜/甜/简易/健康/淡白/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "得意料理＊ジャンキー＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/混沌/かっこいい/懷舊/" + "植物/龍の/" * 3 + "煙の/女王の/烟袋/香炉/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/未来/ロリータ/"
ENDSELECT


