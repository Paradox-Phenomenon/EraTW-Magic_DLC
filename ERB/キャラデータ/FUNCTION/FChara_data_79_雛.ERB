@Fキャラデータ79(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "雛"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_哥特洛丽塔裙]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_蝴蝶结]]}"

CASE "固有内衣形容詞"
	RETURNF "墨绿色的"
CASE "固有下半身内衣名"
	RETURNF "哥特内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "哥特胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[雛]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"
CASE "デート衣装", "人里デート衣装", "おうちデート衣装"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[雛]])))
		RETURNF "23"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/汁物/甜/淡白/質素/新鲜/家庭的/黏稠/妖力/酸/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "丰盛/濃厚/辣/辣/豪華/豪華/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/"
CASE "料理：助手効果"
	RETURNF "隠し味/得意料理＊家庭的＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/黒/美的/芸術的/別緻/" + "闇/妖術/护符/" * 3 + "厄の/不吉の/" * 5
CASE "感性：嫌い"
	RETURNF "パワフル/威厳/" + "光/护臂/" * 3

;農民関連
;服の模様に似ている＆山で生えてそう
;あまり裕福なイメージはない
CASE "農民：説明"
	RETURNF "山菜農家"
CASE "農民：作物"
	RETURNF "薇菜"
CASE "農民：田的种类"
	RETURNF "薇菜畑"
CASE "農民：畑の所在地"
	RETURNF "妖怪之山・山麓"

CASE "農民：MapID"
	RETURNF "7"
CASE "農民：場所ID"
	RETURNF "705"
CASE "農民：報酬"
	RETURNF "350"
CASE "農民：金利"
	RETURNF "3"

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	RETURNF "2"
CASE "一般依頼発生率"
	RETURNF "3"
CASE "固有依頼発生率"
	RETURNF "5"
CASE "固有依頼最終要素"
	RETURNF "101"
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		RETURNF F固有依頼79(ARG, O_DATA, V_NAME)
ENDSELECT


