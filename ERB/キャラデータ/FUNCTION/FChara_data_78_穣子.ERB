@Fキャラデータ78(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "穣子"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_围裙洋装]]}"
;冬季到春季第10日，装备裤袜和围巾
CASE "便装：其他１"
	SIF (DAY:2 == 1 && DAY:3 < 11) || DAY:2 == 4
		RETURNF @"{[[其他衣装_围巾]]}"
CASE "便装：襪子"
	SIF (DAY:2 == 1 && DAY:3 < 11) || DAY:2 == 4
		RETURNF @"{[[襪子_裤袜]]}"

CASE "固有内衣形容詞"
	RETURNF "甜甜香氛的"
CASE "固有下半身内衣名"
	RETURNF "烤红薯色胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "烤红薯色胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[穣子]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/马铃薯/米/蘑菇/煮物/丰盛/濃厚/豪華/野趣/家庭的/软糯的/甜/甜/咸/咸/" + "秋物/" * 5
CASE "料理：讨厌的味道"
	RETURNF "淡白/質素/酸/酸/" + "青蛙/虫肉/冬物/" * 3 + "謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "豊穣/得意料理＊秋物＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "朱/かわいい/時尚/派手/" + "土/植物/果実/食器/" * 3 + "葡萄の/紅葉の/秋の/豊穣の/種/秋風の/" * 5
CASE "感性：嫌い"
	RETURNF "氷/刃物/弾/护臂/機械/" * 3 + "夏の/樱花の/向日葵の/西瓜の/" * 5  + "春の/冬の/春風の/" * 10

;農民関連
;米でもいいが天狗と被るのだよ
CASE "農民：説明"
	RETURNF "芋農家"
CASE "農民：作物"
	RETURNF "芋头"
CASE "農民：田的种类"
	RETURNF "芋头田"
CASE "農民：畑の所在地"
	RETURNF "妖怪之山・山麓"

CASE "農民：MapID"
	RETURNF "7"
CASE "農民：場所ID"
	RETURNF "715"
CASE "農民：報酬"
	RETURNF "400"
CASE "農民：金利"
	RETURNF "4"
ENDSELECT


