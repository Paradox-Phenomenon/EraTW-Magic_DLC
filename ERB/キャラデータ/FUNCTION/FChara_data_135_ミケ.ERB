@Fキャラデータ135(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "三花"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（连衣裙）套"

CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_短袖女式衬衫]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_迷你裙]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_手链]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_项圈]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_小判]]}"

CASE "固有内衣形容詞"
	RETURNF "带着铃铛的"
CASE "固有下半身内衣名"
	RETURNF "迎客胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "三花猫图案胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[三花]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/魚料理/魚料理/肉料理/肉料理/肉料理/油炸食品/甜/甜/咸/咸/濃厚/豪華/野趣/新鲜/"
CASE "料理：讨厌的味道"
	RETURNF "野菜/野菜/野菜/香料/香料/香料/酸/酸/淡白/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "幸運/"
;贈り物関連
CASE "感性：好き"
	RETURNF "高級/金/宝石/かわいい/時尚/ポップ/" + "黄金の/" * 3 + "猫の/幸運の/" * 5
CASE "感性：嫌い"
	RETURNF "奇妙/" + "安物/水/" * 3 + "犬の/狼の/" * 10
ENDSELECT


