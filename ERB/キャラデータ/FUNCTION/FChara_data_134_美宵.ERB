@Fキャラデータ134(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "美宵"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子+兜帽）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_白衬衫]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_胶皮底布鞋子]]}"

CASE "固有内衣形容詞"
	RETURNF "可疑的"
CASE "固有下半身内衣名"
	RETURNF "鲸鱼胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "鲸鹏胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[美宵]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "3"
;教育补丁获取料理经验
CASE "固有指令"
	IF 成人再教育插件开关 == 1
		RETURNF "学习烹饪"
	ENDIF
CASE "固有指令実行可能"
	IF 成人再教育插件开关 == 1
		RETURNF "1"
	ENDIF
;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/魚料理/和食/煮物/下酒菜/丰盛/健康/質素/芸術的/家庭的/软糯的/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "平价食材/ジャンキー/酸/酸/乳酪/乳酪/乳酪/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "プロの味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/かわいい/ポップ/壮大/" + "水/酒/食器/海の/記憶の/" * 3 + "鲸の/" * 5
CASE "感性：嫌い"
	RETURNF "洋風/ロリータ/" + "雷/" * 3 + "忘却の/" * 10
ENDSELECT


