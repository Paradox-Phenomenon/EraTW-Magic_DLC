@Fキャラデータ83(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "琪斯美"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_发饰]]}"
CASE "便装：和服"
	RETURNF @"{[[和服_和服]]}"

CASE "固有内衣形容詞"
	RETURNF "小巧可爱的"
CASE "固有下半身内衣名"
	RETURNF "桃色兜裆布"
CASE "固有上半身内衣"
	RETURNF "0"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[琪斯美]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "0"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/和食/油炸食品/简易/ジャンキー/淡白/質素/野趣/怪诞/黏稠/地底風/甜/甜/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "丰盛/辣/辣/香料/香料/香料/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "地底風/ドッキリ味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黒/混沌/かわいい/懷舊/別緻/" + "火/水/骨/生体品/" * 3 + "地底の/骨の/骷髅の/" * 5
CASE "感性：嫌い"
	RETURNF "派手/パワフル/威厳/" + "护臂/機械/" * 3
ENDSELECT


