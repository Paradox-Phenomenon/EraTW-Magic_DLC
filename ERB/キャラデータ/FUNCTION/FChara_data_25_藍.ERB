@Fキャラデータ25(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "藍"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	IF FLAG:2 > 0
		RETURNF @"{[[襪子_长筒袜]]}"
	ELSE
		RETURNF @"{[[襪子_袜子]]}"
	ENDIF
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_道士服]]}"

CASE "固有内衣形容詞"
	RETURNF "尾部开了个大洞的"
CASE "固有下半身内衣名"
	RETURNF "带洞胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "全罩杯胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[藍]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/卵/和食/中華/油炸食品/丰盛/上品/家庭的/機能的/软糯的/辣/辣/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "咸/咸/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "妖力/妖力/得意料理＊和食＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/秩序/美的/和風/別緻/知的/" + "妖術/書物/" * 3 + "狐の/式神の/" * 5
CASE "感性：嫌い"
	RETURNF "ポップ/ロリータ/マニアック/" + "水/护臂/" * 3 + "狸の/" * 10

;農民関連
;おあげ
CASE "農民：説明"
	RETURNF "大豆農家"
CASE "農民：作物"
	RETURNF "大豆"
CASE "農民：田的种类"
	RETURNF "大豆畑"
CASE "農民：畑の所在地"
	RETURNF "人里"

CASE "農民：MapID"
	RETURNF "2"
CASE "農民：場所ID"
	RETURNF "205"
CASE "農民：報酬"
	RETURNF "600"
CASE "農民：金利"
	RETURNF "5"
ENDSELECT


