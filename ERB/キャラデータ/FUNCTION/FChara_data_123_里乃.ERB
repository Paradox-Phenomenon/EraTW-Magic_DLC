@Fキャラデータ123(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "里乃"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_乌帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_长筒袜]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_茗荷]]}"

CASE "固有内衣形容詞"
	RETURNF "方便跳舞的"
CASE "固有下半身内衣名"
	RETURNF "紧身裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "吊带背心"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[里乃]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/汁物/简易/ジャンキー/淡白/豪華/芸術的/新鲜/软糯的/甜/甜/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "質素/辣/辣/" + "青蛙/虫肉/天狗流/" * 3
CASE "料理：助手効果"
	RETURNF "附魔/薄味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "紫/高級/混沌/かわいい/時尚/ポップ/派手/不思議/" + "音楽/楽器/記憶の/" * 3 + "疯狂な/後戸の/精神の/忘却の/" * 5
CASE "感性：嫌い"
	RETURNF "別緻/" + "生体品/护臂/" * 3 + "天狗の/" * 10
ENDSELECT


