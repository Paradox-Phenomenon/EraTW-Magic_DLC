@Fキャラデータ119(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "合歡乃"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：飾品"
	RETURNF @"{[[飾品_袖]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_菜刀]]}"

;あえて色は決めない
CASE "固有内衣形容詞"
	RETURNF "染色风格新奇的"
CASE "固有下半身内衣名"
	RETURNF "扎染兜裆布"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "扎染裹胸"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[合歡乃]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/蘑菇/和食/鍋物/下酒菜/丰盛/濃厚/秋物/質素/野趣/家庭的/黏稠/咸/咸/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "面包/乳酪/洋食/简易/淡白/外界風/甜/甜/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "母亲的味道/得意料理＊秋物＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "茶/美的/シンプル/別緻/" + "秩序/刃物/" * 3 + "山の/聖域の/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/洋風/ロリータ/" + "機械/" * 5
ENDSELECT


