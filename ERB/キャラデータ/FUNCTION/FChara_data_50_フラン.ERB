@Fキャラデータ50(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "芙兰"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子+兜帽）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_无袖上衣]]}"

CASE "固有内衣形容詞"
	RETURNF "略显成熟的"
CASE "固有下半身内衣名"
	RETURNF "荷叶边丁字裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "胸衣"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[芙兰]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/油炸食品/蛋糕/丰盛/ジャンキー/淡白/新鲜/豪快/怪诞/软绵绵/女僕流/洋食/洋食/甜/甜/甜/"
CASE "料理：讨厌的味道"
	RETURNF "和食/質素/辣/辣/野菜/野菜/野菜/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "彩り/刺激的/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/混沌/かわいい/ポップ/洋風/パワフル/ロリータ/" + "血/魔法/人形/" * 3 + "蝠の/悪魔の/紅魔の/禁断の/禁忌の/狂気の/布娃娃/魔法少女の/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/和風/繊細/知的/" + "水/光/書物/护符/护臂/烟袋/女僕的/" * 3 + "日/鎖の/太陽石の/" * 5
ENDSELECT


