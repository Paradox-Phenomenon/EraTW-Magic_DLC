@Fキャラデータ120(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "阿吽"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：靴"
	RETURNF @"{[[靴_木屐]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_衬衫]]}"

CASE "固有内衣形容詞"
	RETURNF "两种颜色的布缝制的"
CASE "固有下半身内衣名"
	RETURNF "红白胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "红白胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/煮物/丰盛/濃厚/春物/豪華/家庭的/豪快/软糯的/神力/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "辣/辣/香料/香料/香料/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "浓郁/得意料理＊春物＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "白/秩序/かっこいい/シンプル/和風/巫術/" + "护符/" * 3 + "犬の/獅子の/守護の/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/奇妙/" + "刃物/" * 3
ENDSELECT


