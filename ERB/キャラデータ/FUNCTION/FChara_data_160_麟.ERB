@Fキャラデータ160(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "麟"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"
	
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_无袖連衣裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_蝴蝶结]]}"

CASE "固有内衣形容詞"
	RETURNF "有机"
CASE "固有下半身内衣名"
	RETURNF "绿叶内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "叶状胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[麟]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "葉物/" * 2 + "淡白/" * 2 + "健康/" * 5 + "中華/" * 5 + "薬効/" * 5
CASE "料理：讨厌的味道"
	RETURNF "虫肉/" * 5 + "青蛙/" * 5 + "卵/" * 5 + "鳥肉/" * 5 + "獣肉/" * 5 + "魚料理/" * 5
CASE "料理：助手効果"
	RETURNF "薬効/"
;贈り物関連
CASE "感性：好き"
	RETURNF "美的/美麗な/天人の/知恵の/" * 2 + "巫女の/風の/花の/懐かしき/" * 3 + "東方の/" * 5
CASE "感性：嫌い"
	RETURNF "魔神の/" + "被遗忘的/" * 10
ENDSELECT


