@Fキャラデータ26(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "紫"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：飾品"
	RETURNF @"{[[飾品_傘]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	IF FLAG:2 > 0
		RETURNF @"{[[襪子_吊带袜]]}"
	ELSE
		RETURNF @"{[[襪子_袜子]]}"
	ENDIF
CASE "便装：連衣裙"
	IF DAY:2 == 1
		RETURNF @"{[[連衣裙_道士服]]}"
	ELSE
		RETURNF @"{[[連衣裙_晚禮服]]}"
	ENDIF
CASE "便装：腕部装束"
	IF DAY:2 == 1
	ELSE
		RETURNF @"{[[腕部装束_晚宴手套]]}"
	ENDIF

CASE "固有内衣形容詞"
	RETURNF "发出奇怪光泽的"
CASE "固有下半身内衣名"
	RETURNF "丝绸内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "丝绸内衣"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[紫]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/肉料理/葉物/健康/芸術的/上品/家庭的/软绵绵/外界風/和食/和食/甜/甜/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "丰盛/ジャンキー/野趣/咸/咸/" + "虫肉/天界風/月都風/" * 3
CASE "料理：助手効果"
	RETURNF "妖力/妖力/得意料理＊和食＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "高級/美的/芸術的/懷舊/別緻/知的/威厳/巫術/" + "紫/妖術/护符/式神の/夢幻の/" * 3 + "黒死蝶の/生と死の/境界の/隙間の/幻葬の/傘/夢と現の/" * 5
CASE "感性：嫌い"
	RETURNF "ポップ/ロリータ/" + "安物/月/护臂/" * 3 + "フェムトファイバーの/天人の/" * 10
ENDSELECT


