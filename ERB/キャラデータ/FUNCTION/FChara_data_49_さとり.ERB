@Fキャラデータ49(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "覚"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_发箍]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"

CASE "固有内衣形容詞"
	RETURNF "优美薔薇刺绣的"
CASE "固有下半身内衣名"
	RETURNF "高级时尚内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "高级时尚胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[覚]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"
;;addition custom code
;CASE "固有下着SHIFTABLE"
;	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/煮物/派/简易/淡白/質素/上品/家庭的/软绵绵/地底風/洋食/洋食/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "肉料理/中華/濃厚/野趣/霊障/辣/辣/丰盛/丰盛/丰盛/外界風/外界風/外界風/"
CASE "料理：助手効果"
	RETURNF "地底風/得意料理＊家庭的＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "粉色/秩序/かわいい/シンプル/洋風/別緻/知的/" + "精神/動物/生体品/" * 3 + "心形の/瞳の/地底の/心の/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/和風/派手/パワフル/" + "安物/刃物/护臂/" * 3

;農民関連
;農家というか庭師？？？
;出荷用ではなく覚さまの趣味の範疇ということで報酬はすくなめに
;きっと部屋に活けたり妹の飾った死体にデコレーションしてる
CASE "農民：説明"
	RETURNF "蔷薇農家"
CASE "農民：作物"
	RETURNF "蔷薇花"
CASE "農民：田的种类"
	RETURNF "薔薇園"
CASE "農民：畑の所在地"
	RETURNF "地底"

CASE "農民：MapID"
	RETURNF "9"
CASE "農民：場所ID"
	RETURNF "925"
CASE "農民：報酬"
	RETURNF "350"
CASE "農民：金利"
	RETURNF "6"

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	RETURNF "2"
CASE "一般依頼発生率"
	RETURNF "3"
CASE "固有依頼発生率"
	RETURNF "5"
CASE "固有依頼最終要素"
	RETURNF "103"
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		RETURNF F固有依頼49(ARG, O_DATA, V_NAME)
ENDSELECT


