@Fキャラデータ145(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "小兎姫"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：和服"
	RETURNF @"{[[和服_和服]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_上衣]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_草履]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_足袋]]}"	

CASE "固有内衣形容詞"
	RETURNF "不知为何化为现实的"
CASE "固有下半身内衣名"
	RETURNF "幻想内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "幻想胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[小兎姫]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "软绵绵/" * 2 +  "香料/" * 2 + "サクサク/" * 3 + "油炸食品/" * 5 + "咸/" * 5 + "絢爛/" * 2 + "高级食材/" * 10
CASE "料理：讨厌的味道"
	RETURNF "葉物/" * 2 + "酸/" * 5 + "果物/" * 3 + "辣/" * 8 + "平价食材/" * 10
CASE "料理：助手効果"
	RETURNF "得意料理＊霊障＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "奇妙/高級/和風の/可爱黑暗的/怪诞/かわいい/時尚/法具/手杖/俗气の/破烂の/古旧の/粗陋の/有缺口の/弯曲の/偽物の/锈迹の/损壊の/被诅咒の/诅咒の/" + "紫/手錠/" * 3 + "秩序/マニアック/弾/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/シンプル/派手/玩具の/" + "安物/" * 3 + "妖力/" * 10
ENDSELECT


