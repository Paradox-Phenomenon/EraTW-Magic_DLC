@Fキャラデータ157(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "残無"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_绳饰]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_罩衫]]}"
CASE "便装：裤子"
	RETURNF @"{[[裤子_短裤]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_木屐]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_绳饰]]}"

CASE "固有内衣形容詞"
	RETURNF "呼唤鬼魂的"
CASE "固有下半身内衣名"
	RETURNF "虚无胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "虚无吊带背心"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "鍋物/淡白/ジャンキー/豪快/上品/質素/软糯的/霊障/地獄風/辣/辣/咸/咸/" + "米/野菜/" * 3
CASE "料理：讨厌的味道"
	RETURNF "甜/甜/丰盛/健康/家庭的/新鲜/" + "面包/" * 3
CASE "料理：助手効果"
	RETURNF "地獄風/薄味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黒/かっこいい/シンプル/懷舊/知的/不思議/" + "闇/妖術/無の/" * 3 + "虚無の/" * 5
CASE "感性：嫌い"
	RETURNF "かわいい/ポップ/ロリータ/マニアック/"+ "機械/" * 5
ENDSELECT


