@Fキャラデータ163(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "驯子"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（吊带睡裙）套"
	
CASE "便装：裤子"
	RETURNF @"{[[裤子_探险短裤]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_探险夹克]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_金饰发箍]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_靴子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_长筒袜]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_金权杖]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_耳环]]}"

CASE "固有内衣形容詞"
	RETURNF "荷鲁斯之眼刺绣的"
CASE "固有下半身内衣名"
	RETURNF "素色亚麻胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "素色亚麻胸罩"
CASE "固有内衣着用条件"
	;也是必穿
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
;彼女の謎は正解あるから、謎料理より隠し味がすきそう
CASE "料理：喜欢的味道"
	RETURNF "隠し味/" * 3 + "洋食/外界風/ジャンキー/サクサク/怪诞/辣/"
CASE "料理：讨厌的味道"
	RETURNF "科学的/化学的/" * 5 + "淡白/" * 3 + "和食/简易/健康/"
CASE "料理：助手効果"
	RETURNF "隠し味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "モダンな/杖/青/金/マニアック/" + "守護の/知恵の/千年の/異国風の/砂漠の/守護石/ピラミッド/" * 3 + "謎の/エニグマティクな/神秘的/" * 5
CASE "感性：嫌い"
	RETURNF "和風/灰/シンプル/可怕的/" + "封印されし/禁忌の/境界の/" * 3 
ENDSELECT


