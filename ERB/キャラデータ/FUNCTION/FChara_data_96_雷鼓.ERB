@Fキャラデータ96(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "雷鼓"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_夹克衫]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_衬衫]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_领带]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_吊帯]]}"
CASE "便装：其他３"
	RETURNF @"{[[其他衣装_大鼓]]}"

CASE "固有内衣形容詞"
	RETURNF "摇滚风格的"
CASE "固有下半身内衣名"
	RETURNF "侧边系绳胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "黑文胸"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[雷鼓]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "面包/香料/洋食/油炸食品/丰盛/豪華/芸術的/豪快/サクサク/辣/辣/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "简易/酸/酸/" + "青蛙/虫肉/蘑菇/謎料理/" * 3
CASE "料理：助手効果"
	RETURNF "刺激的/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/かっこいい/混沌/シンプル/和風/パワフル/知的/" + "雷/音楽/楽器/" * 3 + "太古の/雷神の/闪电の/领带/鼓槌/指揮棒/" * 5
CASE "感性：嫌い"
	RETURNF "洋風/繊細/ロリータ/" + "刃物/生体品/护臂/" + "精霊銀の/" * 10
ENDSELECT


