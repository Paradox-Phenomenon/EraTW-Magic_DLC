@Fキャラデータ48(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "露易茲"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_水手服]]}"

CASE "固有内衣形容詞"
	RETURNF "旅行用的"
CASE "固有下半身内衣名"
	RETURNF "一次性内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "一次性胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "乳酪/香料/洋食/汁物/ジャンキー/淡白/豪華/新鲜/怪诞/软糯的/魔界風/外界風/甜/甜/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "野趣/咸/咸/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/"
CASE "料理：助手効果"
	RETURNF "魔界風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黒/美的/時尚/ポップ/繊細/" + "魔法/自然/" * 3 + "地上の/楽園の/霊天の/" * 5
CASE "感性：嫌い"
	RETURNF "奇妙/懷舊/パワフル/ロリータ/マニアック/" + "护臂/" * 3
ENDSELECT

