@Fキャラデータ92(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "布都"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_乌帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_水干]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_迷你裙]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_盘子]]}"

CASE "固有内衣形容詞"
	RETURNF "好像是被谁骗着穿的"
CASE "固有下半身内衣名"
	RETURNF "儿童内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "裹胸"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/卵/汁物/ジャンキー/淡白/豪華/上品/家庭的/软糯的/仙術/天界風/和食/和食/甜/甜/甜/"
CASE "料理：讨厌的味道"
	RETURNF "洋食/丰盛/濃厚/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/辣/辣/辣/辣/" + "怪诞/謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "薄味/得意料理＊和食＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/白/火/秩序/かわいい/懷舊/壮大/" + "巫術/护符/食器/" * 3 + "仙人の/風水の/皿/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/可怕的/知的/" + "死生/機械/" * 3 
ENDSELECT


