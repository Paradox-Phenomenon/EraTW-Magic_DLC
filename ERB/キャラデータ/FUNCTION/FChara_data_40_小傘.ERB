@Fキャラデータ40(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "小傘"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "パンイチ"

CASE "便装：飾品"
	RETURNF @"{[[飾品_傘]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_木屐]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "固有指令"
	RETURNF "伞的修理"
CASE "固有指令実行可能"
	RETURNF @"{(FLAG:傘耐久度 > 5000 || ITEM:壊掉的傘) && !GETBIT(TFLAG:一日一回, 13)}"

CASE "固有内衣形容詞"
	RETURNF "吓唬人的"
CASE "固有下半身内衣名"
	RETURNF "眼珠图案胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "眼珠图案胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[小傘]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/和食/煮物/濃厚/質素/新鲜/謎料理/软糯的/美味的水/甜/甜/辣/辣/茄子/茄子/茄子/"
CASE "料理：讨厌的味道"
	RETURNF "肉料理/简易/酸/酸/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/"
CASE "料理：助手効果"
	RETURNF "ドッキリ味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/虹/かわいい/懷舊/繊細/" + "水/金属/刃物/" * 3 + "绣球花の/虹の/雨の/雪の/嵐の/" * 5
CASE "感性：嫌い"
	RETURNF "洋風/パワフル/" + "日/生体品/护臂/" * 3 + "傘/" * 5 + "忘却の/" * 10
ENDSELECT


