@Fキャラデータ72(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "永琳"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_蝴蝶结]]}"

CASE "固有内衣形容詞"
	RETURNF "神秘气息浓厚的"
CASE "固有下半身内衣名"
	RETURNF "倭文布胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "倭文布胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:3
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

CASE "固有指令"
	IF 成人再教育插件开关 == 1
		RETURNF "与永琳对话"
	ELSE
		RETURNF "贩卖生药"
	ENDIF
CASE "固有指令実行可能"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/蘑菇/中華/汁物/简易/健康/淡白/質素/機能的/上品/滑溜溜/月都風/科学的/赏月/咸/咸/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "洋食/丰盛/ジャンキー/甜/甜/香料/香料/香料/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "月都風/薬効/"
;贈り物関連
CASE "感性：好き"
	RETURNF "銀/秩序/美的/懷舊/知的/" + "毒/道具/" * 3 + "千年の/神代の/賢者の/药瓶/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/ポップ/ロリータ/マニアック/" + "护臂/" * 3

;農民関連
;ホントに薬？
CASE "農民：説明"
	RETURNF "薬草農家"
CASE "農民：作物"
	RETURNF "薬草"
CASE "農民：田的种类"
	RETURNF "薬草畑"
CASE "農民：畑の所在地"
	RETURNF "迷途竹林"

CASE "農民：MapID"
	RETURNF "4"
CASE "農民：場所ID"
	RETURNF "436"
CASE "農民：報酬"
	RETURNF "600"
CASE "農民：金利"
	RETURNF "14"
ENDSELECT


