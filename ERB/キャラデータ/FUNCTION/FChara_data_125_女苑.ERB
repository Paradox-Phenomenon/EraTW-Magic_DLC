@Fキャラデータ125(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "女苑"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍）套"

CASE "便装：飾品"
	RETURNF @"{[[飾品_太阳镜]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_长靴]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_夹克衫]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_手链]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_耳环]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_单肩包]]}"

CASE "固有内衣形容詞"
	RETURNF "总之很华丽的"
CASE "固有下半身内衣名"
	RETURNF "闪亮胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "闪亮胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "高级食材/肉料理/面包/洋食/汁物/派/丰盛/ジャンキー/濃厚/豪華/上品/新鲜/サクサク/甜/甜/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "淡白/" + "酸/質素/野菜/" * 2 + "平价食材/怪诞/謎料理/" * 3 + "青蛙/虫肉/" * 5
CASE "料理：助手効果"
	RETURNF "絢爛/"
;贈り物関連
CASE "感性：好き"
	RETURNF "高級/混沌/美的/時尚/洋風/派手/威厳/壮大/装飾/" + "金/宝石/扇/" * 3 + "高級的/華麗的/钱包/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/奇妙/懷舊/和風/別緻/" + "書物/生体品/遺物/护臂/機械/" * 3 + "安物/主役の/" * 10
ENDSELECT


