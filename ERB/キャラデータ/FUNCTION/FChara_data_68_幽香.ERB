@Fキャラデータ68(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "幽香"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"


CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_傘]]}"
CASE "便装：襪子"
	IF FLAG:2 > 0
		RETURNF @"{[[襪子_吊带袜]]}"
	ELSE
		RETURNF @"{[[襪子_袜子]]}"
	ENDIF
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_背心]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_領巾]]}"

CASE "固有内衣形容詞"
	RETURNF "色气与可爱并存的"
CASE "固有下半身内衣名"
	RETURNF "荷叶边内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "荷叶边胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[幽香]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"
	
;CASE "固有指令"
;	RETURNF "弾幕勝負"
;CASE "固有指令実行可能"
;	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "面包/牛奶/洋食/汁物/蛋糕/丰盛/健康/夏物/豪華/上品/新鲜/软绵绵/夢幻風/咸/咸/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "辣/辣/" + "青蛙/虫肉/質素/" * 3 + "謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "夢幻風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "緑/かわいい/時尚/懷舊/パワフル/" + "土/植物/" * 3 + "向日葵の/花の/華の/夢幻の/種/傘/" * 5
CASE "感性：嫌い"
	RETURNF "繊細/マニアック/" + "火/刃物/" * 3

;農民関連
;「かき」と読みます
;園芸用の草花のこと
;仕事の手伝いと被ってるがどうしよう
CASE "農民：説明"
	RETURNF "花卉農家"
CASE "農民：作物"
	RETURNF "花苗"
CASE "農民：田的种类"
	RETURNF "花圃"
CASE "農民：畑の所在地"
	RETURNF "迷途竹林"

CASE "農民：MapID"
	RETURNF "4"
CASE "農民：場所ID"
	RETURNF "438"
CASE "農民：報酬"
	RETURNF "400"
CASE "農民：金利"
	RETURNF "15"
ENDSELECT


