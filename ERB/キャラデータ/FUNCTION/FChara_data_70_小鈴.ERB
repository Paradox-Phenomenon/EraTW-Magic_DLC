@Fキャラデータ70(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "小鈴"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（连衣裙）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_发饰]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_行灯袴]]}"
CASE "便装：和服"
	RETURNF @"{[[和服_和服]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_肌襦袢]]}"

CASE "固有内衣形容詞"
	RETURNF "英文报纸图案的"
CASE "固有下半身内衣名"
	RETURNF "黑白印花内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "黑白印花胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[小鈴]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/牛奶/和食/麺類/酸/简易/淡白/豪華/上品/家庭的/软糯的/外界風/" + "甜/" * 3
CASE "料理：讨厌的味道"
	RETURNF "野趣/辣/辣/" + "青蛙/香料/地獄風/" * 3 + "虫肉/怪诞/謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "薄味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "緑/秩序/かわいい/奇妙/ポップ/知的/不思議/マニアック/" + "眼鏡/書物/" * 3 + "妖怪の/妖魔の/外界の/妖魔圖鑒/鈴/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/可怕的/" + "火/幽霊/刃物/弾/生体品/护臂/烟袋/鼠の/" * 3
ENDSELECT


