@Fキャラデータ91(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "屠自古"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_乌帽子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_护符]]}"

CASE "固有内衣形容詞"
	RETURNF "没有重量的"
CASE "固有下半身内衣名"
	RETURNF "灵体胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "灵体胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"


;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/油炸食品/简易/淡白/上品/新鲜/豪快/软绵绵/仙術/和食/和食/咸/咸/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "洋食/丰盛/濃厚/質素/甜/甜/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/"
CASE "料理：助手効果"
	RETURNF "刺激的/"
;贈り物関連
CASE "感性：好き"
	RETURNF "緑/美的/懷舊/威厳/" + "雷/幽霊/" * 3 + "亡霊の/闪电の/" * 5
CASE "感性：嫌い"
	RETURNF "ポップ/繊細/" + "护符/生体品/" * 3

;農民関連
;豪族組で相談したら土地も用意できそうだけどそこまでしてくれるか？
CASE "農民：説明"
	RETURNF "大根農家"
CASE "農民：作物"
	RETURNF "大根"
CASE "農民：田的种类"
	RETURNF "大根畑"
CASE "農民：畑の所在地"
	RETURNF "人里"

CASE "農民：MapID"
	RETURNF "2"
CASE "農民：場所ID"
	RETURNF "205"
CASE "農民：報酬"
	RETURNF "400"
CASE "農民：金利"
	RETURNF "12"
ENDSELECT


