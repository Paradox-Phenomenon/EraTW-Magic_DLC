@Fキャラデータ4(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "魅魔"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：外搭"
	RETURNF @"{[[外搭_披肩]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_新月之杖]]}"

CASE "固有内衣形容詞"
	RETURNF "嫩肤之上夺目的"
CASE "固有下半身内衣名"
	RETURNF "薔薇刺绣胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "蔷薇刺绣胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[魅魔]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "香料/蘑菇/洋食/汁物/咸/简易/淡白/豪華/上品/豪快/软绵绵/赏月/辣/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "中華/甜/丰盛/濃厚/質素/魔界風/魔界風/魔界風/"
CASE "料理：助手効果"
	RETURNF "魔力/" * 2
;贈り物関連
CASE "感性：好き"
	RETURNF "黒/混沌/可怕的/懷舊/知的/威厳/" + "幽霊/魔法/闇/" * 3 + "幽霊の/闇の/斗篷/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/未来/ロリータ/" + "神霊/护符/护臂/" * 3

ENDSELECT


