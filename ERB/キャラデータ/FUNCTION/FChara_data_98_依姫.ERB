@Fキャラデータ98(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "依姫"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_背带裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_短袖女式衬衫]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_手链]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_束腰]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_刀]]}"

CASE "固有内衣形容詞"
	RETURNF "毫无污秽的"
CASE "固有下半身内衣名"
	RETURNF "无邪的衬裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "清浄的内衬"
CASE "固有内衣着用条件"
	SIF !RAND:3
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/麺類/健康/質素/上品/芸術的/软糯的/月都風/赏月/美味的水/中華/中華/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "洋食/ジャンキー/野趣/酸/酸/" + "青蛙/虫肉/怪诞/" * 3 + "謎料理/生命力/" * 5
CASE "料理：助手効果"
	RETURNF "月都風/切れ味/神力/神力/"
;贈り物関連
CASE "感性：好き"
	RETURNF "白/秩序/美的/シンプル/大陸風/別緻/威厳/" + "水/月/神霊/巫術/刃物/护符/" * 3 + "海神の/海の/穢れなき/かわいい/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/奇妙/洋風/派手/ロリータ/マニアック/" + "土/闇/死生/生体品/烟袋/" * 3 + "地上の/万魔殿な/" * 10
ENDSELECT


