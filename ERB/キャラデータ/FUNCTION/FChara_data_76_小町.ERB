@Fキャラデータ76(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "小町"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_发饰]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_木屐]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_足袋]]}"
CASE "便装：和服"
	RETURNF @"{[[和服_和服]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_肌襦袢]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_帯]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_大镰]]}"

CASE "固有内衣形容詞"
	RETURNF "成熟魅力溢出的"
CASE "固有下半身内衣名"
	RETURNF "丁字裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "蕾丝胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[小町]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/香料/和食/油炸食品/下酒菜/丰盛/ジャンキー/濃厚/豪華/新鲜/豪快/霊障/冥界風/辣/辣/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "健康/化学的/酸/酸/質素/質素/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/"
CASE "料理：助手効果"
	RETURNF "冥界風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/美的/和風/派手/" + "死生/酒/" * 3 + "死神の/彼岸の/带来死亡の/" * 5
CASE "感性：嫌い"
	RETURNF "洋風/繊細/ロリータ/マニアック/" + "领带/" * 3

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	RETURNF "2"
CASE "一般依頼発生率"
	RETURNF "3"
CASE "固有依頼発生率"
	RETURNF "5"
CASE "固有依頼最終要素"
	RETURNF "101"
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		CALLF 固有依頼76(ARG, O_DATA, V_NAME)
ENDSELECT


