@Fキャラデータ100(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "鈴仙二號"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_长筒袜]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_白衬衫]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_西装上衣]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_领带]]}"

CASE "固有内衣形容詞"
	RETURNF "除了朴素毫无特点的"
CASE "固有下半身内衣名"
	RETURNF "玉兔配给胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "玉兔配给胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[鈴仙二號]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/米/中華/葉物/简易/健康/質素/機能的/家庭的/玉兎流/月都風/赏月/甜/甜/酸/酸/胡萝卜/胡萝卜/胡萝卜/胡萝卜/胡萝卜/"
CASE "料理：讨厌的味道"
	RETURNF "咸/咸/" + "青蛙/獣肉/虫肉/生命力/" * 3 + "怪诞/謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "玉兎流/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黄/秩序/かわいい/繊細/" + "月/护符/桃の/" * 3 + "兔の/海神の/领带/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/可怕的/パワフル/威厳/" + "刃物/护臂/" * 3
ENDSELECT


