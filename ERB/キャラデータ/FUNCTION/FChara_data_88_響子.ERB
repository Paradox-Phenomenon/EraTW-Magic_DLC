@Fキャラデータ88(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "響子"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_扫帚]]}"

CASE "固有内衣形容詞"
	RETURNF "古朴妖怪图案的"
CASE "固有下半身内衣名"
	RETURNF "印花内裤(山彦)"
CASE "固有上半身内衣"
	RETURNF "0"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[響子]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "鳥肉/牛奶/麺類/派/酸/简易/濃厚/質素/野趣/家庭的/软糯的/" + "甜/" * 3
CASE "料理：讨厌的味道"
	RETURNF "辣/辣/怪诞/怪诞/怪诞/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "浓郁/得意料理＊家庭的＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "緑/かっこいい/ポップ/派手/" + "パワフル/音楽/" * 3 + "犬の/山の/経典/" * 5
CASE "感性：嫌い"
	RETURNF "別緻/威厳/知的/" + "闇/" * 3
ENDSELECT


