@Fキャラデータ90(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "青娥"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（吊带睡裙）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_簪子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_背心]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_羽衣]]}"

CASE "固有内衣形容詞"
	RETURNF "体现性感的"
CASE "固有下半身内衣名"
	RETURNF "系带胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "胸前系带文胸"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[青娥]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"
CASE "デート衣装", "人里デート衣装", "おうちデート衣装"
	SELECTCASE RAND:3
		CASE 2
			RETURNF @"{[[生足美鈴套]]}"
		CASE 1
			RETURNF @"{[[辣妹系休闲套装]]}"
	ENDSELECT

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/麺類/丰盛/淡白/上品/新鲜/黏稠/仙術/妖力/霊障/月都風/中華/中華/辣/辣/咸/咸/怪诞/怪诞/怪诞/"
CASE "料理：讨厌的味道"
	RETURNF "質素/神力/神力/神力/酸/酸/冥界風/冥界風/冥界風/天界風/天界風/天界風/"
CASE "料理：助手効果"
	RETURNF "妖力/霊障/得意料理＊中華＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "高級/混沌/可怕的/奇妙/大陸風/知的/不思議/" + "青/闇/骨/死生/妖術/" * 3 + "死霊の/仙人の/呪術の/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/ロリータ/" + "安物/神霊/护臂/" * 3
ENDSELECT


