@Fキャラデータ86(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "水蜜"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裤子"
	RETURNF @"{[[裤子_短裤]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_水手服]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_木舀子]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_船锚]]}"

CASE "固有内衣形容詞"
	RETURNF "绣上船锚的"
CASE "固有下半身内衣名"
	RETURNF "男孩子气内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "吊带背心"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[村紗]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/香料/汁物/咖喱/ジャンキー/濃厚/冷/機能的/豪快/怪诞/滑溜溜/辣/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "油炸食品/甜/甜/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/"
CASE "料理：助手効果"
	RETURNF "刺激的/美味的水/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/混沌/可怕的/" + "水/幽霊/妖術/" * 3 + "海の/深海の/錨の/" * 5
CASE "感性：嫌い"
	RETURNF "知的/威厳/" + "光/火/护符/护臂/" * 3
ENDSELECT


