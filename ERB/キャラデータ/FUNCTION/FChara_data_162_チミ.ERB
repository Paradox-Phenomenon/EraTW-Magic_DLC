@Fキャラデータ162(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "魑魅"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（吊带睡裙）套"
	
CASE "便装：外搭"
	RETURNF @"{[[外搭_树叶蓑衣]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_围巾]]}"

CASE "固有内衣形容詞"
	RETURNF "马赛克模糊的"
CASE "固有下半身内衣名"
	RETURNF "漩涡胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "漩涡胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:3
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
;鮮やかで自然に親しいぬえ
CASE "料理：喜欢的味道"
	RETURNF "甜/野趣/果物/謎料理/" * 3 + "新鲜/酸/" * 2 + "野菜/怪诞/滑溜溜/淡白/妖力/"
CASE "料理：讨厌的味道"
	RETURNF "科学的/化学的/" * 5 + "辣/ジャンキー/" * 3 + "機能的/" * 2
CASE "料理：助手効果"
	RETURNF "未知の味/妖力/"
;贈り物関連
CASE "感性：好き"
	RETURNF "混沌/古の/可怕的/奇妙/不思議/葉っぱの/" + "森の/水の/妖術/自然/うずまきの/" * 3 + "謎の/正体不明の/幻獣の/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/洋風/ポップ/知的/" + "モダンな/金属/" * 3 + "真実の/" * 10
ENDSELECT


