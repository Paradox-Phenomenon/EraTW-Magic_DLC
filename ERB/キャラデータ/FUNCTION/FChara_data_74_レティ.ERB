@Fキャラデータ74(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "蕾蒂"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_头巾帽]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_背心]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_围巾]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_胸针]]}"

CASE "固有内衣形容詞"
	RETURNF "冰霜般的"
CASE "固有下半身内衣名"
	RETURNF "雪女胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "雪女胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/牛奶/鍋物/冰淇淋/丰盛/濃厚/豪華/芸術的/家庭的/软糯的/甜/甜/咸/咸/" + "冷/" * 3 + "冬物/" * 5
CASE "料理：讨厌的味道"
	RETURNF "辣/辣/" + "香料/春物/謎料理/" * 3
CASE "料理：助手効果"
	RETURNF "氷結/得意料理＊冬物＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "美的/芸術的/別緻/" + "白/銀/氷/" * 3 + "水晶の/雪だるまの/冬の/白雪の/" * 5
CASE "感性：嫌い"
	RETURNF "日/护臂/" * 3 + "春の/秋の/樱花の/向日葵の/西瓜の/春風の/秋風の/" * 5 + "火/夏の/" * 10
ENDSELECT


