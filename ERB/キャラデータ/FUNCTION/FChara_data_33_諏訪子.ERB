@Fキャラデータ33(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "諏訪子"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子+兜帽）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	IF FLAG:2 > 0
		RETURNF @"{[[襪子_长筒袜]]}"
	ELSE
		RETURNF @"{[[襪子_袜子]]}"
	ENDIF
CASE "便装：上半身内衣１"
	RETURNF @"{[[上半身内衣_はだけ不可_裹胸]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_无袖上衣]]}"

CASE "固有内衣形容詞"
	RETURNF "少女香气的"
CASE "固有下半身内衣名"
	RETURNF "蛙神胖次"
CASE "固有上半身内衣"
	RETURNF "0"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[諏訪子]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "獣肉/和食/汁物/甜/简易/質素/野趣/家庭的/黏稠/妖力/美味的水/酸/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "中華/丰盛/辣/辣/" + "青蛙/" * 10
CASE "料理：助手効果"
	RETURNF "加護/美味的水/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/緑/巫術/秩序/美的/懷舊/" + "土/水/妖術/大地の/" * 3 + "翡翠の/蛙の/白蛇の/" * 5
CASE "感性：嫌い"
	RETURNF "パワフル/" + "風/刃物/护臂/" * 3 + "茨の/風神の/博霊の/" * 10

;農民関連
;沼っぽい場所に生えるっぽいので
;ケロケロな諏訪子様に協力してもらおう
;財力もありそうだけどそもそもの単価が安いという脳内設定
CASE "農民：説明"
	RETURNF "菱農家"
CASE "農民：作物"
	RETURNF "菱"
CASE "農民：田的种类"
	RETURNF "蓄水池"
CASE "農民：畑の所在地"
	RETURNF "妖怪之山・山麓"

CASE "農民：MapID"
	RETURNF "7"
CASE "農民：場所ID"
	RETURNF "708"
CASE "農民：報酬"
	RETURNF "400"
CASE "農民：金利"
	RETURNF "12"
ENDSELECT


