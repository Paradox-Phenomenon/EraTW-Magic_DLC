@Fキャラデータ153(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "美天"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"
CASE "便装：飾品"
	RETURNF @"{[[飾品_袖]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_手链]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_金箍]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_试管]]}"

CASE "固有内衣形容詞"
	RETURNF "西游记风格的"
CASE "固有下半身内衣名"
	RETURNF "猴王胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "猴王胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "麺類/丰盛/濃厚/豪華/豪快/新鲜/サクサク/神力/畜生流/" + "中華/辣/咸/" * 2 + "炸薯条/肉料理/" * 3
CASE "料理：讨厌的味道"
	RETURNF "野菜/酸/酸/简易/淡白/質素/"
CASE "料理：助手効果"
	RETURNF "畜生流/得意料理＊中華＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/秩序/かっこいい/大陸風/パワフル/壮大/" + "神霊/水獭の/" * 3 + "猴子の/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/洋風/繊細/知的/" + "狼の/鹫の/犬の/" * 10
ENDSELECT


