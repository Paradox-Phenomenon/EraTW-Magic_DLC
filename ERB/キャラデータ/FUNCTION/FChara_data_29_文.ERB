@Fキャラデータ29(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "文"

;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裙子）套"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_兜巾]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_木屐]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_领带]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_照相机]]}"

CASE "固有内衣形容詞"
	RETURNF "濡鸦色的"
CASE "固有下半身内衣名"
	RETURNF "高叉胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "三角胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[文]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;特殊衣装設定
CASE "おうちデート衣装"
	IF MAIN_MAP == 2
		RETURNF @"{[[鴨舌帽文套]]}"
	ELSE
		RETURNF @"{[[学院系休闲套装]]}"
	ENDIF
CASE "人里デート衣装", "人間衣装"
	RETURNF @"{[[鴨舌帽文套]]}"

CASE "固有指令"
	RETURNF "订阅新闻"
CASE "固有指令実行可能"
	RETURNF @"{!FLAG:新聞購読}"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/獣肉/虫肉/和食/煮物/ジャンキー/濃厚/豪華/機能的/野趣/サクサク/天狗流/辣/辣/咸/咸/" + "秋物/" * 3
CASE "料理：讨厌的味道"
	RETURNF "洋食/酸/酸/卵/卵/卵/外界風/外界風/外界風/鳥肉/鳥肉/鳥肉/鳥肉/鳥肉/"
CASE "料理：助手効果"
	RETURNF "得意料理＊秋物＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "白/宝石/秩序/かわいい/懷舊/知的/不思議/壮大/" + "風/鳥/文具/硬幣/風の/秋の/" * 3 + "鸦の/枫叶の/天狗の/疾風の/手賬/领带/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/ポップ/パワフル/ロリータ/" + "弾/护臂/" * 3 + "龟の/河童の/鬼の/" * 10

;農民関連
;天狗も水田持ってそう
;山っぽさをだすなら芥末なども可
CASE "農民：説明"
	RETURNF "米農家"
CASE "農民：作物"
	RETURNF "大米"
CASE "農民：田的种类"
	RETURNF "水田"
CASE "農民：畑の所在地"
	RETURNF "妖怪之山・山麓"

CASE "農民：MapID"
	RETURNF "7"
CASE "農民：場所ID"
	RETURNF "732"
CASE "農民：報酬"
	RETURNF "450"
CASE "農民：金利"
	RETURNF "12"

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	RETURNF "2"
CASE "一般依頼発生率"
	RETURNF "3"
CASE "固有依頼発生率"
	RETURNF "5"
CASE "固有依頼最終要素"
	RETURNF "102"
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		RETURNF F固有依頼29(ARG, O_DATA, V_NAME)
ENDSELECT


