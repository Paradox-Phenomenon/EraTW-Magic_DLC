@Fキャラデータ140(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "龍"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍+睡帽）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_兜巾]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_斗篷]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_木屐]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_三脚架]]}"
	
CASE "固有内衣形容詞"
	RETURNF "带亮粉的"
CASE "固有下半身内衣名"
	RETURNF "星空胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "星空胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[龍]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "2"
;特殊衣装
CASE "デート衣装", "人里デート衣装", "おうちデート衣装"
	SELECTCASE DAY:2
		CASE 1,4
			RETURNF @"{[[盛装和服套装]]}"
		CASEELSE
			RETURNF @"{[[浴衣穿搭]]}"
	ENDSELECT

CASE "固有指令"
	RETURNF "龙珠的交易"
CASE "固有指令実行可能"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/米/米/獣肉/獣肉/獣肉/虫肉/虫肉/虫肉/和食/麺類/甜/甜/咸/咸/淡白/豪華/野趣/新鲜/软糯的/天狗流/"
CASE "料理：讨厌的味道"
	RETURNF "鳥肉/鳥肉/鳥肉/鳥肉/鳥肉/卵/卵/卵/洋食/酸/酸/"
CASE "料理：助手効果"
	RETURNF "薄味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/美的/懷舊/威厳/" + "星/鳥/" * 3 + "鸦の/天狗の/龍の/星空の/星降の/透镜/" * 5
CASE "感性：嫌い"
	RETURNF "赤/ロリータ/マニアック/" + "日/" * 3 + "河童の/鬼の/" * 10
ENDSELECT


