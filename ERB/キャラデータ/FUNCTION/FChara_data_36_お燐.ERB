@Fキャラデータ36(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "阿燐"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"

CASE "固有内衣形容詞"
	RETURNF "不妨碍尾巴的"
CASE "固有下半身内衣名"
	RETURNF "镂空蕾丝胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "褶边胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/肉料理/油炸食品/丰盛/ジャンキー/濃厚/温暖/野趣/家庭的/サクサク/地底風/甜/甜/咸/咸/" + "怪诞/" * 3
CASE "料理：讨厌的味道"
	RETURNF "野菜/简易/健康/冷/辣/辣/香料/香料/香料/"
CASE "料理：助手効果"
	RETURNF "地獄風/地底風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/混沌/可怕的/奇妙/" + "火/骨/幽霊/妖術/生体品/" * 3 + "猫の/死霊の/地霊の/廃獄の/骷髅の/" * 5
CASE "感性：嫌い"
	RETURNF "水/氷/护臂/" * 3 + "犬の/狼の/" * 10

;農民関連
;獼猴桃はマタタビの仲間でネコをメロメロにする
;果実にその効果はないみたいだが
CASE "農民：説明"
	RETURNF "獼猴桃農家"
CASE "農民：作物"
	RETURNF "獼猴桃"
CASE "農民：田的种类"
	RETURNF "獼猴桃農園"
CASE "農民：畑の所在地"
	RETURNF "地底"

CASE "農民：MapID"
	RETURNF "9"
CASE "農民：場所ID"
	RETURNF "926"
CASE "農民：報酬"
	RETURNF "400"
CASE "農民：金利"
	RETURNF "8"
ENDSELECT


