@Fキャラデータ12(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "露米娅"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_无袖上衣]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_領巾]]}"

CASE "固有内衣形容詞"
	RETURNF "映着黑暗的"
CASE "固有下半身内衣名"
	RETURNF "漆黑胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "漆黑吊带衫"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[露米娅]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/肉料理/油炸食品/甜/濃厚/豪華/野趣/サクサク/丰盛/丰盛/" + "青蛙/咸/怪诞/" * 3
CASE "料理：讨厌的味道"
	RETURNF "野菜/酸/淡白/質素/简易/简易/简易/"
CASE "料理：助手効果"
	RETURNF "浓郁/"
;贈り物関連
CASE "感性：好き"
	RETURNF "可怕的/ロリータ/" + "黒/闇/生体品/" * 3 + "妖魔の/宵闇の/闇の/" * 5
CASE "感性：嫌い"
	RETURNF "知的/" + "白/光/日/照明/" * 3

ENDSELECT


