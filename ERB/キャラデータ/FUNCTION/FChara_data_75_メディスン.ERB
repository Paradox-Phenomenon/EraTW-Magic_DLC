@Fキャラデータ75(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "梅蒂欣"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"

CASE "固有内衣形容詞"
	RETURNF "可能有毒的"
CASE "固有下半身内衣名"
	RETURNF "紫色胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "紫色胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[梅蒂欣]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "卵/牛奶/汁物/派/简易/豪華/上品/新鲜/软绵绵/霊障/甜/甜/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "神力/辣/辣/丰盛/丰盛/" + "青蛙/虫肉/香料/" * 3
CASE "料理：助手効果"
	RETURNF "刺激的/"
;贈り物関連
CASE "感性：好き"
	RETURNF "紫/混沌/かわいい/洋風/不思議/" + "毒/装飾/" * 3 + "铃兰の/毒の/药瓶/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/和風/知的/" + "金属/生体品/护臂/烟袋/機械/" * 3
ENDSELECT


