@Fキャラデータ85(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "一輪"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_头巾]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_法衣]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_金环]]}"

CASE "固有内衣形容詞"
	RETURNF "闻着香香的"
CASE "固有下半身内衣名"
	RETURNF "半旧的棉布胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "半旧的棉布胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[一輪]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/香料/和食/鍋物/甜/简易/健康/淡白/質素/家庭的/豪快/软绵绵/" + "咸/" * 3
CASE "料理：讨厌的味道"
	RETURNF "洋食/上品/外界風/酸/酸/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/"
CASE "料理：助手効果"
	RETURNF "薄味/得意料理＊软绵绵＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/白/秩序/美的/パワフル/" + "風/法具/" * 3 + "雲の/天輪の/法輪/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/繊細/ロリータ/マニアック/" + "土/" * 3 + "蜘蛛の/" * 5
ENDSELECT


