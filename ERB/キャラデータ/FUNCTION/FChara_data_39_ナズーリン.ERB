@Fキャラデータ39(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "纳兹琳"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子+兜帽）套"

CASE "便装：外搭"
	RETURNF @"{[[外搭_披肩]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_无袖上衣]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_探测棒]]}"

CASE "固有内衣形容詞"
	RETURNF "尾部有洞的"
CASE "固有下半身内衣名"
	RETURNF "灰色针织内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "针织内衣"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "3"

CASE "固有指令"
	IF 成人再教育插件开关 == 1
		RETURNF "与纳兹琳对话"
	ELSE 
		RETURNF "灵摆查找"
	ENDIF
CASE "固有指令実行可能"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "香料/中華/油炸食品/辣/丰盛/ジャンキー/濃厚/野趣/新鲜/怪诞/黏稠/甜/甜/甜/乳酪/乳酪/乳酪/乳酪/乳酪/"
CASE "料理：讨厌的味道"
	RETURNF "简易/健康/新鲜/咸/咸/淡白/淡白/淡白/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "得意料理＊乳酪＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "灰/かわいい/懷舊/繊細/知的/" + "宝石/遺物/" * 3 + "鼠の/小小の/" * 5
CASE "感性：嫌い"
	RETURNF "パワフル/派手/" + "护臂/" * 3 + "猫の/" * 10

;農民関連
;泣きついたら小言を言いながら何とかしてくれそう
;特に寺の連中が見てたら断りきれない
CASE "農民：説明"
	RETURNF "茄子農家"
CASE "農民：作物"
	RETURNF "茄子"
CASE "農民：田的种类"
	RETURNF "茄子畑"
CASE "農民：畑の所在地"
	RETURNF "命蓮寺"

CASE "農民：MapID"
	RETURNF "1"
CASE "農民：場所ID"
	RETURNF "106"
CASE "農民：報酬"
	RETURNF "400"
CASE "農民：金利"
	RETURNF "8"
ENDSELECT


