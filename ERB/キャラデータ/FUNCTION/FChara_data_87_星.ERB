@Fキャラデータ87(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "星"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_法衣]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_羽衣]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_长矛]]}"
CASE "便装：其他３"
	RETURNF @"{[[其他衣装_宝塔]]}"

CASE "固有内衣形容詞"
	RETURNF "和本人一致的"
CASE "固有下半身内衣名"
	RETURNF "虎纹胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "虎纹胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[星]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/肉料理/油炸食品/丰盛/濃厚/豪華/野趣/家庭的/サクサク/神力/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "面包/简易/淡白/外界風/化学的/辣/辣/香料/香料/香料/怪诞/怪诞/怪诞/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "幸運/得意料理＊肉料理＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黄/金/秩序/かわいい/シンプル/大陸風/派手/" + "光/宝石/巫術/法具/" * 3 + "虎の/正義の/牙/爪/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/別緻/ロリータ/マニアック/" + "闇/生体品/" * 3
ENDSELECT


