@Fキャラデータ111(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "皮絲"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_小丑帽]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_裤袜]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_火把]]}"

CASE "固有内衣形容詞"
	RETURNF "不会从裤袜上显出痕迹的"
CASE "固有下半身内衣名"
	RETURNF "细绳丁字裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "迷你吊带背心"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[皮絲]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "乳酪/香料/油炸食品/蛋糕/ジャンキー/濃厚/新鲜/豪快/软糯的/地獄風/" + "洋食/甜/辣/" * 2  + "怪诞/漢堡/" * 3
CASE "料理：讨厌的味道"
	RETURNF "和食/中華/葉物/简易/上品/酸/酸/健康/健康/淡白/淡白/野菜/野菜/野菜/"
CASE "料理：助手効果"
	RETURNF "地獄風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/青/混沌/可怕的/奇妙/ポップ/派手/ロリータ/" + "火/骨/妖術/照明/" * 3 + "疯狂な/地獄の/狂気の/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/シンプル/和風/別緻/繊細/知的/水/" + "書物/" * 3
ENDSELECT


