@Fキャラデータ45(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "理香子"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：飾品"
	RETURNF @"{[[飾品_眼鏡]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_白大褂]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_上衣]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"

CASE "固有内衣形容詞"
	RETURNF "朴实的"
CASE "固有下半身内衣名"
	RETURNF "白内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "白文胸"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[理香子]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/乳酪/麺類/简易/ジャンキー/サクサク/化学的/甜/甜/辣/辣/機能的/機能的/機能的/"
CASE "料理：讨厌的味道"
	RETURNF "野趣/酸/酸/青蛙/青蛙/青蛙/蘑菇/蘑菇/蘑菇/謎料理/謎料理/謎料理/魔力/魔力/魔力/魔力/魔力/"
CASE "料理：助手効果"
	RETURNF "化学的/"
;贈り物関連
CASE "感性：好き"
	RETURNF "白/技術/秩序/美的/シンプル/未来/知的/" + "眼鏡/" * 3 + "量子の/纳米技术の/機械/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/奇妙/懷舊/不思議/ロリータ/" + "生体品/护臂/" * 3 + "魔法/" * 10
ENDSELECT

