@Fキャラデータ124(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "隠岐奈"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_乌帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_长靴]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_道士服]]}"

CASE "固有内衣形容詞"
	RETURNF "投影了夜空的"
CASE "固有下半身内衣名"
	RETURNF "星辰胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "星辰胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:3
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"
;特殊衣装
CASE "デート衣装", "人里デート衣装"
	RETURNF @"{[[辣妹系休闲套装]]}"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/煮物/健康/豪華/芸術的/上品/滑溜溜/辣/辣/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "質素/咸/咸/" + "青蛙/虫肉/謎料理/" * 3 + "天狗流/" * 5
CASE "料理：助手効果"
	RETURNF "附魔/加護/絢爛/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黄/高級/混沌/美的/芸術的/懷舊/派手/知的/威厳/" + "巫術/美術品/四季の/" * 3 + "七星の/後戸の/隐匿の/" * 5
CASE "感性：嫌い"
	RETURNF "洋風/別緻/ロリータ/" + "安物/" * 3 + "天狗の/沉眠の/" * 10
ENDSELECT


