@Fキャラデータ139(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "典"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（吊带睡裙）套"

CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_旗袍·裤]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_足袋]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_试管]]}"

CASE "固有内衣形容詞"
	RETURNF "蛊惑的"
CASE "固有下半身内衣名"
	RETURNF "纯白胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "管狐胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[典]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/肉料理/肉料理/卵/卵/卵/油炸食品/甜/甜/辣/辣/简易/淡白/豪華/上品/新鲜/黏稠/"
CASE "料理：讨厌的味道"
	RETURNF "酸/酸/濃厚/質素/質素/野趣/野趣/"
CASE "料理：助手効果"
	RETURNF "隠し味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "高級/白/混沌/かわいい/シンプル/別緻/知的/" + "純白の/狐の/药瓶/" * 5
CASE "感性：嫌い"
	RETURNF "黒/秩序/派手/威厳/" + "安物/护符/" * 3 + "狸の/护臂/" * 10

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	RETURNF "2"
CASE "一般依頼発生率"
	RETURNF "3"
CASE "固有依頼発生率"
	RETURNF "5"
CASE "固有依頼最終要素"
	RETURNF "101"
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		CALLF 固有依頼139(ARG, O_DATA, V_NAME)

ENDSELECT


