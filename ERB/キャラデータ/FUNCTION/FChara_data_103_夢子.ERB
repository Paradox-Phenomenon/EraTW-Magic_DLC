@Fキャラデータ103(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "夢子"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（吊带睡裙）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_女仆发箍]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_长筒袜]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_围裙洋装]]}"

CASE "固有内衣形容詞"
	RETURNF "有着谜之重量和冰冷感的"
CASE "固有下半身内衣名"
	RETURNF "梦子胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "梦子胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "面包/牛奶/洋食/葉物/派/健康/淡白/豪華/上品/家庭的/软绵绵/魔力/魔界風/甜/甜/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "濃厚/野趣/咸/咸/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "魔界風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/秩序/美的/シンプル/洋風/繊細/" + "神霊/刃物/" * 3 + "女僕的/魔界の/懐剣/護刀/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/和風/パワフル/ロリータ/" + "生体品/" * 3
ENDSELECT


