@Fキャラデータ133(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "早鬼"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_牛仔帽]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_长靴]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_结丝巾]]}"

CASE "固有内衣形容詞"
	RETURNF "蹄铁印纹的"
CASE "固有下半身内衣名"
	RETURNF "黑色紧身裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "黑翼胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[早鬼]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/香料/中華/鍋物/丰盛/ジャンキー/濃厚/温暖/豪華/野趣/豪快/サクサク/畜生流/" + "辣/胡萝卜/" * 3
CASE "料理：讨厌的味道"
	RETURNF "質素/" + "甜/酸/简易/淡白/" * 2 + "天界風/" * 3
CASE "料理：助手効果"
	RETURNF "畜生流/得意料理＊豪快＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黒/赤/混沌/かっこいい/シンプル/パワフル/壮大/" + "狼の/" * 3 + "马の/天馬の/结丝巾/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/繊細/知的/" + "神霊/書物/機械/" * 3 + "埴轮の/水獭の/鹫の/龟の/龍の/埴轮/" * 10
ENDSELECT


