@Fキャラデータ93(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "若鷺姫"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：和服"
	RETURNF @"{[[和服_和服]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_帯]]}"

CASE "固有内衣形容詞"
	RETURNF "人鱼标配的"
CASE "固有下半身内衣名"
	RETURNF "贝壳比基尼"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "贝壳胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[若鷺姫]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "99"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/葉物/酸/简易/健康/淡白/冷/質素/野趣/家庭的/滑溜溜/美味的水/甜/甜/甜/"
CASE "料理：讨厌的味道"
	RETURNF "丰盛/ジャンキー/辣/辣/" + "怪诞/謎料理/" * 5 + "魚料理/" * 10
CASE "料理：助手効果"
	RETURNF "美味的水/得意料理＊淡白＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/鉱物/かわいい/芸術的/ポップ/別緻/" + "水/宝石/魚/" * 3 + "魚の/人魚の/深海魚の/古代魚の/鱗/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/可怕的/派手/威厳/" + "氷/雷/刃物/弾/护臂/烟袋/" * 3 + "火/" * 5
ENDSELECT


