@Fキャラデータ155(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "血枪"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子+兜帽）套"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_地獄Ｔ恤衬衫]]}"
CASE "便装：裤子"
	RETURNF @"{[[裤子_短裤]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_注射器]]}"

CASE "固有内衣形容詞"
	RETURNF "怨念缠卷的"
CASE "固有下半身内衣名"
	RETURNF "鬼火胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "鬼火胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "汁物/饮用/咸/咸/酸/酸/ジャンキー/濃厚/豪快/新鲜/怪诞/黏稠/霊障/地底風/" + "肉料理/" * 3 + "血の魔力/" * 5
CASE "料理：讨厌的味道"
	RETURNF "甜/甜/淡白/質素/芸術的/"
CASE "料理：助手効果"
	RETURNF "血の魔力/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/妖術/混沌/可怕的/奇妙/マニアック/" + "火/血/鹫の/チュパカブラの/" * 3 + "血の/"* 5
CASE "感性：嫌い"
	RETURNF "青/秩序/時尚/未来/" + "水/" * 3 + "狼の/水獭の/" * 10
ENDSELECT


