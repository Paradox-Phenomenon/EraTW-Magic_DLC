@Fキャラデータ53(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "帝"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：飾品"
	RETURNF @"{[[飾品_首飾]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"

CASE "固有指令"
	RETURNF "买药"
CASE "固有指令実行可能"
	RETURNF "1"

CASE "固有内衣形容詞"
	RETURNF "带来财运的"
CASE "固有下半身内衣名"
	RETURNF "缎带内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "缎带胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/蘑菇/和食/葉物/简易/濃厚/豪華/野趣/家庭的/软糯的/神力/玉兎流/赏月/甜/甜/咸/咸/胡萝卜/胡萝卜/胡萝卜/胡萝卜/胡萝卜/"
CASE "料理：讨厌的味道"
	RETURNF "丰盛/質素/辣/辣/" + "青蛙/獣肉/虫肉/謎料理/" * 3
CASE "料理：助手効果"
	RETURNF "ドッキリ味/幸運/"
;贈り物関連
CASE "感性：好き"
	RETURNF "粉色/高級/かわいい/和風/ポップ/" + "护符/" * 3 + "兔の/四葉の/幸運の/" * 5
CASE "感性：嫌い"
	RETURNF "パワフル/可怕的/" + "安物/水/刃物/护臂/" * 3 + "龟の/" * 10

;農民関連
;金もってそう
CASE "農民：説明"
	RETURNF "胡萝卜農家"
CASE "農民：作物"
	RETURNF "胡萝卜"
CASE "農民：田的种类"
	RETURNF "胡萝卜畑"
CASE "農民：畑の所在地"
	RETURNF "迷途竹林"

CASE "農民：MapID"
	RETURNF "4"
CASE "農民：場所ID"
	RETURNF "433"
CASE "農民：報酬"
	RETURNF "450"
CASE "農民：金利"
	RETURNF "15"
ENDSELECT


