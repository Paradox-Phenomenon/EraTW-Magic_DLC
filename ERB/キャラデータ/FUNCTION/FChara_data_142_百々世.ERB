@Fキャラデータ142(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "百百世"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_Ｔ恤衬衫]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_迷你裙]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_蝴蝶结]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_蝴蝶结]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_铲子]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_镐]]}"

CASE "固有内衣形容詞"
	RETURNF "略显奇怪的"
CASE "固有下半身内衣名"
	RETURNF "蜈蚣胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "蜈蚣胸罩"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/肉料理/肉料理/虫肉/虫肉/虫肉/油炸食品/辣/辣/咸/咸/丰盛/ジャンキー/濃厚/野趣/豪快/怪诞/サクサク/"
CASE "料理：讨厌的味道"
	RETURNF "甜/甜/简易/健康/淡白/質素/質素/質素/"
CASE "料理：助手効果"
	RETURNF "刺激的/"
;贈り物関連
CASE "感性：好き"
	RETURNF "鉱物/黒/混沌/可怕的/パワフル/壮大/" + "土/虫/毒/生体品/龍珠の/" * 3 + "龍の/龍神の/ドラゴンの/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/繊細/ロリータ/"
ENDSELECT


