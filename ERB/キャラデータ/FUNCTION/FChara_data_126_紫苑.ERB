@Fキャラデータ126(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "紫苑"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（浴巾）套"

CASE "便装：飾品"
	RETURNF @"{[[飾品_御札]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_Ｔ恤衬衫]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_连帽衫]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_手链]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_破茶碗]]}"

CASE "固有内衣形容詞"
	RETURNF "算不上内衣的"
CASE "固有下半身内衣名"
	RETURNF "『抵押品』字样的纸条"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "『大减价』字样的纸条"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[紫苑]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "高级食材/肉料理/蘑菇/野菜/和食/麺類/甜/丰盛/ジャンキー/濃厚/豪華/新鲜/家庭的/软绵绵/" + "咸/SO严选/" * 3
CASE "料理：讨厌的味道"
	IF CFLAG:126:口上セレクタ == 1
		RETURNF "謎料理/謎料理/謎料理/"
	ELSE
		RETURNF "简易/健康/淡白/質素/辣/辣/平价食材/平价食材/平价食材/謎料理/謎料理/謎料理/"
	ENDIF
CASE "料理：助手効果"
	RETURNF "貧乏飯/"
;贈り物関連
CASE "感性：好き"
	RETURNF "金/青/高級/混沌/かわいい/奇妙/和風/別緻/" + "护符/食器/人形/" * 3 + "幸運の/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/派手/" + "刃物/弾/遺物/护臂/機械/" * 3 + "主役の/" * 10
ENDSELECT


