@Fキャラデータ44(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "艾伦"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_围裙洋装]]}"

CASE "固有内衣形容詞"
	RETURNF "非常蓬松的"
CASE "固有下半身内衣名"
	RETURNF "丝带灯笼裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "吊带背心"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "卵/蘑菇/洋食/葉物/派/简易/健康/淡白/芸術的/新鲜/家庭的/软绵绵/赏月/甜/甜/甜/"
CASE "料理：讨厌的味道"
	RETURNF "丰盛/濃厚/辣/辣/" + "青蛙/虫肉/怪诞/謎料理/" * 3
CASE "料理：助手効果"
	RETURNF "得意料理＊软绵绵＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黄/かわいい/ポップ/不思議/" + "月/魔法/" * 3 + "蓬蓬松松の/猫の/" * 5
CASE "感性：嫌い"
	RETURNF "パワフル/威厳/" + "妖術/护臂/機械/" * 3
ENDSELECT


