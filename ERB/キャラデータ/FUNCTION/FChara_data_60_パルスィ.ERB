@Fキャラデータ60(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "帕露西"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_上衣]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_臂套]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_围巾]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_帯]]}"

CASE "固有内衣形容詞"
	RETURNF "非常暴露的"
CASE "固有下半身内衣名"
	RETURNF "丁字裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "细绳胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[帕露西]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/和食/煮物/淡白/質素/上品/家庭的/软绵绵/地底風/辣/辣/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "简易/濃厚/甜/甜/酸/酸/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "地底風/嫉妬/"
;贈り物関連
CASE "感性：好き"
	RETURNF "かわいい/時尚/和風/別緻/" + "緑/刃物/人形/" * 3 + "诅咒の/嫉妬の/樱花の/針/" * 5
CASE "感性：嫌い"
	RETURNF "派手/ロリータ/威厳/マニアック/" + "背叛の/" * 10

;農民関連
;はじかみ
;新鲜な緑やら食べた時のヒリヒリ感もなんとなくイメージに合うかな
CASE "農民：説明"
	RETURNF "山椒農家"
CASE "農民：作物"
	RETURNF "花椒"
CASE "農民：田的种类"
	RETURNF "山椒畑"
CASE "農民：畑の所在地"
	RETURNF "地底"

CASE "農民：MapID"
	RETURNF "9"
CASE "農民：場所ID"
	RETURNF "945"
CASE "農民：報酬"
	RETURNF "400"
CASE "農民：金利"
	RETURNF "8"
ENDSELECT


