@Fキャラデータ156(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "日狭美"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍+睡帽）套"
CASE "便装：帽子"
	IF TCVAR:156:弾幕勝負結果 == 1
		RETURNF "0"
	ELSE
		RETURNF @"{[[頭装備_遮脸]]}"
	ENDIF
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_旗袍]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_长靴]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_长手套]]}"

CASE "固有内衣形容詞"
	RETURNF "煽情的"
CASE "固有下半身内衣名"
	RETURNF "山葡萄胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "山葡萄胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[日狭美]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/葉物/淡白/豪華/上品/芸術的/滑溜溜/鬼の魔力/地獄風/甜/甜/酸/酸/" + "竹笋/" * 3 + "山葡萄/" * 5
CASE "料理：讨厌的味道"
	RETURNF "辣/辣/濃厚/機能的/" + "虫肉/" * 3
CASE "料理：助手効果"
	RETURNF "地獄風/得意料理＊野趣＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "紫/美的/芸術的/威厳/" + "土/果実/" * 3 + "葡萄の/黄泉の/" * 5
CASE "感性：嫌い"
	RETURNF "安物/火/黄/繊細/ロリータ/" + "金属/" * 3
ENDSELECT


