@Fキャラデータ65(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "椛"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_兜巾]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_袖]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_木屐]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_无袖上衣]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_大剑]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_盾]]}"

CASE "固有内衣形容詞"
	RETURNF "实用至上的"
CASE "固有下半身内衣名"
	RETURNF "碎布兜裆布"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "裹胸"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[椛]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "3"

CASE "固有指令"
	RETURNF "千里眼"
CASE "固有指令実行可能"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/獣肉/虫肉/和食/油炸食品/丰盛/機能的/野趣/豪快/软糯的/天狗流/甜/甜/咸/咸/" + "秋物/" * 3
CASE "料理：讨厌的味道"
	RETURNF "野菜/酸/酸/地底風/地底風/地底風/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "切れ味/得意料理＊秋物＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "白/秩序/かわいい/シンプル/和風/" + "刃物/" * 3 + "犬の/狼の/紅葉の/天狗の/千里の/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/ロリータ/威厳/マニアック/" + "弾/" + "河童の/鬼の/" * 10

;農民関連
;山っぽい作物を
CASE "農民：説明"
	RETURNF "蕎麥農家"
CASE "農民：作物"
	RETURNF "蕎麥"
CASE "農民：田的种类"
	RETURNF "蕎麥畑"
CASE "農民：畑の所在地"
	RETURNF "妖怪之山·山頂"

CASE "農民：MapID"
	RETURNF "8"
CASE "農民：場所ID"
	RETURNF "801"
CASE "農民：報酬"
	RETURNF "400"
CASE "農民：金利"
	RETURNF "7"
ENDSELECT


