@Fキャラデータ56(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "神子"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_头戴式耳机]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_无袖上衣]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_剑]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_手链]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_笏板]]}"

CASE "固有内衣形容詞"
	RETURNF "定制的"
CASE "固有下半身内衣名"
	RETURNF "真丝蕾丝内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "真丝蕾丝胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[神子]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"
;教育补丁获取口才
CASE "固有指令"
	IF 成人再教育插件开关 == 1
		RETURNF "学习演讲"
	ENDIF
CASE "固有指令実行可能"
	IF 成人再教育插件开关 == 1
		RETURNF "1"
	ENDIF

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/魚料理/煮物/简易/健康/淡白/豪華/上品/新鲜/サクサク/仙術/月都風/天界風/外界風/" + "和食/甜/酸/" * 2
CASE "料理：讨厌的味道"
	RETURNF "洋食/質素/辣/辣/" + "青蛙/虫肉/濃厚/謎料理/冥界風/地獄風/" * 3
CASE "料理：助手効果"
	RETURNF "絢爛/"
;贈り物関連
CASE "感性：好き"
	RETURNF "紫/金/高級/秩序/美的/時尚/和風/派手/知的/威厳/" + "光/日/宝石/巫術/梟の/斗篷/" * 3 + "黄金の/神霊の/仙人の/七星の/威厳の/救世の/宝剣/" * 5
CASE "感性：嫌い"
	RETURNF "黒/混沌/シンプル/別緻/繊細/ロリータ/" + "安物/闇/死生/生体品/" * 3
ENDSELECT


