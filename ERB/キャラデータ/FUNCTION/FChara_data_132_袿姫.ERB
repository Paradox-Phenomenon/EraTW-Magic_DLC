@Fキャラデータ132(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "袿姫"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（连衣裙）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_头巾]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_作業圍裙]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_涼鞋]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_首飾]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_雕刻刀]]}"

CASE "固有内衣形容詞"
	RETURNF "用造型术制作的"
CASE "固有下半身内衣名"
	RETURNF "造物神胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "造物神胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[袿姫]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/面包/汁物/蛋糕/简易/豪華/芸術的/上品/软绵绵/甜/甜/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "野趣/霊障/咸/咸/香料/香料/香料/畜生流/畜生流/畜生流/畜生流/畜生流/"
CASE "料理：助手効果"
	RETURNF "彩り/隠し味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "青/秩序/美的/芸術的/懷舊/威厳/" + "土/付喪神/巫術/美術品/人形/几何学模様の/" * 3 + "鬼形の/埴轮の/造形術の/手办/雕刻/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/シンプル/" + "妖怪/生体品/" * 3 + "狼の/水獭の/鹫の/" * 10
ENDSELECT


