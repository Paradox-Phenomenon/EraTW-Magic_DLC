@Fキャラデータ166(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "贝子"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（吊带睡裙）套"
	
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_发箍]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_巨大贝壳]]}"

CASE "固有内衣形容詞"
	RETURNF "可防御○Ｇ电磁波的"
CASE "固有下半身内衣名"
	RETURNF "铝箔胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "铝箔胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[贝子]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：好きな味"
	RETURNF "魚料理/怪诞/ジャンキー/ドッキリ味/高級巧克力/巧克力/とろとろ/甜/甜/" + "隠し味/謎料理/" * 5
CASE "料理：嫌いな味"
	RETURNF "刺激的/健康/淡白/辣/辣/"
CASE "料理：助手効果"
	RETURNF "謎料理/"
;贈り物関連
CASE "感性：好き"
	RETURNF "混沌/不思議/奇妙/白/金/海の/" + "偽物の/オカルティックな/幻影の/貝殻の/女神の/" * 3 + "陰謀論の/蜃気楼の/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/知的/瞳の/技術/" + "虚無の/夢と現の/" * 3 + "真実の/" * 10
ENDSELECT


