@Fキャラデータ22(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "露娜薩"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_背心]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_小提琴]]}"

CASE "固有内衣形容詞"
	RETURNF "月牙图案的"
CASE "固有下半身内衣名"
	RETURNF "迷你胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "无肩带胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[露娜薩]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"
;教育补丁获取演奏经验
CASE "固有指令"
	IF 成人再教育插件开关 == 1
		RETURNF "学习演奏"
	ENDIF
CASE "固有指令実行可能"
	IF 成人再教育插件开关 == 1
		RETURNF "1"
	ENDIF
;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/果物/洋食/汁物/派/简易/健康/淡白/芸術的/家庭的/新鲜/软糯的/赏月/甜/甜/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "丰盛/濃厚/野趣/辣/辣/青蛙/青蛙/青蛙/香料/香料/香料/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "薄味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黒/幽霊/美的/シンプル/別緻/繊細/" + "音楽/月/楽器/" * 3 + "虹の/幽霊の/憂鬱の/三位一体の/" * 5
CASE "感性：嫌い"
	RETURNF "派手/パワフル/威厳/" + "星/日/刃物/弾/护臂/烟袋/" * 3 + "鼓槌/拨片/指揮棒/" * 5 + "精霊銀の/欢愉の/" * 10
ENDSELECT


