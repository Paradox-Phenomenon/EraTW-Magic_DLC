@Fキャラデータ41(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "鵺"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_长筒袜]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_腕带]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_三叉戟]]}"

CASE "固有内衣形容詞"
	RETURNF "马赛克模糊的"
CASE "固有下半身内衣名"
	RETURNF "正体不明胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "正体不明胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:3
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/香料/麺類/丰盛/ジャンキー/濃厚/新鲜/怪诞/滑溜溜/辣/辣/咸/咸/" + "謎料理/" * 3
CASE "料理：讨厌的味道"
	RETURNF "简易/健康/質素/甜/甜/野菜/野菜/野菜/"
CASE "料理：助手効果"
	RETURNF "未知の味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黒/混沌/可怕的/奇妙/不思議/" + "闇/妖術/生体品/酒/" * 3 + "謎の/正体不明の/夜空の/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/シンプル/知的/" + "光/書物/照明/领带/" * 3 + "真実の/" * 10
ENDSELECT


