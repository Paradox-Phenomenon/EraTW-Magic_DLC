@Fキャラデータ104(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "雪"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"

CASE "固有内衣形容詞"
	RETURNF "魔界流行的"
CASE "固有下半身内衣名"
	RETURNF "灯笼裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "无钢圈文胸"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "卵/香料/和食/油炸食品/简易/濃厚/機能的/新鲜/豪快/滑溜溜/魔界風/辣/辣/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "淡白/野趣/咸/咸/" + "青蛙/虫肉/謎料理/" * 3
CASE "料理：助手効果"
	RETURNF "魔界風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/かっこいい/ポップ/洋風/派手/パワフル/" + "魔法/" * 3 + "魔界の/真紅の/禁断の/" * 5
CASE "感性：嫌い"
	RETURNF "別緻/繊細/懷舊/和風/"
ENDSELECT


