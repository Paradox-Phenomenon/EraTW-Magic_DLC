@Fキャラデータ24(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "橙"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_耳环]]}"

CASE "固有内衣形容詞"
	RETURNF "黑猫图案的"
CASE "固有下半身内衣名"
	RETURNF "手缝胖次"
CASE "固有上半身内衣"
	RETURNF "0"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[橙]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "0"
CASE "固有内衣半透明(後)"
	RETURNF "0"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/肉料理/中華/油炸食品/丰盛/濃厚/野趣/家庭的/謎料理/サクサク/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "健康/酸/酸/野菜/野菜/野菜/香料/香料/香料/"
CASE "料理：助手効果"
	RETURNF "妖力/" * 2
;贈り物関連
CASE "感性：好き"
	RETURNF "朱/かっこいい/大陸風/ロリータ/" + "妖術/生体品/" * 3 + "猫の/橙子の/式神の/" * 5
CASE "感性：嫌い"
	RETURNF "水/氷/書物/烟袋/" * 3 + "犬の/狼の/" * 10
ENDSELECT


