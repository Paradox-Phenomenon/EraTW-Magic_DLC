@Fキャラデータ19(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "莉莉黑"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"

CASE "固有内衣形容詞"
	RETURNF "很暖和的"
CASE "固有下半身内衣名"
	RETURNF "黑春告精胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "黑春告精吊带衫"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/香料/洋食/葉物/濃厚/温暖/質素/野趣/新鲜/软绵绵/冥界風/闪耀/辣/辣/辣/春物/春物/春物/春物/春物/"
CASE "料理：讨厌的味道"
	RETURNF "和食/淡白/冷/甜/甜/咸/咸/牛奶/牛奶/牛奶/夏物/夏物/夏物/"
CASE "料理：助手効果"
	RETURNF "得意料理＊春物＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "植物/かわいい/ロリータ/" + "黒/風/" * 3 + "樱花の/百合の/春の/春風の/" * 5
CASE "感性：嫌い"
	RETURNF "氷/刃物/弾/护臂/烟袋/" * 3 +"白/夏の/枫叶の/西瓜の/紅葉の/" * 5 + "冬の/秋の/秋風の/" * 10
ENDSELECT


