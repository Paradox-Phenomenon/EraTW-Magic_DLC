@Fキャラデータ11(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "魔理沙"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（睡袍）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	IF FLAG:2 > 0
		RETURNF @"{[[襪子_吊带袜]]}"
	ELSE
		RETURNF @"{[[襪子_袜子]]}"
	ENDIF
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_无袖上衣]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_扫帚]]}"

CASE "固有内衣形容詞"
	RETURNF "少女情调的"
CASE "固有下半身内衣名"
	RETURNF "荷叶边灯笼裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "衬裙"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;農民関連
;農家というか蘑菇スポットを教えてくれたのかな
CASE "農民：説明"
	RETURNF "蘑菇農家"
CASE "農民：作物"
	RETURNF "蘑菇"
CASE "農民：田的种类"
	RETURNF "蘑菇農園"
CASE "農民：畑の所在地"
	RETURNF "魔法之森"

CASE "農民：MapID"
	RETURNF "5"
CASE "農民：場所ID"
	RETURNF "507"
CASE "農民：報酬"
	RETURNF "450"
CASE "農民：金利"
	RETURNF "6"

CASE "固有指令"
	IF CFLAG:11:口上セレクタ == 1
		RETURNF "少女行动DA☆ZE"
	ELSE
		RETURNF "帮助别人"
	ENDIF
CASE "固有指令実行可能"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "魚料理/蘑菇/麺類/丰盛/野趣/新鲜/豪快/サクサク/魔界風/外界風/和食/和食/甜/甜/辣/辣/冬物/冬物/冬物/"
CASE "料理：讨厌的味道"
	RETURNF "面包/洋食/酸/酸/" + "怪诞/謎料理/" * 3
CASE "料理：助手効果"
	RETURNF "附魔/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黒/秩序/かわいい/奇妙/パワフル/壮大/" + "魔法/星/書物/鸦の/魔女の/冬の/" * 3 + "蘑菇の/彗星の/星屑の/恋色の/魔法書/箒/" * 5
CASE "感性：嫌い"
	RETURNF "繊細/" + "妖怪/" * 5
ENDSELECT



