@Fキャラデータ59(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "小悪魔"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_长筒袜]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"
CASE "便装：外搭"
	RETURNF @"{[[外搭_背心]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_领带]]}"

CASE "固有内衣形容詞"
	RETURNF "挑逗的"
CASE "固有下半身内衣名"
	RETURNF "蕾丝T字裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "半透蕾丝胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[小悪魔]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "0"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/蘑菇/洋食/麺類/ジャンキー/豪華/新鲜/怪诞/滑溜溜/魔界風/甜/甜/辣/辣/"
CASE "料理：讨厌的味道"
	RETURNF "魚料理/和食/丰盛/酸/酸/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "魔界風/刺激的/"
;贈り物関連
;長短髪口上用に好みを変化

CASE "感性：好き"
	IF CFLAG:[[小悪魔]]:口上セレクタ == 1
		RETURNF "黒/混沌/可怕的/洋風/知的/" + "魔法/書物/" * 3 + "悪魔の/领带/" * 5 + "天使の/" * 10
	ELSE
		RETURNF "黒/混沌/可怕的/洋風/知的/" + "魔法/書物/" * 3 + "悪魔の/领带/" * 5
	ENDIF
CASE "感性：嫌い"
	IF CFLAG:[[小悪魔]]:口上セレクタ == 1
		RETURNF "秩序/和風/" + "光/神霊/护符/护臂/" * 3
	ELSE
		RETURNF "秩序/和風/" + "光/神霊/护符/护臂/" * 3 + "天使の/" * 10
	ENDIF

;農民関連
;まさかの室内栽培
;主人をからかうのが目的だが気づかれていない样子
;ぜんぜん儲からない
CASE "農民：説明"
	RETURNF "豆芽農家"
CASE "農民：作物"
	RETURNF "豆芽"
CASE "農民：田的种类"
	RETURNF "豆芽部屋"
CASE "農民：畑の所在地"
	RETURNF "紅魔館"

CASE "農民：MapID"
	RETURNF "3"
CASE "農民：場所ID"
	RETURNF "310"
CASE "農民：報酬"
	RETURNF "150"
CASE "農民：金利"
	RETURNF "10"
ENDSELECT


