@Fキャラデータ35(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "衣玖"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"

CASE "便装：外搭"
	RETURNF @"{[[外搭_披肩]]}"
CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_褶边女式衬衫]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_羽衣]]}"

CASE "固有内衣形容詞"
	RETURNF "羽衣般轻盈的"
CASE "固有下半身内衣名"
	RETURNF "薄纱胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "薄纱胸罩"
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[衣玖]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/鍋物/甜/简易/健康/淡白/芸術的/新鲜/家庭的/滑溜溜/神力/天界風/酸/酸/酸/"
CASE "料理：讨厌的味道"
	RETURNF "咸/咸/ジャンキー/ジャンキー/ジャンキー/外界風/外界風/外界風/" + "魚料理/謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "天界風/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/秩序/美的/シンプル/別緻/魚/" + "雷/" * 3 + "龍の/龍神の/天女の/闪电の/羽衣/鱗/" * 5
CASE "感性：嫌い"
	RETURNF "混沌/ロリータ/" + "土/火/刃物/弾/护臂/" * 3

ENDSELECT


