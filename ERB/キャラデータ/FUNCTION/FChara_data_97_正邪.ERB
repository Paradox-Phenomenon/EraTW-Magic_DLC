@Fキャラデータ97(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "正邪"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：腕部装束"
	RETURNF @"{[[腕部装束_手链]]}"

CASE "固有内衣形容詞"
	RETURNF "同甘共苦的"
CASE "固有下半身内衣名"
	RETURNF "磨损胖次"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "旧裹胸"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[正邪]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "3"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/麺類/濃厚/豪華/豪快/謎料理/黏稠/霊障/小人族秘伝の味/玉兎流/辣/辣/咸/咸/ジャンキー/ジャンキー/ジャンキー/"
CASE "料理：讨厌的味道"
	RETURNF "野菜/和食/淡白/質素/家庭的/上品/酸/酸/" + "牛奶/健康/女僕流/天狗流/" * 3
CASE "料理：助手効果"
	RETURNF "逆転/"
;贈り物関連
CASE "感性：好き"
	RETURNF "赤/混沌/可怕的/奇妙/派手/壮大/" + "妖術/道具/" * 3 + "鬼の/鏡之国の/機力の/背叛の/逆転の/" * 5
CASE "感性：嫌い"
	RETURNF "シンプル/懷舊/別緻/" + "秩序/光/神霊/护符/書物/项圈/领带/" * 3 + "女王の/王者の/平和の/正義の/魔法少女の/英雄の/主役の/" * 5
ENDSELECT


