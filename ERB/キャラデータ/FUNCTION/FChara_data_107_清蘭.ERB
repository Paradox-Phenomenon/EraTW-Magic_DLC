@Fキャラデータ107(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "清兰"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：連衣裙"
	RETURNF @"{[[連衣裙_連衣裙]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_杵]]}"

CASE "固有内衣形容詞"
	RETURNF "下摆透光的"
CASE "固有下半身内衣名"
	RETURNF "半透灯笼裤"
CASE "固有上半身内衣"
	RETURNF "0"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "野菜/中華/汁物/简易/淡白/豪華/野趣/新鲜/软糯的/玉兎流/月都風/赏月/甜/甜/甜/胡萝卜/胡萝卜/胡萝卜/胡萝卜/胡萝卜/"
CASE "料理：讨厌的味道"
	RETURNF "質素/" + "青蛙/獣肉/虫肉/香料/" * 3 + "辣/辣/辣/辣/" + "謎料理/" * 5
CASE "料理：助手効果"
	RETURNF "玉兎流/薄味/"
;贈り物関連
CASE "感性：好き"
	RETURNF "秩序/かわいい/シンプル/繊細/" + "青/弾/" * 3 + "浅葱色の/兔の/" * 5
CASE "感性：嫌い"
	RETURNF "可怕的/パワフル/知的/" + "刃物/生体品/护臂/" * 3 + "橘色の/" * 10
ENDSELECT


