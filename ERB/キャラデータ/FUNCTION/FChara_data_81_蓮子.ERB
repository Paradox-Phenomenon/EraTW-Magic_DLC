@Fキャラデータ81(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "蓮子"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（裤子）套"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_帽子]]}"
CASE "便装：外搭"
	SIF DAY:2 == 1
		RETURNF @"{[[外搭_披肩]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_长裙]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_女式衬衫]]}"

CASE "固有内衣形容詞"
	RETURNF "收身的"
CASE "固有下半身内衣名"
	RETURNF "斑点内裤"
CASE "固有上半身内衣"
	RETURNF "1"
CASE "固有上半身内衣名"
	RETURNF "隐形胸衣"
CASE "固有内衣着用条件"
	RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"
CASE "固有内衣布料厚度"
	RETURNF "2"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "米/香料/中華/麺類/饮用/简易/ジャンキー/機能的/上品/家庭的/サクサク/月都風/甜/甜/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "酸/酸/虫肉/虫肉/虫肉/怪诞/怪诞/怪诞/謎料理/謎料理/謎料理/謎料理/謎料理/"
CASE "料理：助手効果"
	RETURNF "化学的/得意料理＊ジャンキー＊/"
;贈り物関連
CASE "感性：好き"
	RETURNF "黒/高級/かっこいい/シンプル/懷舊/別緻/知的/不思議/マニアック/" + "星/月/文具/遺物/エニグマティクな/" * 3 + "量子の/未知の/魅知の/幻想の/手賬/领带/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/派手/ロリータ/" + "护臂/" * 3 + "外界の/" * 10
ENDSELECT


