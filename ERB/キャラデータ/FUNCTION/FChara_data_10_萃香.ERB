@Fキャラデータ10(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	RETURNF "萃香"
;こっから衣装設定
CASE "今天的睡衣"
	RETURNF "睡衣（襦袢）套"
;去地底玩
CASE "特殊衣装着用"
	SIF GROUPMATCH(GET_MAPID(CFLAG:[[萃香]]:遭遇位置), 9)
		RETURNF @"{[[萃香茨歌仙变装]]}"

CASE "便装：帽子"
	RETURNF @"{[[頭装備_蝴蝶结]]}"
CASE "便装：靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "便装：襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "便装：裙子"
	RETURNF @"{[[裙子_裙子]]}"
CASE "便装：上身衣服２"
	RETURNF @"{[[上身衣服_はだけ可能_无袖女式衬衫]]}"
CASE "便装：其他１"
	RETURNF @"{[[其他衣装_拘束具]]}"
CASE "便装：其他２"
	RETURNF @"{[[其他衣装_角饰带]]}"
CASE "便装：飾品"
	RETURNF @"{[[飾品_瓢箪]]}"

;どう見ても原作がノーブラ
CASE "固有内衣形容詞"
	RETURNF "非常结实的"
CASE "固有下半身内衣名"
	RETURNF "鬼之胖次"
CASE "固有上半身内衣"
	RETURNF "0"
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[萃香]])))
		RETURNF "1"
CASE "固有内衣半透明(前)"
	RETURNF "1"
CASE "固有内衣半透明(後)"
	RETURNF "1"

;特殊衣装設定
CASE "人里デート衣装", "人間衣装"
	RETURNF @"{[[萃香茨歌仙变装]]}"

;農民関連
;この娘の場合はそこら辺の林をえいやっと畑にしてくれたんだろな
CASE "農民：説明"
	RETURNF "西瓜農家"
CASE "農民：作物"
	RETURNF "西瓜"
CASE "農民：田的种类"
	RETURNF "西瓜畑"
CASE "農民：畑の所在地"
	RETURNF "博麗神社"

CASE "農民：MapID"
	RETURNF "0"
CASE "農民：場所ID"
	RETURNF "22"
CASE "農民：報酬"
	RETURNF "300"
CASE "農民：金利"
	RETURNF "4"

;料理関連
CASE "料理：喜欢的味道"
	RETURNF "肉料理/香料/和食/煮物/下酒菜/辣/丰盛/濃厚/豪華/野趣/豪快/软糯的/天狗流/地獄風/咸/咸/咸/"
CASE "料理：讨厌的味道"
	RETURNF "甜/淡白/" + "謎料理/小人族秘伝の味/" * 5
CASE "料理：助手効果"
	RETURNF "浓郁/刺激的/"
;贈り物関連
CASE "感性：好き"
	RETURNF "金/混沌/かっこいい/派手/パワフル/" + "鎖の/食器/酒/" * 3 + "西瓜の/鬼の/鬼力の/" * 5
CASE "感性：嫌い"
	RETURNF "秩序/繊細/" + "書物/機械/" * 3 + "河童の/天狗の/" * 5

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	RETURNF "2"
CASE "一般依頼発生率"
	RETURNF "3"
CASE "固有依頼発生率"
	RETURNF "5"
CASE "固有依頼最終要素"
	RETURNF "101"
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		CALLF 固有依頼10(ARG, O_DATA, V_NAME)
ENDSELECT

