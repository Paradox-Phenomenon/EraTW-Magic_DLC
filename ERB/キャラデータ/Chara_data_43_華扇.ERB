;IMAGE_I43_特殊エフェクトチェック(CHAR, エフェクト)--------------------------------------------
;角色特有のエフェクト判定  特殊エフェクトを直接指定したい場合に参照
;引数 "エフェクト" に固有のエフェクトが含まれるかを判定する
;例の街道、STRFINDを使用してください
;-------------------------------------------------------------------------------------------
@IMAGE_I43_特殊エフェクトチェック(CHARA, エフェクト)
#DIM CHARA
#DIMS エフェクト

IF CFLAG:43:差し替え適用 == 1
	;替换用画像
	SIF STRFIND(エフェクト, "运动服湿") != -1
		RETURN 1
ELSE
	;通常画像
	SIF STRFIND(エフェクト, "母乳") != -1
		RETURN 1
ENDIF

RETURN 0

;IMAGE_I43_特殊エフェクト(CHARA)--------------------------------------------------------------------
;角色特有のエフェクト表示条件
;使用時注意点:
;	RESULTS配列に特殊エフェクトを格納
;	RETURNで追加するエフェクト数を返却すること
;-------------------------------------------------------------------------------------------
@IMAGE_I43_特殊エフェクト(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIM DYNAMIC エフェクト数 = 0
VARSET RESULTS

IF CFLAG:43:差し替え適用 == 3
	;替换用画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立絵
	ENDIF
ELSEIF CFLAG:43:差し替え適用 == 1
	;替换用画像
	IF SRPITE_运动服湿_43()
		RESULTS:エフェクト数 = 运动服湿
		エフェクト数 += 1
	ENDIF
ELSE
	;通常画像
	IF FLAG:立絵種類
		;顔絵
		IF TALENT:CHARA:母乳体質 && NOWEX:CHARA:噴乳 && CHECK_NUDE(CHARA)
			IF FLAG:巨乳差分表示 && TALENT:CHARA:胸圍>=2
				RESULTS:エフェクト数 = 爆乳母乳
			ELSE
				RESULTS:エフェクト数 = 母乳
			ENDIF
			エフェクト数 += 1
		ENDIF
	ELSE
		;立絵
	ENDIF
ENDIF

RETURN エフェクト数

