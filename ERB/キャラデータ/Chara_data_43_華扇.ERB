@CHARAMOVE_DATA_43(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 43
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;あまり入らない部屋
			CASE P725仙人的宅邸・大鷲的房間, P728仙人的宅邸・空的部屋
				RETURN -5
			;各私室
			CASE P704河童の宣傳站, P706厄神的家, P716秋姉妹的家・土間 TO P719秋姉妹的家・座敷
				RETURN -100
			CASE P733正邪的隠匿処, P744合欢宅邸, P737招财猫的家, P740山童の宣傳站, P742美天居所
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 桜花道的鳥居, 神社境内, 神社走廊
				RETURN 1
			CASE 広場, 商家町, 呑屋小道
				RETURN 1
			CASE 山麓樹海, 玄武之澤, 大蛤蟆之池, 仙人的宅邸, 森の深奥
				RETURN 1
			CASE 九天瀑布, 絶景之丘, 山之湖, 守矢神社境内
				RETURN 1
			;addition custom code, Kourindou
			CASE 香霖堂
				RETURN 1
		ENDSELECT
	;引力設定
	CASE 8
		;平日は3分の2で出步行の
		IF YOUBI_MATCH(DAY, "月火水木金") && INRANGE(TIME, 600, 960)
			SELECTCASE CFLAG:LOCAL:今日の運勢 % 3
			CASE 1
				TCVAR:LOCAL:引力点 = P703玄武之澤
			CASE 2
				TCVAR:LOCAL:引力点 = P711休憩所
			CASEELSE
				TCVAR:LOCAL:引力点 = 0
			ENDSELECT
		ENDIF
ENDSELECT

