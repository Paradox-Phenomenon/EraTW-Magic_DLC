;IMAGE_I43_特殊表情(CHARA)--------------------------------------------------------------------
;角色特有の表情表示条件
;時間停止中でも維持する表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"通常","笑顔","憤怒","発情","睡眠"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I43_特殊表情(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA

IF CFLAG:43:差し替え適用 == 3
	;替换用画像
	IF CHECK_NUDE(CHARA)
		IF RESULTS:0 == "通常"
			RESULTS:0 '= "裸通常"
		ENDIF
		IF RESULTS:1 == "通常"
			RESULTS:1 '= "裸通常"
		ENDIF
	ENDIF
ELSEIF CFLAG:43:差し替え適用
	;替换用画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立絵
	ENDIF
ELSE
	;通常画像
	IF TALENT:CHARA:心情 == 1 || BASE:CHARA:情緒 > MAXBASE:CHARA:情緒 / 2 || TALENT:CHARA:恋慕
		IF RESULTS:0 == "笑顔"
			RESULTS:0 '= "美味"
		ENDIF
		IF RESULTS:1 == "笑顔"
			RESULTS:1 '= "美味"
		ENDIF
	ENDIF
ENDIF

;IMAGE_I43_特殊表情COM(CHARA, 指令)-------------------------------------------------------
;直前の指令で変化する角色特有の表情表示条件
;時間停止中は変化しない表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"自慰","愛撫","性交"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I43_特殊表情COM(CHARA, 指令)
#DIM CHARA
#DIM 指令

SELECTCASE CFLAG:43:差し替え適用
	;替换用画像
	CASE 2
	CASE 1
		IF CHECK_NUDE(CHARA)
		ELSE
			IF IS_BUNNY(CHARA)
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[浴衣穿搭]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 34 || CURRENT_CLOTHES_SET(CHARA) == 31
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[危险野兽礼装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 27 || TEQUIP:CHARA:SWIMMING
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[日式学校运动服]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[不知火舞忍装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[寄叶二号B型套装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[花魁盛装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[白无垢]]
			ELSEIF CHECK_CLO("bra_visible", CHARA)
			ELSE
				SELECTCASE 指令
					CASE 305
						RESULTS = 膝枕覆盖
					CASE 6,12,313
						RESULTS = 揉胸覆盖
				ENDSELECT
			ENDIF
		ENDIF
	CASEELSE
		;通常画像
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
ENDSELECT

