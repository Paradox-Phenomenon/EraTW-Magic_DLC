;IMAGE_I74_特殊服装(CHARA)-------------------------------------------------------------------
;キャラクター特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I74_特殊服装(CHARA)
#DIM CHARA
VARSET RESULTS
SELECTCASE CFLAG:74:差し替え適用
	;替换用画像
	CASE 1
		IF CHECK_NUDE(CHARA)
			;裸
		ELSE
			;服
			IF CFLAG:CHARA:睡眠 || CFLAG:CHARA:陪睡中 || 睡眠時間(CHARA)
				RESULTS = _下着
			ELSEIF IS_BUNNY(CHARA)
				RESULTS = _兔女郎
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[白衣天使套]]
				RESULTS = _护士服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[晚宴礼服套装]]
				RESULTS = _晚礼服
			ELSEIF CHECK_CLO("bra_visible", CHARA)
				RESULTS = _下着
			ENDIF
		ENDIF
		
	CASEELSE
		;通常画像
		IF CHECK_NUDE(CHARA)
			;裸
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立絵
			ENDIF
		ELSE
			;服
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立絵
			ENDIF
		ENDIF
		
ENDSELECT

;IMAGE_I74_特殊表情(CHARA)--------------------------------------------------------------------
;角色特有の表情表示条件
;時間停止中でも維持する表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"通常","笑顔","憤怒","発情","睡眠"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I74_特殊表情(CHARA)
#DIM CHARA

IF CFLAG:74:差し替え適用 == 1
	IF TALENT:CHARA:心情 == 1 || BASE:CHARA:情緒 > MAXBASE:CHARA:情緒*10/6 || TALENT:CHARA:恋慕
		IF RESULTS:0 == "通常"
			RESULTS:0 '= "微笑"
		ENDIF
		IF RESULTS:1 == "通常"
			RESULTS:1 '= "微笑"
		ENDIF
	ENDIF
ELSE
	;通常画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立絵
	ENDIF
ENDIF

;-------------------------------------------------------------------------------------------
@IMAGE_I74_特殊表情COM(CHARA, 指令)
#DIM CHARA
#DIM 指令
SELECTCASE CFLAG:74:差し替え適用

CASE 1
	;替换用画像
	IF CHECK_NUDE(CHARA)
	ELSE
		IF IS_BUNNY(CHARA)
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[白衣天使套]]
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[晚宴礼服套装]]
		ELSEIF CHECK_CLO("bra_visible", CHARA)
		ELSE
			SELECTCASE 指令
				CASE 305
					RESULTS = 膝枕覆盖
				CASE 6,12,313
					RESULTS = 揉胸覆盖
			ENDSELECT
		ENDIF
	ENDIF
CASEELSE
	;通常画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立絵
	ENDIF
ENDSELECT