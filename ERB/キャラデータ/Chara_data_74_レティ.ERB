@CHARAMOVE_DATA_74(ARG, ARG:2)
LOCAL = 74
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;よく居る
			CASE P343湖畔, P345琪露諾的冰屋, P347霧之湖
				RETURN 5
			;紅魔館内部、廃洋館には行かない
			CASE P303守衛小屋 TO P342莉莉卡私室
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 広場, 商家町, 呑屋小道
				;冬の間だけ
				SIF DAY:2 == 4
					RETURN 1
			CASE 霧之湖, 冰造的小雪屋, 正門
				RETURN 1
			CASE 森林的入口, 古木的大樹, 再思之道, 無縁塚
				;冬の間だけ
				SIF DAY:2 == 4
					RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ74
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ74(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	CALLF MAKE_STR(V_NAME, "蕾蒂")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（裤子）套")

CASE "便装：帽子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("帽子", "头巾帽"))
CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("靴", "鞋子"))
CASE "便装：襪子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("襪子", "袜子"))
CASE "便装：連衣裙"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("連衣裙", "連衣裙"))
CASE "便装：外搭"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("外搭", "背心"))
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("其他１", "围巾"))
CASE "便装：其他２"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("其他２", "胸针"))

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "冰霜般的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "雪女胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "雪女胸罩")
CASE "固有内衣着用条件"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "魚料理/牛奶/鍋物/冰淇淋/丰盛/濃厚/豪華/芸術的/家庭的/软糯的/甜/甜/咸/咸/" + "冷/" * 3 + "冬物/" * 5)
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "辣/辣/" + "香料/春物/謎料理/" * 3)
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "氷結/得意料理＊冬物＊/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "美的/芸術的/別緻/" + "白/銀/氷/" * 3 + "水晶の/雪だるまの/冬の/白雪の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "日/护臂/" * 3 + "春の/秋の/樱花の/向日葵の/西瓜の/春風の/秋風の/" * 5 + "火/夏の/" * 10)
ENDSELECT

;-------------------------------------------------
;固有料理設定
;DISH_NAME          料理名
;RESULTS            料理の種類（軽食/主食/甜点）
;CALL 材料設定("")  材料の指定。"汎用"を入れると自動で汎用食材になる
