@CHARAMOVE_DATA_134(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 134
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;広場, 鯢呑亭, 酒屋, 食料品店, 八百屋によく行く
			CASE P202中央広場, P238鯢呑亭, P211酒屋, P216食料品店, P227八百屋
				RETURN 5
			;自室はあまり居ない
			CASE P239美宵的房間
				RETURN -10
			;私室には行かない
			CASE P224慧音宅, P226小鈴私室, P229阿求私室
				RETURN -100
			CASE P208雷鼓的房間, P209八橋的房間, P210弁弁的房間
				RETURN -100
			CASE P231蛮奇的房間, P232蓮子的房間, P233梅莉的房間, P234雪的房間, P235​​舞​的房間
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 桜花道的鳥居, 神社境内, 神社走廊
				RETURN 1
			CASE 広場, 商家町, 呑屋小道, 長屋街
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ134
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ134(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	CALLF MAKE_STR(V_NAME, "美宵")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（裤子+兜帽）套")

CASE "便装：帽子"
	CALLF MAKE_INT(V_NAME, [[頭装備_帽子]])
CASE "便装：上身衣服２"
	CALLF MAKE_INT(V_NAME, [[上身衣服_はだけ可能_白衬衫]])
CASE "便装：裙子"
	CALLF MAKE_INT(V_NAME, [[裙子_长裙]])
CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, [[靴_胶皮底布鞋子]])

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "可疑的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "鲸鱼胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "鲸鹏胸罩")
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[美宵]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 3)
	
;教育补丁获取技能
CASE "固有指令"
	IF 成人再教育插件开关 == 1
		CALLF MAKE_STR(V_NAME, "学习烹饪")
	ENDIF
CASE "固有指令実行可能"
	IF 成人再教育插件开关 == 1
		CALLF MAKE_INT(V_NAME, 1)
	ENDIF
;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "野菜/魚料理/和食/煮物/下酒菜/丰盛/健康/質素/芸術的/家庭的/软糯的/甜/甜/咸/咸/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "平价食材/ジャンキー/酸/酸/乳酪/乳酪/乳酪/謎料理/謎料理/謎料理/謎料理/謎料理/")
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "プロの味/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "青/かわいい/ポップ/壮大/" + "水/酒/食器/海の/記憶の/" * 3 + "鲸の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "洋風/ロリータ/" + "雷/" * 3 + "忘却の/" * 10)
ENDSELECT

