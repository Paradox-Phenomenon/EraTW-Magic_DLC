;IMAGE_I134_特殊服装(CHARA)-------------------------------------------------------------------
;キャラクター特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I134_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS

IF CFLAG:134:差し替え適用 == 2
	IF CHECK_NUDE(CHARA)
		IF GROUPMATCH(1, TEQUIP:CHARA:新妻PLAY)
			RESULTS = _裸エプロン
		ENDIF
	ELSE
		IF CFLAG:CHARA:睡眠 || CFLAG:CHARA:陪睡中 || 睡眠時間(CHARA)
			RESULTS = _下着
		ELSEIF IS_BUNNY(CHARA)
			RESULTS = _バニーギャル
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
			RESULTS = _セーラー服
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[修女服]]
			RESULTS = _シスター
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[浴衣穿搭]]
			RESULTS = _浴衣
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[盛装和服套装]]
			RESULTS = _祭り服
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || CURRENT_CLOTHES_SET(CHARA) == 53 || TEQUIP:CHARA:SWIMMING
			RESULTS = _水着
		ELSEIF CHECK_CLO("bra_visible", CHARA)
			RESULTS = _下着
		ELSEIF GROUPMATCH(DAY:2,2,3)
			RESULTS = _ウェイトレス
		ENDIF
	ENDIF
ELSEIF CFLAG:134:差し替え適用 == 1
	;差し替え画像
	SIF !CHECK_NUDE(134) && WORKING(134) && !TCVAR:CHARA:発情 ;working
		RESULTS = _作業
ELSE
	;通常画像
	IF FLAG:立絵種類
	ELSE
		;立ち絵
		SIF !CHECK_NUDE(134) && WORKING(134) && !TCVAR:CHARA:発情 ;working
			RESULTS = _作業
	ENDIF
ENDIF

;IMAGE_I134_特殊表情(CHARA)--------------------------------------------------------------------
;キャラクター特有の表情表示条件
;時間停止中でも維持する表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"通常","笑顔","憤怒","発情","睡眠"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I134_特殊表情(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
IF CFLAG:134:差し替え適用 == 2
ELSEIF CFLAG:134:差し替え適用 == 1
	;差し替え画像
	IF !CHECK_NUDE(CHARA)
		IF !CFLAG:CHARA:ブチギレ
			IF GROUPMATCH(SELECTCOM, 414, 415) && STRFIND(COM_STR, "K134_お星") > -1
				RESULTS:0 = お星
				RESULTS:1 = 笑顔
			ENDIF
		ENDIF
	ENDIF
ELSE
	;通常画像
	IF FLAG:立絵種類
		;顔絵
		IF !CHECK_NUDE(CHARA)
			IF !CFLAG:CHARA:ブチギレ
				IF GROUPMATCH(SELECTCOM, 414, 415) && STRFIND(COM_STR, "K134_お星") > -1
					RESULTS:0 = お星
					RESULTS:1 = 笑顔
				ELSEIF TALENT:CHARA:心情 == -1
					RESULTS:0 = 悄々
					RESULTS:1 = 悄々
				ENDIF
			ENDIF
		ENDIF
	ELSE
		;立ち絵
		IF !CHECK_NUDE(CHARA)
			IF !CFLAG:CHARA:ブチギレ
				IF GROUPMATCH(SELECTCOM, 414, 415) && STRFIND(COM_STR, "K134_お星") > -1
					RESULTS:0 = お星
					RESULTS:1 = 笑顔
				ENDIF
			ENDIF
		ENDIF
	ENDIF
ENDIF

;IMAGE_I134_特殊表情COM(CHARA, 指令)-------------------------------------------------------
;直前の指令で変化する角色特有の表情表示条件
;時間停止中は変化しない表情はこちら
;使用時注意点:
;   RESULTS:0に表情を格納
;   RESULTS:1にマウスオーバー時の表情を格納すること
;   "自慰","愛撫","性交"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I134_特殊表情COM(CHARA, 指令)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIM 指令

SELECTCASE CFLAG:134:差し替え適用
	;替换用画像
	CASE 2
		IF CHECK_NUDE(CHARA)
		ELSE
			;服
			IF IS_BUNNY(CHARA)
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[修女服]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[浴衣穿搭]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[盛装和服套装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || CURRENT_CLOTHES_SET(CHARA) == 53 || TEQUIP:CHARA:SWIMMING
			ELSEIF CHECK_CLO("bra_visible", CHARA)
			ELSE
				SELECTCASE 指令
					CASE 305
						RESULTS = 膝枕覆盖
					CASE 6,12,313
						RESULTS = 揉胸覆盖
				ENDSELECT
			ENDIF
		ENDIF
	CASEELSE
		;通常画像
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
ENDSELECT
