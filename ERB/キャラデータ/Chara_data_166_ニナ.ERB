@CHARAMOVE_DATA_166(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 166
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
		;たまに連動
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;私室には入らない
			CASE P704河童の宣傳站, P706厄神的家, P709莉莉們的家, P716秋姉妹的家・土間 TO P730仙人的宅邸・庭
				RETURN -100
			CASE P733正邪的隠匿処, P737招财猫的家, P740山童の宣傳站, P742美天居所
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 桜花道的鳥居, 神社境内, 神社本堂, 神社走廊
				RETURN 1
			CASE 広場, 商家町, 呑屋小道, 長屋街
			    RETURN 1
			CASE 山麓樹海, 玄武之澤, 大蛤蟆之池, 森の深奥, 圣域, 浅间净秽山
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ166
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ166(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	CALLF MAKE_STR(V_NAME, "贝子")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（吊带睡裙）套")
	
CASE "便装：連衣裙"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("連衣裙", "連衣裙"))
CASE "便装：帽子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("帽子", "发箍"))
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("其他１", "巨大贝壳"))

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "类似贝壳的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "荷花边胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "荷花边胸罩")
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[贝子]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 0)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 0)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)

;品味系统 待定
[SKIPSTART]
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "葉物/" * 2 + "淡白/" * 2 + "健康/" * 5 + "中華/" * 5 + "薬効/" * 5)
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "虫肉/" * 5 + "青蛙/" * 5 + "卵/" * 5 + "鳥肉/" * 5 + "獣肉/" * 5 + "魚料理/" * 5)
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "薬効/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "美的/美麗な/天人の/知恵の/" * 2 + "巫女の/風の/花の/令人怀念の/" * 3 + "東方の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "魔神の/" + "被遗忘的/" * 10)
[SKIPEND]
ENDSELECT

