@CHARAMOVE_DATA_140(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 140
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;天界には行かない
			CASE P830玄雲海 TO P842比那名居邸庫房
				RETURN -100
			;私室やお風呂は入らない
			CASE P817神奈子私室, P818諏訪子私室, P820早苗私室
				RETURN -100
			CASE P851久侘歌の小屋, P852駒草の小屋, P853魅須丸の小屋, P824廁所, P825風呂
				RETURN -100
			;頂上によく居る
			CASE P805頂上
				RETURN 5
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 広場, 商家町, 呑屋小道
				RETURN 1
			CASE 山麓樹海, 玄武之澤, 大蛤蟆之池, 間欠泉地下中樞, 森の深奥
				RETURN 1
			CASE 九天瀑布, 絶景之丘, 山之湖, 守矢神社境内, 虹龍洞
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ140
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ140(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	CALLF MAKE_STR(V_NAME, "龍")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（睡袍+睡帽）套")

CASE "便装：帽子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("帽子", "兜巾"))
CASE "便装：外搭"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("外搭", "斗篷"))
CASE "便装：連衣裙"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("連衣裙", "連衣裙"))
CASE "便装：襪子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("襪子", "袜子"))
CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("靴", "木屐"))
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("其他１", "三脚架"))
	
CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "带亮粉的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "星空胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "星空胸罩")
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[龍]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 0)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 0)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)
;特殊衣装
CASE "デート衣装", "人里デート衣装", "おうちデート衣装"
	SELECTCASE DAY:2
		CASE 1,4
			CALLF MAKE_INT(V_NAME, [[盛装和服套装]])
		CASEELSE
			CALLF MAKE_INT(V_NAME, [[浴衣穿搭]])
	ENDSELECT

CASE "固有指令"
	CALLF MAKE_STR(V_NAME, "龙珠的交易")
CASE "固有指令実行可能"
	CALLF MAKE_INT(V_NAME, 1)

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "米/米/米/獣肉/獣肉/獣肉/虫肉/虫肉/虫肉/和食/麺類/甜/甜/咸/咸/淡白/豪華/野趣/新鲜/软糯的/天狗流/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "鳥肉/鳥肉/鳥肉/鳥肉/鳥肉/卵/卵/卵/洋食/酸/酸/")
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "薄味/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "青/美的/懷舊/威厳/" + "星/鳥/" * 3 + "鸦の/天狗の/龍の/星空の/星降の/透镜/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "赤/ロリータ/マニアック/" + "日/" * 3 + "河童の/鬼の/" * 10)
ENDSELECT

;-------------------------------------------------
;固有料理設定
;DISH_NAME          料理名
;RESULTS            料理の種類（軽食/主食/甜点）
;CALL 材料設定("")  材料の指定。"汎用"を入れると自動で汎用食材になる
;DISH_TASTE         味の設定
;DISH_COMMENT       （任意）一行コメント
;DISH_TIME          （任意）調理にかかる時間
;DISH_MAXLIMIT      （任意）料理の持続時間
;-------------------------------------------------
@SPECIAL_MENU_140
#LOCALSIZE 1
#LOCALSSIZE 1
DISH_NAME = 大天狗の麦飯
RESULTS = 軽食
CALL 材料設定("汎用")
DISH_TASTE = 和食/米/咸/简易/淡白/質素/野趣/野趣/天狗流/附魔/
DISH_COMMENT = 可食用的不思议之砂制作的饭块（菌、藻类）。用未知的能量来增幅力量。
RETURN 1

@IMAGE_I140_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS
SELECTCASE CFLAG:140:差し替え適用
	CASE 3
		IF CHECK_NUDE(CHARA)
			;裸
			IF CURRENT_CLOTHES_SET(CHARA) == 66
				RESULTS = _逆兔女郎
			ELSEIF GROUPMATCH(1, TEQUIP:CHARA:縄, TEQUIP:CHARA:拘束)
				RESULTS = _绳子覆盖
			ELSEIF GROUPMATCH(1, TEQUIP:CHARA:新妻PLAY)
				RESULTS = _围裙
			ENDIF
		ELSE
			IF  CURRENT_CLOTHES_SET(CHARA) == [[保健室的女教师套]]
				RESULTS = _保健老师覆盖
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 80
				RESULTS = _西式制服覆盖
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 58
				RESULTS = _网球服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[晚宴礼服套装]]
				RESULTS = _晚礼服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 66
				RESULTS = _逆兔女郎
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 55
				RESULTS = _兔女郎
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 32
				RESULTS = _睡裙
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
				RESULTS = _水手服覆盖
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[圣诞套]]
				RESULTS = _圣诞服覆盖
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[赛车女郎套装]]
				RESULTS = _赛车女郎
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[辣妹系休闲套装]]
				RESULTS = _热裤
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[生足美鈴套]]
				RESULTS = _旗袍
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[女僕装]]
				RESULTS = _女仆装
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[啦啦队制服]]
				RESULTS = _啦啦队
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[婚紗套]]
				RESULTS = _婚纱覆盖
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[白衣天使套]]
				RESULTS = _护士服覆盖
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[盛装和服套装]]
				RESULTS = _和服覆盖
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[童贞杀手毛衣]]
				RESULTS = _高领毛衣
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[日式学校运动服]]
				RESULTS = _布鲁马
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[香霖堂天狗套装]]
				RESULTS =_天狗服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[白无垢]]
				RESULTS = _白无垢覆盖
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[浴衣穿搭]]
				RESULTS = _浴衣覆盖
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[西式职业女装]]
				RESULTS = _ol制服覆盖
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 29
				RESULTS = _泳衣
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 28
				RESULTS = _连体泳衣
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 30
				RESULTS = _死库水
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 27
				RESULTS = _Y字泳衣
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52
				RESULTS = _比基尼
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 53 || TEQUIP:CHARA:SWIMMING
				RESULTS = _迷你
			ELSEIF CHECK_CLO("bra_visible", CHARA)
				RESULTS = _内衣
			ENDIF
		ENDIF
	CASE 2
		IF CHECK_NUDE(CHARA)
			;裸
			IF CURRENT_CLOTHES_SET(CHARA) == 66
				IF !RM_RESOURCECHECK("140OWO_服躯_裸_逆兔女郎")
					LOCAL = 0
					CALL 画像合成(LOCAL, "ダミー", 0, 0, 500, 500)
					CALL 画像合成(LOCAL, "140OWO_服躯_服_逆兔女郎")
					CALL 画像合成(LOCAL, "140OWO_裸逆兔女郎特效")
					SPRITECREATE "140OWO_服躯_裸_逆兔女郎", LOCAL
				ENDIF
				RESULTS = _逆兔女郎
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 55
				RESULTS = _兔女郎
			ENDIF
		ELSE
			IF CURRENT_CLOTHES_SET(CHARA) == 66
				RESULTS = _逆兔女郎
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 55
				RESULTS = _兔女郎
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
				RESULTS = _水手服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[浴衣穿搭]] || CURRENT_CLOTHES_SET(CHARA) == [[盛装和服套装]]
				RESULTS = _人里
			ELSEIF DAY:2 == 4
				RESULTS = _冬装
			ENDIF
		ENDIF
	CASE 1
	CASE 0
		IF CHECK_NUDE(CHARA)
			;裸
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立絵
			ENDIF
		ELSE
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立絵
			ENDIF
		ENDIF
ENDSELECT

;IMAGE_I140_特殊表情(CHARA)--------------------------------------------------------------------
;角色特有の表情表示条件
;時間停止中でも維持する表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"通常","笑顔","憤怒","発情","睡眠"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I140_特殊表情(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA

IF CFLAG:140:差し替え適用 == 2
	IF TALENT:CHARA:心情 == 1 || BASE:CHARA:情緒 > MAXBASE:CHARA:情緒 / 2 || TALENT:CHARA:恋慕
		IF RESULTS:0 == "通常"
			RESULTS:0 '= "微笑"
		ENDIF
		IF RESULTS:1 == "通常"
			RESULTS:1 '= "微笑"
		ENDIF
	ENDIF
ELSE
	;通常画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立絵
	ENDIF
ENDIF
