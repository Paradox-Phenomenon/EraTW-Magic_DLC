;IMAGE_I133_特殊服装(CHARA)-------------------------------------------------------------------
;角色特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;   RESULTSに特殊服装を格納すること
;   書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I133_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS
SELECTCASE CFLAG:133:差し替え適用
	CASE 2
		IF CHECK_NUDE(CHARA)
		ELSE
			IF CFLAG:CHARA:睡眠 || CFLAG:CHARA:陪睡中 || 睡眠時間(CHARA)
				RESULTS = _下着
			ELSEIF IS_BUNNY(CHARA)
				RESULTS = _バニーギャル
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[骑手服]]
				RESULTS = _ボディストッキング
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[日式学校运动服]]
				RESULTS = _体操服
			ELSEIF IS_SCHOOLUNIFORM(CHARA)
				RESULTS = _制服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[死库水泳衣]] || TEQUIP:CHARA:SWIMMING
				RESULTS = _水着
			ELSEIF CHECK_CLO("bra_visible", CHARA)
				RESULTS = _下着
			ENDIF
		ENDIF
	CASE 0,1
	IF CHECK_NUDE(CHARA)
	ELSE
	ENDIF
ENDSELECT

;IMAGE_I133_体形(CHARA)-----------------------------------------------------------------------
;角色特有の体形表示条件
;エフェクトを共有する体形差分はこちら
;服装を指定しても自動で表示されるので注意
;使用時注意点:
;   RESULTSに体形を格納すること
;   書式は %体形%%服装% 適宜"_"等入れること
;   "巨乳"は本編で実装済み %体形%巨乳%服装% で追記可能
;-------------------------------------------------------------------------------------------
@IMAGE_I133_体形(CHARA)
#DIM CHARA
VARSET RESULTS

IF CFLAG:133:差し替え適用
	;替换用画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立絵
	ENDIF
ELSE
	;通常画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立絵
	ENDIF
ENDIF

;IMAGE_I133_特殊表情(CHARA)--------------------------------------------------------------------
;角色特有の表情表示条件
;時間停止中でも維持する表情はこちら
;使用時注意点:
;   RESULTS:0に表情を格納
;   RESULTS:1にマウスオーバー時の表情を格納すること
;   "通常","笑顔","憤怒","発情","睡眠"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I133_特殊表情(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA

IF CFLAG:133:差し替え適用 == 2
	IF TALENT:CHARA:心情 == 1 || BASE:CHARA:情緒 > MAXBASE:CHARA:情緒 / 2 || TALENT:CHARA:恋慕
		IF RESULTS:0 == "通常"
			RESULTS:0 '= "微笑"
		ENDIF
		IF RESULTS:1 == "通常"
			RESULTS:1 '= "微笑"
		ENDIF
	ENDIF
ELSE
	;通常画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立絵
	ENDIF
ENDIF

;IMAGE_I133_特殊表情COM(CHARA, 指令)-------------------------------------------------------
;直前の指令で変化する角色特有の表情表示条件
;時間停止中は変化しない表情はこちら
;使用時注意点:
;   RESULTS:0に表情を格納
;   RESULTS:1にマウスオーバー時の表情を格納すること
;   "自慰","愛撫","性交"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I133_特殊表情COM(CHARA, 指令)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIM 指令

SELECTCASE CFLAG:133:差し替え適用
	;替换用画像
	CASE 2
		IF CHECK_NUDE(CHARA)
		ELSE
			;服
			IF IS_BUNNY(CHARA)
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[骑手服]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[日式学校运动服]]
			ELSEIF IS_SCHOOLUNIFORM(CHARA)
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[死库水泳衣]] || TEQUIP:CHARA:SWIMMING
			ELSEIF CHECK_CLO("bra_visible", CHARA)
			ELSE
				SELECTCASE 指令
					CASE 305
						RESULTS = 膝枕覆盖
					CASE 6,12,313
						RESULTS = 揉胸覆盖
				ENDSELECT
			ENDIF
		ENDIF
	CASEELSE
		;通常画像
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
ENDSELECT
