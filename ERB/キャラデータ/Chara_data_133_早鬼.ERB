@CHARAMOVE_DATA_133(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 133
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;是非曲直庁、冥界、八雲邸には行かない（入り口部分は出る時用）
			CASE P612法廷 TO P639八雲邸居間
				RETURN -100
			;他人的家には入らない
			CASE P608潤美的家, P609瓔花的家, P606日狭美の家, P607残無の家
				RETURN -100
			;霊長園には行かない
			CASE P642霊長園 TO P645磨弓的房間
				RETURN -100
			;他所の風呂には行かない
			CASE P646八千慧宅の風呂, P655尤魔宅の風呂
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 中有之道, 三途之川, 彼岸, 地獄, 畜生界
				RETURN 1
			CASE 山麓樹海, 玄武之澤, 大蛤蟆之池
				RETURN 1
			CASE 九天瀑布, 絶景之丘, 山之湖, 守矢神社境内
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ133
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ133(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	CALLF MAKE_STR(V_NAME, "早鬼")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（裤子）套")

CASE "便装：帽子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("帽子", "牛仔帽"))
CASE "便装：上身衣服２"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("上身衣服２", "女式衬衫"))
CASE "便装：裙子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("裙子", "裙子"))
CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("靴", "长靴"))
CASE "便装：襪子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("襪子", "袜子"))
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("其他１", "结丝巾"))

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "蹄铁印纹的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "黑色紧身裤")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "黑翼胸罩")
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[早鬼]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "肉料理/香料/中華/鍋物/丰盛/垃圾/濃厚/温暖/豪華/野趣/豪快/松脆/畜生流/" + "辣/胡萝卜/" * 3)
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "質素/" + "甜/酸/简易/淡白/" * 2 + "天界風/" * 3)
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "畜生流/得意料理＊豪快＊/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "黒/赤/混沌/帥氣的/樸素/充滿力量/壮大/" + "狼の/" * 3 + "马の/天馬の/结丝巾/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "秩序/繊細/知的/" + "神霊/書物/機械/" * 3 + "埴轮の/水獭の/鹫の/龟の/龍の/埴轮/" * 10)
ENDSELECT

