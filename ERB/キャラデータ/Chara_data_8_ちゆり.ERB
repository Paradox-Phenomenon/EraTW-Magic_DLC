@CHARAMOVE_DATA_8(ARG, ARG:2)
LOCAL = 8
SELECTCASE ARG
	;連動設定（RETURN=依存するキャラ, RESULT:1～3=対等に連動するキャラ）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;よく居る
			CASE P44ちゆり私室
				RETURN 5
			;他所
			CASE P27三妖精の家・広間 TO P35三妖精の家・地下室, P15霊夢私室, P56あうんの棲家
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 桜並木の鳥居, 神社境内, 夢幻遺跡
				RETURN 1
			CASE 広場, 商家町, 呑屋小道, 長屋街
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
		;夢美に依存
		TCVAR:LOCAL:引力点 = TCVAR:[[夢美]]:引力点
ENDSELECT

@EXIST_キャラデータ8
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ8(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "呼び名"
	CALLF MAKE_STR(V_NAME, "ちゆり")
;こっから衣装設定
CASE "今日のパジャマ"
	CALLF MAKE_STR(V_NAME, "パジャマ（ズボン＋フード）セット")

CASE "普段着：帽子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("帽子", "帽子"))
CASE "普段着：靴"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("靴", "靴"))
CASE "普段着：靴下"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("靴下", "靴下"))
CASE "普段着：ズボン"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("ズボン", "ショートズボン"))
CASE "普段着：上半身上着１"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("上半身上着１", "セーラー服"))

CASE "固有下着形容詞"
	CALLF MAKE_STR(V_NAME, "青いラインが入った")
CASE "固有下半身下着名"
	CALLF MAKE_STR(V_NAME, "セーラー風ショーツ")
CASE "固有上半身下着"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身下着名"
	CALLF MAKE_STR(V_NAME, "セーラー風ブラ")
CASE "固有下着着用条件"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有下着透ける(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有下着透ける(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有下着生地厚さ"
	CALLF MAKE_INT(V_NAME, 2)

;料理関連
CASE "料理：好きな味"
	CALLF MAKE_STR(V_NAME, "魚料理/スパイス/洋食/カレー/揚げ物/ガッツリ/濃厚/謎料理/サクサク/魔力/化学的/" + "辛い/機能的/" * 3)
CASE "料理：嫌いな味"
	CALLF MAKE_STR(V_NAME, "野菜/淡白/" + "甘い/" * 2 + "カエル/" * 3)
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "化学的/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "白/技術/かっこいい/未来/パワフル/知的/" + "書物/" * 3 + "錨の/アーティファクト/機械/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "レトロ/繊細/ロリータ/威厳/" + "小手/キセル/" * 3)

ENDSELECT

;-------------------------------------------------
;固有料理設定
;DISH_NAME          料理名
;RESULTS            料理の種類（軽食/主食/デザート）
;CALL 材料設定("")  材料の指定。"汎用"を入れると自動で汎用食材になる
;DISH_TASTE         味の設定
;DISH_COMMENT       （任意）一行コメント
;DISH_TIME          （任意）調理にかかる時間
;DISH_MAXLIMIT      （任意）料理の持続時間
;-------------------------------------------------
@SPECIAL_MENU_8
DISH_NAME = 水兵カレー
RESULTS = 主食
CALL 材料設定("魚")
DISH_TASTE = 洋食/カレー/魚料理/野菜/スパイス/辛い/辛い/あっさり/淡白/温かい/温かい/鮮やか/芸術的/とろとろ/
SIF YOUBI_MATCH(DAY, "金")
	DISH_TASTE += "カレーの日/"
DISH_COMMENT = 毎週金曜の昼食に食べるカレーライス。具材はシーフード。
RETURN 1

;IMAGE_I8_特殊服装(CHARA)-------------------------------------------------------------------
;キャラクター特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I8_特殊服装(CHARA)
#DIM CHARA
VARSET RESULTS

IF CFLAG:[[ちゆり]]:差し替え適用
	;差し替え画像
	IF CHECK_NUDE(CHARA)
		;裸
		IF FLAG:立ち絵種類
			;顔絵
		ELSE
			;立ち絵
		ENDIF
	ELSE
		;服
		IF FLAG:立ち絵種類
			;顔絵
			IF GROUPMATCH(CFLAG:[[ちゆり]]:差し替え適用, 1)
				IF CHECK_CLO("bra_visible", CHARA)
					RESULTS = _下着
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 55
					RESULTS = _バニー
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 62
					RESULTS = _変T
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
					RESULTS = _セーラー
				ELSEIF DAY:2 == 2
					RESULTS = _夏服
				ENDIF
			ENDIF
		ELSE
			;立ち絵
			IF GROUPMATCH(CFLAG:[[ちゆり]]:差し替え適用, 1)
				IF CHECK_CLO("bra_visible", CHARA) && EQUIP:CHARA:下半身下着２ != 0
					RESULTS = _下着
				ELSEIF CHECK_CLO("bra_visible", CHARA) && EQUIP:CHARA:下半身下着２ == 0
					RESULTS = _ノーパン下着
				{
				ELSEIF (!EQUIP:CHARA:上半身上着１ && !EQUIP:CHARA:上半身上着２ && !EQUIP:CHARA:外衣 &&
            			!EQUIP:CHARA:着物 && !EQUIP:CHARA:ワンピース &&
						!EQUIP:CHARA:レオタード && !EQUIP:CHARA:ボディースーツ) &&
						EQUIP:CHARA:下半身下着２ != 0
				}
					RESULTS = _ノーブラ下着
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 55
					RESULTS = _バニー
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 62
					RESULTS = _変T
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
					RESULTS = _セーラー
				ELSEIF DAY:2 == 2
					RESULTS = _夏服
				ENDIF
			ENDIF
		ENDIF
	ENDIF
ELSE
	;通常画像
	IF CHECK_NUDE(CHARA)
		;裸
		IF FLAG:立ち絵種類
			;顔絵
		ELSE
			;立ち絵
		ENDIF
	ELSE
		;服
		IF FLAG:立ち絵種類
			;顔絵
		ELSE
			;立ち絵
		ENDIF
	ENDIF
ENDIF

