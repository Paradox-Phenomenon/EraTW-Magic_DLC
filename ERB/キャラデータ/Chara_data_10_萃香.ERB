;-------------------------------------------------------------------------------------------
@IMAGE_I10_特殊照れ(CHARA)
#DIM CHARA
VARSET RESULTS

IF CFLAG:[[萃香]]:差し替え適用
	;差し替え画像
	IF FLAG:立ち絵種類
		;顔絵
		IF GROUPMATCH(CFLAG:[[萃香]]:差し替え適用, 1)
			IF CURRENT_CLOTHES_SET(CHARA) == 76 && !CHECK_NUDE(CHARA)
				RESULTS = 茨歌仙
			ENDIF
		ELSE

		ENDIF
	ELSE
		;立ち絵
	ENDIF
ELSE
	;通常画像
ENDIF

