@CHARAMOVE_DATA_10(ARG, ARG:2)
LOCAL = 10
SELECTCASE ARG
	;連動設定（RETURN=依存するキャラ, RESULT:1～3=対等に連動するキャラ）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;よく居る
			CASE P2境内, P10縁側, P11庭
				RETURN 5
			CASE P701樹海道入り口, P703玄武の沢, P711休憩所, P801山頂入り口, P806滝の裏, P830玄雲海
				RETURN 10
			;私室にはあまり入らない
			CASE P15霊夢私室, P52離れ
				RETURN -5
			;他所
			CASE P27三妖精の家・広間 TO P35三妖精の家・地下室, P37夢幻遺跡・一階通路 TO P51夢幻遺跡・倉庫, P56あうんの棲家
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 桜並木の鳥居, 神社境内, 神社縁側
				RETURN 1
			CASE 麓の樹海, 玄武の沢, 大蝦蟇の池
				RETURN 1
			CASE 九天の滝, 絶景の丘, 山の湖, 守矢神社境内, 天界
				RETURN 1
			CASE 幻想風穴, 地獄の深道, 旧地獄街道
				RETURN 1
		ENDSELECT
ENDSELECT

@EXIST_キャラデータ10
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ10(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "呼び名"
	CALLF MAKE_STR(V_NAME, "萃香")
;こっから衣装設定
CASE "今日のパジャマ"
	CALLF MAKE_STR(V_NAME, "パジャマ（襦袢）セット")

CASE "普段着：帽子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("帽子", "リボン"))
CASE "普段着：靴"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("靴", "靴"))
CASE "普段着：靴下"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("靴下", "靴下"))
CASE "普段着：スカート"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("スカート", "スカート"))
CASE "普段着：上半身上着２"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("上半身上着２", "袖無しブラウス"))
CASE "普段着：その他１"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("その他１", "拘束具"))
CASE "普段着：その他２"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("その他２", "角リボン"))
CASE "普段着：アクセサリ"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("アクセサリ", "瓢箪"))

;どう見ても原作がノーブラ
CASE "固有下着形容詞"
	CALLF MAKE_STR(V_NAME, "とっても丈夫な")
CASE "固有下半身下着名"
	CALLF MAKE_STR(V_NAME, "鬼のパンツ")
CASE "固有上半身下着"
	CALLF MAKE_INT(V_NAME, 0)
CASE "固有下着着用条件"
	SIF !RAND:(1 + (2 * 勝負下着判定([[萃香]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有下着透ける(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有下着透ける(後)"
	CALLF MAKE_INT(V_NAME, 1)

;農民関連
;この娘の場合はそこら辺の林をえいやっと畑にしてくれたんだろな
CASE "農民：説明"
	CALLF MAKE_STR(V_NAME, "スイカ農家")
CASE "農民：作物"
	CALLF MAKE_STR(V_NAME, "スイカ")
CASE "農民：畑の種類"
	CALLF MAKE_STR(V_NAME, "スイカ畑")
CASE "農民：畑のマップ"
	CALLF MAKE_STR(V_NAME, "博麗神社")

CASE "農民：マップID"
	CALLF MAKE_INT(V_NAME, 0)
CASE "農民：場所ID"
	CALLF MAKE_INT(V_NAME, 22)
CASE "農民：報酬"
	CALLF MAKE_INT(V_NAME, 300)
CASE "農民：金利"
	CALLF MAKE_INT(V_NAME, 4)

;料理関連
CASE "料理：好きな味"
	CALLF MAKE_STR(V_NAME, "肉料理/スパイス/和食/煮物/おつまみ/辛い/ガッツリ/濃厚/豪華/野趣/豪快/もちもち/天狗流/地獄風/しょっぱい/しょっぱい/しょっぱい/")
CASE "料理：嫌いな味"
	CALLF MAKE_STR(V_NAME, "甘い/淡白/" + "謎料理/小人族秘伝の味/" * 5)
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "濃い味/刺激的/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "金/混沌/かっこいい/派手/パワフル/" + "鎖の/食器/酒/" * 3 + "スイカの/鬼の/鬼力の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "秩序/繊細/" + "書物/機械/" * 3 + "河童の/天狗の/" * 5)

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "依頼なし発生率"
	CALLF MAKE_INT(V_NAME, 2)
CASE "一般依頼発生率"
	CALLF MAKE_INT(V_NAME, 3)
CASE "固有依頼発生率"
	CALLF MAKE_INT(V_NAME, 5)
CASE "固有依頼最終要素"
	CALLF MAKE_INT(V_NAME, 101)
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		CALLF 固有依頼10(ARG, O_DATA, V_NAME)
ENDSELECT

;IMAGE_I10_特殊服装(CHARA)-------------------------------------------------------------------
;キャラクター特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I10_特殊服装(CHARA)
#DIM CHARA
VARSET RESULTS

IF CFLAG:[[萃香]]:差し替え適用
	;差し替え画像
	IF CHECK_NUDE(CHARA)
		;裸
		IF FLAG:立ち絵種類
			;顔絵
		ELSE
			;立ち絵
		ENDIF
	ELSE
		;服
		IF FLAG:立ち絵種類
			;顔絵
			IF GROUPMATCH(CFLAG:[[萃香]]:差し替え適用, 1)
				IF CHECK_CLO("bra_visible", CHARA)
					RESULTS = _下着
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 55
					RESULTS = _バニー
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 62
					RESULTS = _変T
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
					RESULTS = _セーラー
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 76
					RESULTS = _茨歌仙
				ENDIF
			ELSE

			ENDIF
		ELSE
			;立ち絵
			IF GROUPMATCH(CFLAG:[[萃香]]:差し替え適用, 1)
				IF CHECK_CLO("bra_visible", CHARA) && EQUIP:CHARA:下半身下着２ != 0
					RESULTS = _下着
				ELSEIF CHECK_CLO("bra_visible", CHARA) && EQUIP:CHARA:下半身下着２ == 0
					RESULTS = _ノーパン下着
				{
				ELSEIF (!EQUIP:CHARA:上半身上着１ && !EQUIP:CHARA:上半身上着２ && !EQUIP:CHARA:外衣 &&
            			!EQUIP:CHARA:着物 && !EQUIP:CHARA:ワンピース &&
						!EQUIP:CHARA:レオタード && !EQUIP:CHARA:ボディースーツ) &&
						EQUIP:CHARA:下半身下着２ != 0
				}
					IF CFLAG:CHARA:651 == 18
						RESULTS = _固有下着
					ELSE
						RESULTS = _ノーブラ下着
					ENDIF
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 55
					RESULTS = _バニー
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 62
					RESULTS = _変T
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
					RESULTS = _セーラー
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 76
					RESULTS = _茨歌仙
				ENDIF
			ELSE

			ENDIF
		ENDIF
	ENDIF
ELSE
	;通常画像
	IF CHECK_NUDE(CHARA)
		;裸
		IF FLAG:立ち絵種類
			;顔絵
		ELSE
			;立ち絵
		ENDIF
	ELSE
		;服
		IF FLAG:立ち絵種類
			;顔絵
		ELSE
			;立ち絵
		ENDIF
	ENDIF
ENDIF

;IMAGE_I10_特殊照れ(CHARA)--------------------------------------------------------------------
;キャラクター特有の照れエフェクト表示条件
;使用時注意点:
;	RESULTSに特殊照れを格納すること
;	書式は %特殊照れ%照れ
