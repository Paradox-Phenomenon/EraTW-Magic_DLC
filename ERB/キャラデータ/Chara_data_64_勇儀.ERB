;IMAGE_I64_特殊服装(CHARA)-------------------------------------------------------------------
;角色特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I64_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS

SELECTCASE CFLAG:64:差し替え適用
	;替换用画像
	CASE 2
		IF CHECK_NUDE(CHARA)
			;裸
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立絵
			ENDIF
		ELSE
			;服
			IF CFLAG:CHARA:睡眠 || CFLAG:CHARA:陪睡中 || 睡眠時間(CHARA)
				RESULTS = _下着
			ELSEIF IS_BUNNY(CHARA)
				RESULTS = _裙甲
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[神秘宝藏礼装]]
				RESULTS = _神秘宝藏
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[不知火舞忍装]]
				RESULTS = _不知火
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[女僕装]]
				RESULTS = _女仆
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[女牛仔套装]]
				RESULTS = _牛仔
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[啦啦队制服]]
				RESULTS = _啦啦队
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[婚紗套]]
				RESULTS = _婚纱
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[花魁盛装]]
				RESULTS = _花魁
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[勇仪和服套装]]
				RESULTS = _和服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[日式学校运动服]]
				RESULTS = _布鲁马
			ELSEIF EQUIP:CHARA:外搭 == 11
				RESULTS = _连帽衫
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || CURRENT_CLOTHES_SET(CHARA) == 53 || TEQUIP:CHARA:SWIMMING
				RESULTS = _比基尼
			ELSEIF CHECK_CLO("bra_visible", CHARA)
				RESULTS = _下着
			ELSEIF SPIRIT_马尾判定_64()
				RESULTS = _马尾
			ENDIF
		ENDIF
	CASE 1
		IF CHECK_NUDE(CHARA)
			;裸
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立絵
			ENDIF
		ELSE
			IF CURRENT_CLOTHES_SET(CHARA) == 75
				RESULTS = _黄昏
			ENDIF
		ENDIF
	CASE 0
		;通常画像
		IF CHECK_NUDE(CHARA)
			;裸
			SIF BATHROBE_SWITCH && BATHROOM() && !CFLAG:诶嘿嘿
				RESULTS = _浴袍
		ELSE
			;服
			SIF EQUIP:CHARA:上身衣服２ == 3
				RESULTS = _睡衣
		ENDIF
ENDSELECT

;IMAGE_I64_特殊表情(CHARA)--------------------------------------------------------------------
;角色特有の表情表示条件
;時間停止中でも維持する表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"通常","笑顔","憤怒","発情","睡眠"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I64_特殊表情(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA

SELECTCASE CFLAG:64:差し替え適用
	;替换用画像
	CASE 2
		IF CHECK_NUDE(CHARA)
			;裸
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立絵
			ENDIF
		ELSE
			;服
			IF CFLAG:CHARA:睡眠
				RESULTS = 睡眠覆盖
				RESULTS:1 = 睡眠覆盖
			ENDIF
		ENDIF
	CASE 1
	CASE 0
		;通常画像
		IF CHECK_NUDE(CHARA)
			;裸
		ELSE
			;服
		ENDIF
ENDSELECT

;IMAGE_I64_特殊表情COM(CHARA, 指令)-------------------------------------------------------
;直前の指令で変化する角色特有の表情表示条件
;時間停止中は変化しない表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"自慰","愛撫","性交"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I64_特殊表情COM(CHARA, 指令)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIM 指令

SELECTCASE CFLAG:64:差し替え適用
	CASE 2
		IF CHECK_NUDE(CHARA)
			SELECTCASE 指令
				CASE 80
					RESULTS = 手交覆盖
				CASE 81
					RESULTS = 口交覆盖
				CASE 82
					RESULTS = 乳交覆盖
				CASE 85
					RESULTS = 足交覆盖
				CASE 8
					IF 	EX:CHARA:膣内精液
						RESULTS = 张开阴唇2覆盖
					ELSE
						RESULTS = 张开阴唇覆盖
					ENDIF
				CASE 13
					IF 	EX:CHARA:肛門内精液
						RESULTS = 张开菊穴2覆盖
					ELSE
						RESULTS = 张开菊穴覆盖
					ENDIF
				CASEELSE
					IF MASTER_POSE(SET_V,SET_P) == CHARA
						SELECTCASE TEQUIP:CHARA:110
							CASE POSE_MISSIONARY
							RESULTS = V_正面覆盖
							CASE POSE_COWGIRL,POSE_LOTUS,POSE_SUSPENDED_CONGRESS
							RESULTS = V_上位覆盖
							CASE POSE_DOGGYSTYLE,POSE_REVLOTUS,POSE_REV_COWGIRL
							RESULTS = V_背后覆盖
						ENDSELECT
					ELSEIF MASTER_POSE(SET_A,SET_P) == CHARA
						SELECTCASE TEQUIP:CHARA:110
							CASE POSE_MISSIONARY
							RESULTS = A_正面覆盖
							CASE POSE_COWGIRL,POSE_LOTUS,POSE_SUSPENDED_CONGRESS
							RESULTS = A_上位覆盖
							CASE POSE_DOGGYSTYLE,POSE_REVLOTUS,POSE_REV_COWGIRL
							RESULTS = A_背后覆盖
						ENDSELECT
					ENDIF
			ENDSELECT



		ELSE
			IF IS_BUNNY(CHARA)
			ELSEIF EQUIP:CHARA:外搭 == [[神秘宝藏礼装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[不知火舞忍装]]
			ELSEIF EQUIP:CHARA:連衣裙 == 23
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[女僕装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[女牛仔套装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[啦啦队制服]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[婚紗套]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[花魁盛装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[勇仪和服套装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[日式学校运动服]]
			ELSEIF EQUIP:CHARA:外搭 == 11
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || CURRENT_CLOTHES_SET(CHARA) == 53 || TEQUIP:CHARA:SWIMMING
			ELSEIF CHECK_CLO("bra_visible", CHARA)
			ELSE
				SELECTCASE 指令
					CASE 305
						RESULTS = 膝枕覆盖
					CASE 310
						RESULTS = 揉屁股覆盖
					CASE 6,12,313
						RESULTS = 揉胸覆盖
				ENDSELECT
			ENDIF
		ENDIF
	CASEELSE
		IF CHECK_NUDE(CHARA)
			;裸
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立ち絵
			ENDIF
		ELSE
			;服
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立ち絵
			ENDIF
		ENDIF
ENDSELECT

;IMAGE_I64_差分(CHARA)-----------------------------------------------------------------------
;角色特有の差分表示条件
;裸やエフェクトを共有しない画像はこちら
;使用時注意点:
;	RESULTSに差分を格納すること
;	書式は {CHARA}%差分% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I64_差分(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS

IF CFLAG:64:差し替え適用 == 1
	;替换用画像
ELSEIF CFLAG:64:差し替え適用
	;替换用画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立絵
	ENDIF
ELSE
	IF CURRENT_CLOTHES_SET(CHARA) == 75 && !CHECK_NUDE(CHARA)
		RESULTS = _黄昏
	ENDIF
ENDIF

;IMAGE_I64_特殊エフェクト(CHARA)--------------------------------------------------------------------
;角色特有のエフェクト表示条件
;使用時注意点:
;	RESULTS配列に特殊エフェクトを格納
;	RETURNで追加するエフェクト数を返却すること
;-------------------------------------------------------------------------------------------
@IMAGE_I64_特殊エフェクト(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIM DYNAMIC エフェクト数 = 0
VARSET RESULTS

IF CFLAG:64:差し替え適用 == 2
	;差し替え画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立絵
		IF CHECK_NUDE(CHARA) && CFLAG:CHARA:1998 == 1
			RESULTS:エフェクト数 = 阴毛
			エフェクト数 += 1
		ENDIF
	ENDIF
ELSEIF CFLAG:64:差し替え適用 == 1
	;差し替え画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立ち絵
	ENDIF
ELSE
	;通常画像
	IF FLAG:立絵種類
		;顔絵
		IF CURRENT_CLOTHES_SET(CHARA) == 75
			IF CFLAG:CHARA:脸上精液
				;胸ぶっかけ
				RESULTS:エフェクト数 = 顔精液
				エフェクト数 += 1
			ENDIF
			IF CFLAG:CHARA:口内精液
				;フェラ
				RESULTS:エフェクト数 = 胸精液
				エフェクト数 += 1
			ENDIF
		ENDIF
	ELSE
		;立ち絵
	ENDIF
ENDIF

RETURN エフェクト数