@CHARAMOVE_DATA_64(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 64
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;地霊殿には行かない
			CASE P901地霊殿前 TO P930旧血の池地獄, P947ちやりの棲み処
				RETURN -100
			;酒場と鬼的聚集場所に行きやすい
			CASE P933酒場, P938鬼的聚集場所
				RETURN 5
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			;春と秋だけ
			CASE 呑屋小道
				SIF GROUPMATCH(DAY:2, 1, 3)
					RETURN 1
			CASE 山麓樹海, 玄武之澤, 大蛤蟆之池
				SIF GROUPMATCH(DAY:2, 1, 3)
					RETURN 1
			CASE 幻想風穴, 地獄的深道, 旧地獄街道
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
		;夜はよく酒場
		SIF CFLAG:LOCAL:今日の運勢 % 4 == 0 && INRANGE(TIME, 1200, 1440)
			TCVAR:LOCAL:引力点 = P933酒場
ENDSELECT

@EXIST_キャラデータ64
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ64(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	CALLF MAKE_STR(V_NAME, "勇儀")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（襦袢）套")

CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("靴", "木屐"))
CASE "便装：裙子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("裙子", "裙子"))
CASE "便装：上身衣服２"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("上身衣服２", "女式衬衫"))
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("其他１", "拘束具"))
CASE "便装：飾品"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("飾品", "酒杯"))

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "超强的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "虎皮鬼胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "裹胸")
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[勇儀]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 3)

;特殊衣装
CASE "デート衣装", "人里デート衣装", "おうちデート衣装"
	CALLF MAKE_INT(V_NAME, OBJNAME_TO_ID(ARG, "GET", "衣装セット", "勇仪和服套装"))

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "肉料理/香料/和食/鍋物/開胃/辣/丰盛/濃厚/芸術的/野趣/豪快/松脆/地底風/天狗流/" + "咸/" * 3)
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "简易/淡白/甜/甜/謎料理/謎料理/謎料理/化学的/化学的/化学的/" + "小人族秘伝の味/" * 5)
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "地底風/得意料理＊豪快＊/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "赤/金/混沌/帥氣的/充滿力量/壮大/" + "食器/鎖の/酒/" * 3 + "鬼の/華の/鬼力の/力の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "精神/活潑/繊細/知的/洛麗塔/" + "刃物/弾/書物/機械/" * 3 + "河童の/天狗の/" * 10)
ENDSELECT

;-------------------------------------------------
;固有料理設定
;DISH_NAME          料理名
;RESULTS            料理の種類（軽食/主食/甜点）
;CALL 材料設定("")  材料の指定。"汎用"を入れると自動で汎用食材になる
;DISH_TASTE         味の設定
;DISH_COMMENT       （任意）一行コメント
