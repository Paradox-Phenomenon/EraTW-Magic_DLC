@CHARAMOVE_DATA_103(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 103
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;あんまり入らない
			CASE P512魔理沙宅・寝室, P521人偶洋館・愛麗絲的房間, P522人偶洋館・神綺的房間
				RETURN -5
			;引きこもらない
			CASE P523人偶洋館・夢子的房間
				RETURN -10
			;生活間, 研究室に行きやすい
			CASE P524人偶洋館・研究室, P525人偶洋館・生活間
				RETURN 5
			;他所の私室には入らない
			CASE P511魔理沙宅・居間, P515魔理沙宅・倉庫, P535艾伦宅・寝室, P536艾伦宅・倉庫, P537艾伦宅・風呂
				RETURN -100
			CASE P541朱鷺子的棲息処 TO P544成美の小屋
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 広場, 商家町, 呑屋小道
				RETURN 1
			CASE 森林的入口, 古木的大樹, 霧雨魔法店, 人偶的洋館, 再思之道, 無縁塚
				RETURN 1
			CASE 魔界都市, 万魔殿
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ103
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ103(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	CALLF MAKE_STR(V_NAME, "夢子")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（吊带睡裙）套")

CASE "便装：帽子"
	CALLF MAKE_INT(V_NAME, [[頭装備_女仆发箍]])
CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, [[靴_鞋子]])
CASE "便装：襪子"
	CALLF MAKE_INT(V_NAME, [[襪子_长筒袜]])
CASE "便装：連衣裙"
	CALLF MAKE_INT(V_NAME, [[連衣裙_围裙洋装]])

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "有着谜之重量和冰冷感的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "梦子胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "梦子胸罩")
CASE "固有内衣着用条件"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "面包/牛奶/洋食/葉物/派/健康/淡白/豪華/上品/家庭的/软绵绵/魔力/魔界風/甜/甜/辣/辣/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "濃厚/野趣/咸/咸/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/謎料理/謎料理/謎料理/謎料理/謎料理/")
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "魔界風/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "赤/秩序/美的/シンプル/洋風/繊細/" + "神霊/刃物/" * 3 + "女僕的/魔界の/懐剣/護刀/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "混沌/和風/パワフル/ロリータ/" + "生体品/" * 3)
ENDSELECT

