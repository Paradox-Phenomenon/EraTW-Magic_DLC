;IMAGE_I103_特殊表情COM(CHARA, コマンド)-------------------------------------------------------
;直前のコマンドで変化するキャラクター特有の表情表示条件
;時間停止中は変化しない表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"オナニー","愛撫","性交"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I103_特殊表情COM(CHARA, コマンド)
#DIM CHARA
#DIM コマンド

SELECTCASE CFLAG:103:差し替え適用
	CASE 2
		IF CHECK_NUDE(CHARA)
			SELECTCASE コマンド
				CASE 80
					RESULTS = 手交覆盖
				CASE 81
					RESULTS = 口交覆盖
				CASE 82
					RESULTS = 乳交覆盖
				CASE 85
					RESULTS = 足交覆盖
				CASE 8
					IF EX:CHARA:膣内精液
						RESULTS = 张开阴唇2覆盖
					ELSE
						RESULTS = 张开阴唇覆盖
					ENDIF
				CASE 13
					IF EX:CHARA:肛門内精液
						RESULTS = 张开菊穴2覆盖
					ELSE
						RESULTS = 张开菊穴覆盖
					ENDIF
				CASE 83
					IF CFLAG:CHARA:妊娠経過日数 >= 40
						RESULTS = 妊娠_素股覆盖
					ELSE
						RESULTS = 素股覆盖
					ENDIF
				CASEELSE
					IF MASTER_POSE(SET_V,SET_P) == CHARA && CHECK_NUDE([[神绮]]) && CFLAG:[[神绮]]:诶嘿嘿
						SELECTCASE TEQUIP:CHARA:110
							CASE POSE_MISSIONARY
								RESULTS = 正常位覆盖_d0
							CASE POSE_COWGIRL,POSE_LOTUS,POSE_SUSPENDED_CONGRESS
								RESULTS = 骑乘位覆盖_d0
							CASE POSE_DOGGYSTYLE,POSE_REVLOTUS,POSE_REV_COWGIRL
								RESULTS = 后入位覆盖_d0
						ENDSELECT
					ELSEIF MASTER_POSE(SET_A,SET_P) == CHARA && CHECK_NUDE([[神绮]]) && CFLAG:[[神绮]]:诶嘿嘿
						SELECTCASE TEQUIP:CHARA:110
							CASE POSE_MISSIONARY
								RESULTS = 正常位A覆盖_d0
							CASE POSE_COWGIRL,POSE_LOTUS,POSE_SUSPENDED_CONGRESS
								RESULTS = 正常位A覆盖_d0
							CASE POSE_DOGGYSTYLE,POSE_REVLOTUS,POSE_REV_COWGIRL
						ENDSELECT
					ELSEIF MASTER_POSE(SET_V,SET_P) == CHARA
						SELECTCASE TEQUIP:CHARA:110
							CASE POSE_MISSIONARY
								RESULTS = V_正面覆盖
							CASE POSE_COWGIRL,POSE_SUSPENDED_CONGRESS
								RESULTS = V_骑乘位覆盖
							CASE POSE_LOTUS
								RESULTS = V_对面座位覆盖
							CASE POSE_DOGGYSTYLE,POSE_REV_COWGIRL
								RESULTS = V_后入覆盖
							CASE POSE_STANDING_FROM_BEHIND
								RESULTS = V_站立后入覆盖
							CASE POSE_REVLOTUS
								RESULTS = V_背面坐莲覆盖
							CASE POSE_STANDING_MISSIONARY
								RESULTS = 站立正常覆盖
						ENDSELECT
						IF CFLAG:CHARA:妊娠経過日数 >= 40
							RESULTS = 妊娠_%RESULTS%
						ENDIF
					ELSEIF MASTER_POSE(SET_A,SET_P) == CHARA
						SELECTCASE TEQUIP:CHARA:110
							CASE POSE_MISSIONARY
								RESULTS = A_正面覆盖
							CASE POSE_COWGIRL,POSE_SUSPENDED_CONGRESS
								RESULTS = A_骑乘位覆盖
							CASE POSE_LOTUS
								RESULTS = A_对面座位覆盖
							CASE POSE_DOGGYSTYLE,POSE_REV_COWGIRL
								RESULTS = A_后入覆盖
							CASE POSE_STANDING_FROM_BEHIND
								RESULTS = A_站立后入覆盖
							CASE POSE_REVLOTUS
								RESULTS = A_背面坐莲覆盖
							CASE POSE_STANDING_MISSIONARY
								RESULTS = 站立正常覆盖
						ENDSELECT
						IF CFLAG:CHARA:妊娠経過日数 >= 40
							RESULTS = 妊娠_%RESULTS%
						ENDIF
					ENDIF
			ENDSELECT
		ELSE
			IF IS_BUNNY(CHARA)
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[修女服]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[连体紧身衣]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[时空管理局制服]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[危险野兽礼装]]
			ELSEIF IS_SCHOOLUNIFORM(CHARA)
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[舞娘套装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[皇家糖霜礼装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[岛风制服]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[浴衣穿搭]] || EQUIP:CHARA:和服 == 1
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[辣妹系休闲套装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 33
			ELSEIF CHECK_CLO("bra_visible", CHARA)
			ELSE
				SELECTCASE コマンド
					CASE 305
						RESULTS = 膝枕覆盖
					CASE 330
						SELECTCASE TFLAG:194
							CASE 0
								RESULTS = 掀裙子1覆盖
							CASE 1
								IF RAND:2 + RAND:(1 + (ABL:CHARA:露出癖 > 5))
									RESULTS = 掀裙子2覆盖
								ELSE
									RESULTS = 掀裙子1覆盖
								ENDIF
						ENDSELECT
					CASE 6,12,313
						RESULTS = 揉胸覆盖
				ENDSELECT
			ENDIF
		ENDIF
	CASEELSE
		IF CHECK_NUDE(CHARA)
			;裸
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立ち絵
			ENDIF
		ELSE
			;服
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立ち絵
			ENDIF
		ENDIF
ENDSELECT
DEBUGPRINTFORML 特殊表情决定: %RESULTS%
