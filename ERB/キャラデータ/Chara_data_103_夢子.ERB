;キャラクター特有の自慰画像表示条件
;使用時注意点:
;	RESULTS:0に自慰画像の主体を格納すること
;	RESULTS:1 ～ 3に自慰エフェクトを格納すること
;-------------------------------------------------------------------------------------------
@IMAGE_I103_特殊自慰(CHARA)
#DIM CHARA
VARSET RESULTS

SELECTCASE CFLAG:103:差し替え適用
	CASE 2

	CASEELSE
		IF CHECK_NUDE(CHARA)
			;裸
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立ち絵
			ENDIF
		ELSE
			;服
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立ち絵
			ENDIF
		ENDIF
ENDSELECT

;IMAGE_I103_自慰エフェクト(CHARA)--------------------------------------------------------------------
;キャラクター特有の自慰エフェクト表示条件
@IMAGE_I103_自慰エフェクト(CHARA)
#DIM CHARA
#DIM DYNAMIC エフェクト数 = 0
VARSET RESULTS

SELECTCASE CFLAG:103:差し替え適用
	CASE 2

	CASEELSE
		IF CHECK_NUDE(CHARA)
			;裸
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立ち絵
			ENDIF
		ELSE
			;服
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立ち絵
			ENDIF
		ENDIF
ENDSELECT

RETURN エフェクト数
;********************************************************************************************
[SKIPEND]