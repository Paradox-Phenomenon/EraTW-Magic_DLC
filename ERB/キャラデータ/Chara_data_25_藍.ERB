@CHARAMOVE_DATA_25(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 25
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
		SIF CFLAG:LOCAL:今日の運勢 % 10 == 0
			RETURN [[紫]]
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;紫様の私室はあまり入らない
			CASE P633紫私室
				RETURN -5
			;是非曲直庁、畜生界は行かない
			CASE P610是非曲直庁大堂 TO P618空的部屋, P640異界の関所 TO P655尤魔宅の風呂
				RETURN -100
			;他人的家には入らない
			CASE P608潤美的家, P609瓔花的家
				RETURN -100
			;私室等には入らない
			CASE P623幽幽子私室, P624妖夢私室, P627風呂, P606日狭美の家, P607残無の家
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 桜花道的鳥居, 神社境内, 神社本堂, 神社走廊
				RETURN 1
			CASE 呑屋小道
				RETURN 1
			CASE 中有之道, 三途之川, 迷途之家, 白玉楼庭, 白玉楼
				RETURN 1
			CASE 山麓樹海, 玄武之澤, 大蛤蟆之池, 森の深奥
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ25
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ25(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	CALLF MAKE_STR(V_NAME, "藍")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（襦袢）套")

CASE "便装：帽子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("帽子", "帽子"))
CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("靴", "鞋子"))
CASE "便装：襪子"
	IF FLAG:2 > 0
		CALLF MAKE_INT(V_NAME, CLOTHES_ID("襪子", "长筒袜"))
	ELSE
		CALLF MAKE_INT(V_NAME, CLOTHES_ID("襪子", "袜子"))
	ENDIF
CASE "便装：連衣裙"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("連衣裙", "道士服"))

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "尾部开了个大洞的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "带洞胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "全罩杯胸罩")
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[藍]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "肉料理/卵/和食/中華/油炸食品/丰盛/上品/家庭的/機能的/软糯的/辣/辣/酸/酸/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "咸/咸/謎料理/謎料理/謎料理/謎料理/謎料理/")
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "妖力/妖力/得意料理＊和食＊/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "青/秩序/美的/和風/別緻/知的/" + "妖術/書物/" * 3 + "狐の/式神の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "ポップ/ロリータ/マニアック/" + "水/护臂/" * 3 + "狸の/" * 10)

;農民関連
;おあげ
CASE "農民：説明"
	CALLF MAKE_STR(V_NAME, "大豆農家")
CASE "農民：作物"
	CALLF MAKE_STR(V_NAME, "大豆")
CASE "農民：田的种类"
	CALLF MAKE_STR(V_NAME, "大豆畑")
CASE "農民：畑の所在地"
	CALLF MAKE_STR(V_NAME, "人里")

CASE "農民：MapID"
	CALLF MAKE_INT(V_NAME, 2)
CASE "農民：場所ID"
	CALLF MAKE_INT(V_NAME, 205)
CASE "農民：報酬"
	CALLF MAKE_INT(V_NAME, 600)
CASE "農民：金利"
	CALLF MAKE_INT(V_NAME, 5)
ENDSELECT

;-------------------------------------------------
;固有料理設定
;DISH_NAME          料理名
;RESULTS            料理の種類（軽食/主食/甜点）
;CALL 材料設定("")  材料の指定。"汎用"を入れると自動で汎用食材になる
;DISH_TASTE         味の設定
;DISH_COMMENT       （任意）一行コメント
;DISH_TIME          （任意）調理にかかる時間
;DISH_MAXLIMIT      （任意）料理の持続時間
;-------------------------------------------------
@SPECIAL_MENU_25
#LOCALSIZE 1
#LOCALSSIZE 1
DISH_NAME = 稻荷寿司
RESULTS = 軽食
CALL 材料設定("汎用")
DISH_TASTE = 和食/油炸食品/米/酸/简易/淡白/中立温度/質素/家庭的/
DISH_COMMENT = 稻荷寿司是一种模仿草袋的模样、用油炸豆腐包裹醋饭的寿司。
RETURN 1

;IMAGE_I25_特殊服装(CHARA)-------------------------------------------------------------------
;キャラクター特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I25_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS
IF CFLAG:25:差し替え適用 == 2
	;差し替え画像
	IF CHECK_NUDE(CHARA)
		;裸
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
	ELSE
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
	ENDIF
ELSEIF CFLAG:25:差し替え適用 == 1
	;差し替え画像
	IF CHECK_NUDE(CHARA)
		;裸
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
	ELSE
		;服
		IF CFLAG:CHARA:睡眠 || CFLAG:CHARA:陪睡中 || 睡眠時間(CHARA)
			RESULTS = _睡衣
		ELSEIF IS_BUNNY(CHARA)
			RESULTS = _兔女郎
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == 31 || EQUIP:CHARA:上身衣服２ == 3
			RESULTS = _睡衣
		ELSEIF CHECK_CLO("bra_visible", CHARA)
			RESULTS = _下着
		ENDIF
	ENDIF
ELSE
	;通常画像
	IF CHECK_NUDE(CHARA)
		;裸
		SIF BATHROBE_SWITCH && BATHROOM() && !CFLAG:诶嘿嘿
			RESULTS = _浴袍
	ELSE
		;服
	ENDIF
ENDIF

;IMAGE_I25_特殊表情(CHARA)--------------------------------------------------------------------
;キャラクター特有の表情表示条件
;时间停止中でも维持する表情はこちら
;使用时注意点:
;	RESULTS:0に表情を格纳
;	RESULTS:1にマウスオーバー时の表情を格纳すること
;	"通常","笑颜","愤怒","发情","睡眠"は本编で实装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I25_特殊表情(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA

IF CFLAG:25:差し替え適用 == 1
	IF CHECK_NUDE(CHARA)
	ELSE
		IF IS_BUNNY(CHARA)
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == 31 || EQUIP:CHARA:上身衣服２ == 3
		ELSEIF CHECK_CLO("bra_visible", CHARA)
		ELSEIF (RESULTS:0 == "通常" || RESULTS:0 == "笑顔"); && CFLAG:25:1999
			RESULTS:1 = 笑顔动
			SETANIMETIMER 40
		ELSE
			SETANIMETIMER 32627
		ENDIF
	ENDIF
ELSE
	;通常画像
	IF FLAG:立絵種類
		;颜绘
	ELSE
		;立绘
	ENDIF
ENDIF

@IMAGE_I25_特殊表情COM(CHARA, コマンド)
#DIM CHARA
#DIM コマンド

SELECTCASE CFLAG:25:差し替え適用
	CASE 2
	CASE 1
		IF CHECK_NUDE(CHARA)
		ELSE
			IF IS_BUNNY(CHARA)
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 31 || EQUIP:CHARA:上身衣服２ == 3
			ELSEIF CHECK_CLO("bra_visible", CHARA)
			ELSE
				SELECTCASE コマンド
					CASE 305
						RESULTS = 膝枕覆盖
					CASE 6,12,313
						RESULTS = 揉胸覆盖
				ENDSELECT
			ENDIF
		ENDIF
	CASE 0
		IF CHECK_NUDE(CHARA)
			;裸
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立ち絵
			ENDIF
		ELSE
			;服
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立ち絵
			ENDIF
		ENDIF
ENDSELECT
