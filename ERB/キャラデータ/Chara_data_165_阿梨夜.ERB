;-------------------------------------------------
[SKIPSTART]
@SPECIAL_MENU_165
#LOCALSIZE 1
#LOCALSSIZE 1
DISH_NAME = 圣餐饼
RESULTS = 甜点
CALL 材料設定("汎用")
DISH_TASTE = 洋食/简易/家庭的/芸術的/マニアック/
DISH_COMMENT = 一种轻薄的米饼，常被象征为‘基督的身体’。 
RETURN 1
[SKIPEND]
;IMAGE_I165_特殊服装(CHARA)-------------------------------------------------------------------
;角色特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I165_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS
SELECTCASE CFLAG:165:差し替え適用
	CASE 1
	CASE 0
		IF CHECK_NUDE(CHARA)
		ELSE
			IF IS_BUNNY(CHARA)
				RESULTS = _兔女郎
			ELSEIF IS_SCHOOLUNIFORM(CHARA)
				RESULTS = _制服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 33
				RESULTS = _睡衣
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 73
				RESULTS = _旗袍
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[巫女装束]]
				RESULTS = _巫女服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[晚宴礼服套装]]
				RESULTS = _晚礼服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || CURRENT_CLOTHES_SET(CHARA) == 53 || TEQUIP:CHARA:SWIMMING
				RESULTS = _比基尼
			ELSEIF CHECK_CLO("bra_visible", CHARA)
				RESULTS = _睡衣
			ENDIF
		ENDIF
ENDSELECT
