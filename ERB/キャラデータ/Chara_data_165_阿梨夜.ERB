@CHARAMOVE_DATA_165(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 165
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
		RESULT:1 = [[维缦]]
		RESULT:2 = [[阿梨夜]]
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;山
			;私室には入らない
			CASE P704河童のアジト, P706厄神の家, P709リリーたちの家, P716秋姉妹の家・土間 TO P730仙人の屋敷・庭
				RETURN -100
			CASE P733正邪の隠れ家, P736山姥の家, P737招き猫の家, P740山童のアジト,P742美天居所
				RETURN -100
			;竹林
			CASE P432影狼の家, P437メディスンの家, P439ラルバの家, P443ミスティアの家, P445妹紅の家
				RETURN -100
			;永遠亭の奥には行かない
			CASE P405調剤室, P407廊下 TO P430地下室
				RETURN -100
			;夢幻館には行かない
			CASE P450玄関 TO P466庭
				RETURN -100
			CASE P433斜角の竹林, P434迷いの小道, P444夜雀の屋台, P447竹林入口
				RETURN 1
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 広場, 商家町, 呑屋小道, 寺子屋, 長屋街
				RETURN 1
			CASE 山麓樹海, 玄武之澤, 大蛤蟆之池, 森の深奥, 圣域, 浅间净秽山
				RETURN 1
			CASE 竹林入り口, 迷いの小道, 斜角の竹林, 兎の洞穴, 永遠亭, 無名の丘, 太陽の畑
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ165
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ165(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	CALLF MAKE_STR(V_NAME, "阿梨夜")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（吊带睡裙）套")
	
CASE "便装：連衣裙"
	CALLF MAKE_INT(V_NAME, [[連衣裙_連衣裙]])
CASE "便装：外搭"
	CALLF MAKE_INT(V_NAME, [[外搭_斗篷]])
CASE "便装：飾品"
	CALLF MAKE_INT(V_NAME, [[飾品_石假面]])
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, [[其他衣装_化石]])

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "掌管不变的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "始祖鸟胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "始祖鸟胸罩")
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[阿梨夜]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)

;料理関連
;変化に関連することが嫌い
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "質素/" * 5 + "ヤマドリ/竜骨/上品/地底風/サクサク/咸/咸/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "旬/旬/春物/夏物/秋物/冬物/生命力/月都風/")
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "神力/不変/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "かっこいい/化石/骨/土/鉱物/" + "石の/面/假面/孤独の/神霊/" * 3 + "永遠の/不滅の/不変の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "美的/木の/花の/華の/四季の/" + "破滅の/" * 3 + "刹那の/須臾の/" * 10)
ENDSELECT

