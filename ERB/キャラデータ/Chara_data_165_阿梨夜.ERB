@CHARAMOVE_DATA_165(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 165
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
		;たまに連動
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;私室には入らない
			CASE P704河童の宣傳站, P706厄神的家, P709莉莉們的家, P716秋姉妹的家・土間 TO P730仙人的宅邸・庭
				RETURN -100
			CASE P733正邪的隠匿処, P737招财猫的家, P740山童の宣傳站, P742美天居所
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 山麓樹海, 玄武之澤, 大蛤蟆之池, 森の深奥, 圣域, 浅间净秽山
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ165
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ165(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	CALLF MAKE_STR(V_NAME, "阿梨夜")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（吊带睡裙）套")
	
CASE "便装：連衣裙"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("連衣裙", "連衣裙"))
CASE "便装：外搭"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("外搭", "斗篷"))
CASE "便装：飾品"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("飾品", "石假面"))
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("其他１", "化石"))

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "始祖鸟图案的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "印花胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "印花胸罩")
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[阿梨夜]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 0)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 0)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)

;品味系统 待定
[SKIPSTART]
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "葉物/" * 2 + "淡白/" * 2 + "健康/" * 5 + "中華/" * 5 + "薬効/" * 5)
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "虫肉/" * 5 + "青蛙/" * 5 + "卵/" * 5 + "鳥肉/" * 5 + "獣肉/" * 5 + "魚料理/" * 5)
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "薬効/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "美的/美麗な/天人の/知恵の/" * 2 + "巫女の/風の/花の/令人怀念の/" * 3 + "東方の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "魔神の/" + "被遗忘的/" * 10)
[SKIPEND]
ENDSELECT

;-------------------------------------------------
;固有料理設定
;DISH_NAME          料理名
;RESULTS            料理の種類（軽食/主食/甜点）
;CALL 材料設定("")  材料の指定。"汎用"を入れると自動で汎用食材になる
;DISH_TASTE         味の設定
;DISH_COMMENT       （任意）一行コメント
;DISH_TIME          （任意）調理にかかる時間
;DISH_MAXLIMIT      （任意）料理の持続時間
;-------------------------------------------------
[SKIPSTART]
@SPECIAL_MENU_165
#LOCALSIZE 1
#LOCALSSIZE 1
DISH_NAME = 圣餐饼
RESULTS = 甜点
CALL 材料設定("汎用")
DISH_TASTE = 洋食/简易/家庭的/芸術的/狂熱/
DISH_COMMENT = 一种轻薄的米饼，常被象征为‘基督的身体’。 
RETURN 1
[SKIPEND]
