@CHARAMOVE_DATA_96(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 96
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
		RESULT:1 = [[弁弁]]
		RESULT:2 = [[八橋]]
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;付喪神的房間,広場によく居る
			CASE P208雷鼓的房間, P209八橋的房間, P210弁弁的房間, P202中央広場
				RETURN 5
			;私室には行かない
			CASE P221稗田邸, P224慧音宅, P222寺子屋, P226小鈴私室, P229阿求私室
				RETURN -100
			CASE P231蛮奇的房間, P232蓮子的房間, P233梅莉的房間, P234雪的房間, P235​​舞​的房間, P239美宵的房間
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 広場, 商家町, 呑屋小道, 長屋街
				RETURN 1
			CASE 森林的入口, 香霖堂, 古木的大樹, 再思之道, 無縁塚
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ96
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ96(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	CALLF MAKE_STR(V_NAME, "雷鼓")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（裤子）套")

CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, [[靴_鞋子]])
CASE "便装：裙子"
	CALLF MAKE_INT(V_NAME, [[裙子_裙子]])
CASE "便装：外搭"
	CALLF MAKE_INT(V_NAME, [[外搭_夹克衫]])
CASE "便装：上身衣服１"
	CALLF MAKE_INT(V_NAME, [[上身衣服_はだけ不可_衬衫]])
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, [[其他衣装_领带]])
CASE "便装：其他２"
	CALLF MAKE_INT(V_NAME, [[其他衣装_吊帯]])
CASE "便装：其他３"
	CALLF MAKE_INT(V_NAME, [[其他衣装_大鼓]])

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "摇滚风格的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "侧边系绳胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "黑文胸")
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[雷鼓]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "面包/香料/洋食/油炸食品/丰盛/豪華/芸術的/豪快/サクサク/辣/辣/咸/咸/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "简易/酸/酸/" + "青蛙/虫肉/蘑菇/謎料理/" * 3)
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "刺激的/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "赤/かっこいい/混沌/シンプル/和風/パワフル/知的/" + "雷/音楽/楽器/" * 3 + "太古の/雷神の/闪电の/领带/鼓槌/指揮棒/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "洋風/繊細/ロリータ/" + "刃物/生体品/护臂/" + "精霊銀の/" * 10)
ENDSELECT

