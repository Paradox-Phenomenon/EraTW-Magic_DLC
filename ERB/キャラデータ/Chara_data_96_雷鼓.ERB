;IMAGE_I96_特殊服装(CHARA)-------------------------------------------------------------------
;角色特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I96_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS
SELECTCASE CFLAG:96:差し替え適用
	CASE 2
	CASE 1
		IF CHECK_NUDE(CHARA)
		ELSE
			IF CFLAG:CHARA:睡眠 || CFLAG:CHARA:陪睡中 || 睡眠時間(CHARA)
				RESULTS = _下着
			ELSEIF IS_BUNNY(CHARA)
				RESULTS = _バニーギャル
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[西式职业男装]]
				RESULTS = _マキマ
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 64
				RESULTS = _ライダースーツ
			ELSEIF CHECK_CLO("bra_visible", CHARA)
				RESULTS = _下着
			ENDIF
		ENDIF
	CASE 0
	;通常画像
		IF CHECK_NUDE(CHARA)
			;裸
		ELSE
			;服
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立絵
			ENDIF
		ENDIF
ENDSELECT

;IMAGE_I96_特殊表情(CHARA)--------------------------------------------------------------------
;角色特有の表情表示条件
;時間停止中でも維持する表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"通常","笑顔","憤怒","発情","睡眠"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I96_特殊表情(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA

IF CFLAG:96:差し替え適用 == 1
	IF TALENT:CHARA:心情 == 1 || BASE:CHARA:情緒 > MAXBASE:CHARA:情緒 / 2 || TALENT:CHARA:恋慕
		IF RESULTS:0 == "通常"
			RESULTS:0 '= "微笑"
		ENDIF
		IF RESULTS:1 == "通常"
			RESULTS:1 '= "微笑"
		ENDIF
	ENDIF
ELSE
	;通常画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立絵
	ENDIF
ENDIF

;IMAGE_I96_特殊表情COM(CHARA, 指令)-------------------------------------------------------
;直前の指令で変化する角色特有の表情表示条件
;時間停止中は変化しない表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"自慰","愛撫","性交"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I96_特殊表情COM(CHARA, 指令)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIM 指令

SELECTCASE CFLAG:96:差し替え適用
	;替换用画像
	CASE 1
		IF CHECK_NUDE(CHARA)
		ELSE
			;服
			IF IS_BUNNY(CHARA)
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[西式职业男装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 64
			ELSEIF CHECK_CLO("bra_visible", CHARA)
			ELSE
				SELECTCASE 指令
					CASE 305
						RESULTS = 膝枕覆盖
					CASE 6,12,313
						RESULTS = 揉胸覆盖
				ENDSELECT
			ENDIF
		ENDIF
	CASEELSE
		;通常画像
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
ENDSELECT
@MUSIC_BUFF_96(ARG, SUCCESS)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC SUCCESS
IF SUCCESS == 1
	TIMES SOURCE:ARG:征服, 1.1
	CALL COLORMESSAGE(@"由于%CALLNAME:[[雷鼓]]%的能力，征服提升了",C_YELLOW,1)
ENDIF
