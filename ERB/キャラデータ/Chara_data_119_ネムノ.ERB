@CHARAMOVE_DATA_119(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 119
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;自宅によく居る
			CASE P744合欢宅邸
				RETURN 5
			;私室には入らない
			CASE P704河童の宣傳站, P706厄神的家, P709莉莉們的家, P716秋姉妹的家・土間 TO P730仙人的宅邸・庭
				RETURN -100
			CASE P733正邪的隠匿処, P737招财猫的家, P740山童の宣傳站, P742美天居所
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 山麓樹海, 玄武之澤, 大蛤蟆之池, 森の深奥
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ119
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ119(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	CALLF MAKE_STR(V_NAME, "合歡乃")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（裤子）套")

CASE "便装：飾品"
	CALLF MAKE_INT(V_NAME, [[飾品_袖]])
CASE "便装：連衣裙"
	CALLF MAKE_INT(V_NAME, [[連衣裙_連衣裙]])
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, [[其他衣装_菜刀]])

;あえて色は決めない
CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "染色风格新奇的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "扎染兜裆布")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "扎染裹胸")
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[合歡乃]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 0)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 3)

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "魚料理/蘑菇/和食/鍋物/下酒菜/丰盛/濃厚/秋物/質素/野趣/家庭的/黏稠/咸/咸/酸/酸/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "面包/乳酪/洋食/简易/淡白/外界風/甜/甜/謎料理/謎料理/謎料理/")
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "母亲的味道/得意料理＊秋物＊/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "茶/美的/シンプル/別緻/" + "秩序/刃物/" * 3 + "山の/聖域の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "混沌/洋風/ロリータ/" + "機械/" * 5)
ENDSELECT

;-------------------------------------------------
;固有料理設定
;DISH_NAME          料理名
;RESULTS            料理の種類（軽食/主食/甜点）
;CALL 材料設定("")  材料の指定。"汎用"を入れると自動で汎用食材になる
;DISH_TASTE         味の設定
;DISH_COMMENT       （任意）一行コメント
;DISH_TIME          （任意）調理にかかる時間
;DISH_MAXLIMIT      （任意）料理の持続時間
;-------------------------------------------------
@SPECIAL_MENU_119
#LOCALSIZE 1
#LOCALSSIZE 1
DISH_NAME = 山の郷土料理
RESULTS = 主食
CALL 材料設定("山菜")
DISH_TASTE = 和食/葉物/米/虫肉/野菜/豆/咸/丰盛/健康/濃厚/温暖/野趣/野趣/野趣/家庭的/薬効/母亲的味道/
DISH_COMMENT = 大量使用了山之恩惠的乡土料理。有家乡的味道。
RETURN 1

;IMAGE_I119_特殊服装(CHARA)-------------------------------------------------------------------
;角色特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I119_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS

IF CFLAG:119:差し替え適用 == 2
	;替换用画像
	IF CHECK_NUDE(CHARA)
		IF GROUPMATCH(1, TEQUIP:CHARA:新妻PLAY)
			RESULTS = _裸エプロン
		ENDIF
	ELSE
		IF CFLAG:CHARA:睡眠 || CFLAG:CHARA:陪睡中 || 睡眠時間(CHARA)
			RESULTS = _下着
		ELSEIF IS_BUNNY(CHARA)
			RESULTS = _バニーギャル
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
			RESULTS = _セーラー服
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[女僕装]]
			RESULTS = _メイド
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == 68
			RESULTS = _浴衣
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || CURRENT_CLOTHES_SET(CHARA) == 53 || TEQUIP:CHARA:SWIMMING
			RESULTS = _水着
		ELSEIF CHECK_CLO("bra_visible", CHARA)
			RESULTS = _下着
		ENDIF
	ENDIF
ELSEIF CFLAG:119:差し替え適用 == 1
	;替换用画像
ELSE
	;通常画像
ENDIF

;IMAGE_I119_特殊表情(CHARA)--------------------------------------------------------------------
;角色特有の表情表示条件
;時間停止中でも維持する表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"通常","笑顔","憤怒","発情","睡眠"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I119_特殊表情(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA

IF CFLAG:119:差し替え適用 == 2
	IF TALENT:CHARA:心情 == 1 || BASE:CHARA:情緒 > MAXBASE:CHARA:情緒 / 2 || TALENT:CHARA:恋慕
		IF RESULTS:0 == "通常"
			RESULTS:0 '= "微笑"
		ENDIF
		IF RESULTS:1 == "通常"
			RESULTS:1 '= "微笑"
		ENDIF
	ENDIF
ELSE
	;通常画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立絵
	ENDIF
ENDIF

;IMAGE_I119_特殊表情COM(CHARA, 指令)-------------------------------------------------------
;直前の指令で変化する角色特有の表情表示条件
;時間停止中は変化しない表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"自慰","愛撫","性交"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I119_特殊表情COM(CHARA, 指令)
#DIM CHARA
#DIM 指令

IF CFLAG:119:差し替え適用 == 2
	IF CHECK_NUDE(CHARA)
	ELSE
		;服
		IF IS_BUNNY(CHARA)
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[女僕装]]
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == 68
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || CURRENT_CLOTHES_SET(CHARA) == 53 || TEQUIP:CHARA:SWIMMING
		ELSEIF CHECK_CLO("bra_visible", CHARA)
		ELSE
			SELECTCASE 指令
				CASE 305
					RESULTS = 膝枕覆盖
				CASE 6,12,313
					RESULTS = 揉胸覆盖
			ENDSELECT
		ENDIF
	ENDIF
ELSEIF CFLAG:119:差し替え適用 == 1
	;替换用画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立絵
	ENDIF
ELSE
	;通常画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立絵
	ENDIF
ENDIF
