@CHARAMOVE_DATA_90(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 90
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;神霊廟メンバーの私室はあまり入らない
			CASE P125屠自古私室, P127布都私室, P128神子私室
				RETURN -5
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 地蔵小路, 倒垂的柳樹下, 墓地, 神霊廟広場, 神霊廟道場
				RETURN 1
			CASE 広場, 商家町, 呑屋小道
				RETURN 1
			CASE 中有之道, 三途之川
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ90
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ90(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	CALLF MAKE_STR(V_NAME, "青娥")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（吊带睡裙）套")

CASE "便装：帽子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("帽子", "簪子"))
CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("靴", "鞋子"))
CASE "便装：襪子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("襪子", "袜子"))
CASE "便装：連衣裙"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("連衣裙", "連衣裙"))
CASE "便装：外搭"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("外搭", "背心"))
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("其他１", "羽衣"))

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "体现性感的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "系带胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "胸前系带文胸")
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[青娥]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)
CASE "デート衣装", "人里デート衣装", "おうちデート衣装"
	SELECTCASE RAND:3
		CASE 2
			CALLF MAKE_INT(V_NAME, [[生足美鈴套]])
		CASE 1
			CALLF MAKE_INT(V_NAME, [[辣妹系休闲套装]])
	ENDSELECT

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "肉料理/麺類/丰盛/淡白/上品/新鲜/黏稠/仙術/妖力/霊障/月都風/中華/中華/辣/辣/咸/咸/怪诞/怪诞/怪诞/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "質素/神力/神力/神力/酸/酸/冥界風/冥界風/冥界風/天界風/天界風/天界風/")
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "妖力/霊障/得意料理＊中華＊/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "高級/混沌/可怕的/奇妙/大陸風/知的/不思議/" + "青/闇/骨/死生/妖術/" * 3 + "死霊の/仙人の/呪術の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "秩序/洛麗塔/" + "安物/神霊/护臂/" * 3)
ENDSELECT

;-------------------------------------------------
;固有料理設定
;DISH_NAME          料理名
;RESULTS            料理の種類（軽食/主食/甜点）
;CALL 材料設定("")  材料の指定。"汎用"を入れると自動で汎用食材になる
;DISH_TASTE         味の設定
;DISH_COMMENT       （任意）一行コメント
;DISH_TIME          （任意）調理にかかる時間
