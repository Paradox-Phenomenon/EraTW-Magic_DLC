;-------------------------------------------------
@SPECIAL_MENU_90
#LOCALSIZE 1
#LOCALSSIZE 1
DISH_NAME = 皮蛋
RESULTS = 軽食
CALL 材料設定("卵")
DISH_TASTE = 中華/卵/咸/简易/淡泊/怪诞/霊障/
DISH_COMMENT = 用灰腌制鸭蛋制成的发酵食品。漆黑一片，有点吓人。
RETURN 1

;IMAGE_I90_特殊服装(CHARA)-------------------------------------------------------------------
;角色特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I90_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS
SELECTCASE CFLAG:90:差し替え適用
	CASE 3
		IF CHECK_NUDE(CHARA)
		ELSE
			IF IS_BUNNY(CHARA)
				RESULTS = _バニーギャル
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[白衣天使套]]
				RESULTS = _ナース
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[保健室的女教师套]]
				RESULTS = _白大褂
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[生足美鈴套]]
				RESULTS = _チャイナドレス
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[危险野兽礼装]]
				RESULTS = _危险野兽
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[不给治就捣蛋礼装]]
				RESULTS = _不给治就捣蛋
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[皇家糖霜礼装]]
				RESULTS = _皇家糖霜
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[辣妹系休闲套装]]
				RESULTS = _私服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[魔法少女变装]]
				RESULTS = _魔法少女
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
				RESULTS = _セーラー服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 33
				RESULTS = _ベビードール
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || CURRENT_CLOTHES_SET(CHARA) == 28 || TEQUIP:CHARA:SWIMMING
				RESULTS = _比基尼
			ELSEIF CHECK_CLO("bra_visible", CHARA)
				RESULTS = _下着
			ENDIF
		ENDIF
	CASE 0
		IF CHECK_NUDE(CHARA)
		ELSE
		ENDIF
ENDSELECT

;IMAGE_I90_特殊表情COM(CHARA, 指令)-------------------------------------------------------
;直前の指令で変化する角色特有の表情表示条件
;時間停止中は変化しない表情はこちら
;使用時注意点:
;   RESULTS:0に表情を格納
;   RESULTS:1にマウスオーバー時の表情を格納すること
;   "自慰","愛撫","性交"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I90_特殊表情COM(CHARA, 指令)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIM 指令

SELECTCASE CFLAG:90:差し替え適用
	;替换用画像
	CASE 3
		IF CHECK_NUDE(CHARA)
			SELECTCASE 指令
				CASE 80
					RESULTS = 手交覆盖
				CASE 81
					RESULTS = 口交覆盖
				CASE 82
					RESULTS = 乳交覆盖
				CASE 85
					RESULTS = 足交覆盖
			ENDSELECT
		ELSE
			;服
			IF IS_BUNNY(CHARA)
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[白衣天使套]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[保健室的女教师套]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[生足美鈴套]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[危险野兽礼装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[不给治就捣蛋礼装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[皇家糖霜礼装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[辣妹系休闲套装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[魔法少女变装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 33
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || CURRENT_CLOTHES_SET(CHARA) == 28 || TEQUIP:CHARA:SWIMMING
			ELSEIF CHECK_CLO("bra_visible", CHARA)
			ELSE
				SELECTCASE 指令
					CASE 305
						RESULTS = 膝枕覆盖
					CASE 6,12,313
						RESULTS = 揉胸覆盖
				ENDSELECT
			ENDIF
		ENDIF
	CASEELSE
		;通常画像
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
ENDSELECT
