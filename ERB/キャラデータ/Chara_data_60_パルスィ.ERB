@CHARAMOVE_DATA_60(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 60
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;地霊殿には行かない
			CASE P901地霊殿前 TO P930旧血の池地獄, P947ちやりの棲み処
				RETURN -100
			;酒場と橋によく居る
			CASE P933酒場, P946橋
				RETURN 5
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 幻想風穴, 地獄的深道, 旧地獄街道
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
		;夜はたまに酒場
		SIF CFLAG:LOCAL:今日の運勢 % 8 == 0 && INRANGE(TIME, 1200, 1440)
			TCVAR:LOCAL:引力点 = P933酒場
ENDSELECT

@EXIST_キャラデータ60
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ60(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	CALLF MAKE_STR(V_NAME, "帕露西")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（裤子）套")

CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("靴", "鞋子"))
CASE "便装：襪子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("襪子", "袜子"))
CASE "便装：裙子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("裙子", "裙子"))
CASE "便装：上身衣服２"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("上身衣服２", "女式衬衫"))
CASE "便装：上身衣服１"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("上身衣服１", "上衣"))
CASE "便装：腕部装束"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("腕部装束", "臂套"))
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("其他１", "围巾"))
CASE "便装：其他２"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("其他２", "帯"))

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "非常暴露的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "丁字裤")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "细绳胸罩")
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[帕露西]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 0)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 1)

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "魚料理/和食/煮物/淡白/質素/上品/家庭的/软绵绵/地底風/辣/辣/咸/咸/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "简易/濃厚/甜/甜/酸/酸/謎料理/謎料理/謎料理/謎料理/謎料理/")
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "地底風/嫉妬/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "かわいい/時尚/和風/別緻/" + "緑/刃物/人形/" * 3 + "诅咒の/嫉妬の/樱花の/針/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "派手/ロリータ/威厳/マニアック/" + "背叛の/" * 10)

;農民関連
;はじかみ
;新鲜な緑やら食べた時のヒリヒリ感もなんとなくイメージに合うかな
CASE "農民：説明"
	CALLF MAKE_STR(V_NAME, "山椒農家")
CASE "農民：作物"
	CALLF MAKE_STR(V_NAME, "花椒")
CASE "農民：田的种类"
	CALLF MAKE_STR(V_NAME, "山椒畑")
CASE "農民：畑の所在地"
	CALLF MAKE_STR(V_NAME, "地底")

CASE "農民：MapID"
	CALLF MAKE_INT(V_NAME, 9)
CASE "農民：場所ID"
	CALLF MAKE_INT(V_NAME, 945)
CASE "農民：報酬"
	CALLF MAKE_INT(V_NAME, 400)
CASE "農民：金利"
	CALLF MAKE_INT(V_NAME, 8)
ENDSELECT

;-------------------------------------------------
;固有料理設定
;DISH_NAME          料理名
;RESULTS            料理の種類（軽食/主食/甜点）
;CALL 材料設定("")  材料の指定。"汎用"を入れると自動で汎用食材になる
;DISH_TASTE         味の設定
;DISH_COMMENT       （任意）一行コメント
;DISH_TIME          （任意）調理にかかる時間
;DISH_MAXLIMIT      （任意）料理の持続時間
;-------------------------------------------------
@SPECIAL_MENU_60
#LOCALSIZE 1
#LOCALSSIZE 1
DISH_NAME = 烤年糕
RESULTS = 主食
CALL 材料設定("汎用")
DISH_TASTE = 和食/米/咸/简易/淡白/温暖/春物/質素/家庭的/软糯的/嫉妬/
DISH_COMMENT = 用嫉妒之火烤制的普通年糕。要小心喂食对象的变化。
DISH_TIME = 10
RETURN 1

;IMAGE_I60_特殊服装(CHARA)-------------------------------------------------------------------
;角色特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I60_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS

SELECTCASE CFLAG:60:差し替え適用
CASE 2
	IF CHECK_NUDE(CHARA)
	ELSE
		IF CFLAG:CHARA:睡眠 || CFLAG:CHARA:陪睡中 || 睡眠時間(CHARA)
			RESULTS = _下着
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[忍者套]]
			RESULTS = _忍者
		ELSEIF IS_BUNNY(CHARA)
			RESULTS = _バニーギャル
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
			RESULTS = _セーラー服
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[晚宴礼服套装]]
			RESULTS = _ネロ
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[婚紗套]]
			RESULTS = _ネロブライド
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || CURRENT_CLOTHES_SET(CHARA) == 53 || TEQUIP:CHARA:SWIMMING
			RESULTS = _水着
		ELSEIF CHECK_CLO("bra_visible", CHARA)
			RESULTS = _下着
		ENDIF
	ENDIF
CASE 1
CASE 0
	;通常画像
	IF CHECK_NUDE(CHARA)
		;裸
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
	ELSE
		;服
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
	ENDIF
ENDSELECT

;IMAGE_I60_特殊表情(CHARA)--------------------------------------------------------------------
;角色特有の表情表示条件
;時間停止中でも維持する表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"通常","笑顔","憤怒","発情","睡眠"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I60_特殊表情(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA

SELECTCASE CFLAG:60:差し替え適用
CASE 2
	IF TALENT:CHARA:心情 == 1 || BASE:CHARA:情緒 > MAXBASE:CHARA:情緒 / 2 || TALENT:CHARA:恋慕
		IF RESULTS:0 == "通常"
			RESULTS:0 '= "微笑"
		ENDIF
		IF RESULTS:1 == "通常"
			RESULTS:1 '= "微笑"
		ENDIF
	ENDIF
CASE 1
CASE 0
	;通常画像
	IF CHECK_NUDE(CHARA)
		;裸
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
	ELSE
		;服
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
	ENDIF
ENDSELECT

;IMAGE_I60_特殊表情COM(CHARA, 指令)-------------------------------------------------------
;直前の指令で変化する角色特有の表情表示条件
;時間停止中は変化しない表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"自慰","愛撫","性交"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I60_特殊表情COM(CHARA, 指令)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIM 指令

SELECTCASE CFLAG:60:差し替え適用
CASE 2
	IF CHECK_NUDE(CHARA)
	ELSE
		IF CURRENT_CLOTHES_SET(CHARA) == [[忍者套]]
		ELSEIF IS_BUNNY(CHARA)
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[晚宴礼服套装]]
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[婚紗套]]
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || CURRENT_CLOTHES_SET(CHARA) == 53 || TEQUIP:CHARA:SWIMMING
		ELSEIF CHECK_CLO("bra_visible", CHARA)
		ELSE
			SELECTCASE 指令
				CASE 305
					IF IS_LOVER(CHARA)
						RESULTS = 膝枕2覆盖
					ELSE
						RESULTS = 膝枕覆盖
					ENDIF
				CASE 6,12,313
					RESULTS = 揉胸覆盖
			ENDSELECT
		ENDIF
	ENDIF
CASE 1
CASE 0
	;通常画像
	IF CHECK_NUDE(CHARA)
		;裸
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
	ELSE
		;服
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
	ENDIF
ENDSELECT
