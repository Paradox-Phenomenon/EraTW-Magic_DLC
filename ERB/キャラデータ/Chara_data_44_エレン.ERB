@CHARAMOVE_DATA_44(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 44
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;引きこもらない
			CASE P535艾伦宅・寝室
				RETURN -10
			;魔理沙家,愛麗絲家,妖怪的棲息処
			CASE P511魔理沙宅・居間 TO P515魔理沙宅・倉庫, P521人偶洋館・愛麗絲的房間 TO P531人偶洋館・空的部屋
				RETURN -100
			CASE P541朱鷺子的棲息処, P542莉格露的棲息処, P543露米娅的棲息処, P544成美の小屋
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 夢幻遺跡
				RETURN 1
			CASE 広場, 商家町, 呑屋小道, 長屋街
				RETURN 1
			CASE 霧之湖, 大図書館
				RETURN 1
			CASE 竹林入口, 迷失的小道, 斜角的竹林, 無名之丘, 太陽花田
				RETURN 1
			CASE 森林的入口, 香霖堂, 古木的大樹, 再思之道, 無縁塚
				RETURN 1
			CASE 魔界都市, 冰雪世界, 法界
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
		;平日15～19時は看店
		SIF YOUBI_MATCH(DAY, "月火水木金") && INRANGE(TIME, 900, 1140)
			TCVAR:LOCAL:引力点 = P534轻飘飘的艾伦魔法商店
ENDSELECT

@EXIST_キャラデータ44
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ44(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	CALLF MAKE_STR(V_NAME, "艾伦")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（睡袍）套")

CASE "便装：帽子"
	CALLF MAKE_INT(V_NAME, [[頭装備_蝴蝶结]])
CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, [[靴_鞋子]])
CASE "便装：襪子"
	CALLF MAKE_INT(V_NAME, [[襪子_袜子]])
CASE "便装：連衣裙"
	CALLF MAKE_INT(V_NAME, [[連衣裙_围裙洋装]])

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "非常蓬松的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "丝带灯笼裤")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "吊带背心")
CASE "固有内衣着用条件"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "卵/蘑菇/洋食/葉物/派/简易/健康/淡白/芸術的/新鲜/家庭的/软绵绵/赏月/甜/甜/甜/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "丰盛/濃厚/辣/辣/" + "青蛙/虫肉/怪诞/謎料理/" * 3)
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "得意料理＊软绵绵＊/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "黄/かわいい/ポップ/不思議/" + "月/魔法/" * 3 + "蓬蓬松松の/猫の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "パワフル/威厳/" + "妖術/护臂/機械/" * 3)
ENDSELECT

