@CHARAMOVE_DATA_128(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 128
SELECTCASE ARG
	;連動設定（参照する側＞RETURN=参照先, 参照される側＞RESULT:1～3=連動対象）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向
	CASE 4
		SELECTCASE ARG:2
			;八雲邸と彼岸から先は行かない（入り口部分は出る時用）
			CASE P604彼岸, P610是非曲直庁大堂 TO P655尤魔宅の風呂, P605地獄
				RETURN -100
			;瓔花的家には行かない
			CASE P609瓔花的家, P606日狭美の家, P607残無の家
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 広場, 商家町, 呑屋小道
				RETURN 1
			CASE 中有之道, 三途之川
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ128
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ128(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	CALLF MAKE_STR(V_NAME, "潤美")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（裤子）套")

CASE "便装：上身衣服２"
	CALLF MAKE_INT(V_NAME, [[上身衣服_はだけ可能_无袖服]])
CASE "便装：外搭"
	CALLF MAKE_INT(V_NAME, [[外搭_羽织]])
CASE "便装：裤子"
	CALLF MAKE_INT(V_NAME, [[裤子_短裤]])
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, [[其他衣装_石像]])

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "田园风的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "牛图案胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "牛图案胸罩")
CASE "固有内衣着用条件"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)

CASE "固有指令"
	IF 成人再教育插件开关 == 1
		CALLF MAKE_STR(V_NAME, "与润美对话")
	ELSE
		CALLF MAKE_STR(V_NAME, "鱼的交换")
	ENDIF
CASE "固有指令実行可能"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有指令：鱼的交换比率"
	CALLF MAKE_INT(V_NAME, MAX(5, 10 - ABL:[[潤美]]:親密))

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "魚料理/虫肉/煮物/下酒菜/丰盛/豪華/野趣/家庭的/サクサク/辣/辣/咸/咸/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "酸/酸/青蛙/青蛙/青蛙/小人族秘伝の味/小人族秘伝の味/小人族秘伝の味/")
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "冥界風/得意料理＊魚＊/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "茶/かわいい/シンプル/別緻/" + "魚/人形/鬼の/" * 3 + "石の/深海魚の/古代魚の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "ポップ/派手/ロリータ/マニアック/")
ENDSELECT

