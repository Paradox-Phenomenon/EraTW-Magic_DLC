;IMAGE_I128_特殊服装(CHARA)-------------------------------------------------------------------
;キャラクター特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I128_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS

IF CFLAG:128:差し替え適用 == 2
	IF CHECK_NUDE(CHARA)
	ELSE
		IF CFLAG:CHARA:睡眠 || CFLAG:CHARA:陪睡中 || 睡眠時間(CHARA)
			RESULTS = _下着
		ELSEIF IS_BUNNY(CHARA)
			RESULTS = _バニーギャル
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[白衣天使套]]
			RESULTS = _ナース
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[啦啦队制服]]
			RESULTS = _チアリーダー
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
			RESULTS = _セーラー服
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[修女服]]
			RESULTS = _シスター
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[女僕装]]
			RESULTS = _メイド
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[巫女装束]]
			RESULTS = _巫女
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[忍者套]]
			RESULTS = _忍者
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[辣妹系休闲套装]]
			RESULTS = _私服
		ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[Y字泳衣]]
			RESULTS = _水着
		ELSEIF CHECK_CLO("bra_visible", CHARA)
			RESULTS = _下着
		ENDIF
	ENDIF
ELSEIF CFLAG:128:差し替え適用 == 1
	;差し替え画像
ELSE
	;通常画像
ENDIF

;IMAGE_I128_特殊表情(CHARA)--------------------------------------------------------------------
;キャラクター特有の表情表示条件
;時間停止中でも維持する表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"通常","笑顔","憤怒","発情","睡眠"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I128_特殊表情(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
IF CFLAG:128:差し替え適用 == 2
ELSEIF CFLAG:128:差し替え適用 == 1
	;差し替え画像
ELSE
	;通常画像
ENDIF

;IMAGE_I128_特殊表情COM(CHARA, 指令)-------------------------------------------------------
;直前の指令で変化する角色特有の表情表示条件
;時間停止中は変化しない表情はこちら
;使用時注意点:
;   RESULTS:0に表情を格納
;   RESULTS:1にマウスオーバー時の表情を格納すること
;   "自慰","愛撫","性交"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I128_特殊表情COM(CHARA, 指令)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIM 指令

SELECTCASE CFLAG:128:差し替え適用
	;替换用画像
	CASE 2
		IF CHECK_NUDE(CHARA)
		ELSE
			;服
			IF IS_BUNNY(CHARA)
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[白衣天使套]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[啦啦队制服]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[修女服]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[女僕装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[巫女装束]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[忍者套]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[辣妹系休闲套装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[Y字泳衣]]
			ELSEIF CHECK_CLO("bra_visible", CHARA)
			ELSE
				SELECTCASE 指令
					CASE 305
						RESULTS = 膝枕覆盖
					CASE 6,12,313
						RESULTS = 揉胸覆盖
				ENDSELECT
			ENDIF
		ENDIF
	CASEELSE
		;通常画像
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
ENDSELECT

;IMAGE_I128_特殊エフェクトチェック(CHAR, エフェクト)--------------------------------------------
;角色特有のエフェクト判定  特殊エフェクトを直接指定したい場合に参照
;引数 "エフェクト" に固有のエフェクトが含まれるかを判定する
;例の街道、STRFINDを使用してください
;-------------------------------------------------------------------------------------------
@IMAGE_I128_特殊エフェクトチェック(CHARA, エフェクト)
#DIM CHARA
#DIMS エフェクト

IF CFLAG:128:差し替え適用
	;替换用画像
ELSE
	;通常画像
	SIF STRFIND(エフェクト, "母乳") != -1
		RETURN 1
ENDIF

RETURN 0


;IMAGE_I128_特殊エフェクト(CHARA)--------------------------------------------------------------------
;角色特有のエフェクト表示条件
;使用時注意点:
;	RESULTS配列に特殊エフェクトを格納
;	RETURNで追加するエフェクト数を返却すること
;-------------------------------------------------------------------------------------------
@IMAGE_I128_特殊エフェクト(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIM DYNAMIC エフェクト数 = 0
VARSET RESULTS

IF CFLAG:128:差し替え適用
	;替换用画像
	IF FLAG:立絵種類
		;顔絵
	ELSE
		;立絵
	ENDIF
ELSE
	;通常画像
	IF FLAG:立絵種類
		;顔絵
		IF TALENT:CHARA:母乳体質 && NOWEX:CHARA:噴乳 && CHECK_NUDE(CHARA)
			IF FLAG:巨乳差分表示 && TALENT:CHARA:胸围>=2
				RESULTS:エフェクト数 = 爆乳母乳
			ELSE
				RESULTS:エフェクト数 = 母乳
			ENDIF
			エフェクト数 += 1
		ENDIF
	ELSE
		;立絵
	ENDIF
ENDIF

RETURN エフェクト数