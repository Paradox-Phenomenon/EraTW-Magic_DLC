CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "野趣/咸/咸/" + "青蛙/虫肉/香料/" * 3 + "謎料理/" * 5)
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "夢幻風/女僕流/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "青/混沌/かわいい/洋風/別緻/威厳/" + "妖術/禁断の/" * 3 + "女僕的/夢幻の/悪魔の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "秩序/和風/派手/" + "神霊/" * 3)
ENDSELECT

