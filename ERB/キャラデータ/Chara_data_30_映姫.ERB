;-------------------------------------------------
;斗虫の切り札設定
;ムシ番号,ランク,Ｇ型,Ｘ型の４つをカスタム可
;-------------------------------------------------
@MUSHI_KIRIHUDA_30
;Buff盛り盛り大王虎甲orやる気のない死神螳螂
IF RAND:2
	;ムシ番号
	RESULT = 64
	;ランク
	MUSHI_RANK = 99
	;Ｇ型
	RESULT:1 = 1
	;Ｘ型
	RESULT:2 = 1
ELSE
	;ムシ番号
	RESULT = 318
	;ランク
	MUSHI_RANK = 0
	;Ｇ型
	RESULT:1 = 0
	;Ｘ型
	RESULT:2 = 0
ENDIF
RETURN RESULT

