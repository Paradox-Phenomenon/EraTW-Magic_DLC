@CHARAMOVE_DATA_30(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 30
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;小町の私室はあまり入らない
			CASE P616小町的房間
				RETURN -5
			;八雲邸、畜生界は行かない
			CASE P630八雲邸玄関 TO P655尤魔宅の風呂
				RETURN -100
			;他人的家、他宅の私室等には入らない
			CASE P608潤美的家, P609瓔花的家, P623幽幽子私室, P624妖夢私室, P627風呂, P606日狭美の家, P607残無の家
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 地蔵小路, 倒垂的柳樹下, 命蓮寺境内
				RETURN 1
			CASE 広場, 商家町, 呑屋小道, 長屋街
				RETURN 1
			CASE 中有之道, 三途之川, 彼岸, 白玉楼庭, 白玉楼, 地獄
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT
@EXIST_キャラデータ30
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ30(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	CALLF MAKE_STR(V_NAME, "映姫")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（襦袢）套")
CASE "特殊衣装着用"
	;毎週金曜日はカジュアルデー
	SIF YOUBI_MATCH(DAY, "金")
		CALLF MAKE_INT(V_NAME, 62)
CASE "便装：帽子"
	CALLF MAKE_INT(V_NAME, [[頭装備_帽子]])
CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, [[靴_鞋子]])
CASE "便装：襪子"
	CALLF MAKE_INT(V_NAME, [[襪子_袜子]])
CASE "便装：裙子"
	CALLF MAKE_INT(V_NAME, [[裙子_裙子]])
CASE "便装：上身衣服２"
	CALLF MAKE_INT(V_NAME, [[上身衣服_はだけ可能_女式衬衫]])
CASE "便装：外搭"
	CALLF MAKE_INT(V_NAME, [[外搭_背心]])
CASE "便装：飾品"
	CALLF MAKE_INT(V_NAME, [[飾品_悔悟棒]])

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "穿旧了的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "棉布胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "棉布胸罩")
CASE "固有内衣着用条件"
	SIF !RAND:(1 + (2 * 勝負内衣判定([[映姫]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "野菜/麺類/中華/和食/软糯的/温暖/質素/冥界風/甜/酸/" + "香料/" * 3 + "辣/" * 5)
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "魔力/霊障/咸/咸/" + "青蛙/虫肉/ジャンキー/外界風/化学的/" * 3 + "謎料理/" * 5)
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "冥界風/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "白/黒/秩序/かわいい/シンプル/別緻/" + "死生/法具/" * 3 + "四季の/彼岸の/救世の/手板/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "灰/混沌/派手/ロリータ/マニアック/" + "生体品/护臂/" * 3)

;農民関連
;白黒で思い浮かんだのがこれ
;報酬は多めにくれる
;立地が人里なのは三途之川をうろつくのはやめなさいという心遣い
CASE "農民：説明"
	CALLF MAKE_STR(V_NAME, "胡麻農家")
CASE "農民：作物"
	CALLF MAKE_STR(V_NAME, "芝麻")
CASE "農民：田的种类"
	CALLF MAKE_STR(V_NAME, "胡麻畑")
CASE "農民：畑の所在地"
	CALLF MAKE_STR(V_NAME, "人里")

CASE "農民：MapID"
	CALLF MAKE_INT(V_NAME, 2)
CASE "農民：場所ID"
	CALLF MAKE_INT(V_NAME, 204)
CASE "農民：報酬"
	CALLF MAKE_INT(V_NAME, 450)
CASE "農民：金利"
	CALLF MAKE_INT(V_NAME, 2)

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	CALLF MAKE_INT(V_NAME, 2)
CASE "一般依頼発生率"
	CALLF MAKE_INT(V_NAME, 3)
CASE "固有依頼発生率"
	CALLF MAKE_INT(V_NAME, 5)
CASE "固有依頼最終要素"
	CALLF MAKE_INT(V_NAME, 101)
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		CALLF F固有依頼30(ARG, O_DATA, V_NAME)
ENDSELECT

