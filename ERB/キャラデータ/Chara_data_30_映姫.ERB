;IMAGE_I30_特殊服装(CHARA)-------------------------------------------------------------------
;角色特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I30_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS

IF CFLAG:30:差し替え適用 == 3
	IF CHECK_NUDE(CHARA)
		;裸
	ELSEIF CURRENT_CLOTHES_SET(CHARA) == 62
		;服
		RESULTS = _変Ｔ
	ENDIF
ELSEIF CFLAG:30:差し替え適用 == 1
	;替换用画像
	IF CHECK_NUDE(CHARA)
		;裸
		SIF BATHROBE_SWITCH && BATHROOM() && !CFLAG:诶嘿嘿
			RESULTS = _浴袍
	ELSE
		;服
		SELECTCASE NUDITYCHECK(CHARA)
			CASE 1
				RESULTS = _%\@ FLAG:立絵種類 ? 半裸 # パンイチ \@%
			CASE 2
				RESULTS = _%\@ FLAG:立絵種類 ? 内衣 # ブラ \@%
			CASE 3
				RESULTS = _下着
			CASEELSE
				IF (BETWEENTIME(CFLAG:CHARA:就寝時間 - 90, CFLAG:CHARA:起床時間 + 30) && CFLAG:CHARA:現在位置 ==  CFLAG:CHARA:初期位置) || CFLAG:CHARA:睡眠
					RESULTS = _パジャマ
					;超棒的Ｔ恤衬衫套からは、おはようからおやすみまで逃げられない
					SIF (BETWEENTIME(CFLAG:CHARA:起床時間, CFLAG:CHARA:就寝時間) && CFLAG:現在位置 == CFLAG:CHARA:初期位置) && !CFLAG:CHARA:睡眠 && CURRENT_CLOTHES_SET(CHARA) == 62
						RESULTS = _変Ｔ
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 62
					RESULTS = _変Ｔ
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
					RESULTS = _セーラー
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 17 || DAY:3 == 28
					RESULTS = _うさぎ
				ENDIF
		ENDSELECT
	ENDIF
ELSEIF CFLAG:30:差し替え適用 == 0
	;通常画像
	IF CHECK_NUDE(CHARA)
		;裸
		SIF BATHROBE_SWITCH && BATHROOM() && !CFLAG:诶嘿嘿
			RESULTS = _浴袍
	ELSEIF CURRENT_CLOTHES_SET(CHARA) == 62
		;服
		RESULTS = _変Ｔ
	ENDIF
ENDIF

