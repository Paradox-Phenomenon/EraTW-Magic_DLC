@CHARAMOVE_DATA_163(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 163
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
		;たまに連動
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;山
			;私室には入らない
			CASE P704河童のアジト, P706厄神の家, P709リリーたちの家, P716秋姉妹の家・土間 TO P730仙人の屋敷・庭
				RETURN -100
			CASE P733正邪の隠れ家, P736山姥の家, P737招き猫の家, P740山童のアジト,P742美天居所
				RETURN -100
			;竹林
			CASE P432影狼の家, P437メディスンの家, P439ラルバの家, P443ミスティアの家, P445妹紅の家
				RETURN -100
			;永遠亭の奥には行かない
			CASE P405調剤室, P407廊下 TO P430地下室
				RETURN -100
			;夢幻館には行かない
			CASE P450玄関 TO P466庭
				RETURN -100
			CASE P433斜角の竹林, P434迷いの小道, P444夜雀の屋台, P447竹林入口
				RETURN 1
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 広場, 商家町, 呑屋小道, 寺子屋, 長屋街
				RETURN 1
			CASE 山麓樹海, 玄武之澤, 大蛤蟆之池, 森の深奥, 圣域, 浅间净秽山
				RETURN 1
			CASE 竹林入り口, 迷いの小道, 斜角の竹林, 兎の洞穴, 永遠亭, 無名の丘, 太陽の畑
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ163
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ163(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	CALLF MAKE_STR(V_NAME, "驯子")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（吊带睡裙）套")
	
CASE "便装：裤子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("裤子", "探险短裤"))
CASE "便装：上身衣服２"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("上身衣服２", "探险夹克"))
CASE "便装：帽子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("帽子", "金饰发箍"))
CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("靴", "靴子"))
CASE "便装：襪子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("襪子", "长筒袜"))
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("其他１", "金权杖"))
CASE "便装：其他２"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("其他２", "耳环"))

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "荷鲁斯之眼刺绣的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "素色亚麻胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "素色亚麻胸罩")
CASE "固有内衣着用条件"
	;也是必穿
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)

;料理関連
;彼女の謎は正解あるから、謎料理より隠し味がすきそう
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "隠し味/" * 3 + "洋食/外界風/ジャンキー/サクサク/怪诞/辣/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "科学的/化学的/" * 5 + "淡白/" * 3 + "和食/简易/健康/")
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "隠し味/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "モダンな/杖/青/金/マニアック/" + "守護の/知恵の/千年の/異国風の/砂漠の/守護石/ピラミッド/" * 3 + "謎の/エニグマティクな/神秘的/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "和風/灰/シンプル/可怕的/" + "封印されし/禁忌の/境界の/" * 3 )
ENDSELECT

