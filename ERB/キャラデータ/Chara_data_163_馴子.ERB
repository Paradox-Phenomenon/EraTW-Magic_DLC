;IMAGE_I163_特殊服装(CHARA)-------------------------------------------------------------------
;角色特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I163_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS
SELECTCASE CFLAG:163:差し替え適用
	CASE 1
	CASE 0
		IF CHECK_NUDE(CHARA)
		ELSE
			IF IS_BUNNY(CHARA)
				RESULTS = _兔女郎
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
				RESULTS = _水手服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 33
				RESULTS = _睡裙
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[巫女装束]]
				RESULTS = _巫女服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[晚宴礼服套装]]
				RESULTS = _晚礼服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || CURRENT_CLOTHES_SET(CHARA) == 53 || TEQUIP:CHARA:SWIMMING
				RESULTS = _泳衣
			ELSEIF CHECK_CLO("bra_visible", CHARA)
				RESULTS = _内衣
			ENDIF
		ENDIF
ENDSELECT

@IMAGE_I163_特殊表情(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
SELECTCASE CFLAG:163:差し替え適用
	CASE 1
	CASE 0
		IF TALENT:CHARA:心情 == 1 || BASE:CHARA:情緒 > MAXBASE:CHARA:情緒 / 2 || TALENT:CHARA:恋慕
			IF RESULTS:0 == "通常"
				RESULTS:0 '= "笑顔2"
			ENDIF
			IF RESULTS:1 == "通常"
				RESULTS:1 '= "笑顔2"
			ENDIF
		ENDIF
ENDSELECT
