;IMAGE_I15_特殊服装(CHARA)-------------------------------------------------------------------
;角色特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I15_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS
SELECTCASE CFLAG:15:差し替え適用
	CASE 2
		IF CHECK_NUDE(CHARA)
		;裸
			IF GROUPMATCH(1, TEQUIP:CHARA:新妻PLAY)
				RESULTS = _裸エプロン
			ENDIF
		ELSE
		;服
			IF CURRENT_CLOTHES_SET(CHARA) == 33
				RESULTS = _パジャマ
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[忍者套]]
				RESULTS = _女忍
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[暗杀者套装]]
				RESULTS = _杰克
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[忍者套]]
				RESULTS = _暗杀者套装
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[黑暗系休闲套装]]
				RESULTS = _私服2
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[哥特洛丽塔套装]]
				RESULTS = _ゴシック
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[辣妹系休闲套装]]
				RESULTS = _私服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[迪奥套装]]
				RESULTS = _Dio
			ELSEIF IS_BUNNY(CHARA)
				RESULTS = _バニーギャル
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
				RESULTS = _暁美ほむら
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 61
				RESULTS = _ウェディングドレス
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || TEQUIP:CHARA:SWIMMING
				RESULTS = _水着
			ELSEIF CHECK_CLO("bra_visible", CHARA) && GROUPMATCH(1, TEQUIP:CHARA:新妻PLAY)
				RESULTS = _裸エプロン
			ELSEIF CHECK_CLO("bra_visible", CHARA)
				RESULTS = _下着
			ELSEIF ABL:CHARA:亲密 > 14
				RESULTS = _高好感
			ENDIF
		ENDIF
	CASE 3
		IF CHECK_NUDE(CHARA)
			;裸
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立ち絵
			ENDIF
		ELSE
			;服
			IF FLAG:立絵種類
				;顔絵
				IF CHECK_CLO("bra_visible", CHARA)
					RESULTS = _下着
				ELSEIF IS_BUNNY(CHARA)
					RESULTS = _バニー
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 62
					RESULTS = _変T
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
					RESULTS = _セーラー
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[外出女仆套装]]
					RESULTS = _人里
				ENDIF
			ELSE
				;立ち絵
				IF CHECK_CLO("bra_visible", CHARA) && EQUIP:CHARA:下半身下着２ != 0
					RESULTS = _下着
				ELSEIF CHECK_CLO("bra_visible", CHARA) && EQUIP:CHARA:下半身下着２ == 0
					RESULTS = _ノーパン下着
				{
				ELSEIF (!EQUIP:CHARA:上半身上着１ && !EQUIP:CHARA:上半身上着２ && !EQUIP:CHARA:外搭 &&
						!EQUIP:CHARA:和服 && !EQUIP:CHARA:連衣裙 &&
						!EQUIP:CHARA:レオタード && !EQUIP:CHARA:ボディースーツ) &&
						EQUIP:CHARA:下半身内衣２ != 0
				}
					RESULTS = _ノーブラ下着
				ELSEIF IS_BUNNY(CHARA)
					RESULTS = _バニー
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 62
					RESULTS = _変T
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
					RESULTS = _セーラー
				ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[外出女仆套装]]
					RESULTS = _人里
				ENDIF
			ENDIF
		ENDIF
	CASE 4
	CASE 5
		IF CHECK_NUDE(CHARA)
		ELSE
		;服
			IF CHECK_CLO("bra_visible", CHARA) || CURRENT_CLOTHES_SET(CHARA) == 33
				IF TALENT:CHARA:3 || TALENT:CHARA:7 == 1 || TALENT:CHARA:184 == 1
					IF DAY:0 % 2 || TCVAR:CHARA:142 == 1
						RESULTS = _黑内衣
					ELSE
						RESULTS = _白内衣
					ENDIF
				ELSE
					RESULTS = _白内衣
				ENDIF
			ELSEIF IS_BUNNY(CHARA)
				RESULTS = _兔女郎
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
				RESULTS = _水手服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[晚宴礼服套装]]
				RESULTS = _礼服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[外出女仆套装]]
				RESULTS = _人里
			ELSEIF DAY:0 % 2
				RESULTS = _轮换
			ENDIF
		ENDIF
	CASE 0
	;通常画像
		IF CHECK_NUDE(CHARA)
			;裸
			IF FLAG:立絵種類
				;顔絵
				SIF BATHROBE_SWITCH && BATHROOM() && !CFLAG:诶嘿嘿
					RESULTS = _浴袍
			ELSE
				;立ち絵
				SIF BATHROBE_SWITCH && BATHROOM() && !CFLAG:诶嘿嘿
					RESULTS = _浴袍
			ENDIF
		ELSE
			;服
			IF FLAG:立絵種類
				;顔絵
			ELSE
				;立ち絵
			ENDIF
		ENDIF
ENDSELECT

