@CHARAMOVE_DATA_15(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 15
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
		SIF GET_MAPID(CFLAG:[[レミリア]]:遭遇位置) != MAP湖
			RETURN [[レミリア]]
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;仓库には入らない、屋敷外には出ない
			CASE P305仓库, P334廃洋館・入口 TO P348霧之湖・湖底
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 桜花道的鳥居, 神社境内, 神社走廊
				RETURN 1
			CASE 広場, 商家町, 呑屋小道, 長屋街
				RETURN 1
			CASE 霧之湖, 正門, 大廳, 食堂, 大図書館, 地下室
				RETURN 1
			CASE 森林的入口, 香霖堂, 霧雨魔法店, 人偶的洋館
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ15
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ15(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	CALLF MAKE_STR(V_NAME, "咲夜")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（吊带睡裙）套")
CASE "便装：帽子"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("帽子", "女仆发箍"))
CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("靴", "鞋子"))
CASE "便装：襪子"
	IF FLAG:2 > 0
		CALLF MAKE_INT(V_NAME, CLOTHES_ID("襪子", "吊带袜"))
	ELSE
		CALLF MAKE_INT(V_NAME, CLOTHES_ID("襪子", "长筒袜"))
	ENDIF
CASE "便装：連衣裙"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("連衣裙", "围裙洋装"))
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("其他１", "蝴蝶结"))
CASE "便装：其他２"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("其他２", "小刀"))

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "带吊带的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "高级丝绸胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "高级丝绸胸罩")
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[咲夜]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)
;特殊衣装
CASE "デート衣装", "人里デート衣装", "おうちデート衣装"
	CALLF MAKE_INT(V_NAME, [[外出女仆套装]])

CASE "固有指令"
	CALLF MAKE_STR(V_NAME, "红魔馆出差服务")
CASE "固有指令実行可能"
	IF TFLAG:上门清扫 && (FLAG:澆水代行 || !ITEM:150)
	ELSEIF MAIN_MAP == MAP湖
	ELSE
		CALLF MAKE_INT(V_NAME, 1)
	ENDIF

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "魚料理/香料/中華/煮物/甜/淡白/豪華/上品/家庭的/サクサク/絢爛/" + "酸/" * 3)
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "質素/野趣/咸/咸/虫肉/虫肉/虫肉/謎料理/謎料理/謎料理/謎料理/謎料理/")
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "隠し味/秘術/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "青/美的/シンプル/洋風/別緻/" + "钟表/食器/" * 3 + "瀟洒な/女僕的/時の/時空の/怀表/小刀/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "パワフル/ロリータ/" + "烟袋/" * 3)

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	CALLF MAKE_INT(V_NAME, 2)
CASE "一般依頼発生率"
	CALLF MAKE_INT(V_NAME, 3)
CASE "固有依頼発生率"
	CALLF MAKE_INT(V_NAME, 5)
CASE "固有依頼最終要素"
	CALLF MAKE_INT(V_NAME, 101)
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		CALLF 固有依頼15(ARG, O_DATA, V_NAME)
ENDSELECT

