;IMAGE_I15_特殊表情(CHARA)--------------------------------------------------------------------
;キャラクター特有の表情表示条件
;時間停止中でも維持する表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"通常","笑顔","憤怒","発情","睡眠"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I15_特殊表情(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
SELECTCASE CFLAG:15:差し替え適用
	CASE 2
		IF TALENT:CHARA:恋慕 && !MARK:CHARA:反発刻印 && TALENT:CHARA:機嫌 >= 0
			SIF RESULTS:0 == "通常"
				RESULTS:0 = 微笑
			SIF RESULTS:1 == "通常"
				RESULTS:1 = 微笑
		ENDIF
	CASE 3
	CASE 4
	CASE 5
	CASE 0
ENDSELECT

;IMAGE_I15_特殊表情COM(CHARA, コマンド)-------------------------------------------------------
;直前のコマンドで変化するキャラクター特有の表情表示条件
;時間停止中は変化しない表情はこちら
;使用時注意点:
;	RESULTS:0に表情を格納
;	RESULTS:1にマウスオーバー時の表情を格納すること
;	"オナニー","愛撫","性交"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I15_特殊表情COM(CHARA, コマンド)
#DIM CHARA
#DIM コマンド

SELECTCASE CFLAG:15:差し替え適用
	;替换用画像
	CASE 2
		IF CHECK_NUDE(CHARA)
		ELSE
			IF CURRENT_CLOTHES_SET(CHARA) == 33
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[忍者套]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[暗杀者套装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[忍者套]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[黑暗系休闲套装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[哥特洛丽塔套装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[辣妹系休闲套装]]
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[迪奥套装]]
			ELSEIF IS_BUNNY(CHARA)
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 61
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || TEQUIP:CHARA:SWIMMING
			ELSEIF CHECK_CLO("bra_visible", CHARA) && GROUPMATCH(1, TEQUIP:CHARA:新妻PLAY)
			ELSEIF CHECK_CLO("bra_visible", CHARA)
			ELSE
				SELECTCASE コマンド
					CASE 305
						RESULTS = 膝枕覆盖
					CASE 6,12,313
						IF ABL:CHARA:露出癖 > 5 && ABL:CHARA:亲密 > 9
							RESULTS = 揉胸2覆盖
						ELSE
							RESULTS = 揉胸覆盖
						ENDIF
				ENDSELECT
			ENDIF
		ENDIF
	CASEELSE
		;通常画像
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
ENDSELECT

