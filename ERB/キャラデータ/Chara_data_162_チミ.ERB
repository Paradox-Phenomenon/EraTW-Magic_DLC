@CHARAMOVE_DATA_162(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 162
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
		;たまに連動
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;神社
			;私室には入らない
			CASE P6物置, P15霊夢私室, P17小さい納戸, P18押入れ, P19大きい納戸, P52離れ, P53納戸, P55和室, P56あうんの棲家
				RETURN -100
			;三妖精の家、夢幻遺跡NG
			CASE P27三妖精の家・広間 TO P35三妖精の家・地下室
				RETURN -100
			CASE P36夢幻遺跡前 TO P51夢幻遺跡・倉庫
				RETURN -100
			;寺
			;私室には入らない
			CASE P113ナズーリン私室, P114ムラサ私室, P115星私室, P116一輪私室, P118白蓮私室, P109女苑私室, P136響子私室, P137マミゾウの棲家
				RETURN -100
			;離れには入らない,神霊廟内部は行かない
			CASE P119離れ, P125屠自古私室 TO P134蔵, P138鐘楼, P139邪仙楼
				RETURN -100
			;山
			;私室には入らない
			CASE P704河童のアジト, P706厄神の家, P709リリーたちの家, P716秋姉妹の家・土間 TO P730仙人の屋敷・庭
				RETURN -100
			CASE P733正邪の隠れ家, P736山姥の家, P737招き猫の家, P740山童のアジト,P742美天居所
				RETURN -100
			;竹林
			CASE P432影狼の家, P437メディスンの家, P439ラルバの家, P443ミスティアの家, P445妹紅の家
				RETURN -100
			;永遠亭の奥には行かない
			CASE P405調剤室, P407廊下 TO P430地下室
				RETURN -100
			;夢幻館には行かない
			CASE P450玄関 TO P466庭
				RETURN -100
			CASE P433斜角の竹林, P434迷いの小道, P444夜雀の屋台, P447竹林入口
				RETURN 1
			;森
			CASE P512魔理沙宅・寝室, P522人形の館・神綺の部屋, P523人形の館・夢子の部屋, P526人形の館・風呂, P531人形の館・空き部屋
				RETURN -100
			CASE P535エレン宅・寝室, P537エレン宅・風呂, P541朱鷺子の棲み処, P542リグルの棲み処, P543ルーミアの棲み処, P544成美の小屋, P545慧ノ子の棲み処
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 山麓樹海, 玄武之澤, 大蛤蟆之池, 森の深奥, 圣域, 浅间净秽山
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ162
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ162(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	CALLF MAKE_STR(V_NAME, "魑魅")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（吊带睡裙）套")
	
CASE "便装：外搭"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("外搭", "树叶蓑衣"))
CASE "便装：連衣裙"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("連衣裙", "連衣裙"))
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, CLOTHES_ID("其他１", "围巾"))

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "马赛克模糊的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "漩涡胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "漩涡胸罩")
CASE "固有内衣着用条件"
	SIF !RAND:3
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 0)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 0)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 3)

;料理関連
;鮮やかで自然に親しいぬえ
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "甜/野趣/果物/謎料理/" * 3 + "新鲜/酸/" * 2 + "野菜/怪诞/滑溜溜/淡白/妖力/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "科学的/化学的/" * 5 + "辣/ジャンキー/" * 3 + "機能的/" * 2)
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "未知の味/妖力/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "混沌/古の/可怕的/奇妙/不思議/葉っぱの/" + "森の/水の/妖術/自然/うずまきの/" * 3 + "謎の/正体不明の/幻獣の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "秩序/洋風/ポップ/知的/" + "モダンな/金属/" * 3 + "真実の/" * 10)
ENDSELECT

;-------------------------------------------------
;固有料理設定
;DISH_NAME          料理名
;RESULTS            料理の種類（軽食/主食/甜点）
;CALL 材料設定("")  材料の指定。"汎用"を入れると自動で汎用食材になる
;DISH_TASTE         味の設定
;DISH_COMMENT       （任意）一行コメント
;DISH_TIME          （任意）調理にかかる時間
;DISH_MAXLIMIT      （任意）料理の持続時間
;-------------------------------------------------
[SKIPSTART]
@SPECIAL_MENU_162
#LOCALSIZE 1
#LOCALSSIZE 1
DISH_NAME = 圣餐饼
RESULTS = 甜点
CALL 材料設定("汎用")
DISH_TASTE = 洋食/简易/家庭的/芸術的/マニアック/
DISH_COMMENT = 一种轻薄的米饼，常被象征为‘基督的身体’。 
RETURN 1
[SKIPEND]
;IMAGE_I162_特殊服装(CHARA)-------------------------------------------------------------------
;角色特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I162_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS
SELECTCASE CFLAG:162:差し替え適用
	CASE 1
	CASE 0
		IF CHECK_NUDE(CHARA)
		ELSE
			IF IS_BUNNY(CHARA)
				RESULTS = _兔女郎
			ELSEIF IS_SCHOOLUNIFORM(CHARA)
				RESULTS = _制服
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 33
				RESULTS = _睡裙
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[危险野兽礼装]]
				RESULTS = _危险野兽
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[死库水泳衣]]
				RESULTS = _学校泳装
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[超棒的Ｔ恤衬衫套]]
				RESULTS = _怪T
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[猿神装扮]]
				RESULTS = _虎皮短裙
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == [[浴衣穿搭]]
				RESULTS = _浴衣
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 52 || CURRENT_CLOTHES_SET(CHARA) == 53
				RESULTS = _比基尼
			ELSEIF TEQUIP:CHARA:SWIMMING
				SELECTCASE RAND:3
					CASE 2
						RESULTS = _比基尼
					CASE 1
						RESULTS = _内衣
					CASE 0
						RESULTS = _学校泳装
				ENDSELECT
			ELSEIF CHECK_CLO("bra_visible", CHARA)
				RESULTS = _内衣
			ENDIF
		ENDIF
ENDSELECT
