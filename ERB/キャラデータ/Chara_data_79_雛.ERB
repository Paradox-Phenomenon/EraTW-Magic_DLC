@CHARAMOVE_DATA_79(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 79
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;私室には入らない
			CASE P704河童の宣傳站, P706厄神的家, P716秋姉妹的家・土間 TO P730仙人的宅邸・庭
				RETURN -100
			CASE P733正邪的隠匿処, P744合欢宅邸, P737招财猫的家, P740山童の宣傳站, P742美天居所
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 森林的入口, 香霖堂, 古木的大樹, 再思之道, 無縁塚
				RETURN 1
			CASE 中有之道, 三途之川
				RETURN 1
			CASE 山麓樹海, 玄武之澤, 大蛤蟆之池
				RETURN 1
			CASE 九天瀑布, 絶景之丘, 山之湖, 守矢神社境内
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ79
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ79(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	CALLF MAKE_STR(V_NAME, "雛")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（裤子）套")

CASE "便装：帽子"
	CALLF MAKE_INT(V_NAME, [[頭装備_蝴蝶结]])
CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, [[靴_鞋子]])
CASE "便装：襪子"
	CALLF MAKE_INT(V_NAME, [[襪子_袜子]])
CASE "便装：連衣裙"
	CALLF MAKE_INT(V_NAME, [[連衣裙_哥特洛丽塔裙]])
CASE "便装：腕部装束"
	CALLF MAKE_INT(V_NAME, [[腕部装束_蝴蝶结]])

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "墨绿色的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "哥特内裤")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "哥特胸罩")
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[雛]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)
CASE "デート衣装", "人里デート衣装", "おうちデート衣装"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[雛]])))
		CALLF MAKE_INT(V_NAME, 23)

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "野菜/汁物/甜/淡白/質素/新鲜/家庭的/黏稠/妖力/酸/酸/酸/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "丰盛/濃厚/辣/辣/豪華/豪華/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/")
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "隠し味/得意料理＊家庭的＊/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "赤/黒/美的/芸術的/別緻/" + "闇/妖術/护符/" * 3 + "厄の/不吉の/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "パワフル/威厳/" + "光/护臂/" * 3)

;農民関連
;服の模様に似ている＆山で生えてそう
;あまり裕福なイメージはない
CASE "農民：説明"
	CALLF MAKE_STR(V_NAME, "山菜農家")
CASE "農民：作物"
	CALLF MAKE_STR(V_NAME, "薇菜")
CASE "農民：田的种类"
	CALLF MAKE_STR(V_NAME, "薇菜畑")
CASE "農民：畑の所在地"
	CALLF MAKE_STR(V_NAME, "妖怪之山·山麓")

CASE "農民：MapID"
	CALLF MAKE_INT(V_NAME, 7)
CASE "農民：場所ID"
	CALLF MAKE_INT(V_NAME, 705)
CASE "農民：報酬"
	CALLF MAKE_INT(V_NAME, 350)
CASE "農民：金利"
	CALLF MAKE_INT(V_NAME, 3)

;ここは依頼IDが関連しない情報
;依頼発生率スカ2/一般3/固有5
CASE "没有依頼発生率"
	CALLF MAKE_INT(V_NAME, 2)
CASE "一般依頼発生率"
	CALLF MAKE_INT(V_NAME, 3)
CASE "固有依頼発生率"
	CALLF MAKE_INT(V_NAME, 5)
CASE "固有依頼最終要素"
	CALLF MAKE_INT(V_NAME, 101)
CASEELSE
	;固有依頼関連のデータにバトンタッチ
	SIF STRCOUNT(O_DATA, "依頼")
		CALLF F固有依頼79(ARG, O_DATA, V_NAME)
ENDSELECT

;-------------------------------------------------
;固有料理設定
;DISH_NAME          料理名
;RESULTS            料理の種類（軽食/主食/甜点）
;CALL 材料設定("")  材料の指定。"汎用"を入れると自動で汎用食材になる
;DISH_TASTE         味の設定
;DISH_COMMENT       （任意）一行コメント
;DISH_TIME          （任意）調理にかかる時間
;DISH_MAXLIMIT      （任意）料理の持続時間
;-------------------------------------------------
@SPECIAL_MENU_79
#LOCALSIZE 1
#LOCALSSIZE 1
DISH_NAME = 雏霰
RESULTS = 甜点
CALL 材料設定("甜味料")
DISH_TASTE = 和食/豆/甜/芸術的/新鲜/サクサク/
IF FESTIVAL() == "女兒節"
	DISH_TASTE += "縁起物/"
ELSE
	DISH_TASTE += "过季/"
ENDIF
DISH_COMMENT = 每年雏祭（春之月的第三日）时吃的色彩鲜艳的霰饼。有时还夹杂着豆子。
RETURN 1

;IMAGE_I79_特殊服装(CHARA)-------------------------------------------------------------------
;角色特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I79_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS
SELECTCASE CFLAG:79:差し替え適用
	CASE 2
		IF CHECK_NUDE(CHARA)
		ELSE
			IF CFLAG:CHARA:睡眠 || CFLAG:CHARA:陪睡中 || 睡眠時間(CHARA)
				RESULTS = _下着
			ELSEIF IS_BUNNY(CHARA)
				RESULTS = _バニーギャル
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 92
				RESULTS = _着物
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
				RESULTS = _セーラー服
			ELSEIF EQUIP:CHARA:連衣裙 == 1
				RESULTS = _私服
			ELSEIF CHECK_CLO("bra_visible", CHARA)
				RESULTS = _下着
			ENDIF
		ENDIF
	CASE 0,1
		IF CHECK_NUDE(CHARA)
		ELSE
			IF IS_BUNNY(CHARA)
				RESULTS = _バニー
			ENDIF
		ENDIF
ENDSELECT

;IMAGE_I79_特殊表情COM(CHARA, 指令)-------------------------------------------------------
;直前の指令で変化する角色特有の表情表示条件
;時間停止中は変化しない表情はこちら
;使用時注意点:
;   RESULTS:0に表情を格納
;   RESULTS:1にマウスオーバー時の表情を格納すること
;   "自慰","愛撫","性交"は本編で実装済み
;-------------------------------------------------------------------------------------------
@IMAGE_I79_特殊表情COM(CHARA, 指令)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
#DIM 指令

SELECTCASE CFLAG:79:差し替え適用
	;替换用画像
	CASE 2
		IF CHECK_NUDE(CHARA)
		ELSE
			;服
			IF IS_BUNNY(CHARA)
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 92
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
			ELSEIF EQUIP:CHARA:連衣裙 == 1
			ELSEIF CHECK_CLO("bra_visible", CHARA)
			ELSE
				SELECTCASE 指令
					CASE 305
						RESULTS = 膝枕覆盖
					;CASE 6,12,313
					;	RESULTS = 揉胸覆盖
				ENDSELECT
			ENDIF
		ENDIF
	CASEELSE
		;通常画像
		IF FLAG:立絵種類
			;顔絵
		ELSE
			;立絵
		ENDIF
ENDSELECT
