@CHARAMOVE_DATA_92(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 92
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
		;たまに連動
		SIF CFLAG:LOCAL:今日の運勢 % 10 == 0
			RETURN [[神子]]
		IF CFLAG:LOCAL:今日の運勢 % 10 == 0
			RESULT:1 = [[布都]]
			RESULT:2 = [[屠自古]]
		ENDIF
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;神霊廟メンバーの私室はあんまり入らない
			CASE P125屠自古私室, P128神子私室, P139邪仙楼
				RETURN -5
			;命蓮寺内部
			CASE P103本堂 TO P120庫房
				RETURN -100
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 地蔵小路, 倒垂的柳樹下, 神霊廟広場, 神霊廟道場
				RETURN 1
			CASE 広場, 商家町, 呑屋小道
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ92
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ92(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	CALLF MAKE_STR(V_NAME, "布都")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（襦袢）套")

CASE "便装：帽子"
	CALLF MAKE_INT(V_NAME, [[頭装備_乌帽子]])
CASE "便装：靴"
	CALLF MAKE_INT(V_NAME, [[靴_鞋子]])
CASE "便装：上身衣服１"
	CALLF MAKE_INT(V_NAME, [[上身衣服_はだけ不可_水干]])
CASE "便装：裙子"
	CALLF MAKE_INT(V_NAME, [[裙子_迷你裙]])
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, [[其他衣装_盘子]])

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "好像是被谁骗着穿的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "儿童内裤")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "裹胸")
CASE "固有内衣着用条件"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 3)

;料理関連
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "米/卵/汁物/ジャンキー/淡白/豪華/上品/家庭的/软糯的/仙術/天界風/和食/和食/甜/甜/甜/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "洋食/丰盛/濃厚/青蛙/青蛙/青蛙/虫肉/虫肉/虫肉/辣/辣/辣/辣/" + "怪诞/謎料理/" * 5)
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "薄味/得意料理＊和食＊/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "青/白/火/秩序/かわいい/懷舊/壮大/" + "巫術/护符/食器/" * 3 + "仙人の/風水の/皿/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "混沌/可怕的/知的/" + "死生/機械/" * 3 )
ENDSELECT

