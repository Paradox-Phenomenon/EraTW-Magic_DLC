@CHARAMOVE_DATA_164(ARG, ARG:2)
#LOCALSIZE 1
#LOCALSSIZE 1
LOCAL = 164
SELECTCASE ARG
	;連動設定（RETURN=依存する角色, RESULT:1～3=対等に連動する角色）
	CASE 1
		RESULT:1 = [[维缦]]
		RESULT:2 = [[阿梨夜]]
	;特殊生活時間設定（CFLAG:LOCAL:生活時間補正を設定する）
	CASE 3
	;移動傾向（±～10=行きやすい/行きにくい, -100=行かない）
	CASE 4
		SELECTCASE ARG:2
			;私室には入らない
			CASE P704河童の宣傳站, P706厄神的家, P709莉莉們的家, P716秋姉妹的家・土間 TO P730仙人的宅邸・庭
				RETURN -100
			CASE P733正邪の隠れ家, P736山姥の家, P737招き猫の家, P740山童のアジト,P742美天居所
				RETURN -100
			;竹林
			CASE P432影狼の家, P437メディスンの家, P439ラルバの家, P443ミスティアの家, P445妹紅の家
				RETURN -100
			;永遠亭の奥には行かない
			CASE P405調剤室, P407廊下 TO P430地下室
				RETURN -100
			;夢幻館には行かない
			CASE P450玄関 TO P466庭
				RETURN -100
			CASE P433斜角の竹林, P434迷いの小道, P444夜雀の屋台, P447竹林入口
				RETURN 1
		ENDSELECT
	;出現場所
	CASE 7
		SELECTCASE ARG:2
			CASE 広場, 商家町, 呑屋小道, 寺子屋, 長屋街
				RETURN 1
			CASE 山麓樹海, 玄武之澤, 大蛤蟆之池, 森の深奥, 圣域, 浅间净秽山
				RETURN 1
			CASE 竹林入り口, 迷いの小道, 斜角の竹林, 兎の洞穴, 永遠亭, 無名の丘, 太陽の畑
				RETURN 1
		ENDSELECT
	;引力設定（CFLAG:LOCAL:引力点を設定する）
	CASE 8
ENDSELECT

@EXIST_キャラデータ164
#LOCALSIZE 1
#LOCALSSIZE 1

@キャラデータ164(ARG, O_DATA, V_NAME)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "稱呼"
	CALLF MAKE_STR(V_NAME, "维缦")
;こっから衣装設定
CASE "今天的睡衣"
	CALLF MAKE_STR(V_NAME, "睡衣（吊带睡裙）套")
	
CASE "便装：連衣裙"
	CALLF MAKE_INT(V_NAME, [[連衣裙_无袖高领袍]])
CASE "便装：其他１"
	CALLF MAKE_INT(V_NAME, [[其他衣装_布条]])

CASE "固有内衣形容詞"
	CALLF MAKE_STR(V_NAME, "永恒轮回的")
CASE "固有下半身内衣名"
	CALLF MAKE_STR(V_NAME, "莫比乌斯环胖次")
CASE "固有上半身内衣"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有上半身内衣名"
	CALLF MAKE_STR(V_NAME, "莫比乌斯环胸罩")
CASE "固有内衣着用条件"
	SIF !RAND:(3 - (2 * 勝負内衣判定([[维缦]])))
		CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(前)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣半透明(後)"
	CALLF MAKE_INT(V_NAME, 1)
CASE "固有内衣布料厚度"
	CALLF MAKE_INT(V_NAME, 2)

;料理関連
;鹿だいしゅき、月都関連大嫌い
CASE "料理：喜欢的味道"
	CALLF MAKE_STR(V_NAME, "野趣/" * 3 + "肉料理/和食/獣肉/旬/濃厚/質素/質素/")
CASE "料理：讨厌的味道"
	CALLF MAKE_STR(V_NAME, "化学的/营养饮料/" + "機能的/" * 3 + "月見/月都風/" * 5)
CASE "料理：助手効果"
	CALLF MAKE_STR(V_NAME, "神力/")
;贈り物関連
CASE "感性：好き"
	CALLF MAKE_STR(V_NAME, "自然/美的/獣の/山の/大地の/" + "神代の/過去の/自由の/" * 3 + "白蛇の/懐かしき/" * 5)
CASE "感性：嫌い"
	CALLF MAKE_STR(V_NAME, "秩序/未来/知的/技術/機械/" + "量子の/電子工学の/近未来風の/フェムトファイバーの/" * 3 + "月/穢れなき/人工知能/" * 10 )
ENDSELECT

;-------------------------------------------------
;固有料理設定
;DISH_NAME          料理名
;RESULTS            料理の種類（軽食/主食/甜点）
;CALL 材料設定("")  材料の指定。"汎用"を入れると自動で汎用食材になる
;DISH_TASTE         味の設定
;DISH_COMMENT       （任意）一行コメント
;DISH_TIME          （任意）調理にかかる時間
;DISH_MAXLIMIT      （任意）料理の持続時間
;-------------------------------------------------
[SKIPSTART]
@SPECIAL_MENU_164
#LOCALSIZE 1
#LOCALSSIZE 1
DISH_NAME = 圣餐饼
RESULTS = 甜点
CALL 材料設定("汎用")
DISH_TASTE = 洋食/简易/家庭的/芸術的/マニアック/
DISH_COMMENT = 一种轻薄的米饼，常被象征为‘基督的身体’。 
RETURN 1
[SKIPEND]

;IMAGE_I164_特殊服装(CHARA)-------------------------------------------------------------------
;角色特有の服装表示条件
;エフェクトを共有する服装差分はこちらで指定する
;使用時注意点:
;	RESULTSに特殊服装を格納すること
;	書式は %服装%%特殊服装% 適宜"_"等入れること
;-------------------------------------------------------------------------------------------
@IMAGE_I164_特殊服装(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
VARSET RESULTS
SELECTCASE CFLAG:164:差し替え適用
	CASE 1
	CASE 0
		IF CHECK_NUDE(CHARA)
		ELSE
			IF CFLAG:CHARA:睡眠 || CFLAG:CHARA:陪睡中 || 睡眠時間(CHARA)
				RESULTS = _内衣
			ELSEIF IS_BUNNY(CHARA)
				RESULTS = _兔女郎
			ELSEIF CURRENT_CLOTHES_SET(CHARA) == 74
				RESULTS = _水手服
			ELSEIF CHECK_CLO("bra_visible", CHARA)
				RESULTS = _内衣
			ENDIF
		ENDIF
ENDSELECT
