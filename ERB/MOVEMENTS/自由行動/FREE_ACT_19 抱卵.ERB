@EXIST_FreeAct19
#LOCALSIZE 1
#LOCALSSIZE 1

;オブジェクト本体
@FFreeAct19(ARG, O_DATA, V_NAME)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
#DIM 経過時間
経過時間 = Activity_Duration:TARGET
SELECTCASE O_DATA
;自由行動に付き合うコマンドの名称
CASE "名前"
	RETURNF "一起温暖蛋宝宝"
CASE "CHAIN"
;他キャラに連鎖しない場合コメントアウトすること
	;RETURNF @"{1}"
CASE "経過時間"
;自由行動に付き合うコマンドでの経過時間
;0だと30分か残り時間すべての小さい方
	RETURNF @"{0}"
ENDSELECT

@自由行動内容_19(CHARA, ARGS, 時間係数, CHAIN)
#DIM CHARA
#DIM CHAIN
#DIM 現在地
#DIM メッセージ表示
#DIM 時間係数
#DIM 経過時間
現在地 = CFLAG:CHARA:現在位置
メッセージ表示 = 現在地 == CFLAG:MASTER:現在位置 ? 1 # 0
SELECTCASE ARGS
	CASE "発生"
        SIF !TALENT:CHARA:NESTING
            RETURN 0
        SIF CFLAG:CHARA:現在位置 != CFLAG:CHARA:初期位置
            RETURN 0
		;発生条件、ここでRETURN 0すると発生しない
		;CHAINは連鎖元キャラに相当
		SIF メッセージ表示
			PRINTFORMW %CALLNAME:CHARA%开始温柔地温暖起自己产下的蛋。
		;自由行動にかける時間をRETURNする
		RETURN 60 + RAND:30
	CASE "行動中"
		;行動中の処理、地の文もここで
		IF メッセージ表示
			PRINTFORMW %CALLNAME:CHARA%正%TEXTR("爱怜地抱着蛋")%。
		ENDIF
	CASE "完了"
		;行動時間を使い切ったときの処理、地の文もここで
		SIF メッセージ表示
			PRINTFORMW %CALLNAME:CHARA%似乎已经暖好了蛋。
	CASE "中断"
		;中断したときの処理、地の文もここで
	CASE "付き合う"
		;自由行動に付き合ったとき用メッセージ
		PRINTFORML %CALLNAME:PLAYER%和%CALLNAME:TARGET%一起温暖了蛋宝宝
	CASE "ソース"
		;付き合うコマンド選択時の入手ソース、時間係数は付き合った時間の1/10,子供とふれあうを参照
		SOURCE:歓楽 = (ABL:親密 + 1) * 15 * 時間係数
		SOURCE:情愛 = (ABL:親密 + 1) * 10 * 時間係数
		CFLAG:TARGET:胎児愛情値 += MAX(1, 時間係数 /2)
ENDSELECT

@ACTIVITY19_TAGS
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
LOCAL = 0
SETBIT LOCAL, BIT_自由行動風チラ禁止
RETURNF LOCAL