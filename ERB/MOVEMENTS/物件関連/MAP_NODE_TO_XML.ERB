;ARG_MAIN_MAPで指定されたメインマップのノード間接続をDataTableに数え上げて記録する
;想定される数値をかたっぱしからCAN_MOVE_関数に突っ込んでいく
;ARG_MAIN_MAPにメインマップのIDを受け取る。ARG_REFRESHに非0を指定するとDTの有無にかかわらずデータを作成しなおす
@MAP_ROUTE_TO_DT(ARG_MAIN_MAP = -1 , ARG_REFRESH = 0)
#DIM ARG_MAIN_MAP
#DIM ARG_REFRESH
#DIM L_TEMP
#DIM L_XMLPOS
#DIM L_HITNUM
#DIM L_COST
#DIM L_ROWID
#DIM CNT_0
#DIM CNT_1
#DIM CNT_MAX , 2
#DIMS L_DTNAME
#DIM CONST C_DEFAULT_COST = DEFAULT_MOVECOST ;既定のノード間移動コスト
#DIM CONST C_REGION_MAX = 10 ;地域の最大数を定義する定数が分からなかったので定数で仮置きしておく

;地域DT作成
IF DT_EXIST(DT_REGION) == 0
	DT_CREATE DT_REGION
	DT_COLUMN_ADD DT_REGION , DT_REGION_NAME , "string"

	FOR CNT_0 , 0 , C_REGION_MAX + 1
		DT_COLUMN_ADD DT_REGION , DT_REGION_ABLE + TOSTR(CNT_0) , "int8"
		DT_COLUMN_OPTIONS DT_REGION , DT_REGION_ABLE + TOSTR(CNT_0) , DEFAULT , 1
	NEXT
	FOR CNT_0 , 0 , C_REGION_MAX + 1
		DT_ROW_ADD DT_REGION , DT_REGION_NAME , GET_MAPNAME(CNT_0)
	NEXT
ENDIF

;現時点でのTWにはないが、地域間移動をする際に可能か否かを判定する必要があるならここでやる
[SKIPSTART]
FOR CNT_0 , 0 , C_REGION_MAX + 1
	FOR CNT_1 , 0 , C_REGION_MAX + 1
		;(もしその地域への移動を不可にしたいなら列"DT_REGION_ABLE_{REGIONID}"に0をセットする)
		;地域ID=CNT_0から地域ID=CNT_1への移動を禁止する
		;DT_CELL_SET DT_REGION , CNT_0 , DT_REGION_ABLE + TOSTR(CNT_1) , 0
	NEXT
NEXT
[SKIPEND]

L_DTNAME '= DT_MAINMAP + TOSTR(ARG_MAIN_MAP)

;もしDTがすでにある、かつARG_REFRESHに指定がないなら何もせずに終了
IF DT_EXIST(L_DTNAME) && ARG_REFRESH == 0
	RESULTS '= L_DTNAME
	RETURN 0
ENDIF

DT_RELEASE L_DTNAME
DT_CREATE L_DTNAME

DT_COLUMN_ADD L_DTNAME , DT_COL_START , "int64"
DT_COLUMN_ADD L_DTNAME , DT_COL_DEST , "int64"
DT_COLUMN_ADD L_DTNAME , DT_COL_COST , "int64"
DT_COLUMN_ADD L_DTNAME , DT_COL_TYPE , "int64"

;取りうる数値のすべてに対して総当たりする
;TWのマップ構造で想定される数値セット
CNT_MAX:0 = MINROOM()
CNT_MAX:1 = MAXROOM
L_HITNUM = 0
FOR CNT_0 , CNT_MAX:0 , CNT_MAX:1
	FOR CNT_1 , CNT_MAX:0 , CNT_MAX:1
		;ノード間の移動タイプが設定されているかチェック。関数があろうがなかろうが返値が0なら無視する
		L_TEMP = CAN_MOVE_CALLFORM(ARG_MAIN_MAP , CNT_0 , CNT_1)
		;最下位ビットが1なら移動可能(らしい)
		IF L_TEMP & 1
			L_COST = C_DEFAULT_COST ;←もしノード間の移動コストを考慮するならここで入れる
			;L_COST = RAND:100 ;ノード間のコストをランダムにしても正しく動くか実験用
			L_ROWID = DT_ROW_ADD(L_DTNAME , DT_COL_START , CNT_0 , DT_COL_DEST , CNT_1 , DT_COL_COST , L_COST , DT_COL_TYPE , L_TEMP)
			L_HITNUM++
		ENDIF
	NEXT
NEXT

[SKIPSTART]
;生成したDTをチェックする
PRINTFORML 行数は{DT_ROW_LENGTH(L_DTNAME)}だよ
FOR CNT_0 , 0 , DT_ROW_LENGTH(L_DTNAME)
	PRINTFORML {CNT_0 , 3}  ST:{DT_CELL_GET(L_DTNAME , CNT_0 , DT_COL_START)}  DE:{DT_CELL_GET(L_DTNAME , CNT_0 , DT_COL_DEST)}  CO:{DT_CELL_GET(L_DTNAME , CNT_0 , DT_COL_COST)}
NEXT
PRINTFORMW END
[SKIPEND]

RESULTS '= L_DTNAME
RETURN L_HITNUM


[SKIPSTART]
;@MAP_NODE_TO_DTで作成したDTをもとに、ARG_STARTPOSからARG_DESTPOSへ向かうルートを検索し、次に向かうべき地点を返す
;RETURNで次に向かう地点、RESULT:1に終点までのコスト合計、RESULTSに始点から終点までのルートを格納している
;TWには地点の座標がないので実コストだけを考慮し、推定コストは扱わない
;これA*になってるよな！？
<引数>
	ARG_MAINMAP  = メインマップID
	ARG_STARTPOS = 始点の地点ID
	ARG_DESTPOS  = 終点の地点ID
	ARG_CW       = RESULTSの地点ID同士の接続に使うワード。未指定なら","
<返値>
	RESULT:0 = 次に向かうべき地点。ルートがなければ-1
	RESULT:1 = 目的地到着に必要な実コスト。ルートがなければ-1
	RESULT:2 = 
	RESULT:3 = 目的地に着くまでの中継地点の数
	RESULT:10= 計算にかかった反復数(概算。小さいほどいい)
	RESULTS  = 目的地に着くためのルート全部。ルートがなければ空文字
[SKIPEND]
@CAN_MOVE_BY_DT(ARG_MAINMAP = 0 , ARG_STARTPOS = 0 , ARG_DESTPOS = 0 , ARG_CW = "")
#DIM ARG_MAINMAP
#DIM ARG_STARTPOS
#DIM ARG_DESTPOS
#DIMS ARG_CW
#DIM L_ROWID
#DIM L_ROWID_TEMP
#DIM L_DEST_TEMP , 10 ;一度に検索できるルート。もっと必要なら増やして
#DIM L_HITNUM
#DIM L_COST , 3
#DIM L_MINCOST
#DIMS L_RESULTS
#DIM CNT_0
#DIM DYNAMIC L_FORCOUNT
#DIMS L_DTROUTE
#DIMS L_DTPOINT
#DIM CONST C_MINCOST_NULL = -123456789

;ルートDT作成
CALL MAP_ROUTE_TO_DT(ARG_MAINMAP)
L_DTROUTE '= RESULTS

;ルートDTにARG_STARTPOSかARG_DESTPOSが見つからない場合終了
IF DT_SELECT(L_DTROUTE , @"%DT_COL_START% = {ARG_STARTPOS}" , , L_ROWID) == 0 || DT_SELECT(L_DTROUTE , @"%DT_COL_DEST% = {ARG_DESTPOS}" , , L_ROWID) == 0
	;#;PRINTFORML @CAN_MOVE_BY_DT  指定された始点、終点がDataTableに見つからないよ。指定は正しい？
	;#;PRINTFORMW MAINMAP={ARG_MAINMAP}  START={ARG_STARTPOS}({DT_SELECT(L_DTROUTE , @"%DT_COL_START% = {ARG_STARTPOS}" , , L_ROWID)})  DEST={ARG_DESTPOS}({DT_SELECT(L_DTROUTE , @"%DT_COL_DEST% = {ARG_DESTPOS}" , , L_ROWID)})
	RESULTS = 
	RESULT:1 = -1
	RETURN -1
ENDIF

SIF STRLENS(ARG_CW) == 0
	ARG_CW = ,

;探索した地点を記録するノードDT作成
L_DTPOINT '= DT_NODELIST
DT_RELEASE L_DTPOINT
DT_CREATE L_DTPOINT
DT_COLUMN_ADD L_DTPOINT , DT_COL_MAPID , "int64"
DT_COLUMN_ADD L_DTPOINT , DT_COL_STATUS , "string"
DT_COLUMN_ADD L_DTPOINT , DT_COL_COST , "int64"
DT_COLUMN_ADD L_DTPOINT , DT_COL_FROM , "int64"
DT_ROW_ADD L_DTPOINT , DT_COL_MAPID , ARG_STARTPOS , DT_COL_STATUS , DT_OP , DT_COL_COST , 0 , DT_COL_FROM , -1

L_MINCOST = C_MINCOST_NULL

;OPEN状態、かつ最も到達コストの小さいノードをL_ROWIDへ一個ずつ取り出し、そのノードから移動可能なノードを調べる
;ARG_DESTPOSにたどり着いた時ではなく、OPEN状態のノードが消えたら捜索終了
WHILE DT_SELECT(L_DTPOINT , @"%DT_COL_STATUS% = '%DT_OP%'" , @"%DT_COL_COST% ASC" , L_ROWID)
	;選択中のL_ROWIDから伸びるノードを全て取得
	VARSET L_DEST_TEMP
	L_HITNUM = DT_SELECT(L_DTROUTE , @"%DT_COL_START% = {DT_CELL_GET(L_DTPOINT , L_ROWID , DT_COL_MAPID , 1)}" , @"%DT_COL_COST% ASC" , L_DEST_TEMP)

	;もし最小コスト検索でゴールが出てきたらクローズに設定してCONTINUE(そんなことないよね？)
	[SKIPSTART]
	IF DT_CELL_GET(L_DTPOINT , L_ROWID , DT_COL_MAPID , 1) == ARG_DESTPOS
		DT_CELL_SET L_DTPOINT , L_ROWID , DT_COL_STATUS , DT_CL , 1
		CONTINUE
	ENDIF
	[SKIPEND]

	FOR CNT_0 , 0 , MIN(L_HITNUM , VARSIZE("L_DEST_TEMP"))
		L_FORCOUNT++
		VARSET L_COST
		;ノードへの移動コスト
		L_COST:0 = DT_CELL_GET(L_DTROUTE , L_DEST_TEMP:CNT_0 , DT_COL_COST , 1)

		;現在選択中のノードまでの移動コスト(見つからなければ0)
		L_COST:1 = DT_CELL_GET(L_DTPOINT , L_ROWID , DT_COL_COST , 1)

		;もし推定コストが必要ならここで
		;L_COST:2 = 

		;調べるノードがL_DTPOINTに存在するかチェックして分岐
		L_ROWID_TEMP = DT_SEARCH_MAPID(L_DTPOINT , DT_CELL_GET(L_DTROUTE , L_DEST_TEMP:CNT_0 , DT_COL_DEST , 1))
		IF L_ROWID_TEMP >= 0
			IF DT_CELL_GET(L_DTPOINT , L_ROWID_TEMP , DT_COL_MAPID , 1) == ARG_DESTPOS
				IF SUMARRAY(L_COST) < L_MINCOST
					;もし目標地点であり、かつ移動コストが現時点での目標到達に必要な最低コストより低ければ記録しFROM列を更新、ゴールはCLOSEにする
					;(ここには仮の最低コストが未決定の状態では来ない)
					L_MINCOST = SUMARRAY(L_COST)
					DT_CELL_SET L_DTPOINT , L_ROWID_TEMP , DT_COL_FROM , DT_CELL_GET(L_DTROUTE , L_DEST_TEMP:CNT_0 , DT_COL_START , 1)
				ENDIF
				DT_CELL_SET L_DTPOINT , L_ROWID_TEMP , DT_COL_STATUS , DT_CL , 1
			ELSEIF L_MINCOST != C_MINCOST_NULL && SUMARRAY(L_COST) >= L_MINCOST
				;もし到達コストが、現在見つかっている目標への到達コスト以上ならそのノードはCLOSE
				DT_CELL_SET L_DTPOINT , L_ROWID_TEMP , DT_COL_STATUS , DT_CL , 1
			ELSEIF DT_CELL_GET(L_DTPOINT , L_ROWID_TEMP , DT_COL_COST , 1) > SUMARRAY(L_COST)
				;もしL_DTPOINTに既に地点が登録済みなら、新規ルートのコストが低い場合に限り所要コストとFROM列を選択中のノードへ更新しOPENへ
				DT_CELL_SET L_DTPOINT , L_ROWID_TEMP , DT_COL_COST , SUMARRAY(L_COST) , 1
				DT_CELL_SET L_DTPOINT , L_ROWID_TEMP , DT_COL_FROM , DT_CELL_GET(L_DTROUTE , L_DEST_TEMP:CNT_0 , DT_COL_START , 1) , 1
				DT_CELL_SET L_DTPOINT , L_ROWID_TEMP , DT_COL_STATUS , DT_OP , 1
			ENDIF
		ELSE
			;もし未登録ならL_DTPOINTに登録。その際、最低コストがまだ不明かその地点への移動コストが最低コスト以下ならOPENで、そうでないならCLOSEに設定
			{
				L_ROWID_TEMP = DT_ROW_ADD(L_DTPOINT , 
					DT_COL_MAPID , DT_CELL_GET(L_DTROUTE , L_DEST_TEMP:CNT_0 , DT_COL_DEST , 1) , 
					DT_COL_STATUS , \@ L_MINCOST == C_MINCOST_NULL || SUMARRAY(L_COST) <= L_MINCOST ?  %DT_OP% # %DT_CL% \@ , 
					DT_COL_COST , SUMARRAY(L_COST) , 
					DT_COL_FROM , DT_CELL_GET(L_DTROUTE , L_DEST_TEMP:CNT_0 , DT_COL_START , 1)
				)
			}
			;もし追加した地点が目標地点なら所要コストを最小コストとして記録、CLOSEに設定
			IF DT_CELL_GET(L_DTPOINT , L_ROWID_TEMP , DT_COL_MAPID , 1) == ARG_DESTPOS
				L_MINCOST = SUMARRAY(L_COST)
				DT_CELL_SET L_DTPOINT , L_ROWID_TEMP , DT_COL_STATUS , DT_CL , 1
			ENDIF
		ENDIF
	NEXT
	;ここまで来たら接続先ノードを全て調べたのでCLOSE
	DT_CELL_SET L_DTPOINT , L_ROWID , DT_COL_STATUS , DT_CL , 1
WEND

;終点までの経路を組み立て(DTに記録されているFROM列を終点から始点へ順番に見ていくだけ)
L_DEST_TEMP:0 = ARG_DESTPOS
L_DEST_TEMP:1 = ARG_DESTPOS
L_RESULTS '= TOSTR(ARG_DESTPOS)
RESULT:3 = 0
DO
	L_DEST_TEMP:0 = DT_CELL_GET(L_DTPOINT , DT_SEARCH_MAPID(L_DTPOINT , L_DEST_TEMP:0) , DT_COL_FROM , 1)
	IF L_DEST_TEMP:0 == 0
		;もし上のDT_CELL_GETが0を返したらルートが見つからなかったということ
		RESULTS:0 = 
		RESULT:1 = -1
		RESULT:3 = 0
		RETURN -1
	ELSEIF L_DEST_TEMP:0 == ARG_STARTPOS
		;ここで処理打ち切りなのでARG_STARTPOSから次に向かうべき地点IDがL_DEST_TEMP:1に残っている
		BREAK
	ELSE
		L_DEST_TEMP:1 = L_DEST_TEMP:0
	ENDIF
	L_RESULTS = {L_DEST_TEMP:0}%ARG_CW%%L_RESULTS%
	RESULT:3++
LOOP 1

;終点までの移動コスト取得
RESULT:1 = DT_CELL_GET(L_DTPOINT , DT_SEARCH_MAPID(L_DTPOINT , ARG_DESTPOS) , DT_COL_COST , 1)
RESULT:10 = L_FORCOUNT
;#;PRINTFORML A*  {ARG_STARTPOS}->{ARG_DESTPOS}  搜索结束  计数={L_FORCOUNT}  路径=%L_RESULTS%  下一步该前往的地点={L_DEST_TEMP:1}  移动消费={RESULT:1}  中继点数量={RESULT:3}
RESULTS '= L_RESULTS
RETURN L_DEST_TEMP:1


@DT_SEARCH_MAPID(L_DTNAMENAME = "" , ARG_MAPID = -1 , ARG_COLUMN = DT_COL_MAPID)
#FUNCTION
#DIMS L_DTNAMENAME
#DIMS ARG_COLUMN
#DIM L_TEMP
#DIM ARG_MAPID
#DIM CNT
;[SKIPSTART]
VARSET L_TEMP
IF DT_SELECT(L_DTNAMENAME , @"%ARG_COLUMN% = {ARG_MAPID}" , , L_TEMP)
	RETURNF L_TEMP
ELSE
	RETURNF -1
ENDIF
;[SKIPEND]
[SKIPSTART]
FOR CNT , 0 , DT_ROW_LENGTH(L_DTNAMENAME)
	SIF DT_CELL_GET(L_DTNAMENAME , CNT , ARG_COLUMN) == ARG_MAPID
		RETURNF CNT
NEXT
RETURNF -1
[SKIPEND]


;@CAN_MOVE_系関数が式中関数でCALLFORM呼びできないので強引に
@CAN_MOVE_CALLFORM(ARG_MAIN_MAP = -1 , ARG_NOW_POINT = 0 , ARG_DEST_POINT = 0)
#FUNCTION
#DIM ARG_MAIN_MAP
#DIM ARG_NOW_POINT
#DIM ARG_DEST_POINT

SELECTCASE ARG_MAIN_MAP
	CASE 0
		RETURNF CAN_MOVE_0(ARG_NOW_POINT , ARG_DEST_POINT)
	CASE 1
		RETURNF CAN_MOVE_1(ARG_NOW_POINT , ARG_DEST_POINT)
	CASE 2
		RETURNF CAN_MOVE_2(ARG_NOW_POINT , ARG_DEST_POINT)
	CASE 3
		RETURNF CAN_MOVE_3(ARG_NOW_POINT , ARG_DEST_POINT)
	CASE 4
		RETURNF CAN_MOVE_4(ARG_NOW_POINT , ARG_DEST_POINT)
	CASE 5
		RETURNF CAN_MOVE_5(ARG_NOW_POINT , ARG_DEST_POINT)
	CASE 6
		RETURNF CAN_MOVE_6(ARG_NOW_POINT , ARG_DEST_POINT)
	CASE 7
		RETURNF CAN_MOVE_7(ARG_NOW_POINT , ARG_DEST_POINT)
	CASE 8
		RETURNF CAN_MOVE_8(ARG_NOW_POINT , ARG_DEST_POINT)
	CASE 9
		RETURNF CAN_MOVE_9(ARG_NOW_POINT , ARG_DEST_POINT)
	CASE 10
		RETURNF CAN_MOVE_10(ARG_NOW_POINT , ARG_DEST_POINT)
	CASE 11
		RETURNF CAN_MOVE_11(ARG_NOW_POINT , ARG_DEST_POINT)
	CASEELSE
		THROW 未知のメインマップだよ  ARG_MAIN_MAP={ARG_MAIN_MAP}
ENDSELECT


;@MAP_ROUTE_TO_DTが作るDataTableからERBファイルで使う@CAN_MOVE_関数を作る関数
;ROUTE_DTの作成でCAN_MOVE_関数総ざらいで見てるんだから意味ないじゃん？
;いや…でも…DTを生成し、そのDTをいじればマップエディタになると思わん？　GUIができてない？　仕様も不明？　それはそう
@ROUTE_DT_TO_ERB(ARG_MAINMAP_ID = -1)
#DIMS L_DTNAME
#DIM ARG_MAINMAP_ID
#DIM L_ID_0
#DIM L_ID_1
#DIM L_STARTPOS
#DIM L_DESTPOS
#DIM L_TEMPSTART
#DIMS L_TEMPS , 2

CALL MAP_ROUTE_TO_DT(ARG_MAINMAP_ID)
L_DTNAME '= RESULTS

PRINTFORML @CAN_MOVE_{ARG_MAINMAP_ID}(ARG , ARG:1)
PRINTL #FUNCTION

PRINTFORML SELECTCASE ARG

WHILE DT_SELECT(L_DTNAME ,  , @"%DT_COL_START% ASC" , L_ID_0)
	L_TEMPSTART = DT_CELL_GET(L_DTNAME , L_ID_0 , DT_COL_START , 1)

	VARSET L_TEMPS
	WHILE DT_SELECT(L_DTNAME , @"%DT_COL_START% = {L_TEMPSTART}" , @"%DT_COL_DEST% ASC" , L_ID_1)
		L_STARTPOS = DT_CELL_GET(L_DTNAME , L_ID_1 , DT_COL_START , 1)
		L_DESTPOS = DT_CELL_GET(L_DTNAME , L_ID_1 , DT_COL_DEST , 1)

		IF STRLENS(L_TEMPS:0) == 0
			L_TEMPS:0 = ;%NAME_FROM_PLACE(L_DESTPOS)%
			L_TEMPS:1 = GROUPMATCH(ARG:1 , {L_DESTPOS}
		ELSE
			L_TEMPS:0 += @"、%NAME_FROM_PLACE(L_DESTPOS)%"
			L_TEMPS:1 += @" , {L_DESTPOS}"
		ENDIF
		DT_ROW_REMOVE L_DTNAME , L_ID_1
	WEND
	L_TEMPS:1 += ")"

	;MAPID→ERHのCONSTへの変換ができないのでコメントを併記してごまかす
	PRINTFORML %TAB_FUNC(1)%;%NAME_FROM_PLACE(L_STARTPOS)%
	PRINTFORML %TAB_FUNC(1)%CASE {L_STARTPOS}
	PRINTFORML %TAB_FUNC(2)%%L_TEMPS:0%
	PRINTFORML %TAB_FUNC(2)%%L_TEMPS:1%
WEND

PRINTFORML %TAB_FUNC(1)%CASE MAXROOM
PRINTFORML %TAB_FUNC(2)%SIF ARG:1 == (主地图连接点)
PRINTFORML %TAB_FUNC(3)%RETURNF 1
PRINTFORML ENDSELECT
PRINTFORML RETURNF 0

PRINTFORML ;----------<分割线>----------
PRINTFORML ;把上面的日志复制过去，新建@MOVEMENT_CAN_MOVE_XX.ERB文件吧！
PRINTFORML ;只有(主地图连接点)要自己手动改掉哦！那是跟主地图连接的地点ID！
PRINTFORML ;按下ENTER键就会结束啦！
PRINTFORMW ;--------------------------
RETURN 1


@TAB_FUNC(ARG_TABNUM = 1)
#FUNCTIONS
#DIM ARG_TABNUM
#DIMS CONST C_TAB = "　　"
RETURNF C_TAB * ARG_TABNUM
