;-----------------------------------------
;職場、宴会会場の場所IDを返す関数
;ARGS,"宴会"or"仕事"
;TCHARA,ARGS=="仕事"の場合の働く角色ID
;出力,職場、宴会会場の場所ID
;-----------------------------------------
@GET_JOBPLACE(ARGS,TCHARA = 0)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM 対象ID
#DIM 対象Map
#DIM TCHARA
#DIM OUTID
IF ARGS == "宴会"
	対象ID = FLAG:宴会会場
ELSEIF ARGS == "仕事" && TCHARA != 0
	対象ID = CFLAG:TCHARA:職場
ELSE
	RETURNF 0
ENDIF
;幻想乡大地图下由于不使用外出地图做移动逻辑，因此直接返回据点地图ID
SIF GMF_GETBIT("幻想乡大地图")
	RETURNF 対象ID
RETURNF GET_MAP_REPLACEMENT(対象ID)
