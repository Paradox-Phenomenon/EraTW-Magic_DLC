;-----------------------------------------------------------
;遠距離移動の設定
;ARG     目的地
;ARG:1   現在地
;RETURN  次の目的地
;-----------------------------------------------------------
@SKIP_MOVE_7(ARG, ARG:1)
#DIM 現在的位置
;現在位置取得
IF ARG:1
	現在的位置 = ARG:1
ELSE
	現在的位置 = CFLAG:MASTER:現在位置
ENDIF

;目的地に直接移動できる場合そこに移動
SIF CAN_MOVE(現在的位置, ARG) & 1
	RETURN ARG

;袋小路から行ける場所は固定なので、そこを目指す
SELECTCASE 現在的位置
	CASE P704河童の宣傳站, P709莉莉們的家, P735游泳場
		RETURN P703玄武之澤
	CASE P734小屋
		RETURN P701樹海道入口
	CASE P733正邪的隠匿処
		RETURN P705山道・中腹
	CASE P708大蛤蟆之池
		RETURN P707山道・分岐点
	CASE P737招财猫的家
		RETURN P710猫之里
	CASE P721仙人的宅邸・風呂, P722仙人的宅邸・道場, P720仙人的宅邸・廚房
		RETURN P729仙人的宅邸・玄関
	CASE P724仙人的宅邸・書斎
		RETURN P723仙人的宅邸・二階客間
	CASE P727仙人的宅邸・華扇私室, P728仙人的宅邸・空的部屋
		RETURN P726仙人的宅邸・居間
	CASE P739秘天崖, P740山童の宣傳站
		RETURN P738森の深奥
	;补足一些少的部分，包括一些二级节点
	CASE P710猫之里
		RETURN P707山道・分岐点
	CASE P712間欠泉地下中樞, P732通向山頂的路
		RETURN P711休憩所
	CASE P738森の深奥
		RETURN P703玄武之澤
	;添加锦上京部分，虽然这个函数随着新SKIPMOVE函数已经不再使用，但顺手加上吧，这样之后保底还能用
	CASE P742美天居所
		RETURN P741猿猴通路
	CASE P741猿猴通路
		RETURN P736圣域入口
	CASE P744合欢宅邸, P745月都秘道
		RETURN P743圣域林道
	CASE P746姥芽大宅
		RETURN P747圣域深道
	CASE P753浅间的房间, P754空房间, P761浴室, P762空房间
		RETURN P752四季竖穴
	CASE P756月海通路, P757巧克力河
		RETURN P755化石丛林荒地
	CASE P760磐永神社内屋
		RETURN P759磐永神社本殿
	CASE P759磐永神社本殿
		RETURN P758化石深道
ENDSELECT

;直接移動できない場合、1つ近い位置を暫定目的地に設定し直してループ
;基本的に最短で行けるコースを設定する
;現在地によってコースが変わることも考慮して対応する
SELECTCASE ARG
	;死胡同区
	CASE P704河童の宣傳站, P709莉莉們的家, P735游泳場
		RETURN P703玄武之澤
	CASE P734小屋
		RETURN P701樹海道入口
	CASE P733正邪的隠匿処
		RETURN P705山道・中腹
	CASE P708大蛤蟆之池
		RETURN P707山道・分岐点
	CASE P737招财猫的家
		RETURN P710猫之里
	CASE P721仙人的宅邸・風呂, P722仙人的宅邸・道場, P720仙人的宅邸・廚房
		RETURN P729仙人的宅邸・玄関
	CASE P724仙人的宅邸・書斎
		RETURN P723仙人的宅邸・二階客間
	CASE P727仙人的宅邸・華扇私室, P728仙人的宅邸・空的部屋
		RETURN P726仙人的宅邸・居間
	CASE P739秘天崖, P740山童の宣傳站
		RETURN P738森の深奥
	;补足一些少的部分，包括一些二级节点
	CASE P710猫之里
		RETURN P707山道・分岐点
	CASE P712間欠泉地下中樞, P732通向山頂的路
		RETURN P711休憩所
	CASE P738森の深奥
		RETURN P703玄武之澤
	;添加锦上京部分，虽然这个函数随着新SKIPMOVE函数已经不再使用，但顺手加上吧，这样之后保底还能用
	CASE P742美天居所
		RETURN P741猿猴通路
	CASE P741猿猴通路
		RETURN P736圣域入口
	CASE P744合欢宅邸, P745月都秘道
		RETURN P743圣域林道
	CASE P746姥芽大宅
		RETURN P747圣域深道
	CASE P753浅间的房间, P754空房间, P761浴室, P762空房间
		RETURN P752四季竖穴
	CASE P756月海通路, P757巧克力河
		RETURN P755化石丛林荒地
	CASE P760磐永神社内屋
		RETURN P759磐永神社本殿
	CASE P759磐永神社本殿
		RETURN P758化石深道

	;一些小循环等
	CASE P706厄神的家
		SELECTCASE 現在的位置
		CASE P737招财猫的家
			RETURN P710猫之里
		CASEELSE
			RETURN P707山道・分岐点
		ENDSELECT

	;山麓主干道
	CASE P701樹海道入口
		RETURN P702山道・通往沼澤之道
	CASE P702山道・通往沼澤之道
		SELECTCASE 現在的位置
		CASE P717秋姉妹的家・寝室 TO P719秋姉妹的家・座敷
			RETURN P716秋姉妹的家・土間
		CASEELSE
			RETURN P703玄武之澤
		ENDSELECT
	CASE P703玄武之澤
		SELECTCASE 現在的位置
		CASE P701樹海道入口, P734小屋, P715秋姉妹的家・畑 TO P719秋姉妹的家・座敷
			RETURN P702山道・通往沼澤之道
		CASE P739秘天崖, P740山童の宣傳站
			RETURN P738森の深奥
		CASEELSE
			RETURN P705山道・中腹
		ENDSELECT
	CASE P705山道・中腹
		SELECTCASE 現在的位置
		CASE P701樹海道入口 TO P704河童の宣傳站, P734小屋, P715秋姉妹的家・畑 TO P719秋姉妹的家・座敷, P709莉莉們的家, P735游泳場, P738森の深奥 TO P740山童の宣傳站
			RETURN P703玄武之澤
		CASEELSE
			RETURN P707山道・分岐点
		ENDSELECT
	CASE P707山道・分岐点
		SELECTCASE 現在的位置
		CASE P712間欠泉地下中樞, P732通向山頂的路
			RETURN P711休憩所
		CASE P720仙人的宅邸・廚房 TO P730仙人的宅邸・庭
			RETURN P731帚木
		CASE P741猿猴通路 TO P762空房间
			RETURN P736圣域入口
		CASEELSE
			RETURN P705山道・中腹
		ENDSELECT
	CASE P711休憩所
		SELECTCASE 現在的位置
		CASE P741猿猴通路 TO P762空房间
			RETURN P736圣域入口
		CASEELSE
			RETURN P707山道・分岐点
		ENDSELECT

	;两间大宅，秋姐妹家和华扇家
	CASE P715秋姉妹的家・畑
		SELECTCASE 現在的位置
		CASE P717秋姉妹的家・寝室
			RETURN P719秋姉妹的家・座敷
		CASE P718秋姉妹的家・居間
			RETURN P716秋姉妹的家・土間
		CASEELSE
			RETURN P702山道・通往沼澤之道
		ENDSELECT
	CASE P716秋姉妹的家・土間
		SELECTCASE 現在的位置
		CASE P717秋姉妹的家・寝室, P719秋姉妹的家・座敷
			RETURN P718秋姉妹的家・居間
		CASEELSE
			RETURN P702山道・通往沼澤之道
		ENDSELECT
	CASE P717秋姉妹的家・寝室
		SELECTCASE 現在的位置
		CASE P715秋姉妹的家・畑
			RETURN P719秋姉妹的家・座敷
		CASEELSE
			RETURN P718秋姉妹的家・居間
		ENDSELECT
	CASE P718秋姉妹的家・居間
		RETURN P716秋姉妹的家・土間
	CASE P719秋姉妹的家・座敷
		SELECTCASE 現在的位置
		CASE P716秋姉妹的家・土間
			RETURN P718秋姉妹的家・居間
		CASEELSE
			RETURN P715秋姉妹的家・畑
		ENDSELECT

	CASE P731帚木
		SELECTCASE 現在的位置
		CASE P720仙人的宅邸・廚房 TO P729仙人的宅邸・玄関
			RETURN P730仙人的宅邸・庭
		CASEELSE
			RETURN P707山道・分岐点
		ENDSELECT
	CASE P730仙人的宅邸・庭
		SELECTCASE 現在的位置
		CASE P720仙人的宅邸・廚房 TO P729仙人的宅邸・玄関
			RETURN P729仙人的宅邸・玄関
		CASEELSE
			RETURN P731帚木
		ENDSELECT
	CASE P729仙人的宅邸・玄関
		SELECTCASE 現在的位置
		CASE P724仙人的宅邸・書斎 TO P728仙人的宅邸・空的部屋
			RETURN P723仙人的宅邸・二階客間
		CASEELSE
			RETURN P730仙人的宅邸・庭
		ENDSELECT
	CASE P720仙人的宅邸・廚房 TO P722仙人的宅邸・道場
		RETURN P729仙人的宅邸・玄関
	CASE P723仙人的宅邸・二階客間
		SELECTCASE 現在的位置
		CASE P727仙人的宅邸・華扇私室 TO P728仙人的宅邸・空的部屋
			RETURN P726仙人的宅邸・居間
		CASEELSE
			RETURN P729仙人的宅邸・玄関
		ENDSELECT
	CASE P724仙人的宅邸・書斎, P725仙人的宅邸・大鷲的房間, P726仙人的宅邸・居間
		RETURN P723仙人的宅邸・二階客間
	CASE P727仙人的宅邸・華扇私室, P728仙人的宅邸・空的部屋
		RETURN P726仙人的宅邸・居間
		
	;锦上京部分
	CASE P758化石深道
		RETURN P755化石丛林荒地
	CASE P755化石丛林荒地
		RETURN P752四季竖穴
	CASE P752四季竖穴
		SELECTCASE 現在的位置
		CASE P755化石丛林荒地 TO P760磐永神社内屋
			RETURN P755化石丛林荒地
		CASEELSE
			RETURN P751浅间净秽山
		ENDSELECT
	CASE P751浅间净秽山
		SELECTCASE 現在的位置
		CASE P752四季竖穴 TO P762空房间
			RETURN P752四季竖穴
		CASEELSE
			RETURN P749山中密道
		ENDSELECT
	CASE P750驯子的小屋
		SELECTCASE 現在的位置
		CASE P751浅间净秽山 TO P762空房间
			RETURN P751浅间净秽山
		CASEELSE
			RETURN P749山中密道
		ENDSELECT
	CASE P749山中密道
		SELECTCASE 現在的位置
		CASE P751浅间净秽山 TO P762空房间
			RETURN P751浅间净秽山
		CASEELSE
			RETURN P747圣域深道
		ENDSELECT
	CASE P748魑魅的草棚
		SELECTCASE 現在的位置
		CASE P750驯子的小屋 TO P762空房间
			RETURN P749山中密道
		CASEELSE
			RETURN P747圣域深道
		ENDSELECT
	CASE P747圣域深道
		SELECTCASE 現在的位置
		CASE P750驯子的小屋 TO P762空房间
			RETURN P749山中密道
		CASEELSE
			RETURN P743圣域林道
		ENDSELECT
	CASE P743圣域林道
		SELECTCASE 現在的位置
		CASE P746姥芽大宅 TO P762空房间
			RETURN P747圣域深道
		CASEELSE
			RETURN P736圣域入口
		ENDSELECT
	CASE P736圣域入口
		SELECTCASE 現在的位置
		CASE P743圣域林道 TO P762空房间
			RETURN P743圣域林道
		CASEELSE
			RETURN P707山道・分岐点
		ENDSELECT
ENDSELECT
