;-----------------------------------------------------------
;基礎変更
;ARG:0 キャラ登録番号
;ARG:1 0=体力減少, 1=体力増加, 2=気力減少, 3=気力増加,
;4=体力大減少, 5=体力大増加, 6=気力大減少, 7=気力大増加 (Debug)
;8, 9, 10, 11 = TSP MAXBASE変更 (Debug)
;-----------------------------------------------------------
@CUSTOM_BASE(ARG, ARG:1, DEBUG = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DEBUG
SELECTCASE ARG:1
	CASE 0
		MAXBASE:ARG:体力 -= 100
	CASE 1
		MAXBASE:ARG:体力 += 100
	CASE 2
		MAXBASE:ARG:気力 -= 100
	CASE 3
		MAXBASE:ARG:気力 += 100
	CASE 4
		MAXBASE:ARG:体力 -= 500
	CASE 5
		MAXBASE:ARG:体力 += 500
	CASE 6
		MAXBASE:ARG:気力 -= 500
	CASE 7
		MAXBASE:ARG:気力 += 500
	CASE 8
		SIF IS_MASTER(ARG) && DEBUG
			MAXBASE:ARG:TSP -= 500
	CASE 9
		SIF IS_MASTER(ARG) && DEBUG
			MAXBASE:ARG:TSP -= 100
	CASE 10
		SIF IS_MASTER(ARG) && DEBUG
			MAXBASE:ARG:TSP += 100
	CASE 11
		SIF IS_MASTER(ARG) && DEBUG
			MAXBASE:ARG:TSP += 500
ENDSELECT

MAXBASE:ARG:体力 = LIMIT(MAXBASE:ARG:体力, 1000, DEBUG ? 10000 # 2500)
BASE:ARG:体力 = MAXBASE:ARG:体力

MAXBASE:ARG:気力 = LIMIT(MAXBASE:ARG:気力, 1000, DEBUG ? 10000 # 2500)
BASE:ARG:気力 = MAXBASE:ARG:気力

IF IS_MASTER(ARG) && DEBUG
	MAXBASE:ARG:TSP = LIMIT(MAXBASE:ARG:TSP, 100, 10000)
	BASE:ARG:TSP = MAXBASE:ARG:TSP
ENDIF

