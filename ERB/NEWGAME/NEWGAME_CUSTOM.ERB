@CUSTOM_ABL(ARG, ARG:1, DEBUG = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DEBUG
#DIM MAX_ABL
#DIM TARGET_ABL
#DIM DYNAMIC DIRECT_INPUT_MODE

IF ARG < 200
	TARGET_ABL = ARG
	DIRECT_INPUT_MODE = 1
ELSE
	TARGET_ABL = (ARG - 200) / 2
ENDIF
;例外処理
SIF CUSTOM_選べない能力(TARGET_ABL, ARG:1, DEBUG)
	RETURN 0

IF DEBUG
	IF TARGET_ABL < 40
		MAX_ABL = 99
	ELSE
		MAX_ABL = 6
	ENDIF
ELSE
	MAX_ABL = 2
ENDIF

IF DIRECT_INPUT_MODE
	PRINTFORML 请输入%ABL_TR(TARGET_ABL)%的等级（范围：0～{MAX_ABL}）
	INPUT
	ABL:(ARG:1):TARGET_ABL = RESULT
ELSE
	;増減と正常化
	;奇数(+)
	IF ARG % 2
		ABL:(ARG:1):TARGET_ABL ++
	;偶数(-)
	ELSE
		ABL:(ARG:1):TARGET_ABL --
	ENDIF
ENDIF


ABL:(ARG:1):TARGET_ABL = LIMIT(ABL:(ARG:1):TARGET_ABL, 0, MAX_ABL)

RETURN 1

