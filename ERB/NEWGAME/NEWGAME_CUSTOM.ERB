;好感・信頼変更（debug用）
;-----------------------------------------------------------
@CUSTOM_FAVOR_TRUST(ARG, DEBUG = 0)
#LOCALSIZE 2
#LOCALSSIZE 1
#DIM DEBUG
#DIM DYNAMIC LINECOUNT_HEAD
#DIM CONST BUTTON_VALUES = 0, 500, 1500, 3000, 10000, 50000, 300000

SIF IS_MASTER(ARG)
	RETURN

LINECOUNT_HEAD = LINECOUNT
FOR LOCAL, 0, 2
	CLEARLINE LINECOUNT - LINECOUNT_HEAD
	LOCALS '= \@ !LOCAL ? 好感度 # 信頼度 \@

	PRINTFORML 输入或者通过按钮选择%LOCALS%的值
	IF LOCALS == "信頼度"
		PRINTFORM [{CFLAG:ARG:信頼度, 6, RIGHT}]
	ELSE
		PRINTFORM [{CFLAG:ARG:好感度, 6, RIGHT}]
	ENDIF
	FOR LOCAL:1, 0, VARSIZE("BUTTON_VALUES")
		PRINTFORM  
		PRINTFORM [{BUTTON_VALUES:(LOCAL:1), 6, RIGHT}]
	NEXT
	INPUT
	IF LOCALS == "信頼度"
		CFLAG:ARG:信頼度 = RESULT
	ELSE
		CFLAG:ARG:好感度 = RESULT
	ENDIF
NEXT

