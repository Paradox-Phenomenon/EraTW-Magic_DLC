@CUSTOM_TALENT(inputed, chara, DEBUG = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM inputed
#DIM chara
#DIM DEBUG
#DIM RACE_COUNT

SIF inputed < 0 || inputed > 500
	RETURN 0
SIF TALENTNAME:inputed == ""
	RETURN 0
SIF CUSTOM_選べない素質(inputed, chara, DEBUG)
	RETURN 0

SELECTCASE TALENTNAME:inputed
	;addition custom code, but this looks like it should be on JP as well
	CASE "氷精" ;female only for yuki onna
		IF !IS_FEMALE(CHARA)
			TALENT:chara:inputed = !TALENT:chara:inputed
		ELSE
			IF TALENT:chara:inputed == 2
				TALENT:chara:inputed = 0
			ELSE
				TALENT:chara:inputed ++
			ENDIF
		ENDIF
	CASE "人类" ;button handling
		IF TALENT:chara:inputed == 6
			TALENT:chara:inputed = 0
		ELSE
			TALENT:chara:inputed ++
		ENDIF
	CASE "人妻" ;button handling
		IF TALENT:chara:inputed == 2
			TALENT:chara:inputed = 0
		ELSE
			TALENT:chara:inputed ++
		ENDIF
	CASE "幽霊" ;button handling
		IF TALENT:chara:inputed == 4
			TALENT:chara:inputed = 0
		ELSE
			TALENT:chara:inputed ++
		ENDIF
	CASE "妖怪" ;skip vampire
		IF TALENT:chara:inputed == 2
			TALENT:chara:inputed = 4
		ELSEIF TALENT:chara:inputed == 12
			TALENT:chara:inputed = 0
			;TALENT:chara:inputed = 90
		ELSE
			TALENT:chara:inputed ++
		ENDIF
	CASE "神霊" ;前两个可以扮演
		IF TALENT:chara:inputed == 2
			TALENT:chara:inputed = 0
		ELSE
			TALENT:chara:inputed ++
		ENDIF
	CASE "人形" ;skip puppet maiden
		IF TALENT:chara:inputed == 5
			TALENT:chara:inputed = 0
		ELSE
			TALENT:chara:inputed ++
		ENDIF
	CASE "追加種族" ;female only for shrine maiden/maid, skip hourai
		IF TALENT:chara:inputed == 0 && !IS_FEMALE(CHARA)
			TALENT:chara:inputed = 2
		ELSEIF TALENT:chara:inputed == 2 && !IS_FEMALE(CHARA)
			TALENT:chara:inputed = 0
		ELSEIF TALENT:chara:inputed == 3
			TALENT:chara:inputed = 0
		ELSE
			TALENT:chara:inputed ++
		ENDIF

	CASE "処女"
		IF TALENT:chara:処女 == 1
			TALENT:chara:処女 = 0
		ELSE
			TALENT:chara:処女++
		ENDIF
	CASE "Ｍ感度"
		IF TALENT:chara:Ｍ感度 == 1
			TALENT:chara:Ｍ感度 = -1
		ELSE
			TALENT:chara:Ｍ感度++
		ENDIF
	CASE "動物耳"
		IF TALENT:chara:動物耳 == 4
			TALENT:chara:動物耳 = 0
		ELSE
			TALENT:chara:動物耳++
		ENDIF
	
	;先に例外処理
	CASE "性別"
		IF TALENT:chara:性別 == 3
			TALENT:chara:性別 = 1
		ELSE
			TALENT:chara:性別 ++
		ENDIF
		CALL CUSTOM_INIT(chara)
	CASE "性別嗜好"
		IF TALENT:chara:inputed == 3
			TALENT:chara:inputed = -1
		ELSE
			TALENT:chara:inputed ++
		ENDIF
	CASE "体型"
		;体型が「小人(-5)」と「巨人(3)」の場合を独立処理
		IF TALENT:chara:inputed == -5
			TALENT:chara:inputed = -2
		ELSEIF TALENT:chara:inputed == 5
			TALENT:chara:inputed = -5
		ELSEIF TALENT:chara:inputed == 2
			TALENT:chara:inputed = 5
		ELSE
			TALENT:chara:inputed ++
		ENDIF
	CASE "非童貞", "キス未経験"
		TALENT:chara:inputed = !TALENT:chara:inputed
	CASE "母乳体質"
		TALENT:chara:母乳体質 = !TALENT:chara:母乳体質
		IF TALENT:chara:母乳体質
			MAXBASE:chara:母乳 = 2000
		ELSE
			MAXBASE:chara:母乳 = 0
		ENDIF
	;汎用処理
	CASEELSE
		;真偽型の素質は反転
		IF NAME_TR(TALENTNAME:inputed) == GET_TALENTNAME(inputed,1)
			TALENT:chara:inputed = !TALENT:chara:inputed
		ELSE
		;他は端まで行くと-1を掛ける
			IF STRLENS(GET_TALENTNAME(inputed,TALENT:chara:inputed + 1)) || TALENT:chara:inputed == -1
				TALENT:chara:inputed ++
			ELSE
				TALENT:chara:inputed *= -1
				SIF !STRLENS(GET_TALENTNAME(inputed, TALENT:chara:inputed))
					TALENT:chara:inputed ++
			ENDIF
		ENDIF
ENDSELECT

