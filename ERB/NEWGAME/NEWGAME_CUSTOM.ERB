;キャラカスタマイズ
;-----------------------------------------------------------
@CUSTOM_TERMINAL(ARG, HIKITSUGI, DEBUG = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM HIKITSUGI
#DIM nLineCnt_Head
#DIM DEBUG

CALL CUSTOM_INIT(ARG)

nLineCnt_Head = LINECOUNT
REDRAW 0
DO
SIF LINECOUNT - nLineCnt_Head > 0
	CLEARLINE LINECOUNT - nLineCnt_Head
		
;名前ボタン表示
DRAWLINE
CALL CUSTOM_NAME_BUTTON(ARG)
DRAWLINE
;好感・信頼表示（debug用）
IF !IS_MASTER(ARG)
	CALL PRINT_STATE_FAVOR_TRUST(ARG)
	IF DEBUG
		SETCOLOR 0x70C070
		PRINTBUTTON "[好感·信赖的编辑]", 999
		RESETCOLOR
	ENDIF
	PRINTL
ENDIF
;基礎ボタン付き表示
CALL CUSTOM_BASE_BUTTON(ARG, DEBUG)
;能力・性技表示
CALL PRINT_STATE_ABL(ARG)
PRINTL
CALL COLORMESSAGE(@"　[2000] 能力编辑",0x70C070,1)
;素質表示
CALL PRINT_STATE_TALENT(ARG)
PRINTL
SIF MAGIC_DLC_START
	CALL COLORMESSAGE(@"　[2500] 种族编辑",0x70C070,1)
CALL COLORMESSAGE(@"　移到素质名上查看提示哦",C_YELLOW,1) ;qol custom code
CALL COLORMESSAGE(@"　[3000] 素质编辑",0x70C070,1)
;経験表示
CALL PRINT_STATE_EXP(ARG)
PRINTL
CALL COLORMESSAGE(@"　[4000] 经验编辑",0x70C070,1)
IF HIKITSUGI
	CALL COLORMESSAGE(@"　[5000] 设置周目继承",0x70C070,1)
ENDIF
DRAWLINE
PRINTL 　[9999] 设定完毕
PRINTL
INPUT
SELECTCASE RESULT
	CASE 9999
		PRINTL 这样真的可以吗？
		CALL ASK_YN()
		SIF !RESULT
			RETURN 1
	;NAME
	CASE 0 TO 998
		CALL CUSTOM_NAME(ARG, RESULT)
	CASE 999
		SIF !IS_MASTER(ARG) && DEBUG
			CALL CUSTOM_FAVOR_TRUST(ARG, DEBUG)
	;BASE
	CASE 1000 TO 1999
		CALL CUSTOM_BASE(ARG, RESULT - 1000, DEBUG)
	;ABL
	CASE 2000
		CALL CUSTOM_MENU("ABL", ARG, DEBUG)
	;TALENT
	CASE 3000
		CALL CUSTOM_MENU("TALENT", ARG, DEBUG)
		CALL CUSTOM_INIT(ARG)
	;EXP
	CASE 2500
		SIF MAGIC_DLC_START
			CALL CUSTOM_RACE_MENU(ARG)
	CASE 4000
		CALL CUSTOM_MENU("EXP", ARG, DEBUG)
		CALL CUSTOM_INIT(ARG)
	CASE 5000
		SIF HIKITSUGI
			CALL SAVE_CUSTOM_TALENT(ARG, "恋人")
ENDSELECT
LOOP 1
;-----------------------------------------------------------
;排他処理
;-----------------------------------------------------------
@CUSTOM_INIT(ARG)
#LOCALSIZE 2
#LOCALSSIZE 1
#DIM nTalentCheck = 90,91,164,165,166,189,191,192,193,194,195,196,197
;ARGが女、扶她時の排他
IF TALENT:ARG:性別 & 1
	ABL:ARG:断袖属性 = 0
	ABL:ARG:断袖中毒 = 0
	EXP:ARG:断袖経験 = 0
	IF !(TALENT:ARG:2 & 2)
		EXP:ARG:射精経験 = 0
		EXP:ARG:挿入経験 = 0
	ENDIF
	SIF TALENT:ARG:性別 != 1
		TALENT:ARG:具現 = 0
;ARGが男時の排他
ELSE
	ABL:ARG:Ｖ感覚 = 0
	ABL:ARG:百合属性 = 0
	ABL:ARG:百合中毒 = 0
	EXP:ARG:百合経験 = 0
	EXP:ARG:噴乳経験 = 0
	EXP:ARG:Ｖ経験 = 0
	EXP:ARG:乳交経験 = 0
	EXP:ARG:Ｖ性交経験 = 0
	EXP:ARG:Ｖ拡張経験 = 0
	EXP:ARG:子宮口開発経験 = 0
	TALENT:ARG:Ｖ感度 = 0
	TALENT:ARG:処女 = 0
	TALENT:ARG:母乳体質 = 0
	TALENT:ARG:胸围 = -2
	TALENT:ARG:風騷 = 0
	TALENT:ARG:初潮 = 0
	TALENT:ARG:具現 = 0
ENDIF
;チ○コ
IF TALENT:ARG:2 & 2
	MAXBASE:ARG:精力 = 1000
	BASE:ARG:精力 = 1000
	MAXBASE:ARG:勃起 = 1500
	SIF TALENT:ARG:絶倫
		MAXBASE:ARG:勃起 *= 2
	;実績ボーナス分
	SIF ARG == MASTER
		CALL Pc_Vig_Recover(MASTER)
ELSE
	TALENT:ARG:非童貞 = 0
	MAXBASE:ARG:精力 = 0
	BASE:ARG:精力 = 0
	MAXBASE:ARG:勃起 = 0
	TALENT:ARG:形状 = 0
ENDIF
;処女ならV系経験無し
IF TALENT:ARG:処女 == 1
	ABL:ARG:Ｖ感覚 = 0
	EXP:ARG:Ｖ経験 = 0
	EXP:ARG:Ｖ性交経験 = 0
	EXP:ARG:Ｖ拡張経験 = 0
	EXP:ARG:子宮口開発経験 = 0
	CSTR:ARG:処女喪失履歴 = 
	CFLAG:ARG:処女喪失記念日 = 0
	CFLAG:ARG:処女喪失対象 = 0
	EXP:ARG:膣射経験 = 0
	CFLAG:ARG:累計膣内精液 = 0
;非処女はV経験１
ELSEIF TALENT:ARG:2 & 1 && EXP:ARG:Ｖ経験 == 0
	EXP:ARG:Ｖ経験 = 1
ENDIF

;初吻
IF !EXP:ARG:接吻経験 || TALENT:ARG:キス未経験
	TALENT:ARG:キス未経験 = 1
	EXP:ARG:キス経験 = 0
	CSTR:ARG:ファーストキス喪失履歴 =
	CFLAG:ARG:ファーストキス喪失記念日 = 0
	CFLAG:ARG:ファーストキス喪失相手 = 0
	CFLAG:ARG:ファーストキス喪失対象 = 0
ELSE
	TALENT:ARG:キス未経験 = 0
ENDIF

IF IS_DOUTEI(ARG)
	EXP:ARG:挿入経験 = 0
	CSTR:ARG:童貞喪失履歴 =
	CFLAG:ARG:童貞喪失記念日 = 0
	CFLAG:ARG:童貞喪失相手 = 0
ELSEIF HAS_PENIS(ARG) && EXP:ARG:挿入経験 == 0
	EXP:ARG:挿入経験 = 1
ENDIF

IF !EXP:ARG:Ａ性交経験
	CSTR:ARG:アナル処女喪失履歴 =
	CFLAG:ARG:アナル処女喪失記念日 = 0
	CFLAG:ARG:アナル処女喪失対象 = 0
	CFLAG:ARG:アナル処女喪失相手 = 0
ENDIF

;set PC to human unless other racial traits were chosen
IF ARG == 0
	;female only races
	SIF TALENT:ARG:氷精 == 2 && IS_MALE(ARG)
		TALENT:ARG:氷精 = 0
	SIF TALENT:ARG:追加種族 == 1 && IS_MALE(ARG)
		TALENT:ARG:追加種族 = 0
	SIF TALENT:ARG:追加種族 == 3 && IS_MALE(ARG)
		TALENT:ARG:追加種族 = 0
	SIF TALENT:ARG:人妻 && IS_MALE(ARG)
		TALENT:ARG:人妻 = 0

	LOCAL:1 = 0
	FOR LOCAL, 0, VARSIZE("nTalentCheck")
		SIF TALENT:ARG:(nTalentCheck:LOCAL)
			LOCAL:1 = 1
	NEXT
	SIF !LOCAL:1 && !TALENT:ARG:人間 ;automatically attach human if no other races present
		TALENT:ARG:人間 = 1
ENDIF

