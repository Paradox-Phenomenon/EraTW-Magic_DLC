@CUSTOM_選べない能力(argAbl, ARG, DEBUG = 0)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM argAbl
#DIM DEBUG

#FUNCTION
;個別処理
SELECTCASE ABLNAME:argAbl
	;未使用
	CASE ""
		RETURNF 1
	;時間停止
	CASE "TSLv"
		RETURNF 1
	;同性愛関係
	CASE "百合属性", "百合中毒"
		SIF !(TALENT:ARG:2 & 1)
			RETURNF 1
	CASE "断袖属性", "断袖中毒"
		SIF TALENT:ARG:2 & 1
			RETURNF 1
ENDSELECT
IF !DEBUG
	;汎用処理
	SELECTCASE argAbl
		;中毒関係
		CASE 30 TO 39
			RETURNF 1
		;生活系
		CASE 40 TO 49
			RETURNF 1
		;性技
		CASE 50 TO 59
			RETURNF 1
	ENDSELECT
ENDIF
RETURNF 0

;-----------------------------------------------------------
;素質変更
;-----------------------------------------------------------
@CUSTOM_TALENT_MENU(ARG, DEBUG = 0)
#LOCALSIZE 2
#LOCALSSIZE 2
#DIM DEBUG
VARSET LOCAL
FOR LOCAL, 0, 200
	IF CUSTOM_選べない素質(LOCAL, ARG, DEBUG) == 1
		CONTINUE
	ELSEIF CUSTOM_選べない素質(LOCAL, ARG, DEBUG) == 2
		;表示はさせる
		SETCOLOR 50, 50, 50
		LOCALS = [{LOCAL,3}]%TALENT_TR(LOCAL)%
		GOTO SKIP
	ENDIF
	SETCOLOR 150, 150, 150
	SIF TALENTNAME:LOCAL == ""
		CONTINUE
	SELECTCASE NAME_TR(TALENTNAME:LOCAL)
	;TALENT.CSVに登録されていない
	CASE ""
		CONTINUE
	;exceptions for listing
	CASE NAME_TR("氷精"), NAME_TR("人类"), NAME_TR("妖怪"), NAME_TR("神霊"), NAME_TR("幽霊"), NAME_TR("人形"), NAME_TR("人妻"), NAME_TR("音感"), NAME_TR("動物耳")
		GOTO LIST
	;オンオフ型の素質(TALENTNAMEと素質表示が一致)
	CASE GET_TALENTNAME(LOCAL,1)
		SIF TALENT:ARG:LOCAL
			SETCOLOR C_AQUA
		LOCALS = [{LOCAL,3}]%TALENT_TR(LOCAL)%
	CASE NAME_TR("非童貞")
		SIF !TALENT:ARG:LOCAL
			SETCOLOR C_AQUA
		LOCALS = [{LOCAL,3}]童贞
	CASE NAME_TR("キス未経験")
		SIF !TALENT:ARG:LOCAL
			SETCOLOR C_AQUA
		LOCALS = [{LOCAL,3}]%TALENT_TR(LOCAL)%
	;量的素質
	CASEELSE
		$LIST
		LOCALS =  [{LOCAL,3}]%TALENT_TR(LOCAL)%
		IF STRLENS(GET_TALENTNAME(LOCAL, TALENT:ARG:LOCAL))
			LOCALS:1 = 【%GET_TALENTNAME(LOCAL, TALENT:ARG:LOCAL)%】
			SETCOLOR C_AQUA
		ELSEIF TALENTNAME:LOCAL == "性別"
			LOCALS:1 = 【女性】
			SETCOLOR C_AQUA
		ELSE
			LOCALS:1 = 【－】
		ENDIF
		;LOCALS is used for string comparison earlier
		LOCALS =  [{LOCAL,3}]%TALENT_TR(LOCAL)%
		LOCALS += LOCALS:1
	ENDSELECT
	$SKIP
	IF (!DEBUG && (LOCAL:1 % 3 == 0)) || (DEBUG && (LOCAL:1 % 4 == 0))
		PRINTL 
		PRINT   
	ENDIF
	IF CUSTOM_選べない素質(LOCAL, ARG, DEBUG) == 2
		PRINTPLAINFORM %LOCALS, 30, LEFT%
	ELSE
		PRINTFORM %LOCALS, 30, LEFT%
	ENDIF
	LOCAL:1 ++
NEXT

