;-----------------------------------------------------------
;名前変更ボタン
;-----------------------------------------------------------
@CUSTOM_NAME_BUTTON(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS CONST colortext = "<font color='#70C070'>[变更]</font>"
#DIMS html
;名前
html '= @"<button value='{0}'>" + HTML_SPACE(2) + @"名字：%NAME:ARG%"+ HTML_SPACE(2) + colortext + "</button>"
html += HTML_SPACE(4)
;呼び名
html += @"<button value='{1}'>" + @"称呼：%CALLNAME:ARG%"+ HTML_SPACE(2) + colortext + "</button>"
HTML_PRINT html + "<br><br>"

@CUSTOM_NAME(ARG, ARG:1)
#LOCALSIZE 1
#LOCALSSIZE 1
SELECTCASE ARG:1
	CASE 0
		PRINTL
		PRINTFORML 现在的名字是%NAME:ARG%。
		PRINTFORML 想要变更的话请输入新的名字。(留空为取消)
		PRINTL
		INPUTS
		IF RESULTS != ""
			NAME:ARG '= RESULTS
			PRINTFORMW 已变更。现在的名字是%NAME:ARG%。
		ENDIF
	CASE 1
		PRINTL
		PRINTFORML 现在的称呼是%CALLNAME:ARG%。
		PRINTFORML 想要变更的话请输入新的称呼。(留空为取消)
		PRINTL
		INPUTS
		IF RESULTS != ""
			CALLNAME:ARG '= RESULTS
			PRINTFORMW 已变更。现在的称呼是%CALLNAME:ARG%。
		ENDIF
ENDSELECT

