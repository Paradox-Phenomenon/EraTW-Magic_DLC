@CUSTOM_ABL_MENU(ARG, DEBUG = 0)
#LOCALSIZE 2
#LOCALSSIZE 1
#DIM DEBUG
LOCAL:1 = 0

PRINTFORML 点击想要更改的能力并直接输入目标等级，或者点击按钮。
