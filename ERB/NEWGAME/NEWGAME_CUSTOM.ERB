	CASE GETNUM(TALENT, "非童貞")
		SIF !GETBIT(TALENT:CHARA:性別, 1)
			RETURNF 2
	;男性器があると選べない
	CASE GETNUM(TALENT, "具現")
		SIF GETBIT(TALENT:CHARA:性別, 1)
			RETURNF 2
	;你以外は選べない
	CASE GETNUM(TALENT, "年齢")
		SIF CHARA != NO:MASTER
			RETURNF 1
	;全員選べないが表示はする
	CASE GETNUM(TALENT, "キス未経験")
		RETURNF 2
	;全員選べない１
	CASE GETNUM(TALENT, "恋慕") TO GETNUM(TALENT, "思慕"), GETNUM(TALENT, "心情"), GETNUM(TALENT, "容姿"), GETNUM(TALENT, "把柄"), GETNUM(TALENT, "調合知識"), GETNUM(TALENT, "調合Lv"), GETNUM(TALENT, "採集Lv"), GETNUM(TALENT, "釣りLv"), GETNUM(TALENT, "伐採Lv")
		SIF DEBUG
			RETURNF 0
		RETURNF 1
	;全員選べない２
	CASE GETNUM(TALENT, "自慰狂") TO GETNUM(TALENT, "子宮口性感"), GETNUM(TALENT, "迷信"), GETNUM(TALENT, "嫉妬"), GETNUM(TALENT, "濃厚精液"), GETNUM(TALENT, "精愛味覚"), GETNUM(TALENT, "禁断的知識"), GETNUM(TALENT, "精力超群") TO GETNUM(TALENT, "母性")
		SIF DEBUG
			RETURNF 0
		RETURNF 1
	;女性器があって幼児か幼稚がないと選べない
	CASE GETNUM(TALENT, "初潮")
		SIF !IS_FEMALE(CHARA)
			RETURNF 2
		SIF DEBUG
			RETURNF 0
		SIF !TALENT:CHARA:幼児／幼児退行 && !TALENT:CHARA:幼稚
			RETURNF 2
ENDSELECT
RETURNF 0

