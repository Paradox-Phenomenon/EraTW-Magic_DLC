;-----------------------------------------------------------
;処女設定
;-----------------------------------------------------------
;-----------------------------------------------------------
;処女設定メニュー
;-----------------------------------------------------------
@VIRGIN_SET
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS choices, 11
PRINTL 
PRINTL 在游戏开始前可以变更对角色的处女・非处女 ＋ futa化与否＆形状进行个别设定（若体型设定里选全员futa化,此处的形状设定会失效）
PRINTL 全体设定即可对所有人生效
DRAWLINE
VARSET choices
choices:0 '= "个别设定"
choices:1 '= "全员都不知道什么叫做爱"
choices:2 '= "你是笨蛋吗肯定得全员处女啊"
choices:3 '= "幻想少女很长寿所以肯定经验丰富吧"
choices:4 '= "干脆全部都变的风骚吧"
choices:5 '= "虽然全员都是处女但是裤腰带都很松"
choices:9 '= "不管是不是处女都很想受孕的样子"
SIF 全員の貞操
	choices:全員の貞操 '= "<font color='#67e47e'>(有效)</font>" + choices:全員の貞操
SIF 全員の貞操 ||SUMCARRAY(初期貞操)
	choices:10 '= "全员恢复初始设定"

CALL ASK_CHOICES(choices, 100, "结束")
SELECTCASE RESULT
	;システム
	CASE 0
		CALL SET_VIRGINITY
	CASE 10
		CVARSET 初期貞操
		VARSET 全員の貞操
		PRINTW 在全员初始设定的状态下开始游戏。
	CASE 100
		PRINTW 设定完毕。
		RETURN
	CASE IS == 全員の貞操
		全員の貞操 = 0
		PRINTW 全体设定无效了。
	;貞操
	CASE 1
		全員の貞操 = RESULT
		PRINTW 小兔姬在此。
		PRINTW 在全员无知处女的状态下开始游戏。
	CASE 2
		全員の貞操 = RESULT
		PRINTW 你个处女厨！
		PRINTW 在全员处女的状态下开始游戏。
	CASE 3
		全員の貞操 = RESULT
		PRINTW 在全员非处女的状态下开始游戏。
	CASE 4
		全員の貞操 = RESULT
		PRINTW 在全员风骚的状态下开始游戏。
	CASE 5
		PRINTFORMW 麻烦的家伙。
		全員の貞操 = RESULT
		PRINTW 在全员风骚处女的状态下开始游戏。
	CASE 9
		全員の貞操 = RESULT
		PRINTW 在全员渴望受孕的状态下开始游戏。	
	CASEELSE
		THROW 无效输入。
ENDSELECT
RESTART

;-----------------------------------------------------------
;个別設定
;-----------------------------------------------------------
@SET_VIRGINITY
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA_ID
FOR CHARA_ID, 0, CHARANUM
	SIF !IS_NAMED(CHARA_ID)
		CONTINUE
	SIF TALENT:CHARA_ID:処女
		SETCOLOR C_PINK
	SIF TALENT:CHARA_ID:風騷
		SETCOLOR C_P_BLUE
	LOCALS '= @"[{CHARA_ID, 3}] %SET_VIRGINITY_KEY(初期貞操:CHARA_ID:0)%%CALLNAME:CHARA_ID%"
	PRINTFORMLC %LOCALS%
	RESETCOLOR
NEXT
PRINTL
DRAWLINE
PRINTL [999] 设定结束
DO
	INPUT
	CHARA_ID = RESULT
	SELECTCASE CHARA_ID
		CASE 999
			PRINTW 个别设定完毕。
			RETURN
		CASEELSE
			IF !IS_NAMED(CHARA_ID)
				CLEARLINE 1
				CONTINUE
			ENDIF
			BREAK
	ENDSELECT
LOOP 1

初期貞操:CHARA_ID:0 ++
IF 初期貞操:CHARA_ID:0 >= 8 && 初期貞操:CHARA_ID:0 < 10
	初期貞操:CHARA_ID:0 = 9
ELSEIF 初期貞操:CHARA_ID:0 >= 10
	初期貞操:CHARA_ID:0 = 0
ENDIF

SELECTCASE 初期貞操:CHARA_ID:0
	CASE 0
		PRINTFORMW %CALLNAME:CHARA_ID%的能力恢复为了初始设定
	CASE 1
		PRINTFORMW %CALLNAME:CHARA_ID%变成无知处女了
	CASE 2
		PRINTFORMW %CALLNAME:CHARA_ID%变成处女了
	CASE 3
		PRINTFORMW %CALLNAME:CHARA_ID%变成非处了
	CASE 4
		PRINTFORMW %CALLNAME:CHARA_ID%变得风骚了
	CASE 5
		PRINTFORMW %CALLNAME:CHARA_ID%变成风骚处女了
	CASE 6
		PRINTFORMW %CALLNAME:CHARA_ID%变成扶她
	CASE 7
		PRINTFORMW %CALLNAME:CHARA_ID%变成扶她处女
	CASE 9 
		PRINTFORMW %CALLNAME:CHARA_ID%变得渴望受孕了
	CASEELSE
		THROW 贞操设定不适当
ENDSELECT
RESTART
;-----------------------------------------------------------
;設定略語
;-----------------------------------------------------------
@SET_VIRGINITY_KEY(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
SELECTCASE ARG
	CASE 0
		RETURNF ""
	CASE 1
		RETURNF "[无知]"
	CASE 2
		RETURNF "[处女]"
	CASE 3
		RETURNF "[熟练]"
	CASE 4
		RETURNF "[风骚]"
	CASE 5
		RETURNF "[骚处]"
	CASE 6
		RETURNF "[扶她]"
	CASE 7
		RETURNF "[双处]"
	CASE 9
		RETURNF "[渴求受孕]"
	CASEELSE
		THROW 贞操设定不适当
ENDSELECT
;-----------------------------------------------------------
;処女設定適用
;-----------------------------------------------------------
@VIRGIN_SET_APPLY
#LOCALSIZE 1
#LOCALSSIZE 1
FOR LOCAL, 1, CHARANUM
	IF 初期貞操:LOCAL:0
		CALL VIRGIN_SET_APPLY_PART(LOCAL, 初期貞操:LOCAL:0)
	ELSE
		CALL VIRGIN_SET_APPLY_PART(LOCAL, 全員の貞操)
	ENDIF
NEXT

;-----------------------------------------------------------
;-----------------------------------------------------------
@VIRGIN_SET_APPLY_PART(ARG, ARG:1)
#LOCALSIZE 1
#LOCALSSIZE 1
SELECTCASE ARG:1
	CASE 0
	CASE 1
		CALL SET_VIRGIN(ARG:1)
		TALENT:ARG:無知 = 1
	CASE 2
		CALL SET_VIRGIN(ARG)
	CASE 3
		CALL SET_WELL_EXP(ARG)
	CASE 4
		CALL SET_YARIMAN(ARG)
	CASE 5
		CALL SET_VIRGIN(ARG)
		SIF TALENT:ARG:性別嗜好 == 1
			TALENT:ARG:性別嗜好 = 0
		ABL:ARG:欲望 = 3
		TALENT:ARG:風騷 = 1
		TALENT:ARG:貞操 = -1
	CASE 6
		CALL SET_FUTANARI(ARG)
		SIF 全員扶她化 != 1
			CALL TINKO_DECIDE(ARG)
	CASE 7
		CALL SET_VIRGIN(ARG)
		CALL SET_FUTANARI(ARG)
		SIF 全員扶她化 != 1
			CALL TINKO_DECIDE(ARG)
	CASE 9
		TALENT:ARG:無知 = 0
		SIF TALENT:ARG:性別嗜好 == 1
			TALENT:ARG:性別嗜好 = 0
		TALENT:ARG:妊娠願望 = 1
		SIF TALENT:ARG:幼稚 == 1
			TALENT:ARG:初潮 = 1
		TALENT:ARG:一線越えない = 0
		TALENT:ARG:献身的 = 1
		ABL:ARG:膣射中毒 = 3
CASEELSE
	THROW 贞操设定不适当
ENDSELECT

;-----------------------------------------------------------
;体型変更
;-----------------------------------------------------------
@BODY_SET
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS choices, 11
PRINTL 
PRINTL 游戏开始前可以变更角色的体型素质
PRINTL 可以同时选择复数的设定
DRAWLINE
VARSET choices
;ロリ
choices:1 '= "全员都变成萝莉吧"
SIF 全員ロリ化
	choices:1 '= "<font color='#67e47e'>(有效)</font>" + choices:1
;小人
choices:2 '= "全员都变成小人吧"
SIF 全員小人化
	choices:2 '= "<font color='#67e47e'>(有效)</font>" + choices:2
;動物耳
choices:3 '= "全员兽耳"
SIF 全員動物耳化
	choices:3 '= "<font color='#67e47e'>(有效)</font>" + choices:3
;扶她
choices:4 '= "全员长出小鸡鸡"
SIF 全員扶她化
	choices:4 '= "<font color='#67e47e'>(有效)</font>" + choices:4
;母乳體質
choices:5 '= "全员分泌乳汁"
SIF 全員母乳體質化
	choices:5 '= "<font color='#67e47e'>(有效)</font>" + choices:5
;リセット
IF 全員ロリ化 || 全員小人化 || 全員動物耳化 || 全員扶她化 || 全員母乳體質化
	choices:10 '= "全员恢复初始设定"
ELSE
	choices:10 '= "全员萝莉+小人+兽耳"
ENDIF
CALL ASK_CHOICES(choices, 100, "结束")
SELECTCASE RESULT
	CASE 10
		IF 全員ロリ化 || 全員小人化 || 全員動物耳化 || 全員扶她化 || 全員母乳體質化
			全員ロリ化 = 0
			全員小人化 = 0
			全員動物耳化 = 0
			全員扶她化 = 0
			全員母乳體質化 = 0
			PRINTW 设定重置了。
		ELSE
			全員ロリ化 = 1
			全員小人化 = 1
			全員動物耳化 = 1
			全員扶她化 = 1
			PRINTW 以全员都变成长兽耳的萝莉小人的状态下开始游戏。
		ENDIF
	CASE 100
		PRINTW 设定完毕。
		RETURN
	CASE 1
		IF 全員ロリ化
			全員ロリ化 = 0
		ELSE
			全員ロリ化 = 1
			IF TALENT:MASTER:形状 < 6
				PRINTFORML 偶尔当当萝莉控也不错呢！
				PRINTFORML
				PRINTW 以全员都是幼女的状态下开始游戏。
			ELSE
				PRINTFORML 你个禽兽！
				PRINTFORML
				PRINTW 以全员都是幼女的状态下开始游戏。
			ENDIF
		ENDIF
	CASE 2
		IF 全員小人化
			全員小人化 = 0
		ELSE
			全員小人化 = 1
			IF TALENT:MASTER:形状 < 3
				PRINTW 以全员都是小人的状态下开始游戏。
			ELSE
				PRINTFORML 你个畜生！
				PRINTFORML 
				PRINTW 以全员都是小人的状态下开始游戏。
			ENDIF
		ENDIF
	CASE 3
		IF 全員動物耳化
			全員動物耳化 = 0
		ELSE
			全員動物耳化 = 1
			PRINTFORMW 以全员都长兽耳的状态下开始游戏。
		ENDIF
	CASE 4
		IF 全員扶她化
			全員扶她化 = 0
		ELSE
			全員扶她化 = 1
			PRINTFORMW 以全员都是扶她的状态下开始游戏。
		ENDIF
	CASE 5
		IF 全員母乳體質化
			全員母乳體質化 = 0
		ELSE
			全員母乳體質化 = 1
			PRINTFORMW 以全员都会分泌乳汁的状态下开始游戏。
		ENDIF
ENDSELECT
RESTART

@SET_BODY_APPLY
#LOCALSIZE 1
#LOCALSSIZE 1
;ロリの後に小人でないと小人が上書きされる
IF 全員ロリ化
	FOR LOCAL,1,CHARANUM
		CALL SET_LOLI(LOCAL)
	NEXT
ENDIF
IF 全員小人化
	FOR LOCAL,1,CHARANUM
		TALENT:LOCAL:体型 = -5
	NEXT
ENDIF
IF 全員動物耳化
	FOR LOCAL,1,CHARANUM
		SIF CSVTALENT(LOCAL, GETNUM(TALENT, "動物耳")) == 0
			TALENT:LOCAL:動物耳 = 1
	NEXT
ENDIF
IF 全員扶她化
	FOR LOCAL,1,CHARANUM
		CALL SET_FUTANARI(LOCAL)
	NEXT
ENDIF
IF 全員母乳體質化
	FOR LOCAL,1,CHARANUM
		TALENT:LOCAL:母乳体質 = 2
		MAXBASE:LOCAL:母乳 = 1000
	NEXT
ENDIF
