cost = 周回数 * 100
CALL COLORMESSAGE(@"剩余体力{BASE:MASTER:体力}",C_YELLOW,1)
CALL ASK_M("转一圈", BASE:MASTER:体力 > cost ,"用时间停止一边偷懒一边转", BASE:MASTER:体力 > cost/ 2 && BASE:MASTER:TSP > cost, "累了", 周回数 > 1)
SELECTCASE RESULT
	CASE 0
		PRINTFORMW ………
		PRINTFORMW ……
		PRINTFORMW …
		PRINTFORMW 「唔呼ー♪」
		CALL RECOVER(MASTER,cost * -1,"体力")
		CALL BUFF_BASE([[影狼]],BASE_気力,50,1)
		CALL CHANGE_CFLAG(2,[[影狼]], 100)
		周回数 ++
	CASE 1
		PRINTFORMW ………
		PRINTFORMW ……
		PRINTFORMW …
		PRINTFORMW 「感觉好快？　是因为喝醉了吗……」
		CALL RECOVER(MASTER,cost * -1 / 2,"体力")
		CALL RECOVER(MASTER,cost * -1,"TSP")
		CALL BUFF_BASE([[影狼]],BASE_気力,30,1)
		CALL CHANGE_CFLAG(2,[[影狼]], 30)
		周回数 ++
	CASE 2
		finish = 1
ENDSELECT
IF !finish
	SIF RAND:周回数 > RAND:5 || 周回数 >= 5
		finish = 2
ENDIF
IF finish == 1
	IF 周回数 < 3
		PRINTFORML 「已经？　真没办法呀……」
		PRINTFORML 「唔……　那么、晚安」
	ELSE
		PRINTFORML 「辛苦了！很开心」
		PRINTFORML 「晚安、还会再过来的」
		PRINTFORMW 影狼带着好心情回去了
		CALL CHANGE_CFLAG(2,[[影狼]], 300)
		TALENT:[[影狼]]:心情 = 1
		CFLAG:[[影狼]]:翌日来訪 = 1
	ENDIF
	RETURN
ELSEIF finish == 2
	PRINTFORML 「………呼嗯」
	PRINTFORML 好像睡着了
	CALL CHANGE_CFLAG(2,[[影狼]], 300)
	;竹林以外が拠点なら泊まっていく
	TALENT:[[影狼]]:機嫌 = 1
	CALL KAGEROU_STAY
	RETURN
ENDIF
PRINTFORMW 「再转一圈」
GOTO LOOP

