@DAILY_NAME_EV9(ARG=1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
RETURNF ARG?"小狗钻被窝"#"犬添い寝"

@DAILY_CONDITION_EV9
#LOCALSIZE 1
#LOCALSSIZE 1

IF !RAND:20 && MAIN_MAP == 9
	CALL DAILY_EV9
	RETURN 1
ELSE
	RETURN -1
ENDIF

@DAILY_EV9
#LOCALSIZE 1
#LOCALSSIZE 1
PRINTFORML 觉那里的小狗钻进了%CALLNAME:MASTER%的被窝
SELECTCASE DAY:2
	CASE 2
		PRINTFORML 睡不着了……
		CFLAG:MASTER:徹夜 = 1
	CASE 4
		PRINTFORML 真温暖……
		CALL RECOVER(MASTER,300,"体力")
		CALL RECOVER(MASTER,500,"気力")
	CASEELSE
		CALL RECOVER(MASTER,100,"体力")
		CALL RECOVER(MASTER,200,"気力")
ENDSELECT
PRINTW 
RETURN 1