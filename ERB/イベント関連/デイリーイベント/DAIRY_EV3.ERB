@DAILY_NAME_EV3(ARG=1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
RETURNF ARG?"酒收购价上涨"#"酒屋買取強化"

@DAILY_CONDITION_EV3
#LOCALSIZE 1
#LOCALSSIZE 1

IF FLAG:最後一次訪问酒屋日期 > 0 && !FLAG:酒屋買取強化 && !RAND:30
	CALL DAILY_EV3
	RETURN 1
ELSE
	RETURN -1
ENDIF

@DAILY_EV3
#LOCALSIZE 1
#LOCALSSIZE 1
FLAG:酒屋買取強化 = 7
IF FLAG:新聞購読
	PRINTFORML 根据文文。新闻报道、人间之里的酒屋收购强化宣传活动开始了
	PRINTFORMW 看来可以比平时卖出高价
ENDIF
RETURN 1