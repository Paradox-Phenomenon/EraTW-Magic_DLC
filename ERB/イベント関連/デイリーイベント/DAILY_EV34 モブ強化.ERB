@DAILY_NAME_EV34
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
RETURNF "妖兽强化"

@DAILY_CONDITION_EV34
#LOCALSIZE 1
#LOCALSSIZE 1
SIF RAND:15 > 0
	RETURN -1

CALL DAILY_EV34
RETURN 1

@DAILY_EV34
#LOCALSIZE 1
#LOCALSSIZE 1

;BUFFED_RACE = %TEXTR("化け狐/化け狸/イナバ/山童/玉兎/河童/鴉天狗/白狼天狗")%
BUFFED_RACE = %TEXTR("妖怪狐/妖怪狸/因幡/山童/玉兎/河童/鴉天狗/白狼天狗")%
SELECTCASE BUFFED_RACE
	CASE "白狼天狗"
		PRINTFORMDL 突然上头的哨戒天狗们课下了不讲道理的指标
		PRINTFORMDL 白狼天狗们一边抱怨着，一边为寻找可疑人物而徘徊到岗哨之外……
		CALL PRINT_FACE, 0, "通常", "服", "8"
	CASE "鴉天狗"
		PRINTFORMDL 天狗的新闻大会临近了……
		PRINTFORMDL 鸦天狗们为寻找新闻素材，四处奔波……
		CALL PRINT_FACE, 0, "通常", "服", "93"
	CASE "河童"
		PRINTFORMDL 河童们似乎发明了新的东西
		PRINTFORMDL 她们以实地测试为名，四处寻找合适的对手
		CALL PRINT_FACE, 0, "通常", "服", "16"
	CASE "山童"
		PRINTFORMDL 山童们似乎在四处推销积压的库存商品
		CALL PRINT_FACE, 0, "通常", "服", "91"
	CASE "因幡"
		PRINTFORMDL 兔角同盟的激进派开始闹事了
		CALL PRINT_FACE, 0, "通常", "服", "4"
	CASE "玉兎"
		PRINTFORMDL 玉兔的地上侵攻训练开始了
		PRINTFORMDL 点心不能超过500日元，但团子不计入点心
		CALL PRINT_FACE, 0, "通常", "服", "10"
	CASE "妖怪狐", "妖怪狸"
		PRINTFORMDL 狐狸和狸猫开始了互相欺骗的较量！
		PRINTFORMDL 这是一场比拼牺牲者数量的扰民抗争！
		IF BUFFED_RACE == "妖怪狐"
			CALL PRINT_FACE, 0, "通常", "服", "28"
		ELSE
			CALL PRINT_FACE, 0, "通常", "服", "21"
		ENDIF
ENDSELECT

PRINTFORMDW %BUFFED_RACE%的出现率上升，战斗能力也提升了
RACEBUFF_DAYS = 2 + RAND:2
RETURN 1

@DAILY_EV34_END
#LOCALSIZE 1
#LOCALSSIZE 1
SELECTCASE BUFFED_RACE
	CASE "白狼天狗"
		PRINTFORMDL 哨戒天狗被分配了别的任务，指标的事情不了了之了
	CASE "鴉天狗"
		PRINTFORMDL 离天狗的新闻大会没有几天了
		PRINTFORMDL 鸦天狗们似乎结束了采访，开始进入收尾阶段
		PRINTFORMDL 停止吧！黑道式截稿！
	CASE "河童"
		PRINTFORMDL 河童们的实地测试结束了
		PRINTFORMDL 因为比预想中要逊色，她们似乎已经厌倦，转去研究别的发明了
	CASE "山童"
		PRINTFORMDL 山童们似乎回山里进货去了
	CASE "因幡"
		PRINTFORMDL 是受到了帝的呵斥吗，因幡们老实了
	CASE "玉兎"
		PRINTFORMDL 玉兔的地上侵攻训练结束了
		PRINTFORMDL 就地解散，回到家才算训练结束
	CASE "妖怪狐", "妖怪狸"
		PRINTFORMDL 狐狸和狸猫的互相欺骗较量，以这次%BUFFED_RACE%的胜利告一段落
ENDSELECT
PRINTFORMW %BUFFED_RACE%已经老实了
BUFFED_RACE = ""

