@DAILY_NAME_EV15(ARG=1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
RETURNF ARG?"异常气象"#"異常気象"

@DAILY_CONDITION_EV15
#LOCALSIZE 1
#LOCALSSIZE 1
SIF RAND:20 > 0 || FLAG:異常気象
	RETURN -1
CALL DAILY_EV15
RETURN 1

@DAILY_EV15
#LOCALSIZE 1
#LOCALSSIZE 1
IF WEATHERDLC
	LOCALS '= WEATHERDLC_EV15()
ELSE
	FLAG:異常気象 = 6 + RAND:2
ENDIF

TIME:5 = 0
WIND_VELOCITY = 0
;天气重修，强行设定对应天气系统
CALL qol_FORCESET_REGION_WEATHER_SYSTEM
CALL qol_FORCESET_REGION_RAINBOW_SYSTEM
CALL qol_FORCESET_REGION_WIND_VE_SYSTEM
SELECTCASE FLAG:異常気象
	CASE 6
		LOCALS = 好像女孩子被掀起裙子后越是厌恶你却越会感到舒服
	CASE 7
		LOCALS = 好像风会把胖次吹得到处都是了
ENDSELECT

PRINTFORMW 全球变暖、环境污染、难民问题、总统选举、疫情、长时间加班、走路玩手机、Switch X缺货……
PRINTFORMW 外部世界的各种问题，也无可避免地影响到幻想乡。
CALL COLORMESSAGE(@"由于受到外界影响而产生了天气异变，%LOCALS%",C_PINK,2,1)
