;存在関数を兼ねる
;宴会名を設定
@ENKAI_1_TITLE(ARG = 1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
RETURNF ARG ? "灵梦一时兴起的酒宴" # "霊夢の気紛れ酒盛り"

;宴会を開催可能かどうか設定
;1なら可、0なら不可として処理される
@ENKAI_1_ABLE
#LOCALSIZE 1
#LOCALSSIZE 1
;霊夢が出禁を喰らってない
SIF CFLAG:[[霊夢]]:出禁
	RETURN 0
;土曜であること
SIF DAY % 7 != 6
	RETURN 0

;50%の確率で開催
;比重へ移動。レミリアの気紛れパーティと同じ重さにする
;SIF RAND:100 > 49
;	RETURN 0

RETURN 1

;@ENKAI_XXX_ABLEが1の時、この宴会が開催される重みを表す
;実際は他の開催可能宴会との重みの比によって開催される宴会が選択される
;@ENKAI_XXX_ABLEが1、かつこの関数で0を返すと確定で開催される(その場合、IDが若い宴会が優先される)
@ENKAI_1_WEIGHT
#LOCALSIZE 1
#LOCALSSIZE 1
RETURN 100

;規模を設定
@ENKAI_1_宴会規模
#LOCALSIZE 1
#LOCALSSIZE 1
RETURN 1000 + RAND:1500

;会場を設定
@ENKAI_1_宴会会場
#LOCALSIZE 1
#LOCALSSIZE 1
;博麗神社
IF RAND:5 <= 3
	RETURN P11庭
ELSEIF RAND:4 == 0
	RETURN P2境内
ELSEIF RAND:4 == 0
	RETURN P20本殿の裏
ELSEIF RAND:4 == 0
	RETURN P21守矢神社分社
ELSE
	;ここだけ人間の里
	RETURN P218小料理屋
ENDIF

;開始時間を設定
;ENKAI_LOADDATAの処理順的に既に宴会規模は決定されている…はず
@ENKAI_1_開始時間
#LOCALSIZE 1
#LOCALSSIZE 1
;PM10:40 - (宴会規模/10)
RETURN 1360 - FLAG:宴会規模 / 10

;開始日(DAY:3)を設定
@ENKAI_1_開始日
#LOCALSIZE 1
#LOCALSSIZE 1
RETURN 1

;1なら雨天中止、0なら雨天決行
@ENKAI_1_悪天候中止フラグ
#LOCALSIZE 1
#LOCALSSIZE 1
;開催場所がほぼ屋外なので
RETURN 1

;宴会開催確定時に呼ばれる関数
@ENKAI_1_事前処理
#LOCALSIZE 1
#LOCALSSIZE 1
FLAG:宴会差し入れ = 0
RETURN 1

;宴会終結時に呼ばれる関数
@ENKAI_1_事後処理
#LOCALSIZE 1
#LOCALSSIZE 1
FLAG:宴会差し入れ = 0
RETURN 1

@ENKAI_1_開催決定メッセージ
#LOCALSIZE 1
#LOCALSSIZE 1
PRINTL  
PRINTFORMW %CALLNAME:1%一时兴起要办宴会了

RETURN 1


;特定のフラグを参照して宴会規模などをいじりたい時に
@ENKAI_1_パラメータ補正
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CONST 最小差し入れ補正 = 500

;霊夢の依頼達成で宴会規模がでかくなる
;差し入れしたのに規模が増えない場合もあったので下限を導入
SELECTCASE FLAG:宴会差し入れ
	CASE 51,56,59
		FLAG:31 += RAND:1000
	CASEELSE
		FLAG:31 += RAND:2000
ENDSELECT
RETURN 1

;主催者、参加者、飛び入り参加の発生率設定
@ENKAI_1_参加者設定(ARGHOST , ARGGUEST , ARGNG , ARGRESIDENT , ARGVISITOR)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM REF ARGHOST     ;主催者一覧(=開催・閉幕時に働く人)
#DIM REF ARGGUEST    ;ゲスト一覧(確定で参加する人)
#DIM REF ARGNG       ;その宴会に絶対に来ない人
#DIM REF ARGRESIDENT ;そのマップに住んでいる人の参加確率(%)
#DIM REF ARGVISITOR  ;そのマップに住んでいない人の参加確率(%)

ARGHOST = [[霊夢]] , [[る～こと]] , [[魔理沙]]
ARGGUEST = [[萃香]]
ARGNG = [[正邪]]

IF FLAG:宴会規模 >= 2500
;規模が大きいと参加確率大
	ARGRESIDENT = 12
	ARGVISITOR = 12
ELSE
	ARGRESIDENT = 7
	ARGVISITOR = 7
ENDIF
RETURN 1


