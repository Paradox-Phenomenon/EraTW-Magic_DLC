;主催者、参加者、飛び入り参加の発生率設定
@ENKAI_8_参加者設定(ARGHOST , ARGGUEST , ARGNG , ARGRESIDENT , ARGVISITOR)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM REF ARGHOST     ;主催者一覧(=開催・閉幕時に働く人)
#DIM REF ARGGUEST    ;ゲスト一覧(確定で参加する人)
#DIM REF ARGNG       ;その宴会に絶対に来ない人
#DIM REF ARGRESIDENT ;そのマップに住んでいる人の参加確率(%)
#DIM REF ARGVISITOR  ;そのマップに住んでいない人の参加確率(%)
#DIM L_住所不定キャラ
#DIM DYNAMIC L_配列添え字
#DIM CNT

;菫子一人で宴会の準備してるのなんか不自然だけど他に誰を当てはめたらいいのか…
ARGHOST = ENKAI_8_主催者()

;ENKAI_8_住所不定キャラ()は住所不定(と思われる)キャラの総数を返す
;かつRESULTに該当キャラのキャラ番号を順次入れている
L_住所不定キャラ = ENKAI_8_住所不定キャラ()
FOR CNT , 0 , MIN(L_住所不定キャラ , VARSIZE("ARGGUEST"))
	SIF RESULT:CNT == ENKAI_8_主催者()
		CONTINUE
	ARGGUEST:L_配列添え字 = RESULT:CNT
	L_配列添え字++
NEXT
ARGNG = [[正邪]]

;部外者もちょっと来る
ARGRESIDENT = 3
ARGVISITOR = 3
RETURN 1


;モブキャラでない人物のうち住所不定かつ出禁でないキャラをリストアップして返す式中関数
;RESULTにキャラ番号を順次格納する。式中関数自体はヒットしたキャラの総数を返す
@ENKAI_8_住所不定キャラ
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CNT
#DIM L_CHRNUM

VARSET RESULT , -1
VARSET L_CHRNUM
FOR CNT , 0 , CHARANUM
	;モブは除外
	SIF TALENT:CNT:行きずり
		CONTINUE
	;出禁は除外
	SIF CFLAG:CNT:出禁
		CONTINUE
	;あなたは除外
	SIF CNT == MASTER
		CONTINUE

	;CFLAG:自宅位置が0(=無効なマップ番号)を住所不定と見なしてリストアップ
	;CFLAG:初期位置とCFLAG:自宅位置のどっち参照すればいいか分からなかったがとりあえずCFLAG:自宅位置を見ておく
	IF CFLAG:CNT:自宅位置 == 0
		RESULT:L_CHRNUM = CNT
		L_CHRNUM++
		SIF L_CHRNUM >= VARSIZE("RESULT")
			BREAK
	ENDIF
NEXT
RETURNF L_CHRNUM


;以下内部関数
;ENKAI_8の主催者を決定して返す関数。L_主催者候補の要素が若い順から優先して選ばれる
;L_主催者候補が誰も住所不定判定されない場合、住所不定キャラの全員からランダムで一人選ぶ
@ENKAI_8_主催者
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM DYNAMIC L_主催者候補 = [[菫子]] ;一応菫子にしておく……が他に誰が適切なのか思いつかなかっただけなので変えちゃってほしい
#DIM L_キャラ総数
#DIM CNT

L_キャラ総数 = ENKAI_8_住所不定キャラ()

;まず事前定義された主催者候補が住所不定キャラに含まれているか判定し、番号が若い順に優先して主催者に決定する
FOR CNT , 0 , VARSIZE("L_主催者候補")
	SIF FINDELEMENT(RESULT , L_主催者候補:CNT) >= 0
		RETURNF L_主催者候補:CNT
NEXT

RETURNF RESULT:(RAND:L_キャラ総数)
