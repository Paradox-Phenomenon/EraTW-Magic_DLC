;存在関数を兼ねる
;宴会名を設定
@ENKAI_10_TITLE(ARG = 1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
RETURNF ARG ? "姐姐聚会" # "長女会議"

;宴会を開催可能かどうか設定
;1なら可、0なら不可として処理される
@ENKAI_10_ABLE
#LOCALSIZE 1
#LOCALSSIZE 1
;主催者候補が出禁ではない
SIF CFLAG:[[レミリア]]:出禁 || CFLAG:[[咲夜]]:出禁
	RETURN 0
SIF CFLAG:[[さとり]]:出禁 || CFLAG:[[お燐]]:出禁 || CFLAG:[[お空]]:出禁
	RETURN 0
SIF CFLAG:[[豊姫]]:出禁 || CFLAG:[[レイセン]]:出禁
	RETURN 0

;夏冬、3日
SIF DAY:2 != 2 && DAY:2 != 4
	RETURN 0
SIF DAY:3 != 3
	RETURN 0

RETURN 1

