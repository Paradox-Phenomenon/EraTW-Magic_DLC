;主催者、参加者、飛び入り参加の発生率設定
@ENKAI_10_参加者設定(ARGHOST , ARGGUEST , ARGNG , ARGRESIDENT , ARGVISITOR)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM REF ARGHOST     ;主催者一覧(=開催・閉幕時に働く人)
#DIM REF ARGGUEST    ;ゲスト一覧(確定で参加する人)
#DIM REF ARGNG       ;その宴会に絶対に来ない人
#DIM REF ARGRESIDENT ;そのマップに住んでいる人の参加確率(%)
#DIM REF ARGVISITOR  ;そのマップに住んでいない人の参加確率(%)
#DIM 長女候補 = [[レミリア]] , [[ルナサ]] , [[さとり]] , [[静葉]] , [[豊姫]] , [[白蓮]] , [[幻月]] , [[紫苑]]
#DIM 主催者候補 , 100
#DIM 主催者数
#DIM 参加者数
#DIM CNT

;配列"主催者候補"に主催者候補のキャラ番号を受け取る。主催者数には主催者候補の数が入っている
;姉の従者もセットになっており、主催者として準備し、(たとえ姉でなくても)従者はそのまま宴会に参加する
主催者数 = ENKAI_10_主催者(主催者候補)
FOR CNT , 0 , 主催者数
	ARGHOST:CNT = 主催者候補:CNT
NEXT

;主催者として確定したキャラを除外しながらゲスト参加するキャラのキャラ番号を登録していく
VARSET 参加者数
FOR CNT , 0 , VARSIZE("長女候補")
	IF MATCH(主催者候補 , 長女候補:CNT) == 0
		ARGGUEST:参加者数 = 長女候補:CNT
		参加者数++
	ENDIF
NEXT

ARGNG = [[正邪]]

;長女以外は来ない
ARGRESIDENT = 0
ARGVISITOR = 0
RETURN 1


;開催回数次第で主催を持ち回りにしたいので、主催者側のキャラ番号を返す式中関数
;RESULT:0がメインの主催者、RESULT:1以降は労働者(のつもり)
;この関数自体は主催者として登録すべき人数を返す
@ENKAI_10_主催者(ARG主催者)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM REF ARG主催者
VARSET ARG主催者 , -1
SELECTCASE 宴会開催回数:10 % 3
	CASE 0
		ARG主催者 = [[レミリア]] , [[咲夜]]
	CASE 1
		ARG主催者 = [[さとり]] , [[お燐]] , [[お空]]
	CASE 2
		ARG主催者 = [[豊姫]] , [[レイセン]]
ENDSELECT

RETURNF FINDELEMENT(ARG主催者 , -1)
