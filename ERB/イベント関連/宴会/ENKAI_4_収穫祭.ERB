;主催者、参加者、飛び入り参加の発生率設定
@ENKAI_4_参加者設定(ARGHOST , ARGGUEST , ARGNG , ARGRESIDENT , ARGVISITOR)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM REF ARGHOST     ;主催者一覧(=開催・閉幕時に働く人)
#DIM REF ARGGUEST    ;ゲスト一覧(確定で参加する人)
#DIM REF ARGNG       ;その宴会に絶対に来ない人
#DIM REF ARGRESIDENT ;そのマップに住んでいる人の参加確率(%)
#DIM REF ARGVISITOR  ;そのマップに住んでいない人の参加確率(%)
#DIM CNT_0
#DIM CNT_1

;人里住みのキャラは全員主催者として参加
FOR CNT_0 , 1 , CHARANUM
	IF CFLAG:CNT_0:自宅位置 / 100 == 2
		FOR CNT_1, 0, VARSIZE("ARGHOST")
			IF ARGHOST:CNT_1
				CONTINUE
			ELSE
				ARGHOST:CNT_1 = CNT_0
				BREAK
			ENDIF
		NEXT
	ENDIF
NEXT

;収穫祭なので秋姉妹は必ず参加
ARGGUEST = [[静葉]] , [[穣子]]
ARGNG = [[正邪]]

;人間の里住みのキャラは全て主催になる
ARGRESIDENT = 0
ARGVISITOR = 8
RETURN 1
