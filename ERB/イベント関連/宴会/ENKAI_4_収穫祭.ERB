;宴会を開催可能かどうか設定
;1なら可、0なら不可として処理される
@ENKAI_4_ABLE
#LOCALSIZE 1
#LOCALSSIZE 1
;秋である
SIF DAY:2 != 3
	RETURN 0
;日付が16～26である
SIF INRANGE(DAY:3 , 16 , 26) == 0
	RETURN 0

RETURN 1

