;宴会参加中キャラのうち、恋人か恋慕か思慕のキャラのうち一人を抽選して返す式中関数
@宴会_恋愛キャラ抽選()
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM L_HITNUM
#DIM L_TESTED
#DIMS L_CHR
#DIM CNT
#DIM CNT_TAL
#DIMS L_XML
;セフレとか愛人は扱いがよく分からなかったので保留に
#DIMS CONST CON_TALNAME = "恋人" , "恋慕" , "思慕"

L_XML = <ROOT />

;誤記判定部
IF L_TESTED == 0
	FOR CNT_TAL , 0 , VARSIZE("CON_TALNAME")
		SIF GETNUM(TALENT , CON_TALNAME:CNT_TAL) == -1
			THROW %CON_TALNAME:CNT_TAL%はTALENT配列に見つからないよ
	NEXT
	L_TESTED = 1
ENDIF

;まず該当素質を持つキャラをXMLにピックアップ、属性に対象TALENTのTRUE/FALSEを記録
FOR CNT , 0 , CHARANUM
	;除外条件
	SIF TALENT:CNT:行きずり
		CONTINUE
	SIF CNT == MASTER
		CONTINUE
	;泥酔は除外しない
	SIF CFLAG:CNT:宴会参加 != 1 && CFLAG:CNT:宴会参加 != 2
		CONTINUE

	;XMLへピックアップ
	XML_ADDNODE L_XML , @"/ROOT" , @"<CHR>{CNT}</CHR>"
	FOR CNT_TAL , 0 , VARSIZE("CON_TALNAME")
		XML_ADDATTRIBUTE L_XML , @"/ROOT/CHR[last()]" , CON_TALNAME:CNT_TAL , TOSTR(TALENT:CNT:(CON_TALNAME:CNT_TAL) != 0)
	NEXT
NEXT
DEBUGPRINTFORML XML=
DEBUGPRINTFORML %L_XML%
;抽選部分。CON_TALNAMEに指定されたTALENTを要素数が小さい順に優先して判定する
L_CHR = 
FOR CNT_TAL , 0 , VARSIZE("CON_TALNAME")
	L_HITNUM = XML_GET(L_XML , @"/ROOT/CHR[@%CON_TALNAME:CNT_TAL%='1']")
	SELECTCASE L_HITNUM
		CASE 1
			XML_GET L_XML , @"/ROOT/CHR[@%CON_TALNAME:CNT_TAL%='1'][1]/text()" , L_CHR
			RETURNF TOINT(L_CHR)
		CASE IS > 1
			XML_GET L_XML , @"/ROOT/CHR[@%CON_TALNAME:CNT_TAL%='1'][{RAND(1 , L_HITNUM + 1)}]/text()" , L_CHR
			RETURNF TOINT(L_CHR)
		CASEELSE
			CONTINUE
	ENDSELECT
NEXT

RETURNF -1
[SKIPEND]
