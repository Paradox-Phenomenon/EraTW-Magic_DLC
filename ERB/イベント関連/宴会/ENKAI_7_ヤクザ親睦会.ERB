@ENKAI_7_開催決定メッセージ
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM L_組長該当 , 10
#DIM L_該当
#DIM L_組長 = [[八千慧]] , [[早鬼]] , [[尤魔]]
#DIM CNT
#DIM CONST CON_好感度閾値 = 1500
#DIMS L_お使い
#DIMS L_お使いTEMP

;好感度が高めの組長を探し、使いの部下の名前を作る
;L_組長該当配列には親しい組長のキャラ番号が、L_該当にはヒットした組長の総数が入っている
VARSET L_該当 , 0
VARSET L_お使い
VARSET L_組長該当 , -1

L_該当 = ENKAI_7_懇意キャラ()
FOR CNT , 0 , L_該当
	L_組長該当:CNT = RESULT:CNT
	IF MATCH(L_組長 , L_組長該当:CNT)
		SELECTCASE L_組長該当:CNT
			CASE [[八千慧]]
				L_お使いTEMP = 水獭灵
			CASE [[早鬼]]
				L_お使いTEMP = 野狼灵
			CASE [[尤魔]]
				L_お使いTEMP = 大鹫灵
		ENDSELECT

		IF L_お使い == ""
			L_お使い = %L_お使いTEMP%
		ELSE
			L_お使い = %L_お使い%和%L_お使いTEMP%
		ENDIF
	ENDIF
NEXT

PRINTL  
;３組長と仲が良ければ部下から招待を受ける。そうでなければ風のうわさで知る感じ
SELECTCASE L_該当
	CASE 0
		PRINTFORML 畜生界三大组织好像要开一场和平的酒会了
		PRINTFORML 为什么区区一次喝酒聚会还要特意强调“和平”两个字……完全搞不懂。总之先记下来吧……
	CASEELSE
		IF L_該当 == 1
			PRINTFORML %CALLNAME:(L_組長該当:0)%麾下的%L_お使い%送来了邀请
			PRINTFORML 说是畜生界三大组织联合举办的酒会
		ELSE
			PRINTFORML %L_お使い%争先恐后地把邀请函塞了过来
			PRINTFORML 据说每一位都是各自老大派来的使者
		ENDIF
		PRINTFORML 虽然是内部聚会，但他们愿意带我这个外人进去
		PRINTFORML 总之先记在心里好了
ENDSELECT

;このファイルから確定で依頼を出す手段が分からなかったので依頼の話はしない
;PRINTL 
;PRINTFORML なお、開催に当たってトラブルが起きているようだ
