#LOCALSIZE 1
#LOCALSSIZE 1
#DIM 懇意キャラ , 10
#DIM 懇意キャラ数
#DIM CNT
#DIMS 懇意キャラ名前

懇意キャラ数 = ENKAI_7_懇意キャラ("組長")
