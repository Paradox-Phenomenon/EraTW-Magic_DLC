	懇意キャラ数 = ENKAI_7_懇意キャラ("部下")
懇意キャラ名前 = 

VARSET 懇意キャラ , -1
FOR CNT , 0 , 懇意キャラ数
	懇意キャラ:CNT = RESULT:CNT
NEXT

PRINTL 
PRINTFORMW 剑拔弩张的气氛中，三大组织的酒会正式开始了！
PRINTL 

;ボス勢or部下勢の誰と親しいかチェックして宴会開幕メッセージを適宜変更する
;@ENKAI_7_懇意キャラ()はボスも部下も一緒くたにして返すので冗長になるね
IF 懇意キャラ数 == 0
	;部下ともボスとも親しくない

ELSEIF GROUPMATCH(懇意キャラ , [[八千慧]] , [[早鬼]] , [[尤魔]]) > 0
	;ボス勢と親しい（ボスと部下の両方に懇意キャラが居る場合、ボス勢を優先する）
	SIF GROUPMATCH(懇意キャラ , [[八千慧]])
		懇意キャラ名前 = %CALLNAME:[[八千慧]]%
	IF GROUPMATCH(懇意キャラ , [[早鬼]])
		IF 懇意キャラ名前 == ""
			懇意キャラ名前 = %CALLNAME:[[早鬼]]%
		ELSE
			懇意キャラ名前 = %懇意キャラ名前%、%CALLNAME:[[早鬼]]%
		ENDIF
	ENDIF
	IF GROUPMATCH(懇意キャラ , [[尤魔]])
		IF 懇意キャラ名前 == ""
			懇意キャラ名前 = %CALLNAME:[[尤魔]]%
		ELSE
			懇意キャラ名前 = %懇意キャラ名前%和%CALLNAME:[[尤魔]]%
		ENDIF
	ENDIF

;３組長はサツバツ
	IF 懇意キャラ数 >= 3
		;あなたの隣は二つしかないのだ！
		PRINTFORML %懇意キャラ名前%为了抢%CALLNAME:MASTER%旁边的座位，互相瞪得火花四溅
		PRINTFORMW 谁都不肯让步……好可怕……
	ELSE
		;親しいキャラが一人か二人
		PRINTFORMW %懇意キャラ名前%理所当然地坐到了%CALLNAME:MASTER%旁边……
	ENDIF
ELSE
	;ボス勢と親しくなく、かつ部下勢と親しい
	SIF GROUPMATCH(懇意キャラ , [[美天]])
		懇意キャラ名前 = %CALLNAME:[[美天]]%
	IF GROUPMATCH(懇意キャラ , [[慧ノ子]])
		IF 懇意キャラ名前 == ""
			懇意キャラ名前 = %CALLNAME:[[慧ノ子]]%
		ELSE
			懇意キャラ名前 = %懇意キャラ名前%、%CALLNAME:[[慧ノ子]]%
		ENDIF
	ENDIF
	IF GROUPMATCH(懇意キャラ , [[ちやり]])
		IF 懇意キャラ名前 == ""
			懇意キャラ名前 = %CALLNAME:[[ちやり]]%
		ELSE
			懇意キャラ名前 = %懇意キャラ名前%和%CALLNAME:[[ちやり]]%
		ENDIF
	ENDIF

	;部下勢はなあなあな感じ
	IF 懇意キャラ数 >= 3
		PRINTFORMW %懇意キャラ名前%她们把%CALLNAME:MASTER%围在中间坐下了
	ELSE
		PRINTFORMW %懇意キャラ名前%坐到了%CALLNAME:MASTER%旁边……
	ENDIF
ENDIF

RETURN 1

