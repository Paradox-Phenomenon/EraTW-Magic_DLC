;L_CHRLISTに指定されたキャラのうち、親密がCON_親密閾値以上のキャラを入れる式中間数
;この式中間数自体はヒットしたキャラの総数を返す
@ENKAI_7_懇意キャラ(ARGMODE = "ALL")
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CNT
#DIM L_MAXCNT
#DIM L_HITNUM
#DIM L_CHRLIST , 10
#DIM CONST CON_親密閾値 = 6
#DIMS ARGMODE

VARSET L_CHRLIST , -1

SELECTCASE ARGMODE
	CASE "組長"
		L_CHRLIST = [[八千慧]] , [[早鬼]] , [[尤魔]]
	CASE "部下"
		L_CHRLIST = [[ちやり]] , [[美天]] , [[慧ノ子]]
	CASE "ALL"
		L_CHRLIST = [[八千慧]] , [[早鬼]] , [[尤魔]] , [[ちやり]] , [[美天]] , [[慧ノ子]]
	CASEELSE
		;予期しない分岐
		THROW 予期しない分岐  ARGMODE=%ARGMODE%
ENDSELECT

L_HITNUM = 0

L_MAXCNT = FINDELEMENT(L_CHRLIST , -1)
SIF L_MAXCNT == -1
	L_MAXCNT = VARSIZE("L_CHRLIST")

FOR CNT , 0 , L_MAXCNT
	IF ABL:(L_CHRLIST:CNT):親密 >= CON_親密閾値 || 1
		RESULT:L_HITNUM = L_CHRLIST:CNT
		L_HITNUM++
	ENDIF
NEXT

RETURNF L_HITNUM
