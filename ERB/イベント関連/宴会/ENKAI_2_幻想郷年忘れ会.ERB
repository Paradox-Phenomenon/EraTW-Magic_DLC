;存在関数を兼ねる
;宴会名を設定
@ENKAI_2_TITLE(ARG = 1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
RETURNF ARG ? "幻想乡忘年会" # "幻想郷年忘れ会"

;宴会を開催可能かどうか設定
;1なら可、0なら不可として処理される
@ENKAI_2_ABLE
#LOCALSIZE 1
#LOCALSSIZE 1
;冬である
SIF DAY:2 != 4
	RETURN 0
;日付が25～30である
SIF INRANGE(DAY:3 , 25 , 30) == 0
	RETURN 0

RETURN 1

;@ENKAI_XXX_ABLEが1の時、この宴会が開催される重みを表す
;実際は他の開催可能宴会との重みの比によって開催される宴会が選択される
;@ENKAI_XXX_ABLEが1、かつこの関数で0を返すと確定で開催される(その場合、IDが若い宴会が優先される)
@ENKAI_2_WEIGHT
#LOCALSIZE 1
#LOCALSSIZE 1
RETURN 0

;規模を設定
@ENKAI_2_宴会規模
#LOCALSIZE 1
#LOCALSSIZE 1
RETURN 6000

;会場を設定
@ENKAI_2_宴会会場
#LOCALSIZE 1
#LOCALSSIZE 1
;博麗神社
RETURN P9居間

;開始時間を設定
@ENKAI_2_開始時間
#LOCALSIZE 1
#LOCALSSIZE 1
;PM3:00
RETURN 900

;開始日(DAY:3)を設定
@ENKAI_2_開始日
#LOCALSIZE 1
#LOCALSSIZE 1
RETURN 31 - DAY:3

;1なら雨天中止、0なら雨天決行
@ENKAI_2_悪天候中止フラグ
#LOCALSIZE 1
#LOCALSSIZE 1
RETURN 0

