;宴会の最大定義数
#DIM CONST ENKAI_ID_MAX = 100
#DIM CONST ENKAI_ID_MIN = 1 ;0は不可

;その宴会の参加者判定を既にしたかどうか記録する変数
;もし判定済みならENKAI_IDが入っている
#DIM SAVEDATA ENKAI_ENTRY_DONE

;宴会が開催された回数を記録。添え字は宴会ID
;これは宴会が予約された時点で加算され、雨天中止などで実際に開催されなくてもカウンターが進む
#DIM SAVEDATA 宴会開催回数 , 100

;宴会の終了日・終了時刻を記録。開始日・開始時刻はFLAGにある(TWデフォルトの変数)
;FLAG:38、39あたりが空いているので予約できなくもなさそうだが、場所が窮屈そうなのとパッチの一存でFLAGを触りたくなかったので
;GREP置き換えのためにかぶらないであろうENKAI_をつけておく
#DIM SAVEDATA ENKAI_終了日
#DIM SAVEDATA ENKAI_終了時刻
