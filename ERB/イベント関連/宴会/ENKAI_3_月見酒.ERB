ARGGUEST = [[輝夜]]
ARGNG = [[正邪]]

ARGRESIDENT = 33
ARGVISITOR = 9
RETURN 1


;永遠亭関連で思慕・恋慕キャラがいたらそのキャラが月見酒に誘ってくる
;複数いたらランダム抽選。まず恋慕キャラを抽選し、該当なしなら思慕キャラ、それでもいないなら永琳
@ENKAI_3_勧誘キャラ抽選
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CNT
#DIM CNT_TAL
#DIM L_勧誘キャラ候補 , 10
#DIM L_ヒット数
#DIM CONST CON_永遠亭キャラ = [[てゐ]] , [[鈴仙]] , [[永琳]] , [[輝夜]]
#DIMS CONST CON_TALNAME = "恋慕" , "思慕" ;配列順に優先して抽選する

FOR CNT_TAL , 0 , VARSIZE("CON_TALNAME")
	VARSET L_勧誘キャラ候補 , -1
	VARSET L_ヒット数

	FOR CNT , 0 , VARSIZE("CON_永遠亭キャラ")
		IF TALENT:(CON_永遠亭キャラ:CNT):(CON_TALNAME:CNT_TAL)
			L_勧誘キャラ候補:L_ヒット数 = CON_永遠亭キャラ:CNT
			L_ヒット数++
		ENDIF
	NEXT

	IF L_ヒット数 == 1
		RETURNF L_勧誘キャラ候補:0
	ELSEIF L_ヒット数 > 1
		RETURNF L_勧誘キャラ候補:(RAND:L_ヒット数)
	ENDIF
NEXT

;ここまでヒットなしなら消去法で永琳当選
RETURNF [[永琳]]


@重さ抽選(ARG_WEIGHT)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM REF ARG_WEIGHT
#DIM L_WEIGHT
#DIM L_TARGETWEIGHT
#DIM CNT

L_WEIGHT = 0
FOR CNT , 0 , VARSIZE("ARG_WEIGHT")
	SIF ARG_WEIGHT:CNT > 0
		L_WEIGHT += ARG_WEIGHT:CNT
NEXT

SIF L_WEIGHT == 0
	RETURNF -1

L_TARGETWEIGHT = RAND:L_WEIGHT
L_WEIGHT = 0

FOR CNT , 0 , VARSIZE("ARG_WEIGHT")
	SIF ARG_WEIGHT:CNT > 0
		L_WEIGHT += ARG_WEIGHT:CNT
	SIF L_WEIGHT > L_TARGETWEIGHT
		RETURNF CNT
NEXT
RETURNF -1
