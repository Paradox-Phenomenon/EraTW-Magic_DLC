;存在関数を兼ねる
;宴会名を設定
@ENKAI_6_TITLE(ARG = 1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
RETURNF ARG ? "蕾米莉亚一时兴起的派对" # "レミリアの気紛れなパーティ"

;宴会を開催可能かどうか設定
;1なら可、0なら不可として処理される
@ENKAI_6_ABLE
#LOCALSIZE 1
#LOCALSSIZE 1
;レミリアが出禁を喰らってない
SIF CFLAG:[[レミリア]]:出禁
	RETURN 0
;土曜であること
SIF DAY % 7 != 6
	RETURN 0
;メインマップが霧の湖・紅魔館であること
SIF MAIN_MAP != 3
	RETURN 0

;50%の確率で開催
;比重へ移動。霊夢の気紛れ酒盛りと同じ重さにする
;ランダム要素として機能していないがTWのコードがそうなっている
;SIF RAND:50 > 49
;	RETURN 0

RETURN 1

;@ENKAI_XXX_ABLEが1の時、この宴会が開催される重みを表す
;実際は他の開催可能宴会との重みの比によって開催される宴会が選択される
;@ENKAI_XXX_ABLEが1、かつこの関数で0を返すと確定で開催される(その場合、IDが若い宴会が優先される)
@ENKAI_6_WEIGHT
#LOCALSIZE 1
#LOCALSSIZE 1
RETURN 100

;規模を設定
@ENKAI_6_宴会規模
#LOCALSIZE 1
#LOCALSSIZE 1
RETURN 1500 + RAND:2500

;会場を設定
@ENKAI_6_宴会会場
#LOCALSIZE 1
#LOCALSSIZE 1
;霧の湖
RETURN P324大バルコニー

;開始時間を設定
@ENKAI_6_開始時間
#LOCALSIZE 1
#LOCALSSIZE 1
;PM7:00。当然夜
RETURN 1140

;開始日(DAY:3)を設定
@ENKAI_6_開始日
#LOCALSIZE 1
#LOCALSSIZE 1
RETURN 1

;1なら雨天中止、0なら雨天決行
@ENKAI_6_悪天候中止フラグ
#LOCALSIZE 1
#LOCALSSIZE 1
;開催場所がバルコニーなので
RETURN 1

;宴会開催確定時に呼ばれる関数
@ENKAI_6_事前処理
#LOCALSIZE 1
#LOCALSSIZE 1

RETURN 1

;宴会終結時に呼ばれる関数
@ENKAI_6_事後処理
#LOCALSIZE 1
#LOCALSSIZE 1

RETURN 1

@ENKAI_6_開催決定メッセージ
#LOCALSIZE 1
#LOCALSSIZE 1
PRINTL  
PRINTFORMW %CALLNAME:16%一时兴起要开派对了

RETURN 1

;特定のフラグを参照して宴会規模などをいじりたい時に
@ENKAI_6_パラメータ補正
#LOCALSIZE 1
#LOCALSSIZE 1

RETURN 1

;主催者、参加者、飛び入り参加の発生率設定
@ENKAI_6_参加者設定(ARGHOST , ARGGUEST , ARGNG , ARGRESIDENT , ARGVISITOR)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM REF ARGHOST     ;主催者一覧(=開催・閉幕時に働く人)
#DIM REF ARGGUEST    ;ゲスト一覧(確定で参加する人)
#DIM REF ARGNG       ;その宴会に絶対に来ない人
#DIM REF ARGRESIDENT ;そのマップに住んでいる人の参加確率(%)
#DIM REF ARGVISITOR  ;そのマップに住んでいない人の参加確率(%)

ARGHOST = [[咲夜]] , [[美鈴]] , [[小悪魔]]
ARGGUEST = [[レミリア]] , [[フラン]]
ARGNG = [[正邪]]

ARGRESIDENT = 33
IF FLAG:宴会規模 >= 2500
	ARGVISITOR = 14
ELSE
	ARGVISITOR = 9
ENDIF
RETURN 1
