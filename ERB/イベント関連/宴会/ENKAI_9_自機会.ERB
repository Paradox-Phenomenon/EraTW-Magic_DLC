[SKIPSTART]
;自機会
;キャラが増えすぎるので花とか萃とか酔とかはなし
霊夢：多数
紫：永
魔理沙：多数
アリス：永
咲夜：妖永輝虹
レミリア：永
妖夢：永神鬼
幽々子：永
鈴仙：紺
文：文DS
はたて：DS
早苗：星神紺虹
チルノ：妖精大戦争
正邪：アマノジャク。TW宴会に全く出てこない設定なので除外
[SKIPEND]


;存在関数を兼ねる
;宴会名を設定
@ENKAI_9_TITLE(ARG = 1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
RETURNF ARG ? "自机聚会" # "自機会"

;宴会を開催可能かどうか設定
;1なら可、0なら不可として処理される
@ENKAI_9_ABLE
#LOCALSIZE 1
#LOCALSSIZE 1
;主催者が出禁ではない
SIF CFLAG:[[霊夢]]:出禁 || CFLAG:[[魔理沙]]:出禁
	RETURN 0

;春夏、20日
SIF DAY:2 != 1 && DAY:2 != 2
	RETURN 0
SIF DAY:3 != 20
	RETURN 0

RETURN 1

;@ENKAI_XXX_ABLEが1の時、この宴会が開催される重みを表す
;実際は他の開催可能宴会との重みの比によって開催される宴会が選択される
;@ENKAI_XXX_ABLEが1、かつこの関数で0を返すと確定で開催される(その場合、IDが若い宴会が優先される)
@ENKAI_9_WEIGHT
#LOCALSIZE 1
#LOCALSSIZE 1
RETURN 50

;規模を設定
@ENKAI_9_宴会規模
#LOCALSIZE 1
#LOCALSSIZE 1
RETURN 1501 + RAND:500

;会場を設定
@ENKAI_9_宴会会場
#LOCALSIZE 1
#LOCALSSIZE 1
;博麗神社
RETURN P11庭

;開始時間を設定
@ENKAI_9_開始時間
#LOCALSIZE 1
#LOCALSSIZE 1
;PM7:00
RETURN 1140

;開始日(DAY:3)を設定
@ENKAI_9_開始日
#LOCALSIZE 1
#LOCALSSIZE 1
RETURN 3

;1なら雨天中止、0なら雨天決行
@ENKAI_9_悪天候中止フラグ
#LOCALSIZE 1
#LOCALSSIZE 1
;開催場所が屋外なので
RETURN 1

