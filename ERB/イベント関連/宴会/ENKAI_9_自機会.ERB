;主催者、参加者、飛び入り参加の発生率設定
@ENKAI_9_参加者設定(ARGHOST , ARGGUEST , ARGNG , ARGRESIDENT , ARGVISITOR)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM REF ARGHOST     ;主催者一覧(=開催・閉幕時に働く人)
#DIM REF ARGGUEST    ;ゲスト一覧(確定で参加する人)
#DIM REF ARGNG       ;その宴会に絶対に来ない人
#DIM REF ARGRESIDENT ;そのマップに住んでいる人の参加確率(%)
#DIM REF ARGVISITOR  ;そのマップに住んでいない人の参加確率(%)
#DIM L_住所不定キャラ
#DIM DYNAMIC L_配列添え字
#DIM CNT

ARGHOST = [[霊夢]] , [[魔理沙]]
ARGGUEST = [[紫]] , [[チルノ]] , [[咲夜]] , [[レミリア]] , [[アリス]] , [[妖夢]] , [[幽々子]] , [[文]] , [[早苗]] , [[はたて]]
ARGNG = [[正邪]]

;部外者も少しだけ来る
ARGRESIDENT = 5
ARGVISITOR = 3
RETURN 1
