@ENKAI_LOADDATA(ARG_ID)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM ARG_ID

;宴会名
EnkaiTitle '= GETMETHS(@"ENKAI_{ARG_ID}_TITLE", "Null")

;宴会種別
FLAG:宴会開催フラグ = ARG_ID

;宴会規模
CALLFORM ENKAI_{ARG_ID}_宴会規模
FLAG:宴会規模 = RESULT

;会場
CALLFORM ENKAI_{ARG_ID}_宴会会場
FLAG:宴会会場 = RESULT

;開始時間
CALLFORM ENKAI_{ARG_ID}_開始時間
FLAG:開始時間 = RESULT

;開催期間
RESULT = 0
TRYCCALLFORM ENKAI_{ARG_ID}_開催期間
	IF RESULT > 0
		ENKAI_終了時刻 = FLAG:開始時間 + RESULT
		ENKAI_終了日 = DAY
		IF ENKAI_終了時刻 / 1440 > 0
			ENKAI_終了日 += ENKAI_終了時刻 / 1440
			ENKAI_終了時刻 = ENKAI_終了時刻 % 1440
		ENDIF
	ENDIF
CATCH
	ENKAI_終了日 = -1
	ENKAI_終了時刻 = -1
ENDCATCH

;開始日
CALLFORM ENKAI_{ARG_ID}_開始日
FLAG:開始日 = RESULT

;雨天決行/中止
CALLFORM ENKAI_{ARG_ID}_悪天候中止フラグ
FLAG:悪天候中止フラグ = RESULT

;宴会別事前処理を呼び出し
TRYCCALLFORM ENKAI_{FLAG:宴会開催フラグ}_事前処理

CATCH

ENDCATCH

RETURN ARG_ID
