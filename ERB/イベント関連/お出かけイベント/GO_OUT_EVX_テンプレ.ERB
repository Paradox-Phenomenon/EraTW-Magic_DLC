@GO_OUT_NAME_EVX(ARG=1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
RETURNF ARG ? "显示名" # "原名"

;イベント発生判定。EVXのXを一括置換で空いてる数字に変えてください。
;発生タイミングは時止め無しの拠点帰還時、一日一回
@GO_OUT_CONDITION_EVX
#LOCALSIZE 1
#LOCALSSIZE 1
IF !RAND:10
	CALL GO_OUT_EVX
ELSE
	;イベント不成立ならRETURN 0
	RETURN 0
ENDIF

;帰宅時以外でのイベント発生判定。EVXのXを一括置換で空いてる数字に変えてください。
;こちらは時止め無しなら拠点からの出発や、地域間の移動でも判定が発生する。
;拠点機関時のものとは別枠で一日一回
@DEPARTURE_CONDITION_EVX
#LOCALSIZE 1
#LOCALSSIZE 1
IF !RAND:15
	CALL GO_OUT_EVX(1)
	RETURN 1
ELSE
	;イベント不成立ならRETURN 0
	RETURN 0
ENDIF

;イベント本体。最後はRETURN 1でお願いします。
@GO_OUT_EVX(DEPARTURE)
#DIM DEPARTURE	;帰宅じゃない場合
#LOCALSIZE 1
#LOCALSSIZE 1
RETURN 1

[SKIPSTART]
※补充事项
・触发时机为未停止时间返回据点时，每日一次
・CFLAG:現在位置 保持为移动前的状态
・FLAG:デート相手 为约会对象的角色编号，为0则表示只有你一人
・使用角色变量时需要指定角色编号
・无论外出事件成功与否，接下来都有机会触发约会后事件

由于在经验变动处理之后运行，EXP的增加会延续到下一回合
在此函数内，例如要给 MASTER 增加 3 点射精经验时：
TCVAR:MASTER:射精経験 += 3
CALL AddEXP("射精経験", MASTER, 3)
这样做看起来比较得体
[SKIPEND]
