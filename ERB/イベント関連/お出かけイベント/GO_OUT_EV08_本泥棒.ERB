@GO_OUT_NAME_EV8(ARG=1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTIONS
RETURNF ARG ? "偷书贼" # "本泥棒"

;イベント発生判定。
;発生タイミングは時止め無しの拠点帰還時、一日一回
@GO_OUT_CONDITION_EV8
#LOCALSIZE 1
#LOCALSSIZE 1
;帰還で発生するのは紅魔館在住時のみ
SIF MAIN_MAP != 3
	RETURN 0
SIF RAND:15 > 0
	RETURN 0
SIF FLAG:デート相手 == [[魔理沙]]
	RETURN 0
SIF CFLAG:[[魔理沙]]:出禁 || CFLAG:[[魔理沙]]:神社在住
	RETURN 0
;訪問予定/仕事/宴会参加キャラを弾く
SIF CFLAG:[[魔理沙]]:拠点来訪 || 仕事日チェック([[魔理沙]]) || CFLAG:[[魔理沙]]:宴会参加
	RETURN 0
CALL GO_OUT_EV8
RETURN 1


;こちらは時止め無しなら拠点からの出発や、地域間の移動でも判定が発生する。
;拠点機関時のものとは別枠で一日一回
@DEPARTURE_CONDITION_EV8
#LOCALSIZE 1
#LOCALSSIZE 1
;移動先が紅魔館の時のみ
SIF CFLAG:MASTER:デート中 != 3
	RETURN 0
SIF RAND:12 > 0
	RETURN 0
SIF FLAG:デート相手 == [[魔理沙]]
	RETURN 0
SIF CFLAG:[[魔理沙]]:出禁
	RETURN 0
;訪問予定/仕事/宴会参加キャラを弾く
SIF CFLAG:[[魔理沙]]:拠点来訪 || 仕事日チェック([[魔理沙]]) || CFLAG:[[魔理沙]]:宴会参加
	RETURN 0
CALL GO_OUT_EV8(1)
RETURN 1

;イベント本体。最後はRETURN 1でお願いします。
@GO_OUT_EV8(DEPARTURE)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DEPARTURE	;帰宅じゃない場合
PRINTFORMW 走到快要看到红魔馆的时候，魔理沙以极快的速度从上空飞驰而过
PRINTFORMW 多半是又去偷书了吧
;这部分涉及角色解读，无需多写
SELECTCASE FLAG:デート相手
	CASE [[パチュリー]]
		PRINTFORMDW %CALLNAME:(FLAG:デート相手)%的脸色显得很不痛快……
;CASE 
;    PRINTFORMDW 
ENDSELECT 
PRINTFORMW 又走了一小段路，发现路边掉着一个像是魔理沙的遗失物的东西
IF !RAND:3
		LOCALS = %TEXTR("マジックポーション/破眠ポーション/ポーション")%
		CALL GET_ITEM(LOCALS, 1, 1)
ELSE
	LOCALS = %TEXTR("冬虫夏草/やばいキノコ/魔法のキノコ")%
	CALL GET_ITEM(LOCALS, 3, 1)
ENDIF
RETURN 1
