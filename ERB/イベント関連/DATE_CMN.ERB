;FileName_DATE_CMN.ERB ----------------------------- Rev1.01
;约会帰りイベント (CFLAG:13)
;CALL		USER
;ARG		角色NO
;RETURN		VOID
;COMMENT	
;-----------------------------------------------------------
@DATE_EVENT(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM 珠不足
#DIM 経験不足
#DIM DATE_SCORE

VARSET LOCAL
;中止フラグ（外部参照にて使用のこと 例:LOCAL@DATE_EVENT:2 = 1 太几把牛逼了，推荐用秘籍写控制流。
LOCAL:2 = 0
SIF LOCAL:2
	RETURN 1
;パラメータによる発生基礎値生成

DATE_SCORE = DATE_EVENT_CHECKSUM(ARG)

;別れ際にプレゼント
CALL GIFT(ARG)
IF RESULT == 1
;合意無し（キス成功してない）
;修改约会后初吻判定
;ELSEIF !(CFLAG:ARG:既成事実 & 合意_キス) && !(CFLAG:ARG:デート後イベントフラグ & 1)
ELSEIF TALENT:ARG:キス未経験 && !(CFLAG:ARG:13 & 1) && CSTR:ARG:初吻位置 != "约会后回去的路上"
	;成功判定
	IF (DATE_SCORE > 220 + TALENT:ARG:一線越えない * 30 + ABS(TALENT:ARG:キス未経験 * 20)) && CFLAG:ARG:合意判定 > 180 && (TALENT:ARG:思慕 || TALENT:ARG:恋慕)
		CALL KOJO_MESSAGE_SEND("SP_EVENT",1,ARG,0,DATE_SCORE)
		;中止フラグ
		IF !TCVAR:ARG:中止接吻
			CALL ADD_KISS(ARG)
			SETBIT CFLAG:ARG:约会後イベントフラグ , 0
		ENDIF
	ELSEIF !MARK:ARG:反発刻印
		CALL KOJO_MESSAGE_SEND("SP_EVENT",3,ARG,0)
	ENDIF
	EXP:ARG:愛情経験 += 10
;反発刻印消去処理
ELSEIF MARK:ARG:反発刻印 && DATE_SCORE > 50
	;ABL:親密LVUP処理取り込み。解読が面倒だったので要所々々取り摘んで…
	FOR LOCAL,0,4
		珠不足 = 0
		経験不足 = 0
		SIF JUEL_DEMAND(9,LOCAL,0,ARG) == -2
			BREAK
		SIF JUEL_DEMAND(9,LOCAL,0,ARG) < 0
			CONTINUE
		;必要な宝珠を尋找
		FOR LOCAL:1,0,100
			IF JUEL_DEMAND(9,LOCAL,LOCAL:1,ARG) > 0
				IF JUEL:(ARG):(LOCAL:1) < JUEL_DEMAND(9,LOCAL,LOCAL:1,ARG) / 2
					珠不足 ++
					BREAK
				ENDIF
			ENDIF
		NEXT
		SIF 珠不足
			CONTINUE
		;必要な経験を尋找
		FOR LOCAL:1,0,100
			IF EXP_DEMAND(9,LOCAL,LOCAL:1,ARG) > 0
				IF  EXP:(ARG):(LOCAL:1) < EXP_DEMAND(9,LOCAL,LOCAL:1,ARG) / 2
					経験不足 ++
					BREAK
				ENDIF
			ENDIF
		NEXT
		SIF 経験不足
			CONTINUE
		;ここまで来れたら反発刻印消去
		;要するに约会でいい雰囲気＋親密LVUP水準の1/2満たしたら反発消去
		MARK:ARG:反発刻印 --
		CALL KOJO_MESSAGE_SEND("SP_EVENT",3,ARG,(MARK:ARG:反発刻印 + 1),DATE_SCORE)
		PRINTL
		IF MARK:ARG:反発刻印
			PRINTFORMW %CALLNAME:ARG%的反感刻印LV下降为{MARK:ARG:反発刻印}了
		ELSE
			PRINTFORMW %CALLNAME:ARG%失去了反感刻印LV1
		ENDIF
		BREAK
	NEXT
;告白していない（MASTERに恋人が居ない）
ELSEIF !(CFLAG:ARG:既成事実 & 合意_恋人) && !(CFLAG:ARG:デート後イベントフラグ & 2) && !FLAG:告白禁止 && CAN_MAKE_恋人()
	;成功判定
	IF (DATE_SCORE > 530 + TALENT:ARG:一線越えない * 20)
		CALL DATE_EVENT_CONFESSION(ARG)
	;贈り物イベント
	ELSEIF GIFT_DATE_CHECK(ARG)
		CALL GIFT_DATE_EVENT(ARG)
	ELSEIF GROUPMATCH(TALENT:ARG:PREGNANCY_TYPE, PREGNANCY_EGGS, PREGNANCY_CLUTCH) && IS_FALLEN(ARG) && EGG_GIFT_DATE_CHECK(ARG)
		CALL EGG_GIFT_DATE_EVENT(ARG)
	ELSEIF !MARK:ARG:反発刻印
		CALL KOJO_MESSAGE_SEND("SP_EVENT",3,ARG,0,DATE_SCORE)
	ENDIF
;贈り物イベント
ELSEIF GIFT_DATE_CHECK(ARG)
	CALL GIFT_DATE_EVENT(ARG)
ELSEIF GROUPMATCH(TALENT:ARG:PREGNANCY_TYPE, PREGNANCY_EGGS, PREGNANCY_CLUTCH) && IS_FALLEN(ARG) && EGG_GIFT_DATE_CHECK(ARG)
	CALL EGG_GIFT_DATE_EVENT(ARG)
ELSE
	CALL KOJO_MESSAGE_SEND("SP_EVENT",3,ARG,0,DATE_SCORE)
ENDIF

@DATE_EVENT_CHECKSUM(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
LOCAL = MARK:ARG:不埒刻印 * 10 + MARK:ARG:快楽刻印 * 10
IF TALENT:ARG:恋慕
	LOCAL += MIN(ABL:ARG:親密 * 10, 100) + MIN(ABL:ARG:欲望 * 10,100) + MIN(ABL:ARG:奉仕精神 * 10,100)
	LOCAL += MIN(EXP:ARG:デート経験,100) + MIN(EXP:ARG:愛情経験,100)
ELSEIF TALENT:ARG:思慕
	LOCAL += MIN(ABL:ARG:親密 * 10, 50) + MIN(ABL:ARG:欲望 * 10,50) + MIN(ABL:ARG:奉仕精神 * 10,50)
	LOCAL += MIN(EXP:ARG:デート経験,50)
ENDIF
LOCAL += GETPALAMLV(PALAM:ARG:欲情,10) * 5 + GETPALAMLV(PALAM:ARG:好意,10) * 5 + GETPALAMLV(PALAM:ARG:恭順,10) * 5
;60
LOCAL += BASE:ARG:ムード / 50 + (1000 - BASE:ARG:理性) / 30
LOCAL += TALENT:ARG:度胸 * 10 + TALENT:ARG:性的興味 * 10 - TALENT:ARG:自制心 * 10 - TALENT:ARG:無関心 * 10
RETURNF LOCAL

@DATE_EVENT_CONFESSION(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
CALL KOJO_MESSAGE_SEND("SP_EVENT",2,ARG,0)
PRINTFORML 对%CALLNAME:ARG%的告白…
CALL ASK_YN(@"接受%\@ TALENT:MASTER:左拥右抱 ? # （只能有1名恋人）\@%","拒绝")
IF !RESULT
	SETBIT CFLAG:ARG:既成事實 , 2
	SETBIT CFLAG:MASTER:既成事實, 2
	TALENT:MASTER:恋人 = NO:ARG
	TALENT:ARG:恋人 = 1
	SETBIT CFLAG:ARG:约会後イベントフラグ , 1
	CALL KOJO_MESSAGE_SEND("SP_EVENT",2,ARG,1)
	PRINTL
	PRINTFORMW 与%CALLNAME:ARG%成为了恋人
ELSE
	CALL KOJO_MESSAGE_SEND("SP_EVENT",2,ARG,2)
ENDIF

@GIFT(ARG)
#DIM 好感度上升值
#DIM 礼物评价
;约会前好感度と现好感度を比较
#LOCALSIZE 1
#LOCALSSIZE 1
;多人约会移除
SIF 同行人数() > 1
	RETURN 0
好感度上升值 = CFLAG:ARG:2 - TFLAG:约会前好感度
IF DAY:2 == 4 && DAY:3 == 24 && ITEM:94 && TFLAG:约会前好感度
	PRINTFORML 要送出圣诞礼物吗？
	CALL ASK_YN
	IF !RESULT
		PRINTFORMW 把礼物送给了%CALLNAME:ARG%
		ITEM:94 = 0
		IF TALENT:ARG:恋人
			PRINTFORMW 能看见%CALLNAME:ARG%的变得一片通红
			PRINTFORMW ……得到了对脸颊的一吻作为回礼
			礼物评价 = 10
		ELSEIF TALENT:ARG:恋慕
			PRINTFORMW 能看见%CALLNAME:ARG%的变得一片通红
			PRINTFORMW 受到礼物的%CALLNAME:ARG%感觉非常幸福
			礼物评价 = 7
		ELSEIF TALENT:ARG:思慕
			PRINTFORML %CALLNAME:ARG%惊讶之余很开心的接受了
			PRINTFORML %CALLNAME:ARG%面对表示好意的礼物、更加在意起%CALLNAME:MASTER%了
			礼物评价 = 5
		ELSE
			PRINTFORMW %CALLNAME:ARG%因为受到的高价礼物显得有些不知所措、不过并没有讨厌
			礼物评价 = 2
		ENDIF
		CALL CHANGE_CFLAG(2, ARG, 好感度上升值 * 礼物评价 / 5)
		CALL CHANGE_CFLAG(4, ARG, 好感度上升值 * 礼物评价 / 10)
		RETURN 1
	ELSE
		RETURN 0
	ENDIF
ELSE
	RETURN 0
ENDIF

@WITH_恋人(ARG)
#LOCALSIZE 2
#LOCALSSIZE 1
#FUNCTION
;恋人の何人とARGが同じ場所に居るかを返す
VARSET LOCAL
SIF ARG == 0
	ARG = MASTER
FOR LOCAL,1,CHARANUM
	SIF CFLAG:LOCAL:現在位置 == CFLAG:ARG:現在位置 && TALENT:LOCAL:恋人
		LOCAL:1 ++
NEXT
RETURNF LOCAL:1

@CAN_MAKE_恋人()
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
SIF POLYAMOUR_CHEAT || TALENT:MASTER:左拥右抱
	RETURNF 1
SIF INRANGECARRAY(TALENT:恋人, 1, CHARANUM, 1, CHARANUM) <= FLAG:追加恋人枠
	RETURNF 1
RETURNF 0
;===========================================
;接吻経験や初吻処理などをまとめてやる関数
;===========================================
@ADD_KISS(ARG, ARG:1 = 1, ARG:2 = 0) ;custom code
#LOCALSIZE 1
#LOCALSSIZE 1
IF TALENT:MASTER:キス未経験
	CALL SET_FIRSTKISS(MASTER, ARG, ARG:2 == 0 ? 1 # 0) ;custom code, mutual kiss returns 1, so it's set to outside of date (0), on date by default (1)
	CALL AddEXP("愛情経験", ARG, 10) ;custom code
ENDIF
IF TALENT:ARG:キス未経験
	CALL SET_FIRSTKISS(ARG, MASTER, ARG:2 == 0 ? 1 # 0) ;custom code
	CALL AddEXP("愛情経験", ARG, 10) ;custom code
ENDIF
CALL AddEXP("接吻経験", ARG, ARG:1) ;custom code
CALL AddEXP("接吻経験", MASTER, ARG:1) ;custom code
SETBIT CFLAG:ARG:既成事実 , 0

