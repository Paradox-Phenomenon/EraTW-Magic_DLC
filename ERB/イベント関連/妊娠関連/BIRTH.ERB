@BIRTH(ARG)
#DIM CHILDNUM
#DIM DYNAMIC INITCHILDNUM
#DIM DYNAMIC CHILDCOUNT
	;make sure pregnancy is at least 1, set variables.
CFLAG:ARG:WithChildCount = MAX(CFLAG:ARG:WithChildCount,1)
PregnancyProgress:ARG:0 = MAX(PregnancyProgress:ARG:0,101)
INITCHILDNUM = (CFLAG:ARG:子供人数+1) % MAXCHILD
CHILDCOUNT = CFLAG:ARG:子供人数
CFLAG:ARG:LatestChildCount = COUNT_BIRTH_MATES(ARG)
CFLAG:ARG:BirthEventsCount++
DRAWLINE
$LOOP
;妊娠消去、出産経験、性別の決定、誕生日決定
	;reduce with child count and remove a pregnancy tracker once for each child.
CFLAG:ARG:WithChildCount -= 1
CALL REMOVE_PREGNANCY_PROGRESS(ARG)
EXP:ARG:出産経験 += 1
	;Moved.
CFLAG:ARG:子供人数 ++
CFLAG:MASTER:子供人数 ++
CFLAG:ARG:育児人数 ++
CFLAG:MASTER:育児人数 ++
Qol_Info_Count_Array:ARG:Qol_Count_Birth ++
CHILDNUM = CFLAG:ARG:子供人数 % MAXCHILD
SIF !(CFLAG:ARG:子供人数 % MAXCHILD)
	CHILDNUM = MAXCHILD
IF FLAG:子供の性別
	CHILD_SEX:ARG:CHILDNUM = FLAG:子供の性別
ELSE
	CHILD_SEX:ARG:CHILDNUM = RAND:2 + 1
ENDIF
CHILD_BIRTHDAY:ARG:CHILDNUM = DAY
CHILD_BIRTHDATE:ARG:CHILDNUM = (DAY / 124 + (DAY % 124 ? 1 # 0)) * 1000
CHILD_BIRTHDATE:ARG:CHILDNUM += DAY:2 * 100 + DAY:3
CHILD_WEATHER:ARG:CHILDNUM = %GET_WEATHER()%

IF CFLAG:ARG:無自覚妊娠
	CHILD_LOVE:ARG:CHILDNUM = -100
ELSEIF TALENT:ARG:恋慕
	CHILD_LOVE:ARG:CHILDNUM = 300
ELSEIF TALENT:ARG:思慕
	CHILD_LOVE:ARG:CHILDNUM = 200
ELSE
	CHILD_LOVE:ARG:CHILDNUM = 100
ENDIF

SIF !CFLAG:ARG:無自覚妊娠 && ITEM:私達だけが知る哀嘆 == 1
	CHILD_LOVE:ARG:CHILDNUM += 150

	;loop again if there are more children to be born.
SIF CFLAG:ARG:WithChildCount && PregnancyProgress:ARG:0 > 100
	GOTO LOOP
	;only send KOJO event once, differentiate live birth and hatching, and pass the number of the first child being born as ARG:1.
IF CFLAG:ARG:無自覚妊娠
	LOCAL:1 = 4
ELSEIF TALENT:ARG:恋慕
	LOCAL:1 = 1
ELSEIF TALENT:ARG:思慕
	LOCAL:1 = 2
ELSE
	LOCAL:1 = 3
ENDIF
IF TALENT:ARG:NESTING
	CALL KOJO_MESSAGE_SEND("EVENT",0,ARG,LOCAL:1,INITCHILDNUM,"HATCHING")
ELSE
	CALL KOJO_MESSAGE_SEND("EVENT",25,ARG,LOCAL:1,INITCHILDNUM)
ENDIF

	;separate loop to name all children, use LOCAL instead of CHILDNUM, account for pregnancy types.
FOR LOCAL,INITCHILDNUM,INITCHILDNUM+CFLAG:ARG:LatestChildCount
	;あらかじめ自立先を決めちゃう（自立するときにもっかい決める）
	CALL 自立先選定(ARG, LOCAL)
	IF FLAG:EGGNANCY && GROUPMATCH(TALENT:ARG:PREGNANCY_TYPE, PREGNANCY_EGGS, PREGNANCY_CLUTCH)
		PRINTFORMW %CALLNAME:ARG%が卵を産むと、すぐに子供が孵りました
	ELSE
		PRINTFORMW \@ TALENT:ARG:NESTING ? %CALLNAME:ARG%の卵が孵りました # %CALLNAME:ARG%は、%CALLNAME:MASTER%の子供を無事出産しました\@
	ENDIF
	PRINTFORMW \@ CHILD_SEX:ARG:LOCAL == 1 ? %CALLNAME:ARG%に似た元気な女の子 # %CALLNAME:MASTER%に似た元気な男の子 \@です
	PRINTFORMW %CALLNAME:ARG%は産まれたばかりの赤ん坊を受け取ると、優しく抱きかかえ母乳を飲ませ始めた
	IF TALENT:ARG:母性 == 0
		PRINTFORMW %CALLNAME:ARG%は[母性]に目覚めた！
		TALENT:ARG:母性 = 1
	ENDIF
	PRINTL ******************************************************************
	CHILDCOUNT++
	PRINTFORML 第{CHILDNUM}子　母：%CALLNAME:ARG%　父：%CALLNAME:MASTER%
	PRINTFORML 　性別：\@ CHILD_SEX:ARG:LOCAL == 1 ? 女 # 男 \@
	PRINTFORM 誕生日：
	CALL PRINT_DATE(DAY)
	PRINTFORML  %FESTIVAL()% -%GET_WEATHER()%-
	;PRINTFORML 　身長：
	;PRINTFORML 　体重：
	;PRINTFORML 　種族：
	;PRINTFORML 髪の色：
	;PRINTFORML 目の色：
	PRINTL ******************************************************************
	CALL CHILD_NAME(ARG, LOCAL)
NEXT

;育児中・母性追加
CFLAG:ARG:出産経過日 = 1 + FLAG:妊娠日程倍率
CFLAG:ARG:無自覚妊娠 = 0
CFLAG:ARG:身に覚え_母 = 0
CFLAG:ARG:身に覚え_父 = 0
CFLAG:ARG:妊娠自覚状態 = 0 

CFLAG:ARG:産休中 = 0
	;set pregnancy or nesting progress to the next due child (if any) instead of zero.
IF GROUPMATCH(TALENT:ARG:PREGNANCY_TYPE, PREGNANCY_EGGS, PREGNANCY_CLUTCH) && !FLAG:EGGNANCY
	TALENT:ARG:NESTING = PregnancyProgress:ARG:0
	CFLAG:ARG:妊娠経過日数 = 0
ELSE
	CFLAG:ARG:妊娠経過日数 = PregnancyProgress:ARG:0
	TALENT:ARG:NESTING = 0
		;Only unset pregnancy talent if progress is below 20.
	SIF CFLAG:ARG:妊娠経過日数 < 20
		TALENT:ARG:妊娠 = 0
ENDIF
EXP:ARG:愛情経験 += 10
IF FLAG:甲斐性無
	PRINTFORML 我が子の誕生に%CALLNAME:MASTER%は
	CALL ASK_YN("親としての責任感が芽生えるのを感じた","今後起こりうる様々な事態への不安を感じた")
	IF !RESULT
		PRINTFORMW %CALLNAME:MASTER%は甲斐性無しではなくなった
			;only set the flag if it's turned off.
		FLAG:甲斐性無 = 0
	ELSE
		PRINTFORMW 人の性格がそんなに簡単に変えられ成長できるなら誰も苦労しません
		PRINTFORMW %CALLNAME:MASTER%は前以上に頼りない性格のまま、%CALLNAME:ARG%と仲良く育児に臨むのでした
	ENDIF
ENDIF

@CHILD_NAME(YOME, CHILDNUM)
#DIM YOME
#DIM CHILDNUM
#DIMS PROPOSED_NAME, MAXCHILD

IF CHILD_SEX:YOME:CHILDNUM == 1
	PROPOSED_NAME:0 = %ランダムキャラ_命名(YOME)%
ELSE
	PROPOSED_NAME:0 = %男の子_命名(YOME, CHILDNUM)%
ENDIF
$LOOP0
PRINTL 子供の名前を決めましょう
PRINTFORML 
CALL ASK_M("自分で決める",1, "ランダム候補一覧",1, @"%CALLNAME:YOME%の提案に従って「%PROPOSED_NAME:0%」と名付ける",1)
;CALL ASK_M("自分で決める",1,"ランダム候補一覧",1,"「メキシコに吹く熱風！」という意味の「サンタナ」というのはどうかな！",1)
SELECTCASE RESULT
	CASE 0
		$LOOP1
		PRINTL 子供の名前を入力してください
		INPUTS
		IF RESULTS == ""
			GOTO LOOP1
		ELSE
			PROPOSED_NAME:0 = %RESULTS%
			CALL CHK_CHILDNAME_DUPLICATION(PROPOSED_NAME:0)
			PRINTFORML %PROPOSED_NAME:0%でいいですか？
			CALL ASK_YN
			IF RESULT
				GOTO LOOP1
			ELSE
				CHILDNAME:YOME:CHILDNUM = %PROPOSED_NAME:0%
			ENDIF
		ENDIF
	CASE 1
		$LOOP2
		;changed to a fixed number because MAXCHILD has been expanded
		FOR LOCAL, 1, 31
			IF CHILD_SEX:YOME:CHILDNUM == 1
				PROPOSED_NAME:LOCAL = %ランダムキャラ_命名(YOME)%
			ELSE
				PROPOSED_NAME:LOCAL = %男の子_命名(YOME, CHILDNUM)%
			ENDIF
			PRINTFORML [{LOCAL}] - %PROPOSED_NAME:LOCAL%
		NEXT
		DRAWLINE
		PRINTFORML [99] - 候補再生成
		PRINTFORML [100] - 戻る
		$LOOP3
		INPUT
		SELECTCASE RESULT
			;changed to a fixed number because MAXCHILD has been expanded
			CASE 1 TO 30
				LOCAL = RESULT
				CALL CHK_CHILDNAME_DUPLICATION(PROPOSED_NAME:LOCAL)
				PRINTFORML %PROPOSED_NAME:LOCAL%でいいですか？
				CALL ASK_YN
				IF RESULT
					GOTO LOOP0
				ELSE
					CHILDNAME:YOME:CHILDNUM = %PROPOSED_NAME:LOCAL%
				ENDIF
			CASE 99
				GOTO LOOP2
			CASE 100
				GOTO LOOP0
			CASEELSE
				GOTO LOOP3
		ENDSELECT
	CASE 2
		;PRINTFORML 怒った%CALLNAME:YOME%が名前を決めてしまった…
		PRINTFORML %CALLNAME:YOME%は嬉しそうに我が子へ呼びかけている
		CHILDNAME:YOME:CHILDNUM = %PROPOSED_NAME:0%
ENDSELECT

PRINTFORML %CHILDNAME:YOME:CHILDNUM%という名前になりました
TALENT:YOME:育児中 = CHILDNUM
CALL ASK_DIARY(@"%CALLNAME:YOME%に\@ CHILD_SEX:YOME:CHILDNUM == 1? 女# 男\@の子が生まれた。<br>%CHILDNAME:YOME:CHILDNUM%と名付けた。")
;----------------------------------------------------
;そのキャラに特定の年齢の子供がいたら返す関数
;----------------------------------------------------
@CHK_HAVE_CHILD(ARG,ARG:1,ARG:2)
#FUNCTION
#DIM 年齢
SIF !CFLAG:ARG:子供人数
	RETURNF 0

FOR LOCAL, 1, MAXCHILD + 1
	SIF CHILDNAME:ARG:LOCAL == ""
		CONTINUE
	年齢 = DAY - CHILD_BIRTHDAY:ARG:LOCAL
	SIF INRANGE(年齢,ARG:1,ARG:2-1)
		RETURNF LOCAL
NEXT

RETURNF 0
;----------------------------------------------------
;誕生日の子供がいるか返す関数
;eraTW4.570proto_bugfix_m05での仕様変更
;・REFを使用し、配列を書き換えるF関数にした（引数を全て渡さないとエラーになる）
;・仕様上、配列の想定最大要素数は10*キャラクタ数上限となる（＝RESULTの要素数を突破してエラーが出たので仕様変更）
;・BREAKやCONTINUEを使用して処理を効率化
;----------------------------------------------------
@CHILD_HAPPY_BIRTHDAY(CNT_BIRTHDAY, NAME_CHILD, AGE_CHILD)
#FUNCTION
#DIM CHARA
#DIM CHILDNUM
#DIM  REF CNT_BIRTHDAY
#DIMS REF NAME_CHILD
#DIM  REF AGE_CHILD
FOR CHARA, 1, CHARANUM
	SIF !CFLAG:CHARA:子供人数
		CONTINUE
	FOR CHILDNUM, 1, MIN(MAXCHILD + 1, CFLAG:CHARA:子供人数 + 1)
		;名無し≒未登録なら次のキャラへ
		SIF !STRLENS(CHILDNAME:CHARA:CHILDNUM)
			BREAK
		;誕生日以外はスキップ
		SIF (DAY - CHILD_BIRTHDAY:CHARA:CHILDNUM) % 124
			CONTINUE
		CNT_BIRTHDAY ++
		NAME_CHILD:CNT_BIRTHDAY = %CHILDNAME:CHARA:CHILDNUM%
		AGE_CHILD:CNT_BIRTHDAY = (DAY - CHILD_BIRTHDAY:CHARA:CHILDNUM) / 124
	NEXT
NEXT
RETURNF CNT_BIRTHDAY

;子供の名前被りチェック
@CHK_CHILDNAME_DUPLICATION(ARGS)
#DIM C_ID
FOR C_ID,1,CHARANUM
	;"FOR LOCAL,0,10"から修正
	FOR LOCAL,1, MAXCHILD + 1
		SIF CHILDNAME:C_ID:LOCAL == ARGS
			CALL COLORMESSAGE(@"%CALLNAME:C_ID%に同名の子供がいます",C_YELLOW,1)
	NEXT
NEXT