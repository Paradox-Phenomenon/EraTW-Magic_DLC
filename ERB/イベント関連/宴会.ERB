@ENKAI_SETTING
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CNT
#DIM L_WEIGHT
#DIM L_WEIGHT_TOTAL
#DIM L_WEIGHT_RANDOM
#DIMS L_ENKAI_XML

;------------------------------------------------------------------------------------------------------
;宴会の開催判定
;------------------------------------------------------------------------------------------------------
;1ターンで飲む酒の量は経過時間 * 10 通常は30分なので300、宴会規模1200なら2時間程度の宴会となる
;主催者は宴会の準備と片づけの仕事をしなければならない
;一日に複数の宴会を開ける仕様ではないので注意（人が分散しちゃって寂しいし…）
;DAY:2が季節(1=春 2=夏 3=秋 4=冬)、DAY:3が日付(1～31)
;------------------------------------------------------------------------------------------------------
PRINTL  

;開催判定は宴会フラグが立っていない状態でしか行われない（バグ防止）
SIF FLAG:宴会開催FLAG
	RETURN
	
;宴会参加者判定済み変数を初期化
ENKAI_ENTRY_DONE = 0
;開催可能宴会の種類と比重を格納するXML
L_ENKAI_XML = <ROOT />

;宴会が開催可能かチェック
L_WEIGHT_TOTAL = 0
FOR CNT , ENKAI_ID_MIN , ENKAI_ID_MAX
	;ENKAI_XXX_TITLEを存在確認に使う
	SIF EXISTFUNCTION(@"ENKAI_{CNT}_TITLE") == 0
		CONTINUE

	;開催可能か確認
	CALLFORM ENKAI_{CNT}_ABLE
	SIF RESULT == 0
		CONTINUE

	;宴会の比重をチェック
	CALLFORM ENKAI_{CNT}_WEIGHT
	L_WEIGHT = RESULT
	IF L_WEIGHT == 0
		;もし比重の設定が0ならその時点で開催が確定する
		FLAG:宴会開催フラグ = CNT
		BREAK
	ELSE
		L_WEIGHT_TOTAL += L_WEIGHT
		XML_ADDNODE L_ENKAI_XML , @"/ROOT" , @"<ENKAI />"
		XML_ADDNODE L_ENKAI_XML , @"/ROOT/ENKAI[last()]" , @"<ENKAI_ID>{CNT}</ENKAI_ID>"
		XML_ADDNODE L_ENKAI_XML , @"/ROOT/ENKAI[last()]" , @"<ENKAI_WEIGHT>{L_WEIGHT}</ENKAI_WEIGHT>"
	ENDIF
NEXT

;ここまで来て宴会比重フラグが0かつ開催が確定した宴会がないなら開催できる宴会はない
SIF FLAG:宴会開催フラグ == 0 && L_WEIGHT_TOTAL == 0
	RETURN 0

;ここまで来て宴会開催フラグが立ってないなら開催できる宴会を抽選する
IF FLAG:宴会開催フラグ == 0
	L_WEIGHT_RANDOM = RAND:L_WEIGHT_TOTAL
	L_WEIGHT_TOTAL = 0
	FOR CNT , 1 , XML_GET(L_ENKAI_XML , @"/ROOT/ENKAI") + 1
		RESULTS:0 = 
		XML_GET L_ENKAI_XML , @"/ROOT/ENKAI[{CNT}]/ENKAI_WEIGHT/text()" , RESULTS
		L_WEIGHT_TOTAL += TOINT(RESULTS)

		RESULTS:0 = 
		XML_GET L_ENKAI_XML , @"/ROOT/ENKAI[{CNT}]/ENKAI_ID/text()" , RESULTS

		IF L_WEIGHT_TOTAL > L_WEIGHT_RANDOM
			FLAG:宴会開催フラグ = TOINT(RESULTS:0)
			BREAK
	ENDIF
	NEXT
ENDIF

;宴会開催回数を記録
宴会開催回数:(FLAG:宴会開催フラグ)++
;ここまで来たら開催する宴会の種類が確定しているので呼び出し
CALL ENKAI_LOADDATA(FLAG:宴会開催フラグ)

;現在の参加人数をリセット
FLAG:参加人数 = 0
CALL SET_ENKAI_LOCATIONDISPLAY
SIF FLAG:宴会開催FLAG
	CALL 宴会概要
PRINTL  

RETURN 1


@ENKAI_ENTRY
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC HOST_LIST  , 人物数量上限;主催者参加
#DIM DYNAMIC GUEST_LIST , 人物数量上限;客参加
#DIM DYNAMIC NG_LIST    , 人物数量上限;来ない
#DIM ResidentRate	;そのMapに住んでいる角色の参加確率
#DIM VisitorRate	;そのMapに住んでいない角色の参加確率
;---   宴会の参加者決定   -----------------------------------------------------------------------------
;CFLAG:宴会参加 0=不参加 1=参加 2=主催者 3=脱落者 4=飲まないけど参加
;宴会パッチ：TW既存の宴会の定義を各ファイルに切り分け
;------------------------------------------------------------------------------------------------------
;宴会パッチ：もしその宴会に対して参加者確定処理が既に終わっていれば何もしない
SIF ENKAI_ENTRY_DONE
	RETURN 0

SIF INRANGE(FLAG:宴会開催フラグ , ENKAI_ID_MIN , ENKAI_ID_MAX) == 0
	RETURN 0

;フラグ初期化
CVARSET CFLAG, GETNUM(CFLAG, "宴会参加"), 0, 1

;霊夢の差し入れ依頼などで宴会規模が大きくなるような処理を行う
TRYCALLFORM ENKAI_{FLAG:宴会開催フラグ}_パラメータ補正

;主催者、ゲスト、NGキャラ、同じマップの住人参加率、違うマップの住人参加率を設定
CALLFORM ENKAI_{FLAG:宴会開催フラグ}_参加者設定(HOST_LIST , GUEST_LIST , NG_LIST , ResidentRate , VisitorRate)
;上記の設定値を元に実際の参加者を確定させる
CALL ENKAI_ENTRY_CHARALIST(HOST_LIST, GUEST_LIST, NG_LIST, ResidentRate, VisitorRate)

;宴会パッチ：@ENKAI_ENTRY実行済みフラグ立て
ENKAI_ENTRY_DONE = FLAG:宴会開催フラグ

RETURN 1


;リストを利用した宴会キャラのプリセット関数
@ENKAI_ENTRY_CHARALIST(HOST_LIST, GUEST_LIST, NG_LIST, ResidentRate, VisitorRate)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM REF HOST_LIST  ;主催者参加
#DIM REF GUEST_LIST ;客参加
#DIM REF NG_LIST    ;来ない
#DIM L_NUM
#DIM L_ID
#DIM ResidentRate
#DIM VisitorRate
#DIM VenueMap

VenueMap = FLAG:宴会会場 / 100

L_NUM = FINDELEMENT(HOST_LIST, 0)
IF L_NUM >= 1
	FOR L_ID, 0, L_NUM
		CFLAG:(HOST_LIST:L_ID):宴会参加 = 2
	NEXT
ENDIF
L_NUM = FINDELEMENT(GUEST_LIST, 0)
IF L_NUM >= 1
	FOR L_ID, 0, L_NUM
		CFLAG:(GUEST_LIST:L_ID):宴会参加 = 1
	NEXT
ENDIF
;設定したことを明確化するために-1にします
L_NUM = FINDELEMENT(NG_LIST, 0)
IF L_NUM >= 1
	FOR L_ID, 0, L_NUM
		CFLAG:(NG_LIST:L_ID):宴会参加 = -1
	NEXT
ENDIF

FOR LOCAL, 1, CHARANUM
	IF CFLAG:LOCAL:宴会参加
		SIF CFLAG:LOCAL:宴会参加 < 0
			CFLAG:LOCAL:宴会参加 = 0
		CONTINUE
	ENDIF
	IF GET_MAPID(CFLAG:LOCAL:自宅位置) == VenueMap
		SIF RAND:100 < ResidentRate
			CFLAG:LOCAL:宴会参加 = 1
	ELSE
		SIF RAND:100 < VisitorRate
			CFLAG:LOCAL:宴会参加 = 1
	ENDIF
NEXT

@ENKAI_WORK(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;宴会の行動内容を入力する
;NOSAMES:全部の引数が異なると1, 1つでも一致していると0を返す
IF FLAG:宴会開催FLAG > 0 && (NOSAMES(CFLAG:ARG:職種, JOB_宴会準備, JOB_宴会参加, JOB_宴会の片づけ, JOB_酔いつぶれる) || CFLAG:ARG:行動 == 0)
	;宴会の時間になったら准备仕事の量に応じて主催者が動き始める
	IF TIME >= FLAG:開始時間 - (FLAG:宴会規模 / 30) - 15 && TIME < FLAG:開始時間 && CFLAG:ARG:宴会参加 == 2
		CALL ENKAI_PREPARE(ARG)
		RETURN 1
	;玩耍に来るだけの奴は時間になったら玩耍に来る
	ELSEIF DAY == FLAG:開始日 && TIME >= FLAG:開始時間 && CFLAG:ARG:同行 == 0
		CALL ENKAI_START(ARG)
		RETURN 1
	;とっくに始まってる場合
	ELSEIF 宴会開催中判定() && CFLAG:ARG:同行 == 0
		CALL ENKAI_START(ARG)
		RETURN 1
	ENDIF
ELSEIF FLAG:宴会開催FLAG > 0
	RETURN 1
ENDIF
RETURN 0


@ENKAI_PREPARE(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;主催者の準備仕事
IF CFLAG:ARG:職種 != JOB_宴会準備
	MAXBASE:ARG:工作量 = FLAG:宴会規模 / 3
	;最大値、2400
	SIF MAXBASE:ARG:工作量 >= 2400
		MAXBASE:ARG:工作量 = 2400
	BASE:ARG:工作量 = MAXBASE:ARG:工作量
	CFLAG:ARG:職種 = JOB_宴会準備
	CFLAG:ARG:職場 = TFLAG:宴会場
	TCVAR:ARG:315 = 0
	CFLAG:ARG:行動 = 5
ENDIF
RETURN 1

@ENKAI_START(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;それぞれが飲むペースを変えるので、宴の規模に応じて工作量が変化
IF CFLAG:ARG:職種 != JOB_宴会参加 && TCVAR:ARG:烂醉 == 0
	MAXBASE:ARG:工作量 = FLAG:宴会規模
	;最大値、通常7200(半日)・酒呑み神なら制限無
	SIF MAXBASE:ARG:工作量 >= 7200 && TALENT:ARG:酒耐性 != 3
		MAXBASE:ARG:工作量 = 7200
	MAXBASE:ARG:工作量 += RAND:500
	IF TALENT:ARG:酒耐性 == -1
		TIMES MAXBASE:ARG:工作量, 0.75
	ELSEIF TALENT:ARG:酒耐性 == 1
		TIMES MAXBASE:ARG:工作量, 1.25
	ELSEIF TALENT:ARG:酒耐性 == 2
		TIMES MAXBASE:ARG:工作量, 1.5
	ELSEIF TALENT:ARG:酒耐性 == 3
		TIMES MAXBASE:ARG:工作量, 2.0
	ENDIF
	BASE:ARG:工作量 = MAXBASE:ARG:工作量
	;仕事内容・宴会に参加
	CFLAG:ARG:職種 = JOB_宴会参加
	CFLAG:ARG:職場 = TFLAG:宴会場
	CFLAG:ARG:現在位置 = TFLAG:宴会場
	;qol优化，更换礼服
	TCVAR:ARG:着替え = 宴会服决定(ARG)
	TCVAR:ARG:315 = 0
	CFLAG:ARG:行動 = 5
	IF CFLAG:ARG:宴会参加 == 2
		;主催者は片付け予定をセット(工作量は最大1200)
		CFLAG:ARG:片付け工作量 = MIN(FLAG:宴会規模 / 6, 1200)
		CFLAG:ARG:片付け場所 = FLAG:宴会会場
	ENDIF
ENDIF

RETURN 1


@ENKAI_KATAZUKE(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;主催者の片づけ仕事
MAXBASE:ARG:工作量 = CFLAG:ARG:片付け工作量
BASE:ARG:工作量 = MAXBASE:ARG:工作量
;仕事内容・宴会的善后
CFLAG:ARG:職種 = 50
CFLAG:ARG:職場 = GET_MAP_REPLACEMENT(CFLAG:ARG:片付け場所)
TCVAR:ARG:沒法幫忙 = 0
CFLAG:ARG:行動 = 5
RETURN 1


;宴会パッチ：各所で同じ判定をしていたので酔いつぶれ判定を独立関数(@宴会泥酔判定)に
@ENKAI_DRUNK(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
;酔いつぶれるラインを超えていたら戻る
SIF 宴会泥酔判定(ARG)
	RETURN 1

;酒を飲まないなら酔わない 
IF TALENT:ARG:酒耐性 == -2 || CFLAG:ARG:妊娠自覚状態 == 1
	CFLAG:ARG:職種 = 0
	CFLAG:ARG:宴会参加 = 4
	IF CFLAG:MASTER:現在位置 == CFLAG:ARG:現在位置
		PRINTFORMW %CALLNAME:ARG%似乎已经玩得尽兴了
	ENDIF
ELSE
	CFLAG:ARG:職種 = 0
	CFLAG:ARG:宴会参加 = 3
;	PRINTFORMW %CALLNAME:ARG%は微醺気分のようです
	IF CFLAG:MASTER:現在位置 == CFLAG:ARG:現在位置
		PRINTFORMW %CALLNAME:ARG%似乎已经玩得尽兴了
	ENDIF
ENDIF
RETURN 1

@ENKAI_END
#LOCALSIZE 1
#LOCALSSIZE 1
;会場となった場所は荒れ果てる、拠点外でも対象地点的污垢増加させるためTFLAG:宴会場ではない
SIF YOGORE:(FLAG:宴会会場) < 300
	YOGORE:(FLAG:宴会会場) += 1000
CALL ENKAI_STOP()

@ENKAI_STOP
#LOCALSIZE 1
#LOCALSSIZE 1
;悪天候などによる中止    因恶劣天气等原因中止
FOR LOCAL,0,CHARANUM
	SIF	CFLAG:LOCAL:宴会参加 == 0
		CONTINUE
	CFLAG:LOCAL:職種 = 0
	MAXBASE:LOCAL:工作量 = 0
	BASE:LOCAL:工作量 = 0
	CFLAG:LOCAL:宴会参加 = 0
	CFLAG:LOCAL:行動 = 0
	;需要清空宴会筹办者的收拾工作量，否则筹办者将于第二天因为收拾工作量错误地进入宴会参加状态。[CFLAG:宴会参加]将导致角色无法外出或出现在所属的地图上，在下一次宴会结束前无法解除。
	CFLAG:LOCAL:片付け工作量 = 0
NEXT
;FLAG:宴会開催FLAG = 0
FLAG:宴会規模 = 0
FLAG:宴会会場 = 0
TFLAG:宴会場 = 0
FLAG:開始時間 = 0
FLAG:開始日 = 0
FLAG:参加人数 = 0
FLAG:悪天候中止FLAG = 0
FLAG:宴会差し入れ = 0
;宴会会場表示 = 
TFLAG:宴会状態 = 0
;宴会パッチ：宴会終了時刻を削除
ENKAI_終了日 = -1
ENKAI_終了時刻 = -1

;宴会パッチ：宴会別終了処理を呼び出し
TRYCCALLFORM ENKAI_{FLAG:宴会開催フラグ}_事後処理

CATCH

ENDCATCH
FLAG:宴会開催フラグ = 0

RETURN 0

@宴会予定表示
#LOCALSIZE 1
#LOCALSSIZE 1
;宴会パッチ：宴会開催確定時のメッセージを宴会定義ファイルから表示する機能
TRYCCALLFORM ENKAI_{FLAG:宴会開催フラグ}_予定
	
CATCH
	PRINTFORM {FLAG:開始時間 / 60}:{(FLAG:開始時間 % 60)/10}{(FLAG:開始時間 % 60)%10}开始在%宴会場表示()%召开%EnkaiTitle%
ENDCATCH
RETURN 1

@SET_ENKAI_LOCATIONDISPLAY
#LOCALSIZE 1
#LOCALSSIZE 1
宴会会場表示 = 

@宴会場表示
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
LOCALS = 宴会場表示エラー
IF FLAG:宴会開催FLAG
	IF IN_HOME(FLAG:宴会会場)
		LOCALS = %NAME_FROM_PLACE(FLAG:宴会会場)%
	ELSE
		LOCALS = %GET_MAPNAME(FLAG:宴会会場/100)%的%GET_PLACENAME(FLAG:宴会会場)%
	ENDIF
ENDIF
RETURNF LOCALS

@宴会概要
;システムメッセージ
#LOCALSIZE 1
#LOCALSSIZE 1
PRINTFORML \@ FLAG:開始日 == 1? 明日# {FLAG:開始日}日后\@、{FLAG:開始時間 / 60}:{(FLAG:開始時間 % 60)/10}{(FLAG:開始時間 % 60)%10}开始要在%宴会場表示()%召开「%EnkaiTitle%」

;宴会パッチ：宴会定義に概要説明を表示する関数があれば表示、ないならTWデフォルト
TRYCCALLFORM ENKAI_{FLAG:宴会開催フラグ}_開催決定メッセージ
	
CATCH
PRINT 这样的话
IF FLAG:宴会規模 >= 5000
	PRINTW ……看起来这将是持久战啊
ELSEIF FLAG:宴会規模 >= 2500
	PRINTW 、这边也得充分准备呢
ELSEIF FLAG:宴会規模 >= 1500
	PRINTW 、正好可以用来联络感情
ELSE
	PRINTW 、应该将会是个不错的聚会
ENDIF
PRINTFORMW \@ FLAG:開始日 == 1? 时间上有一点仓促呢、要不要参加呢……# 要参加就得把预定空出来呢……\@
SIF FLAG:悪天候中止フラグ > 0
	PRINTFORMW 也说不准、碰上雨天就中止了……
ENDCATCH
FLAG:開始日 += DAY
RETURN 1

@宴会参加人数再計算
#LOCALSIZE 1
#LOCALSSIZE 1
;宴会の参加人数をセット    设定宴会参加人数
FLAG:参加人数 = 0
;FOR LOCAL,0,CHARANUM
;	IF (CFLAG:LOCAL:宴会参加 == 1 || CFLAG:LOCAL:宴会参加 == 2) && !TCVAR:LOCAL:烂醉
;		SIF CFLAG:LOCAL:現在位置 == TFLAG:宴会場
;			FLAG:参加人数 ++
;	ENDIF
;NEXT
LOCAL = 0
WHILE LOCAL + 1 < CHARANUM
	LOCAL = FINDCHARA(CFLAG:現在位置, TFLAG:宴会場, LOCAL + 1)
	IF LOCAL < 0
		BREAK
	ELSE
		;烂醉していない参加者および主催者をカウント    统计未醉酒的参会者及主办方
		SIF (CFLAG:LOCAL:宴会参加 == 1 || CFLAG:LOCAL:宴会参加 == 2) && !TCVAR:LOCAL:烂醉
			FLAG:参加人数 ++
	ENDIF
WEND

@宴会開催中判定
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
;RETURNF FLAG:宴会開催FLAG == 98 || FLAG:宴会開催FLAG == 99
RETURNF TFLAG:宴会状態 == 98 || TFLAG:宴会状態 == 99

@宴会場所在判定(ARG)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
RETURNF 宴会開催中判定() && CFLAG:ARG:現在位置 == TFLAG:宴会場

@宴会開始日判定()
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
RETURNF 宴会開催中判定() == 0 && DAY >= FLAG:開始日

;宴会パッチ：宴会の終了時刻になったかどうかを判定する式中関数を追加
;宴会終了時刻でない、あるいは宴会終了日時が設定されていなければ0を返す
@宴会期間終了判定()
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
SIF ENKAI_終了日 == -1
	RETURNF 0

IF DAY > ENKAI_終了日 || DAY == ENKAI_終了日 && TIME >= ENKAI_終了時刻
	RETURNF 1
ELSE
	RETURNF 0
ENDIF

;そのキャラが泥酔しているか判定する式中関数。泥酔しているなら非0を返す
;既に泥酔しているかどうかは判定しない
;CHRにキャラ登録番号を受け取る
@宴会泥酔判定(CHR = -1)
#LOCALSIZE 1
#LOCALSSIZE 1
#FUNCTION
#DIM CHR
#DIM CONST 泥酔閾値 = 80 ;MAXBASE:酒気 * 泥酔閾値 / 100で泥酔ラインを設定。それより高ければ泥酔判定される

SIF BASE:CHR:酒気 > MAXBASE:CHR:酒気 * 泥酔閾値 / 100
	RETURNF 1

RETURNF 0

@宴会服决定(ARG)
#FUNCTION
#LOCALSIZE 1
#LOCALSSIZE 1
SELECTCASE ARG
	CASE 15
		RETURNF [[晚宴礼服套装]]
	CASE 77,78,134
		RETURNF [[浴衣穿搭]]
	CASE 88
		RETURNF [[鸟兽伎乐套装]]
	CASE 102
		RETURNF [[晚宴礼服套装]]
	CASE 130
		RETURNF [[生足美鈴套]]
	CASEELSE
ENDSELECT
