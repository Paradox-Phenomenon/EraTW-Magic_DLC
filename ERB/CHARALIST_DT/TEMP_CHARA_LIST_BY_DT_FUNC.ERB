ELSE
	L_TEMPS += @"<button value='%C_BUTTON_CHANGE_CGROUP_NAME%'>[この列グループを改名]</button>　　　　"
	L_TEMPS += @"<button value='%C_BUTTON_REMOVE_CGROUP%'>[この列グループを削除]</button>"
	L_TEMPS += @"</p>"
ENDIF

HTML_PRINT L_TEMPS
