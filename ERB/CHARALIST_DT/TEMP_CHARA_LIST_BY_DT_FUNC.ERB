;編集終了選択肢
;この関数を抜けるには、この列グループに最低一個列を置かねばならない
FOR CNT_0 , 0 , MAX_COLUMN
	IF STRLENS(COLUMN_NAME:ARG_COLG:CNT_0) > 0
		HTML_PRINT @"<p align='center'><button value='%C_BUTTON_END%'>[編集を終了]</button></p>"
		BREAK
	ELSEIF CNT_0 == MAX_COLUMN - 1
		HTML_PRINT @"<p align='center'><font color='gray'><nonbutton title='処理を終了できません。列グループには最低一つの列が必要です'>[編集を終了]</nonbutton></font></p>"
	ENDIF
