#FUNCTIONS
#DIM ARG_INT

RETURNF TOSTR(ARG_INT / 0x10000 % 0x100 , "X2") + TOSTR(ARG_INT / 0x100 % 0x100 , "X2") + TOSTR(ARG_INT % 0x100 , "X2")


;INT型の数値をAARRGGBB形式の文字列にして返す
