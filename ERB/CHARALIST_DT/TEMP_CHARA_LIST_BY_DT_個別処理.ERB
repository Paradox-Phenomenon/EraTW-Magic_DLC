@LIST_DT_TALENT個別処理(ARG_ELEMENT = -1 , ARG_VALUE = 0 , ARG_SHORT = 0)
#DIM ARG_ELEMENT
#DIM ARG_VALUE
#DIM ARG_SHORT
IF ARG_ELEMENT == -1
	RESULTS = 値を渡し忘れてない？
	RETURN -1
ENDIF

;TW既存の関数による素質名の取得
RESULTS '= GET_TALENTNAME(ARG_ELEMENT , ARG_VALUE)
;省略指定なしならそのまま返す
SIF ARG_SHORT == 0
	RETURN 1

;以下省略処理
;一部の素質名は意味が重複していたり、長かったりするので省略処理をする
SELECTCASE ARG_ELEMENT
	CASE 13
		;プライド高い・低い
		RESULTS '= REPLACE(RESULTS , "プライド" , "")
	CASE 15
		;機嫌
		IF RESULTS == "不機嫌"
			RESULTS = 悪
		ELSEIF RESULTS == "上機嫌"
			RESULTS = 良
		ENDIF
	CASE 30
		;貞操観念・無頓着
		RESULTS '= REPLACE(RESULTS , "貞操" , "")
	CASE 40
		;痛みに強い・弱い
		RESULTS '= REPLACE(RESULTS , "痛みに" , "")
	CASE 41
		;濡れやすさ。略したいけどうまい略が思いつかない
		
	CASE 50
		;習得早い・遅い
		RESULTS '= REPLACE(RESULTS , "習得" , "")
	CASE 61
		;汚臭耐性
		IF RESULTS == "潔癖症"
			RESULTS = 潔癖
		ELSEIF RESULTS == "汚臭敏感"
			RESULTS = 敏感
		ELSEIF RESULTS == "汚臭鈍感"
			RESULTS = 鈍感
		ELSEIF RESULTS == "汚れ無視"
			RESULTS = 無視
		ENDIF
	CASE 70
		;快感の否定・快感に素直
		RESULTS '= REPLACE(RESULTS , "快感の" , "")
		RESULTS '= REPLACE(RESULTS , "快感に" , "")
	CASE 81
		;性別嗜好
		IF RESULTS == "両刀"
			;RESULTS = 両刀
		ELSEIF RESULTS == "男嫌い"
			RESULTS = 男嫌
		ELSEIF RESULTS == "女嫌い"
			RESULTS = 女嫌
		ELSEIF RESULTS == "人間不信"
			RESULTS = 不信
		ENDIF
	CASE 101
		;Ｃ感度
		RESULTS '= REPLACE(RESULTS , "Ｃ" , "")
	CASE 102
		;Ｖ感度
		RESULTS '= REPLACE(RESULTS , "Ｖ" , "")
	CASE 103
		;Ａ感度
		RESULTS '= REPLACE(RESULTS , "Ａ" , "")
	CASE 104
		;Ｂ感度
		RESULTS '= REPLACE(RESULTS , "Ｂ" , "")
	;↓一応分岐作ったけど、実際使ってみたらあまりにも味気なかったのでこの分岐排除
	[SKIPSTART]
	CASE 105
		;バストサイズ
		IF RESULTS == "絶壁"
			RESULTS = 壁
		ELSE
			RESULTS '= REPLACE(RESULTS , "乳" , "")
		ENDIF
	[SKIPEND]
	CASE 106
		;Ｍ感度
		RESULTS '= REPLACE(RESULTS , "Ｍ" , "")
	;↓一応分岐作ったけど、実際使ってみたらあまりにも味気なかったのでこの分岐排除
	[SKIPSTART]
	CASE 108
		;ヒップサイズ
		;これ省略していいのかなぁ。どう省略したらいいのか…
		IF ARG_VALUE == -2
			RESULTS = 纖臀
		ELSEIF ARG_VALUE == -1
			RESULTS = 小臀
		ELSEIF ARG_VALUE == 0
			RESULTS = 並臀
		ELSEIF ARG_VALUE == 1
			RESULTS = 潤臀
		ELSEIF ARG_VALUE == 2
			RESULTS = 豊臀
		ENDIF
	[SKIPEND]
	CASE 121
		;酒耐性
		IF RESULTS == "下戸"
			;２文字だしそのままで
			;RESULTS = 下戸
		ELSEIF RESULTS == "お酒に弱い"
			RESULTS = 弱い
		ELSEIF RESULTS == "お酒に強い"
			RESULTS = 強い
		ELSEIF RESULTS == "酒豪"
			;２文字だしそのままで
			;RESULTS = 酒豪
		ELSEIF RESULTS == "うわばみ"
			RESULTS = 蟒蛇
		ENDIF
	CASE 130
		;回復速度
		RESULTS '= REPLACE(RESULTS , "回復" , "")
	CASE 143
		;動物耳系
		RESULTS '= REPLACE(RESULTS , "ミミ" , "")
		RESULTS '= REPLACE(RESULTS , "耳" , "")
	CASE 149
		;母乳/授乳。@GET_TALENTNAMEはCASE 130になっているが、CSVの母乳関連は149になっている
		IF RESULTS == "授乳可能"
			RESULTS = 授乳
		ELSEIF RESULTS == "母乳体質"
			RESULTS = 母乳
		ENDIF
	CASE 161
		;音楽知識。音楽知識って排他なのね
		RESULTS '= REPLACE(RESULTS , "知識" , "")
	CASE 162
		;音感
		SIF RESULTS == "絶対音感"
			RESULTS = 絶対
	CASE 250
		;チン形状。なんか見てて笑っちゃった
		RESULTS '= REPLACE(RESULTS , "チンポ" , "")
		RESULTS '= REPLACE(RESULTS , "チン" , "")
	CASE 274
		;積み石系
		RESULTS '= REPLACE(RESULTS , "積み石" , "")
	CASEELSE
		;RESULTS = 
		;RETURN 0
ENDSELECT

RETURN 1


@LIST_DT_CELL_DISABLE(ARG_VAR = "" , ARG_CHR = 0)
#FUNCTION
#DIM ARG_CHR
#DIMS ARG_VAR
[SKIPSTART]
	CASE (COLUMN_VARの中身で指定)
		;ここに文字列を入れると選択不可のセルにその文字列が表示される
		RESULTS = 
		;1を返すとカラムが使用不能になる
		RETURNF 1
[SKIPEND]

SELECTCASE ARG_VAR
	CASE "CFLAG,340"
		;溜まってる度
		;溜まってる度はぱんつ窃盗実績による解除が必要。MASTERのだけは分かる
		IF NOTICE_LUST(ARG_CHR)
			RETURNF 0
		ELSE
			;HTML_PRINTできないことに気づいたのでtooltip禁止
			;RESULTS = 今の%CALLNAME:MASTER%に他人の性欲を知る術などない。それはぱんつの神の御業である
			IF ARG_CHR == MASTER
				RESULTS = 
			ELSE
				RESULTS = (不明)
			ENDIF
			RETURNF 1
		ENDIF
	CASE "CFLAG,900"
		;生理周期
		IF NOTICE_CYCLE(ARG_CHR)
			RETURNF 0
		ELSE
			;RESULTS = 今の%CALLNAME:MASTER%に他人の生理周期を知る術などない。恋人や超能力者じゃないんですから
			RESULTS = (不明)
			RETURNF 1
		ENDIF
	CASEELSE
		RETURNF 0
ENDSELECT


@STR_AND_HITNUM_TO_SCORE(ARG_STR = "" , ARG_HITNUM = 0)
#FUNCTION
#DIM ARG_HITNUM
#DIMS ARG_STR
#DIM CONST C_BIGNUMBER = 10000000000000 ;ヒット数が格納される桁
#DIM L_NUM

IF STRLENS(ARG_STR) == 0
	IF ARG_HITNUM == 0
		RETURNF 0
	ELSE
		RETURNF ARG_HITNUM * C_BIGNUMBER
	ENDIF
ENDIF

RETURNF ARG_HITNUM * C_BIGNUMBER + HASH_FROM_STR(ARG_STR)
