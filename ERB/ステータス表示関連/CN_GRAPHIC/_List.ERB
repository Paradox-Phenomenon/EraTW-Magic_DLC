;使用字符串实现的可变长数组模拟
;以"值,值,值,"的形式保存数据。（元素数≥1时末尾逗号必须）
;例如，可变长数组字符串STR为"短发,中长发,长发,"时，LIST_GET(STR, 1)返回"中长发"。
;又如，STR为"短发,中长发,长发,"时，LIST_ADD(STR, "大波浪")返回"短发,中长发,长发,大波浪,"。
;限制：存储的值中不能包含逗号。自然也不支持嵌套。
;默认一个可变长数组中元素的最大数量为100个。修改_LIST.ERH可以增加，但执行速度可能不实用。
;为了尽可能提高速度，省略了数据格式的检查。因此传入错误格式的数据时后果不可预测。
;用于集中存放数据。
;与_Dictionary互相独立，因此可以将关联数组作为值存储，也可以创建可变长数组的关联数组。但嵌套会出问题。

;@LIST_ADD(_LIST, _VALUE) ;在目标可变长数组的末尾追加_VALUE并返回。
;@LIST_SET(_LIST, _INDEX, _VALUE) ;将目标可变长数组的第_INDEX个元素用_VALUE覆盖并返回。若数组长度不足则自动扩展。
;@LIST_ADDLIST(_LIST, _LIST_OTHER) ;将_LIST_OTHER拼接到目标可变长数组的末尾并返回。
;@LIST_GET(_LIST, _INDEX) ;返回目标可变长数组的第_INDEX个元素。若超出数组范围则返回空字符串。
;@LIST_INDEXOF(_LIST, _VALUE) ;若目标可变长数组中存在与_VALUE完全一致的元素则返回其首次出现的INDEX，不存在则返回-1。
;@LIST_COUNT(_LIST) ;返回目标可变长数组的长度（元素数）。
;@LIST_INSERTAT(_LIST, _INDEX, _VALUE) ;在目标可变长数组的第_INDEX个位置插入_VALUE并返回。
;@LIST_REMOVEAT(_LIST, _INDEX) ;删除目标可变长数组的第_INDEX个元素并返回。若超出数组范围则原样返回。
;@LIST_REMOVEALL(_LIST, _VALUE) ;从目标可变长数组中删除所有与_VALUE一致的元素并返回。
;@LIST_SORT(_LIST) ;将目标可变长数组按升序排序并返回。
;@LIST_SORT_R(_LIST) ;将目标可变长数组按降序排序并返回。
;@LIST_FOREACH(_LIST, _FUNCNAME) ;对目标可变长数组中的所有元素依次执行 CALLFORM %_FUNCNAME%, _VALUE;

;-------------------------------------------------
; 内置MAP函数等价实现
; 本库使用字符串拼接模拟可变长数组，可用内置MAP函数部分替代。
; MAP是无序字典，不保证插入顺序，也不支持按索引访问。
; 若需要保持顺序/索引访问，仍需使用本库或ERB原生数组。
; 若仅需集合功能（无需顺序），可用MAP的key表示元素，value留空。
;
; 初始化：MAP_CREATE "listName"（仅需一次，之后用名称引用）
;
; LIST_ADD(list, val)          → MAP_SET "listName", val, ""（无序，无法追加到末尾）
; LIST_SET(list, idx, val)     → MAP_SET "listName", TOSTR(idx), val（用数字字符串作key）
; LIST_ADDLIST(list, other)    → MAP_MERGE "listName", "otherListName"
; LIST_GET(list, idx)          → MAP_GET("listName", TOSTR(idx))（用数字字符串作key）
; LIST_INDEXOF(list, val)      → MAP_FINDKEY("listName", val, "VAL_EQ")（返回匹配的key列表）
; LIST_COUNT(list)             → MAP_SIZE("listName")
; LIST_INSERTAT(list, idx, val)→ 无等价实现（MAP不支持在指定位置插入）
; LIST_REMOVEAT(list, idx)     → MAP_REMOVE "listName", TOSTR(idx)（用数字字符串作key）
; LIST_REMOVEALL(list, val)    → MAP_REMOVEIF "listName", val, "VAL_EQ"
; LIST_SORT(list)              → 无直接等价（MAP无序，需取出key后用ARRAYSORT排序）
; LIST_SORT_R(list)            → 同上
; LIST_FOREACH(list, funcName) → MAP_GETKEYS "listName", 1
;                                 FOR i, 0, RESULT
;                                     CALLFORM %funcName%, MAP_GET("listName", RESULTS:i)
;                                 NEXT
;
; 注意：LIST_* 以字符串为数据载体（值语义），MAP_* 以名称引用全局字典（引用语义）。
;       LIST_* 的数据可随字符串变量存档/传递，MAP_* 的数据需通过 MAP_TOXML/MAP_TOSTRING 序列化。
;       LIST_* 保持插入顺序且支持索引访问，MAP_* 不保证顺序且只能按key访问。
;-------------------------------------------------

;-------------------------------------------------
; 内置SQL函数等价实现
; 也可用SQLite表替代，且SQL天然支持ORDER BY排序和ROWID索引，可完整替代有序数组。
; 表结构：CREATE TABLE listName (idx INTEGER PRIMARY KEY, val TEXT)
;         idx列即数组下标，val列存储值，PRIMARY KEY自动按idx排序。
;
; 初始化：SQL_CONNECT "db"
;         SQL_EXECUTE_NONQUERY "db", "CREATE TABLE IF NOT EXISTS listName (idx INTEGER PRIMARY KEY, val TEXT)"
;
; LIST_ADD(list, val)          → SQL_P_EXECUTE_NONQUERY "db",
;                                     "INSERT INTO listName (val) VALUES (@0)", val
; LIST_SET(list, idx, val)     → SQL_P_EXECUTE_NONQUERY "db",
;                                     "UPDATE listName SET val = @0 WHERE idx = @1", val, TOSTR(idx)
; LIST_ADDLIST(list, other)    → SQL_EXECUTE_NONQUERY "db",
;                                     "INSERT INTO listName (val) SELECT val FROM otherListName"
; LIST_GET(list, idx)          → SQL_P_EXECUTE_SCALAR_STRING("db",
;                                     "SELECT val FROM listName WHERE idx = @0", TOSTR(idx))
; LIST_INDEXOF(list, val)      → SQL_P_EXECUTE_SCALAR_LONG("db",
;                                     "SELECT MIN(idx) FROM listName WHERE val = @0", val)
; LIST_COUNT(list)             → SQL_EXECUTE_SCALAR_LONG("db",
;                                     "SELECT COUNT(*) FROM listName")
; LIST_INSERTAT(list, idx, val)→ SQL_EXECUTE_NONQUERY "db",
;                                     "UPDATE listName SET idx = idx + 1 WHERE idx >= {idx}"
;                                 SQL_P_EXECUTE_NONQUERY "db",
;                                     "INSERT INTO listName (idx, val) VALUES (@0, @1)", TOSTR(idx), val
; LIST_REMOVEAT(list, idx)     → SQL_P_EXECUTE_NONQUERY "db",
;                                     "DELETE FROM listName WHERE idx = @0", TOSTR(idx)
;                                 SQL_EXECUTE_NONQUERY "db",
;                                     "UPDATE listName SET idx = idx - 1 WHERE idx > {idx}"
; LIST_REMOVEALL(list, val)    → SQL_P_EXECUTE_NONQUERY "db",
;                                     "DELETE FROM listName WHERE val = @0", val
; LIST_SORT(list)              → 需重建idx：SELECT val FROM listName ORDER BY val ASC → 清空表 → 按序INSERT
; LIST_SORT_R(list)            → 同上，ORDER BY val DESC
; LIST_FOREACH(list, funcName) → LOCAL:0 = SQL_EXECUTE_READER("db", "SELECT val FROM listName ORDER BY idx")
;                                 WHILE SQL_READER_READ(LOCAL:0)
;                                     CALLFORM %funcName%, SQL_READER_GET_STRING(LOCAL:0, 0)
;                                 WEND
;                                 SQL_READER_CLOSE LOCAL:0
;
; 注意：SQL表天然保持插入顺序（通过idx列），支持索引访问和排序，是MAP无法实现的功能。
;       SQL还支持LIKE、范围、聚合等复杂查询，远超LIST_*的能力。
;-------------------------------------------------


;================================================
;@LIST_SET (#FUNCTIONS);将目标可变长数组的第_INDEX个元素用_VALUE覆盖并返回。若数组长度不足则自动扩展。
;_LIST       目标可变长数组（字符串）
;_INDEX      要添加或修改的位置索引
;_VALUE      要添加或修改的值
;RETURNF     添加或修改后的可变长数组（字符串）
;等价实现：MAP_SET "listName", TOSTR(_INDEX), _VALUE（用数字字符串作key）
;================================================
@LIST_SET(_LIST, _INDEX, _VALUE)
#FUNCTIONS
#DIMS _LIST
#DIM _INDEX
#DIMS _VALUE
#DIM _COUNT
IF _INDEX < 0
	THROW _List.ERB:_INDEX指定了负值({_INDEX})→%_LIST%
ENDIF
_LIST_LENGTH = STRCOUNT(_LIST, ",")
;若数组长度不足则扩展（增加逗号）后返回
IF _INDEX >= _LIST_LENGTH
	RETURNF _LIST + ("," * (_INDEX - _LIST_LENGTH)) + _VALUE + ","
ENDIF
;搜索第(_INDEX-1)个和第_INDEX个逗号的位置，存入_LIST_INDEX_LEFT和_LIST_INDEX_RIGHT
_LIST_INDEX_COMMA = -1
_LIST_INDEX_LEFT = -1
_COUNT = 0
WHILE 1
	_LIST_INDEX_COMMA = STRFINDU(_LIST, "," , _LIST_INDEX_COMMA + 1)
	IF _COUNT == _INDEX
		_LIST_INDEX_RIGHT = _LIST_INDEX_COMMA
		BREAK
	ENDIF
	_LIST_INDEX_LEFT = _LIST_INDEX_COMMA
	_COUNT ++
WEND
IF _INDEX > 0
	;右端包含逗号的形式截取
	_LIST_LEFT '= SUBSTRINGU(_LIST,0,_LIST_INDEX_LEFT+1)
ELSE
	_LIST_LEFT '= ""
ENDIF
;左端包含逗号的形式截取
_LIST_RIGHT '= SUBSTRINGU(_LIST, _LIST_INDEX_RIGHT , -1)

;拼接后返回
RETURNF _LIST_LEFT + _VALUE + _LIST_RIGHT


;================================================
;@LIST_ADD (#FUNCTIONS);在目标可变长数组的末尾追加_VALUE并返回。
;_LIST       目标可变长数组（字符串）
;_VALUE      要追加的值
;RETURNF     追加后的可变长数组（字符串）
;等价实现：MAP_SET "listName", _VALUE, ""（无序，无法追加到末尾；仅适合集合语义）
;================================================
@LIST_ADD(_LIST, _VALUE)
#FUNCTIONS
#DIMS _LIST
#DIMS _VALUE
RETURNF _LIST + _VALUE + ","

;================================================
;@LIST_ADDLIST (#FUNCTIONS);将_LIST_OTHER拼接到目标可变长数组的末尾并返回。
;_LIST       目标可变长数组（字符串）
;_LIST_OTHER 要拼接的可变长数组
;RETURNF     拼接后的可变长数组（字符串）
;等价实现：MAP_MERGE "listName", "otherListName"
;================================================
@LIST_ADDLIST(_LIST, _LIST_OTHER)
#FUNCTIONS
#DIMS _LIST
#DIMS _LIST_OTHER
RETURNF _LIST + "," + _LIST_OTHER

;@LIST_GET(_LIST, _INDEX) ;返回目标可变长数组的第_INDEX个元素。若超出数组范围则返回空字符串。
;================================================
;@LIST_GET (#FUNCTIONS);返回目标可变长数组的第_INDEX个元素。若超出数组范围则返回空字符串。
;_LIST       目标可变长数组（字符串）
;_INDEX      要获取的元素索引
;RETURNF     获取到的元素
;等价实现：MAP_GET("listName", TOSTR(_INDEX))（用数字字符串作key）
;================================================
@LIST_GET(_LIST, _INDEX)
#FUNCTIONS
#DIMS _LIST
#DIM _INDEX
#DIM _COUNT
IF _INDEX < 0
	THROW _List.ERB:_INDEX指定了负值({_INDEX})→%_LIST%
ENDIF
;搜索第(_INDEX-1)个和第_INDEX个逗号的位置，存入_LIST_INDEX_LEFT和_LIST_INDEX_RIGHT
_LIST_INDEX_COMMA = -1
_LIST_INDEX_LEFT = -1
_COUNT = 0
WHILE 1
	_LIST_INDEX_COMMA = STRFINDU(_LIST, "," , _LIST_INDEX_COMMA + 1)
	IF _COUNT == _INDEX
		_LIST_INDEX_RIGHT = _LIST_INDEX_COMMA
		BREAK
	ENDIF
	;_INDEX超出数组范围
	IF _LIST_INDEX_COMMA < 0
		RETURNF ""
	ENDIF
	_LIST_INDEX_LEFT = _LIST_INDEX_COMMA
	_COUNT ++
WEND
RETURNF SUBSTRINGU(_LIST,_LIST_INDEX_LEFT + 1, _LIST_INDEX_RIGHT - _LIST_INDEX_LEFT - 1)



;@LIST_COUNT(_LIST) ;返回目标可变长数组的长度（元素数）。
;================================================
;@LIST_COUNT (#FUNCTION);返回目标可变长数组的长度（元素数）。
;_LIST       目标可变长数组（字符串）
;RETURNF     长度（元素数）
;等价实现：MAP_SIZE("listName")
;================================================
@LIST_COUNT(_LIST)
#FUNCTION
#DIMS _LIST
RETURNF STRCOUNT(_LIST, ",")



;================================================
;@LIST_INSERTAT (#FUNCTIONS);在目标可变长数组的第_INDEX个位置插入_VALUE并返回。
;_LIST       目标可变长数组（字符串）
;_INDEX      要插入的位置索引
;_VALUE      要插入的值
;RETURNF     插入后的可变长数组（字符串）
;等价实现：无等价实现（MAP不支持在指定位置插入）
;================================================
@LIST_INSERTAT(_LIST, _INDEX, _VALUE)
#FUNCTIONS
#DIMS _LIST
#DIM _INDEX
#DIMS _VALUE
#DIM _COUNT
IF _INDEX < 0
	THROW _List.ERB:_INDEX指定了负值({_INDEX})→%_LIST%
ENDIF
_LIST_LENGTH = STRCOUNT(_LIST, ",")
;若数组长度不足则扩展（增加逗号）后返回。与LIST_SET相同处理
IF _INDEX >= _LIST_LENGTH
	RETURNF _LIST + ("," * (_INDEX - _LIST_LENGTH)) + _VALUE + ","
ENDIF

;搜索第(_INDEX-1)个和第_INDEX个逗号的位置
_LIST_INDEX_COMMA = -1
_LIST_INDEX_LEFT = -1
_COUNT = 0
WHILE 1
	_LIST_INDEX_COMMA = STRFINDU(_LIST, "," , _LIST_INDEX_COMMA + 1)
	IF _COUNT == _INDEX
		_LIST_INDEX_RIGHT = _LIST_INDEX_COMMA
		BREAK
	ENDIF
	_LIST_INDEX_LEFT = _LIST_INDEX_COMMA
	_COUNT ++
WEND
IF _INDEX > 0
	;右端包含逗号的形式截取
	_LIST_LEFT '= SUBSTRINGU(_LIST,0,_LIST_INDEX_LEFT+1)
ELSE
	_LIST_LEFT '= ""
ENDIF
;左端包含逗号的形式截取（注意是_LIST_INDEX_LEFT而非_RIGHT，保留原INDEX位置的元素）
_LIST_RIGHT '= SUBSTRINGU(_LIST, _LIST_INDEX_LEFT , -1)

;拼接后返回
RETURNF _LIST_LEFT + _VALUE + _LIST_RIGHT



;================================================
;@LIST_REMOVEAT (#FUNCTIONS);删除目标可变长数组的第_INDEX个元素并返回。若超出数组范围则原样返回。
;_LIST       目标可变长数组（字符串）
;_INDEX      要删除的位置索引
;RETURNF     删除后的可变长数组（字符串）
;等价实现：MAP_REMOVE "listName", TOSTR(_INDEX)（用数字字符串作key）
;================================================
@LIST_REMOVEAT(_LIST, _INDEX)
#FUNCTIONS
#DIMS _LIST
#DIM _INDEX
#DIM _COUNT
IF _INDEX < 0
	THROW _List.ERB:_INDEX指定了负值({_INDEX})→%_LIST%
ENDIF
_LIST_LENGTH = STRCOUNT(_LIST, ",")
;若超出数组范围则原样返回
IF _INDEX > _LIST_LENGTH
	RETURNF _LIST
ENDIF
;若要删除的是数组唯一的元素则返回空数组（空字符串）
IF _LIST_LENGTH == 1 && _INDEX == 0
	RETURNF ""
ENDIF
;搜索第(_INDEX-1)个和第_INDEX个逗号的位置
_LIST_INDEX_COMMA = -1
_LIST_INDEX_LEFT = -1
_COUNT = 0
WHILE 1
	_LIST_INDEX_COMMA = STRFINDU(_LIST, "," , _LIST_INDEX_COMMA + 1)
	IF _COUNT == _INDEX
		_LIST_INDEX_RIGHT = _LIST_INDEX_COMMA
		BREAK
	ENDIF
	_LIST_INDEX_LEFT = _LIST_INDEX_COMMA
	_COUNT ++
WEND
IF _INDEX > 0
	;右端不包含逗号的形式截取
	_LIST_LEFT '= SUBSTRINGU(_LIST,0,_LIST_INDEX_LEFT)
ELSE
	_LIST_LEFT '= ""
ENDIF
;左端包含逗号的形式截取
_LIST_RIGHT '= SUBSTRINGU(_LIST, _LIST_INDEX_RIGHT , -1)

;拼接后返回
RETURNF _LIST_LEFT + _LIST_RIGHT


;================================================
;@LIST_INDEXOF (#FUNCTION) ;若目标可变长数组中存在与_VALUE完全一致的元素则返回其首次出现的INDEX，不存在则返回-1。
;_LIST       目标可变长数组（字符串）
;_VALUE      要搜索的值
;RETURNF     找到的INDEX或-1
;等价实现：MAP_FINDKEY("listName", _VALUE, "VAL_EQ")（返回匹配的key列表，非单个INDEX）
;================================================
@LIST_INDEXOF(_LIST, _VALUE)
#FUNCTION
#DIMS _LIST
#DIMS _VALUE
#DIM _KEYCOUNT
#DIM _CNT
;偷懒用"_VALUE + ",""做FIND的话，当_VALUE为空字符串时会出问题
SPLIT _LIST, ",", _LIST_ELEMENT
IF RESULT > _LIST_MAX
	THROW _List.ERB:列表元素数过多→%_LIST%
ENDIF
_KEYCOUNT = RESULT-1 ;末尾为逗号，所以SPLIT后末尾为空字符串
IF _KEYCOUNT <= 0
	RETURNF -1
ENDIF
FOR _CNT,0,_KEYCOUNT
	IF _LIST_ELEMENT:_CNT == _VALUE
		RETURNF _CNT
	ENDIF
NEXT
RETURNF -1

;================================================
;@LIST_REMOVEALL (#FUNCTIONS) ;从目标可变长数组中删除所有与_VALUE一致的元素并返回。
;_LIST       目标可变长数组（字符串）
;_VALUE      要删除的值
;RETURNF     删除后的可变长数组（字符串）
;等价实现：MAP_REMOVEIF "listName", _VALUE, "VAL_EQ"
;================================================
@LIST_REMOVEALL(_LIST, _VALUE)
#FUNCTIONS
#DIMS _LIST
#DIMS _VALUE
#DIM _KEYCOUNT
#DIM _CNT
;偷懒用"_VALUE + ",""对空字符串做REPLACE的话，当_VALUE为空字符串时会出问题
SPLIT _LIST, ",", _LIST_ELEMENT
IF RESULT > _LIST_MAX
	THROW _List.ERB:列表元素数过多→%_LIST%
ENDIF
_KEYCOUNT = RESULT-1 ;末尾为逗号，所以SPLIT后末尾为空字符串
IF _KEYCOUNT <= 0
	RETURNF _LIST
ENDIF
_LIST '= ""
FOR _CNT,0,_KEYCOUNT
	IF _LIST_ELEMENT:_CNT == _VALUE
		CONTINUE
	ENDIF
	_LIST += _LIST_ELEMENT:_CNT + ","
NEXT
RETURNF _LIST

;================================================
;@LIST_SORT (#FUNCTIONS) ;将目标可变长数组按升序排序并返回。
;_LIST       目标可变长数组（字符串）
;RETURNF     排序后的可变长数组（字符串）
;等价实现：无直接等价（MAP无序，需取出key后用ARRAYSORT排序）
;================================================
@LIST_SORT(_LIST)
#FUNCTIONS
#DIMS _LIST
#DIMS _FUNCNAME
#DIM _KEYCOUNT
#DIM _CNT
SPLIT _LIST, ",", _LIST_ELEMENT
IF RESULT > _LIST_MAX
	THROW _List.ERB:列表元素数过多→%_LIST%
ENDIF
_KEYCOUNT = RESULT-1 ;末尾为逗号，所以SPLIT后末尾为空字符串
IF _KEYCOUNT <= 0
	RETURNF _LIST
ENDIF
ARRAYSORT _LIST_ELEMENT, FORWARD, 0, _KEYCOUNT
_LIST '= ""
FOR _CNT,0,_KEYCOUNT
	_LIST += _LIST_ELEMENT:_CNT + ","
NEXT
RETURNF _LIST

;================================================
;@LIST_SORT_R (#FUNCTIONS) ;将目标可变长数组按降序排序并返回。
;_LIST       目标可变长数组（字符串）
;RETURNF     排序后的可变长数组（字符串）
;等价实现：无直接等价（MAP无序，需取出key后用ARRAYSORT排序）
;================================================
@LIST_SORT_R(_LIST)
#FUNCTIONS
#DIMS _LIST
#DIMS _FUNCNAME
#DIM _KEYCOUNT
#DIM _CNT
SPLIT _LIST, ",", _LIST_ELEMENT
IF RESULT > _LIST_MAX
	THROW _List.ERB:列表元素数过多→%_LIST%
ENDIF
_KEYCOUNT = RESULT-1 ;末尾为逗号，所以SPLIT后末尾为空字符串
IF _KEYCOUNT <= 0
	RETURNF _LIST
ENDIF
ARRAYSORT _LIST_ELEMENT, BACK, 0, _KEYCOUNT
_LIST '= ""
FOR _CNT,0,_KEYCOUNT
	_LIST += _LIST_ELEMENT:_CNT + ","
NEXT
RETURNF _LIST

;================================================
;@LIST_FOREACH ;对目标可变长数组中的所有元素依次执行 CALLFORM %_FUNCNAME%, _VALUE;
;_LIST  目标可变长数组（字符串）
;_FUNCNAME    要执行的函数名(CALLFORM %_FUNCNAME%, _VALUE)
;RESULT       无
;等价实现：MAP_GETKEYS "listName", 1
;           FOR i, 0, RESULT
;               CALLFORM %_FUNCNAME%, MAP_GET("listName", RESULTS:i)
;           NEXT
;================================================
@LIST_FOREACH(_LIST, _FUNCNAME)
#DIMS _LIST
#DIMS _FUNCNAME
#DIM _KEYCOUNT
#DIM _CNT
#DIMS _LIST_ELEMENT_P,_LIST_MAX ;使用独立变量以免FOREACH中无法对其他数组执行SORT等操作。递归需求大概没有所以不用DYNAMIC

SPLIT _LIST, ",", _LIST_ELEMENT_P
IF RESULT > _LIST_MAX
	THROW _List.ERB:列表元素数过多→%_LIST%
ENDIF

_KEYCOUNT = RESULT-1 ;末尾为逗号，所以SPLIT后末尾为空字符串
IF _KEYCOUNT <= 0
	RETURN
ENDIF
FOR _CNT,0,_KEYCOUNT
	CALLFORM %_FUNCNAME%, _LIST_ELEMENT_P:_CNT
NEXT
RETURN




