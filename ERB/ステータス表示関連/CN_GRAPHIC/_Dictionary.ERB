;使用字符串实现的关联数组模拟
;以[键:值]的形式保存各种数据。
;例如，关联数组字符串STR为"[发型:短发][发色:绿][瞳色:蓝]"时，DIC_GET(STR, "发色")返回"绿"。
;又如，STR为"[发型:短发][发色:绿][瞳色:蓝]"时，DIC_SET(STR, "发型", "长发")返回"[发型:长发][发色:绿][瞳色:蓝]"。
;限制：键和值中不能包含"[", ":", "]"。自然也不支持嵌套。
;默认一个关联数组中键的最大数量为100个。修改_Dictionary.ERH可以增加，但执行速度可能不实用。
;为了尽可能提高速度，省略了数据格式的检查。因此传入错误格式的数据时后果不可预测。
;用于集中存放数据。
;与_List互相独立，因此可以将可变长数组作为值存储，也可以创建关联数组的可变长数组。但嵌套会出问题。


;@DIC_SET(_DICTIONARY, _KEY, _VALUE) ;将_VALUE存入目标关联数组的_KEY中并返回。若键已存在则覆盖。
;@DIC_GET(_DICTIONARY, _KEY) ;获取目标关联数组中_KEY的值。若键不存在则返回空字符串。
;@DIC_REMOVE(_DICTIONARY, _KEY) ;删除目标关联数组中的_KEY并返回。若键不存在则原样返回。
;@DIC_CONTAINSKEY(_DICTIONARY, _KEY) ;判断目标关联数组中是否存在_KEY。存在返回1，不存在返回0。
;@DIC_COUNT(_DICTIONARY) ;获取目标关联数组中包含的键的数量。
;@DIC_FOREACH(_DICTIONARY, _FUNCNAME);对目标关联数组中的所有元素执行 CALLFORM %FUNCNAME%, _KEY, _VALUE;

;-------------------------------------------------
; 内置MAP函数等价实现
; 本库使用字符串拼接模拟关联数组，可用内置MAP函数替代。
; MAP基于C# Dictionary<string,string>，性能远优于字符串操作。
;
; 初始化：MAP_CREATE "dictName"（仅需一次，之后用名称引用）
;
; DIC_SET(dict, key, val)      → MAP_SET "dictName", key, val
; DIC_GET(dict, key)           → MAP_GET("dictName", key)
; DIC_REMOVE(dict, key)        → MAP_REMOVE "dictName", key
; DIC_CONTAINSKEY(dict, key)   → MAP_HAS("dictName", key)
; DIC_COUNT(dict)              → MAP_SIZE("dictName")
; DIC_FOREACH(dict, funcName)  → MAP_GETKEYS "dictName", 1
;                                 FOR i, 0, RESULT
;                                     CALLFORM %funcName%, RESULTS:i, MAP_GET("dictName", RESULTS:i)
;                                 NEXT
;
; 注意：DIC_* 以字符串为数据载体（值语义），MAP_* 以名称引用全局字典（引用语义）。
;       DIC_* 的数据可随字符串变量存档/传递，MAP_* 的数据需通过 MAP_TOXML/MAP_TOSTRING 序列化。
;-------------------------------------------------

;-------------------------------------------------
; 内置SQL函数等价实现
; 也可用SQLite表替代，适合数据量大或需要复杂查询的场景。
; 表结构：CREATE TABLE dictName (k TEXT PRIMARY KEY, v TEXT)
;
; 初始化：SQL_CONNECT "db"
;         SQL_EXECUTE_NONQUERY "db", "CREATE TABLE IF NOT EXISTS dictName (k TEXT PRIMARY KEY, v TEXT)"
;
; DIC_SET(dict, key, val)      → SQL_P_EXECUTE_NONQUERY "db",
;                                     "INSERT OR REPLACE INTO dictName (k, v) VALUES (@0, @1)", key, val
; DIC_GET(dict, key)           → SQL_P_EXECUTE_SCALAR_STRING("db",
;                                     "SELECT v FROM dictName WHERE k = @0", key)
; DIC_REMOVE(dict, key)        → SQL_P_EXECUTE_NONQUERY "db",
;                                     "DELETE FROM dictName WHERE k = @0", key
; DIC_CONTAINSKEY(dict, key)   → SQL_P_EXECUTE_SCALAR_LONG("db",
;                                     "SELECT COUNT(*) FROM dictName WHERE k = @0", key)
; DIC_COUNT(dict)              → SQL_EXECUTE_SCALAR_LONG("db",
;                                     "SELECT COUNT(*) FROM dictName")
; DIC_FOREACH(dict, funcName)  → LOCAL:0 = SQL_EXECUTE_READER("db", "SELECT k, v FROM dictName")
;                                 WHILE SQL_READER_READ(LOCAL:0)
;                                     CALLFORM %funcName%, SQL_READER_GET_STRING(LOCAL:0, 0), SQL_READER_GET_STRING(LOCAL:0, 1)
;                                 WEND
;                                 SQL_READER_CLOSE LOCAL:0
;
; 注意：SQL表为持久化存储（文件数据库）或会话级存储（内存数据库），不受游戏重置影响（内存库除外）。
;       SQL支持复杂查询（LIKE、范围、聚合等），是DIC_*无法实现的高级功能。
;-------------------------------------------------




;================================================
;@DIC_SET (#FUNCTIONS)将_VALUE存入目标关联数组的_KEY中并返回。若键已存在则覆盖。
;_DICTIONARY 目标关联数组（字符串）
;_KEY        要添加/修改的键
;_VALUE      要添加的值
;RETURNF     添加或修改后的关联数组（字符串）
;等价实现：MAP_SET "dictName", _KEY, _VALUE
;================================================
@DIC_SET(_DICTIONARY, _KEY, _VALUE)
#FUNCTIONS
#DIMS _DICTIONARY
#DIMS _KEY
#DIMS _VALUE
;检查_KEY是否已存在
_DIC_INDEX_OPEN = STRFINDU(_DICTIONARY, "[" + _KEY + ":")
;若_KEY不存在则追加[KEY:VALUE]后返回
IF _DIC_INDEX_OPEN < 0
	RETURNF _DICTIONARY + "[" + _KEY + ":" + _VALUE + "]"
ENDIF
;若_KEY已存在，从_DICTIONARY中移除旧[KEY:VALUE]，再追加新的[KEY:VALUE]
IF _DIC_INDEX_OPEN > 0
	_DICTIONARY_LEFT '= SUBSTRINGU(_DICTIONARY,0,_DIC_INDEX_OPEN)
ELSE
	_DICTIONARY_LEFT '= ""
ENDIF
;搜索"[KEY:"之后第一个"]"
_DIC_INDEX_CLOSE = STRFINDU(_DICTIONARY, "]", _DIC_INDEX_OPEN)
;获取旧[KEY:VALUE]右侧的文本
IF _DIC_INDEX_CLOSE < 0
	THROW 关联数组字符串格式不正确→%_DICTIONARY%
ELSEIF _DIC_INDEX_CLOSE+1 < STRLENSU(_DICTIONARY)
	_DICTIONARY_RIGHT '= SUBSTRINGU(_DICTIONARY, _DIC_INDEX_CLOSE + 1 , -1)
ELSE
	_DICTIONARY_RIGHT '= ""
ENDIF
;拼接后返回
RETURNF _DICTIONARY_LEFT + "[" + _KEY + ":" + _VALUE + "]" + _DICTIONARY_RIGHT



;================================================
;@DIC_CONTAINSKEY (#FUNCTION) ;判断目标关联数组中是否存在_KEY。存在返回1，不存在返回0。
;_DICTIONARY 目标关联数组（字符串）
;_KEY        键
;RETURNF     存在为1，不存在为0
;等价实现：MAP_HAS("dictName", _KEY)
;================================================
@DIC_CONTAINSKEY(_DICTIONARY, _KEY)
#FUNCTION
#DIMS _DICTIONARY
#DIMS _KEY
RETURNF STRFINDU(_DICTIONARY, "[" + _KEY + ":") >= 0


;================================================
;@DIC_REMOVE (#FUNCTIONS)) ;删除目标关联数组中的_KEY并返回。若键不存在则原样返回。
;_DICTIONARY 目标关联数组（字符串）
;_KEY        键
;RETURNF     删除键后的关联数组（字符串）
;等价实现：MAP_REMOVE "dictName", _KEY
;================================================
@DIC_REMOVE(_DICTIONARY, _KEY)
#FUNCTIONS
#DIMS _DICTIONARY
#DIMS _KEY
;检查_KEY是否已存在
_DIC_INDEX_OPEN = STRFINDU(_DICTIONARY, "[" + _KEY + ":")
;若_KEY不存在则原样返回
IF _DIC_INDEX_OPEN < 0
	RETURNF _DICTIONARY
ENDIF
;若_KEY已存在，从_DICTIONARY中移除[KEY:VALUE]
IF _DIC_INDEX_OPEN > 0
	_DICTIONARY_LEFT '= SUBSTRINGU(_DICTIONARY,0,_DIC_INDEX_OPEN)
ELSE
	_DICTIONARY_LEFT '= ""
ENDIF
;搜索"[KEY:"之后第一个"]"
_DIC_INDEX_CLOSE = STRFINDU(_DICTIONARY, "]", _DIC_INDEX_OPEN)
;获取旧[KEY:VALUE]右侧的文本
IF _DIC_INDEX_CLOSE < 0
	THROW _Dictionary.ERB:关联数组字符串格式不正确→%_DICTIONARY%
ELSEIF _DIC_INDEX_CLOSE+1 < STRLENSU(_DICTIONARY)
	_DICTIONARY_RIGHT '= SUBSTRINGU(_DICTIONARY, _DIC_INDEX_CLOSE + 1 , -1)
ELSE
	_DICTIONARY_RIGHT '= ""
ENDIF
;拼接后返回
RETURNF _DICTIONARY_LEFT + _DICTIONARY_RIGHT


;================================================
;@DIC_GET (#FUNCTIONS)) ;获取目标关联数组中_KEY的值。若键不存在则返回空字符串。
;_DICTIONARY 目标关联数组（字符串）
;_KEY        键
;RETURNF     键对应的值或空字符串
;等价实现：MAP_GET("dictName", _KEY)
;================================================
@DIC_GET(_DICTIONARY, _KEY)
#FUNCTIONS
#DIMS _DICTIONARY
#DIMS _KEY
;检查_KEY是否存在
_DIC_INDEX_OPEN = STRFINDU(_DICTIONARY, "[" + _KEY + ":")
;若_KEY不存在则返回空字符串
IF _DIC_INDEX_OPEN < 0
	RETURNF ""
ENDIF
;计算值的起始位置索引
_DIC_INDEX_OPEN = _DIC_INDEX_OPEN + STRLENSU(_KEY) + 2
;搜索"[KEY:"之后第一个"]"
_DIC_INDEX_CLOSE = STRFINDU(_DICTIONARY, "]", _DIC_INDEX_OPEN)
IF _DIC_INDEX_CLOSE < 0
	THROW _Dictionary.ERB:关联数组字符串格式不正确→%_DICTIONARY%
ENDIF
RETURNF SUBSTRINGU(_DICTIONARY, _DIC_INDEX_OPEN, _DIC_INDEX_CLOSE - _DIC_INDEX_OPEN)



;================================================
;@DIC_COUNT (#FUNCTION) ;获取目标关联数组中包含的键的数量。
;_DICTIONARY 目标关联数组（字符串）
;RETURNF     键的数量
;等价实现：MAP_SIZE("dictName")
;================================================
@DIC_COUNT(_DICTIONARY)
#FUNCTION
#DIMS _DICTIONARY
#DIM _COUNT
_DIC_INDEX_OPEN = -1
_COUNT = 0
WHILE 1
	_DIC_INDEX_OPEN = STRFINDU(_DICTIONARY, "[" , _DIC_INDEX_OPEN + 1)
	IF _DIC_INDEX_OPEN < 0
		BREAK
	ENDIF
	_COUNT ++
WEND
RETURNF _COUNT



;================================================
;@DIC_FOREACH ;对目标关联数组中的所有元素执行 CALLFORM %FUNCNAME%, _KEY, _VALUE;
;_DICTIONARY  目标关联数组（字符串）
;_FUNCNAME    要执行的函数名(CALLFORM %FUNCNAME%, _KEY, _VALUE)
;RESULT       无
;等价实现：MAP_GETKEYS "dictName", 1
;           FOR i, 0, RESULT
;               CALLFORM %_FUNCNAME%, RESULTS:i, MAP_GET("dictName", RESULTS:i)
;           NEXT
;================================================
@DIC_FOREACH(_DICTIONARY, _FUNCNAME)
#DIMS _DICTIONARY
#DIMS _FUNCNAME
#DIM _KEYCOUNT
#DIM _CNT
#DIMS _DIC_PAIRS,_DIC_MAX

SPLIT _DICTIONARY, "[", _DIC_PAIRS
IF RESULT > _DIC_MAX
	THROW _Dictionary.ERB:关联数组的键数过多→%_DICTIONARY%
ENDIF
_KEYCOUNT = RESULT
FOR _CNT,0,_KEYCOUNT
	;应为空字符串或"键:值]"格式
	_DIC_INDEX_OPEN = STRFINDU(_DIC_PAIRS:_CNT, ":")
	IF _DIC_INDEX_OPEN < 0
		CONTINUE
	ENDIF
	;_KEY = SUBSTRINGU(_DIC_PAIRS:_CNT, 0, _DIC_INDEX_OPEN)
	;_VALUE = SUBSTRINGU(_DIC_PAIRS:_CNT, _DIC_INDEX_OPEN + 1, STRLENSU(_DIC_PAIRS:_CNT) - (_DIC_INDEX_OPEN + 1) -1)
	;CALLFORM %_FUNCNAME%, _KEY, _VALUE
	CALLFORM %_FUNCNAME%, SUBSTRINGU(_DIC_PAIRS:_CNT, 0, _DIC_INDEX_OPEN), SUBSTRINGU(_DIC_PAIRS:_CNT, _DIC_INDEX_OPEN + 1, STRLENSU(_DIC_PAIRS:_CNT) - (_DIC_INDEX_OPEN + 1) -1)
NEXT

