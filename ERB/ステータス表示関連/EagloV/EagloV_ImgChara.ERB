@EagloV_特殊效果_17(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 10
#DIM DYNAMIC エフェクト数 = 0
#DIM CHARA
VARSET LOCALS
SIF !CHARA
	CHARA = 17
CALL EagloV_人偶差分_17(CHARA)
IF RESULT && SPRITECREATED(RESULTS)
	LOCALS:(エフェクト数*2) = %RESULTS%
	エフェクト数 += 1
ELSE
	RETURN
ENDIF
CALL EagloV_GET_颊红差分(, CHARA)
IF RESULT && SPRITECREATED(@"EagloV17_特效_人偶颊红")
	LOCALS:(エフェクト数*2) = EagloV17_特效_人偶颊红
	エフェクト数 += 1
ENDIF
IF CFLAG:CHARA:睡眠
	LOCALS:(エフェクト数*2) = EagloV17_特效_人偶闭目
ELSEIF (FLAG:時間停止 && EX:CHARA:無自覚Ｃ絶頂 + EX:CHARA:無自覚Ｖ絶頂 + EX:CHARA:無自覚Ａ絶頂 + EX:CHARA:無自覚Ｂ絶頂 + EX:CHARA:無自覚Ｍ絶頂 > 30) || (TCVAR:CHARA:烂醉 && BASE:CHARA:酒気 > MAXBASE:CHARA:酒気 * 2/3)
	LOCALS:(エフェクト数*2) = EagloV17_特效_人偶白目
ELSEIF FLAG:時間停止
	LOCALS:(エフェクト数*2) = EagloV17_特效_人偶常目
ELSEIF NOWEX:CHARA:TotalEX > 2 
	LOCALS:(エフェクト数*2) = EagloV17_特效_人偶白目
ELSEIF TCVAR:CHARA:烂醉
	LOCALS:(エフェクト数*2) = EagloV17_特效_人偶闭目
ELSEIF BASE:CHARA:憤怒 >= 900
	LOCALS:(エフェクト数*2) = EagloV17_特效_人偶暗目
ELSEIF CFLAG:CHARA:心情不快 > 0
	LOCALS:(エフェクト数*2) = EagloV17_特效_人偶闭目
ELSE
	LOCALS:(エフェクト数*2) = EagloV17_特效_人偶常目
ENDIF
エフェクト数 += 1

; 3rd眼气泡
IF RAND:4 && !FLAG:時間停止
	CALL EagloV_气泡判定(CHARA)
	;DEBUGPRINTFORML 气泡是%RESULTS%：{SPRITECREATED(@"EagloV17_特效_人偶%RESULTS%")}
	IF SPRITECREATED(@"EagloV17_特效_人偶%RESULTS%")
		LOCALS:(エフェクト数*2) = EagloV17_特效_人偶%RESULTS%
		エフェクト数 += 1
	ENDIF
ENDIF
[IF DEBUG]
FOR LOCAL, 0, 10
	SIF LOCALS:LOCAL != ""
		DEBUGPRINTFORML {LOCAL}%LOCALS:LOCAL%
NEXT
[ENDIF]
VARSET RESULTS
ARRAYCOPY "LOCALS", "RESULTS"
RETURN エフェクト数

@EagloV_人偶差分_17(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
SIF CFLAG:CHARA:睡眠 || CFLAG:CHARA:诶嘿嘿 || EagloV_服装初步判定(CHARA) != "服"
	RETURN 0
TRYCALLFORM EagloV_特殊服装_{CHARA}
IF RESULT
	IF SPRITECREATED(@"EagloV17_特效_人偶%RESULTS%")
		RESULTS = EagloV17_特效_人偶%RESULTS%
		RETURN 1
	ENDIF
ENDIF

