#LOCALSIZE 1
#LOCALSSIZE 1
IF IS_BUNNY(1)
	RESULTS = 兔女郎
	RETURN 2
ELSEIF EQUIP:1:下半身内衣２ == 2
	RESULTS = 灯笼裤
	RETURN 1
ENDIF

@EagloV_特殊服装_1(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 1
