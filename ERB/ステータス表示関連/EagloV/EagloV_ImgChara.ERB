		IF !SPRITECREATED(表情索引)
			G_ID = 0
			CALL 画像合成(G_ID, "ダミー", 0, 0, 500, 500)
			CALL EagloV_GET_表情差分(表情:LOCAL)
			表情_眉 = %RESULTS:0%
			表情_目 = %RESULTS:1%
			表情_口 = %RESULTS:2%
			表情_鼻 = %RESULTS:3%
			;EagloV{CHARA}_眉_{眉}
			SIF SPRITECREATED(@"EagloV{CHARA}_眉_%表情_眉%")
				CALL 画像合成(G_ID, @"EagloV{CHARA}_眉_%表情_眉%")

			;EagloV{CHARA}_目_{目}
			IF SPRITECREATED(@"EagloV{CHARA}_目_%表情_目%红")
				CALL 画像合成(G_ID, @"EagloV{CHARA}_目_%表情_目%红")
			ELSE
				CALL 画像合成(G_ID, @"EagloV{CHARA}_目_%表情_目%")
			ENDIF
			;EagloV{CHARA}_口_{口}
			SIF SPRITECREATED(@"EagloV{CHARA}_口_%表情_口%")
				CALL 画像合成(G_ID, @"EagloV{CHARA}_口_%表情_口%")

			;EagloV{CHARA}_鼻_{鼻}
			SIF SPRITECREATED(@"EagloV{CHARA}_鼻_%表情_鼻%")
				CALL 画像合成(G_ID, @"EagloV{CHARA}_鼻_%表情_鼻%")

			; 合成体图
			SPRITECREATE 表情索引, G_ID
		ENDIF
	NEXT
	RESULTS:0 '= COND_STR(@"%表情:0%红",表情:0 != "")
	RESULTS:1 '= COND_STR(@"%表情:1%红",表情:1 != "")
	RETURN 1
ENDIF

