	RESULTS = EagloV

; RETURN：0:无，1:胸罩胖次，2:连体内衣
@EagloV_特殊内衣_28
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM CHARA
SIF !CHARA
	CHARA = 28
IF IS_BUNNY(CHARA)
	RESULTS = 兔女郎
	RETURN 2
ENDIF
RETURN 0

@EagloV_特殊表情_28
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS DYNAMIC 表情,2
#DIMS DYNAMIC 表情_眉
#DIMS DYNAMIC 表情_目,2
#DIMS DYNAMIC 表情_口,2
#DIMS DYNAMIC 表情_鼻
#DIMS DYNAMIC 表情索引
#DIM DYNAMIC G_ID
#DIM CHARA
SIF !CHARA
	CHARA = 28
VARSET RESULTS
CALL EagloV_表情判定(CHARA,,1)
表情:0 = %RESULTS:0%
表情:1 = %RESULTS:1%
FOR LOCAL, 0, 2
	SIF 表情:LOCAL == ""
		CONTINUE
	CALL EagloV_GET_表情差分(表情:LOCAL)
	表情_眉 = %RESULTS:0%
	表情_目:LOCAL = %RESULTS:1%
	表情_口:LOCAL = %RESULTS:2%
	表情_鼻 = %RESULTS:3%
	IF 表情_口:LOCAL == "笑口" && 表情_目:LOCAL == "笑目"
		表情索引 = %EagloV_表情索引(, CHARA, 表情:LOCAL+"2")%
		IF !SPRITECREATED(表情索引)
			G_ID = 0
			CALL 画像合成(G_ID, "ダミー", 0, 0, 500, 500)
			;EagloV{CHARA}_眉_{眉}
			SIF SPRITECREATED(@"EagloV{CHARA}_眉_%表情_眉%")
				CALL 画像合成(G_ID, @"EagloV{CHARA}_眉_%表情_眉%")

			;EagloV{CHARA}_目_{目}
			SIF SPRITECREATED(@"EagloV{CHARA}_目_笑目")
				CALL 画像合成(G_ID, @"EagloV{CHARA}_目_笑目")

			;EagloV{CHARA}_口_{口}
			SIF SPRITECREATED(@"EagloV{CHARA}_口_大笑口")
				CALL 画像合成(G_ID, @"EagloV{CHARA}_口_大笑口")

			;EagloV{CHARA}_鼻_{鼻}
			SIF SPRITECREATED(@"EagloV{CHARA}_鼻_%表情_鼻%")
				CALL 画像合成(G_ID, @"EagloV{CHARA}_鼻_%表情_鼻%")

			; 合成体图
			SPRITECREATE 表情索引, G_ID
		ENDIF
	ENDIF
NEXT
RESULTS:0 '= 表情:0 != ""&&表情_口:0 == "笑口"&& 表情_目:0 == "笑目"&&CFLAG:CHARA:每回合随机数 % 3 == 0?@"%表情:0%2"# 表情:0
RESULTS:1 '= 表情:1 != ""&&表情_口:1 == "笑口"&& 表情_目:1 == "笑目"&&CFLAG:CHARA:每回合随机数 % 3 == 0?@"%表情:1%2"# 表情:1
RETURN 1

@EagloV_特殊效果_28
#LOCALSIZE 1
#LOCALSSIZE 10
#DIM DYNAMIC エフェクト数 = 0
#DIMS DYNAMIC 表情,2
#DIM CHARA
