@EagloV_特殊效果_1(CHARA)
#LOCALSIZE 1
#LOCALSSIZE 10
#DIM DYNAMIC エフェクト数 = 0
#DIM CHARA
VARSET LOCALS
SIF !CHARA
	CHARA = 1
IF EagloV_服装初步判定(CHARA) == "胖次" || EagloV_服装初步判定(CHARA) == "内衣"
	IF !IS_LOVER(CHARA)
		LOCALS:(エフェクト数*2) = EagloV1_特效_创可贴
		エフェクト数 += 1
	ENDIF
ENDIF

VARSET RESULTS
ARRAYCOPY "LOCALS", "RESULTS"
RETURN エフェクト数

@EagloV_特殊表情_1
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM G_ID
SIF CFLAG:1:诶嘿嘿 || FLAG:時間停止 || CFLAG:1:睡眠 || CFLAG:1:ブチギレ
	RETURN 0
IF !SPRITECREATED("EagloV表情_得意颜_1")
	G_ID = 0
	CALL 画像合成(G_ID, "ダミー", 0, 0, 500, 500)
	CALL 画像合成(G_ID, "EagloV1_眉_挑眉")
	CALL 画像合成(G_ID, "EagloV1_目_半目")
	CALL 画像合成(G_ID, "EagloV1_鼻_鼻")
	CALL 画像合成(G_ID, "EagloV1_口_大笑")
	SPRITECREATE "EagloV表情_得意颜_1", G_ID
ENDIF

IF TALENT:1:心情 > 0 && RAND:6 == 0
	RESULTS:0 = 得意颜
	RESULTS:1 = 好心情
	RETURN 1
ENDIF
IF GETPALAMLV(PALAM:1:欲情, 8) >= 8 && CFLAG:1:积攒度 < 200 && RAND:2
	RESULTS:0 = 得意颜
	RESULTS:1 = 好心情
	RETURN 1
ENDIF
;}

