;-------------------------------------------------
;関数名:GET_TALENTNAME
;概　要:素質名取得関数
;引　数:ARG:0…TALENT登録番号
;　　　:ARG:1…TALENTの中身
;　　　:ARG_ALL_GET=0…以前と変わらない挙動(既定)
;　　　:           =1(追加)…そのTALENT変数がどういう数値を取りうるか返す。汚臭耐性(TALENT:61)なら"-2,-1,0,1,2"
;　　　:           =2(追加)…そのTALENT変数がどういう名前を取りうるか返す。汚臭耐性(TALENT:61)なら"潔癖症,汚臭敏感,,汚臭鈍感,汚れ無視"
;　　　:ARG_SW…ARG_ALL_GETが非0の時に返す文字列を区切る文字列。既定は,
;戻り値:素質名
;備　考:文中関数
;素質の名前を返す。
;2025/9/10  各TALENTが取り得る値、返しうる名前を取得できるように。従来の使い方に限っては挙動が変わっていないはず
;2025/9/19  区切り文字を定数へ移行
;-------------------------------------------------
@GET_TALENTNAME(ARG , ARG:1 , ARG_ALL_GET = 0 , ARG_SW = ",")
#FUNCTIONS
#DIM ARG_ALL_GET
#DIMS ARG_SW ;SPLIT WORD
#DIM CNT
#DIM CONST C_ABILITY_MAX6 = 6
#DIMS L_TNAME
#DIMS L_TVALUE
#DIMS L_SPLITSTR , 20
#DIM L_SPLITNUM
#DIM L_SAVERES

SELECTCASE ARG
	;処女
	CASE 0
		L_TNAME = 無自覚非処女%ARG_SW%%ARG_SW%処女
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
	;童貞
	CASE 1
		L_TNAME = %ARG_SW%%ARG_SW%童貞
		L_TVALUE = 0%ARG_SW%1
	;性別
	CASE 2
		L_TNAME = %ARG_SW%オトコ%ARG_SW%ふたなり
		L_TVALUE = 0%ARG_SW%2%ARG_SW%3
	;キス未経験
	CASE 6
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = キス未経験？%ARG_SW%%ARG_SW%キス未経験
	;度胸
	CASE 10
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = 臆病%ARG_SW%%ARG_SW%気丈
	;態度
	CASE 11
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = 素直%ARG_SW%%ARG_SW%反抗的
	;応答
	CASE 12
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = 大人しい%ARG_SW%%ARG_SW%生意気
	;プライド
	CASE 13
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = プライド低い%ARG_SW%%ARG_SW%プライド高い
	;機嫌
	CASE 15
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = 不機嫌%ARG_SW%%ARG_SW%上機嫌
	;容姿
	CASE 16
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = 醜悪%ARG_SW%%ARG_SW%美形
	;年齢
	CASE 17
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1%ARG_SW%2
		L_TNAME = 子供%ARG_SW%%ARG_SW%中年%ARG_SW%老人
	;性的興味
	CASE 23
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = 保守的%ARG_SW%%ARG_SW%好奇心
	;陽気／陰気,
	CASE 24
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = 陰気%ARG_SW%%ARG_SW%陽気
	;貞操観念
	CASE 30
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = 貞操無頓着%ARG_SW%%ARG_SW%貞操観念
	;自己愛
	CASE 31
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = 抑圧%ARG_SW%%ARG_SW%解放
	;羞恥心
	CASE 33
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = 恥薄い%ARG_SW%%ARG_SW%恥じらい
	;痛覚
	CASE 40
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = 痛みに強い%ARG_SW%%ARG_SW%痛みに弱い
	;濡れやすさ
	CASE 41
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = 濡れにくい%ARG_SW%%ARG_SW%濡れやすい
	;習得速度
	CASE 50
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = 習得遅い%ARG_SW%%ARG_SW%習得早い
	;伐採釣り採集調合Lv
	CASE 46, 47, 48, 49
		L_TVALUE = 0
		FOR CNT , 1 , C_ABILITY_MAX6 + 1
			L_TVALUE += @"%ARG_SW%{CNT}"
		NEXT

		L_TNAME = %TALENTNAME:ARG%0
		FOR CNT , 1 , C_ABILITY_MAX6 + 1
			L_TNAME += @"%ARG_SW%%TALENTNAME:ARG%{CNT}"
		NEXT
	;汚臭耐性
	CASE 61
		L_TVALUE = -2%ARG_SW%-1%ARG_SW%0%ARG_SW%1%ARG_SW%2
		L_TNAME = 潔癖症%ARG_SW%汚臭敏感%ARG_SW%%ARG_SW%汚臭鈍感%ARG_SW%汚れ無視
	;快感応答
	CASE 70
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = 快感の否定%ARG_SW%%ARG_SW%快感に素直
	;性別嗜好
	CASE 81
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1%ARG_SW%2%ARG_SW%3
		L_TNAME = 両刀%ARG_SW%%ARG_SW%男嫌い%ARG_SW%女嫌い%ARG_SW%人間不信
	;体型
	CASE 100
		L_TVALUE = -5%ARG_SW%-2%ARG_SW%-1%ARG_SW%0%ARG_SW%1%ARG_SW%2%ARG_SW%5
		L_TNAME = 小人%ARG_SW%幼児体型%ARG_SW%小柄体型%ARG_SW%%ARG_SW%長身%ARG_SW%巨躯%ARG_SW%巨人
	;Ｃ感度
	CASE 101
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = Ｃ鈍感%ARG_SW%%ARG_SW%Ｃ敏感
	;Ｖ感度
	CASE 102
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = Ｖ鈍感%ARG_SW%%ARG_SW%Ｖ敏感
	;Ａ感度
	CASE 103
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = Ａ鈍感%ARG_SW%%ARG_SW%Ａ敏感
	;Ｂ感度
	CASE 104
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = Ｂ鈍感%ARG_SW%%ARG_SW%Ｂ敏感
	;バストサイズ
	CASE 105
		L_TVALUE = -2%ARG_SW%-1%ARG_SW%0%ARG_SW%1%ARG_SW%2
		L_TNAME = 絶壁%ARG_SW%貧乳%ARG_SW%%ARG_SW%巨乳%ARG_SW%爆乳
		;0は"普乳"が設定されていたがコメントアウトされている
	;Ｍ感度
	CASE 106
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1%ARG_SW%2
		L_TNAME = Ｍ鈍感%ARG_SW%%ARG_SW%Ｍ敏感%ARG_SW%Ｍ過敏
	;ヒップサイズ
	CASE 108
		L_TVALUE = -2%ARG_SW%-1%ARG_SW%0%ARG_SW%1%ARG_SW%2
		L_TNAME = 纖臀%ARG_SW%小臀%ARG_SW%%ARG_SW%潤臀%ARG_SW%豊臀
		;0は"並臀"が設定されていたがコメントアウトされている
	;酒耐性
	CASE 121
		L_TVALUE = -2%ARG_SW%-1%ARG_SW%0%ARG_SW%1%ARG_SW%2%ARG_SW%3
		L_TNAME = 下戸%ARG_SW%酒に弱い%ARG_SW%%ARG_SW%酒に強い%ARG_SW%酒豪%ARG_SW%うわばみ
	;回復速度
	CASE 130
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1
		L_TNAME = 回復遅い%ARG_SW%%ARG_SW%回復早い
	CASE 143
		L_TVALUE = 0%ARG_SW%1%ARG_SW%2%ARG_SW%3%ARG_SW%4
		L_TNAME = %ARG_SW%動物耳%ARG_SW%ウサミミ%ARG_SW%イヌミミ%ARG_SW%ネコミミ
	;CASE 130  ←母乳系はこの関数では130になっていたがtalent.csvは149になっている。CASEの位置も143の次なので書き換え忘れ？
	CASE 149
		L_TVALUE = 0%ARG_SW%1%ARG_SW%2
		L_TNAME = %ARG_SW%授乳可能%ARG_SW%母乳体質
	;音楽知識
	CASE 161
		L_TVALUE = 0%ARG_SW%1%ARG_SW%2%ARG_SW%3
		L_TNAME = %ARG_SW%楽器知識%ARG_SW%歌唱知識%ARG_SW%舞踏知識
	;音感
	CASE 162
		L_TVALUE = -1%ARG_SW%0%ARG_SW%1%ARG_SW%2
		L_TNAME = 音痴%ARG_SW%%ARG_SW%音感%ARG_SW%絶対音感
	;氷精
	CASE 164
		L_TVALUE = 0%ARG_SW%1%ARG_SW%2
		L_TNAME = %ARG_SW%氷精%ARG_SW%雪女
	;セフレ
	CASE 185
		L_TVALUE = 0%ARG_SW%1%ARG_SW%2
		L_TNAME = %ARG_SW%セフレ%ARG_SW%愛人
	;人間
	CASE 190
		L_TVALUE = 0%ARG_SW%1%ARG_SW%2%ARG_SW%3%ARG_SW%4%ARG_SW%5%ARG_SW%6
		L_TNAME = %ARG_SW%人間%ARG_SW%仙人%ARG_SW%天人%ARG_SW%月人%ARG_SW%魔界人%ARG_SW%外界人
	;妖怪
	CASE 191
		;さすがに長いので{}使うね
		{
			L_TVALUE = 
				0%ARG_SW%
				1%ARG_SW%
				2%ARG_SW%
				3%ARG_SW%
				4%ARG_SW%
				5%ARG_SW%
				6%ARG_SW%
				7%ARG_SW%
				8%ARG_SW%
				9%ARG_SW%
				10%ARG_SW%
				11%ARG_SW%
				12
		}
		{
			L_TNAME = 
				%ARG_SW%
				妖怪%ARG_SW%
				鬼%ARG_SW%
				吸血鬼%ARG_SW%
				河童%ARG_SW%
				天狗%ARG_SW%
				妖獣%ARG_SW%
				妖鳥%ARG_SW%
				妖蟲%ARG_SW%
				悪魔%ARG_SW%
				小人%ARG_SW%
				座敷わらし%ARG_SW%
				山童
		}
		;タブ文字と半角スペースを削除
		L_TVALUE = REPLACE(L_TVALUE , "	" , "")
		L_TVALUE = REPLACE(L_TVALUE , " " , "")
		L_TNAME = REPLACE(L_TNAME , "	" , "")
		L_TNAME = REPLACE(L_TNAME , " " , "")
	;妖精
	CASE 192
		L_TVALUE = 0%ARG_SW%1
		L_TNAME = %ARG_SW%妖精
	;神霊
	CASE 193
		L_TVALUE = 0%ARG_SW%1%ARG_SW%2%ARG_SW%3
		L_TNAME = %ARG_SW%神霊%ARG_SW%死神%ARG_SW%閻魔
	;幽霊
	CASE 194
		L_TVALUE = 0%ARG_SW%1%ARG_SW%2%ARG_SW%3%ARG_SW%4
		L_TNAME = %ARG_SW%幽霊%ARG_SW%騒霊%ARG_SW%亡霊%ARG_SW%悪霊
	;付喪神
	CASE 195
		L_TVALUE = 0%ARG_SW%1
		L_TNAME = %ARG_SW%付喪神
	;人形
	CASE 196
		L_TVALUE = 0%ARG_SW%1%ARG_SW%2%ARG_SW%3%ARG_SW%4%ARG_SW%5%ARG_SW%99
		L_TNAME = %ARG_SW%人形%ARG_SW%ロボット%ARG_SW%ゴーレム%ARG_SW%埴輪%ARG_SW%キョンシー%ARG_SW%人形の乙女
	;追加種族
	CASE 197
		L_TVALUE = 0%ARG_SW%1%ARG_SW%2%ARG_SW%3%ARG_SW%4
		L_TNAME = %ARG_SW%巫女%ARG_SW%魔法使い%ARG_SW%メイド%ARG_SW%蓬莱人
	;人妻
	CASE 198
		L_TVALUE = 0%ARG_SW%1%ARG_SW%2
		L_TNAME = %ARG_SW%人妻%ARG_SW%未亡人
	;温泉従業員
	CASE 199
		L_TVALUE = 0%ARG_SW%1%ARG_SW%2%ARG_SW%3%ARG_SW%4
		L_TNAME = %ARG_SW%風俗嬢%ARG_SW%娼婦%ARG_SW%馴染みの風俗嬢%ARG_SW%馴染みの娼婦
	;酒造家
	CASE 225
		L_TVALUE = 0%ARG_SW%1%ARG_SW%2
		L_TNAME = %ARG_SW%酒造家%ARG_SW%杜氏
	;積み石
	CASE 274
		L_TVALUE = 0%ARG_SW%1%ARG_SW%2%ARG_SW%3%ARG_SW%4%ARG_SW%5%ARG_SW%6
		L_TNAME = %ARG_SW%積み石ビギナー%ARG_SW%積み石ルーキー%ARG_SW%積み石エリート%ARG_SW%積み石ベテラン%ARG_SW%積み石マスター%ARG_SW%積み石王
	;形状
	CASE 250
		;3は欠番？
		L_TVALUE = 0%ARG_SW%1%ARG_SW%2%ARG_SW%4%ARG_SW%5%ARG_SW%6%ARG_SW%10
		L_TNAME = %ARG_SW%幼チン%ARG_SW%粗チン%ARG_SW%ホタルチンポ%ARG_SW%イボチン%ARG_SW%巨チン%ARG_SW%超巨チン
	;PREGNANCY_TYPE
	CASE 310
		L_TVALUE = 0%ARG_SW%{PREGNANCY_LITTERS}%ARG_SW%{PREGNANCY_EGGS}%ARG_SW%{PREGNANCY_CLUTCH}
		L_TNAME = %ARG_SW%多胎%ARG_SW%産卵（単）%ARG_SW%産卵（複）
	;Nesting
	CASE 311
		L_TVALUE = 0%ARG_SW%1
		L_TNAME = %ARG_SW%孵育
	;Hyperfertile
	CASE 312
		L_TVALUE = 0%ARG_SW%1
		L_TNAME = %ARG_SW%超排卵
	CASEELSE
		L_TVALUE = 0%ARG_SW%1
		L_TNAME = %ARG_SW%%TALENTNAME:ARG%
ENDSELECT

IF ARG_ALL_GET == 1
	;取り得る値を返す
	RETURNF L_TVALUE
ELSEIF ARG_ALL_GET == 2
	;取り得る名前を返す
	RETURNF L_TNAME
ELSE
	;(従来の挙動)ARG:1で指定された値のTALENTNAMEを返す
	;従来の挙動はRESULTを破壊しないのでRESULTを保持する
	L_SAVERES = RESULT

	VARSET L_SPLITSTR
	SPLIT L_TVALUE , ARG_SW , L_SPLITSTR
	L_SPLITNUM = FINDELEMENT(L_SPLITSTR , TOSTR(ARG:1) , , ,1)

	VARSET L_SPLITSTR
	SPLIT L_TNAME , ARG_SW , L_SPLITSTR

	RESULT = L_SAVERES
	IF L_SPLITNUM >= 0
		RETURNF L_SPLITSTR:L_SPLITNUM
	ELSE
		RETURNF ""
	ENDIF
ENDIF


;-------------------------------------------------
;CHARAの種族素質ARGの名称を返す
;-------------------------------------------------
@GET_TRIBENAME(CHARA, ARG)
#FUNCTIONS
#DIM CHARA
SELECTCASE ARG
CASE GETNUM(TALENT, "人間")
	SELECTCASE TALENT:CHARA:ARG
	CASE 1
		RETURNF "人間"
	CASE 2
		RETURNF "仙人"
	CASE 3
		RETURNF "天人"
	CASE 4
		RETURNF "月人"
	CASE 5
		RETURNF "魔界人"
	CASE 6
		RETURNF "外界人"
	CASEELSE
		RETURNF "名称不明（人間）"
	ENDSELECT
CASE GETNUM(TALENT, "妖怪")
	SELECTCASE TALENT:CHARA:ARG
	CASE 1
		RETURNF "妖怪"
	CASE 2
		RETURNF "鬼"
	CASE 3
		RETURNF "吸血鬼"
	CASE 4
		RETURNF "河童"
	CASE 5
		RETURNF "天狗"
	CASE 6
		RETURNF "妖獣"
	CASE 7
		RETURNF "妖鳥"
	CASE 8
		RETURNF "妖蟲"
	CASE 9
		RETURNF "悪魔"
	CASE 10
		RETURNF "小人"
	CASE 11
		RETURNF "座敷わらし"
	CASE 12
		RETURNF "山童"
	CASEELSE
		RETURNF "名称不明（妖怪）"
	ENDSELECT
CASE GETNUM(TALENT, "妖精")
	SELECTCASE TALENT:CHARA:ARG
	CASE 1
		RETURNF "妖精"
	CASEELSE
		RETURNF "名称不明（妖精）"
	ENDSELECT
CASE GETNUM(TALENT, "神霊")
	SELECTCASE TALENT:CHARA:ARG
	CASE 1
		RETURNF "神霊"
	CASE 2
		RETURNF "死神"
	CASE 3
		RETURNF "閻魔"
	CASEELSE
		RETURNF "名称不明（神霊）"
	ENDSELECT
CASE GETNUM(TALENT, "幽霊")
	SELECTCASE TALENT:CHARA:ARG
	CASE 1
		RETURNF "幽霊"
	CASE 2
		RETURNF "騒霊"
	CASE 3
		RETURNF "亡霊"
	CASE 4
		RETURNF "悪霊"
	CASEELSE
		RETURNF "名称不明（幽霊）"
	ENDSELECT
CASE GETNUM(TALENT, "付喪神")
	SELECTCASE TALENT:CHARA:ARG
	CASE 1
		RETURNF "付喪神"
	CASEELSE
		RETURNF "名称不明（付喪神）"
	ENDSELECT
CASE GETNUM(TALENT, "人形")
	SELECTCASE TALENT:CHARA:ARG
	CASE 1
		RETURNF "人形"
	CASE 2
		RETURNF "ロボット"
	CASE 3
		RETURNF "ゴーレム"
	CASE 4
		RETURNF "埴輪"
	CASE 5
		RETURNF "キョンシー"
	CASE 99
		RETURNF "人形の乙女"
	CASEELSE
		RETURNF "名称不明（人形）"
	ENDSELECT
CASE GETNUM(TALENT, "追加種族")
	SELECTCASE TALENT:CHARA:ARG
	CASE 1
		RETURNF "巫女"
	CASE 2
		RETURNF "魔法使い"
	CASE 3
		RETURNF "メイド"
	CASE 4
		RETURNF "蓬莱人"
	CASEELSE
		RETURNF "名称不明（追加種族）"
	ENDSELECT
ENDSELECT
