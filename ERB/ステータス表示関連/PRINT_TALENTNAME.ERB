;-------------------------------------------------
;函数名:GET_TALENTNAME
;概　要:素質名取得函数
;参　数:ARG:0…TALENT编号
;　　　:ARG:1…TALENT的值
;返回值:素質名
;备　考:文中函数
;返回素质的名称
;-------------------------------------------------
@GET_TALENTNAME(ARG,ARG:1)
#FUNCTIONS
SELECTCASE ARG
