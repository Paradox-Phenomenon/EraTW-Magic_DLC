	CASEELSE
		RETURNF "名称不明（付丧神）"
	ENDSELECT
CASE GETNUM(TALENT, "人形")
	SELECTCASE TALENT:CHARA:ARG
	CASE 1
		RETURNF "人形"
	CASE 2
		RETURNF "机械"
	CASE 3
