@F角色列表34(ARG, O_DATA, V_NAME)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "有剧本选项的角色列表"
CASE "SHOP表示"
	RETURNF @"{1}"
CASE "判定"
	IF ARG == MASTER
	ELSEIF !CHECK_CHARA(ARG, "存在")
	ELSEIF GETBIT(CFLAG:ARG:kojo_option,CFLAG:ARG:剧本选择)
		RETURNF @"{1}"
	ELSE
	ENDIF
ENDSELECT
