;複合条件系




;オブジェクト本体
@F角色列表31(ARG, O_DATA, V_NAME)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "可换装PLAY的角色列表"
;CASE "SHOP表示"
;	RETURNF @"{1}"
CASE "判定"
;換装ることができる
	IF ARG == MASTER
		RETURNF @"{1}"
	ELSEIF !CHECK_CHARA(ARG, "存在") || !CHECK_CHARA(ARG, "同室")
	ELSEIF FLAG:時間停止 == 1
		RETURNF @"{1}"
	ELSEIF 睡眠時間(ARG)
	ELSEIF CHECK_CHARA(ARG, "陥落")
		RETURNF @"{1}"
	ELSEIF CHECK_CHARA(ARG, "掌握把柄")
	ELSEIF CHECK_CHARA(ARG, "被掌握把柄")
		RETURNF @"{1}"
	ELSE
	ENDIF
ENDSELECT





@F角色列表32(ARG, O_DATA, V_NAME)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "可换装的角色列表"
CASE "SHOP表示"
	RETURNF @"{1}"
CASE "判定"
	IF ARG == MASTER
	ELSEIF !CHECK_CHARA(ARG, "存在")
	ELSEIF CHECK_CHARA(ARG, "掌握把柄")
	ELSEIF CHECK_CHARA(ARG, "陥落") || CHECK_CHARA(ARG, "被掌握把柄")
		RETURNF @"{1}"
	ELSE
	ENDIF
ENDSELECT





