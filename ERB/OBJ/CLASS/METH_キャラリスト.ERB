;角色列表


;オブジェクト本体
@F角色列表1(ARG, O_DATA, V_NAME)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "现有的角色列表"
CASE "SHOP表示"
	RETURNF @"{1}"
CASE "判定"
	SIF CHECK_CHARA(ARG, "存在")
		RETURNF @"{1}"
ENDSELECT





