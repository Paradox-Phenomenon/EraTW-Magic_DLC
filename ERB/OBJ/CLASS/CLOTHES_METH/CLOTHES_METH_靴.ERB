
@F靴1(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
SELECTCASE O_DATA
CASE "名前"
	RETURNF "鞋子"
CASE "装備部位"
	RETURNF "「靴」"
;旧装備処理との照会用、靴の1
ENDSELECT
