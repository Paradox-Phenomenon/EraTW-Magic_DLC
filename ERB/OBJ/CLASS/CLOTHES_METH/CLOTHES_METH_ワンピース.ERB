
@F連衣裙1(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
SELECTCASE O_DATA
CASE "名前"
	RETURNF "連衣裙"
CASE "装備部位"
	RETURNF "「連衣裙」"
;旧装備処理との照会用、連衣裙の1
ENDSELECT
