
@F上半身内衣_はだけ不可1(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
SELECTCASE O_DATA
CASE "名前"
	RETURNF "文胸"
CASE "装備部位"
	RETURNF "「上半身内衣１」"
;旧装備処理との照会用、上半身内衣１の1
CASE "つける"
	IF TALENT:ARG:幼稚 || TALENT:ARG:幼児／幼児退行
		RETURNF "0"
	ELSE
		RETURNF "1"
	ENDIF
CASE "布料厚度"
	RETURNF "2"
ENDSELECT

