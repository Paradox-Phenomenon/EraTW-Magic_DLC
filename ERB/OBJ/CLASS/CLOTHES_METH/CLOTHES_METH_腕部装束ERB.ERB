
@F腕部装束1(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
SELECTCASE O_DATA
CASE "名前"
	RETURNF "手甲"
CASE "装備部位"
	RETURNF "「腕部装束」"
;旧装備処理との照会用、腕部装束の1
ENDSELECT

