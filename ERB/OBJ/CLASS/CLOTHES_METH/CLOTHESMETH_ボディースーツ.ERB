
@Fボディースーツ1(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
SELECTCASE O_DATA
CASE "名前"
	RETURNF "连体紧身衣"
CASE "装備部位"
	RETURNF "「ボディースーツ」"
;旧装備処理との照会用、ボディースーツの1
ENDSELECT

