@F下半身内衣_ずらし可能0(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
SELECTCASE O_DATA
CASE "名前"
	;STR型の一時変数を定義する命令
	RETURNF "没穿内裤"
CASE "能穿"
;没穿内裤を履くとは
	SIF (TALENT:ARG:風騷 || TALENT:ARG:小悪魔 || TALENT:ARG:炮友 || ABL:ARG:露出癖 >= 8) && !RAND:5
		RETURNF "1"
CASE "関連内衣"
	RETURNF "0"
ENDSELECT

