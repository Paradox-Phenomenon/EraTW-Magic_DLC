
@F裙子1(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
SELECTCASE O_DATA
CASE "名前"
	RETURNF "裙子"
CASE "装備部位"
	RETURNF "「裙子」"
;旧装備処理との照会用、裙子の1
ENDSELECT
