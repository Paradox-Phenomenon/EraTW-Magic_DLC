
@F和服1(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
SELECTCASE O_DATA
CASE "名前"
	RETURNF "和服"
CASE "装備部位"
	RETURNF "「和服」"
;旧装備処理との照会用、和服の1
ENDSELECT

