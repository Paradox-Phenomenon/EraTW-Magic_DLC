
@F上半身内衣_はだけ可能1(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
SELECTCASE O_DATA
CASE "名前"
	RETURNF "比基尼内衣"
CASE "装備部位"
	RETURNF "「上半身内衣２」"
;旧装備処理との照会用、上半身内衣２の1
ENDSELECT

