
@F下半身内衣_ずらし不可1(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
SELECTCASE O_DATA
CASE "名前"
	RETURNF "兜襠布"
CASE "装備部位"
	RETURNF "「下半身内衣１」"
;旧装備処理との照会用、下半身内衣１の1
CASE "半透明(前)"
	RETURNF "1"
CASE "半透明(後)"
	RETURNF "0"
ENDSELECT
