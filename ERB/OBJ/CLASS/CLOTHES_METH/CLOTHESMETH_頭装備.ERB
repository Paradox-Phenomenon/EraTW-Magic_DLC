
@F頭装備1(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
SELECTCASE O_DATA
CASE "名前"
	RETURNF "帽子"
CASE "装備部位"
	RETURNF "「帽子」"
;旧装備処理との照会用、帽子の1
ENDSELECT

