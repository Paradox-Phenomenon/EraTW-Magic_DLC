
@F上身衣服_はだけ不可1(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
SELECTCASE O_DATA
CASE "名前"
	RETURNF "无袖上衣"
CASE "装備部位"
	RETURNF "「上身衣服１」"
;旧装備処理との照会用、上身衣服１の1
ENDSELECT

