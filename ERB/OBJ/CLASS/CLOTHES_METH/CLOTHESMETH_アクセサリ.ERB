
;オブジェクト本体
@F飾品1(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
SELECTCASE O_DATA
CASE "名前"
	RETURNF "眼鏡"
CASE "装備部位"
	RETURNF "「飾品」"
;旧装備処理との照会用、飾品の1
ENDSELECT

