;オブジェクト本体
@F衣装セット1(ARG, O_DATA)
#FUNCTIONS
#LOCALSIZE 1
#LOCALSSIZE 1
#DIMS O_DATA
#DIMS V_NAME
SELECTCASE O_DATA
CASE "名前"
	RETURNF "一套男装"
CASE "基本套装"
	RETURNF "1"

;こっから衣装設定系
CASE "靴"
	RETURNF @"{[[靴_鞋子]]}"
CASE "襪子"
	RETURNF @"{[[襪子_袜子]]}"
CASE "裤子"
	RETURNF @"{[[裤子_裤子]]}"
CASE "上半身内衣１"
;漢女は裹胸をつける
	IF GETBIT(TALENT:ARG:2, 0)
		RETURNF @"{[[上半身内衣_はだけ不可_裹胸]]}"
	ELSE
		RETURNF @"{[[上半身内衣_はだけ不可_Ｔ恤衫]]}"
	ENDIF
CASE "上身衣服１"
	RETURNF @"{[[上身衣服_はだけ不可_上衣]]}"
ENDSELECT




