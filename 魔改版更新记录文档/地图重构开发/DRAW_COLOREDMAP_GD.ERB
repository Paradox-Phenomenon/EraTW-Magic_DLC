;===============================================================
; 初始化
;===============================================================
@INIT_MAPGD
	IF !IS_MAPGD_INITIALIZED
		GCREATE GID_BLANK, 1, 1
		GCLEAR GID_BLANK, 0x00000000
		SPRITECREATE "MAP_BLANK", GID_BLANK
		
		SIF !MAP_EXIST("MAP_BG_INFO")
			MAP_CREATE "MAP_BG_INFO"  ; 用于记录各个地图缓存的宽度/高度等信息
			
		IS_MAPGD_INITIALIZED = 1
	ENDIF

;===============================================================
; 构建地图动画底图 (每天/切换新地图时执行一次)
;===============================================================
@BUILD_MAP_BG_ANIMATION(MAP_MODE)
#DIM	DYNAMIC	FRAME
#DIM	DYNAMIC	ROW
#DIM	DYNAMIC	COLUMN
#DIM	DYNAMIC	CELL_HEIGHT
#DIMS	DYNAMIC	MAP_MODE
#DIM	DYNAMIC	SEEDA
#DIM	DYNAMIC	实际行数
#DIMS	DYNAMIC	MAP_DATA, 42
#DIMS	DYNAMIC	COLOR_DATA, 42
#DIMS	DYNAMIC	COLORCOLUMNS, 128
#DIMS	DYNAMIC	COLUMN_STR
#DIMS	DYNAMIC	CURRENT_STR
#DIMS	DYNAMIC	TEMP_TILE
#DIM	DYNAMIC	当前位置X
#DIM	DYNAMIC	当前位置Y
#DIM	DYNAMIC	CURRENT_COLOR
#DIM	DYNAMIC	TILE_W
#DIM	DYNAMIC	MAX_WIDTH_PX
#DIM	DYNAMIC	MAP_HASH_ID
#DIMS	DYNAMIC	MAP_CACHE_KEY

#DIM	CONST	SAFE_CANVAS_WIDTH = 3000
#DIM	DYNAMIC	CANVAS_HEIGHT
#DIM	DYNAMIC	GID_ANIME

CALL INIT_MAPGD
CELL_HEIGHT = GETCONFIG("一行の高さ")
; -----------------------------------------------------------
; 1. 缓存生命周期管理：天数改变时清空底图缓存记录
; -----------------------------------------------------------
IF CACHED_MAP_DAY != DAY
	MAP_CLEAR "MAP_BG_INFO"
	CACHED_MAP_DAY = DAY
ENDIF

; 标识仅包含地图和分页，不包含察知模式，因为察知不改变底图地形
MAP_HASH_ID = MAIN_MAP * 1000 + TFLAG:地圖切換 * 10
MAP_CACHE_KEY '= @"%MAP_MODE%_{MAP_HASH_ID}"

; 如果今天已经生成过该地图的底图，直接跳过生成
IF MAP_HAS("MAP_BG_INFO", MAP_CACHE_KEY)
	RETURN 1
ENDIF

; -----------------------------------------------------------
; 2. 获取地图数据
; -----------------------------------------------------------
VARSET MAP_DATA, "NULL"
VARSET COLOR_DATA, "0"

IF MAP_MODE == "ODEKAKE"
	TRYCCALLFORM COLOREDODEKAKEMAP_{CFLAG:MASTER:约会中}(MAP_DATA, COLOR_DATA)
	CATCH
		RETURN 0
	ENDCATCH
ELSEIF MAP_MODE == "GLOBAL"
	TRYCCALLFORM COLOREDFIELD(MAP_DATA, COLOR_DATA)
	CATCH
		RETURN 0
	ENDCATCH
ELSE
	CALLFORM MAP_VIEWING(MAIN_MAP)
	TFLAG:地圖切換 = LIMIT(TFLAG:地圖切換, 1, MAP_PAGES)
	DO
		TRYCCALLFORM COLOREDMAP_%RESULTS%_{TFLAG:地圖切換}(MAP_DATA, COLOR_DATA)
			BREAK
		CATCH
			TFLAG:地圖切換 --
		ENDCATCH
	LOOP TFLAG:地圖切換 > 0
ENDIF

实际行数 = 0
FOR ROW, 0, 42
	SIF MAP_DATA:ROW == "NULL" || MAP_DATA:ROW == ""
		BREAK
	实际行数++
NEXT

CANVAS_HEIGHT = 实际行数 * CELL_HEIGHT

; -----------------------------------------------------------
; 3. 渲染 20 帧动画底图
; -----------------------------------------------------------
MAX_WIDTH_PX = 0

SPRITEDISPOSE @"MAP_ANIME_%MAP_CACHE_KEY%"

FOR FRAME, 0, ANIMATION_FRAMES
	GID_ANIME = 9000 + MAP_HASH_ID * 20 + FRAME
	
	IF GCREATED(GID_ANIME) == 0
		GCREATE GID_ANIME, SAFE_CANVAS_WIDTH, CANVAS_HEIGHT
	ENDIF
	GCLEAR GID_ANIME, 0x00000000
	GSETFONT GID_ANIME, "ＭＳ ゴシック", CELL_HEIGHT, 0
	
	当前位置Y = 0
	FOR ROW, 0, 实际行数
		COLUMN_STR '= REPLACE(MAP_DATA:ROW, "​", "")
		LOCAL = STRLENSU(COLUMN_STR)
		SPLIT COLOR_DATA:ROW, ",", COLORCOLUMNS

		当前位置X = 0
		FOR COLUMN, 0, LOCAL
			CURRENT_STR '= CHARATU(COLUMN_STR, COLUMN)
			SIF CURRENT_STR == ""
				BREAK

			CURRENT_COLOR = 0
			
			IF COLORCOLUMNS:COLUMN == "def"
				CURRENT_COLOR = GETDEFCOLOR()
			ELSEIF COLORCOLUMNS:COLUMN != ""
				IF ISNUMERIC(COLORCOLUMNS:COLUMN)
					CURRENT_COLOR = APPLYCOLOR_F(TOINT(COLORCOLUMNS:COLUMN))
				ELSE
					CALL GETSEASONALCOLORS(COLORCOLUMNS:COLUMN, FRAME)
					SIF RESULT > -1
						CURRENT_COLOR = RESULT
				ENDIF
			ENDIF

			; --- 仅将文本画上去 ---
			IF ISNUMERIC(CURRENT_STR)
				LOCAL:1 = TOINT(CURRENT_STR) * 10
				COLUMN++
				CURRENT_STR '= CHARATU(COLUMN_STR, COLUMN)
				LOCAL:1 += TOINT(CURRENT_STR)

				IF MAP_MODE == "ODEKAKE" && LOCAL:1 >= 10
					TEMP_TILE '= "◇"
				ELSE
					; 全角转换，留作按钮底字
					TEMP_TILE '= (LOCAL:1 > 9 ? TOSTR(LOCAL:1) # TOFULL(TOSTR(LOCAL:1)))
				ENDIF
				
				; 底图部分强制将该位置渲染为默认颜色或白色，悬停等变色交由后期
				; 如果你的基础地图需要赋予这些地点颜色，可以在这里给定默认配色
				CURRENT_COLOR = GETDEFCOLOR()
			ELSE
				CALL GETANIMATIONCHARACTER(FRAME, COLORCOLUMNS:COLUMN, CURRENT_STR, SEEDA, 1)
				TEMP_TILE '= RESULTS
			ENDIF

			TILE_W = HTML_STRINGLEN(TEMP_TILE, 1)
			
			GSETBRUSH GID_ANIME, CURRENT_COLOR | 0xFF000000
			GDRAWTEXT GID_ANIME, TEMP_TILE, 当前位置X, 当前位置Y
			
			当前位置X += TILE_W
		NEXT
		SIF 当前位置X > MAX_WIDTH_PX
			MAX_WIDTH_PX = 当前位置X
			
		当前位置Y += CELL_HEIGHT
	NEXT
NEXT

; 生成动画精灵
SPRITEANIMECREATE @"MAP_ANIME_%MAP_CACHE_KEY%", MAX_WIDTH_PX, CANVAS_HEIGHT
FOR FRAME, 0, ANIMATION_FRAMES
	GID_ANIME = 9000 + MAP_HASH_ID * 20 + FRAME
	SPRITEANIMEADDFRAME @"MAP_ANIME_%MAP_CACHE_KEY%", GID_ANIME, 0, 0, MAX_WIDTH_PX, CANVAS_HEIGHT, 0, 0, ANIMATERECOLOREDMAPS
NEXT

; 记录该地图的尺寸信息用于后续 HTML 组装
MAP_SET "MAP_BG_INFO", MAP_CACHE_KEY, @"{MAX_WIDTH_PX},{CANVAS_HEIGHT},{实际行数}"
RETURN 1


;===============================================================
; 供主界面的渲染接口 (分离逻辑后的极速渲染器)
; 每次打开地图/更新状态实时拼凑 HTML，极大减轻内存负担
;===============================================================
@DRAW_COLOREDMAP_GD(MAP_MODE)
#DIMS	DYNAMIC	MAP_MODE
#DIM	DYNAMIC	CELL_HEIGHT
#DIM	DYNAMIC	FRAME
#DIMS	DYNAMIC	MAP_CACHE_KEY
#DIMS	DYNAMIC	MAP_INFO
#DIMS	DYNAMIC	INFO_PARTS, 3
#DIM	DYNAMIC	MAX_WIDTH_PX
#DIM	DYNAMIC	CANVAS_HEIGHT
#DIM	DYNAMIC	实际行数
#DIM	DYNAMIC	SEEDA
	
#DIMS	DYNAMIC	MAP_DATA, 42
#DIMS	DYNAMIC	COLOR_DATA, 42
#DIMS	DYNAMIC	COLORCOLUMNS, 128
#DIMS	DYNAMIC	COLUMN_STR
#DIMS	DYNAMIC	CURRENT_STR
#DIMS	DYNAMIC	TEMP_TILE
#DIMS	DYNAMIC	TOOLTIP_STR
#DIMS	DYNAMIC	HTML_BUTTONS
#DIMS	DYNAMIC	FINAL_HTML

#DIM	DYNAMIC	ROW
#DIM	DYNAMIC	COLUMN
#DIM	DYNAMIC	LOCATION
#DIM	DYNAMIC	REAL_LOC
#DIM	DYNAMIC	CURRENT_COLOR
#DIM	DYNAMIC	当前位置X
#DIM	DYNAMIC	当前位置Y
#DIM	DYNAMIC	TILE_W

#DIM	DYNAMIC	GID_HOVER
#DIM	DYNAMIC	GID_COLOR
CELL_HEIGHT = GETCONFIG("一行の高さ")
; 1. 确保底图已经生成
CALL BUILD_MAP_BG_ANIMATION(MAP_MODE)

MAP_CACHE_KEY '= @"%MAP_MODE%_{MAIN_MAP * 1000 + TFLAG:地圖切換 * 10}"
MAP_INFO '= MAP_GET("MAP_BG_INFO", MAP_CACHE_KEY)
SPLIT MAP_INFO, ",", INFO_PARTS
MAX_WIDTH_PX = TOINT(INFO_PARTS:0)
CANVAS_HEIGHT = TOINT(INFO_PARTS:1)
实际行数 = TOINT(INFO_PARTS:2)

IF MAP_MODE == "ODEKAKE"
	TRYCALLFORM COLOREDODEKAKEMAP_{CFLAG:MASTER:约会中}(MAP_DATA, COLOR_DATA)
ELSEIF MAP_MODE == "GLOBAL"
	TRYCALLFORM COLOREDFIELD(MAP_DATA, COLOR_DATA)
ELSE
	CALLFORM MAP_VIEWING(MAIN_MAP)
	TRYCALLFORM COLOREDMAP_%RESULTS%_{TFLAG:地圖切換}(MAP_DATA, COLOR_DATA)
ENDIF

; 3. 动态解析并生成最新的 HTML 按钮与状态高亮层
HTML_BUTTONS '= ""
当前位置Y = 0

FOR ROW, 0, 实际行数
	COLUMN_STR '= REPLACE(MAP_DATA:ROW, "​", "")
	LOCAL = STRLENSU(COLUMN_STR)

	当前位置X = 0
	FOR COLUMN, 0, LOCAL
		CURRENT_STR '= CHARATU(COLUMN_STR, COLUMN)
		SIF CURRENT_STR == ""
			BREAK

		IF ISNUMERIC(CURRENT_STR)
			LOCAL:1 = TOINT(CURRENT_STR) * 10
			COLUMN++
			CURRENT_STR '= CHARATU(COLUMN_STR, COLUMN)
			LOCAL:1 += TOINT(CURRENT_STR)
			
			; 还原真实 LOCATION 并获取当下的状态 (颜色+Tooltip)
			IF MAP_MODE == "ODEKAKE"
				IF LOCAL:1 >= 10
					TEMP_TILE '= "◇"
				ELSE
					TEMP_TILE '= (LOCAL:1 > 9 ? TOSTR(LOCAL:1) # TOFULL(TOSTR(LOCAL:1)))
				ENDIF
				REAL_LOC = LOCAL:1 + (CFLAG:MASTER:约会中 * 100)
			ELSEIF MAP_MODE != "GLOBAL"
				TEMP_TILE '= (LOCAL:1 > 9 ? TOSTR(LOCAL:1) # TOFULL(TOSTR(LOCAL:1)))
				REAL_LOC = LOCAL:1 + MAIN_MAP * 100
			ENDIF

			; >>> 调用我们抽离出来的终极状态获取函数 <<<
			CALL GET_LOCATION_STATUS_AND_TOOLTIP(REAL_LOC, MAP_MODE)
			CURRENT_COLOR = RESULT
			TOOLTIP_STR '= RESULTS
			TILE_W = HTML_STRINGLEN(TEMP_TILE, 1)

			; 检查并生成金色悬停图 (永久缓存，直到游戏结束)
			IF !SPRITECREATED(@"MAP_HOVER_{REAL_LOC}")
				GID_HOVER = GID_HOVER_BASE + REAL_LOC
				GCREATE GID_HOVER, TILE_W, CELL_HEIGHT
				GCLEAR GID_HOVER, 0x00000000
				GSETFONT GID_HOVER, "ＭＳ ゴシック", CELL_HEIGHT, 0
				GSETBRUSH GID_HOVER, HOVER_COLOR
				GDRAWTEXT GID_HOVER, TEMP_TILE, 0, 0
				SPRITECREATE @"MAP_HOVER_{REAL_LOC}", GID_HOVER
			ENDIF

			; 检查并生成常驻的高亮变色图 (如果颜色不是默认色，才需要用一个图片盖上去)
			IF CURRENT_COLOR != GETDEFCOLOR()
				IF !SPRITECREATED(@"MAP_COLOR_{CURRENT_COLOR}_%TEMP_TILE%")
					; GID 分配一个小技巧，随便找个很远的空地
					GID_COLOR = 85000 + CURRENT_COLOR % 5000 
					GCREATE GID_COLOR, TILE_W, CELL_HEIGHT
					GCLEAR GID_COLOR, 0x00000000
					GSETFONT GID_COLOR, "ＭＳ ゴシック", CELL_HEIGHT, 0
					GSETBRUSH GID_COLOR, CURRENT_COLOR | 0xFF000000
					GDRAWTEXT GID_COLOR, TEMP_TILE, 0, 0
					SPRITECREATE @"MAP_COLOR_{CURRENT_COLOR}_%TEMP_TILE%", GID_COLOR
				ENDIF
			ENDIF

			; 组装包含高亮图（常驻）与金图（悬停）的按钮 DIV
			HTML_BUTTONS += @"<div rect='{当前位置X}px,{当前位置Y}px,{TILE_W}px,{CELL_HEIGHT}px'>"
			HTML_BUTTONS += @"<button value='{REAL_LOC}' title='%HTML_ESCAPE(TOOLTIP_STR)%'>"
			IF CURRENT_COLOR != GETDEFCOLOR()
				; 如果有状态高亮，底图是高亮字，悬停是金字
				HTML_BUTTONS += @"<img src='MAP_COLOR_{CURRENT_COLOR}_%TEMP_TILE%' srcb='MAP_HOVER_{REAL_LOC}' width='{TILE_W}px' height='{CELL_HEIGHT}px'>"
			ELSE
				; 否则底图透明露出背景字，悬停是金字
				HTML_BUTTONS += @"<img src='MAP_BLANK' srcb='MAP_HOVER_{REAL_LOC}' width='{TILE_W}px' height='{CELL_HEIGHT}px'>"
			ENDIF
			HTML_BUTTONS += @"</button></div>"
			
			当前位置X += TILE_W
		ELSE
			; 如果只是普通字符，获取宽度增加位移
			CALL GETANIMATIONCHARACTER(FRAME, COLORCOLUMNS:COLUMN, CURRENT_STR, SEEDA, 1)
			TILE_W = HTML_STRINGLEN(RESULTS, 1)
			当前位置X += TILE_W
		ENDIF
	NEXT
	当前位置Y += CELL_HEIGHT
NEXT

FINAL_HTML += @"<img src='MAP_ANIME_%MAP_CACHE_KEY%' height='{CANVAS_HEIGHT}px'>"
FINAL_HTML += @"<shape type='space' param='-{MAX_WIDTH_PX}px'>"
FINAL_HTML += HTML_BUTTONS

HTML_PRINT FINAL_HTML

;===============================================================
; 获取特定地点的 状态颜色 和 Tooltip文本 (从原 GETMAP 提取)
; 返回值：
;   RESULT   : 该地点计算出的 ARGB 颜色代码 (0xRRGGBB)
;   RESULTS  : 拼接好的 Tooltip 字符串 (HTML_ESCAPE 处理前)
; 参数：
;   LOCATION : 地点 ID (通常为 MAIN_MAP * 100 + ARG 或 ODEKAKE ID)
;   MAP_MODE     : "ODEKAKE" 表示外出地图，空字符串表示据点地图
;===============================================================
@GET_LOCATION_STATUS_AND_TOOLTIP(LOCATION, MAP_MODE)
#DIM	DYNAMIC	LOCATION
#DIMS	DYNAMIC	MAP_MODE
#DIM	DYNAMIC	RET_COLOR
#DIMS	DYNAMIC	RET_TOOLTIP
#DIM	DYNAMIC	Q_ID
#DIM	DYNAMIC	CHARA

; 1. 默认颜色与提取地点名
RET_COLOR = GETDEFCOLOR()
RET_TOOLTIP '= NAME_FROM_PLACE(LOCATION)

; 2. 脏污 / 积雪 颜色判定 & Tooltip追加
IF (TALENT:MASTER:汚部屋察知 || MAGIC_IS_CLAIR()) && FLAG:察知模式 == 2 && MAP_MODE != "ODEKAKE"
	IF OUTROOF(LOCATION) && DAY:2 == 4
		SELECTCASE YOGORE:LOCATION
			CASE IS < 100
				RET_COLOR = C_GREEN
				RET_TOOLTIP += "  积雪量:干净"
			CASE IS < 500
				RET_COLOR = C_M_GREEN
				RET_TOOLTIP += "  积雪量:小"
			CASE IS < 1000
				RET_COLOR = C_P_GREEN
				RET_TOOLTIP += "  积雪量:较小"
			CASE IS < 2000
				RET_COLOR = 0xFFFFFF
				RET_TOOLTIP += "  积雪量:中"
			CASE IS < 3500
				RET_COLOR = 0xFFFFFF
				RET_TOOLTIP += "  积雪量:较大"
			CASE IS < 5000
				RET_COLOR = 0xFFFFFF
				RET_TOOLTIP += "  积雪量:大"
			CASEELSE
				RET_COLOR = 0xFFFFFF
				RET_TOOLTIP += "  积雪量:雪山"
		ENDSELECT
	ELSE
		SELECTCASE YOGORE:LOCATION
			CASE IS < 100
				RET_COLOR = C_GREEN
				RET_TOOLTIP += "  清洁度:最高"
			CASE IS < 500
				RET_COLOR = C_M_GREEN
				RET_TOOLTIP += "  清洁度:高"
			CASE IS < 1000
				RET_COLOR = C_P_GREEN
				RET_TOOLTIP += "  清洁度:较高"
			CASE IS < 2000
				RET_COLOR = C_YELLOW
				RET_TOOLTIP += "  清洁度:中"
			CASE IS < 3500
				RET_COLOR = C_V_PINK
				RET_TOOLTIP += "  清洁度:较低"
			CASE IS < 5000
				RET_COLOR = C_RED
				RET_TOOLTIP += "  清洁度:低"
			CASEELSE
				RET_COLOR = C_RED
				RET_TOOLTIP += "  清洁度:垃圾山"
		ENDSELECT
	ENDIF
ENDIF

; 3. 气息察觉判定 & Tooltip 追加
IF (TALENT:MASTER:居場所察知 || MAGIC_IS_CLAIR()) && (FLAG:察知模式 == 1 || MAP_MODE == "ODEKAKE")
	; 路人兜底颜色判定
	IF MAP_MODE != "ODEKAKE" && (ROOMDATA:(LOCATION % 100) & 場所_路人)
		RET_COLOR = C_D_PINK
	ENDIF

	; 遍历角色检查气息
	FOR CHARA, 1, CHARANUM
		KEHAI = 0
		; 若为建筑内部
		IF MAP_MODE != "ODEKAKE" && GETMAP_BUILDING(MAIN_MAP, LOCATION, LOCATION)
			FOR Q_ID, MINROOM(), MAXROOM
				IF GETMAP_BUILDING(MAIN_MAP, LOCATION, Q_ID) && CFLAG:CHARA:現在位置 == Q_ID
					KEHAI = CHECK_HEHAI(CHARA)
					BREAK
				ENDIF
			NEXT
		ELSEIF CFLAG:CHARA:現在位置 == LOCATION
			KEHAI = CHECK_HEHAI(CHARA)
		ENDIF

		; 追加 Tooltip
		IF KEHAI > 0
			SIF RET_TOOLTIP != ""
				RET_TOOLTIP += UNICODE(0x000D) ; 换行符
			RET_TOOLTIP += @"%CALLNAME:CHARA, 20, LEFT%"
			SELECTCASE KEHAI
				CASE 1
					RET_TOOLTIP += "什么都没在做"
				CASE 2
					RET_TOOLTIP += "工作中"
				CASE 3
					RET_TOOLTIP += "睡眠中"
				CASE 4
					RET_TOOLTIP += "自由行动中"
			ENDSELECT
		ENDIF
		
		; 颜色优先度：若有高级活动，颜色覆盖
		IF FLAG:察知模式 == 1 || MAP_MODE == "ODEKAKE"
			SELECTCASE KEHAI
				CASE 1
					RET_COLOR = C_H_PINK
				CASE 2
					RET_COLOR = C_D_ORANGE
				CASE 3
					RET_COLOR = C_N_BLUE
				CASE 4
					RET_COLOR = C_YELLOW
			ENDSELECT
		ENDIF
	NEXT
	
	SIF RET_TOOLTIP == NAME_FROM_PLACE(LOCATION) || RET_TOOLTIP == ""
		RET_TOOLTIP = 谁都不在
ENDIF

; 4. 特殊覆盖：当前所在位置 (MASTER 优先最高)
IF CFLAG:MASTER:現在位置 == LOCATION
	RET_COLOR = C_GREEN
ENDIF

; 5. 特殊覆盖：Map预览/夜晚睡眠/开局选房间
IF CFLAG:MASTER:睡眠 || (DAY == 1 && TIME == 0)
	SIF LOCATION == 默认初期位置 || CMATCH(CFLAG:大家候補, LOCATION, 1, CHARANUM)
		RET_COLOR = C_ORANGE
ENDIF

; 6. 特殊覆盖：外出地图且为特殊传送点(ARG >= 10的情况)
; 这里简化判定：如果名称里没有地点但是有效按钮，可能会走这里。假设正常LOCATION不会冲突。
IF MAP_MODE == "ODEKAKE" && (LOCATION % 100) >= 100
	RET_COLOR = C_P_PURPLE
ENDIF

; 通过 RESULT 和 RESULTS 返回
RESULTS '= RET_TOOLTIP
RETURN RET_COLOR

@QOL_COM400_GD
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM	DYNAMIC	INPUT_LOOP_LINE
#DIMS	DYNAMIC	UI_MESSAGE

IF GMF_GETBIT("幻想乡大地图") && GMF_METHOD_STACK != "COM400"
	SIF GMF_IS_ODEKAKE()
		CALL GMF_604_TO_400
	JUMP GMF_MAP_METHOD(-1, 0, "COM400")
ENDIF

SIF ANIMATERECOLOREDMAPS > 0 && !FLAG:70
	SETANIMETIMER 40

TOOLTIP_SETDELAY 100

LINESTART = LINECOUNT
$MAP_LOOP
CLEARLINE LINECOUNT - LINESTART
CALL COM400_DRAW_UI(0, UI_MESSAGE) 
UI_MESSAGE = 
INPUT_LOOP_LINE = LINECOUNT

$INPUT_LOOP
CLEARLINE LINECOUNT - INPUT_LOOP_LINE
INPUTS

LOCALS:0 = %RESULTS%

; 退出指令拦截
IF LOCALS:0 == "" || LOCALS:0 == "MOUSE_R" || LOCALS:0 == "ESC"
	TOOLTIP_SETDELAY 500
	RETURN -1
ENDIF

; 热键处理
SELECTCASE LOCALS:0
	CASE "Z", "z", "X", "x"
		IF TALENT:MASTER:居場所察知 && (LOCALS:0 == "Z" || LOCALS:0 == "z")
			CALL QOL_HITOSAGASI(, 1)
		ELSEIF TALENT:MASTER:汚部屋察知 && (LOCALS:0 == "X" || LOCALS:0 == "x")
			CALL OHEYA_CHECK()
		ELSE
			GOTO MAP_LOOP
		ENDIF
		IF RESULT > 0
			LOCAL:0 = RESULT
		ENDIF
		GOTO MAP_LOOP
	CASE "Y", "y"
		IF TALENT:MASTER:居場所察知 && TALENT:MASTER:汚部屋察知
			FLAG:察知模式 = (FLAG:察知模式 >= 2) ? 0 # FLAG:察知模式 + 1
		ELSEIF TALENT:MASTER:居場所察知
			FLAG:察知模式 = !FLAG:察知模式
		ELSEIF TALENT:MASTER:汚部屋察知
			FLAG:察知模式 = (!FLAG:察知模式) * 2
		ENDIF
		GOTO MAP_LOOP
	CASE "C", "c"
		FLAG:移動先表示 = (FLAG:移動先表示 >= 5) ? 0 # FLAG:移動先表示 + 1
		GOTO MAP_LOOP
ENDSELECT

; 地点跳转与系统按钮处理
IF ISNUMERIC(LOCALS:0)
	LOCAL:0 = TOINT(LOCALS:0)
ELSE
	GOTO INPUT_LOOP
ENDIF

CALL COM400_PROCESS_INPUT(1, LOCALS:0, UI_MESSAGE)

SELECTCASE RESULT
	CASE -1
		TOOLTIP_SETDELAY 500
		RETURN -1
	CASE 0
		TOOLTIP_SETDELAY 500
		RETURN 1
	CASE 1
		GOTO INPUT_LOOP
	CASE 2
		GOTO MAP_LOOP
ENDSELECT
