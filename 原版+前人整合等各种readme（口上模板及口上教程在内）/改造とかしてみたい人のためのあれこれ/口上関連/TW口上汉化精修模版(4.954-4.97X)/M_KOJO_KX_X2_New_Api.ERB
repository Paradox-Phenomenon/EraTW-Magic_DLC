;================================
;4.980新增，自定义指令覆写
;================================
;================================
;自定义指令覆写示例
;XXX为口上名，X为角色编号，Y为指令编号
;使用时请移除SKIPSTART~SKIPEND。
;================================
;-------------------------------------------------
;函数名:M_KOJO_XXX_OVERRIDE_COM_KX_Y
;概　要:指令逻辑覆写（劫持）
;参　数:无 (指令ID已体现在函数名结尾Y中)
;返回值:安全失败值 = 放弃覆写，交还给系统原版指令执行
;		  1  = 覆写执行成功 (相当于原版COM返回1)
;		  0  = 覆写执行完毕，但要求系统跳过后续的SOURCE计算 (相当于原版COM返回0)
;		 -1  = 强制中断/中止指令 (相当于原版COM返回-1)
;备　注:当你完全不满意系统的指令逻辑，想要为特定角色彻底重写某指令时使用。
;-------------------------------------------------
[SKIPSTART]
@M_KOJO_XXX_OVERRIDE_COM_KX_Y
#LOCALSIZE 1
#LOCALSSIZE 1
; 在这里写自制的 Y号 COM指令逻辑
RETURN 1

@M_KOJO_XXX_OVERRIDE_SCOM_KX_Y
#LOCALSIZE 1
#LOCALSSIZE 1
; 在这里写自制的 Y号 SCOM指令逻辑
RETURN 1 ;注意，SCOM的覆写需要返回非零才能生效

[SKIPEND]


[SKIPSTART]
; 如果想针对某类指令统一转发、覆写逻辑，可以在这里拦截
@M_KOJO_XXX_OVERRIDE_COM_KX_PRI_GENERAL(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
IF 0 == 1
	IF GROUPMATCH(ARG, 10, 11, 12)
		; 写统一的处理逻辑...
		SOURCE:服从 += 1000
		RETURN 1 ; 拦截生效
	ENDIF
ENDIF

RETURN 安全失败值 ; 未命中条件，放行给对应的单独覆写或系统原版

@M_KOJO_XXX_OVERRIDE_SCOM_KX_PRI_GENERAL(ARG)
#LOCALSIZE 1
#LOCALSSIZE 1
IF 0 == 1
	IF GROUPMATCH(ARG, 10, 11, 12)
		; 写统一的处理逻辑...
		SOURCE:服从 += 1000
		RETURN 1 ; 拦截生效
	ENDIF
ENDIF

RETURN 安全失败值 ; 未命中条件，放行给对应的单独覆写或系统原版
[SKIPEND]

