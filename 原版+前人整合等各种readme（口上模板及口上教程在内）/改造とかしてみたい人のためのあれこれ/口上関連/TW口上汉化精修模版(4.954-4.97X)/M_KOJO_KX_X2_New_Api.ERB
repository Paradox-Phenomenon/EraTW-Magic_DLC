;================================
; 4.980新增，通用拦截器，包含成否、文本、追加SOURCE三种类型的判定拦截
;================================
;================================
;自定义指令成否优先判定 (SUCCESS_PRI_GENERAL)
;XXX为口上名，X为角色编号
;使用时请移除SKIPSTART~SKIPEND。
;================================
[SKIPSTART]
;-------------------------------------------------
;函数名:M_KOJO_XXX_SUCCESS_KX_PRI_GENERAL(ARG, ARGS)
;概　要:指令成否的优先统一拦截判定
;参　数:ARG  = 指令ID (SELECTCOM 或 TFLAG:50)
;		ARGS = 指令类型 ("COM"常规指令 或 "SCOM"派生指令)
;返回值[0]:	1 = 已处理（将拦截且不再执行后续的 独立指令判定 与 兜底判定）
;			0 = 未处理（放行，继续向下执行后续的判定逻辑）
;返回值[1]:	HACK钩子，用于屏蔽并重新钩回SELECTCOM
;备　注:在独立指令判定前进行全局拦截。非常适合处理诸如“睡眠/时停等特定状态下一律大成功/大失败”、“多条同类指令共用一套成否判定逻辑”的场景。
;-------------------------------------------------
@M_KOJO_XXX_SUCCESS_KX_PRI_GENERAL(ARG, ARGS)
#LOCALSIZE 1
#LOCALSSIZE 1
SELECTCASE ARGS
	CASE "COM"
		; 示例：满足某条件，任何指令都是大失败
		IF 0 == 1
			TFLAG:192 = -1 ;强制大失败
			;返回1，告诉底层：我已经处理完毕，无需再调用独立函数
			RETURN 1
		ENDIF
		SELECTCASE ARG
			; 示例：300~312 使用同一套成否计算方式
			CASE 300 TO 312
				;假设1011号CFLAG为特定状态判定
				IF CFLAG:X:1011 == 1
					TFLAG:192 = -1 ;强制大失败
				ELSE
					TFLAG:192 = 1  ;强制大成功
				ENDIF
				RETURN 1
		ENDSELECT
	CASE "SCOM"
		SELECTCASE ARG
			CASEELSE
		ENDSELECT
ENDSELECT

;如果未触发拦截规则，返回0
;系统会继续执行对应的独立和兜底指令判定
RETURN 0
[SKIPEND]


;================================
;自定义统一文本屏蔽拦截 (MESSAGECHECK_PRI_GENERAL)
;XXX为口上名，X为角色编号
;使用时请移除SKIPSTART~SKIPEND。
;================================
[SKIPSTART]
;-------------------------------------------------
;函数名:M_KOJO_XXX_MESSAGE_MESSAGECHECK_PRI_GENERAL_KX(ARG, ARGS)
;概　要:文本显示设定的优先统一拦截判定
;参　数:ARG  = 指令ID / 派生指令ID / COUNTER指令ID (取决于ARGS)
;		ARGS = 指令类型 ("COM", "SCOM", "CUSTOM_COM", "CUSTOM_SCOM", "COUNTER")
;返回值:-1 = 拦截器未激活（放行，继续执行独立设定的 MESSAGECHECK）
;		 0 = 显示情景文本，显示口上文本（系统默认状态）
;		 1 = 屏蔽情景文本，显示口上文本（接管演出！完全替代系统文本）
;		 2 = 显示情景文本，屏蔽口上文本（通常用于无口/失神等状态）
;		 3 = 屏蔽情景文本，屏蔽口上文本（完全静音跳过）
;备　注:用于多条指令共用一套判定逻辑的情况
;-------------------------------------------------
@M_KOJO_XXX_MESSAGE_MESSAGECHECK_PRI_GENERAL_KX(ARG, ARGS)
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM  CONST 拦截器未激活 = -1 ; 由于0/1/2/3均为有意义的返回值，约定-1为拦截器未激活的安全失败值

; 示例：满足某条件，全局接管指令文本
IF 0 == 1
	; 屏蔽所有主动指令的系统自带文本，只显示剧本文本，COUNTER除外
	;IF GROUPMATCH(ARGS, "COM", "SCOM", "CUSTOM_COM", "CUSTOM_SCOM")
	;	RETURN 1
	;ENDIF
ENDIF
SELECTCASE ARGS
	CASE "COM"
		; 比如 0~30 是爱抚道具类，统一屏蔽系统文本
		;IF INRANGE(ARG, 0, 30)
		;	RETURN 1
		;ENDIF
	CASE "SCOM"
	CASE "COUNTER"
	;CASE "CUSTOM_COM"
	;CASE "CUSTOM_SCOM"		
	CASEELSE
		
ENDSELECT

;如果未触发拦截规则，务必返回 -1；系统会继续执行对应的独立和兜底指令判定
RETURN 拦截器未激活
[SKIPEND]


