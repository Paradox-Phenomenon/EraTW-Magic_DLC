;==================================================
;7,V插入同时指交
;==================================================
@M_KOJO_XXX_MESSAGE_CUSTOM_SCOM_KX_7
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC F_INDEX = -1
#DIM DYNAMIC V_INDEX = -1
#DIM DYNAMIC STATE_CHANGE ;0=继续, 1=新加入指奸, 2=新加入插入
#DIM DYNAMIC L_PARTNER
#DIM DYNAMIC TARGET_STATE ;0=插入对象(V), 1=指奸对象(F)
#DIM DYNAMIC F_TARGET
#DIM DYNAMIC V_TARGET
V_TARGET = MASTER_POSE(SET_V,SET_P,1)
F_TARGET = MASTER_POSE(SET_V,SET_YUBI,1)

FOR LOCAL, 0, ADD_SEX_MODULE_ACTION_COUNT
	IF ADD_SEX_MODULE_IS_ACTION(LOCAL, SET_YUBI, SET_V)
		F_INDEX = LOCAL
	ELSEIF ADD_SEX_MODULE_IS_ACTION(LOCAL, SET_P, SET_V)
		V_INDEX = LOCAL
	ENDIF
NEXT

IF F_INDEX < 0 || V_INDEX < 0
	RETURN 0
ENDIF

;搭档不是指令执行对象，因此一定延续上回合状态
;TARGET可能有状态变化
STATE_CHANGE = 0 ;TARGET继续状态
IF SELECTCOM == T3手指插入 && F_TARGET != TARGET && V_TARGET != TARGET
	F_TARGET = TARGET
	STATE_CHANGE = 1 ;新加入指奸
ELSEIF V_TARGET != TARGET && F_TARGET != TARGET
	V_TARGET = TARGET
	STATE_CHANGE = 2 ;新加入插入
ENDIF
IF V_TARGET == TARGET
	L_PARTNER = F_TARGET
	TARGET_STATE = 0 ;当前TARGET是被插入的对象
ELSE
	L_PARTNER = V_TARGET
	TARGET_STATE = 1 ;当前TARGET是被指奸的对象
ENDIF

IF STATE_CHANGE == 0
	IF TARGET_STATE == 0
		;PRINTFORML %CALLNAME:TARGET%继续被%CALLNAME:MASTER%深深插入着。
		RETURN 1
	ELSE
		;PRINTFORML %CALLNAME:TARGET%继续被%CALLNAME:MASTER%的手指在蜜穴中搅弄着。
		RETURN 1
	ENDIF
ELSEIF STATE_CHANGE == 1
	;PRINTFORML %CALLNAME:TARGET%被%CALLNAME:MASTER%的手指缓缓伸入，身体不由自主地颤了一下。
	RETURN 1
ELSEIF STATE_CHANGE == 2
	;PRINTFORML %CALLNAME:TARGET%将%CALLNAME:MASTER%粗硬的肉棒整个吞入湿热的蜜壶……
	RETURN 1
ENDIF

;未输入文本
RETURN 0

;搭档用文本函数，TARGET被重定向为剧本角色，请注意，此时剧本角色并不是指令的执行对象。搭档文本会在真正的执行对象调用文本后再调用。
@M_KOJO_XXX_MESSAGE_CUSTOM_SCOM_KX_7_2
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC F_INDEX = -1
#DIM DYNAMIC V_INDEX = -1
#DIM DYNAMIC STATE_CHANGE
#DIM DYNAMIC L_PARTNER
L_PARTNER = TFLAG:現在のTARGET

FOR LOCAL, 0, ADD_SEX_MODULE_ACTION_COUNT
	IF ADD_SEX_MODULE_IS_ACTION(LOCAL, SET_YUBI, SET_V)
		F_INDEX = LOCAL
	ELSEIF ADD_SEX_MODULE_IS_ACTION(LOCAL, SET_P, SET_V)
		V_INDEX = LOCAL
	ENDIF
NEXT

IF ADD_SEX_MODULE_CHARA:V_INDEX == L_PARTNER
	;PRINTFORML %CALLNAME:TARGET%继续被%CALLNAME:MASTER%深深插入着。
	RETURN 1
ELSE
	;PRINTFORML %CALLNAME:TARGET%继续被%CALLNAME:MASTER%的手指在蜜穴中搅弄着。
	RETURN 1
ENDIF

;特殊的联动文本（可自行扩展）
IF L_PARTNER == 某角色
	;PRINTFORML 「……我们一个被手指、一个被肉棒……好害羞啊……」
	RETURN 1
ENDIF

;未输入文本
RETURN 0

;==================================================
;8,V插入并指交两人
;==================================================
@M_KOJO_XXX_MESSAGE_CUSTOM_SCOM_KX_8
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC F1_INDEX = -1
#DIM DYNAMIC F2_INDEX = -1
#DIM DYNAMIC V_INDEX = -1
#DIM DYNAMIC STATE_CHANGE ;0=继续, 1=新加入指奸, 2=新加入插入
#DIM DYNAMIC L_PARTNER
#DIM DYNAMIC TARGET_STATE ;0=插入对象, 1=指奸对象
#DIM DYNAMIC F_TARGET
#DIM DYNAMIC V_TARGET

V_TARGET = MASTER_POSE(SET_V,SET_P,1)
F_TARGET = MASTER_POSE(SET_V,SET_YUBI,1)

FOR LOCAL, 0, ADD_SEX_MODULE_ACTION_COUNT
	IF ADD_SEX_MODULE_IS_ACTION(LOCAL, SET_YUBI, SET_V)
		IF F1_INDEX == -1
			F1_INDEX = LOCAL
		ELSE
			F2_INDEX = LOCAL
		ENDIF
	ELSEIF ADD_SEX_MODULE_IS_ACTION(LOCAL, SET_P, SET_V)
		V_INDEX = LOCAL
	ENDIF
NEXT

IF F1_INDEX < 0 || F2_INDEX < 0 || V_INDEX < 0
	RETURN 0
ENDIF

;搭档不是指令执行对象，因此一定延续上回合状态
;TARGET可能有状态变化
STATE_CHANGE = 0 ;TARGET继续状态
IF SELECTCOM == 3 && (ADD_SEX_MODULE_CHARA:F1_INDEX == TARGET || ADD_SEX_MODULE_CHARA:F2_INDEX == TARGET)
	&& V_TARGET != TARGET && F_TARGET != TARGET
	STATE_CHANGE = 1 ;新加入指奸
ELSEIF GROUPMATCH(SELECTCOM,60,61,65,67,68) && V_TARGET != TARGET && F_TARGET != TARGET
	V_TARGET = TARGET
	STATE_CHANGE = 2 ;新加入插入
ENDIF
IF V_TARGET == TARGET
	L_PARTNER = (ADD_SEX_MODULE_CHARA:F1_INDEX == TARGET ? ADD_SEX_MODULE_CHARA:F2_INDEX : ADD_SEX_MODULE_CHARA:F1_INDEX)
	TARGET_STATE = 0 ;当前TARGET是被插入的对象
ELSE
	L_PARTNER = ADD_SEX_MODULE_CHARA:V_INDEX
	TARGET_STATE = 1 ;当前TARGET是被指奸的对象
ENDIF

IF STATE_CHANGE == 0
	IF TARGET_STATE == 0
		;PRINTFORML %CALLNAME:TARGET%继续被%CALLNAME:MASTER%深深插入着。
		RETURN 1
	ELSE
		;PRINTFORML %CALLNAME:TARGET%继续被%CALLNAME:MASTER%的手指玩弄着。
		RETURN 1
	ENDIF
ELSEIF STATE_CHANGE == 1
	;PRINTFORML %CALLNAME:TARGET%被%CALLNAME:MASTER%的手指突然伸入，忍不住发出一声娇喘。
	RETURN 1
ELSEIF STATE_CHANGE == 2
	;PRINTFORML %CALLNAME:TARGET%将%CALLNAME:MASTER%火热的肉棒吞入体内……
	RETURN 1
ENDIF

;未输入文本
RETURN 0

;搭档用文本函数，TARGET被重定向为剧本角色，请注意，此时剧本角色并不是指令的执行对象。搭档文本会在真正的执行对象调用文本后再调用。
@M_KOJO_XXX_MESSAGE_CUSTOM_SCOM_KX_8_2
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC F1_INDEX = -1
#DIM DYNAMIC F2_INDEX = -1
#DIM DYNAMIC V_INDEX = -1
#DIM DYNAMIC STATE_CHANGE
;ADD_SEX_MODULE_CHARA 0~2分别对应三人，用IDX检出
FOR LOCAL, 0, ADD_SEX_MODULE_ACTION_COUNT
	IF ADD_SEX_MODULE_IS_ACTION(LOCAL, SET_YUBI, SET_V)
		IF F1_INDEX == -1
			F1_INDEX = LOCAL
		ELSE
			F2_INDEX = LOCAL
		ENDIF
	ELSEIF ADD_SEX_MODULE_IS_ACTION(LOCAL, SET_P, SET_V)
		V_INDEX = LOCAL
	ENDIF
NEXT

IF ADD_SEX_MODULE_CHARA:V_INDEX == TARGET
	;PRINTFORML %CALLNAME:TARGET%继续被%CALLNAME:MASTER%深深插入着。
	RETURN 1
ELSE
	;PRINTFORML %CALLNAME:TARGET%继续被%CALLNAME:MASTER%的手指玩弄着。
	RETURN 1
ENDIF

;特殊的联动文本（可自行扩展）
IF 0
	;PRINTFORML 「我们三个人……同时被MASTER这样……啊……」
	RETURN 1
ENDIF

;未输入文本
RETURN 0

