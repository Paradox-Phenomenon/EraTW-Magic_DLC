;==================================================
;5,双女上位
;==================================================
@M_KOJO_XXX_MESSAGE_CUSTOM_SCOM_KX_5
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC C_TARGET
#DIM DYNAMIC V_TARGET
#DIM DYNAMIC STATE_CHANGE ;0=继续, 1=新加入女上位, 2=新加入被舔阴
#DIM DYNAMIC L_PARTNER
#DIM DYNAMIC TARGET_STATE ;0=V_TARGET, 1=C_TARGET

V_TARGET = MASTER_POSE(SET_V,SET_P,1)
C_TARGET = MASTER_POSE(SET_C,SET_M,1)

;TARGET的状态变化
STATE_CHANGE = 0 ;TARGET与上个回合相比状态没有变化
IF SELECTCOM == 65 && C_TARGET != TARGET && V_TARGET != TARGET
	V_TARGET = TARGET
	STATE_CHANGE = 1 ;TARGET是新加入的女上位对象
ELSEIF SELECTCOM == 1 && V_TARGET != TARGET && C_TARGET != TARGET
	C_TARGET = TARGET
	STATE_CHANGE = 2 ;TARGET是新加入的被舔阴对象
ENDIF
IF V_TARGET == TARGET
	L_PARTNER = C_TARGET
	TARGET_STATE = 0 ;TARGET是女上位对象
ELSE
	L_PARTNER = V_TARGET
	TARGET_STATE = 1 ;TARGET是被舔阴对象
ENDIF

IF STATE_CHANGE == 0
	IF TARGET_STATE = 0
		;PRINTFORML %CALLNAME:TARGET%继续女上位
		RETURN 1
	ELSEIF TARGET_STATE = 1
		;PRINTFORML %CALLNAME:TARGET%继续骑在%CALLNAME:MASTER%脸上
		RETURN 1
	ENDIF
ELSEIF STATE_CHANGE == 1
	;PRINTFORML %CALLNAME:TARGET%将肉棒吞入蜜壶
	RETURN 1
ELSEIF STATE_CHANGE == 2
	;PRINTFORML %CALLNAME:TARGET%骑在%CALLNAME:MASTER%脸上
	RETURN 1
ENDIF

;未输入文本
RETURN 0

;搭档用文本函数，TARGET被重定向为剧本角色，但并不是指令的执行对象。但注意，会在真正的执行对象调用文本后再调用。
@M_KOJO_XXX_MESSAGE_CUSTOM_SCOM_KX_5_2
#LOCALSIZE 1
#LOCALSSIZE 1
#DIM DYNAMIC C_TARGET
#DIM DYNAMIC V_TARGET
#DIM DYNAMIC STATE_CHANGE ;0=继续, 1=新加入女上位, 2=新加入被舔阴
#DIM DYNAMIC L_PARTNER
L_PARTNER = TFLAG:現在のTARGET
V_TARGET = MASTER_POSE(SET_V,SET_P,1)
C_TARGET = MASTER_POSE(SET_C,SET_M,1)

;剧本主人公不是指令执行对象，因此一定是延续上回合状态的人
;可能状态变化是搭档角色
STATE_CHANGE = 0 ;搭档与上个回合相比状态没有变化
IF SELECTCOM == 65 && C_TARGET != L_PARTNER && V_TARGET != L_PARTNER
	V_TARGET = L_PARTNER
	STATE_CHANGE = 1 ;搭档是新加入的女上位对象
ELSEIF SELECTCOM == 1 && V_TARGET != L_PARTNER && C_TARGET != L_PARTNER
	C_TARGET = L_PARTNER
	STATE_CHANGE = 2 ;搭档是新加入的被舔阴对象
ENDIF
IF V_TARGET == L_PARTNER
	L_PARTNER = C_TARGET
ELSE
	L_PARTNER = V_TARGET
ENDIF

IF TARGET_STATE = 0
	;PRINTFORML %CALLNAME:TARGET%继续女上位
	RETURN 1
ELSEIF TARGET_STATE = 1
	;PRINTFORML %CALLNAME:TARGET%继续骑在%CALLNAME:MASTER%脸上
	RETURN 1
ENDIF

;特殊的联动文本
IF L_PARTNER == 某角色
	;PRINTFORML 「文本1」
	RETURN 1
ENDIF

;未输入文本
RETURN 0

