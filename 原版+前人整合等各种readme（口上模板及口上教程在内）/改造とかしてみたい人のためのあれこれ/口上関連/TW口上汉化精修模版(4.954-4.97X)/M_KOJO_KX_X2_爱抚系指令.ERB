#LOCALSSIZE 1
IF 0
	PRINTFORMW 
	;分支有文本，返回1
	RETURN 1
ENDIF
;没有进入任何有文本的分枝提前返回，剧本侧没有输出任何内容，因此返回0
RETURN 0

