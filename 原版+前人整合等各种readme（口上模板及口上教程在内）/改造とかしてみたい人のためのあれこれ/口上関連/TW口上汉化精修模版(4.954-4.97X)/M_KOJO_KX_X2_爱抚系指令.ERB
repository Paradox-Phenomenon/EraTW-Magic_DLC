	;恋慕
	IF TALENT:恋慕
		PRINTFORMW 
		RETURN 1
	;屈服3
	ELSEIF MARK:不埒刻印 == 3
		PRINTFORMW 
		RETURN 1
	;思慕
	ELSEIF TALENT:思慕
		PRINTFORMW 
		RETURN 1
	;其他
	ELSE
		PRINTFORMW 
		RETURN 1
	ENDIF
ENDIF

RETURN 0

