;9100，摄影
;TFLAG:193(1=大成功 0=成功 -1=失败 -2=放弃拍摄)
;可参考地文：ERB\fromEN\Custom_Commands\ADD_CUSTOM_COM100 摄影.ERB
;CHECK_PHOTO记录了拍摄相片的信息（如果拍下了的话）
;CHECK_PHOTO:0 地点 （如"秋姉妹的家・寝室"）
;CHECK_PHOTO:1 日期 （如"第1年 秋之月第1日"）
;CHECK_PHOTO:2 时间 （如"8时00分"）
;CHECK_PHOTO:3 品质 （0~6）
;CHECK_PHOTO:4 角色（集合）（如"顔絵_服_通常_80◇顔絵_照れ_80◇/"或者"顔絵_裸_通常_52◇顔絵_照れ_52◇顔絵_吐息_52◇/"或者"0/"或者""）
;CHECK_PHOTO:5 基本描述（目前为空）
;如果想基于角色对相片信息的某一部分做出的反应写差分的话，就请多加使用STRFIND函数（或者STRCOUNT）
;例如STRFIND(CHECK_PHOTO:4, @"_{TARGET}◇")，意思就是检测相片中是否有TARGET这个角色，有的话会返回一个大于-1的值，否则返回-1
;以下为使用STRCOUNT检测拍摄状态的部分例子：
;STRCOUNT(CHECK_PHOTO:4, "◇")，检测是否拍角色
;STRCOUNT(CHECK_PHOTO:4, @"_{TARGET}◇") == STRCOUNT(CHECK_PHOTO:4, @"◇") && STRCOUNT(CHECK_PHOTO:4, @"◇")，检测是否只拍TARGET
;具体的使用例子还请翻看查看相册的地文
;==================================================
@M_KOJO_XXX_SUCCESS_CUSTOM_COM_KX_100
;成否判定
;TFLAG:192（-1＝强制失败、0=根据COM文件决定、1=强制成功or大成功）
TFLAG:192 = 0
;==================================================
;可选项：关于地文描述的显示设置
;如果返回0，则地文与口上都会显示；如果返回1，则地文会隐藏，口上会显示；如果返回2，则地文会显示，口上会隐藏；如果返回3则均会被隐藏
;==================================================
@M_KOJO_XXX_MESSAGE_MESSAGECHECK_CUSTOM_COM_KX_100
RETURN 0

@M_KOJO_XXX_MESSAGE_CUSTOM_COM_KX_100

