;==================================================
;9011，换衣服
;TFLAG:194(具体看下面的注释)
;地文位置：ERB\fromEN\Custom_Commands\Add_CUSTOM_COM11 换衣服.ERB
;顺带一提地文里并没有涉及具体操作...所以在这一点上可以稍微奔放些？（比如自己上手之类的）
;==================================================
@M_KOJO_XXX_MESSAGE_CUSTOM_COM_KX_11
SELECTCASE TFLAG:194
	CASE 1
	;让角色换身干衣服（仅角色卧室，全阶段）
	CASE 2
	;让角色换上浴袍
		IF CFLAG:MASTER:300 == CFLAG:MASTER:311
		;你先生卧室（全阶段）
		ELSE
		;情色旅店（仅思慕及以下）
		ENDIF
	CASE 3
	;让角色换上内衣（仅角色卧室，仅恋慕及以上）
	CASE 4
	;让角色换上裸体衬衫（仅你先生卧室，仅恋慕及以上）
	CASE 5
	;让角色全裸
		IF CFLAG:MASTER:300 == CFLAG:MASTER:311 || CFLAG:MASTER:300 == CFLAG:TARGET:311
		;你先生/角色卧室（仅恋人）
		ELSE
		;情色旅店（仅恋慕及以上）
		ENDIF        
ENDSELECT
;未返回文本
RETURN 0

