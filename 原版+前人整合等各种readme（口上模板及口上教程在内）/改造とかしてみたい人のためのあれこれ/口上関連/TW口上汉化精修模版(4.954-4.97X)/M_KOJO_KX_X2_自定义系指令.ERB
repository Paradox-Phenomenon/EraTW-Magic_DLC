;STRCOUNT(CHECK_PHOTO:4, "◇")，检测是否包含除自机外的角色
;STRCOUNT(CHECK_PHOTO:4, @"_{TARGET}◇")，检测是否包含TARGET
;STRCOUNT(CHECK_PHOTO:4, @"_{TARGET}◇") == STRCOUNT(CHECK_PHOTO:4, @"◇") && STRCOUNT(CHECK_PHOTO:4, @"◇")，检测是否只拍到了TARGET
;STRFIND(CHECK_PHOTO:4, @"裸_{TARGET}◇") != -1，检测TARGET是否裸体（只看上半身）
;STRFIND(CHECK_PHOTO:4, "発情_{TARGET}◇") != -1，检测TARGET是否发情（STRFIND(CHECK_PHOTO:4, "発情") != -1，检测是否有角色发情，注意区分）
;STRFIND(CHECK_PHOTO:4, "性交_{TARGET}◇") != -1，检测TARGET是否正在诶嘿嘿
;STRFIND(CHECK_PHOTO:4, "自慰_{TARGET}◇") != -1，检测TARGET是否正在自慰
;STRFIND(CHECK_PHOTO:4, "愛撫_{TARGET}◇") != -1，检测TARGET是否正在被爱抚
;STRFIND(CHECK_PHOTO:4, "イキ顔_{TARGET}◇") != -1，检测TARGET是否高潮
;STRFIND(CHECK_PHOTO:4, "通常_{TARGET}◇") != -1，检测TARGET是否处于通常状态
;STRFIND(CHECK_PHOTO:4, "笑顔_{TARGET}◇") != -1，检测TARGET是否露出笑颜
;TRFIND(CHECK_PHOTO:4, "憤怒_{TARGET}◇") != -1，检测TARGET是否生气
;STRFIND(CHECK_PHOTO:4, "睡眠_{TARGET}◇") != -1，检测TARGET是否在睡觉
;STRFIND(CHECK_PHOTO:4, "照れ_{TARGET}◇") != -1，检测TARGET是否脸红
;STRFIND(CHECK_PHOTO:4, "吐息_{TARGET}◇") != -1，检测TARGET是否发出吐息
;STRFIND(CHECK_PHOTO:4, "汗_{TARGET}◇") != -1，检测TARGET是否出汗
;具体的使用例子还请翻看地文
